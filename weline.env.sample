# install 命令使用的环境配置（复制为 weline.env 后按需修改）
# 用于 bin/install.sh / bin/install.bat 安装 php、pgsql、mysql 等到 extend/server/

# PHP 主版本（未配置时从 composer.json require.php 解析，如 ^8.4 -> 8.4）
# INSTALL_PHP_VERSION=8.4

# PostgreSQL 主版本，缺省 16（当前稳定版）
INSTALL_PGSQL_VERSION=16

# MySQL 主版本，缺省 8.0
INSTALL_MYSQL_VERSION=8.0

# 无参数时默认安装的组件，逗号分隔（可选，缺省为 php 和 pgsql）
# INSTALL_DEFAULT=php,pgsql

# 安装时从 php.ini disable_functions 中移除的函数（逗号分隔），保证 Composer/WLS/进程等可用
# 常见：exec, putenv, proc_open, proc_get_status, shell_exec, passthru, system, popen, pcntl_fork, pcntl_signal
# PHP_FUNCTIONS=exec,putenv,proc_open,proc_get_status,shell_exec,passthru,system,popen,pcntl_fork,pcntl_signal

# PostgreSQL 数据目录（推荐 extend，var 易被删除）。Linux install.sh / Windows run.php 会自动 init 并启动
# PGSQL_DATA_DIR=extend/server/pgsql/data

# PostgreSQL：写入 app/etc/env.php 的 db，及建库时由超管创建的应用账户
# DB_PORT 可不配置；项目内 PostgreSQL 初始化/启动时会在 5432 被占用时自动选择 5433+，
# 并把最终端口写回 weline.env，避免多个本地项目抢同一个端口。
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=weline
# DB_USERNAME=weline
# DB_PASSWORD=weline
# 建库时使用的超管（默认 postgres）。未配置 PGSQL_INIT_PASSWORD 时会依次尝试空密码、postgres、weline
# 若配置了 PGSQL_INIT_PASSWORD，则初始化 PostgreSQL 实例（如设置 postgres 密码）时须使用相同信息
# PGSQL_INIT_USER=postgres
# PGSQL_INIT_PASSWORD=your_postgres_superuser_password

# OpenSearch：Search 模块默认搜索引擎版本（Windows/Linux 自动下载官方发行包）
# INSTALL_OPENSEARCH_VERSION=3.5.0

# Search 模块默认搜索引擎与默认作用域
# SEARCH_DEFAULT_ENGINE=opensearch
# SEARCH_DEFAULT_SCOPE=default

# OpenSearch 安装位置（相对项目根目录）
# SEARCH_OPENSEARCH_INSTALL_DIR=extend/server/opensearch
# SEARCH_OPENSEARCH_DATA_DIR=D:/WelineRuntime/opensearch-data
# SEARCH_OPENSEARCH_LOG_DIR=D:/WelineRuntime/opensearch-logs
# 也支持绝对路径，例如 Windows 可写到其他盘：
# 安装目录建议保持在项目内，其他磁盘主要用于 data/log/tmp

# OpenSearch 下载 / 解压临时目录，默认使用系统临时目录下的 weline-opensearch
# 当项目盘空间不足时，建议显式指向其他磁盘
# SEARCH_OPENSEARCH_TMP_DIR=D:/WelineRuntime/opensearch-tmp
# SEARCH_OPENSEARCH_DOWNLOAD_DIR=D:/WelineRuntime/opensearch-tmp/downloads
# SEARCH_OPENSEARCH_EXTRACT_DIR=D:/WelineRuntime/opensearch-tmp/extract

# OpenSearch 连接配置：安装完成后会写入 app/etc/env.php -> search.engines.opensearch
# SEARCH_OPENSEARCH_HOST=http://127.0.0.1
# SEARCH_OPENSEARCH_PORT=9200
# SEARCH_OPENSEARCH_INDEX=products
# SEARCH_OPENSEARCH_TIMEOUT=5
# SEARCH_OPENSEARCH_USERNAME=
# SEARCH_OPENSEARCH_PASSWORD=

# OpenSearch 单节点配置参数（写入 extend/server/opensearch/config/opensearch.yml）
# SEARCH_OPENSEARCH_CLUSTER_NAME=weline-search
# SEARCH_OPENSEARCH_NODE_NAME=weline-search-node
# SEARCH_OPENSEARCH_BIND_HOST=127.0.0.1

# 可选：自定义 OpenSearch 安装配置文件路径
# SEARCH_OPENSEARCH_CONFIG_FILE=extend/server/opensearch/config/opensearch.yml

# 可选：当当前环境没有默认官方发行包时（例如特定平台），可指定自定义下载地址
# SEARCH_OPENSEARCH_DOWNLOAD_URL=

# WLS shared state lifecycle defaults
# WLS_SHARED_STATE_IDLE_SHUTDOWN_GRACE_SEC=30
# WLS_SHARED_STATE_EPHEMERAL_CONSUMER_TTL_SEC=120
