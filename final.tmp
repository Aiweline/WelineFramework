    <style>
        #le-hero-6a0ca2858c61c {
            background: linear-gradient(135deg, #1a0a2e 0%, #0d0020 50%, #090012 100%);
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        #le-hero-6a0ca2858c61c::before {
            content: '';
            position: absolute;
            top: -20%;
            left: -10%;
            width: 60%;
            height: 60%;
            background: radial-gradient(ellipse, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
            pointer-events: none;
        }
        
        #le-hero-6a0ca2858c61c::after {
            content: '';
            position: absolute;
            bottom: -20%;
            right: -10%;
            width: 50%;
            height: 50%;
            background: radial-gradient(ellipse, rgba(236, 72, 153, 0.12) 0%, transparent 70%);
            pointer-events: none;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-main {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            margin-bottom: 60px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-content {
            max-width: 600px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 700;
            color: #a78bfa;
            margin-bottom: 28px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-title {
            font-size: 3.5rem;
            font-weight: 900;
            line-height: 1.1;
            color: #f5f3ff;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-title span {
            background: linear-gradient(135deg, #8b5cf6, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-description {
            font-size: 1.2rem;
            line-height: 1.7;
            color: #c4b5fd;
            margin-bottom: 36px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-cta {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 36px;
            background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
            color: #ffffff;
            font-size: 1.05rem;
            font-weight: 700;
            border-radius: 14px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 24px rgba(139, 92, 246, 0.4);
            text-decoration: none;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(139, 92, 246, 0.5);
        }
        
        #le-hero-6a0ca2858c61c .le-hero-btn-primary svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 36px;
            background: transparent;
            color: #a78bfa;
            font-size: 1.05rem;
            font-weight: 700;
            border: 2px solid rgba(139, 92, 246, 0.5);
            border-radius: 14px;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-btn-secondary:hover {
            background: rgba(139, 92, 246, 0.1);
            border-color: #ec4899;
            color: #ec4899;
        }
        
        /* Decorative dice visual */
        #le-hero-6a0ca2858c61c .le-hero-visual {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-dice-board {
            width: 100%;
            max-width: 460px;
            aspect-ratio: 1;
            position: relative;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-board-bg {
            width: 100%;
            height: 100%;
            background: linear-gradient(145deg, rgba(139, 92, 246, 0.12) 0%, rgba(236, 72, 153, 0.08) 100%);
            border-radius: 32px;
            border: 2px solid rgba(139, 92, 246, 0.2);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-board-bg::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: conic-gradient(from 0deg, transparent, rgba(139, 92, 246, 0.2), transparent, rgba(236, 72, 153, 0.15), transparent);
            animation: le-board-rotate 25s linear infinite;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-board-inner {
            position: relative;
            z-index: 1;
            width: 85%;
            height: 85%;
            background: rgba(9, 0, 18, 0.9);
            border-radius: 24px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            padding: 24px;
            align-content: center;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-dice {
            width: 100%;
            aspect-ratio: 1;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            animation: leFloat 3s ease-in-out infinite;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-dice:nth-child(1) { background: rgba(139, 92, 246, 0.2); border: 1px solid rgba(139, 92, 246, 0.3); animation-delay: 0s; }
        #le-hero-6a0ca2858c61c .le-hero-dice:nth-child(2) { background: rgba(236, 72, 153, 0.2); border: 1px solid rgba(236, 72, 153, 0.3); animation-delay: 0.5s; }
        #le-hero-6a0ca2858c61c .le-hero-dice:nth-child(3) { background: rgba(6, 182, 212, 0.2); border: 1px solid rgba(6, 182, 212, 0.3); animation-delay: 1s; }
        #le-hero-6a0ca2858c61c .le-hero-dice:nth-child(4) { background: rgba(245, 158, 11, 0.2); border: 1px solid rgba(245, 158, 11, 0.3); animation-delay: 1.5s; }
        
        @keyframes le-board-rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        @keyframes leFloat {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-8px); }
        }
        
        /* Stats */
        #le-hero-6a0ca2858c61c .le-hero-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-stat {
            padding: 24px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(139, 92, 246, 0.12);
            border-radius: 16px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-stat:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(236, 72, 153, 0.3);
            transform: translateY(-4px);
        }
        
        #le-hero-6a0ca2858c61c .le-hero-stat-value {
            font-size: 2rem;
            font-weight: 900;
            background: linear-gradient(135deg, #8b5cf6, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 4px;
        }
        
        #le-hero-6a0ca2858c61c .le-hero-stat-label {
            font-size: 0.9rem;
            color: #c4b5fd;
            font-weight: 600;
        }
        
        @media (max-width: 992px) {
            #le-hero-6a0ca2858c61c .le-hero-main {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            
            #le-hero-6a0ca2858c61c .le-hero-content {
                max-width: 100%;
                text-align: center;
            }
            
            #le-hero-6a0ca2858c61c .le-hero-badge {
                margin-left: auto;
                margin-right: auto;
            }
            
            #le-hero-6a0ca2858c61c .le-hero-cta {
                justify-content: center;
            }
            
            #le-hero-6a0ca2858c61c .le-hero-title {
                font-size: 2.5rem;
            }
            
            #le-hero-6a0ca2858c61c .le-hero-visual {
