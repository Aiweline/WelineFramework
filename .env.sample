# Git 部署配置示例文件
#
# 复制此文件为项目根目录的 .env 文件并根据实际情况修改配置
# 此文件用于配置 Git 拉取和部署相关参数

# Git 仓库配置
GIT_REPO_URL=https://github.com/username/repository.git
GIT_BRANCH=main
GIT_USERNAME=your_username
GIT_TOKEN=your_access_token_or_password

# 部署配置
# DEPLOY_DIR 自动使用 .env 文件所在目录，无需配置
BACKUP_BEFORE_DEPLOY=true
CLEAN_BEFORE_DEPLOY=false

# Git 高级配置（可选）
# GIT_REMOTE_NAME=origin
# GIT_PULL_STRATEGY=merge
# GIT_CREDENTIAL_HELPER=cache