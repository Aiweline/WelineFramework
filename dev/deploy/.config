# WelineFramework deploy webhook config.
# 这是可提交的占位配置。真实服务器密钥请在部署环境中改写，不要提交真实 token。
# 完整说明见 dev/deploy/.config.exsample。

DEPLOY_ROOT=''

GIT_REMOTE='origin'
GIT_REMOTE_URL=''
GIT_BRANCH=''
GIT_UPDATE_MODE='reset'
DEPLOY_FORCE_RESET='0'
DEPLOY_SWITCH_BRANCH='0'
GIT_SUBMODULE_UPDATE='0'

RUN_COMPOSER_INSTALL='0'
COMPOSER_COMMAND='composer install --no-dev --prefer-dist --optimize-autoloader'
POST_DEPLOY_COMMAND=''

LOCK_FILE=''
LOG_FILE=''

WEBHOOK_HOST='127.0.0.1'
WEBHOOK_PORT='9097'
WEBHOOK_PATH='/deploy'
WEBHOOK_SECRET=''
WEBHOOK_BRANCH=''
WEBHOOK_BASH='bash'

CLOUDFLARE_ENABLED='0'
CLOUDFLARE_API_TOKEN=''
CLOUDFLARE_ZONE_ID=''
