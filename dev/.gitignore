*
!.gitkeep
!.gitignore
!.temp
# 忽略 dev 目录下的所有内容
*

# 但保留以下文件和目录
!.gitkeep
!.gitignore
!.temp

# 保留 ai 目录及其所有内容（必须按顺序）
!ai/
!ai/**

# 保留部署 webhook 脚本与示例配置
!deploy/
!deploy/**

!docker/
!docker/**

# 保留分项口令脚本
!tools/
!tools/fenxiang/
!tools/fenxiang/**

# 保留分仓口令脚本；日志与运行输出不入库
!tools/fencang/
!tools/fencang/*.ps1
tools/fencang/*.log
tools/fencang/*.tmp
tools/fencang/*.local.json

# 但排除 codex tasks 全目录（本地任务日志不入库）
ai/codex/tasks/

# Codex 任务过程产物保留在本地
ai/codex/tasks/**/artifacts/*
