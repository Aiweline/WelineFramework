{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learning-mcp.local/schemas/experience.v1.json",
  "title": "Learning MCP Experience v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["experience_id", "project_id", "schema_version", "version", "fingerprint", "title", "category", "problem_pattern", "correct_approach", "reusable_rule", "wrong_approaches", "corrections", "verification", "scope", "exceptions", "confidence", "confidence_breakdown", "status", "source_session_count", "first_seen_at", "last_seen_at", "created_at", "updated_at"],
  "properties": {
    "experience_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "schema_version": {"const": "experience.v1"},
    "version": {"type": "integer", "minimum": 1},
    "fingerprint": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "category": {"type": "string"},
    "problem_pattern": {"type": "string", "minLength": 1},
    "trigger": {"type": "string"},
    "root_cause": {"type": "string"},
    "correct_approach": {"type": "string", "minLength": 1},
    "reusable_rule": {"type": "string", "minLength": 1},
    "wrong_approaches": {"type": "array", "items": {"type": "object"}},
    "corrections": {"type": "array", "items": {"type": "object"}},
    "verification": {"type": "array", "items": {"type": "object"}},
    "scope": {"type": "object"},
    "exceptions": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence_breakdown": {"type": "object"},
    "status": {"type": "string"},
    "source_session_count": {"type": "integer", "minimum": 0},
    "source_session_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "first_seen_at": {"type": "string", "format": "date-time"},
    "last_seen_at": {"type": "string", "format": "date-time"},
    "valid_until": {"type": ["string", "null"], "format": "date-time"},
    "supersedes_id": {"type": "string"},
    "metadata": {"type": "object"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
