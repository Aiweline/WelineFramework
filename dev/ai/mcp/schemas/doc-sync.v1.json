{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weline.local/schemas/doc-sync.v1.json",
  "title": "Read-only Codex module documentation synchronization plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "summary", "operations", "rationale", "validation_profile"],
  "properties": {
    "schema_version": {
      "const": "doc-sync.v1"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "operations": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/replaceDocumentSection"},
          {"$ref": "#/$defs/createFile"}
        ]
      }
    },
    "rationale": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2000
      }
    },
    "validation_profile": {
      "const": "weline.php.module"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner", "mode", "redactions", "duration_ms"],
      "properties": {
        "planner": {"const": "codex"},
        "mode": {"const": "ephemeral-read-only"},
        "redactions": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0}
      }
    }
  },
  "$defs": {
    "docPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^app/code/[^/]+/[^/]+/doc(?:/|$)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "hash": {
      "type": "string",
      "pattern": "^(?:sha256:)?[A-Fa-f0-9]{64}$"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    },
    "replaceDocumentSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "heading",
        "replacement",
        "expected_file_sha256",
        "expected_digest",
        "source_refs"
      ],
      "properties": {
        "kind": {"const": "replace_document_section"},
        "path": {"$ref": "#/$defs/docPath"},
        "heading": {"type": "string", "minLength": 1, "maxLength": 512},
        "replacement": {"type": "string", "maxLength": 16777216},
        "expected_file_sha256": {"$ref": "#/$defs/hash"},
        "expected_digest": {"$ref": "#/$defs/hash"},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "createFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "content", "source_refs"],
      "properties": {
        "kind": {"const": "create_file"},
        "path": {"$ref": "#/$defs/docPath"},
        "content": {"type": "string", "maxLength": 16777216},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    }
  }
}
