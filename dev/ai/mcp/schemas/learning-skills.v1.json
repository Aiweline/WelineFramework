{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weline validated learning skill classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skills"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "learning-skills.v1"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "name",
          "description",
          "triggers",
          "knowledge_types",
          "surfaces",
          "experience_ids"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,47}$"
          },
          "name": {
            "type": "string",
            "minLength": 4,
            "maxLength": 64
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "pattern": "^[^\\r\\n]+$"
          },
          "triggers": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 120,
              "pattern": "^[^\\r\\n]+$"
            }
          },
          "knowledge_types": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "string",
              "enum": ["skill_knowledge", "operational_observation"]
            }
          },
          "surfaces": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120,
              "pattern": "^[^\\r\\n]+$"
            }
          },
          "experience_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": {
              "type": "string",
              "pattern": "^exp-[A-Za-z0-9._:-]+$"
            }
          }
        }
      }
    }
  }
}
