{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 716800
  },
  "output": {
    "style": "markdown",
    "filePath": ".codex/code-intelligence/repomix-output.md",
    "fileSummary": true,
    "directoryStructure": true,
    "compress": true,
    "topFilesLength": 20,
    "truncateBase64": true,
    "git": {
      "sortByChanges": true,
      "includeDiffs": false,
      "includeLogs": false
    }
  },
  "include": [
    "AGENTS.md",
    "AI-ENTRY.md",
    "AI-README.md",
    "CLAUDE.md",
    "composer.json",
    "app/bootstrap.php",
    "app/autoload.php",
    "bin/w",
    "app/code/**/*.php",
    "app/code/**/*.phtml",
    "app/code/**/*.xml",
    "app/code/**/*.json",
    "app/code/**/*.js",
    "app/code/**/*.css",
    "app/design/**/*.php",
    "app/design/**/*.phtml",
    "app/design/**/*.xml",
    "app/design/**/*.json",
    "app/design/**/*.js",
    "app/design/**/*.css",
    "tests/**/*.php",
    "tests/**/*.js",
    "dev/ai/global-constraints.md",
    "dev/ai/PROJECT_QUALITY_SYSTEM.md",
    "dev/ai/diagrams/**/*.txt",
    "dev/ai/skills/_index.md",
    "dev/ai/skills/**/*.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".codex/code-intelligence/**",
      ".codex/skills/**",
      "generated/**",
      "var/**",
      "tests/var/**",
      "pub/static/**",
      "pub/media/**",
      "dev/ai/archive/**",
      "dev/ai/code_backup/**",
      "dev/ai/codex/tasks/**",
      "dev/ai/codex/plugins/**",
      "dev/ai/codex/automations/**",
      "vendor/**",
      "node_modules/**",
      "app/code/**/i18n/*.csv",
      "app/code/**/doc/**",
      "app/code/**/docs/**",
      "app/code/**/view/statics/**/assets/libs/**",
      "app/code/**/view/statics/**/assets/vendor/**",
      "app/code/**/view/statics/**/assets/**",
      "app/code/**/view/statics/**/lib/**",
      "app/code/**/view/statics/**/libs/**",
      "app/code/**/view/statics/**/vendor/**",
      "app/code/**/view/statics/**/build/**",
      "app/design/**/assets/**",
      "app/code/**/view/statics/**/*.map",
      "app/code/**/view/statics/**/*.min.js",
      "app/code/**/view/statics/**/*.min.css",
      "app/code/**/view/statics/**/*bundle*.js",
      "app/code/**/view/statics/**/*bundle*.css",
      "app/code/**/view/statics/**/ckeditor.js",
      "app/code/**/view/statics/**/ckeditor.js.map",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.svg",
      "**/*.ico",
      "**/*.webp",
      "**/*.mp4",
      "**/*.mp3",
      "**/*.woff",
      "**/*.woff2",
      "**/*.ttf",
      "**/*.eot",
      "**/*.zip",
      "**/*.tar",
      "**/*.gz",
      "**/*.tgz",
      "**/*.log",
      "**/*.bak",
      "**/*.cache",
      "**/*.sqlite",
      "**/*.sqlite3",
      "**/*.db"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
