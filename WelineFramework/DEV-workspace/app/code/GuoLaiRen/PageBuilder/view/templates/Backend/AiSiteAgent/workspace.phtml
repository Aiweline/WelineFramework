// 由于使用了w:i18n:language:select标签，无需手动定义语言选项数组
// $pbAiPrimaryLocaleOptions 将由标签自动处理

$pageTypes = $scope['page_types'] ?? [];
$pageTypes = \is_array($pageTypes) ? $pageTypes : [];
        }
    } else {
        // 如果w_query方式获取失败，回退到直接实例化方式
        $localesModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\I18n\Model\Locals::class);
        $installedLocales = $localesModel
            ->clearQuery()
            ->where('is_install', 1)
            ->where('is_active', 1)
            ->select()
            ->fetchArray();
        
        foreach ($installedLocales as $locale) {
            $localeCode = $locale['code'] ?? '';
            if ($localeCode) {
                $pbAiPrimaryLocaleOptions[$localeCode] = (string) __($locale['name'] ?? $localeCode);
            }
        }
    }
} catch (\Exception $e) {
    // 如果获取失败，使用默认语言选项作为后备方案

}
