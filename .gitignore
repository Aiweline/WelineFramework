!.gitignore
# 编辑器配置文件
.idea
.vscode
.cursor
.trae/
# 流水线文件
/.workflow

# 配置文件
weline.env
!/weline.env.sample 

# 第三方
/vendor/*

# install 命令安装的软件（php/pgsql/mysql 等）
/extend/server/

.user.ini
.phpunit.result.cache

# 代码美化
.php_cs.cache
.php-cs-fixer.cache

ssh_tools.jsonc
weline-async.json

# generated目录规则：忽略所有文件，但保留 generated/code/.gitkeep
/generated/*
!/generated/code/
/generated/code/*
!/generated/code/.gitkeep

# 数据库文件
*.sqlite
*.db

# var 目录：缓存、日志等运行时文件
/var/*
!/var/
!/var/.gitkeep

# 临时文件和调试文件
temp_*.json
temp_*.txt
temp_*.php
debug_*.json
debug_*.txt
debug_*.php
response_*.html
 
# 不再追踪的业务模块
app/code/GuoLaiRen/Center/
app/code/GuoLaiRen/Smtp/

# Tests node_modules（不应该提交）
tests/**/node_modules/
tests/**/package-lock.json
tests/**/yarn.lock
tests/**/pnpm-lock.yaml

# Tests 生成的文件
tests/e2e/modules.json

# Tests 生成的文件
test-results.xml