#!/usr/bin/env bash
#
# 统一服务入口（轻量转发器）
#
# 用法：
#   ./bin/server server start [args...]      # 启动 Weline Server（默认实例/按 server:start 参数）
#   ./bin/server server stop [args...]       # 停止 Weline Server
#   ./bin/server server restart [args...]    # 重启 Weline Server
#   ./bin/server server status [args...]     # 查看 Weline Server 状态
#
#   ./bin/server pgsql start|stop|status [-D dataDir]
#
#   ./bin/server all start [args...]         # 先 pgsql:start，再 server:start
#   ./bin/server all stop [args...]          # 先 server:stop，再 pgsql:stop
#
#
# 这里不启用 `set -euo/pipefail`，避免在部分 Windows+MSYS Bash 环境下
# 对 `set` 选项解析不兼容导致脚本提前失败。
#

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "${ROOT_DIR}/.." && pwd)"

die() {
  echo "ERROR: $*" >&2
  exit 1
}

DEFAULT_PHP_1="${PROJECT_ROOT}/extend/server/php/bin/php"
DEFAULT_PHP_2="${PROJECT_ROOT}/extend/server/php/bin/php.exe"
DEFAULT_PHP_3="${PROJECT_ROOT}/extend/server/php/php"
DEFAULT_PHP_4="${PROJECT_ROOT}/extend/server/php/php.exe"

if [[ -x "${DEFAULT_PHP_1}" ]]; then
  PHP_BIN="${PHP_BIN:-${DEFAULT_PHP_1}}"
elif [[ -x "${DEFAULT_PHP_2}" ]]; then
  PHP_BIN="${PHP_BIN:-${DEFAULT_PHP_2}}"
elif [[ -x "${DEFAULT_PHP_3}" ]]; then
  PHP_BIN="${PHP_BIN:-${DEFAULT_PHP_3}}"
elif [[ -x "${DEFAULT_PHP_4}" ]]; then
  PHP_BIN="${PHP_BIN:-${DEFAULT_PHP_4}}"
else
  PHP_BIN="${PHP_BIN:-php}"
fi

if [[ $# -lt 2 ]]; then
  echo "Usage: $0 <server|pgsql|all> <start|stop|restart|status> [args...]"
  exit 0
fi

SERVICE="$1"
ACTION="$2"
shift 2 || true

PGSQL_DIR="${PROJECT_ROOT}/extend/server/pgsql"
PGSQL_BIN="${PGSQL_DIR}/bin"
PGSQL_DATA_DEFAULT="${PGSQL_DIR}/data"
PGSQL_ENV_DEFAULT="${PROJECT_ROOT}/weline.env"
PGSQL_OWNER_CLI="${PROJECT_ROOT}/setup/server_installer/pgsql_owner_cli.php"
PGSQL_PROJECT_PORT_MIN=55432
PGSQL_PROJECT_PORT_MAX=65535

pgsql_normalize_path() {
  local path="$1"
  if [[ -d "$path" ]]; then
    (cd "$path" 2>/dev/null && pwd -P) || echo "$path"
    return 0
  fi
  local parent base
  parent="$(dirname "$path")"
  base="$(basename "$path")"
  if [[ -d "$parent" ]]; then
    (cd "$parent" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base") || echo "$path"
    return 0
  fi
  echo "$path"
}

pgsql_guard_project_data() {
  local data_dir="$1"
  local data_abs default_abs
  data_abs="$(pgsql_normalize_path "$data_dir")"
  default_abs="$(pgsql_normalize_path "$PGSQL_DATA_DEFAULT")"
  if [[ "$data_abs" != "$default_abs" ]]; then
    echo "ERROR: bin/server pgsql only manages this project data directory: ${PGSQL_DATA_DEFAULT}" >&2
    echo "       Refusing custom data directory: ${data_dir}" >&2
    return 1
  fi

  if [[ -f "$PGSQL_OWNER_CLI" ]]; then
    "$PHP_BIN" "$PGSQL_OWNER_CLI" server-can-manage
    local rc=$?
    if [[ "$rc" -eq 2 ]]; then
      echo "Skipping local PostgreSQL because env.php is authoritative for another database target."
      return 2
    fi
    return "$rc"
  fi
  return 0
}

pgsql_resolve_data_dir() {
  local data_dir="${PGSQL_DATA_DEFAULT}"
  local i
  for ((i=1; i<="$#"; i++)); do
    local arg="${!i}"
    if [[ "$arg" == "-D" || "$arg" == "--data-dir" ]]; then
      local next_index=$((i+1))
      local next="${!next_index:-}"
      if [[ -n "$next" && ! "$next" =~ ^- ]]; then
        data_dir="$next"
      fi
    fi
  done
  echo "$data_dir"
}

pgsql_find_pgctl_in_extend() {
  local candidate
  candidate="${PGSQL_BIN}/pg_ctl"
  if [[ -x "${candidate}" ]]; then
    echo "${candidate}"
    return 0
  fi
  candidate="${PGSQL_BIN}/pg_ctl.exe"
  if [[ -x "${candidate}" ]]; then
    echo "${candidate}"
    return 0
  fi
  return 1
}

pgsql_find_initdb_in_extend() {
  local candidate
  candidate="${PGSQL_BIN}/initdb"
  if [[ -x "${candidate}" ]]; then
    echo "${candidate}"
    return 0
  fi
  candidate="${PGSQL_BIN}/initdb.exe"
  if [[ -x "${candidate}" ]]; then
    echo "${candidate}"
    return 0
  fi
  return 1
}

pgsql_command_exists() {
  command -v "$1" >/dev/null 2>&1
}

pgsql_resolve_env_file() {
  local env_file="${WELINE_ENV_FILE:-${PGSQL_ENV_DEFAULT}}"
  if [[ "$env_file" =~ ^[A-Za-z]:[\\/].* ]] || [[ "$env_file" == /* ]] || [[ "$env_file" == \\\\* ]]; then
    echo "$env_file"
    return 0
  fi
  echo "${PROJECT_ROOT}/${env_file}"
}

pgsql_read_port_from_env() {
  local env_file
  env_file="$(pgsql_resolve_env_file)"
  [[ -f "$env_file" ]] || return 1
  local line
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    if [[ "$line" =~ ^[[:space:]]*DB_PORT[[:space:]]*=[[:space:]]*([0-9]+)[[:space:]]*$ ]]; then
      local p="${BASH_REMATCH[1]}"
      if [[ "$p" -gt 0 && "$p" -le 65535 ]]; then
        echo "$p"
        return 0
      fi
    fi
  done < "$env_file"
  return 1
}

pgsql_sync_env_port() {
  local port="$1"
  [[ -z "$port" ]] && return 0
  local env_file
  env_file="$(pgsql_resolve_env_file)"
  local current
  current="$(pgsql_read_port_from_env 2>/dev/null || true)"
  if [[ "$current" == "$port" ]]; then
    if [[ -f "$PGSQL_OWNER_CLI" ]]; then
      "$PHP_BIN" "$PGSQL_OWNER_CLI" sync-env-port "$port" >/dev/null 2>&1 || true
    fi
    return 0
  fi
  mkdir -p "$(dirname "$env_file")" 2>/dev/null || true
  if [[ -f "$env_file" ]]; then
    if grep -qE '^[[:space:]]*DB_PORT[[:space:]]*=' "$env_file" 2>/dev/null; then
      sed -i.bak -E "s/^[[:space:]]*DB_PORT[[:space:]]*=.*/DB_PORT=${port}/" "$env_file" 2>/dev/null || true
    else
      printf '\nDB_PORT=%s\n' "$port" >> "$env_file"
    fi
  else
    printf 'DB_PORT=%s\n' "$port" > "$env_file"
  fi
  export DB_PORT="$port"
  if [[ -f "$PGSQL_OWNER_CLI" ]]; then
    "$PHP_BIN" "$PGSQL_OWNER_CLI" sync-env-port "$port" >/dev/null 2>&1 || true
  fi
  echo "已同步 PostgreSQL 端口到 $(basename "$env_file")：${port}" >&2
}

pgsql_is_port_in_use() {
  local port="$1"
  [[ -z "$port" ]] && return 1
  [[ "$port" -le 0 || "$port" -gt 65535 ]] && return 1

  if pgsql_command_exists ss; then
    if ss -lntp 2>/dev/null | grep -q ":${port}"; then
      return 0
    fi
  fi

  if pgsql_command_exists lsof; then
    if lsof -i :"${port}" 2>/dev/null | grep -q LISTEN; then
      return 0
    fi
  fi

  if pgsql_command_exists netstat; then
    if netstat -an 2>/dev/null | grep -E "[:.]${port}[^0-9].*(LISTEN|LISTENING)" >/dev/null; then
      return 0
    fi
  fi

  return 1
}

pgsql_project_preferred_port() {
  local range seed normalized hex
  range=$((PGSQL_PROJECT_PORT_MAX - PGSQL_PROJECT_PORT_MIN + 1))
  normalized="$(printf '%s' "${PROJECT_ROOT}" | tr '\\' '/' | tr '[:upper:]' '[:lower:]')"
  if pgsql_command_exists sha256sum; then
    hex="$(printf '%s' "$normalized" | sha256sum | awk '{print substr($1,1,8)}')"
    seed=$((16#$hex))
  else
    seed="$(printf '%s' "$normalized" | cksum 2>/dev/null | awk '{print $1}')"
  fi
  [[ -z "$seed" ]] && seed=0
  echo $((PGSQL_PROJECT_PORT_MIN + (seed % range)))
}

pgsql_normalize_project_port() {
  local port="$1"
  if [[ -z "$port" || ! "$port" =~ ^[0-9]+$ || "$port" -le 0 || "$port" -gt 65535 || "$port" -eq 5432 ]]; then
    pgsql_project_preferred_port
    return 0
  fi
  echo "$port"
}

pgsql_read_port_from_conf() {
  local data_dir="$1"
  local conf="${data_dir}/postgresql.conf"
  if [[ -f "$conf" ]]; then
    local line
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      if [[ "$line" =~ ^[[:space:]]*port[[:space:]]*=[[:space:]]*([0-9]+) ]]; then
        local p="${BASH_REMATCH[1]}"
        if [[ "$p" -gt 0 && "$p" -le 65535 ]]; then
          echo "$p"
          return 0
        fi
      fi
    done < "$conf"
  fi
  return 1
}

pgsql_resolve_port_from_conf() {
  local data_dir="$1"
  local p
  p="$(pgsql_read_port_from_conf "$data_dir" 2>/dev/null || true)"
  if [[ -n "$p" ]]; then
    echo "$p"
    return 0
  fi
  pgsql_project_preferred_port
}

pgsql_write_port_conf() {
  local data_dir="$1"
  local port="$2"
  local conf="${data_dir}/postgresql.conf"
  [[ -f "$conf" ]] || return 0
  if grep -qE '^[[:space:]]*#?[[:space:]]*port[[:space:]]*=' "$conf" 2>/dev/null; then
    sed -i.bak -E "s/^[[:space:]]*#?[[:space:]]*port[[:space:]]*=[[:space:]]*[0-9]+/port = ${port}/" "$conf" 2>/dev/null || true
  else
    printf '\nport = %s\n' "$port" >> "$conf"
  fi
}

pgsql_find_available_port() {
  local port="$1"
  port="$(pgsql_normalize_project_port "$port")"
  if [[ "$port" -ne 5432 ]] && ! pgsql_is_port_in_use "$port"; then
    echo "$port"
    return 0
  fi

  local candidate attempts i
  candidate="$(pgsql_project_preferred_port)"
  attempts=$((PGSQL_PROJECT_PORT_MAX - PGSQL_PROJECT_PORT_MIN + 1))
  for ((i=0; i<attempts; i++)); do
    if [[ "$candidate" -ne 5432 ]] && ! pgsql_is_port_in_use "$candidate"; then
      echo "$candidate"
      return 0
    fi
    candidate=$((candidate + 1))
    [[ "$candidate" -gt "$PGSQL_PROJECT_PORT_MAX" ]] && candidate="$PGSQL_PROJECT_PORT_MIN"
  done
  echo "ERROR: no available project PostgreSQL port in ${PGSQL_PROJECT_PORT_MIN}-${PGSQL_PROJECT_PORT_MAX}" >&2
  return 1
}

pgsql_select_project_port() {
  local data_dir="$1"
  local configured
  configured="$(pgsql_read_port_from_env 2>/dev/null || true)"
  if [[ -z "$configured" ]]; then
    configured="$(pgsql_read_port_from_conf "$data_dir" 2>/dev/null || true)"
  fi
  [[ -z "$configured" ]] && configured="$(pgsql_project_preferred_port)"
  configured="$(pgsql_normalize_project_port "$configured")"

  local port
  port="$(pgsql_find_available_port "$configured")" || return 1
  if [[ "$port" != "$configured" ]]; then
    echo "端口 ${configured} 已被占用，当前项目 PostgreSQL 改用端口 ${port}。" >&2
  fi
  pgsql_write_port_conf "$data_dir" "$port"
  pgsql_sync_env_port "$port"
  echo "$port"
}

pgsql_start() {
  local data_dir
  data_dir="$(pgsql_resolve_data_dir "$@")"
  pgsql_guard_project_data "$data_dir"
  local guard_rc=$?
  [[ "$guard_rc" -eq 2 ]] && return 0
  [[ "$guard_rc" -ne 0 ]] && return "$guard_rc"

  local pgctl
  if pgctl="$(pgsql_find_pgctl_in_extend)"; then
    local initdb
    if [[ ! -f "${data_dir}/PG_VERSION" ]]; then
      if ! initdb="$(pgsql_find_initdb_in_extend)"; then
        echo "extend/server/pgsql/bin 下未找到 initdb，无法初始化数据目录：${data_dir}"
        echo "请执行 bin/install.sh pgsql 或手动安装 PostgreSQL 到 extend/server/pgsql。"
        return 1
      fi
      mkdir -p "${data_dir}"
      echo "初始化 PostgreSQL 数据目录（initdb）：${data_dir}"
      "${initdb}" -D "${data_dir}" -E UTF8 -U postgres
    fi

    # 权限自检与自动修复：PostgreSQL 要求 data 目录权限为 0700 或 0750
    if [[ -d "${data_dir}" ]]; then
      if command -v stat >/dev/null 2>&1; then
        # 使用八进制权限，兼容大多数 Linux
        local mode
        mode="$(stat -c '%a' "${data_dir}" 2>/dev/null || echo '')"
        if [[ -n "${mode}" && "${mode}" != "700" && "${mode}" != "750" ]]; then
          echo "检测到数据目录权限为 ${mode}，PostgreSQL 要求为 0700 或 0750。"
        fi
      fi
      echo "尝试自动修复数据目录权限为 0700：chmod 700 \"${data_dir}\""
      chmod 700 "${data_dir}" 2>/dev/null || true
    fi

    if "${pgctl}" -D "${data_dir}" status >/dev/null 2>&1; then
      local running_port_pre desired_port_pre
      running_port_pre="$(pgsql_read_port_from_conf "${data_dir}" 2>/dev/null || true)"
      desired_port_pre="$(pgsql_read_port_from_env 2>/dev/null || true)"
      [[ -z "$desired_port_pre" ]] && desired_port_pre="$running_port_pre"
      desired_port_pre="$(pgsql_normalize_project_port "$desired_port_pre")"
      if [[ -n "$running_port_pre" && "$running_port_pre" == "$desired_port_pre" && "$running_port_pre" != "5432" ]]; then
        pgsql_sync_env_port "$running_port_pre"
        echo "PostgreSQL is already running for this project: ${data_dir}"
        "${pgctl}" -D "${data_dir}" status || true
        return 0
      fi
      echo "Restarting project PostgreSQL from port ${running_port_pre:-unknown} to project port ${desired_port_pre}."
      "${pgctl}" -D "${data_dir}" stop -m fast || true
      if "${pgctl}" -D "${data_dir}" status >/dev/null 2>&1; then
        echo "ERROR: project PostgreSQL is still running after stop; cannot change port safely." >&2
        return 1
      fi
    fi

    if "${pgctl}" -D "${data_dir}" status >/dev/null 2>&1; then
      local running_port
      running_port="$(pgsql_read_port_from_conf "${data_dir}" 2>/dev/null || true)"
      if [[ -n "$running_port" ]]; then
        pgsql_sync_env_port "$running_port"
      fi
      echo "PostgreSQL 已在运行：${data_dir}"
      "${pgctl}" -D "${data_dir}" status || true
      return 0
    fi

    local port
    port="$(pgsql_select_project_port "${data_dir}")" || return 1

    local logfile="${data_dir}/logfile"
    echo "启动 PostgreSQL（pg_ctl）：${data_dir}，端口：${port}"
    if [[ "$(uname -s)" == "Linux" ]]; then
      # 注意：-o 后面的参数必须作为一个整体传给 pg_ctl，否则会被当成多余参数报错
      "${pgctl}" -D "${data_dir}" -l "${logfile}" -o "-k ${data_dir} -p ${port}" start
    else
      "${pgctl}" -D "${data_dir}" -l "${logfile}" -o "-p ${port}" start
    fi
    local rc=$?
    echo
    echo "=== PostgreSQL 状态检查 ==="
    "${pgctl}" -D "${data_dir}" status || true
    echo "==========================="
    echo
    if [[ ${rc} -ne 0 ]]; then
      echo "✖ PostgreSQL 启动失败（退出码：${rc}）"
      echo "  日志文件：${logfile}"
      if [[ -f "${logfile}" ]]; then
        echo
        echo "──── PostgreSQL 日志（最后 50 行） ────"
        tail -n 50 "${logfile}" || true
        echo "──────────────────────────────────────"
        echo
        echo "提示：如需查看更多日志，可执行："
        echo "  tail -n 200 \"${logfile}\""
      else
        echo "  未找到日志文件：${logfile}"
      fi
      return "${rc}"
    else
      echo "✓ PostgreSQL 已尝试启动，如上为当前状态。"
      return 0
    fi
  fi

  # extend/server 中无 pg_ctl：不接管系统 PostgreSQL。
  echo "pg_ctl was not found in extend/server/pgsql/bin."
  echo "bin/server pgsql only manages this project's extend/server/pgsql/data and will not start a system PostgreSQL service."
  echo "Install or link the matching PostgreSQL major version into extend/server/pgsql, then retry."
  return 1
}

pgsql_status() {
  local data_dir
  data_dir="$(pgsql_resolve_data_dir "$@")"
  pgsql_guard_project_data "$data_dir"
  local guard_rc=$?
  [[ "$guard_rc" -eq 2 ]] && return 0
  [[ "$guard_rc" -ne 0 ]] && return "$guard_rc"

  local pgctl
  if pgctl="$(pgsql_find_pgctl_in_extend)"; then
    if [[ ! -f "${data_dir}/PG_VERSION" ]]; then
      echo "extend/server/pgsql 尚未初始化数据目录：${data_dir}"
      return 0
    fi
    "${pgctl}" -D "${data_dir}" status || true
    return 0
  fi

  echo "未检测到 extend/server/pgsql/bin/pg_ctl。bin/server pgsql 不检查系统 PostgreSQL 服务。"
  return 0
}

pgsql_stop() {
  local data_dir
  data_dir="$(pgsql_resolve_data_dir "$@")"
  pgsql_guard_project_data "$data_dir"
  local guard_rc=$?
  [[ "$guard_rc" -eq 2 ]] && return 0
  [[ "$guard_rc" -ne 0 ]] && return "$guard_rc"

  local pgctl
  if pgctl="$(pgsql_find_pgctl_in_extend)"; then
    if [[ ! -f "${data_dir}/PG_VERSION" ]]; then
      echo "extend/server/pgsql 尚未初始化数据目录：${data_dir}"
      return 0
    fi
    echo "停止 PostgreSQL（pg_ctl stop -m fast）：${data_dir}"
    "${pgctl}" -D "${data_dir}" stop -m fast || true
    echo "状态："
    "${pgctl}" -D "${data_dir}" status || true
    return 0
  fi

  echo "未检测到 extend/server/pgsql/bin/pg_ctl。bin/server pgsql 不停止系统 PostgreSQL 服务。"
  return 0
}

case "$SERVICE" in
  server)
    "${PHP_BIN}" "${PROJECT_ROOT}/bin/w" "server:${ACTION}" "$@"
    ;;
  pgsql)
    case "${ACTION}" in
      start)  pgsql_start "$@" ;;
      status) pgsql_status "$@" ;;
      stop)   pgsql_stop "$@" ;;
      help|-h|--help)
        echo "用法：bash bin/server pgsql <start|status|stop>"
        echo
        echo "说明："
        echo "  1) 优先使用 extend/server/pgsql/bin 下的 pg_ctl + data 目录；"
        echo "  2) 若 env.php 指向外部或非当前项目数据库，会跳过本地 PostgreSQL；"
        echo "  3) 不启动、停止或检查系统 PostgreSQL（systemctl/service）；"
        echo "  4) 当前项目端口被占用时会自动选择项目端口，并同步 postgresql.conf 与 env.php。"
        echo
        echo "示例："
        echo "  bash bin/server pgsql start"
        echo "  bash bin/server pgsql status"
        echo "  bash bin/server pgsql stop"
        echo "  bash bin/server pgsql start"
        ;;
      *)
        die "pgsql 子命令只支持：start / status / stop / help"
        ;;
    esac
    ;;
  all)
    case "$ACTION" in
      start)
        pgsql_start "$@"
        "${PHP_BIN}" "${PROJECT_ROOT}/bin/w" "server:start" "$@"
        ;;
      stop)
        "${PHP_BIN}" "${PROJECT_ROOT}/bin/w" "server:stop" "$@"
        pgsql_stop "$@"
        ;;
      restart)
        pgsql_start "$@"
        "${PHP_BIN}" "${PROJECT_ROOT}/bin/w" "server:restart" "$@"
        ;;
      status)
        pgsql_status "$@"
        "${PHP_BIN}" "${PROJECT_ROOT}/bin/w" "server:status" "$@"
        ;;
      *)
        die "all 只支持 start/stop/restart/status"
        ;;
    esac
    ;;
  *)
    die "unknown service: ${SERVICE} (expected server|pgsql|all)"
    ;;
esac
