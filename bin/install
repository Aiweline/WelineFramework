#!/usr/bin/env bash
# 统一安装入口：在 Git Bash 下运行 ./bin/install 时用 cmd 执行 install.bat；在 Linux/Mac 下执行 install.sh。
# 用法：Git Bash 用 ./bin/install；CMD 用 install.bat；Linux/Mac 用 ./bin/install 或 ./bin/install.sh

if [ -z "${BASH_VERSION:-}" ]; then
  exec /usr/bin/env bash "$0" "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS="$(uname -s)"

case "$OS" in
  MINGW*|MSYS*|*NT*|CYGWIN*)
    # Windows (Git Bash / MSYS2 / Cygwin)：用 cmd 执行 install.bat；用正斜杠路径避免引号转义问题
    if command -v cygpath >/dev/null 2>&1; then
      WIN_BIN="$(cygpath -w "$SCRIPT_DIR")"
    else
      WIN_BIN="$(echo "$SCRIPT_DIR" | sed -e 's|^/\([a-zA-Z]\)/|\1:\|' -e 's|/|\\|g')"
    fi
    WIN_BAT="${WIN_BIN//\\/\/}/install.bat"
    exec cmd //c "$WIN_BAT $*"
    ;;
  *)
    exec "$SCRIPT_DIR/install.sh" "$@"
    ;;
esac
