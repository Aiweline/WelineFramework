{
  "name": "aiweline/weline-framework",
  "description": "微蓝WelineFramework框架！",
  "homepage": "https://gitee.com/aiweline/WelineFramework",
  "keywords": [
    "weline",
    "WelineFramework",
    "framework",
    "web",
    "ORM",
    "app",
    "php",
    "php8"
  ],
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "proprietary",
  "authors": [
    {
      "name": "秋枫雁飞",
      "email": "aiweline@qq.com",
      "homepage": "https://gitee.com/aiweline"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-iconv": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-exif": "*",
    "ext-fileinfo": "*",
    "ext-simplexml": "*",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-zip": "*",
    "ext-gd": "*",
    "symfony/intl": "^5.2",
    "symfony/polyfill-intl-icu": "^1.23",
    "jdorn/sql-formatter": "^1.2",
    "wikimedia/less.php": "^3.1",
    "mrclay/jsmin-php": "^2.4",
    "guzzlehttp/guzzle": "^7.4",
    "friendsofphp/php-cs-fixer": "^3.58",
    "phpoffice/phpspreadsheet": "^1.29",
    "shopify/shopify-api": "^5.8",
    "openai-php/client": "^0.9.2",
    "phpstan/phpstan": "*",
    "ext-curl": "*",
    "phpclassic/php-shopify": "^1.2",
    "ecomphp/tiktokshop-php": "^2.6",
    "ardagnsrn/ollama-php": "^1.0",
    "dragonmantank/cron-expression": "^3.4",
    "studio-42/elfinder": "^2.1.65",
    "weline/base": "@dev",
    "lipis/flag-icons": "^7.5"
  },
  "repositories": [
    {
      "type": "path",
      "url": "app/code/Weline/*",
      "options": {
        "symlink": false
      }
    }
  ],
  "opcache-autoloader": true,
  "apcu-autoloader": true,
  "optimize-autoloader": true,
  "autoload": {
    "classmap": [
      "extend/",
      "generated/code/"
    ],
    "psr-4": {
      "Weline\\Framework\\": [
        "app/code/Weline/Framework/"
      ],
      "Weline\\": [
        "app/code/Weline/"
      ],
      "": [
        "app/code/",
        "generated/code/"
      ]
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "symfony/var-dumper": "^6.1",
    "phpunit/phpunit": "^9.6"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}