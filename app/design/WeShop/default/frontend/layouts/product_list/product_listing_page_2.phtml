                        <?php 
                        $total = $this->getData('total') ?? 0;
                        $page = $this->getData('page') ?? 1;
                        $pageSize = $this->getData('page_size') ?? 12;
                        $totalPages = ceil($total / $pageSize);
                        ?>
                        <?php if ($totalPages > 1): ?>
                            <div class="weshop-pagination">
                                <nav class="weshop-pagination-nav">
                                    <?php if ($page > 1): ?>
                                        <a href="<?= $this->getUrl('catalog/category', ['page' => $page - 1]) ?>" class="weshop-pagination-link">
                                            <span class="material-symbols-outlined" style="font-size: 1.25rem;">chevron_left</span>
                                        </a>
                                    <?php endif; ?>
                                    
                                    <?php for ($i = 1; $i <= min($totalPages, 13); $i++): ?>
                                        <?php if ($i == $page): ?>
                                            <span class="weshop-pagination-link active"><?= $i ?></span>
                                        <?php elseif ($i <= 3 || $i > $totalPages - 3 || abs($i - $page) <= 1): ?>
