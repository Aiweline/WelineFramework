<?php
/**
 * Layout: account auth login page variant 2 compatibility host.
 */
$meta = $this->getData('meta') ?? [];
?>
<!DOCTYPE html>
<html class="light" lang="<?= $this->getLocale() ?>">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::account_auth::head-after</w:hook>
</head>
<body>
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::account_auth::body-start</w:hook>
    <div class="relative flex min-h-screen w-full flex-col">
        <div class="layout-container flex h-full grow flex-col">
            <if condition="meta.showHeader">
                <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::header-before</w:hook>
                <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default"/>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::header-after</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
            </if>
            <main class="flex-1">
                <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::content-before</w:hook>
                <if condition="meta.content">
                    {{meta.content}}
                    <elseif condition="content"/>
                    {{content}}
                    <elseif condition="meta.contentTemplate"/>
                    <?php echo $this->fetch($this->getData("meta.contentTemplate")); ?>
                    <elseif condition="contentTemplate"/>
                    <?php echo $this->fetch($this->getData("contentTemplate")); ?>
                    <else>
                    <?= $this->getChildHtml('content') ?>
                </if>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::content-after</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>
            </main>
            <if condition="meta.showFooter">
                <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::footer-before</w:hook>
                <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default"/>
                <w:hook>Weline_Theme::frontend::layouts::account_auth::footer-after</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
            </if>
        </div>
    </div>
    <w:hook>Weline_Theme::frontend::layouts::account_auth::body-end</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
</body>
</html>
