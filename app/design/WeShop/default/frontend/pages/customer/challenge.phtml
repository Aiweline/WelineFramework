<script>
(function () {
    'use strict';

    var form = document.querySelector('[data-challenge-form]');
    if (!form) {
        return;
    }

    var codeInput = document.getElementById('code');
    var submitButton = document.getElementById('verifyBtn');
    var submitLabel = submitButton ? submitButton.querySelector('[data-submit-label]') : null;
    var codeError = document.getElementById('codeError');
    var verifyingText = '验证中...';
    var invalidCodeText = '请输入6位身份验证器验证码或8位备用恢复码。';

    function sanitizeDigits(value) {
        return value.replace(/\D/g, '').slice(0, 8);
    }

    function hideError() {
        if (!codeError) {
            return;
        }

        codeError.hidden = true;
        codeError.textContent = '';
    }

    function showError(message) {
        if (!codeError) {
            return;
        }

        codeError.hidden = false;
        codeError.textContent = message;
    }

    if (codeInput) {
        codeInput.addEventListener('input', function () {
            hideError();

            var digits = sanitizeDigits(this.value);
            if (digits.length > 6) {
                this.value = digits.slice(0, 4) + '-' + digits.slice(4);
                return;
            }

            this.value = digits;
        });

        window.setTimeout(function () {
            codeInput.focus();
        }, 0);
    }

    form.addEventListener('submit', function (event) {
        if (!codeInput) {
            return;
        }

        hideError();

        var digits = sanitizeDigits(codeInput.value);
        if (digits.length !== 6 && digits.length !== 8) {
            event.preventDefault();
            showError(invalidCodeText);
            codeInput.focus();
            return;
        }

        codeInput.value = digits.length === 8
            ? digits.slice(0, 4) + '-' + digits.slice(4)
            : digits;

        if (submitButton) {
            submitButton.disabled = true;
        }

        if (submitLabel) {
            submitLabel.textContent = verifyingText;
        }
    });
}());
</script>
