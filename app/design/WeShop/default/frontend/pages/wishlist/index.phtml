<script>
(function () {
    document.querySelectorAll('[data-remove-wishlist-item]').forEach(function (button) {
        button.addEventListener('click', function () {
            var wishlistId = this.getAttribute('data-remove-wishlist-item');
            if (!wishlistId) {
                return;
            }

            fetch('<?= $this->getUrl('wishlist/remove') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ wishlist_id: wishlistId })
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (payload && payload.success) {
                    window.location.reload();
                }
            });
        });
    });
})();
</script>
