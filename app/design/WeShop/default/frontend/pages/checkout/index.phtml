<script>
// Checkout step navigation will be handled by AJAX in production
document.addEventListener('DOMContentLoaded', function() {
    // Form submissions
    document.getElementById('shipping-form')?.addEventListener('submit', function(e) {
        e.preventDefault();
        // Ajax submit and go to next step
        var formData = new FormData(this);
        fetch('<?= $this->getUrl('checkout/save-shipping') ?>', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.href = '<?= $this->getUrl('checkout') ?>?step=2';
            } else {
                alert(data.message || '<?= __('Please check your shipping information') ?>');
            }
        });
    });
    
    document.getElementById('payment-form')?.addEventListener('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(this);
        fetch('<?= $this->getUrl('checkout/save-payment') ?>', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.href = '<?= $this->getUrl('checkout') ?>?step=3';
            } else {
                alert(data.message || '<?= __('Please check your payment information') ?>');
            }
        });
    });
    
    // Step navigation
    document.querySelectorAll('.step-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
            window.location.href = '<?= $this->getUrl('checkout') ?>?step=' + this.dataset.step;
        });
    });
    
    document.querySelectorAll('.step-back').forEach(function(btn) {
        btn.addEventListener('click', function() {
            window.location.href = '<?= $this->getUrl('checkout') ?>?step=' + this.dataset.step;
        });
    });
});
</script>
