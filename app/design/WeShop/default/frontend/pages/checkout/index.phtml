<script>
    (function () {
        var radios = document.querySelectorAll('input[name="shipping_address_id"]');
        var newAddressFields = document.querySelectorAll('[data-new-address-field]');

        function syncNewAddressRequirement() {
            var hasSavedAddress = false;
            radios.forEach(function (radio) {
                if (radio.checked) {
                    hasSavedAddress = true;
                }
            });

            newAddressFields.forEach(function (field) {
                if (hasSavedAddress) {
                    field.removeAttribute('required');
                }
            });
        }

        radios.forEach(function (radio) {
            radio.addEventListener('change', syncNewAddressRequirement);
        });

        syncNewAddressRequirement();
    })();
</script>

