$canonicalCategoryProducts = trim((string) $this->getHook('WeShop_Catalog::frontend::layouts::category::products-content'));
$buildCategoryPageUrl = function (int $targetPage) use ($category) {
    $params = method_exists($this->request, 'getQuery') && is_array($this->request->getQuery())
        ? $this->request->getQuery()
        : [];
    if (!empty($category['category_id'])) {
        $params['id'] = $category['category_id'];
    }
    if (!empty($category['handle'])) {
        $params['handle'] = $category['handle'];
    }
    $params['page'] = max(1, $targetPage);

    return $this->getUrl('catalog/category/view', $params);
};
