<script>
    (function () {
        var form = document.getElementById('weshop-address-form');
        var resetButton = document.getElementById('weshop-address-reset');
        var feedback = document.getElementById('weshop-address-feedback');
        var idField = document.getElementById('weshop-address-id');
        var fieldMap = {
            firstname: document.getElementById('weshop-address-firstname'),
            lastname: document.getElementById('weshop-address-lastname'),
            telephone: document.getElementById('weshop-address-telephone'),
            country_id: document.getElementById('weshop-address-country'),
            region: document.getElementById('weshop-address-region'),
            city: document.getElementById('weshop-address-city'),
            district: document.getElementById('weshop-address-district'),
            street: document.getElementById('weshop-address-street'),
            postcode: document.getElementById('weshop-address-postcode'),
            is_default: document.getElementById('weshop-address-default')
        };
        var addressApiPromise = null;

        function showFeedback(message, isError) {
            if (!feedback) {
                return;
            }

            feedback.classList.remove('hidden', 'border-green-200', 'bg-green-50', 'text-green-700', 'border-red-200', 'bg-red-50', 'text-red-700');
            if (isError) {
                feedback.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
            } else {
                feedback.classList.add('border-green-200', 'bg-green-50', 'text-green-700');
            }
            feedback.textContent = message || '';
        }

        function resetForm() {
            form.reset();
            idField.value = '';
        }

        function assignCardToForm(card) {
            idField.value = card.getAttribute('data-address-id') || '';
            fieldMap.firstname.value = card.getAttribute('data-firstname') || '';
            fieldMap.lastname.value = card.getAttribute('data-lastname') || '';
            fieldMap.telephone.value = card.getAttribute('data-telephone') || '';
            fieldMap.country_id.value = card.getAttribute('data-country-id') || '';
            fieldMap.region.value = card.getAttribute('data-region') || '';
            fieldMap.city.value = card.getAttribute('data-city') || '';
            fieldMap.district.value = card.getAttribute('data-district') || '';
            fieldMap.street.value = card.getAttribute('data-street') || '';
            fieldMap.postcode.value = card.getAttribute('data-postcode') || '';
            fieldMap.is_default.checked = card.getAttribute('data-is-default') === '1';
            form.scrollIntoView({behavior: 'smooth', block: 'start'});
        }

        function getAddressApi() {
            if (!addressApiPromise) {
                addressApiPromise = window.Weline && window.Weline.Api
                    ? window.Weline.Api.resource('address')
                    : Promise.reject(new Error('Weline.Api is unavailable.'));
            }
            return addressApiPromise;
        }

        function formDataToObject(formData) {
            var payload = {};
            formData.forEach(function (value, key) {
                payload[key] = value;
            });
            payload.address_id = parseInt(payload.address_id || '0', 10) || 0;
            payload.is_default = payload.is_default === '1' || payload.is_default === 'true';
            return payload;
        }

        function addressAction(operation, body, errorMessage) {
            return getAddressApi().then(function (AddressApi) {
                return AddressApi[operation](body, {
                    onError: function (_status, error) {
                        showFeedback((error && error.message) || errorMessage, true);
                    }
                });
            });
        }

        document.querySelectorAll('[data-address-edit]').forEach(function (button) {
            button.addEventListener('click', function () {
                var card = this.closest('[data-address-card]');
                if (card) {
                    assignCardToForm(card);
                }
            });
        });

        document.querySelectorAll('[data-address-default]').forEach(function (button) {
            button.addEventListener('click', function () {
                addressAction('setDefault', {
                    address_id: parseInt(this.getAttribute('data-address-default') || '0', 10) || 0
                }, '<?= addslashes((string) __('Unable to update the default address.')) ?>').then(function (payload) {
                    if (payload && payload.success) {
                        window.location.reload();
                        return;
                    }

                    showFeedback((payload && payload.message) || '<?= addslashes((string) __('Unable to update the default address.')) ?>', true);
                }).catch(function (error) {
                    showFeedback((error && error.message) || '<?= addslashes((string) __('Unable to update the default address.')) ?>', true);
                });
            });
        });

        document.querySelectorAll('[data-address-delete]').forEach(function (button) {
            button.addEventListener('click', function () {
                addressAction('delete', {
                    address_id: parseInt(this.getAttribute('data-address-delete') || '0', 10) || 0
                }, '<?= addslashes((string) __('Unable to remove the address.')) ?>').then(function (payload) {
                    if (payload && payload.success) {
                        window.location.reload();
                        return;
                    }

                    showFeedback((payload && payload.message) || '<?= addslashes((string) __('Unable to remove the address.')) ?>', true);
                }).catch(function (error) {
                    showFeedback((error && error.message) || '<?= addslashes((string) __('Unable to remove the address.')) ?>', true);
                });
            });
        });

        resetButton.addEventListener('click', function () {
            resetForm();
            form.scrollIntoView({behavior: 'smooth', block: 'start'});
        });

        form.addEventListener('submit', function (event) {
            event.preventDefault();
            var payloadData = formDataToObject(new FormData(form));

            addressAction('save', payloadData, '<?= addslashes((string) __('Unable to save the address.')) ?>').then(function (payload) {
                if (payload && payload.success) {
                    window.location.reload();
                    return;
                }

                showFeedback((payload && payload.message) || '<?= addslashes((string) __('Unable to save the address.')) ?>', true);
            }).catch(function (error) {
                showFeedback((error && error.message) || '<?= addslashes((string) __('Unable to save the address.')) ?>', true);
            });
        });
    })();
</script>
