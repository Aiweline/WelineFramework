<script>
    (function () {
        var form = document.getElementById('rma-request-form');
        var submit = document.getElementById('rma-submit');
        var feedback = document.getElementById('rma-feedback');
        var apiPromise = null;

        if (!form || !submit || !feedback) {
            return;
        }

        function getRmaApi() {
            if (!apiPromise) {
                apiPromise = Promise.resolve(window.Weline.Api.resource('rma'));
            }

            return apiPromise;
        }

        submit.addEventListener('click', function () {
            var payload = {};
            new FormData(form).forEach(function (value, key) {
                payload[key] = value;
            });

            getRmaApi().then(function (RmaApi) {
                return RmaApi.create(payload, {silent: true});
            }).then(function (result) {
                if (result && result.success) {
                    feedback.textContent = result.message || '<?= __('Your return request has been submitted.') ?>';
                    feedback.classList.remove('text-red-500');
                    feedback.classList.add('text-emerald-500');
                    window.setTimeout(function () {
                        window.location.href = (result.data && result.data.redirect_url) || '/customer/account/index#returns';
                    }, 300);
                    return;
                }

                if (result && result.data && result.data.redirect_url) {
                    window.location.href = result.data.redirect_url;
                    return;
                }

                feedback.textContent = (result && result.message) ? result.message : '<?= __('Unable to submit your request right now.') ?>';
                feedback.classList.remove('text-emerald-500');
                feedback.classList.add('text-red-500');
            }).catch(function () {
                feedback.textContent = '<?= __('Unable to submit your request right now.') ?>';
                feedback.classList.remove('text-emerald-500');
                feedback.classList.add('text-red-500');
            });
        });
    })();
</script>
