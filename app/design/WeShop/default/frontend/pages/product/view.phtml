<script>
// Image Gallery
function changeMainImage(thumbnail) {
    var mainImage = document.getElementById('main-product-image');
    var imageUrl = thumbnail.dataset.image;
    mainImage.style.backgroundImage = 'url("' + imageUrl + '")';
    
    // Update thumbnails
    var thumbnails = document.querySelectorAll('#product-thumbnails > div');
    thumbnails.forEach(function(thumb) {
        thumb.classList.remove('border-2', 'border-primary');
        thumb.classList.add('opacity-70');
    });
    thumbnail.classList.add('border-2', 'border-primary');
    thumbnail.classList.remove('opacity-70');
}

// Tabs
function activateProductTab(tabName) {
    var targetContent = document.getElementById(tabName + '-content');
    if (!targetContent) {
        return false;
    }

    document.querySelectorAll('.product-tab').forEach(function(t) {
        var isActive = t.dataset.tab === tabName;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    document.querySelectorAll('.tab-content').forEach(function(content) {
        content.setAttribute('hidden', 'hidden');
    });
    targetContent.removeAttribute('hidden');

    return true;
}

function getProductReviewDeepLinkTargetId() {
    var params = new URLSearchParams(window.location.search || '');
    var replyId = Number(params.get('reply_id') || 0);
    if (replyId > 0) {
        return 'review-reply-' + replyId;
    }

    var reviewId = Number(params.get('review_id') || 0);
    if (reviewId > 0) {
        return 'review-' + reviewId;
    }

    var hash = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : '';
    return /^review(?:-reply)?-\d+$/.test(hash) ? hash : '';
}

function focusProductReviewDeepLink() {
    var targetId = getProductReviewDeepLinkTargetId();
    if (!targetId) {
        return;
    }

    activateProductTab('reviews');
    window.setTimeout(function() {
        var node = document.getElementById(targetId);
        if (!node) {
            return;
        }
        document.querySelectorAll('[data-review-deep-link-target="1"]').forEach(function(item) {
            item.removeAttribute('data-review-deep-link-target');
            item.classList.remove('ring-2', 'ring-primary/30', 'border-primary');
        });
        node.classList.add('ring-2', 'ring-primary/30', 'border-primary');
        node.setAttribute('data-review-deep-link-target', '1');
        if (!node.hasAttribute('tabindex')) {
            node.setAttribute('tabindex', '-1');
        }
        node.scrollIntoView({behavior: 'auto', block: 'center', inline: 'nearest'});
        try {
            node.focus({preventScroll: true});
        } catch (error) {
            node.focus();
        }
    }, 160);
}

document.querySelectorAll('.product-tab').forEach(function(tab) {
    tab.addEventListener('click', function(e) {
        e.preventDefault();
        activateProductTab(this.dataset.tab);
    });
});

focusProductReviewDeepLink();
window.addEventListener('load', focusProductReviewDeepLink);
window.addEventListener('hashchange', focusProductReviewDeepLink);
</script>
