    <script>
        (function () {
            var form = document.getElementById('review-form');
            var submit = document.getElementById('review-submit');
            var feedback = document.getElementById('review-feedback');

            if (!form || !submit) {
                return;
            }

            submit.addEventListener('click', function () {
                var payload = {};
                new FormData(form).forEach(function (value, key) {
                    payload[key] = value;
                });

                fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(payload)
                }).then(function (response) {
                    return response.json();
                }).then(function (result) {
                    if (result && result.success) {
                        feedback.textContent = result.message || '<?= __('Thank you for your review.') ?>';
                        feedback.classList.remove('text-red-500');
                        feedback.classList.add('text-emerald-500');
                        form.reset();
                        return;
                    }
                    if (result && result.data && result.data.redirect_url) {
                        window.location.href = result.data.redirect_url;
                        return;
                    }
                    feedback.textContent = result.message || '<?= __('Unable to submit your review right now.') ?>';
                    feedback.classList.remove('text-emerald-500');
                    feedback.classList.add('text-red-500');
                }).catch(function () {
                    feedback.textContent = '<?= __('Unable to submit your review right now.') ?>';
                    feedback.classList.remove('text-emerald-500');
                    feedback.classList.add('text-red-500');
                });
            });
        })();
    </script>
