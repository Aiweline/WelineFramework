$hasPrevious = (bool) ($this->getData('has_previous') ?? false);
$hasNext = (bool) ($this->getData('has_next') ?? false);
$reviewUrl = (string) ($this->getData('review_url') ?? $this->getUrl('review'));
$createUrl = (string) ($this->getData('create_url') ?? $this->getUrl('review/create'));
$productId = (int) ($product['product_id'] ?? 0);
$buildPaginationUrl = function (int $targetPage) use ($reviewUrl, $productId, $pageSize): string {
    $params = [
        'product_id' => $productId,
        'page' => max(1, $targetPage),
        'page_size' => $pageSize,
    ];

    $query = http_build_query($params);

    return $reviewUrl . ($query !== '' ? '?' . $query : '');
};
