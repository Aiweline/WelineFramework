<script>
document.addEventListener('DOMContentLoaded', function() {
    // Quantity controls
    document.querySelectorAll('.qty-decrease').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            var input = document.querySelector('.qty-input[data-item-id="' + itemId + '"]');
            var currentVal = parseInt(input.value) || 1;
            if (currentVal > 1) {
                updateCartItem(itemId, currentVal - 1);
            }
        });
    });
    
    document.querySelectorAll('.qty-increase').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            var input = document.querySelector('.qty-input[data-item-id="' + itemId + '"]');
            var currentVal = parseInt(input.value) || 1;
            updateCartItem(itemId, currentVal + 1);
        });
    });
    
    document.querySelectorAll('.qty-input').forEach(function(input) {
        input.addEventListener('change', function() {
            var itemId = this.dataset.itemId;
            var qty = parseInt(this.value) || 1;
            if (qty < 1) qty = 1;
            updateCartItem(itemId, qty);
        });
    });
    
    // Delete item
    document.querySelectorAll('.delete-item').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            if (confirm('<?= __('Are you sure you want to remove this item?') ?>')) {
                deleteCartItem(itemId);
            }
        });
    });
    
    // Save for later
    document.querySelectorAll('.save-for-later').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            saveForLater(itemId);
        });
    });
    
    // Apply promo code
    document.getElementById('apply-promo')?.addEventListener('click', function() {
        var code = document.getElementById('promo-code').value;
        if (code) {
            applyPromoCode(code);
        }
    });
});

function updateCartItem(itemId, qty) {
    fetch('<?= $this->getUrl('cart/update') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({item_id: itemId, qty: qty})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message || '<?= __('Error updating cart') ?>');
        }
    });
}

function deleteCartItem(itemId) {
    fetch('<?= $this->getUrl('cart/delete') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({item_id: itemId})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message || '<?= __('Error removing item') ?>');
        }
    });
}

function saveForLater(itemId) {
    fetch('<?= $this->getUrl('wishlist/add-from-cart') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({item_id: itemId})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        }
    });
}

function applyPromoCode(code) {
    fetch('<?= $this->getUrl('cart/apply-coupon') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({code: code})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message || '<?= __('Invalid promo code') ?>');
        }
    });
}
</script>
