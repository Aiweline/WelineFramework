<script>
document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('weshop:cart:added', function() {
        window.location.reload();
    });

    // Quantity controls
    document.querySelectorAll('.qty-decrease').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            var input = document.querySelector('.qty-input[data-item-id="' + itemId + '"]');
            var currentVal = parseInt(input.value) || 1;
            if (currentVal > 1) {
                updateCartItem(itemId, currentVal - 1);
            }
        });
    });
    
    document.querySelectorAll('.qty-increase').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            var input = document.querySelector('.qty-input[data-item-id="' + itemId + '"]');
            var currentVal = parseInt(input.value) || 1;
            updateCartItem(itemId, currentVal + 1);
        });
    });
    
    document.querySelectorAll('.qty-input').forEach(function(input) {
        input.addEventListener('change', function() {
            var itemId = this.dataset.itemId;
            var qty = parseInt(this.value) || 1;
            if (qty < 1) qty = 1;
            updateCartItem(itemId, qty);
        });
    });
    
    // Delete item
    document.querySelectorAll('.delete-item').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            deleteCartItem(itemId);
        });
    });
    
    // Save for later
    document.querySelectorAll('.save-for-later').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var itemId = this.dataset.itemId;
            saveForLater(itemId);
        });
    });
    
    // Apply promo code
    document.getElementById('apply-promo')?.addEventListener('click', function() {
        var code = document.getElementById('promo-code').value;
        if (code) {
            applyPromoCode(code);
        }
    });
});

var workerApiPromises = Object.create(null);

function getWorkerApi(provider) {
    if (!workerApiPromises[provider]) {
        if (!window.Weline?.Api?.resource) {
            return Promise.reject(new Error('Weline.Api.resource is not available'));
        }
        workerApiPromises[provider] = Promise.resolve(window.Weline.Api.resource(provider));
    }
    return workerApiPromises[provider];
}

function normalizeWorkerPayload(payload) {
    if (!payload || typeof payload !== 'object') {
        return payload || {};
    }
    if (!Object.prototype.hasOwnProperty.call(payload, 'code') || typeof payload.data !== 'object' || !payload.data) {
        return payload;
    }

    var code = Number(payload.code || 0);
    return Object.assign({
        code: code,
        message: payload.msg || payload.data.message || '',
        success: code >= 200 && code < 300 && payload.data.success !== false,
    }, payload.data);
}

async function updateCartItem(itemId, qty) {
    try {
        var CartApi = await getWorkerApi('cart');
        var data = normalizeWorkerPayload(await CartApi.update({
            item_id: parseInt(itemId, 10),
            quantity: qty,
        }));
        if (data.success !== false) {
            window.location.reload();
        } else {
            showCartMessage(data.message || '<?= __('Error updating cart') ?>', 'error');
        }
    } catch (error) {
        showCartMessage(error.message || '<?= __('Error updating cart') ?>', 'error');
    }
}

async function deleteCartItem(itemId) {
    try {
        var CartApi = await getWorkerApi('cart');
        var data = normalizeWorkerPayload(await CartApi.remove({
            item_id: parseInt(itemId, 10),
        }));
        if (data.success !== false) {
            window.location.reload();
        } else {
            showCartMessage(data.message || '<?= __('Error removing item') ?>', 'error');
        }
    } catch (error) {
        showCartMessage(error.message || '<?= __('Error removing item') ?>', 'error');
    }
}

async function saveForLater(itemId) {
    try {
        var WishlistApi = await getWorkerApi('wishlist');
        var data = normalizeWorkerPayload(await WishlistApi.addFromCart({
            item_id: parseInt(itemId, 10),
        }));
        if (data.success) {
            window.location.reload();
            return;
        }
        if (data.data && data.data.redirect_url) {
            window.location.href = data.data.redirect_url;
            return;
        }
        showCartMessage(data.message || '<?= __('Unable to save this item for later right now.') ?>', 'error');
    } catch (error) {
        showCartMessage(error.message || '<?= __('Unable to save this item for later right now.') ?>', 'error');
    }
}

async function applyPromoCode(code) {
    try {
        var PromotionApi = await getWorkerApi('promotion');
        var data = normalizeWorkerPayload(await PromotionApi.applyCoupon({
            code: code,
            order_total: <?= (float) ($cartSummary['grand_total'] ?? $cartSummary['total'] ?? 0) ?>,
        }));
        if (data.success) {
            window.location.reload();
        } else {
            showCartMessage(data.message || '<?= __('Invalid promo code') ?>', 'warning');
        }
    } catch (error) {
        showCartMessage(error.message || '<?= __('Invalid promo code') ?>', 'warning');
    }
}

function showCartMessage(message, type) {
    if (window.WeShop && typeof window.WeShop.showNotification === 'function') {
        window.WeShop.showNotification(message, type || 'info');
        return;
    }

    console.error(message);
}
</script>
