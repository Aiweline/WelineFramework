<script>
    (function () {
        var form = document.getElementById('qa-form');
        var submit = document.getElementById('qa-submit');
        var feedback = document.getElementById('qa-feedback');
        var removeButtons = document.querySelectorAll('[data-remove-question]');

        function setFeedback(message, ok) {
            if (!feedback) {
                return;
            }

            feedback.textContent = message || '';
            feedback.classList.remove('text-red-500', 'text-emerald-500');
            feedback.classList.add(ok ? 'text-emerald-500' : 'text-red-500');
        }

        if (form && submit && <?= $canAsk ? 'true' : 'false' ?>) {
            submit.addEventListener('click', function () {
                var payload = {};
                new FormData(form).forEach(function (value, key) {
                    payload[key] = value;
                });

                fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(payload)
                }).then(function (response) {
                    return response.json();
                }).then(function (result) {
                    if (result && result.success) {
                        setFeedback(result.message || '<?= __('Your question has been submitted and is pending review.') ?>', true);
                        form.reset();
                        return;
                    }

                    if (result && result.data && result.data.redirect_url) {
                        window.location.href = result.data.redirect_url;
                        return;
                    }

                    setFeedback((result && result.message) || '<?= __('Unable to submit your question right now.') ?>', false);
                }).catch(function () {
                    setFeedback('<?= __('Unable to submit your question right now.') ?>', false);
                });
            });
        }

        removeButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                var questionId = this.getAttribute('data-remove-question');
                if (!questionId) {
                    return;
                }

                fetch('<?= htmlspecialchars($removeAction, ENT_QUOTES) ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ question_id: questionId })
                }).then(function (response) {
                    return response.json();
                }).then(function (result) {
                    if (result && result.success) {
                        var card = document.querySelector('[data-question-card=\"' + questionId + '\"]');
                        if (card) {
                            card.remove();
                        } else {
                            window.location.reload();
                        }
                        return;
                    }

                    if (result && result.data && result.data.redirect_url) {
                        window.location.href = result.data.redirect_url;
                    }
                });
            });
        });

        if (!<?= $canAsk ? 'true' : 'false' ?> && submit) {
            submit.addEventListener('click', function () {
                window.location.href = '<?= htmlspecialchars($loginUrl, ENT_QUOTES) ?>';
            });
        }
    })();
</script>
