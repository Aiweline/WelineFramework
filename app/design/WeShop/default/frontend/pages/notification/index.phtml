<script>
    (function () {
        var apiPromise = null;

        function getNotificationApi() {
            if (!apiPromise) {
                apiPromise = Promise.resolve(window.Weline.Api.resource('notification'));
            }

            return apiPromise;
        }

        function updateUnreadCount(nextCount) {
            document.querySelectorAll('[data-unread-count]').forEach(function (el) {
                el.textContent = String(nextCount < 0 ? 0 : nextCount);
            });
        }

        document.querySelectorAll('[data-mark-read]').forEach(function (button) {
            button.addEventListener('click', function () {
                var notificationId = this.getAttribute('data-mark-read');
                if (!notificationId) {
                    return;
                }

                getNotificationApi().then(function (NotificationApi) {
                    return NotificationApi.markRead({notification_id: parseInt(notificationId, 10)}, {silent: true});
                }).then(function (payload) {
                    if (!payload) {
                        return;
                    }

                    if (payload.data && payload.data.redirect_url) {
                        window.location.href = payload.data.redirect_url;
                        return;
                    }

                    if (!payload.success) {
                        return;
                    }

                    if (payload.data && typeof payload.data.unread_count !== 'undefined') {
                        updateUnreadCount(parseInt(payload.data.unread_count, 10));
                    }

                    var card = button.closest('[data-notification-item]');
                    if (card) {
                        card.setAttribute('data-notification-read', '1');
                        card.classList.remove('border-primary/50', 'bg-primary/5', 'dark:border-primary/50', 'dark:bg-primary/10');
                        card.classList.add('border-border-light', 'bg-background-light', 'dark:border-border-dark', 'dark:bg-background-dark');
                    }
                    button.remove();
                });
            });
        });
    })();
</script>

