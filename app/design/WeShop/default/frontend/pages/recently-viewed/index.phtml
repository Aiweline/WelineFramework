<script>
    (function () {
        document.querySelectorAll('[data-remove-recently-viewed]').forEach(function (button) {
            button.addEventListener('click', function () {
                var viewId = this.getAttribute('data-remove-recently-viewed');
                if (!viewId) {
                    return;
                }

                fetch('<?= $this->getUrl('recently-viewed/remove') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ view_id: viewId })
                }).then(function (response) {
                    return response.json();
                }).then(function (payload) {
                    if (payload && payload.success) {
                        window.location.reload();
                        return;
                    }

                    if (payload && payload.data && payload.data.redirect_url) {
                        window.location.href = payload.data.redirect_url;
                    }
                });
            });
        });
    })();
</script>
