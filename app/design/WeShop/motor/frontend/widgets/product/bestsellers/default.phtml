<?php
/**
 * Motor theme override for bestseller widget.
 *
 * @var \Weline\Framework\View\Template $this
 */

$title = (string) ($this->getData('title') ?? __('热销产品'));
$subtitle = (string) ($this->getData('subtitle') ?? __('最受欢迎的商品'));
$limit = max(1, (int) ($this->getData('limit') ?? 8));
$showSalesCount = (bool) ($this->getData('show_sales_count') ?? false);
$columns = (string) ($this->getData('columns') ?? '4');
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $price = rand(30, 400);
    $originalPrice = (float) round($price * 1.15, 2);
    $rating = rand(42, 50) / 10;
    $reviewCount = rand(50, 1000);
    $productName = (string) __('热销产品 %d', $i);

    $products[] = [
        'id' => $i,
        'name' => $productName,
        'url' => '/product/best-' . $i,
        'image' => $placeholder,
        'price' => $price,
        'original_price' => $originalPrice,
        'rating' => $rating,
        'review_count' => $reviewCount,
        'sales_count' => rand(100, 5000),
        'rank' => $i,
    ];
}

$widgetId = 'motor-bestsellers-' . uniqid();
$allowedColumns = ['1', '2', '3', '4', '5', '6'];
if (!in_array($columns, $allowedColumns, true)) {
    $columns = '4';
}
?>

<section class="motor-bestsellers-widget" id="<?= htmlspecialchars($widgetId, ENT_QUOTES) ?>">
    <?php if ($title !== '' || $subtitle !== ''): ?>
        <header class="motor-bestsellers-widget__header">
            <div class="motor-bestsellers-widget__eyebrow">
                <span class="motor-bestsellers-widget__eyebrow-mark"></span>
                <span><?= __('Top Picks') ?></span>
            </div>
            <?php if ($title !== ''): ?>
                <h2 class="motor-bestsellers-widget__title font-heading">
                    <?= htmlspecialchars($title, ENT_QUOTES) ?>
                </h2>
            <?php endif; ?>
            <?php if ($subtitle !== ''): ?>
                <p class="motor-bestsellers-widget__subtitle">
                    <?= htmlspecialchars($subtitle, ENT_QUOTES) ?>
                </p>
            <?php endif; ?>
        </header>
    <?php endif; ?>

    <div class="motor-bestsellers-widget__grid motor-bestsellers-widget__grid--<?= htmlspecialchars($columns, ENT_QUOTES) ?>">
        <?php foreach ($products as $product): ?>
            <?php
            $productId = (int) ($product['id'] ?? 0);
            $productName = (string) ($product['name'] ?? '');
            $productUrl = (string) ($product['url'] ?? '#');
            $productImage = (string) ($product['image'] ?? '');
            $productPrice = (float) ($product['price'] ?? 0);
            $productOriginalPrice = (float) ($product['original_price'] ?? 0);
            $productRank = (int) ($product['rank'] ?? 0);
            $productRating = (float) ($product['rating'] ?? 0);
            $reviewCount = (int) ($product['review_count'] ?? 0);
            $salesCount = (int) ($product['sales_count'] ?? 0);
            $hasDiscount = $productOriginalPrice > $productPrice;
            ?>
            <article class="motor-bestsellers-card motor-card">
                <a href="<?= htmlspecialchars($productUrl, ENT_QUOTES) ?>" class="motor-bestsellers-card__media">
                    <?php if ($productRank > 0): ?>
                        <span class="motor-bestsellers-card__rank"><?= sprintf('%02d', $productRank) ?></span>
                    <?php endif; ?>
                    <span class="motor-bestsellers-card__badge motor-badge"><?= __('HOT') ?></span>
                    <?php if ($productImage !== ''): ?>
                        <img src="<?= htmlspecialchars($productImage, ENT_QUOTES) ?>" alt="<?= htmlspecialchars($productName, ENT_QUOTES) ?>" loading="lazy">
                    <?php else: ?>
                        <span class="motor-bestsellers-card__placeholder material-symbols-outlined">image</span>
                    <?php endif; ?>
                </a>

                <div class="motor-bestsellers-card__body">
                    <div class="motor-bestsellers-card__meta">
                        <span class="motor-bestsellers-card__rating">
                            <span class="material-symbols-outlined">star</span>
                            <?= number_format($productRating, 1) ?>
                        </span>
                        <span class="motor-bestsellers-card__reviews">(<?= number_format($reviewCount) ?>)</span>
                        <?php if ($showSalesCount): ?>
                            <span class="motor-bestsellers-card__sales"><?= number_format($salesCount) ?> <?= __('Sold') ?></span>
                        <?php endif; ?>
                    </div>

                    <h3 class="motor-bestsellers-card__name">
                        <a href="<?= htmlspecialchars($productUrl, ENT_QUOTES) ?>">
                            <?= htmlspecialchars($productName, ENT_QUOTES) ?>
                        </a>
                    </h3>

                    <div class="motor-bestsellers-card__price-row">
                        <span class="motor-bestsellers-card__price"><?= $this->formatPrice($productPrice) ?></span>
                        <?php if ($hasDiscount): ?>
                            <span class="motor-bestsellers-card__price-old"><?= $this->formatPrice($productOriginalPrice) ?></span>
                        <?php endif; ?>
                    </div>

                    <button type="button" class="motor-bestsellers-card__action motor-btn-primary" data-product-id="<?= $productId ?>">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <span><?= __('Add to Cart') ?></span>
                    </button>
                </div>
            </article>
        <?php endforeach; ?>
    </div>
</section>
