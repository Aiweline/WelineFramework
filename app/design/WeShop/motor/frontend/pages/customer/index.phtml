$fullName = trim(((string) ($customer['firstname'] ?? '')) . ' ' . ((string) ($customer['lastname'] ?? '')));
if ($fullName === '') {
    $fullName = (string) ($customer['username'] ?? $customer['email'] ?? __('Rider'));
}

$memberSince = trim((string) ($customer['created_at'] ?? ''));
$email = (string) ($customer['email'] ?? '');

$avatarInitial = 'M';
if ($fullName !== '') {
    $avatarInitial = function_exists('mb_substr')
        ? (string) mb_substr($fullName, 0, 1)
        : (string) substr($fullName, 0, 1);
    if ($avatarInitial === '') {
        $avatarInitial = 'M';
    }
}
$avatarInitial = strtoupper($avatarInitial);

$quickLinkIconMap = [
    'compare_arrows' => 'exchange',
    'receipt_long' => 'file-text-o',
    'history' => 'history',
    'favorite' => 'heart',
    'location_on' => 'map-marker',
    'verified_user' => 'shield',
];

$resolveQuickLinkIcon = static function (array $link) use ($quickLinkIconMap): string {
    $rawIcon = trim((string) ($link['icon'] ?? ''));

    if ($rawIcon !== '' && isset($quickLinkIconMap[$rawIcon])) {
        return $quickLinkIconMap[$rawIcon];
    }

    if ($rawIcon !== '' && strpos($rawIcon, 'fa-') === 0) {
        $rawIcon = substr($rawIcon, 3);
    }

    $normalized = preg_replace('/[^a-z0-9\-]/i', '', $rawIcon ?? '');
    return $normalized !== '' ? strtolower($normalized) : 'arrow-right';
};
