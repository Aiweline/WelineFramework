/**
 * 片段：Head - Motor Theme
 * 页面头部区域（meta标签、CSS、JS初始化等）
 * Motor 主题覆盖版本
 */
$themeData = $this->getData('theme') ?? [];

$frontendBaseUrl = $this->request->getUrlBuilder()->getFrontendUrl('/');
?>
<!-- Base URL 设置：所有相对链接将基于此路径 -->
<base href="<?= htmlspecialchars($frontendBaseUrl) ?>">
<!-- Favicon Hook: 允许其他模块通过 hook 提供自定义 favicon -->
<w:hook>Weline_Theme::frontend::partials::head::favicon<else/>
<link rel="icon" type="image/svg+xml" href="@static(Weline_Theme::theme/frontend/assets/img/favicon.svg)">
<link rel="Shortcut Icon" href="@static(Weline_Theme::theme/frontend/assets/img/favicon.svg)">
<link rel="Bookmark" href="@static(Weline_Theme::theme/frontend/assets/img/favicon.svg)">
</w:hook>
<w:seo slot="head"/>
<w:geo slot="head"/>

<w:block class='Weline\Frontend\Block\Header\Base' template='Weline_Frontend::header/base.phtml'/>

<css>Weline_Frontend::/libs/loading/loading.css</css>
<css>Weline_Frontend::/libs/font-awesome-4.7.0/css/font-awesome.min.css</css>
<css>Weline_Frontend::libs/bootstrap-5.1.3-dist/css/bootstrap.min.css</css>
<js>Weline_Frontend::/libs/jquery/3.6.0/jquery.js</js>

<script>
    window.WelineApiConfig = window.WelineApiConfig || {};
    window.WelineApiConfig.workerUrl = window.WelineApiConfig.workerUrl || '@static(Weline_Frontend::js/weline-api-worker.js)';
    window.WelineApiConfig.baseUrl = window.WelineApiConfig.baseUrl || window.location.origin;
    window.WelineApiConfig.cartCountCookieKey = window.WelineApiConfig.cartCountCookieKey || 'weline_cart_item_count';
</script>

<?php
// 注意：jQuery 由 Weline_Frontend 模块通过 asset 系统加载，主题不应重复加载 ?>

<?php
$area = $themeData['area'] ?? 'frontend';
$welineThemeColorMode = $themeData['colorMode'] ?? 'default';
$layoutType = $themeData['layoutType'] ?? null;
$layoutOption = $themeData['layoutOption'] ?? null;
$theme = $themeData['theme'] ?? null;

$isDev = defined('DEV') && DEV;
$baseUrl = $this->request->getBaseUrl();

if ($isDev) {
    $modulesConfigUrl = '/Weline/Frontend/view/statics/base/weline.modules.js';
    $modulesBaseUrl = '/Weline/Frontend/view/statics/js/weline-api';
} else {
    $modulesConfigUrl = '/static/Weline/Frontend/base/weline.modules.js';
    $modulesBaseUrl = '/static/Weline/Frontend/js/weline-api';
}

$currentLang = \w_env('user.lang', 'zh_Hans_CN');
$htmlDir = (string)($this->getData('htmlDir') ?: 'ltr');
$htmlDir = $htmlDir === 'rtl' ? 'rtl' : 'ltr';
$currentCurrency = \w_env('user.currency', 'CNY');
$defaultLang = \w_env('website.language', '') ?: \Weline\Framework\App\Env::get('locale', \Weline\Framework\App\Env::get('lang', 'zh_Hans_CN')) ?: 'zh_Hans_CN';
$defaultCurrency = \w_env('website.currency', '') ?: \Weline\Framework\App\Env::get('currency', 'CNY') ?: 'CNY';
$availableCurrencies = [];
try {
    if (class_exists(\Weline\Websites\Data\WebsiteData::class)) {
        foreach (\Weline\Websites\Data\WebsiteData::getCurrencyCodes() as $currencyCode) {
            $currencyCode = strtoupper(trim((string)$currencyCode));
            if ($currencyCode !== '') {
                $availableCurrencies[] = $currencyCode;
            }
        }
    }
} catch (\Throwable) {
    $availableCurrencies = [];
}
$defaultCurrency = strtoupper(trim((string)$defaultCurrency)) ?: 'CNY';
$availableCurrencies[] = $defaultCurrency;
$availableCurrencies = array_values(array_unique($availableCurrencies));
$currentCurrency = strtoupper(trim((string)$currentCurrency));
if (!\Weline\Framework\App\State::isAllowedCurrencyCode($currentCurrency)) {
    $currentCurrency = $defaultCurrency;
}
$siteName = $this->getData('site_name') ?? __('Weline Framework');

$envConfig = [
    'WELINE_ENV' => DEV ? 'DEV' : 'PROD',
    'DEV' => DEV,
    'PROD' => !DEV,
];

$themeConfigPayload = [
    'env' => $envConfig,
    'baseUrl' => $baseUrl,
    'modulesConfigUrl' => $modulesConfigUrl,
    'modulesBaseUrl' => $modulesBaseUrl,
    'assetVersion' => '20260606-language-flag',
    'currentLang' => $currentLang,
    'currentCurrency' => $currentCurrency,
    'defaultLang' => $defaultLang,
    'defaultCurrency' => $defaultCurrency,
    'availableCurrencies' => $availableCurrencies,
    'htmlDir' => $htmlDir,
    'textDirection' => $htmlDir,
    'isRtl' => $htmlDir === 'rtl',
    'debug' => DEV,
    'i18n' => [
        'currentLang' => $currentLang,
        'defaultLang' => $defaultLang,
        'direction' => $htmlDir,
    ],
    'site' => [
        'name' => $siteName,
    ],
    'theme' => [
        'area' => $area,
        'colorMode' => $welineThemeColorMode,
        'layoutType' => $layoutType,
        'layoutOption' => $layoutOption,
    ],
];

$this->setData('themeConfigPayload', json_encode($themeConfigPayload, JSON_UNESCAPED_UNICODE));
$this->setData('envConfig', $envConfig);
?>
<!-- Theme配置：使用data-no-extract标记，不会被提取到外部JS文件 -->
<script data-no-extract="true">
    (function() {
        if (!window.__WelineThemeConfig) {
            window.__WelineThemeConfig = {};
        }
        const themeConfig = <?= json_encode($themeConfigPayload, JSON_UNESCAPED_UNICODE) ?>;
        Object.assign(window.__WelineThemeConfig, themeConfig);
        const textDirection = themeConfig.htmlDir === 'rtl' || themeConfig.textDirection === 'rtl' ? 'rtl' : 'ltr';
        document.documentElement.setAttribute('dir', textDirection);
        document.documentElement.setAttribute('data-dir', textDirection);
        document.documentElement.classList.toggle('is-rtl', textDirection === 'rtl');
        document.documentElement.classList.toggle('is-ltr', textDirection !== 'rtl');

        if (window.__WelineThemeConfig.modulesConfigUrl) {
            window.modulesConfigUrl = window.__WelineThemeConfig.modulesConfigUrl;
        }
    })();
</script>
<!-- 主题JS -->
<theme:css>Weline_Theme::theme/frontend/assets/css/theme.css</theme:css>
<link rel="stylesheet" href="<?= htmlspecialchars($this->fetchTagSource(\Weline\Framework\View\Data\DataInterface::dir_type_STATICS, 'Weline_Theme::css/remixicon.css')) ?>" type="text/css">
<?php
if (!empty($layoutType) && !empty($layoutOption) && $theme && $theme->getId()) {
    $assetsManager = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Helper\LayoutAssetsManager::class);
    try {
        $assetsManager->ensureLayoutCssGenerated($area, $layoutType, $layoutOption, $theme);
        $cssUrl = $assetsManager->getCssUrl($area, $layoutType, $layoutOption, $theme, $this);
        ?>
<link href="<?= htmlspecialchars($cssUrl) ?>" rel="stylesheet" type="text/css"/>
<?php
    } catch (\Exception $e) {
        if (defined('DEV') && DEV) {
            try {
                $logger = \Weline\Framework\App\Env::getInstance()->getLogger();
                if ($logger) {
                    $logger->error('Motor Theme Head: failed to resolve layout css url', [
                        'layoutType' => $layoutType,
                        'layoutOption' => $layoutOption,
                        'error' => $e->getMessage(),
                    ]);
                }
            } catch (\Exception $logError) {
            }
        }
    }
}
?>
<script src="<?= htmlspecialchars($isDev ? '/Weline/Frontend/view/statics/js/weline-api-fallback.js?v=20260522-dev-cache' : '/static/Weline/Frontend/js/weline-api-fallback.js') ?>"></script>
<script src="<?= htmlspecialchars($isDev ? '/Weline/Theme/view/theme/frontend/assets/js/theme.js?v=20260606-language-flag' : '/static/Weline/Theme/theme/frontend/assets/js/theme.js') ?>"></script>
