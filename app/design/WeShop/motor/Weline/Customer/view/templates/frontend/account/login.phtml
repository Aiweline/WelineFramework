<script>
(function() {
    'use strict';

    var form = document.getElementById('loginForm');
    if (!form) {
        return;
    }

    var loginBtn = document.getElementById('loginBtn');
    var loginText = document.getElementById('loginText');
    var usernameInput = document.getElementById('username');
    var passwordInput = document.getElementById('password');
    var togglePasswordBtn = document.getElementById('togglePassword');
    var togglePasswordIconWrap = togglePasswordBtn ? togglePasswordBtn.querySelector('.motor-password-toggle-icon') : null;
    var defaultLoginText = loginText ? loginText.textContent : '';
    var showPasswordText = <?= json_encode((string) __('显示密码'), JSON_UNESCAPED_UNICODE) ?>;
    var hidePasswordText = <?= json_encode((string) __('隐藏密码'), JSON_UNESCAPED_UNICODE) ?>;
    var defaultErrorText = <?= json_encode((string) __('登录失败，请检查用户名和密码'), JSON_UNESCAPED_UNICODE) ?>;
    var requestErrorText = <?= json_encode((string) __('登录请求失败，请稍后重试'), JSON_UNESCAPED_UNICODE) ?>;

    function decodeHtmlEntities(message) {
        var decoded = String(message || '');
        var helper = document.createElement('textarea');

        for (var i = 0; i < 3; i++) {
            helper.innerHTML = decoded;

            if (!helper.value || helper.value === decoded) {
                break;
            }

            decoded = helper.value;
        }

        return decoded;
    }

    function showError(message) {
        clearError();

        var firstField = form.querySelector('.motor-field') || form.firstChild;
        var alertEl = document.createElement('div');
        var iconEl = document.createElement('i');
        var textEl = document.createElement('span');
        var readableMessage = decodeHtmlEntities(message || defaultErrorText);

        alertEl.className = 'motor-alert';
        alertEl.setAttribute('role', 'alert');
        iconEl.className = 'fa fa-exclamation-circle';
        textEl.textContent = readableMessage;

        alertEl.appendChild(iconEl);
        alertEl.appendChild(textEl);
        form.insertBefore(alertEl, firstField);

        if (typeof alertEl.scrollIntoView === 'function') {
            alertEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    }

    function clearError() {
        var existing = form.querySelector('.motor-alert');
        if (existing) {
            existing.remove();
        }
    }

    function resetSubmitState() {
        loginBtn.disabled = false;
        loginBtn.classList.remove('is-loading');
        loginBtn.classList.remove('is-success');
        loginText.style.visibility = 'visible';
        loginText.textContent = defaultLoginText;
    }

    function setPasswordVisible(visible) {
        if (!passwordInput || !togglePasswordBtn) {
            return;
        }

        passwordInput.type = visible ? 'text' : 'password';
        togglePasswordBtn.setAttribute('aria-label', visible ? hidePasswordText : showPasswordText);
        togglePasswordBtn.setAttribute('title', visible ? hidePasswordText : showPasswordText);
        if (togglePasswordIconWrap) {
            var svgShow = togglePasswordIconWrap.querySelector('.motor-pwd-svg--show');
            var svgHide = togglePasswordIconWrap.querySelector('.motor-pwd-svg--hide');
            if (svgShow && svgHide) {
                if (visible) {
                    svgShow.setAttribute('hidden', 'hidden');
                    svgHide.removeAttribute('hidden');
                } else {
                    svgShow.removeAttribute('hidden');
                    svgHide.setAttribute('hidden', 'hidden');
                }
            }
        }
    }

    if (togglePasswordBtn) {
        togglePasswordBtn.addEventListener('click', function() {
            setPasswordVisible(passwordInput.type === 'password');
        });
    }

    if (usernameInput) {
        usernameInput.addEventListener('input', clearError);
    }

    if (passwordInput) {
        passwordInput.addEventListener('input', clearError);
    }

    function normalizeLoginPayload(raw) {
        if (raw == null) {
            return null;
        }
        if (typeof raw === 'object' && raw !== null && !Array.isArray(raw)) {
            if (
                typeof raw.success !== 'undefined' ||
                typeof raw.redirect !== 'undefined' ||
                raw.status === 'authenticated' ||
                raw.status === 'challenge_required'
            ) {
                return raw;
            }
            if (raw.data && typeof raw.data === 'object') {
                return normalizeLoginPayload(raw.data);
            }
        }
        if (typeof raw === 'string') {
            var t = raw.trim();
            if (t.charAt(0) === '{' || t.charAt(0) === '[') {
                try {
                    return normalizeLoginPayload(JSON.parse(t));
                } catch (e) {
                    return null;
                }
            }
        }
        return null;
    }

    function isLoginSuccessPayload(payload) {
        if (!payload || typeof payload !== 'object') {
            return false;
        }
        if (payload.success === true || payload.success === 'true') {
            return true;
        }
        return payload.status === 'authenticated';
    }

    form.addEventListener('submit', function(event) {
        event.preventDefault();
        clearError();

        loginBtn.classList.remove('is-success');
        loginText.textContent = defaultLoginText;

        if (!usernameInput.value.trim()) {
            showError(<?= json_encode((string) __('请输入用户名或邮箱'), JSON_UNESCAPED_UNICODE) ?>);
            usernameInput.focus();
            return;
        }

        if (!passwordInput.value) {
            showError(<?= json_encode((string) __('请输入密码'), JSON_UNESCAPED_UNICODE) ?>);
            passwordInput.focus();
            return;
        }

        loginBtn.disabled = true;
        loginBtn.classList.add('is-loading');
        loginText.style.visibility = 'hidden';

        var formData = new FormData(form);
        var serialized = new URLSearchParams(formData).toString();

        window.Weline.Api.request('/customer/account/login', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json, text/javascript, */*;q=0.01'
            },
            body: serialized,
            credentials: 'same-origin'
        })
        .then(function(response) {
            var data = normalizeLoginPayload(response.data);

            if (response.ok && isLoginSuccessPayload(data)) {
                loginBtn.classList.remove('is-loading');
                loginBtn.classList.add('is-success');
                loginText.textContent = <?= json_encode((string) __('登录成功！'), JSON_UNESCAPED_UNICODE) ?>;
                loginText.style.visibility = 'visible';

                setTimeout(function() {
                    window.location.href = (data && data.redirect) || '/customer/account';
                }, 700);

                return;
            }

            handleError((data && data.message) || defaultErrorText);
        })
        .catch(function(error) {
            var errData = error && error.response ? error.response.data : null;
            var parsed = normalizeLoginPayload(errData);
            var message = (parsed && parsed.message) ||
                (errData && typeof errData === 'object' && errData.message) ||
                (error && error.message) ||
                requestErrorText;
            handleError(message);
        });
    });

    function handleError(message) {
        resetSubmitState();
        showError(message);
    }
})();
</script>
