<script>
(function() {
    'use strict';

    var navLinks = Array.prototype.slice.call(document.querySelectorAll('[data-account-nav-link][data-section]'));
    var actionButtons = Array.prototype.slice.call(document.querySelectorAll('[data-target-section]'));
    var sections = Array.prototype.slice.call(document.querySelectorAll('[data-account-section]'));
    var profileForm = document.getElementById('profileForm');
    var securityForm = document.getElementById('securityForm');
    var avatarInput = document.getElementById('avatar');
    var avatarPreview = document.getElementById('avatarPreview');
    var avatarFallback = document.getElementById('avatarFallback');
    var profileSubmit = document.getElementById('profileSubmit');
    var securitySubmit = document.getElementById('securitySubmit');
    /** 与侧栏 href 同源，禁止仅用 #section 调用 replaceState（否则地址栏易变成 /#xxx） */
    var accountSectionUrlBase = <?= json_encode($accountIndexPathJs, JSON_UNESCAPED_UNICODE) ?>;
    var showPasswordText = <?= json_encode((string) __('显示密码'), JSON_UNESCAPED_UNICODE) ?>;
    var hidePasswordText = <?= json_encode((string) __('隐藏密码'), JSON_UNESCAPED_UNICODE) ?>;
    var updateFailedText = <?= json_encode((string) __('更新失败，请稍后重试'), JSON_UNESCAPED_UNICODE) ?>;
    var securityUpdateFailedText = <?= json_encode((string) __('修改失败，请稍后重试'), JSON_UNESCAPED_UNICODE) ?>;

    var sidebarContentMount = document.querySelector('[data-account-sidebar-content-mount]');
    var sidebarContentLoaded = !sidebarContentMount;
    var sidebarContentLoading = null;

    function refreshAccountSections() {
        sections = Array.prototype.slice.call(document.querySelectorAll('[data-account-section]'));
    }

    function executeInsertedScripts(container) {
        Array.prototype.slice.call(container.querySelectorAll('script')).forEach(function(oldScript) {
            var script = document.createElement('script');
            Array.prototype.slice.call(oldScript.attributes).forEach(function(attribute) {
                script.setAttribute(attribute.name, attribute.value);
            });
            script.text = oldScript.textContent || '';
            oldScript.parentNode.replaceChild(script, oldScript);
        });
    }

    function loadSidebarContent() {
        if (!sidebarContentMount || sidebarContentLoaded) {
            return Promise.resolve(true);
        }

        if (sidebarContentLoading) {
            return sidebarContentLoading;
        }

        var url = sidebarContentMount.getAttribute('data-account-sidebar-content-url') || '';
        if (!url) {
            sidebarContentLoaded = true;
            return Promise.resolve(false);
        }

        sidebarContentLoading = fetch(url, {
            credentials: 'same-origin',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        }).then(function(response) {
            if (!response.ok) {
                throw new Error('Account sections request failed: ' + response.status);
            }
            return response.json();
        }).then(function(payload) {
            if (!payload || payload.success === false) {
                if (payload && payload.redirect) {
                    window.location.href = payload.redirect;
                }
                return false;
            }

            sidebarContentMount.innerHTML = payload.html || '';
            executeInsertedScripts(sidebarContentMount);
            sidebarContentLoaded = true;
            refreshAccountSections();
            window.dispatchEvent(new CustomEvent('weline:account-sidebar-content-loaded', {
                detail: { length: payload.length || 0 }
            }));
            return true;
        }).catch(function(error) {
            sidebarContentLoading = null;
            console.error(error);
            return false;
        });

        return sidebarContentLoading;
    }

    function decodeHtmlEntities(message) {
        var s = String(message || '');
        if (s.indexOf('&') === -1) {
            return s;
        }
        var div = document.createElement('div');
        var prev;
        for (var i = 0; i < 5; i++) {
            prev = s;
            div.innerHTML = s;
            s = div.textContent || div.innerText || '';
            if (s === prev || s.indexOf('&') === -1) {
                break;
            }
        }
        return s;
    }

    function setMessage(element, message) {
        if (!element) {
            return;
        }

        if (!message) {
            element.textContent = '';
            element.hidden = true;
            return;
        }

        element.textContent = decodeHtmlEntities(message);
        element.hidden = false;
    }

    function clearMessagePair(successElement, errorElement) {
        setMessage(successElement, '');
        setMessage(errorElement, '');
    }

    function setButtonLoading(button, loading) {
        if (!button) {
            return;
        }

        button.classList.toggle('is-loading', loading);
        button.disabled = loading;
    }

    var accountApiPromise = null;

    function getAccountApi() {
        if (!accountApiPromise) {
            if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                accountApiPromise = window.Weline.Api.resource('account');
            } else if (window.Weline && typeof window.Weline.load === 'function') {
                accountApiPromise = window.Weline.load('api').then(function() {
                    if (!window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
                        throw new Error('Weline.Api is unavailable.');
                    }
                    return window.Weline.Api.resource('account');
                });
            } else {
                accountApiPromise = Promise.reject(new Error('Weline.Api is unavailable.'));
            }
        }
        return accountApiPromise;
    }

    function formDataToObject(formData) {
        var payload = {};
        formData.forEach(function(value, key) {
            payload[key] = value;
        });
        delete payload.form_key;
        return payload;
    }

    function parseQueryString(queryString) {
        var normalized = String(queryString || '').replace(/^[?#]/, '');
        var query = {};
        if (!normalized) {
            return query;
        }

        try {
            var parsed = new URLSearchParams(normalized);
            parsed.forEach(function (value, key) {
                query[String(key)] = String(value);
            });
        } catch (error) {}

        return query;
    }

    function parseHash(inputHash) {
        var rawHash = String(inputHash || '');
        if (!rawHash) {
            return { section: '', query: {} };
        }

        var trimmed = rawHash.replace(/^.*#/, '');
        if (!trimmed) {
            return { section: '', query: {} };
        }

        var section = trimmed;
        var query = {};
        var splitAt = trimmed.indexOf('?');

        if (splitAt !== -1) {
            section = trimmed.substring(0, splitAt);
            var queryString = trimmed.substring(splitAt + 1);
            if (queryString) {
                try {
                    var parsed = new URLSearchParams(queryString);
                    parsed.forEach(function (value, key) {
                        query[String(key)] = String(value);
                    });
                } catch (error) {}
            }
        }

        return {
            section: section,
            query: query
        };
    }

    function parseAccountState() {
        var hashState = parseHash(window.location.hash || '');
        var searchQuery = parseQueryString(window.location.search || '');
        var mergedQuery = {};

        Object.keys(searchQuery).forEach(function (key) {
            mergedQuery[key] = searchQuery[key];
        });
        Object.keys(hashState.query).forEach(function (key) {
            if (!(key in mergedQuery)) {
                mergedQuery[key] = hashState.query[key];
            }
        });

        return {
            section: hashState.section,
            query: mergedQuery
        };
    }

    function getNavTarget(link) {
        var targetId = link.getAttribute('data-section') || '';
        var query = parseQueryString(window.location.search || '');

        try {
            var targetUrl = new URL(link.getAttribute('href') || '', window.location.origin);
            var hashInfo = parseHash(targetUrl.hash || '');
            if (hashInfo.section) {
                targetId = hashInfo.section;
            }

            Object.assign(query, parseQueryString(targetUrl.search || ''), hashInfo.query || {});
        } catch (error) {
            var fallbackHashInfo = parseHash(link.getAttribute('href') || '');
            if (fallbackHashInfo.section) {
                targetId = fallbackHashInfo.section;
            }
            Object.assign(query, fallbackHashInfo.query || {});
        }

        return {
            section: targetId,
            query: query
        };
    }

    function hasNavSection(section) {
        if (!section) {
            return false;
        }

        return !!(
            document.querySelector('[data-account-section="' + section + '"]')
            || document.getElementById(section + '-section')
        );
    }

    function updateHash(section, query) {
        if (window.history && typeof window.history.replaceState === 'function') {
            var nextUrl = new URL(window.location.href);
            nextUrl.pathname = accountSectionUrlBase;
            if (query && typeof query === 'object') {
                Object.keys(query).forEach(function (key) {
                    var value = query[key];
                    if (value === '' || value === null || value === undefined) {
                        nextUrl.searchParams.delete(key);
                        return;
                    }

                    nextUrl.searchParams.set(key, String(value));
                });
            }
            nextUrl.hash = '#' + section;
            window.history.replaceState(null, '', nextUrl.pathname + nextUrl.search + nextUrl.hash);
        }
    }

    function applyReturnAnchor(query) {
        if (!query || !query.return_anchor) {
            return;
        }

        var anchor = document.getElementById(String(query.return_anchor));
        if (anchor && typeof anchor.scrollIntoView === 'function') {
            anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    function request(operation, payload) {
        return getAccountApi().then(function(AccountApi) {
            return AccountApi[operation](payload, {
                silent: true
            });
        }).then(function(data) {
            return { ok: data && data.success !== false, data: data };
        });
    }

    function setActiveNavLink(sectionName) {
        navLinks.forEach(function(link) {
            var isActive = link.getAttribute('data-section') === sectionName;
            link.classList.toggle('is-active', isActive);
            if (link.classList.contains('motor-account-sidebar__link')) {
                link.classList.toggle('motor-account-sidebar__link--active', isActive);
            }
        });
    }

    function showSection(sectionName, shouldScroll, query) {
        sectionName = sectionName || 'overview';

        if (!hasNavSection(sectionName) && sidebarContentMount && !sidebarContentLoaded) {
            return loadSidebarContent().then(function() {
                return showSection(sectionName, shouldScroll, query);
            });
        }

        if (!hasNavSection(sectionName)) {
            sectionName = 'overview';
        }

        var targetId = sectionName + '-section';
        var targetSection = document.querySelector('[data-account-section="' + sectionName + '"]');
        if (!targetSection) {
            targetSection = document.getElementById(targetId);
        }

        sections.forEach(function(section) {
            var isTarget = section === targetSection;
            section.hidden = !isTarget;
            section.classList.toggle('d-none', !isTarget);
        });

        setActiveNavLink(sectionName);
        if (window.history && typeof window.history.replaceState === 'function') {
            updateHash(sectionName, query);
        }

        if (sectionName === 'orders') {
            applyReturnAnchor(query);
        }

        if (shouldScroll) {
            var targetSection = document.getElementById(targetId);
            if (targetSection && typeof targetSection.scrollIntoView === 'function') {
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
    }

    function syncFromHash() {
        var parsed = parseAccountState();
        var targetId = parsed.section || 'overview';
        if (!hasNavSection(targetId) && (!sidebarContentMount || sidebarContentLoaded)) {
            targetId = 'overview';
        }

        showSection(targetId, false, parsed.query);
        applyReturnAnchor(parsed.query);
    }

    navLinks.forEach(function(link) {
        link.addEventListener('click', function(event) {
            event.preventDefault();
            var navTarget = getNavTarget(link);
            showSection(navTarget.section, true, navTarget.query);
            updateHash(navTarget.section, navTarget.query);
        });
    });

    actionButtons.forEach(function(button) {
        button.addEventListener('click', function() {
            showSection(button.getAttribute('data-target-section'), true);
        });
    });

    syncFromHash();
    window.addEventListener('hashchange', syncFromHash);

    function updateAvatarPreview() {
        if (!avatarPreview || !avatarFallback) {
            return;
        }

        var url = avatarInput ? avatarInput.value.trim() : '';
        if (!url) {
            avatarPreview.hidden = true;
            avatarPreview.removeAttribute('src');
            avatarFallback.style.display = 'flex';
            return;
        }

        avatarPreview.hidden = false;
        avatarPreview.src = url;
        avatarFallback.style.display = 'none';
    }

    if (avatarInput) {
        avatarInput.addEventListener('input', function() {
            var profileError = document.getElementById('profileErrorMsg');
            if (profileError) {
                profileError.hidden = true;
            }
        });
    }

    var previewAvatarBtn = document.getElementById('previewAvatarBtn');
    if (previewAvatarBtn) {
        previewAvatarBtn.addEventListener('click', updateAvatarPreview);
    }

    document.querySelectorAll('[data-account-password]').forEach(function(button) {
        var target = document.querySelector(button.getAttribute('data-account-password'));
        if (!target) {
            return;
        }

        button.setAttribute('aria-label', showPasswordText);
        button.addEventListener('click', function() {
            var visible = target.type === 'password';
            var icon = button.querySelector('i');
            target.type = visible ? 'text' : 'password';
            button.setAttribute('aria-label', visible ? hidePasswordText : showPasswordText);
            if (icon) {
                icon.className = visible ? 'fa fa-eye-slash' : 'fa fa-eye';
            }
        });
    });

    if (profileForm) {
        profileForm.addEventListener('submit', function(event) {
            event.preventDefault();

            var successMsg = document.getElementById('profileSuccessMsg');
            var errorMsg = document.getElementById('profileErrorMsg');
            clearMessagePair(successMsg, errorMsg);
            setButtonLoading(profileSubmit, true);

            var serialized = formDataToObject(new FormData(profileForm));
            request('updateProfile', serialized)
            .then(function(response) {
                var data = response.data || {};
                if (response.ok && data.success) {
                    setMessage(successMsg, data.message || <?= json_encode((string) __('更新成功'), JSON_UNESCAPED_UNICODE) ?>);
                    updateAvatarPreview();
                    return;
                }

                setMessage(errorMsg, data.message || updateFailedText);
            })
            .catch(function(error) {
                setMessage(errorMsg, (error && error.message) || updateFailedText);
            })
            .finally(function() {
                setButtonLoading(profileSubmit, false);
            });
        });
    }

    if (securityForm) {
        securityForm.addEventListener('submit', function(event) {
            event.preventDefault();

            var successMsg = document.getElementById('securitySuccessMsg');
            var errorMsg = document.getElementById('securityErrorMsg');
            var oldPassword = document.getElementById('old_password');
            var newPassword = document.getElementById('new_password');
            var confirmPassword = document.getElementById('confirm_password');

            clearMessagePair(successMsg, errorMsg);

            if (!oldPassword.value || !newPassword.value || !confirmPassword.value) {
                setMessage(errorMsg, <?= json_encode((string) __('请填写所有密码字段'), JSON_UNESCAPED_UNICODE) ?>);
                return;
            }

            if (newPassword.value.length < 6) {
                setMessage(errorMsg, <?= json_encode((string) __('新密码长度不能少于 6 位'), JSON_UNESCAPED_UNICODE) ?>);
                newPassword.focus();
                return;
            }

            if (newPassword.value !== confirmPassword.value) {
                setMessage(errorMsg, <?= json_encode((string) __('两次输入的新密码不一致'), JSON_UNESCAPED_UNICODE) ?>);
                confirmPassword.focus();
                return;
            }

            setButtonLoading(securitySubmit, true);

            var serialized = formDataToObject(new FormData(securityForm));
            request('updatePassword', serialized)
            .then(function(response) {
                var data = response.data || {};
                if (response.ok && data.success) {
                    setMessage(successMsg, data.message || <?= json_encode((string) __('修改成功'), JSON_UNESCAPED_UNICODE) ?>);
                    securityForm.reset();
                    return;
                }

                setMessage(errorMsg, data.message || securityUpdateFailedText);
            })
            .catch(function(error) {
                setMessage(errorMsg, (error && error.message) || securityUpdateFailedText);
            })
            .finally(function() {
                setButtonLoading(securitySubmit, false);
            });
        });
    }
})();
</script>
