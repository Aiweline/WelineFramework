            </span>
        </a>

        <w:hook name="account.sidebar"/>

        <a class="motor-account-sidebar__link motor-account-sidebar__link--logout" href="<?= htmlspecialchars($accountLogoutPath, ENT_QUOTES, 'UTF-8') ?>" data-account-logout-confirm>
            <span class="motor-account-sidebar__link-label">
                <i class="fa fa-sign-out"></i>
                <span class="motor-account-sidebar__link-text">
