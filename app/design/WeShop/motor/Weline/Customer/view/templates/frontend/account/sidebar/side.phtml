<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \Weline\Customer\Model\Customer $user */
$user = $user ?? $this->getData('user');
if (!$user instanceof \Weline\Customer\Model\Customer) {
    try {
        $sessionUser = \Weline\Framework\Session\SessionFactory::getInstance()->createFrontendSession()->getUser();
        if ($sessionUser instanceof \Weline\Customer\Model\Customer) {
            $user = $sessionUser;
        }
    } catch (\Throwable) {
    }
}
$avatar = is_object($user) && method_exists($user, 'getAvatar') ? (string)($user->getAvatar() ?? '') : '';
$username = is_object($user) && method_exists($user, 'getUsername') ? (string)($user->getUsername() ?? '') : '';
$email = is_object($user) && method_exists($user, 'getEmail') ? (string)($user->getEmail() ?? '') : '';
if ($username === '' && $email !== '') {
    $username = $email;
}
$avatarInitial = $username !== '' ? strtoupper(mb_substr($username, 0, 1)) : '?';
$accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
if (!is_string($accountIndexPath) || $accountIndexPath === '') {
    $accountIndexPath = '/customer/account/index';
}
$accountIndexPath = rtrim($accountIndexPath, '/');
$accountLogoutPath = parse_url($this->getFrontendUrl('customer/account/logout'), PHP_URL_PATH);
if (!is_string($accountLogoutPath) || $accountLogoutPath === '') {
    $accountLogoutPath = '/customer/account/logout';
}
$accountSidebarAssetVersion = '20260522-account-logout-confirm-1';
$accountLogoutConfigJson = json_encode([
    'title' => (string) __('退出登录'),
    'message' => (string) __('确定要退出登录吗？'),
    'confirmText' => (string) __('确认退出'),
    'cancelText' => (string) __('取消'),
], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);
if (!is_string($accountLogoutConfigJson) || $accountLogoutConfigJson === '') {
    $accountLogoutConfigJson = '{}';
}
?>
<script id="weline-account-logout-config" type="application/json"><?= $accountLogoutConfigJson ?></script>
<script src="@static(Weline_Customer::js/account-logout.js)?v=<?= $accountSidebarAssetVersion ?>" defer></script>
<div class="motor-account-sidebar">
    <header class="motor-account-sidebar__header">
        <div class="motor-account-sidebar__avatar">
            <?php if ($avatar): ?>
                <img src="<?= htmlspecialchars($avatar) ?>" alt="<?= htmlspecialchars($username) ?>" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="motor-account-sidebar__avatar-fallback" style="display:none"><?= htmlspecialchars($avatarInitial) ?></div>
            <?php else: ?>
                <div class="motor-account-sidebar__avatar-fallback"><?= htmlspecialchars($avatarInitial) ?></div>
            <?php endif; ?>
        </div>

        <div class="motor-account-sidebar__meta">
            <div class="motor-account-sidebar__badge">
                <i class="fa fa-motorcycle"></i>
                <lang>Motor 会员</lang>
            </div>
            <h3 class="motor-account-sidebar__username"><?= htmlspecialchars($username) ?></h3>
            <?php if ($email): ?>
                <p class="motor-account-sidebar__email"><?= htmlspecialchars($email) ?></p>
            <?php endif; ?>
            <p class="motor-account-sidebar__subtext"><lang>资料、密码与登录状态都可以在这里快速管理。</lang></p>
        </div>
    </header>

    <nav class="motor-account-sidebar__nav">
        <a class="motor-account-sidebar__link motor-account-sidebar__link--active" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#overview" data-section="overview" data-account-nav-link="true">
            <span class="motor-account-sidebar__link-label">
                <i class="fa fa-dashboard"></i>
