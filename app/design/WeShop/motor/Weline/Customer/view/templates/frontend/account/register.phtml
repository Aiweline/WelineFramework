<script>
(function() {
    'use strict';

    var form = document.getElementById('registerForm');
    if (!form) {
        return;
    }

    var errorBox = document.getElementById('registerError');
    var errorText = document.getElementById('registerErrorText');
    var passwordInput = document.getElementById('password');
    var confirmPasswordInput = document.getElementById('confirm_password');
    var submitBtn = document.getElementById('registerSubmit');
    var showPasswordText = <?= json_encode((string) __('显示密码'), JSON_UNESCAPED_UNICODE) ?>;
    var hidePasswordText = <?= json_encode((string) __('隐藏密码'), JSON_UNESCAPED_UNICODE) ?>;

    function showError(message) {
        errorText.textContent = String(message || '');
        errorBox.hidden = false;
    }

    function clearError() {
        errorText.textContent = '';
        errorBox.hidden = true;
    }

    function setToggleState(button, visible) {
        var icon = button.querySelector('i');
        button.setAttribute('aria-label', visible ? hidePasswordText : showPasswordText);
        if (icon) {
            icon.className = visible ? 'fa fa-eye-slash' : 'fa fa-eye';
        }
    }

    document.querySelectorAll('[data-toggle-password]').forEach(function(button) {
        var target = document.querySelector(button.getAttribute('data-toggle-password'));
        if (!target) {
            return;
        }

        setToggleState(button, false);
        button.addEventListener('click', function() {
            var visible = target.type === 'password';
            target.type = visible ? 'text' : 'password';
            setToggleState(button, visible);
        });
    });

    form.addEventListener('input', clearError);

    form.addEventListener('submit', function(event) {
        clearError();

        if (passwordInput.value.length < 8) {
            event.preventDefault();
            showError(<?= json_encode((string) __('密码长度至少需要 8 位'), JSON_UNESCAPED_UNICODE) ?>);
            passwordInput.focus();
            return;
        }

        if (passwordInput.value !== confirmPasswordInput.value) {
            event.preventDefault();
            showError(<?= json_encode((string) __('两次输入的密码不一致'), JSON_UNESCAPED_UNICODE) ?>);
            confirmPasswordInput.focus();
            return;
        }

        submitBtn.classList.add('is-loading');
        submitBtn.disabled = true;
    });
})();
</script>
