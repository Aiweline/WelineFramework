$normalizeFlashMessage = static function (string $message): string {
    $decoded = html_entity_decode($message, ENT_QUOTES | ENT_HTML5, 'UTF-8');
    $plain = trim(strip_tags($decoded));
    // 兼容 Bootstrap alert close 文案残留（例如 "Close 操作成功！..."）
    $plain = preg_replace('/^\s*close\s*/i', '', $plain) ?? $plain;
    $plain = preg_replace('/\s+/', ' ', $plain) ?? $plain;
    return trim($plain);
};

$successMessage = $normalizeFlashMessage($rawSuccessMessage);
$serverErrorMessage = $normalizeFlashMessage($rawServerErrorMessage);
