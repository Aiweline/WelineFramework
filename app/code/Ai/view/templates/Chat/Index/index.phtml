<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ai we line Ai助手集合。</title>
    <link rel="stylesheet" href="@static(chat/css/monokai-sublime.css)">
    <link rel="stylesheet" href="@static(chat/css/chat.css?v=03240800)">
    <link rel="shortcut icon" href="@static(Weline_Frontend::img/favicon.png)"/>
</head>
<body>
<div id="app">
    <div>
        AI模型选择：
        <select id="model" style="height:45px;border:1px silver solid;background:transparent;padding;1rem" onchange="changeModel()">
            <foreach name="models">
                <option value="{{v.model_id}}"><lang>厂商：</lang>{{v.vendor}}-<lang>产品：</lang>{{v.product}}-<lang>模型:</lang>{{v.model}}</lang></option>
            </foreach>
        </select>
    </div>
    <div class="messages-container" style="padding-top:8rem;">
        <div id="messages"></div>
    </div>
    <div class="input-area">
        <textarea id="input" placeholder="说几句吧……"></textarea>
        <button id="send" onclick="sendMessage()" data-url="@url('*/v1/chat/completions')"><lang>发送</lang></button>
    </div>

    <div style="    position: fixed;
    top: 10px;
    right: 10px;
    display: flex;
    gap: 1rem;
    align-items: center;padding: 16px 16px;
    background-color: #e2e9f4;
    border-radius: var(--border-radius);">
        <lang>功能支持框架WelineFramework.</lang>
        <a style="    display: flex;
    align-items: center;
    gap: 1rem;"
                href="https://github.com/Aiweline/WelineFramework" target="_blank">
            <svg height="32" aria-hidden="true" viewBox="0 0 16 16" version="1.1" width="32" data-view-component="true" class="octicon octicon-mark-github v-align-middle color-fg-default">
                <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path>
            </svg></a>
        <a style="    display: flex;
    align-items: center;
    gap: 1rem;"
                href="https://gitee.com/aiweline/WelineFramework" target="_blank">
            <img style="height:32px" src="https://gitee.com/static/images/logo-black.svg?t=158106664" alt=""></a>
    </div>

</div>
<script src="@static(chat/js/marked.min.js)"></script>
<script src="@static(chat/js/highlight.min.js)"></script>
<script src="@static(chat/js/chat.js?v=03240800)"></script>
</body>
</html>
