<script>
(function() {
    'use strict';
    
    var API_URLS = {
        getConfig: '<?= $this->getUrl("shopify/backend/config/getFeishuData") ?>',
        saveConfig: '<?= $this->getUrl("shopify/backend/config/saveFeishu") ?>',
        testConnection: '<?= $this->getUrl("shopify/backend/config/testFeishu") ?>'
    };
    
    function init() {
        loadFeishuConfig();
        bindEvents();
    }
    
    function bindEvents() {
        document.getElementById('feishuConfigForm').addEventListener('submit', function(e) {
            e.preventDefault();
            saveFeishuConfig();
        });
        
        document.getElementById('testConnectionBtn').addEventListener('click', testFeishuConnection);
    }
    
    function loadFeishuConfig() {
        fetch(API_URLS.getConfig)
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data && data.code === 0 && data.data) {
                    var config = data.data;
                    document.querySelector('input[name="webhook_url"]').value = config.webhook_url || '';
                    document.querySelector('input[name="secret"]').value = config.secret || '';
                    document.querySelector('input[name="enable_error_notify"]').checked = config.enable_error_notify == 1;
                    document.querySelector('input[name="enable_overdue_notify"]').checked = config.enable_overdue_notify == 1;
                    
                    if (config.notify_keywords && Array.isArray(config.notify_keywords)) {
                        document.querySelector('textarea[name="notify_keywords"]').value = config.notify_keywords.join('\n');
                    }
                }
            })
            .catch(function(error) {
                console.error('加载配置失败:', error);
            });
    }
    
    function saveFeishuConfig() {
        var form = document.getElementById('feishuConfigForm');
        var submitBtn = form.querySelector('button[type="submit"]');
        var originalText = submitBtn.innerHTML;
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...';
        
        var formData = new FormData(form);
        
        fetch(API_URLS.saveConfig, { method: 'POST', body: formData })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.code === 0) {
                    showMessage('success', '✅ 飞书配置保存成功！');
                    setTimeout(loadFeishuConfig, 500);
                } else {
                    showMessage('error', '❌ 保存失败：' + (data.msg || '未知错误'));
                }
            })
            .catch(function(error) {
                showMessage('error', '❌ 保存失败：网络错误');
            })
            .finally(function() {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });
    }
    
    function testFeishuConnection() {
        var testBtn = document.getElementById('testConnectionBtn');
        var originalText = testBtn.innerHTML;
        
        testBtn.disabled = true;
        testBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>测试中...';
        
        fetch(API_URLS.testConnection, { method: 'POST' })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.code === 0) {
                    showMessage('success', '✅ 飞书连接测试成功！');
                } else {
                    showMessage('error', '❌ 连接测试失败：' + (data.msg || '未知错误'));
                }
            })
            .catch(function(error) {
                showMessage('error', '❌ 连接测试失败：网络错误');
            })
            .finally(function() {
                testBtn.disabled = false;
                testBtn.innerHTML = originalText;
            });
    }
    
    function showMessage(type, message) {
        var existingToast = document.querySelector('.message-toast');
        if (existingToast) existingToast.remove();
        
        var alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
        var icon = type === 'success' ? 'mdi-check-circle' : 'mdi-alert-circle';
        
        var messageHtml = document.createElement('div');
        messageHtml.className = 'alert ' + alertClass + ' alert-dismissible fade show message-toast';
        messageHtml.setAttribute('role', 'alert');
        messageHtml.innerHTML = '<i class="mdi ' + icon + ' me-2"></i>' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        
        var form = document.getElementById('feishuConfigForm');
        form.parentNode.insertBefore(messageHtml, form);
        
        setTimeout(function() {
            var toast = document.querySelector('.message-toast');
            if (toast) toast.style.opacity = '0';
        }, 3000);
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
