<script>
$(document).ready(function() {
    // 加载现有配置
    loadFeishuConfig();
    
    // 表单提交处理
    $('#feishuConfigForm').on('submit', function(e) {
        e.preventDefault();
        saveFeishuConfig();
    });
});

// 加载飞书配置
function loadFeishuConfig() {
    fetch('<?= $this->getUrl("shopify/backend/config/getFeishuData") ?>')
        .then(response => response.json())
        .then(data => {
            console.log('加载配置数据:', data);
            if (data && data.code === 0 && data.data) {
                const config = data.data;
                
                // 填充表单数据
                $('input[name="webhook_url"]').val(config.webhook_url || '');
                $('input[name="secret"]').val(config.secret || '');
                $('input[name="enable_error_notify"]').prop('checked', config.enable_error_notify == 1);
                $('input[name="enable_overdue_notify"]').prop('checked', config.enable_overdue_notify == 1);
                
                // 填充关键词
                if (config.notify_keywords && Array.isArray(config.notify_keywords)) {
                    $('textarea[name="notify_keywords"]').val(config.notify_keywords.join('\n'));
                }
            } else {
                console.log('没有找到配置数据或数据格式错误');
            }
        })
        .catch(error => {
            console.error('加载配置失败:', error);
        });
}

// 保存飞书配置
function saveFeishuConfig() {
    const formData = new FormData($('#feishuConfigForm')[0]);
    
    // 显示加载状态
    const submitBtn = $('#feishuConfigForm button[type="submit"]');
    const originalText = submitBtn.html();
    submitBtn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...');
    
    fetch('<?= $this->getUrl("shopify/backend/config/saveFeishu") ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 0) {
            showMessage('success', '✅ 飞书配置保存成功！');
            // 保存成功后重新加载配置数据
            setTimeout(() => {
                loadFeishuConfig();
            }, 500);
        } else {
            showMessage('error', '❌ 保存失败：' + (data.msg || '未知错误'));
        }
    })
    .catch(error => {
        console.error('保存配置失败:', error);
        showMessage('error', '❌ 保存失败：网络错误');
    })
    .finally(() => {
        // 恢复按钮状态
        submitBtn.prop('disabled', false).html(originalText);
    });
}

// 测试飞书连接
function testFeishuConnection() {
    const testBtn = $('button[onclick="testFeishuConnection()"]');
    const originalText = testBtn.html();
    testBtn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin me-1"></i>测试中...');
    
    fetch('<?= $this->getUrl("shopify/backend/config/testFeishu") ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 0) {
            showMessage('success', '✅ 飞书连接测试成功！');
        } else {
            showMessage('error', '❌ 连接测试失败：' + (data.msg || '未知错误'));
        }
    })
    .catch(error => {
        console.error('测试连接失败:', error);
        showMessage('error', '❌ 连接测试失败：网络错误');
    })
    .finally(() => {
        // 恢复按钮状态
        testBtn.prop('disabled', false).html(originalText);
    });
}

// 显示消息提示
function showMessage(type, message) {
    // 移除现有的消息
    $('.message-toast').remove();
    
    const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
    const icon = type === 'success' ? 'mdi-check-circle' : 'mdi-alert-circle';
    
    const messageHtml = `
        <div class="alert ${alertClass} alert-dismissible fade show message-toast" role="alert">
            <i class="mdi ${icon} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    // 在表单上方显示消息
    $('#feishuConfigForm').before(messageHtml);
    
    // 3秒后自动隐藏
    setTimeout(() => {
        $('.message-toast').fadeOut();
    }, 3000);
}
</script>

