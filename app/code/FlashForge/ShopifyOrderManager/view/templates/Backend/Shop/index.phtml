                    <div class="async-form-group">
                        <label class="async-form-label">
                            <i class="mdi mdi-shield-key"></i>Access Token<span class="text-danger">*</span>
                        </label>
                        <textarea class="async-form-control" id="edit_access_token" name="access_token" rows="3" required></textarea>
                    </div>
                    
                    <div class="async-form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="edit_status" name="status" value="1">
                            <label class="form-check-label" for="edit_status">
                                <i class="mdi mdi-toggle-switch me-1"></i><lang>启用店铺</lang>
                            </label>
                        </div>
                    </div>
                </form>
                
                <div class="loading-overlay" id="editLoadingOverlay">
                    <div class="loading-spinner text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden"><lang>保存中...</lang></span>
                        </div>
                        <p class="mt-3 mb-0"><lang>正在保存店铺信息...</lang></p>
                    </div>
                </div>
            </div>
            <div class="async-modal-footer">
                <button type="button" class="async-btn async-btn-secondary" id="cancelEditBtn">
                    <i class="mdi mdi-close me-1"></i><lang>取消</lang>
                </button>
                <button type="button" class="async-btn async-btn-primary" id="saveEditBtn">
                    <i class="mdi mdi-content-save me-1"></i><lang>保存修改</lang>
                </button>
            </div>
        </div>
    </div>
</div>

<js:part name="w-delete"/>

<script>
(function() {
    'use strict';
    
    var API_URLS = {
        toggleStatus: '<?= $this->getBackendUrl('shopify/backend/shop/toggle-status') ?>',
        getShop: '<?= $this->getBackendUrl('shopify/backend/shop/getShop') ?>',
        save: '<?= $this->getBackendUrl('shopify/backend/shop/save') ?>'
    };
    
    var addModal = document.getElementById('addShopModal');
    var editModal = document.getElementById('editShopModal');
    
    function init() {
        bindEvents();
    }
    
    function bindEvents() {
        document.getElementById('addShopBtn')?.addEventListener('click', showAddModal);
        document.getElementById('closeAddModal')?.addEventListener('click', closeAddModal);
        document.getElementById('cancelAddBtn')?.addEventListener('click', closeAddModal);
        document.getElementById('saveShopBtn')?.addEventListener('click', saveShopAsync);
        
        document.getElementById('closeEditModal')?.addEventListener('click', closeEditModal);
        document.getElementById('cancelEditBtn')?.addEventListener('click', closeEditModal);
        document.getElementById('saveEditBtn')?.addEventListener('click', saveEditAsync);
        
        document.querySelectorAll('.edit-shop-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                showEditModal(this.dataset.shopId);
            });
        });
        
        document.querySelectorAll('.toggle-status-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                toggleStatus(this.dataset.shopId, this.dataset.status);
            });
        });
        
        addModal?.addEventListener('click', function(e) {
            if (e.target === addModal) closeAddModal();
        });
        
        editModal?.addEventListener('click', function(e) {
            if (e.target === editModal) closeEditModal();
        });
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeAddModal();
                closeEditModal();
            }
        });
    }
    
    function showAddModal() {
        addModal.style.display = 'flex';
        document.getElementById('asyncShopForm').reset();
        document.getElementById('async_status').checked = true;
    }
    
    function closeAddModal() {
        addModal.style.display = 'none';
    }
    
    function showEditModal(shopId) {
        fetch(API_URLS.getShop + '?id=' + shopId)
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.code === 0 && data.data) {
                    var shop = data.data;
                    document.getElementById('edit_shop_id').value = shop.shop_id;
                    document.getElementById('edit_shop_name').value = shop.shop_name;
                    document.getElementById('edit_shop_url').value = shop.shop_url;
                    document.getElementById('edit_api_key').value = shop.api_key;
                    document.getElementById('edit_api_secret').value = shop.api_secret;
                    document.getElementById('edit_access_token').value = shop.access_token;
                    document.getElementById('edit_status').checked = shop.status == 1;
                    editModal.style.display = 'flex';
                } else {
                    showMessage('error', '获取店铺信息失败：' + (data.msg || '未知错误'));
                }
            })
            .catch(function(error) {
                showMessage('error', '获取店铺信息失败，请重试');
            });
    }
    
    function closeEditModal() {
        editModal.style.display = 'none';
    }
    
    function saveShopAsync() {
        var form = document.getElementById('asyncShopForm');
        var loadingOverlay = document.getElementById('asyncLoadingOverlay');
        
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        
        loadingOverlay.style.display = 'flex';
        var formData = new FormData(form);
        
        fetch(API_URLS.save, { method: 'POST', body: formData })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                loadingOverlay.style.display = 'none';
                if (data.code === 0) {
                    showMessage('success', data.msg);
                    closeAddModal();
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage('error', data.msg);
                }
            })
            .catch(function(error) {
                loadingOverlay.style.display = 'none';
                showMessage('error', '保存失败，请重试');
            });
    }
    
    function saveEditAsync() {
        var form = document.getElementById('editShopForm');
        var loadingOverlay = document.getElementById('editLoadingOverlay');
        
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        
        loadingOverlay.style.display = 'flex';
        var formData = new FormData(form);
        formData.set('status', document.getElementById('edit_status').checked ? '1' : '0');
        
        fetch(API_URLS.save, { method: 'POST', body: formData })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                loadingOverlay.style.display = 'none';
                if (data.code === 0) {
                    showMessage('success', data.msg);
                    closeEditModal();
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage('error', data.msg);
                }
            })
            .catch(function(error) {
                loadingOverlay.style.display = 'none';
                showMessage('error', '保存失败，请重试');
            });
    }
    
    function toggleStatus(shopId, currentStatus) {
        var action = currentStatus == 1 ? '禁用' : '启用';
        showMessage('info', '正在' + action + '店铺，请稍候...');
        
        fetch(API_URLS.toggleStatus, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + shopId
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.code === 0) {
                showMessage('success', data.msg);
                setTimeout(function() { location.reload(); }, 1000);
            } else {
                showMessage('error', '操作失败：' + data.msg);
            }
        })
        .catch(function(error) {
            showMessage('error', '操作失败，请重试');
        });
    }
    
    function showMessage(type, message) {
        var container = document.querySelector('.shopify-shop-manager .card-body') || document.body;
        var alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-' + (type === 'success' ? 'success' : type === 'error' ? 'danger' : 'info') + ' alert-dismissible fade show message-toast';
        alertDiv.style.marginBottom = '15px';
        alertDiv.innerHTML = '<i class="mdi mdi-' + (type === 'success' ? 'check-circle' : type === 'error' ? 'alert-circle' : 'information') + ' me-2"></i>' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        container.insertBefore(alertDiv, container.firstChild);
        
        setTimeout(function() {
            if (alertDiv.parentNode) {
                alertDiv.classList.remove('show');
                setTimeout(function() {
                    if (alertDiv.parentNode) alertDiv.parentNode.removeChild(alertDiv);
                }, 300);
            }
        }, 4000);
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
