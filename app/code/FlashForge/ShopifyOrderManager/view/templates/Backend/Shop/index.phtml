<script src='@static(Weline_Admin::assets/js/pages/table-responsive.init.js)'></script>

<script>
// 切换店铺状态
function toggleStatus(shopId, currentStatus) {
    const action = currentStatus == 1 ? '禁用' : '启用';
    
    // 显示确认提示
    showMessage('info', `正在${action}店铺，请稍候...`);
    
    fetch('<?= $this->getBackendUrl('shopify/backend/shop/toggle-status') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + shopId
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 0) {
            showMessage('success', data.msg);
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            showMessage('error', '操作失败：' + data.msg);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showMessage('error', '操作失败，请重试');
    });
}


// 异步添加店铺功能
function showAddShopModal() {
    document.getElementById('addShopModal').style.display = 'flex';
    // 清空表单
    document.getElementById('asyncShopForm').reset();
    // 设置默认状态为启用
    document.getElementById('async_status').checked = true;
}

// 异步编辑店铺功能
function showEditShopModal(shopId) {
    // 先获取店铺数据
    fetch('<?= $this->getBackendUrl('shopify/backend/shop/getShop') ?>?id=' + shopId)
        .then(response => response.json())
        .then(data => {
            if (data.code === 0 && data.data) {
                const shop = data.data;
                // 填充表单数据
                document.getElementById('edit_shop_id').value = shop.shop_id;
                document.getElementById('edit_shop_name').value = shop.shop_name;
                document.getElementById('edit_shop_url').value = shop.shop_url;
                document.getElementById('edit_api_key').value = shop.api_key;
                document.getElementById('edit_api_secret').value = shop.api_secret;
                document.getElementById('edit_access_token').value = shop.access_token;
                document.getElementById('edit_status').checked = shop.status == 1;
                
                // 显示编辑模态框
                document.getElementById('editShopModal').style.display = 'flex';
            } else {
                showMessage('error', '获取店铺信息失败：' + (data.msg || '未知错误'));
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showMessage('error', '获取店铺信息失败，请重试');
        });
}

function closeEditShopModal() {
    document.getElementById('editShopModal').style.display = 'none';
}

function closeAddShopModal() {
    document.getElementById('addShopModal').style.display = 'none';
}

function saveShopAsync() {
    const form = document.getElementById('asyncShopForm');
    const loadingOverlay = document.getElementById('asyncLoadingOverlay');
    
    // 验证表单
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    // 显示加载动画
    loadingOverlay.style.display = 'flex';
    
    // 收集表单数据
    const formData = new FormData(form);
    
    // 发送AJAX请求
    fetch('<?= $this->getBackendUrl('shopify/backend/shop/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        // 隐藏加载动画
        loadingOverlay.style.display = 'none';
        
        if (data.code === 0) {
            // 成功提示
            showMessage('success', data.msg);
            // 关闭模态框
            closeAddShopModal();
            // 刷新页面
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            // 错误提示
            showMessage('error', data.msg);
        }
    })
    .catch(error => {
        // 隐藏加载动画
        loadingOverlay.style.display = 'none';
        console.error('Error:', error);
        showMessage('error', '保存失败，请重试');
    });
}

function saveEditShopAsync() {
    const form = document.getElementById('editShopForm');
    const loadingOverlay = document.getElementById('editLoadingOverlay');
    
    // 验证表单
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    // 显示加载动画
    loadingOverlay.style.display = 'flex';
    
    // 收集表单数据
    const formData = new FormData(form);
    
    // 处理状态字段 - 确保复选框状态正确传递
    const statusCheckbox = document.getElementById('edit_status');
    if (statusCheckbox.checked) {
        formData.set('status', '1');
    } else {
        formData.set('status', '0');
    }
    
    // 发送AJAX请求
    fetch('<?= $this->getBackendUrl('shopify/backend/shop/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        // 隐藏加载动画
        loadingOverlay.style.display = 'none';
        
        if (data.code === 0) {
            // 成功提示
            showMessage('success', data.msg);
            // 关闭模态框
            closeEditShopModal();
            // 刷新页面
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            // 错误提示
            showMessage('error', data.msg);
        }
    })
    .catch(error => {
        // 隐藏加载动画
        loadingOverlay.style.display = 'none';
        console.error('Error:', error);
        showMessage('error', '保存失败，请重试');
    });
}

// 显示消息提示
function showMessage(type, message) {
    // 查找页面头部容器
    let headerContainer = document.querySelector('.page-header') || 
                         document.querySelector('.card-header') || 
                         document.querySelector('.modern-card .card-header');
    
    // 如果没有找到合适的头部容器，使用页面顶部
    if (!headerContainer) {
        headerContainer = document.querySelector('.container-fluid') || document.body;
    }
    
    // 创建提示元素
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show message-toast`;
    alertDiv.style.marginBottom = '15px';
    alertDiv.style.borderRadius = '8px';
    alertDiv.style.boxShadow = '0 2px 8px rgba(0,0,0,0.1)';
    alertDiv.innerHTML = `
        <i class="mdi mdi-${type === 'success' ? 'check-circle' : 'alert-circle'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    // 在头部容器顶部插入提示
    if (headerContainer === document.body) {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    } else {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    }
    
    // 自动移除提示
    setTimeout(() => {
        if (alertDiv.parentNode) {
            alertDiv.classList.remove('show');
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.parentNode.removeChild(alertDiv);
                }
            }, 300);
        }
    }, 4000);
}

// 点击模态框外部关闭
document.addEventListener('click', function(e) {
    const addModal = document.getElementById('addShopModal');
    const editModal = document.getElementById('editShopModal');
    if (e.target === addModal) {
        closeAddShopModal();
    }
    if (e.target === editModal) {
        closeEditShopModal();
    }
});

// ESC键关闭模态框
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeAddShopModal();
        closeEditShopModal();
    }
});
</script>

<!-- 异步添加店铺模态框 -->
<div class="async-modal" id="addShopModal">
    <div class="async-modal-content">
        <div class="async-modal-header">
            <h4><i class="mdi mdi-store me-2"></i>添加新店铺</h4>
            <button type="button" class="async-modal-close" onclick="closeAddShopModal()">
                <i class="mdi mdi-close"></i>
            </button>
        </div>
        <div class="async-modal-body">
            <form id="asyncShopForm">
                <div class="row">
                    <div class="col-md-6">
                        <div class="async-form-group">
                            <label class="async-form-label">
                                <i class="mdi mdi-store"></i>店铺名称<span class="text-danger">*</span>
                            </label>
                            <input type="text" class="async-form-control" id="async_shop_name" name="shop_name" required 
                                   placeholder="请输入店铺名称">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="async-form-group">
                            <label class="async-form-label">
                                <i class="mdi mdi-link"></i>店铺URL<span class="text-danger">*</span>
                            </label>
                            <input type="url" class="async-form-control" id="async_shop_url" name="shop_url" required 
                                   placeholder="https://your-shop.myshopify.com">
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="async-form-group">
                            <label class="async-form-label">
                                <i class="mdi mdi-key"></i>API Key<span class="text-danger">*</span>
                            </label>
                            <input type="text" class="async-form-control" id="async_api_key" name="api_key" required 
                                   placeholder="请输入API Key">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="async-form-group">
                            <label class="async-form-label">
                                <i class="mdi mdi-key-variant"></i>API Secret<span class="text-danger">*</span>
                            </label>
                            <input type="password" class="async-form-control" id="async_api_secret" name="api_secret" required 
                                   placeholder="请输入API Secret">
                        </div>
                    </div>
                </div>
                
                <div class="async-form-group">
                    <label class="async-form-label">
                        <i class="mdi mdi-shield-key"></i>Access Token<span class="text-danger">*</span>
                    </label>
                    <textarea class="async-form-control" id="async_access_token" name="access_token" rows="3" required 
                              placeholder="请输入Access Token"></textarea>
                </div>
                
                <div class="async-form-group">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="async_status" name="status" value="1" checked>
                        <label class="form-check-label" for="async_status">
                            <i class="mdi mdi-toggle-switch me-1"></i>启用店铺
                        </label>
                    </div>
                </div>
            </form>
            
            <!-- 加载动画 -->
            <div class="loading-overlay" id="asyncLoadingOverlay">
                <div class="loading-spinner">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">保存中...</span>
                    </div>
                    <p class="mt-3 mb-0">正在保存店铺信息...</p>
                </div>
            </div>
        </div>
        <div class="async-modal-footer">
            <button type="button" class="async-btn async-btn-secondary" onclick="closeAddShopModal()">
                <i class="mdi mdi-close me-1"></i>取消
            </button>
            <button type="button" class="async-btn async-btn-primary" onclick="saveShopAsync()">
                <i class="mdi mdi-content-save me-1"></i>保存店铺
            </button>
        </div>
    </div>
</div>

