// 加载订单详情数据
function loadOrderDetail(orderId) {
    console.log('Loading order detail for ID:', orderId);
    
    if (!orderId || orderId === 'undefined' || orderId === 'null') {
        const loading = document.getElementById('orderDetailLoading');
        loading.innerHTML = `
            <div class="text-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                错误：订单ID无效 (${orderId})
            </div>
        `;
        return;
    }
    
    const url = `<?= $this->getUrl("shopify/backend/order/getdetail") ?>?id=${orderId}`;
    console.log('Request URL:', url);
    
    fetch(url)
        .then(response => {
            console.log('Response status:', response.status);
            return response.json();
        })
        .then(data => {
            console.log('Response data:', data);
            const loading = document.getElementById('orderDetailLoading');
            const content = document.getElementById('orderDetailContent');
            
            if (data.code === 0) {
                // 隐藏加载状态，显示内容
                loading.style.display = 'none';
                content.style.display = 'block';
                
                // 填充订单详情数据
                fillOrderDetailData(data.data);
            } else {
                loading.innerHTML = `
                    <div class="text-danger">
                        <i class="mdi mdi-alert-circle me-2"></i>
                        加载失败: ${data.msg}
                    </div>
                `;
            }
        })
        .catch(error => {
            console.error('Error loading order detail:', error);
            const loading = document.getElementById('orderDetailLoading');
            loading.innerHTML = `
                <div class="text-danger">
                    <i class="mdi mdi-alert-circle me-2"></i>
                    网络错误，请稍后重试
                </div>
            `;
        });
}

// 填充订单详情数据
function fillOrderDetailData(data) {
    const order = data.order;
    const shop = data.shop;
    const orderItems = data.orderItems;
    const shippingAddress = data.shippingAddress;
    const billingAddress = data.billingAddress;
    const discountCodes = data.discountCodes;
    
    // 设置弹窗标题
    document.getElementById('modalOrderTitle').textContent = `订单详情 - ${order.order_number || order.shopify_order_number || 'N/A'}`;
    
    // 填充基本信息
    document.getElementById('detailOrderNumber').textContent = order.order_number || order.shopify_order_number || 'N/A';
    document.getElementById('detailShopName').textContent = shop.shop_name || '未知店铺';
    document.getElementById('detailOrderStatus').innerHTML = `<span class="status-badge ${getStatusClass(order.order_status)}">${getStatusText(order.order_status)}</span>`;
    document.getElementById('detailFinancialStatus').innerHTML = `<span class="status-badge ${getStatusClass(order.financial_status)}">${getStatusText(order.financial_status)}</span>`;
    document.getElementById('detailFulfillmentStatus').innerHTML = `<span class="status-badge ${getStatusClass(order.fulfillment_status)}">${getStatusText(order.fulfillment_status)}</span>`;
    document.getElementById('detailCreatedAt').textContent = formatDateTime(order.shopify_created_at || order.created_at);
    document.getElementById('detailUpdatedAt').textContent = formatDateTime(order.shopify_updated_at || order.updated_at);
    document.getElementById('detailCurrency').textContent = order.currency || 'CNY';
    
    // 填充客户信息
    document.getElementById('detailCustomerName').textContent = order.customer_name || order.customer_first_name + ' ' + order.customer_last_name || 'N/A';
    document.getElementById('detailCustomerEmail').textContent = order.customer_email || 'N/A';
    document.getElementById('detailCustomerPhone').textContent = order.customer_phone || 'N/A';
    document.getElementById('detailCustomerId').textContent = order.customer_id || 'N/A';
    
    // 填充支付方式
    let paymentMethod = 'N/A';
    if (order.payment_gateway_names && order.payment_gateway_names.trim() !== '') {
        paymentMethod = order.payment_gateway_names;
    } else if (order.gateway && order.gateway.trim() !== '') {
        paymentMethod = order.gateway;
    } else if (order.payment_method_name && order.payment_method_name.trim() !== '') {
        paymentMethod = order.payment_method_name;
    }
    document.getElementById('detailPaymentMethod').textContent = paymentMethod;
    
    // 填充商品明细
    fillOrderItems(orderItems);
    
    // 填充地址信息
    fillAddressInfo(shippingAddress, billingAddress);
    
    // 填充费用汇总
    fillOrderSummary(order, discountCodes);
}

// 填充商品明细
function fillOrderItems(orderItems) {
    const tbody = document.getElementById('orderItemsBody');
    
    // 清空现有内容，防止重复显示
    tbody.innerHTML = '';
    
    if (!orderItems || orderItems.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="6" class="text-center text-muted">
                    <i class="mdi mdi-package-variant-closed me-2"></i>
                    暂无商品信息
                </td>
            </tr>
        `;
        return;
    }
    
    // 去重处理：基于shopify_item_id和product_title去重
    const uniqueItems = [];
    const seenItems = new Set();
    
    orderItems.forEach(item => {
        const key = `${item.shopify_item_id || item.item_id}_${item.product_title}_${item.sku}`;
        if (!seenItems.has(key)) {
            seenItems.add(key);
            uniqueItems.push(item);
        }
    });
    
    console.log(`原始项目数量: ${orderItems.length}, 去重后数量: ${uniqueItems.length}`);
    
    tbody.innerHTML = uniqueItems.map(item => {
        // 使用数据库中存储的真实价格信息
        const originalPrice = parseFloat(item.original_price || 0);
        const realUnitPrice = parseFloat(item.price || 0); // 真实销售单价
        const quantity = parseInt(item.quantity || 1);
        const totalDiscount = parseFloat(item.total_discount || 0);
        const totalTax = parseFloat(item.total_tax || 0);
        
        // 计算单件折扣
        const unitDiscount = quantity > 0 ? totalDiscount / quantity : 0;
        
        // 计算单件税费（从总税费按数量分摊）
        const unitTax = quantity > 0 ? totalTax / quantity : 0;
        
        // 计算小计（真实单价 × 数量，不包含税费）
        const subtotal = realUnitPrice * quantity;
        
        // 计算折扣百分比
        const discountPercent = originalPrice > 0 ? Math.round((unitDiscount / originalPrice) * 100) : 0;
        
        return `
            <tr>
                <td>
                    <div class="product-info">
                        <div class="product-title">${item.product_title || 'N/A'}</div>
                        ${item.variant_title ? `<div class="product-variant">${item.variant_title}</div>` : ''}
                        ${item.sku ? `<div class="product-sku">SKU: ${item.sku}</div>` : ''}
                    </div>
                </td>
                <td>${item.sku || 'N/A'}</td>
                <td>${quantity}</td>
                <td>
                    <div class="price-info">
                        ${originalPrice > realUnitPrice ? `
                            <div class="original-price" style="text-decoration: line-through; color: #999; font-size: 12px;">
                                ¥${originalPrice.toFixed(2)}
                            </div>
                        ` : ''}
                        <div class="real-price" style="color: #e74c3c; font-weight: bold;">
                            ¥${realUnitPrice.toFixed(2)}
                        </div>
                        ${discountPercent > 0 ? `
                            <div class="discount-badge" style="background: #e74c3c; color: white; font-size: 10px; padding: 2px 4px; border-radius: 3px; margin-top: 2px;">
                                -${discountPercent}%
                            </div>
                        ` : ''}
                    </div>
                </td>
                <td>
                    <div class="quantity-info" style="display: flex; align-items: center; gap: 8px;">
                        <span style="color: #e74c3c; font-weight: bold;">¥${realUnitPrice.toFixed(2)}</span>
                        <span style="background: #f8f9fa; padding: 2px 8px; border-radius: 12px; font-size: 12px; color: #666;">x ${quantity}</span>
                    </div>
                </td>
                <td class="fw-bold" style="color: #2c3e50;">
                    <div class="subtotal-price" style="color: #2c3e50; font-weight: bold;">
                        ¥${subtotal.toFixed(2)}
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

// 填充地址信息
function fillAddressInfo(shippingAddress, billingAddress) {
    // 配送地址
    if (shippingAddress && Object.keys(shippingAddress).length > 0) {
        const name = `${shippingAddress.first_name || ''} ${shippingAddress.last_name || ''}`.trim() || 'N/A';
        const details = [
            shippingAddress.address1,
            shippingAddress.address2,
            shippingAddress.city,
            shippingAddress.province,
            shippingAddress.country,
            shippingAddress.zip
        ].filter(Boolean).join(', ') || 'N/A';
        
        document.getElementById('shippingAddressName').textContent = name;
        document.getElementById('shippingAddressDetails').textContent = details;
    } else {
        document.getElementById('shippingAddressName').textContent = 'N/A';
        document.getElementById('shippingAddressDetails').textContent = '暂无配送地址信息';
    }
    
    // 账单地址
    if (billingAddress && Object.keys(billingAddress).length > 0) {
        const name = `${billingAddress.first_name || ''} ${billingAddress.last_name || ''}`.trim() || 'N/A';
        const details = [
            billingAddress.address1,
            billingAddress.address2,
            billingAddress.city,
            billingAddress.province,
            billingAddress.country,
            billingAddress.zip
        ].filter(Boolean).join(', ') || 'N/A';
        
        document.getElementById('billingAddressName').textContent = name;
        document.getElementById('billingAddressDetails').textContent = details;
    } else {
        document.getElementById('billingAddressName').textContent = 'N/A';
        document.getElementById('billingAddressDetails').textContent = '暂无账单地址信息';
    }
}

// 填充费用汇总
function fillOrderSummary(order, discountCodes) {
    const subtotal = parseFloat(order.subtotal_price || 0);
    const shipping = parseFloat(order.total_shipping_price_set?.shop_money?.amount || order.shipping_price || 0);
    const tax = parseFloat(order.total_tax || 0);
    const discount = parseFloat(order.total_discounts || 0);
    const total = parseFloat(order.total_price || 0);
    
    // 计算折扣百分比
    const originalSubtotal = subtotal + discount;
    const discountPercent = originalSubtotal > 0 ? Math.round((discount / originalSubtotal) * 100) : 0;
    
    document.getElementById('summarySubtotal').innerHTML = `
        <div style="display: flex; flex-direction: column; align-items: flex-end;">
            ${originalSubtotal > subtotal ? `
                <div style="text-decoration: line-through; color: #999; font-size: 12px;">
                    ¥${originalSubtotal.toFixed(2)}
                </div>
            ` : ''}
            <div style="color: #2c3e50; font-weight: bold;">
                ¥${subtotal.toFixed(2)}
            </div>
        </div>
    `;
    
    document.getElementById('summaryShipping').textContent = `¥${shipping.toFixed(2)}`;
    document.getElementById('summaryTax').textContent = `¥${tax.toFixed(2)}`;
    
    document.getElementById('summaryDiscount').innerHTML = `
        <div style="display: flex; flex-direction: column; align-items: flex-end;">
            <div style="color: #e74c3c; font-weight: bold;">
                -¥${discount.toFixed(2)}
            </div>
            ${discountPercent > 0 ? `
                <div style="font-size: 11px; color: #e74c3c;">
                    ${discountPercent}% 折扣
                </div>
            ` : ''}
        </div>
    `;
    
    document.getElementById('summaryTotal').innerHTML = `
        <div style="color: #667eea; font-weight: 700; font-size: 18px;">
            ¥${total.toFixed(2)}
        </div>
    `;
    
    // 填充优惠券信息
    if (discountCodes && discountCodes.length > 0) {
        const discountSection = document.getElementById('discountSection');
        const discountList = document.getElementById('discountCodesList');
        
        discountSection.style.display = 'block';
        discountList.innerHTML = discountCodes.map(code => `
            <div class="address-card">
                <div class="address-name">${code.code || 'N/A'}</div>
                <div class="address-details">
                    类型: ${code.type || 'N/A'}<br>
                    金额: ¥${parseFloat(code.amount || 0).toFixed(2)}
                </div>
            </div>
        `).join('');
    } else {
        document.getElementById('discountSection').style.display = 'none';
    }
}

// 点击弹窗外部关闭弹窗
document.addEventListener('click', function(event) {
    const modal = document.getElementById('orderDetailModal');
    if (event.target === modal) {
        closeOrderDetailModal();
    }
});

// ESC键关闭弹窗
document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        const modal = document.getElementById('orderDetailModal');
        if (modal.classList.contains('show')) {
            closeOrderDetailModal();
        }
    }
});
</script>

@template(Weline_Admin::common/footer.phtml)
</body>
</html>
