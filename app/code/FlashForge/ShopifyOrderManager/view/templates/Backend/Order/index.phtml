// 确认导出
function confirmExport(shopId, startDate, endDate, orderStatus, orderNumber) {
    const format = document.querySelector('input[name="exportFormat"]:checked').value;
    
    // 关闭模态框
    const modal = bootstrap.Modal.getInstance(document.getElementById('exportFormatModal'));
    modal.hide();
    
    // 开始导出
    performExport(shopId, startDate, endDate, orderStatus, orderNumber, format);
}

// 执行导出
function performExport(shopId, startDate, endDate, orderStatus, orderNumber, format) {
    // 显示框架加载动画
    showLoading();
    
    // 构建导出URL
    const params = new URLSearchParams({
        shop_id: shopId,
        start_date: startDate,
        end_date: endDate,
        format: format
    });
    
    if (orderStatus) {
        params.append('order_status', orderStatus);
    }
    if (orderNumber) {
        params.append('order_number', orderNumber);
    }
    
    const exportUrl = `<?= $this->getUrl('shopify/backend/order/export') ?>?${params.toString()}`;
    
    // 创建隐藏的下载链接
    const link = document.createElement('a');
    link.href = exportUrl;
    link.style.display = 'none';
    document.body.appendChild(link);
    
    // 监听下载完成
    link.addEventListener('click', function() {
        setTimeout(() => {
            hideLoading();
            showMessage('success', `🎉 订单数据导出成功！格式：${format.toUpperCase()}`);
            document.body.removeChild(link);
        }, 1000);
    });
    
    // 触发下载
    link.click();
    
    // 如果下载没有触发，显示错误信息
    setTimeout(() => {
        if (document.body.contains(link)) {
            hideLoading();
            showMessage('error', '❌ 导出失败，请检查网络连接或联系管理员');
            document.body.removeChild(link);
        }
    }, 10000);
}


