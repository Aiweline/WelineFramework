<script>
// 分页相关全局变量
let currentPage = 1;
let totalPages = 1;
let pageSize = 20;
let totalCount = 0;

// 模拟订单数据
const mockOrders = [
    {
        id: 'SO-2024-001',
        shop: '测试店铺1',
        customer: '张三',
        amount: '¥299.00',
        status: 'completed',
        statusText: '已完成',
        createTime: '2024-01-15 14:30:25'
    },
    {
        id: 'SO-2024-002',
        shop: '测试店铺2',
        customer: '李四',
        amount: '¥599.00',
        status: 'processing',
        statusText: '处理中',
        createTime: '2024-01-15 16:45:12'
    },
    {
        id: 'SO-2024-003',
        shop: '测试店铺1',
        customer: '王五',
        amount: '¥199.00',
        status: 'pending',
        statusText: '待处理',
        createTime: '2024-01-15 18:20:33'
    }
];

// 模拟统计数据
const mockStats = {
    totalOrders: 156,
    totalRevenue: '¥45,680.00',
    totalCustomers: 89
};

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    loadShops();
    loadOrders();
    updateStats();
    
    // 为筛选表单添加事件监听器
    setupFilterEventListeners();
});

// 设置筛选表单事件监听器
function setupFilterEventListeners() {
    const shopFilter = document.getElementById('shopFilter');
    const startDate = document.getElementById('startDate');
    const endDate = document.getElementById('endDate');
    
    // 为所有筛选输入框添加change事件监听器
    [shopFilter, startDate, endDate].forEach(element => {
        if (element) {
            element.addEventListener('change', updateClearButtonState);
            element.addEventListener('input', updateClearButtonState);
        }
    });
    
    // 初始化清除按钮状态
    updateClearButtonState();
}

// 加载店铺列表
function loadShops() {
    console.log('Loading shops...');
    // 从真实API获取店铺数据
    fetch('<?= $this->getUrl("shopify/backend/shop/getlist") ?>')
        .then(response => {
            console.log('Shop API response status:', response.status);
            return response.json();
        })
        .then(data => {
            console.log('Shop API data:', data);
            const shopFilter = document.getElementById('shopFilter');
            
            if (data.code === 0 && data.data && data.data.length > 0) {
                data.data.forEach(shop => {
                    const option = document.createElement('option');
                    option.value = shop.shop_id;
                    option.textContent = shop.shop_name;
                    shopFilter.appendChild(option);
                });
                console.log('Shops loaded successfully:', data.data.length);
            } else {
                // 如果没有店铺数据，显示提示
                const option = document.createElement('option');
                option.value = '';
                option.textContent = '暂无店铺数据';
                option.disabled = true;
                shopFilter.appendChild(option);
                console.log('No shop data available');
            }
        })
        .catch(error => {
            console.error('Error loading shops:', error);
            const shopFilter = document.getElementById('shopFilter');
            const option = document.createElement('option');
            option.value = '';
            option.textContent = '加载店铺失败';
            option.disabled = true;
            shopFilter.appendChild(option);
        });
}

// 加载订单数据
function loadOrders(page = 1) {
    showLoading();
    
    // 更新当前页码
    currentPage = page;
    
    // 获取筛选参数
    const shopId = document.getElementById('shopFilter').value;
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    
    console.log('Filter parameters:', { shopId, startDate, endDate, page });
    
    // 构建请求参数
    const params = new URLSearchParams();
    if (shopId) params.append('shop_id', shopId);
    if (startDate) params.append('start_date', startDate);
    if (endDate) params.append('end_date', endDate);
    params.append('page', page);
    params.append('limit', pageSize);
    
    const apiUrl = `<?= $this->getUrl("shopify/backend/order/getlist") ?>?${params.toString()}`;
    console.log('Order API URL:', apiUrl);
    
    // 发送AJAX请求获取真实数据
    fetch(apiUrl)
        .then(response => {
            console.log('Order API response status:', response.status);
            
            // 检查是否需要登录
            if (response.status === 302 || response.status === 401) {
                hideLoading();
                showMessage('error', '请先登录系统');
                // 重定向到登录页面
                setTimeout(() => {
                    window.location.href = '<?= $this->getUrl("admin/user/login") ?>';
                }, 2000);
                return;
            }
            
            // 检查响应是否为JSON
            const contentType = response.headers.get('content-type');
            if (!contentType || !contentType.includes('application/json')) {
                throw new Error('响应不是有效的JSON格式');
            }
            
            return response.json();
        })
        .then(data => {
            console.log('Order API data:', data);
            hideLoading();
            
            if (data && data.code === 0) {
                displayOrders(data.data);
                
                // 更新分页信息
                totalCount = data.count || 0;
                totalPages = Math.ceil(totalCount / pageSize);
                updatePagination();
                
                // 使用API返回的统计数据
                if (data.stats) {
                    updateStatsFromApi(data.stats);
                } else {
                    // 如果没有统计数据，使用返回的数据计算（兼容性）
                    updateStatsFromData(data.data);
                }
                console.log('Orders loaded successfully:', data.data.length, 'Total:', totalCount, 'Pages:', totalPages);
            } else {
                const errorMsg = data ? data.msg : '未知错误';
                showMessage('error', '获取订单数据失败: ' + errorMsg);
                displayEmptyState();
            }
        })
        .catch(error => {
            hideLoading();
            console.error('Error loading orders:', error);
            showMessage('error', '网络错误，请稍后重试: ' + error.message);
            displayEmptyState();
        });
}

// 显示订单数据
function displayOrders(orders) {
    const tbody = document.querySelector('#ordersTable tbody');
    
    if (!orders || orders.length === 0) {
        displayEmptyState();
        return;
    }
    
    // 调试信息：打印第一个订单的数据结构
    if (orders.length > 0) {
        console.log('First order data structure:', orders[0]);
        console.log('Available order fields:', Object.keys(orders[0]));
    }
    
    tbody.innerHTML = orders.map(order => `
        <tr>
            <td>
                <strong>${order.order_number || order.shopify_order_number || 'N/A'}</strong>
            </td>
            <td>${order.shop_name || '未知店铺'}</td>
            <td>${order.customer_name || order.customer_email || 'N/A'}</td>
            <td>
                <span class="text-success fw-bold">¥${parseFloat(order.total_price || 0).toFixed(2)}</span>
            </td>
            <td>
                <span class="status-badge ${getStatusClass(order.order_status || order.fulfillment_status)}">
                    <i class="mdi mdi-${getStatusIcon(order.order_status || order.fulfillment_status)}"></i>
                    ${getStatusText(order.order_status || order.fulfillment_status)}
                </span>
            </td>
            <td>${formatDateTime(order.shopify_created_at || order.created_at)}</td>
            <td>
                <div class="action-buttons">
                    <button class="action-btn action-btn-view" onclick="viewOrder('${order.order_id || order.id || order.shopify_order_id || 'unknown'}')" title="查看详情">
                        <i class="mdi mdi-eye"></i>
                    </button>
                </div>
            </td>
        </tr>
    `).join('');
}

// 显示空状态
function displayEmptyState() {
    const tbody = document.querySelector('#ordersTable tbody');
    tbody.innerHTML = `
        <tr>
            <td colspan="7" class="empty-state">
                <i class="mdi mdi-package-variant-closed"></i>
                <h4>暂无订单数据</h4>
                <p>请选择店铺或调整筛选条件来查看订单信息</p>
            </td>
        </tr>
    `;
}

// 获取状态图标
function getStatusIcon(status) {
    const icons = {
        'pending': 'clock-outline',
        'processing': 'cog',
        'completed': 'check-circle',
        'cancelled': 'close-circle',
        'fulfilled': 'check-circle',
        'unfulfilled': 'clock-outline',
        'partial': 'cog',
        'open': 'clock-outline',
        'closed': 'check-circle'
    };
    return icons[status] || 'help-circle';
}

// 获取状态样式类
function getStatusClass(status) {
    const classes = {
        'pending': 'pending',
        'processing': 'processing',
        'completed': 'completed',
        'cancelled': 'cancelled',
        'fulfilled': 'completed',
        'unfulfilled': 'pending',
        'partial': 'processing',
        'open': 'pending',
        'closed': 'completed'
    };
    return classes[status] || 'pending';
}

// 获取状态文本
function getStatusText(status) {
    const texts = {
        'pending': '待处理',
        'processing': '处理中',
        'completed': '已完成',
        'cancelled': '已取消',
        'fulfilled': '已发货',
        'unfulfilled': '未发货',
        'partial': '部分发货',
        'open': '开放',
        'closed': '已关闭'
    };
    return texts[status] || status || '未知';
}

// 格式化日期时间
function formatDateTime(dateTime) {
    if (!dateTime) return 'N/A';
    
    try {
        const date = new Date(dateTime);
        return date.toLocaleString('zh-CN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        });
    } catch (e) {
        return dateTime;
    }
}

// 从API统计数据更新统计
function updateStatsFromApi(stats) {
    document.getElementById('totalOrders').textContent = stats.totalOrders || '0';
    document.getElementById('totalRevenue').textContent = `¥${stats.totalRevenue || '0.00'}`;
    document.getElementById('totalCustomers').textContent = stats.customerCount || '0';
}

// 从真实数据更新统计（兼容性方法）
function updateStatsFromData(orders) {
    if (!orders || orders.length === 0) {
        document.getElementById('totalOrders').textContent = '0';
        document.getElementById('totalRevenue').textContent = '¥0.00';
        document.getElementById('totalCustomers').textContent = '0';
        return;
    }
    
    const totalOrders = orders.length;
    const totalRevenue = orders.reduce((sum, order) => sum + parseFloat(order.total_price || 0), 0);
    const uniqueCustomers = new Set(orders.map(order => order.customer_email || order.customer_name)).size;
    
    document.getElementById('totalOrders').textContent = totalOrders;
    document.getElementById('totalRevenue').textContent = `¥${totalRevenue.toFixed(2)}`;
    document.getElementById('totalCustomers').textContent = uniqueCustomers;
}

// 更新统计数据
function updateStats() {
    document.getElementById('totalOrders').textContent = mockStats.totalOrders;
    document.getElementById('totalRevenue').textContent = mockStats.totalRevenue;
    document.getElementById('totalCustomers').textContent = mockStats.totalCustomers;
}

// 更新分页显示
function updatePagination() {
    const paginationList = document.getElementById('paginationList');
    const paginationContainer = document.getElementById('paginationContainer');
    const paginationInfo = document.getElementById('paginationInfo');
    
    // 更新分页信息
    if (paginationInfo) {
        const startRecord = (currentPage - 1) * pageSize + 1;
        const endRecord = Math.min(currentPage * pageSize, totalCount);
        
        document.getElementById('currentRange').textContent = `${startRecord}-${endRecord}`;
        document.getElementById('totalCount').textContent = totalCount;
        document.getElementById('currentPage').textContent = currentPage;
        document.getElementById('totalPages').textContent = totalPages;
        
        paginationInfo.style.display = totalCount > 0 ? 'flex' : 'none';
    }
    
    if (!paginationList || totalPages <= 1) {
        paginationContainer.style.display = 'none';
        return;
    }
    
    paginationContainer.style.display = 'flex';
    paginationList.innerHTML = '';
    
    // 上一页按钮
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="goToPage(${currentPage - 1}); return false;">上一页</a>`;
    paginationList.appendChild(prevLi);
    
    // 页码按钮
    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);
    
    // 第一页
    if (startPage > 1) {
        const firstLi = document.createElement('li');
        firstLi.className = 'page-item';
        firstLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="goToPage(1); return false;">1</a>`;
        paginationList.appendChild(firstLi);
        
        if (startPage > 2) {
            const ellipsisLi = document.createElement('li');
            ellipsisLi.className = 'page-item disabled';
            ellipsisLi.innerHTML = '<span class="page-link">...</span>';
            paginationList.appendChild(ellipsisLi);
        }
    }
    
    // 中间页码
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === currentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="goToPage(${i}); return false;">${i}</a>`;
        paginationList.appendChild(li);
    }
    
    // 最后一页
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const ellipsisLi = document.createElement('li');
            ellipsisLi.className = 'page-item disabled';
            ellipsisLi.innerHTML = '<span class="page-link">...</span>';
            paginationList.appendChild(ellipsisLi);
        }
        
        const lastLi = document.createElement('li');
        lastLi.className = 'page-item';
        lastLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="goToPage(${totalPages}); return false;">${totalPages}</a>`;
        paginationList.appendChild(lastLi);
    }
    
    // 下一页按钮
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="javascript:void(0)" onclick="goToPage(${currentPage + 1}); return false;">下一页</a>`;
    paginationList.appendChild(nextLi);
}

// 跳转到指定页面
function goToPage(page) {
    if (page < 1 || page > totalPages || page === currentPage) {
        return;
    }
    loadOrders(page);
}

// 改变页面大小
function changePageSize() {
    const newPageSize = parseInt(document.getElementById('pageSizeSelect').value);
    pageSize = newPageSize;
    loadOrders(1); // 改变页面大小时重置到第一页
}

// 清除所有筛选条件
function clearFilters() {
    // 检查是否有筛选条件
    const shopId = document.getElementById('shopFilter').value;
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    
    if (!shopId && !startDate && !endDate) {
        showMessage('info', '当前没有筛选条件需要清除');
        return;
    }
    
    // 确认对话框
    if (!confirm('确定要清除所有筛选条件吗？')) {
        return;
    }
    
    // 清除店铺筛选
    document.getElementById('shopFilter').value = '';
    
    // 清除日期筛选
    document.getElementById('startDate').value = '';
    document.getElementById('endDate').value = '';
    
    // 重置页面大小到默认值
    document.getElementById('pageSizeSelect').value = '20';
    pageSize = 20;
    
    // 更新清除按钮状态
    updateClearButtonState();
    
    // 重新加载订单数据
    loadOrders(1);
    
    // 显示成功提示
    showMessage('success', '筛选条件已清除，显示所有订单');
}

// 更新清除按钮状态
function updateClearButtonState() {
    const clearBtn = document.getElementById('clearFiltersBtn');
    const shopId = document.getElementById('shopFilter').value;
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    
    // 如果有任何筛选条件，启用按钮；否则禁用
    const hasFilters = shopId || startDate || endDate;
    clearBtn.disabled = !hasFilters;
    
    if (hasFilters) {
        clearBtn.classList.remove('btn-outline-secondary');
        clearBtn.classList.add('btn-outline-warning');
        clearBtn.title = '清除所有筛选条件';
    } else {
        clearBtn.classList.remove('btn-outline-warning');
        clearBtn.classList.add('btn-outline-secondary');
        clearBtn.title = '当前没有筛选条件';
    }
}

// 筛选订单
function filterOrders() {
    loadOrders(1); // 筛选时重置到第一页
}

// 导出订单
function exportOrders() {
    // 获取当前筛选条件，添加空值检查
    const shopFilter = document.getElementById('shopFilter');
    const startDateEl = document.getElementById('startDate');
    const endDateEl = document.getElementById('endDate');
    
    const shopId = shopFilter ? shopFilter.value : '';
    const startDate = startDateEl ? startDateEl.value : '';
    const endDate = endDateEl ? endDateEl.value : '';
    const orderStatus = ''; // 页面中没有订单状态筛选
    const orderNumber = ''; // 页面中没有订单号筛选
    
    // 验证必填字段
    if (!startDate || !endDate) {
        showMessage('error', '请选择导出时间范围！');
        return;
    }
    
    // 验证日期范围
    if (new Date(startDate) > new Date(endDate)) {
        showMessage('error', '开始日期不能大于结束日期！');
        return;
    }
    
    // 验证时间范围限制
    const startDateObj = new Date(startDate);
    const endDateObj = new Date(endDate);
    const timeDiff = endDateObj.getTime() - startDateObj.getTime();
    const daysDiff = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1; // 包含开始和结束日期
    
    // 检查是否超过一个季度（90天）
    if (daysDiff > 90) {
        showMessage('error', '导出时间范围不能超过一个季度（90天）！请缩小时间范围。');
        return;
    }
    
    // 显示导出格式选择对话框
    showExportFormatDialog(shopId, startDate, endDate, orderStatus, orderNumber, daysDiff);
}

// 快速导出
function quickExport(period) {
    const now = new Date();
    let startDate, endDate, periodName;
    
    switch (period) {
        case 'week':
            // 这周：周一到周日
            const dayOfWeek = now.getDay();
            const monday = new Date(now);
            monday.setDate(now.getDate() - (dayOfWeek === 0 ? 6 : dayOfWeek - 1));
            monday.setHours(0, 0, 0, 0);
            
            const sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            sunday.setHours(23, 59, 59, 999);
            
            startDate = formatDate(monday);
            endDate = formatDate(sunday);
            periodName = '这周';
            break;
            
        case 'month':
            // 这一个月：从今天往前推30天
            const monthStart = new Date(now);
            monthStart.setDate(now.getDate() - 30);
            monthStart.setHours(0, 0, 0, 0);
            
            const monthEnd = new Date(now);
            monthEnd.setHours(23, 59, 59, 999);
            
            startDate = formatDate(monthStart);
            endDate = formatDate(monthEnd);
            periodName = '这一个月';
            break;
            
        case 'quarter':
            // 这个季度：从今天往前推90天
            const quarterStart = new Date(now);
            quarterStart.setDate(now.getDate() - 90);
            quarterStart.setHours(0, 0, 0, 0);
            
            const quarterEnd = new Date(now);
            quarterEnd.setHours(23, 59, 59, 999);
            
            startDate = formatDate(quarterStart);
            endDate = formatDate(quarterEnd);
            periodName = '这个季度';
            break;
            
        default:
            showMessage('error', '无效的时间范围！');
            return;
    }
    
    // 获取当前店铺筛选
    const shopFilter = document.getElementById('shopFilter');
    const shopId = shopFilter ? shopFilter.value : '';
    
    // 计算天数差
    const startDateObj = new Date(startDate);
    const endDateObj = new Date(endDate);
    const timeDiff = endDateObj.getTime() - startDateObj.getTime();
    const daysDiff = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
    
    // 显示确认对话框
    const confirmMessage = `确定要导出${periodName}的订单数据吗？\n\n时间范围：${startDate} 至 ${endDate}\n预计天数：${daysDiff}天\n\n注意：导出时间范围不能超过90天，数量不能超过10万条。`;
    
    if (confirm(confirmMessage)) {
        // 直接显示导出格式选择对话框
        showExportFormatDialog(shopId, startDate, endDate, '', '', daysDiff);
    }
}

// 格式化日期为 YYYY-MM-DD 格式
function formatDate(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
}

