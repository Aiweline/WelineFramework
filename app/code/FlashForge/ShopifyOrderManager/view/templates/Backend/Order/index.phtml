<script>
(function() {
    'use strict';
    
    // API URLs
    var API_URLS = {
        shopList: '<?= $this->getUrl("shopify/backend/shop/getlist") ?>',
        orderList: '<?= $this->getUrl("shopify/backend/order/getlist") ?>',
        orderDetail: '<?= $this->getUrl("shopify/backend/order/getdetail") ?>',
        orderExport: '<?= $this->getUrl("shopify/backend/order/export") ?>',
        login: '<?= $this->getUrl("admin/user/login") ?>'
    };
    
    // 状态变量
    var currentPage = 1;
    var totalPages = 1;
    var pageSize = 20;
    var totalCount = 0;
    
    // DOM 元素缓存
    var elements = {};
    
    // 初始化
    function init() {
        cacheElements();
        bindEvents();
        loadShops();
        loadOrders();
    }
    
    // 缓存 DOM 元素
    function cacheElements() {
        elements.shopFilter = document.getElementById('shopFilter');
        elements.startDate = document.getElementById('startDate');
        elements.endDate = document.getElementById('endDate');
        elements.pageSizeSelect = document.getElementById('pageSizeSelect');
        elements.clearFiltersBtn = document.getElementById('clearFiltersBtn');
        elements.ordersTable = document.getElementById('ordersTable');
        elements.paginationList = document.getElementById('paginationList');
        elements.paginationContainer = document.getElementById('paginationContainer');
        elements.paginationInfo = document.getElementById('paginationInfo');
        elements.orderDetailModal = document.getElementById('orderDetailModal');
        elements.orderDetailLoading = document.getElementById('orderDetailLoading');
        elements.orderDetailContent = document.getElementById('orderDetailContent');
    }
    
    // 绑定事件
    function bindEvents() {
        document.getElementById('filterOrdersBtn').addEventListener('click', function() {
            loadOrders(1);
        });
        
        elements.clearFiltersBtn.addEventListener('click', clearFilters);
        
        elements.pageSizeSelect.addEventListener('change', function() {
            pageSize = parseInt(this.value);
            loadOrders(1);
        });
        
        [elements.shopFilter, elements.startDate, elements.endDate].forEach(function(el) {
            if (el) {
                el.addEventListener('change', updateClearButtonState);
            }
        });
        
        document.getElementById('exportOrdersBtn')?.addEventListener('click', exportOrders);
        document.getElementById('customExportBtn')?.addEventListener('click', exportOrders);
        
        document.querySelectorAll('[data-quick-export]').forEach(function(el) {
            el.addEventListener('click', function(e) {
                e.preventDefault();
                quickExport(this.dataset.quickExport);
            });
        });
        
        document.getElementById('closeModalBtn').addEventListener('click', closeOrderDetailModal);
        
        elements.orderDetailModal.addEventListener('click', function(e) {
            if (e.target === this) {
                closeOrderDetailModal();
            }
        });
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && elements.orderDetailModal.classList.contains('show')) {
                closeOrderDetailModal();
            }
        });
        
        document.querySelectorAll('.order-detail-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                switchTab(this.dataset.tab);
            });
        });
    }
    
    // 加载店铺列表
    function loadShops() {
        fetch(API_URLS.shopList)
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.code === 0 && data.data && data.data.length > 0) {
                    data.data.forEach(function(shop) {
                        var option = document.createElement('option');
                        option.value = shop.shop_id;
                        option.textContent = shop.shop_name;
                        elements.shopFilter.appendChild(option);
                    });
                }
            })
            .catch(function(error) {
                console.error('Error loading shops:', error);
            });
    }
    
    // 加载订单
    function loadOrders(page) {
        page = page || 1;
        currentPage = page;
        showLoading();
        
        var params = new URLSearchParams();
        if (elements.shopFilter.value) params.append('shop_id', elements.shopFilter.value);
        if (elements.startDate.value) params.append('start_date', elements.startDate.value);
        if (elements.endDate.value) params.append('end_date', elements.endDate.value);
        params.append('page', page);
        params.append('limit', pageSize);
        
        fetch(API_URLS.orderList + '?' + params.toString())
            .then(function(response) {
                if (response.status === 302 || response.status === 401) {
                    hideLoading();
                    showMessage('error', '请先登录系统');
                    setTimeout(function() {
                        window.location.href = API_URLS.login;
                    }, 2000);
                    return;
                }
                return response.json();
            })
            .then(function(data) {
                hideLoading();
                if (data && data.code === 0) {
                    displayOrders(data.data);
                    totalCount = data.count || 0;
                    totalPages = Math.ceil(totalCount / pageSize);
                    updatePagination();
                    if (data.stats) {
                        updateStatsFromApi(data.stats);
                    } else {
                        updateStatsFromData(data.data);
                    }
                } else {
                    showMessage('error', '获取订单数据失败: ' + (data ? data.msg : '未知错误'));
                    displayEmptyState();
                }
            })
            .catch(function(error) {
                hideLoading();
                showMessage('error', '网络错误，请稍后重试');
                displayEmptyState();
            });
    }
    
    // 显示订单
    function displayOrders(orders) {
        var tbody = elements.ordersTable.querySelector('tbody');
        
        if (!orders || orders.length === 0) {
            displayEmptyState();
            return;
        }
        
        tbody.innerHTML = orders.map(function(order) {
            return '<tr>' +
                '<td><strong>' + (order.order_number || order.shopify_order_number || 'N/A') + '</strong></td>' +
                '<td>' + (order.shop_name || '未知店铺') + '</td>' +
                '<td>' + (order.customer_name || order.customer_email || 'N/A') + '</td>' +
                '<td><span class="text-success fw-bold">¥' + parseFloat(order.total_price || 0).toFixed(2) + '</span></td>' +
                '<td><span class="status-badge ' + getStatusClass(order.order_status || order.fulfillment_status) + '">' +
                    '<i class="mdi mdi-' + getStatusIcon(order.order_status || order.fulfillment_status) + '"></i>' +
                    getStatusText(order.order_status || order.fulfillment_status) +
                '</span></td>' +
                '<td>' + formatDateTime(order.shopify_created_at || order.created_at) + '</td>' +
                '<td><div class="action-buttons">' +
                    '<button class="action-btn action-btn-view" data-order-id="' + (order.order_id || order.id || order.shopify_order_id) + '" title="查看详情">' +
                        '<i class="mdi mdi-eye"></i>' +
                    '</button>' +
                '</div></td>' +
            '</tr>';
        }).join('');
        
        tbody.querySelectorAll('.action-btn-view').forEach(function(btn) {
            btn.addEventListener('click', function() {
                viewOrder(this.dataset.orderId);
            });
        });
    }
    
    // 显示空状态
    function displayEmptyState() {
        var tbody = elements.ordersTable.querySelector('tbody');
        tbody.innerHTML = '<tr><td colspan="7" class="empty-state">' +
            '<i class="mdi mdi-package-variant-closed"></i>' +
            '<h4>暂无订单数据</h4>' +
            '<p>请选择店铺或调整筛选条件来查看订单信息</p>' +
        '</td></tr>';
    }
    
    // 状态相关函数
    function getStatusIcon(status) {
        var icons = {
            'pending': 'clock-outline',
            'processing': 'cog',
            'completed': 'check-circle',
            'cancelled': 'close-circle',
            'fulfilled': 'check-circle',
            'unfulfilled': 'clock-outline',
            'partial': 'cog',
            'open': 'clock-outline',
            'closed': 'check-circle'
        };
        return icons[status] || 'help-circle';
    }
    
    function getStatusClass(status) {
        var classes = {
            'pending': 'pending',
            'processing': 'processing',
            'completed': 'completed',
            'cancelled': 'cancelled',
            'fulfilled': 'completed',
            'unfulfilled': 'pending',
            'partial': 'processing',
            'open': 'pending',
            'closed': 'completed'
        };
        return classes[status] || 'pending';
    }
    
    function getStatusText(status) {
        var texts = {
            'pending': '待处理',
            'processing': '处理中',
            'completed': '已完成',
            'cancelled': '已取消',
            'fulfilled': '已发货',
            'unfulfilled': '未发货',
            'partial': '部分发货',
            'open': '开放',
            'closed': '已关闭'
        };
        return texts[status] || status || '未知';
    }
    
    function formatDateTime(dateTime) {
        if (!dateTime) return 'N/A';
        try {
            var date = new Date(dateTime);
            return date.toLocaleString('zh-CN', {
                year: 'numeric', month: '2-digit', day: '2-digit',
                hour: '2-digit', minute: '2-digit', second: '2-digit'
            });
        } catch (e) {
            return dateTime;
        }
    }
    
    // 统计更新
    function updateStatsFromApi(stats) {
        document.getElementById('totalOrders').textContent = stats.totalOrders || '0';
        document.getElementById('totalRevenue').textContent = '¥' + (stats.totalRevenue || '0.00');
        document.getElementById('totalCustomers').textContent = stats.customerCount || '0';
    }
    
    function updateStatsFromData(orders) {
        if (!orders || orders.length === 0) {
            document.getElementById('totalOrders').textContent = '0';
            document.getElementById('totalRevenue').textContent = '¥0.00';
            document.getElementById('totalCustomers').textContent = '0';
            return;
        }
        var totalRevenue = orders.reduce(function(sum, order) {
            return sum + parseFloat(order.total_price || 0);
        }, 0);
        var uniqueCustomers = new Set(orders.map(function(order) {
            return order.customer_email || order.customer_name;
        })).size;
        
        document.getElementById('totalOrders').textContent = orders.length;
        document.getElementById('totalRevenue').textContent = '¥' + totalRevenue.toFixed(2);
        document.getElementById('totalCustomers').textContent = uniqueCustomers;
    }
    
    // 分页
    function updatePagination() {
        if (elements.paginationInfo) {
            var startRecord = (currentPage - 1) * pageSize + 1;
            var endRecord = Math.min(currentPage * pageSize, totalCount);
            
            document.getElementById('currentRange').textContent = startRecord + '-' + endRecord;
            document.getElementById('totalCount').textContent = totalCount;
            document.getElementById('currentPage').textContent = currentPage;
            document.getElementById('totalPages').textContent = totalPages;
            
            elements.paginationInfo.style.display = totalCount > 0 ? 'flex' : 'none';
        }
        
        if (totalPages <= 1) {
            elements.paginationContainer.style.display = 'none';
            return;
        }
        
        elements.paginationContainer.style.display = 'flex';
        elements.paginationList.innerHTML = '';
        
        var prevLi = document.createElement('li');
        prevLi.className = 'page-item ' + (currentPage === 1 ? 'disabled' : '');
        prevLi.innerHTML = '<a class="page-link" href="javascript:void(0)">上一页</a>';
        if (currentPage > 1) {
            prevLi.querySelector('a').addEventListener('click', function() { goToPage(currentPage - 1); });
        }
        elements.paginationList.appendChild(prevLi);
        
        var startPage = Math.max(1, currentPage - 2);
        var endPage = Math.min(totalPages, currentPage + 2);
        
        for (var i = startPage; i <= endPage; i++) {
            (function(page) {
                var li = document.createElement('li');
                li.className = 'page-item ' + (page === currentPage ? 'active' : '');
                li.innerHTML = '<a class="page-link" href="javascript:void(0)">' + page + '</a>';
                li.querySelector('a').addEventListener('click', function() { goToPage(page); });
                elements.paginationList.appendChild(li);
            })(i);
        }
        
        var nextLi = document.createElement('li');
        nextLi.className = 'page-item ' + (currentPage === totalPages ? 'disabled' : '');
        nextLi.innerHTML = '<a class="page-link" href="javascript:void(0)">下一页</a>';
        if (currentPage < totalPages) {
            nextLi.querySelector('a').addEventListener('click', function() { goToPage(currentPage + 1); });
        }
        elements.paginationList.appendChild(nextLi);
    }
    
    function goToPage(page) {
        if (page < 1 || page > totalPages || page === currentPage) return;
        loadOrders(page);
    }
    
    // 筛选
    function clearFilters() {
        elements.shopFilter.value = '';
        elements.startDate.value = '';
        elements.endDate.value = '';
        elements.pageSizeSelect.value = '20';
        pageSize = 20;
        updateClearButtonState();
        loadOrders(1);
        showMessage('success', '筛选条件已清除');
    }
    
    function updateClearButtonState() {
        var hasFilters = elements.shopFilter.value || elements.startDate.value || elements.endDate.value;
        elements.clearFiltersBtn.disabled = !hasFilters;
        if (hasFilters) {
            elements.clearFiltersBtn.classList.remove('btn-outline-secondary');
            elements.clearFiltersBtn.classList.add('btn-outline-warning');
        } else {
            elements.clearFiltersBtn.classList.remove('btn-outline-warning');
            elements.clearFiltersBtn.classList.add('btn-outline-secondary');
        }
    }
    
    // 导出
    function exportOrders() {
        var startDate = elements.startDate.value;
        var endDate = elements.endDate.value;
        
        if (!startDate || !endDate) {
            showMessage('error', '请选择导出时间范围！');
            return;
        }
        
        if (new Date(startDate) > new Date(endDate)) {
            showMessage('error', '开始日期不能大于结束日期！');
            return;
        }
        
        var daysDiff = Math.ceil((new Date(endDate) - new Date(startDate)) / (1000 * 3600 * 24)) + 1;
        if (daysDiff > 90) {
            showMessage('error', '导出时间范围不能超过90天！');
            return;
        }
        
        performExport(elements.shopFilter.value, startDate, endDate, 'csv');
    }
    
    function quickExport(period) {
        var now = new Date();
        var startDate, endDate;
        
        switch (period) {
            case 'week':
                var dayOfWeek = now.getDay();
                var monday = new Date(now);
                monday.setDate(now.getDate() - (dayOfWeek === 0 ? 6 : dayOfWeek - 1));
                startDate = formatDate(monday);
                endDate = formatDate(now);
                break;
            case 'month':
                var monthStart = new Date(now);
                monthStart.setDate(now.getDate() - 30);
                startDate = formatDate(monthStart);
                endDate = formatDate(now);
                break;
            case 'quarter':
                var quarterStart = new Date(now);
                quarterStart.setDate(now.getDate() - 90);
                startDate = formatDate(quarterStart);
                endDate = formatDate(now);
                break;
        }
        
        performExport(elements.shopFilter.value, startDate, endDate, 'csv');
    }
    
    function formatDate(date) {
        var year = date.getFullYear();
        var month = String(date.getMonth() + 1).padStart(2, '0');
        var day = String(date.getDate()).padStart(2, '0');
        return year + '-' + month + '-' + day;
    }
    
    function performExport(shopId, startDate, endDate, format) {
        showLoading();
        var params = new URLSearchParams({
            shop_id: shopId || '',
            start_date: startDate,
            end_date: endDate,
            format: format
        });
        
        var link = document.createElement('a');
        link.href = API_URLS.orderExport + '?' + params.toString();
        link.style.display = 'none';
        document.body.appendChild(link);
        link.click();
        
        setTimeout(function() {
            hideLoading();
            showMessage('success', '订单数据导出成功！');
            document.body.removeChild(link);
        }, 1000);
    }
    
    // 订单详情
    function viewOrder(orderId) {
        elements.orderDetailModal.classList.add('show');
        document.body.style.overflow = 'hidden';
        elements.orderDetailLoading.style.display = 'block';
        elements.orderDetailContent.style.display = 'none';
        switchTab('basic');
        loadOrderDetail(orderId);
    }
    
    function closeOrderDetailModal() {
        elements.orderDetailModal.classList.remove('show');
        document.body.style.overflow = '';
    }
    
    function switchTab(tabName) {
        document.querySelectorAll('.order-detail-tab').forEach(function(tab) {
            tab.classList.remove('active');
        });
        document.querySelectorAll('.tab-content').forEach(function(content) {
            content.classList.remove('active');
        });
        document.querySelector('[data-tab="' + tabName + '"]').classList.add('active');
        document.getElementById('tab-' + tabName).classList.add('active');
    }
    
    function loadOrderDetail(orderId) {
        if (!orderId || orderId === 'undefined') {
            elements.orderDetailLoading.innerHTML = '<div class="text-danger"><i class="mdi mdi-alert-circle me-2"></i>错误：订单ID无效</div>';
            return;
        }
        
        fetch(API_URLS.orderDetail + '?id=' + orderId)
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.code === 0) {
                    elements.orderDetailLoading.style.display = 'none';
                    elements.orderDetailContent.style.display = 'block';
                    fillOrderDetailData(data.data);
                } else {
                    elements.orderDetailLoading.innerHTML = '<div class="text-danger"><i class="mdi mdi-alert-circle me-2"></i>加载失败: ' + data.msg + '</div>';
                }
            })
            .catch(function(error) {
                elements.orderDetailLoading.innerHTML = '<div class="text-danger"><i class="mdi mdi-alert-circle me-2"></i>网络错误，请稍后重试</div>';
            });
    }
    
    function fillOrderDetailData(data) {
        var order = data.order;
        var shop = data.shop;
        var orderItems = data.orderItems;
        var shippingAddress = data.shippingAddress;
        var billingAddress = data.billingAddress;
        var discountCodes = data.discountCodes;
        
        document.getElementById('modalOrderTitle').textContent = '订单详情 - ' + (order.order_number || order.shopify_order_number || 'N/A');
        document.getElementById('detailOrderNumber').textContent = order.order_number || order.shopify_order_number || 'N/A';
        document.getElementById('detailShopName').textContent = shop.shop_name || '未知店铺';
        document.getElementById('detailOrderStatus').innerHTML = '<span class="status-badge ' + getStatusClass(order.order_status) + '">' + getStatusText(order.order_status) + '</span>';
        document.getElementById('detailFinancialStatus').innerHTML = '<span class="status-badge ' + getStatusClass(order.financial_status) + '">' + getStatusText(order.financial_status) + '</span>';
        document.getElementById('detailFulfillmentStatus').innerHTML = '<span class="status-badge ' + getStatusClass(order.fulfillment_status) + '">' + getStatusText(order.fulfillment_status) + '</span>';
        document.getElementById('detailCreatedAt').textContent = formatDateTime(order.shopify_created_at || order.created_at);
        document.getElementById('detailUpdatedAt').textContent = formatDateTime(order.shopify_updated_at || order.updated_at);
        document.getElementById('detailCurrency').textContent = order.currency || 'CNY';
        document.getElementById('detailCustomerName').textContent = order.customer_name || (order.customer_first_name + ' ' + order.customer_last_name) || 'N/A';
        document.getElementById('detailCustomerEmail').textContent = order.customer_email || 'N/A';
        document.getElementById('detailCustomerPhone').textContent = order.customer_phone || 'N/A';
        document.getElementById('detailCustomerId').textContent = order.customer_id || 'N/A';
        document.getElementById('detailPaymentMethod').textContent = order.payment_gateway_names || order.gateway || order.payment_method_name || 'N/A';
        
        fillOrderItems(orderItems);
        fillAddressInfo(shippingAddress, billingAddress);
        fillOrderSummary(order, discountCodes);
    }
    
    function fillOrderItems(orderItems) {
        var tbody = document.getElementById('orderItemsBody');
        tbody.innerHTML = '';
        
        if (!orderItems || orderItems.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted"><i class="mdi mdi-package-variant-closed me-2"></i>暂无商品信息</td></tr>';
            return;
        }
        
        tbody.innerHTML = orderItems.map(function(item) {
            var realUnitPrice = parseFloat(item.price || 0);
            var quantity = parseInt(item.quantity || 1);
            var subtotal = realUnitPrice * quantity;
            
            return '<tr>' +
                '<td><div class="product-info">' +
                    '<div class="product-title">' + (item.product_title || 'N/A') + '</div>' +
                    (item.variant_title ? '<div class="product-variant">' + item.variant_title + '</div>' : '') +
                    (item.sku ? '<div class="product-sku">SKU: ' + item.sku + '</div>' : '') +
                '</div></td>' +
                '<td>' + (item.sku || 'N/A') + '</td>' +
                '<td>' + quantity + '</td>' +
                '<td>¥' + realUnitPrice.toFixed(2) + '</td>' +
                '<td>¥' + realUnitPrice.toFixed(2) + ' x ' + quantity + '</td>' +
                '<td class="fw-bold">¥' + subtotal.toFixed(2) + '</td>' +
            '</tr>';
        }).join('');
    }
    
    function fillAddressInfo(shippingAddress, billingAddress) {
        if (shippingAddress && Object.keys(shippingAddress).length > 0) {
            var name = ((shippingAddress.first_name || '') + ' ' + (shippingAddress.last_name || '')).trim() || 'N/A';
            var details = [shippingAddress.address1, shippingAddress.address2, shippingAddress.city, shippingAddress.province, shippingAddress.country, shippingAddress.zip].filter(Boolean).join(', ') || 'N/A';
            document.getElementById('shippingAddressName').textContent = name;
            document.getElementById('shippingAddressDetails').textContent = details;
        } else {
            document.getElementById('shippingAddressName').textContent = 'N/A';
            document.getElementById('shippingAddressDetails').textContent = '暂无配送地址信息';
        }
        
        if (billingAddress && Object.keys(billingAddress).length > 0) {
            var name = ((billingAddress.first_name || '') + ' ' + (billingAddress.last_name || '')).trim() || 'N/A';
            var details = [billingAddress.address1, billingAddress.address2, billingAddress.city, billingAddress.province, billingAddress.country, billingAddress.zip].filter(Boolean).join(', ') || 'N/A';
            document.getElementById('billingAddressName').textContent = name;
            document.getElementById('billingAddressDetails').textContent = details;
        } else {
            document.getElementById('billingAddressName').textContent = 'N/A';
            document.getElementById('billingAddressDetails').textContent = '暂无账单地址信息';
        }
    }
    
    function fillOrderSummary(order, discountCodes) {
        var subtotal = parseFloat(order.subtotal_price || 0);
        var shipping = parseFloat(order.total_shipping_price_set?.shop_money?.amount || order.shipping_price || 0);
        var tax = parseFloat(order.total_tax || 0);
        var discount = parseFloat(order.total_discounts || 0);
        var total = parseFloat(order.total_price || 0);
        
        document.getElementById('summarySubtotal').textContent = '¥' + subtotal.toFixed(2);
        document.getElementById('summaryShipping').textContent = '¥' + shipping.toFixed(2);
        document.getElementById('summaryTax').textContent = '¥' + tax.toFixed(2);
        document.getElementById('summaryDiscount').textContent = '-¥' + discount.toFixed(2);
        document.getElementById('summaryTotal').textContent = '¥' + total.toFixed(2);
        
        if (discountCodes && discountCodes.length > 0) {
            document.getElementById('discountSection').style.display = 'block';
            document.getElementById('discountCodesList').innerHTML = discountCodes.map(function(code) {
                return '<div class="address-card"><div class="address-name">' + (code.code || 'N/A') + '</div><div class="address-details">类型: ' + (code.type || 'N/A') + '<br>金额: ¥' + parseFloat(code.amount || 0).toFixed(2) + '</div></div>';
            }).join('');
        } else {
            document.getElementById('discountSection').style.display = 'none';
        }
    }
    
    // 工具函数
    function showLoading() {
        if (typeof $ !== 'undefined' && $('#loading').length) {
            $('#loading').show();
        }
    }
    
    function hideLoading() {
        if (typeof $ !== 'undefined' && $('#loading').length) {
            $('#loading').hide();
        }
    }
    
    function showMessage(type, message) {
        var container = document.querySelector('.shopify-order-manager .card-body') || document.body;
        var alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-' + (type === 'error' ? 'danger' : type) + ' alert-dismissible fade show message-toast';
        alertDiv.style.marginBottom = '15px';
        alertDiv.innerHTML = '<i class="mdi mdi-' + (type === 'success' ? 'check-circle' : type === 'error' ? 'alert-circle' : 'information') + ' me-2"></i>' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
        container.insertBefore(alertDiv, container.firstChild);
        
        setTimeout(function() {
            if (alertDiv.parentNode) {
                alertDiv.classList.remove('show');
                setTimeout(function() {
                    if (alertDiv.parentNode) alertDiv.parentNode.removeChild(alertDiv);
                }, 300);
            }
        }, 4000);
    }
    
    // 页面加载完成后初始化
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
