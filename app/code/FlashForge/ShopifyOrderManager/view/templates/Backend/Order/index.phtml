// 显示消息提示
function showMessage(type, message) {
    // 查找页面头部容器
    let headerContainer = document.querySelector('.card-header') || 
                         document.querySelector('.modern-card .card-header');
    
    // 如果没有找到合适的头部容器，使用页面顶部
    if (!headerContainer) {
        headerContainer = document.querySelector('.container-fluid') || document.body;
    }
    
    // 创建提示元素
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type === 'success' ? 'success' : type === 'error' ? 'danger' : type} alert-dismissible fade show message-toast`;
    alertDiv.style.marginBottom = '15px';
    alertDiv.style.borderRadius = '12px';
    alertDiv.style.boxShadow = '0 8px 25px rgba(0,0,0,0.15)';
    alertDiv.innerHTML = `
        <i class="mdi mdi-${type === 'success' ? 'check-circle' : type === 'error' ? 'alert-circle' : 'information'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    // 在头部容器顶部插入提示
    if (headerContainer === document.body) {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    } else {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    }
    
    // 自动移除提示
    setTimeout(() => {
        if (alertDiv.parentNode) {
            alertDiv.classList.remove('show');
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.parentNode.removeChild(alertDiv);
                }
            }, 300);
        }
    }, 4000);
}

