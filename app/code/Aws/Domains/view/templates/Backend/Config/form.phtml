<script>
document.getElementById('configForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const form = this;
    const submitBtn = document.getElementById('submitBtn');
    const originalText = submitBtn.innerHTML;

    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('保存中...') ?>';
    submitBtn.disabled = true;

    const formData = new FormData(form);

    fetch('<?= $this->getBackendUrl('aws/backend/config/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;

        if (data.success) {
            alert('<?= __('保存成功') ?>');
            window.location.href = '<?= $this->getBackendUrl('aws/backend/config/index') ?>';
        } else {
            alert(data.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(err => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        alert('<?= __('请求失败') ?>: ' + err.message);
    });
});
</script>
