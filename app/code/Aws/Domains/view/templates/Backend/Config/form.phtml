<?php
/**
 * AWS 配置表单（内容模板）
 *
 * @var \Weline\Framework\View\Template $this
 */

/** @var \Aws\Domains\Model\AwsConfig $config */
$config = $config ?? null;
/** @var array $regions */
$regions = $regions ?? [];

$isEdit = $config && $config->getId();
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-0">
                <?php if ($isEdit): ?>
                    <lang>编辑 AWS 配置</lang>
                <?php else: ?>
                    <lang>新增 AWS 配置</lang>
                <?php endif; ?>
            </h4>
            <a href="<?= $this->getBackendUrl('aws/backend/config/index') ?>" class="btn btn-secondary">
                <i class="mdi mdi-arrow-left me-1"></i>
                <lang>返回列表</lang>
            </a>
        </div>
    </div>
</div>

<div class='row'>
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form id="configForm">
                    <?php if ($isEdit): ?>
                        <input type="hidden" name="id" value="<?= (int)$config->getId() ?>">
                    <?php endif; ?>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="name" class="form-label"><lang>配置名称</lang> <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="name" name="name" required
                                       value="<?= htmlspecialchars((string)($config?->getData('name') ?? ''), ENT_QUOTES) ?>"
                                       placeholder="<?= __('例如：主账号、测试账号') ?>">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="region" class="form-label"><lang>AWS 区域</lang></label>
                                <select class="form-select" id="region" name="region">
                                    <?php foreach ($regions as $code => $name): ?>
                                        <option value="<?= htmlspecialchars($code??'', ENT_QUOTES) ?>"
                                            <?= ($config?->getData('region') ?? 'us-east-1') === $code ? 'selected' : '' ?>>
                                            <?= htmlspecialchars($name??'', ENT_QUOTES) ?> (<?= htmlspecialchars($code??'', ENT_QUOTES) ?>)
                                        </option>
                                    <?php endforeach; ?>
                                </select>
                                <div class="form-text"><lang>Route 53 Domains 仅支持 us-east-1 区域</lang></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="access_key_id" class="form-label"><lang>Access Key ID</lang> <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="access_key_id" name="access_key_id" required
                                       value="<?= htmlspecialchars((string)($config?->getData('access_key_id') ?? ''), ENT_QUOTES) ?>"
                                       placeholder="AKIAIOSFODNN7EXAMPLE">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="secret_access_key" class="form-label">
                                    <lang>Secret Access Key</lang>
                                    <?php if (!$isEdit): ?>
                                        <span class="text-danger">*</span>
                                    <?php endif; ?>
                                </label>
                                <input type="password" class="form-control" id="secret_access_key" name="secret_access_key"
                                       <?= $isEdit ? '' : 'required' ?>
                                       value="<?= $isEdit ? '********' : '' ?>"
                                       placeholder="<?= $isEdit ? __('留空则不修改') : '' ?>">
                                <?php if ($isEdit): ?>
                                    <div class="form-text"><lang>留空则保持原密钥不变</lang></div>
                                <?php endif; ?>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label for="description" class="form-label"><lang>备注说明</lang></label>
                                <textarea class="form-control" id="description" name="description" rows="3"
                                          placeholder="<?= __('可选，配置的描述信息') ?>"><?= htmlspecialchars((string)($config?->getData('description') ?? ''), ENT_QUOTES) ?></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="is_active" name="is_active" value="1"
                                    <?= (!$isEdit || $config?->isActive()) ? 'checked' : '' ?>>
                                <label class="form-check-label" for="is_active">
                                    <lang>启用此配置</lang>
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="is_default" name="is_default" value="1"
                                    <?= $config?->isDefault() ? 'checked' : '' ?>>
                                <label class="form-check-label" for="is_default">
                                    <lang>设为默认配置</lang>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <a href="<?= $this->getBackendUrl('aws/backend/config/index') ?>" class="btn btn-secondary me-2">
                            <lang>取消</lang>
                        </a>
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <lang>保存</lang>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    document.getElementById('configForm').addEventListener('submit', function(e) {
        e.preventDefault();

        var form = this;
        var submitBtn = document.getElementById('submitBtn');
        var originalText = submitBtn.innerHTML;

        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('保存中...') ?>';
        submitBtn.disabled = true;

        var formData = new FormData(form);

        fetch('<?= $this->getBackendUrl('aws/backend/config/save') ?>', {
            method: 'POST',
            body: formData
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;

            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __('保存成功') ?>');
                }
                setTimeout(function() {
                    window.location.href = '<?= $this->getBackendUrl('aws/backend/config/index') ?>';
                }, 1000);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('保存失败') ?>');
                }
            }
        })
        .catch(function(err) {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
            }
        });
    });
})();
</script>
