<script>
function setDefault(id) {
    if (!confirm('<?= __('确定要将此配置设为默认吗？') ?>')) {
        return;
    }
    fetch('<?= $this->getBackendUrl('aws/backend/config/setDefault') ?>?id=' + id)
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message || '<?= __('操作失败') ?>');
            }
        })
        .catch(err => {
            alert('<?= __('请求失败') ?>: ' + err.message);
        });
}

function testConnection(id) {
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
    btn.disabled = true;

    fetch('<?= $this->getBackendUrl('aws/backend/config/test') ?>?id=' + id)
        .then(res => res.json())
        .then(data => {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
            if (data.success) {
                alert('<?= __('连接测试成功') ?>');
            } else {
                alert(data.message || '<?= __('连接测试失败') ?>');
            }
        })
        .catch(err => {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
            alert('<?= __('请求失败') ?>: ' + err.message);
        });
}

function deleteConfig(id) {
    if (!confirm('<?= __('确定要删除此配置吗？此操作不可撤销。') ?>')) {
        return;
    }
    fetch('<?= $this->getBackendUrl('aws/backend/config/delete') ?>?id=' + id)
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message || '<?= __('删除失败') ?>');
            }
        })
        .catch(err => {
            alert('<?= __('请求失败') ?>: ' + err.message);
        });
}
</script>
