<script>
(function() {
    'use strict';

    var setDefaultUrl = '<?= $this->getBackendUrl('aws/backend/config/setDefault') ?>';
    var testUrl = '<?= $this->getBackendUrl('aws/backend/config/test') ?>';
    var deleteUrl = '<?= $this->getBackendUrl('aws/backend/config/delete') ?>';

    function setDefault(id) {
        AdminConfirm.show('<?= __('确定要将此配置设为默认吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;

            fetch(setDefaultUrl + '?id=' + id)
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        AdminToast.error(data.message || '<?= __('操作失败') ?>');
                    }
                })
                .catch(function(err) {
                    AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
                });
        });
    }

    function testConnection(id, btn) {
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
        btn.disabled = true;

        fetch(testUrl + '?id=' + id)
            .then(function(res) { return res.json(); })
            .then(function(data) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                if (data.success) {
                    AdminToast.success('<?= __('连接测试成功') ?>');
                } else {
                    AdminToast.error(data.message || '<?= __('连接测试失败') ?>');
                }
            })
            .catch(function(err) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
            });
    }

    function deleteConfig(id) {
        AdminConfirm.show('<?= __('确定要删除此配置吗？此操作不可撤销。') ?>').then(function(confirmed) {
            if (!confirmed) return;

            fetch(deleteUrl + '?id=' + id)
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        AdminToast.error(data.message || '<?= __('删除失败') ?>');
                    }
                })
                .catch(function(err) {
                    AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
                });
        });
    }

    window.AwsConfig = {
        setDefault: setDefault,
        testConnection: testConnection,
        deleteConfig: deleteConfig
    };
})();
</script>
