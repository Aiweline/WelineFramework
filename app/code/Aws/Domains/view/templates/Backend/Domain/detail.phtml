<script>
function toggleAutoRenew(domainName, enable) {
    const action = enable ? '<?= __('开启') ?>' : '<?= __('关闭') ?>';
    if (!confirm('<?= __('确定要') ?>' + action + '<?= __('自动续费吗？') ?>')) {
        return;
    }

    const formData = new FormData();
    formData.append('domain_name', domainName);
    formData.append('config_id', <?= $config_id ?>);
    formData.append('enable', enable ? '1' : '');

    fetch('<?= $this->getBackendUrl('aws/backend/domain/toggleAutoRenew') ?>', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert(data.message || '<?= __('操作失败') ?>');
        }
    })
    .catch(err => {
        alert('<?= __('请求失败') ?>: ' + err.message);
    });
}
</script>
