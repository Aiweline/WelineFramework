<script>
(function() {
    'use strict';

    var renewUrl = '<?= $this->getBackendUrl('aws/backend/domain/doRenew') ?>';
    var indexUrl = '<?= $this->getBackendUrl('aws/backend/domain/index') ?>';

    var renewForm = document.getElementById('renewForm');

    if (renewForm) {
        renewForm.addEventListener('submit', function(e) {
            e.preventDefault();

            var submitBtn = document.getElementById('submitBtn');
            var originalHtml = submitBtn.innerHTML;

            AdminConfirm.show('<?= __('确定要续费此域名吗？费用将从您的 AWS 账户扣除。') ?>').then(function(confirmed) {
                if (!confirmed) return;

                submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('处理中...') ?>';
                submitBtn.disabled = true;

                var formData = new FormData(renewForm);

                fetch(renewUrl, {
                    method: 'POST',
                    body: formData
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    submitBtn.innerHTML = originalHtml;
                    submitBtn.disabled = false;

                    if (data.success) {
                        AdminToast.success(data.message || '<?= __('域名续费请求已提交') ?>');
                        window.location.href = indexUrl;
                    } else {
                        AdminToast.error(data.message || '<?= __('续费失败') ?>');
                    }
                })
                .catch(function(err) {
                    submitBtn.innerHTML = originalHtml;
                    submitBtn.disabled = false;
                    AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
                });
            });
        });
    }
})();
</script>
