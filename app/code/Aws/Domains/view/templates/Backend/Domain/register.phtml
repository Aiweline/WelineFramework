<script>
(function() {
    'use strict';

    var checkUrl = '<?= $this->getBackendUrl('aws/backend/domain/checkAvailability') ?>';
    var registerUrl = '<?= $this->getBackendUrl('aws/backend/domain/doRegister') ?>';
    var indexUrl = '<?= $this->getBackendUrl('aws/backend/domain/index') ?>';

    var checkDomainBtn = document.getElementById('checkDomainBtn');
    var registerForm = document.getElementById('registerForm');

    if (checkDomainBtn) {
        checkDomainBtn.addEventListener('click', function() {
            var domain = document.getElementById('domain_name').value.trim();
            var configId = document.getElementById('config_id').value;
            var resultDiv = document.getElementById('domainCheckResult');

            if (!domain) {
                resultDiv.innerHTML = '<span class="text-danger"><?= __('请输入域名') ?></span>';
                return;
            }

            var btn = this;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
            btn.disabled = true;

            var formData = new FormData();
            formData.append('domain', domain);
            formData.append('config_id', configId);

            fetch(checkUrl, {
                method: 'POST',
                body: formData
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                btn.innerHTML = originalText;
                btn.disabled = false;

                if (data.success) {
                    if (data.available) {
                        resultDiv.innerHTML = '<span class="text-success"><i class="mdi mdi-check-circle me-1"></i><?= __('域名可以注册') ?></span>';
                    } else {
                        resultDiv.innerHTML = '<span class="text-warning"><i class="mdi mdi-alert-circle me-1"></i>' + (data.message || '<?= __('域名不可用') ?>') + '</span>';
                    }
                } else {
                    resultDiv.innerHTML = '<span class="text-danger"><i class="mdi mdi-alert-circle me-1"></i>' + (data.message || '<?= __('检查失败') ?>') + '</span>';
                }
            })
            .catch(function(err) {
                btn.innerHTML = originalText;
                btn.disabled = false;
                resultDiv.innerHTML = '<span class="text-danger"><?= __('请求失败') ?>: ' + err.message + '</span>';
            });
        });
    }

    if (registerForm) {
        registerForm.addEventListener('submit', function(e) {
            e.preventDefault();

            var submitBtn = document.getElementById('submitBtn');
            var originalHtml = submitBtn.innerHTML;

            AdminConfirm.show('<?= __('确定要购买此域名吗？费用将从您的 AWS 账户扣除。') ?>').then(function(confirmed) {
                if (!confirmed) return;

                submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('处理中...') ?>';
                submitBtn.disabled = true;

                var formData = new FormData(registerForm);

                fetch(registerUrl, {
                    method: 'POST',
                    body: formData
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    submitBtn.innerHTML = originalHtml;
                    submitBtn.disabled = false;

                    if (data.success) {
                        AdminToast.success(data.message || '<?= __('域名注册请求已提交') ?>');
                        window.location.href = indexUrl;
                    } else {
                        AdminToast.error(data.message || '<?= __('注册失败') ?>');
                    }
                })
                .catch(function(err) {
                    submitBtn.innerHTML = originalHtml;
                    submitBtn.disabled = false;
                    AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
                });
            });
        });
    }
})();
</script>
