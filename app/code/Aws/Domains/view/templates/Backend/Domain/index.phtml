<script>
(function() {
    'use strict';

    var configId = <?= $config_id ?>;
    var toggleUrl = '<?= $this->getBackendUrl('aws/backend/domain/toggleAutoRenew') ?>';

    function toggleAutoRenew(domainName, enable) {
        var action = enable ? '<?= __('开启') ?>' : '<?= __('关闭') ?>';

        AdminConfirm.show('<?= __('确定要') ?>' + action + '<?= __('域名') ?> ' + domainName + ' <?= __('的自动续费吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;

            var formData = new FormData();
            formData.append('domain_name', domainName);
            formData.append('config_id', configId);
            formData.append('enable', enable ? '1' : '');

            fetch(toggleUrl, {
                method: 'POST',
                body: formData
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    location.reload();
                } else {
                    AdminToast.error(data.message || '<?= __('操作失败') ?>');
                }
            })
            .catch(function(err) {
                AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
            });
        });
    }

    window.AwsDomainIndex = {
        toggleAutoRenew: toggleAutoRenew
    };
})();
</script>
