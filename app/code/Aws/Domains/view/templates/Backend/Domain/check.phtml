<script>
document.getElementById('checkForm').addEventListener('submit', function(e) {
    e.preventDefault();
    checkDomain();
});

document.getElementById('domain').addEventListener('input', function() {
    document.getElementById('getSuggestionsBtn').disabled = this.value.trim() === '';
});

document.getElementById('getSuggestionsBtn').addEventListener('click', function() {
    getSuggestions();
});

function checkDomain() {
    const domain = document.getElementById('domain').value.trim();
    const configId = document.getElementById('config_id').value;
    const resultDiv = document.getElementById('checkResult');
    const checkBtn = document.getElementById('checkBtn');
    const originalHtml = checkBtn.innerHTML;

    if (!domain) {
        alert('<?= __('请输入域名') ?>');
        return;
    }

    checkBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('查询中...') ?>';
    checkBtn.disabled = true;
    resultDiv.style.display = 'none';

    const formData = new FormData();
    formData.append('domain', domain);
    formData.append('config_id', configId);

    fetch('<?= $this->getBackendUrl('aws/backend/domain/checkAvailability') ?>', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        checkBtn.innerHTML = originalHtml;
        checkBtn.disabled = false;
        resultDiv.style.display = 'block';

        if (data.success) {
            const availableClass = data.available ? 'alert-success' : 'alert-warning';
            const icon = data.available ? 'mdi-check-circle-outline' : 'mdi-alert-circle-outline';

            let html = `<div class="alert ${availableClass}">
                <i class="mdi ${icon} me-2"></i>
                ${data.message}
            </div>`;

            if (data.available) {
                html += `<a href="<?= $this->getBackendUrl('aws/backend/domain/register') ?>?domain=${encodeURIComponent(domain)}&config_id=${configId}"
                           class="btn btn-success">
                    <i class="mdi mdi-cart-plus me-1"></i>
                    <?= __('立即购买') ?>
                </a>`;
            }

            resultDiv.innerHTML = html;
        } else {
            resultDiv.innerHTML = `<div class="alert alert-danger">
                <i class="mdi mdi-alert-circle-outline me-2"></i>
                ${data.message || '<?= __('查询失败') ?>'}
            </div>`;
        }
    })
    .catch(err => {
        checkBtn.innerHTML = originalHtml;
        checkBtn.disabled = false;
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<div class="alert alert-danger">
            <i class="mdi mdi-alert-circle-outline me-2"></i>
            <?= __('请求失败') ?>: ${err.message}
        </div>`;
    });
}

function getSuggestions() {
    const domain = document.getElementById('domain').value.trim();
    const configId = document.getElementById('config_id').value;
    const resultDiv = document.getElementById('suggestionsResult');
    const btn = document.getElementById('getSuggestionsBtn');
    const originalHtml = btn.innerHTML;

    if (!domain) {
        alert('<?= __('请先输入域名') ?>');
        return;
    }

    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('获取中...') ?>';
    btn.disabled = true;

    const formData = new FormData();
    formData.append('domain', domain);
    formData.append('config_id', configId);

    fetch('<?= $this->getBackendUrl('aws/backend/domain/suggestions') ?>', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        btn.innerHTML = originalHtml;
        btn.disabled = false;

        if (data.success && data.suggestions && data.suggestions.length > 0) {
            let html = '<div class="row">';
            data.suggestions.forEach(function(suggestion) {
                const domainName = suggestion.DomainName || suggestion;
                const availability = suggestion.Availability || 'AVAILABLE';
                const badgeClass = availability === 'AVAILABLE' ? 'bg-success' : 'bg-secondary';

                html += `<div class="col-md-4 mb-2">
                    <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                        <span>${domainName}</span>
                        <span class="badge ${badgeClass}">${availability === 'AVAILABLE' ? '<?= __('可用') ?>' : availability}</span>
                    </div>
                </div>`;
            });
            html += '</div>';
            resultDiv.innerHTML = html;
        } else {
            resultDiv.innerHTML = '<div class="text-muted"><?= __('暂无建议') ?></div>';
        }
    })
    .catch(err => {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
        resultDiv.innerHTML = `<div class="text-danger"><?= __('获取失败') ?>: ${err.message}</div>`;
    });
}
</script>
