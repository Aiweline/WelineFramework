<script>
let nsIndex = <?= count($currentNameservers) ?: 2 ?>;

document.getElementById('addNsBtn').addEventListener('click', function() {
    const list = document.getElementById('nameserversList');
    const row = document.createElement('div');
    row.className = 'input-group mb-2 ns-row';
    row.innerHTML = `
        <span class="input-group-text"><i class="mdi mdi-server"></i></span>
        <input type="text" class="form-control" name="nameservers[${nsIndex}][name]"
               placeholder="<?= __('例如：ns1.example.com') ?>">
        <button type="button" class="btn btn-outline-danger remove-ns-btn">
            <i class="mdi mdi-delete"></i>
        </button>
    `;
    list.appendChild(row);
    nsIndex++;
});

document.getElementById('nameserversList').addEventListener('click', function(e) {
    if (e.target.closest('.remove-ns-btn')) {
        const rows = document.querySelectorAll('.ns-row');
        if (rows.length > 2) {
            e.target.closest('.ns-row').remove();
        } else {
            alert('<?= __('至少需要保留 2 个域名服务器') ?>');
        }
    }
});

document.getElementById('nsForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const submitBtn = document.getElementById('submitBtn');
    const originalHtml = submitBtn.innerHTML;

    // 验证至少有 2 个域名服务器
    const inputs = document.querySelectorAll('input[name^="nameservers"]');
    let validCount = 0;
    inputs.forEach(function(input) {
        if (input.value.trim() !== '') {
            validCount++;
        }
    });

    if (validCount < 2) {
        alert('<?= __('至少需要提供 2 个有效的域名服务器') ?>');
        return;
    }

    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('保存中...') ?>';
    submitBtn.disabled = true;

    const formData = new FormData(this);

    fetch('<?= $this->getBackendUrl('aws/backend/domain/updateNameservers') ?>', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        submitBtn.innerHTML = originalHtml;
        submitBtn.disabled = false;

        if (data.success) {
            alert(data.message || '<?= __('域名服务器更新成功') ?>');
            window.location.href = '<?= $this->getBackendUrl('aws/backend/domain/detail', ['domain' => $domain_name, 'config_id' => $config_id]) ?>';
        } else {
            alert(data.message || '<?= __('更新失败') ?>');
        }
    })
    .catch(err => {
        submitBtn.innerHTML = originalHtml;
        submitBtn.disabled = false;
        alert('<?= __('请求失败') ?>: ' + err.message);
    });
});
</script>
