<script>
(function() {
    'use strict';
    
    var nsIndex = <?= count($currentNameservers) ?: 2 ?>;

    document.getElementById('addNsBtn')?.addEventListener('click', function() {
        var list = document.getElementById('nameserversList');
        var row = document.createElement('div');
        row.className = 'input-group mb-2 ns-row';
        row.innerHTML = '<span class="input-group-text"><i class="mdi mdi-server"></i></span>' +
            '<input type="text" class="form-control" name="nameservers[' + nsIndex + '][name]" placeholder="<?= __('例如：ns1.example.com') ?>">' +
            '<button type="button" class="btn btn-outline-danger remove-ns-btn"><i class="mdi mdi-delete"></i></button>';
        list.appendChild(row);
        nsIndex++;
    });

    document.getElementById('nameserversList')?.addEventListener('click', function(e) {
        if (e.target.closest('.remove-ns-btn')) {
            var rows = document.querySelectorAll('.ns-row');
            if (rows.length > 2) {
                e.target.closest('.ns-row').remove();
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.warning('<?= __('至少需要保留 2 个域名服务器') ?>');
                }
            }
        }
    });

    document.getElementById('nsForm')?.addEventListener('submit', function(e) {
        e.preventDefault();

        var submitBtn = document.getElementById('submitBtn');
        var originalHtml = submitBtn.innerHTML;

        var inputs = document.querySelectorAll('input[name^="nameservers"]');
        var validCount = 0;
        inputs.forEach(function(input) {
            if (input.value.trim() !== '') {
                validCount++;
            }
        });

        if (validCount < 2) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.warning('<?= __('至少需要提供 2 个有效的域名服务器') ?>');
            }
            return;
        }

        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __('保存中...') ?>';
        submitBtn.disabled = true;

        var formData = new FormData(this);

        var url = '<?= $this->getBackendUrl('aws/backend/domain/updateNameservers') ?>';
        var opts = { method: 'POST', body: formData };
        window.Weline.Api.request(url, opts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            submitBtn.innerHTML = originalHtml;
            submitBtn.disabled = false;

            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success(data.message || '<?= __('域名服务器更新成功') ?>');
                }
                setTimeout(function() {
                    window.location.href = '<?= $this->getBackendUrl('aws/backend/domain/detail', ['domain' => $domain_name, 'config_id' => $config_id]) ?>';
                }, 1000);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('更新失败') ?>');
                }
            }
        })
        .catch(function(err) {
            submitBtn.innerHTML = originalHtml;
            submitBtn.disabled = false;
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __('请求失败') ?>: ' + err.message);
            }
        });
    });
})();
</script>
