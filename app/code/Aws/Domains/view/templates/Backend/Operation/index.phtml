                                        ?>
                                        <span class="badge <?= $statusClass ?>"><?= htmlspecialchars($statusName, ENT_QUOTES) ?></span>
                                    </td>
                                    <td>
                                        <?php if (!empty($op['aws_operation_id'])): ?>
                                            <code class="small"><?= htmlspecialchars(substr($op['aws_operation_id'], 0, 20), ENT_QUOTES) ?>...</code>
                                        <?php else: ?>
                                            <span class="text-muted">-</span>
                                        <?php endif; ?>
                                    </td>
                                    <td><?= htmlspecialchars($op['operator_name'] ?? '-', ENT_QUOTES) ?></td>
                                    <td><?= htmlspecialchars($op['created_at'] ?? '-', ENT_QUOTES) ?></td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-info aws-show-detail-btn"
                                                data-id="<?= (int)($op['operation_id'] ?? 0) ?>">
