                    </nav>
                    <div class="text-center text-muted small mt-2">
                        <lang>共</lang> <?= $total ?> <lang>条记录</lang>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><lang>操作详情</lang></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailContent">
                <div class="text-center py-4">
                    <i class="mdi mdi-loading mdi-spin mdi-48px"></i>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><lang>关闭</lang></button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    document.querySelectorAll('.aws-show-detail-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.dataset.id;
            showDetail(id);
        });
    });
    
    function showDetail(id) {
        var modal = new bootstrap.Modal(document.getElementById('detailModal'));
        var content = document.getElementById('detailContent');

        content.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin mdi-48px"></i></div>';
        modal.show();

        var url = '<?= $this->getBackendUrl('aws/backend/operation/detail') ?>?id=' + id;
        window.Weline.Api.get(url, { silent: true })
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success && data.operation) {
                    var op = data.operation;
                    var html = '<table class="table table-borderless">' +
                        '<tr><th width="30%"><?= __('操作ID') ?></th><td>' + op.id + '</td></tr>' +
                        '<tr><th><?= __('域名') ?></th><td>' + (op.domain_name || '-') + '</td></tr>' +
                        '<tr><th><?= __('操作类型') ?></th><td>' + op.operation_type_name + '</td></tr>' +
                        '<tr><th><?= __('状态') ?></th><td>' + op.status_name + '</td></tr>' +
                        '<tr><th><?= __('AWS 操作ID') ?></th><td><code>' + (op.aws_operation_id || '-') + '</code></td></tr>' +
                        (op.error_message ? '<tr><th><?= __('错误信息') ?></th><td class="text-danger">' + op.error_message + '</td></tr>' : '') +
                        '<tr><th><?= __('操作人') ?></th><td>' + (op.operator_name || '-') + '</td></tr>' +
                        '<tr><th><?= __('创建时间') ?></th><td>' + op.created_at + '</td></tr>' +
                        '<tr><th><?= __('更新时间') ?></th><td>' + op.updated_at + '</td></tr>' +
                        '</table>';

                    if (op.request_data && Object.keys(op.request_data).length > 0) {
                        html += '<h6><?= __('请求数据') ?></h6>' +
                            '<pre class="bg-light p-2 rounded small" style="max-height: 200px; overflow: auto;">' + 
                            JSON.stringify(op.request_data, null, 2) + '</pre>';
                    }

                    if (op.response_data && Object.keys(op.response_data).length > 0) {
                        html += '<h6><?= __('响应数据') ?></h6>' +
                            '<pre class="bg-light p-2 rounded small" style="max-height: 200px; overflow: auto;">' + 
                            JSON.stringify(op.response_data, null, 2) + '</pre>';
                    }

                    content.innerHTML = html;
                } else {
                    content.innerHTML = '<div class="alert alert-danger">' + (data.message || '<?= __('获取失败') ?>') + '</div>';
                }
            })
            .catch(function(err) {
                content.innerHTML = '<div class="alert alert-danger"><?= __('请求失败') ?>: ' + err.message + '</div>';
            });
    }
})();
</script>
