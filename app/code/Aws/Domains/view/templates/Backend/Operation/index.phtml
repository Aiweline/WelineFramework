                                    </td>
                                    <td>
                                        <?php
                                        $opType = $op['operation_type'] ?? '';
                                        $typeName = $operation_types[$opType] ?? $opType;
                                        ?>
                                        <span class="badge bg-info"><?= htmlspecialchars($typeName, ENT_QUOTES) ?></span>
                                    </td>
                                    <td>
                                        <?php
                                        $opStatus = $op['status'] ?? '';
                                        $statusName = $statuses[$opStatus] ?? $opStatus;
                                        $statusClass = match ($opStatus) {
                                            DomainOperation::STATUS_SUCCESS => 'bg-success',
                                            DomainOperation::STATUS_FAILED => 'bg-danger',
                                            DomainOperation::STATUS_IN_PROGRESS => 'bg-warning text-dark',
                                            DomainOperation::STATUS_CANCELLED => 'bg-secondary',
                                            default => 'bg-light text-dark',
