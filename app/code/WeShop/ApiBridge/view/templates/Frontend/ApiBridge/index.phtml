<script>
document.addEventListener('DOMContentLoaded', function() {
    const testerSection = document.getElementById('api-tester-section');
    const docsSection = document.getElementById('api-docs-section');
    const testerForm = document.getElementById('api-tester-form');
    const testEndpointSelect = document.getElementById('test-endpoint');
    const testResponseCode = document.getElementById('test-response-code');
    const docsContent = document.getElementById('docs-content');
    const docsEndpointName = document.getElementById('docs-endpoint-name');

    // Test endpoint buttons
    document.querySelectorAll('.test-endpoint-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const endpoint = this.dataset.endpoint;
            testEndpointSelect.value = endpoint;
            testerSection.style.display = 'block';
            docsSection.style.display = 'none';
            testerSection.scrollIntoView({ behavior: 'smooth' });
        });
    });

    // View docs buttons
    document.querySelectorAll('.view-docs-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const endpoint = this.dataset.endpoint;
            showEndpointDocs(endpoint);
        });
    });

    // Close tester button
    document.getElementById('close-tester-btn').addEventListener('click', function() {
        testerSection.style.display = 'none';
    });

    // Close docs button
    document.getElementById('close-docs-btn').addEventListener('click', function() {
        docsSection.style.display = 'none';
    });

    // Form submission
    testerForm.addEventListener('submit', function(e) {
        e.preventDefault();

        const endpoint = testEndpointSelect.value;
        const method = document.getElementById('test-method').value;
        const paramsText = document.getElementById('test-params').value;

        let params = {};
        try {
            params = JSON.parse(paramsText);
        } catch (err) {
                // 不再使用 alert/confirm/prompt；改为写入页面现有的响应提示区域
                testResponseCode.textContent = <?= json_encode(__('Invalid JSON format in parameters')) ?>;
            return;
        }

        testResponseCode.textContent = '<?= __('Loading...') ?>';

        // Make AJAX request
        fetch('<?= $this->getUrl('weshop/apibridge/test') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                endpoint: endpoint,
                method: method,
                params: params
            })
        })
        .then(function(response) {
            return response.json();
        })
        .then(function(data) {
            testResponseCode.textContent = JSON.stringify(data, null, 2);
        })
        .catch(function(error) {
            testResponseCode.textContent = 'Error: ' + error.message;
        });
    });

    function showEndpointDocs(endpoint) {
        const endpoints = <?= json_encode($api_doc['endpoints'] ?? []) ?>;
        const endpointData = endpoints[endpoint];

        if (endpointData) {
            docsEndpointName.textContent = endpointData.name || endpoint;
            docsContent.innerHTML = generateDocsContent(endpointData);
            docsSection.style.display = 'block';
            testerSection.style.display = 'none';
            docsSection.scrollIntoView({ behavior: 'smooth' });
        }
    }

    function generateDocsContent(endpointData) {
        let html = '<div class="endpoint-docs">';
        html += '<h6>' + '<?= __('Endpoint Information') ?>' + '</h6>';
        html += '<table class="table table-sm">';
        html += '<tbody>';
        html += '<tr><th scope="row"><?= __('Name') ?></th><td>' + (endpointData.name || '-') + '</td></tr>';
        html += '<tr><th scope="row"><?= __('Version') ?></th><td>' + (endpointData.version || '-') + '</td></tr>';
        html += '<tr><th scope="row"><?= __('Description') ?></th><td>' + (endpointData.description || '-') + '</td></tr>';
        html += '<tr><th scope="row"><?= __('Class') ?></th><td><code>' + (endpointData.class || '-') + '</code></td></tr>';
        html += '</tbody></table>';

        html += '<h6 class="mt-4">' + '<?= __('Available Methods') ?>' + '</h6>';
        html += '<ul class="list-group">';
        html += '<li class="list-group-item"><code>index</code> - <?= __('List all items') ?></li>';
        html += '<li class="list-group-item"><code>getList</code> - <?= __('Get paginated list') ?></li>';
        html += '<li class="list-group-item"><code>get</code> - <?= __('Get single item') ?></li>';
        html += '<li class="list-group-item"><code>create</code> - <?= __('Create new item') ?></li>';
        html += '<li class="list-group-item"><code>update</code> - <?= __('Update existing item') ?></li>';
        html += '<li class="list-group-item"><code>delete</code> - <?= __('Delete item') ?></li>';
        html += '</ul>';
        html += '</div>';

        return html;
    }
});
</script>
