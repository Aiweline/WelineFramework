<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 控制器模板获取前事件 - 传递产品数据到布局模板 -->
    <event name="Weline_Framework_Controller::fetch_file_before">
        <observer name="WeShop_Product::controller_fetch_file_before" instance="WeShop\Product\Observer\ControllerFetchFileBefore" disabled="false" shared="true" sort="20"/>
    </event>
    
    <!-- 产品事件定义 -->
    <events>
        <!-- 产品保存前事件 -->
        <event name="WeShop_Product::product_save_before">
            <description>产品保存前触发，可用于验证产品数据</description>
        </event>
        
        <!-- 产品保存后事件 -->
        <event name="WeShop_Product::product_save_after">
            <description>产品保存后触发，可用于更新索引、缓存、库存等</description>
            <!-- 库存模块可以监听此事件初始化库存记录 -->
        </event>
        
        <!-- 产品删除前事件 -->
        <event name="WeShop_Product::product_delete_before">
            <description>产品删除前触发，可用于验证是否可删除</description>
        </event>
        
        <!-- 产品删除后事件 -->
        <event name="WeShop_Product::product_delete_after">
            <description>产品删除后触发，可用于清理相关数据</description>
        </event>
        
        <!-- 分类保存后事件 -->
        <event name="WeShop_Product::category_save_after">
            <description>分类保存后触发，可用于更新分类缓存</description>
        </event>
        
        <!-- 分类删除后事件 -->
        <event name="WeShop_Product::category_delete_after">
            <description>分类删除后触发，可用于清理相关数据</description>
        </event>
        
        <!-- 产品状态变更事件 -->
        <event name="WeShop_Product::product_status_change">
            <description>产品状态变更时触发（启用/禁用）</description>
        </event>
        
        <!-- 产品价格变更事件 -->
        <event name="WeShop_Product::product_price_change">
            <description>产品价格变更时触发</description>
        </event>
    </events>
</config>

