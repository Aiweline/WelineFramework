    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.toolbar-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.toolbar-item label {
    font-size: 0.875rem;
    color: var(--color-text-muted, #6c757d);
    white-space: nowrap;
}

.sort-select,
.pagesize-select {
    padding: 0.5rem 2rem 0.5rem 0.75rem;
