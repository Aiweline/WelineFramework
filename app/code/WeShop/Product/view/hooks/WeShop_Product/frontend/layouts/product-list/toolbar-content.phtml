<?php
/**
 * WeShop Product模块 - 产品列表工具栏Hook
 * 
 * 在产品列表页工具栏区域渲染排序、视图切换、每页数量等选项
 * Hook名称：WeShop_Product::frontend::layouts::product-list::toolbar-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品列表数据（由控制器传递）
$products = $this->getData('products') ?? [];
$pagination = $this->getData('pagination') ?? [];
$sortOptions = $this->getData('sort_options') ?? [];
$currentSort = $this->getData('current_sort') ?? 'default';
$currentView = $this->getData('current_view') ?? 'grid';
$pageSize = (int)($pagination['page_size'] ?? 24);
$totalCount = (int)($pagination['total'] ?? count($products));

// 默认排序选项
if (empty($sortOptions)) {
    $sortOptions = [
        'default' => __('默认排序'),
        'price_asc' => __('价格从低到高'),
        'price_desc' => __('价格从高到低'),
        'name_asc' => __('名称 A-Z'),
        'name_desc' => __('名称 Z-A'),
        'newest' => __('最新上架'),
        'bestselling' => __('销量最高'),
    ];
}

// 每页数量选项
$pageSizeOptions = [12, 24, 48, 96];
?>

<div class="product-toolbar">
    <div class="toolbar-left">
        <span class="product-count">
            <?= sprintf(__('共 %d 件商品'), $totalCount) ?>
        </span>
    </div>
    
    <div class="toolbar-right">
        <!-- 排序选择 -->
        <div class="toolbar-item sort-selector">
            <label for="product-sort"><?= __('排序') ?>:</label>
            <select id="product-sort" class="sort-select" data-action="sort">
                <?php foreach ($sortOptions as $value => $label): ?>
                <option value="<?= htmlspecialchars($value) ?>" <?= $currentSort === $value ? 'selected' : '' ?>>
                    <?= htmlspecialchars($label) ?>
                </option>
                <?php endforeach; ?>
            </select>
        </div>
        
        <!-- 每页数量 -->
        <div class="toolbar-item pagesize-selector">
            <label for="page-size"><?= __('每页') ?>:</label>
            <select id="page-size" class="pagesize-select" data-action="pagesize">
                <?php foreach ($pageSizeOptions as $size): ?>
                <option value="<?= $size ?>" <?= $pageSize === $size ? 'selected' : '' ?>>
                    <?= $size ?> <?= __('件') ?>
                </option>
                <?php endforeach; ?>
            </select>
        </div>
        
        <!-- 视图切换 -->
        <div class="toolbar-item view-switcher">
            <button type="button" 
                    class="view-btn <?= $currentView === 'grid' ? 'active' : '' ?>" 
                    data-view="grid" 
                    title="<?= __('网格视图') ?>">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
                    <rect x="0" y="0" width="8" height="8" rx="1"></rect>
                    <rect x="10" y="0" width="8" height="8" rx="1"></rect>
                    <rect x="0" y="10" width="8" height="8" rx="1"></rect>
                    <rect x="10" y="10" width="8" height="8" rx="1"></rect>
                </svg>
            </button>
            <button type="button" 
                    class="view-btn <?= $currentView === 'list' ? 'active' : '' ?>" 
                    data-view="list" 
                    title="<?= __('列表视图') ?>">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
                    <rect x="0" y="0" width="18" height="4" rx="1"></rect>
                    <rect x="0" y="7" width="18" height="4" rx="1"></rect>
                    <rect x="0" y="14" width="18" height="4" rx="1"></rect>
                </svg>
            </button>
        </div>
    </div>
</div>

<style>
