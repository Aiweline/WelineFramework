<?php
/**
 * WeShop Product模块 - 产品列表分页Hook
 * 
 * 在产品列表页分页区域渲染分页组件
 * Hook名称：WeShop_Product::frontend::layouts::product-list::pagination-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取分页数据（由控制器传递）
$pagination = $this->getData('pagination') ?? [];
$products = $this->getData('products') ?? [];

// 分页参数
$currentPage = (int)($pagination['current_page'] ?? 1);
$pageSize = (int)($pagination['page_size'] ?? 24);
$totalCount = (int)($pagination['total'] ?? count($products));
$totalPages = (int)($pagination['total_pages'] ?? ceil($totalCount / $pageSize));

// 如果只有一页或没有数据，不渲染分页
if ($totalPages <= 1) {
    return;
}

// 计算显示的页码范围
$maxVisiblePages = 5;
$startPage = max(1, $currentPage - floor($maxVisiblePages / 2));
$endPage = min($totalPages, $startPage + $maxVisiblePages - 1);

// 调整起始页
if ($endPage - $startPage + 1 < $maxVisiblePages) {
    $startPage = max(1, $endPage - $maxVisiblePages + 1);
}

// 获取当前URL参数
$currentUrl = parse_url(\w_env_request_uri(), PHP_URL_PATH);
$queryParams = \w_env_get();
if (!is_array($queryParams)) {
    $queryParams = [];
}
unset($queryParams['page']);
$baseQuery = http_build_query($queryParams);
$baseUrl = $currentUrl . ($baseQuery ? '?' . $baseQuery . '&' : '?');
?>

<nav class="pagination-nav" aria-label="<?= __('产品列表分页') ?>">
    <div class="pagination-info">
        <?php
        $startItem = ($currentPage - 1) * $pageSize + 1;
        $endItem = min($currentPage * $pageSize, $totalCount);
        ?>
        <span class="pagination-text">
            <?= sprintf(__('显示 %d-%d，共 %d 件'), $startItem, $endItem, $totalCount) ?>
        </span>
    </div>
    
    <ul class="pagination">
        <!-- 首页 -->
        <?php if ($currentPage > 1): ?>
        <li class="page-item">
            <a href="<?= htmlspecialchars($baseUrl) ?>page=1" class="page-link page-first" title="<?= __('首页') ?>">
                <span aria-hidden="true">«</span>
            </a>
        </li>
        <?php endif; ?>
        
        <!-- 上一页 -->
        <?php if ($currentPage > 1): ?>
        <li class="page-item">
            <a href="<?= htmlspecialchars($baseUrl) ?>page=<?= $currentPage - 1 ?>" class="page-link page-prev" title="<?= __('上一页') ?>">
                <span aria-hidden="true">‹</span>
            </a>
        </li>
        <?php endif; ?>
        
        <!-- 页码省略号（前） -->
        <?php if ($startPage > 1): ?>
        <li class="page-item disabled">
            <span class="page-link page-ellipsis">…</span>
        </li>
        <?php endif; ?>
        
        <!-- 页码 -->
        <?php for ($page = $startPage; $page <= $endPage; $page++): ?>
        <li class="page-item <?= $page === $currentPage ? 'active' : '' ?>">
            <?php if ($page === $currentPage): ?>
            <span class="page-link current"><?= $page ?></span>
            <?php else: ?>
            <a href="<?= htmlspecialchars($baseUrl) ?>page=<?= $page ?>" class="page-link"><?= $page ?></a>
            <?php endif; ?>
        </li>
        <?php endfor; ?>
        
        <!-- 页码省略号（后） -->
        <?php if ($endPage < $totalPages): ?>
        <li class="page-item disabled">
            <span class="page-link page-ellipsis">…</span>
        </li>
        <?php endif; ?>
        
        <!-- 下一页 -->
        <?php if ($currentPage < $totalPages): ?>
        <li class="page-item">
            <a href="<?= htmlspecialchars($baseUrl) ?>page=<?= $currentPage + 1 ?>" class="page-link page-next" title="<?= __('下一页') ?>">
                <span aria-hidden="true">›</span>
            </a>
        </li>
        <?php endif; ?>
        
        <!-- 末页 -->
        <?php if ($currentPage < $totalPages): ?>
        <li class="page-item">
            <a href="<?= htmlspecialchars($baseUrl) ?>page=<?= $totalPages ?>" class="page-link page-last" title="<?= __('末页') ?>">
                <span aria-hidden="true">»</span>
            </a>
        </li>
        <?php endif; ?>
    </ul>
    
    <!-- 页码跳转 -->
    <div class="pagination-jump">
        <label for="page-jump"><?= __('跳转到') ?></label>
        <input type="number" 
               id="page-jump" 
               class="page-jump-input" 
               min="1" 
               max="<?= $totalPages ?>" 
               value="<?= $currentPage ?>" />
        <span class="total-pages">/ <?= $totalPages ?> <?= __('页') ?></span>
        <button type="button" class="btn-page-jump"><?= __('确定') ?></button>
    </div>
</nav>

<style>
/* ========================================
   分页组件样式
   ======================================== */
.pagination-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
}

.pagination-info {
    font-size: 0.875rem;
    color: var(--color-text-muted, #6c757d);
}

.pagination {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
}

.page-item {
    display: flex;
}

.page-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 0.5rem;
    border: 1px solid var(--color-border-light, #e5e7eb);
    background: var(--color-bg-primary, #fff);
    color: var(--color-text-primary, #111827);
    font-size: 0.875rem;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s;
}

.page-link:hover {
    border-color: var(--color-accent, #3b82f6);
    color: var(--color-accent, #3b82f6);
}

.page-item.active .page-link,
.page-link.current {
    background: var(--color-accent, #3b82f6);
    border-color: var(--color-accent, #3b82f6);
    color: #fff;
}

.page-item.disabled .page-link {
    color: var(--color-text-muted, #9ca3af);
    cursor: default;
    pointer-events: none;
}

.page-ellipsis {
    border: none;
    background: none;
}

.page-first,
.page-last,
.page-prev,
.page-next {
    font-size: 1.1rem;
}

/* 页码跳转 */
.pagination-jump {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #6b7280);
}

.page-jump-input {
    width: 50px;
    height: 32px;
    padding: 0 0.5rem;
    border: 1px solid var(--color-border-light, #e5e7eb);
    border-radius: 4px;
    text-align: center;
    font-size: 0.875rem;
    -moz-appearance: textfield;
}

.page-jump-input::-webkit-outer-spin-button,
.page-jump-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

.page-jump-input:focus {
    outline: none;
    border-color: var(--color-accent, #3b82f6);
}

.total-pages {
    white-space: nowrap;
}

.btn-page-jump {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-accent, #3b82f6);
    background: transparent;
    color: var(--color-accent, #3b82f6);
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-page-jump:hover {
    background: var(--color-accent, #3b82f6);
    color: #fff;
}

/* 响应式设计 */
@media (max-width: 576px) {
    .pagination-nav {
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .pagination {
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .page-link {
        min-width: 32px;
        height: 32px;
        font-size: 0.8rem;
    }
    
    .pagination-jump {
        flex-wrap: wrap;
        justify-content: center;
    }
    
    /* 在移动端隐藏首末页按钮 */
    .page-first,
    .page-last {
        display: none;
    }
}
</style>

<script>
(function() {
    // 页码跳转
    var jumpInput = document.getElementById('page-jump');
    var jumpBtn = document.querySelector('.btn-page-jump');
    
    if (jumpInput && jumpBtn) {
        var maxPage = <?= $totalPages ?>;
        var baseUrl = '<?= htmlspecialchars($baseUrl) ?>';
        
        function jumpToPage() {
            var page = parseInt(jumpInput.value) || 1;
            page = Math.max(1, Math.min(maxPage, page));
            window.location.href = baseUrl + 'page=' + page;
        }
        
        jumpBtn.addEventListener('click', jumpToPage);
        
        jumpInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                jumpToPage();
            }
        });
    }
})();
</script>
