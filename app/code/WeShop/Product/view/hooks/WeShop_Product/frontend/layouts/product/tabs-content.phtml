    <section class="product-tab-panel product-detail-section" id="qa-content" role="region" aria-labelledby="qa-heading" data-product-section="qa">
        <header class="product-detail-section__header">
            <h3 class="product-detail-section__title" id="qa-heading"><?= __('Q&A') ?></h3>
            <?php if ($qaCount > 0): ?>
                <span class="product-detail-section__count">(<?= $qaCount ?>)</span>
            <?php endif; ?>
        </header>
        <w:hook>WeShop_QA::frontend::layouts::product-questions::content<else/>
            <p class="product-tab-empty">
                <span class="product-tab-empty__title"><?= __('No questions yet') ?></span>
