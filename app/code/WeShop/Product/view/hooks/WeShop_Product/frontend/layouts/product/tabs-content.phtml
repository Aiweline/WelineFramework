    <section class="product-tab-panel product-detail-section" id="reviews-content" role="region" aria-labelledby="reviews-heading" data-product-section="reviews">
        <header class="product-detail-section__header">
            <h3 class="product-detail-section__title" id="reviews-heading"><?= __('Reviews') ?></h3>
            <?php if ($reviewCount > 0): ?>
                <span class="product-detail-section__count">(<?= $reviewCount ?>)</span>
            <?php endif; ?>
        </header>
        <w:hook>WeShop_Review::frontend::layouts::product-reviews::content<else/>
            <p class="product-tab-empty">
                <span class="product-tab-empty__title"><?= __('No reviews yet') ?></span>
