<?php
/**
 * Product detail tabs host for default-theme compatibility.
 *
 * @hook-priority 100
 * @hook-sort-order 1
 * @hook-solo false
 */
$product = (array) ($this->getData('product') ?? []);
$reviews = (array) ($this->getData('reviews') ?? []);
$qa = (array) ($this->getData('qa') ?? []);
$specifications = (array) ($product['specifications'] ?? []);
$productId = (int) ($product['product_id'] ?? 0);

if ($productId <= 0) {
    return;
}

$__welineProductTabsCacheKey = null;
$__welineProductTabsCache = null;
$__welineProductTabsBufferStarted = false;
$__welineProductHookTtl = 120;
$__welineProductHookMemoryOptions = [
    'connect_timeout' => 0.08,
    'timeout' => 0.12,
    'acquire_timeout' => 0.08,
];
try {
    $__welineProductHookPolicy = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\CacheManager\Service\RuntimeCachePolicy::class);
    $__welineProductHookTtl = $__welineProductHookPolicy->ttl('page.product_view_ttl', $__welineProductHookTtl);
    $__welineProductHookMemoryOptions = $__welineProductHookPolicy->memoryOptions($__welineProductHookMemoryOptions);
} catch (\Throwable) {
}
try {
    if (\class_exists(\Weline\Framework\Runtime\Runtime::class, false)
        && \Weline\Framework\Runtime\Runtime::isPersistent()
        && \class_exists(\Weline\Server\Service\MemoryStateFacade::class)) {
        $__welineProductTabsCacheKey = 'product.tabs.' . sha1(json_encode([
            'product_id' => $productId,
            'lang' => \Weline\Framework\App\State::getLang(),
            'lang_local' => \Weline\Framework\App\State::getLangLocal(),
            'currency' => \Weline\Framework\App\State::getCurrency(),
            'product_sig' => [
                $product['updated_at'] ?? null,
                $product['description'] ?? null,
                $product['specifications'] ?? null,
            ],
            'reviews_sig' => md5(json_encode($reviews, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: ''),
            'qa_sig' => md5(json_encode($qa, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: ''),
        ], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: (string)$productId);
        $__welineLocalProductHookCache = $GLOBALS['weline_product_hook_output_cache'][$__welineProductTabsCacheKey] ?? null;
        if (is_array($__welineLocalProductHookCache)
            && (float)($__welineLocalProductHookCache['expires_at'] ?? 0) >= microtime(true)
            && is_string($__welineLocalProductHookCache['html'] ?? null)) {
            echo $__welineLocalProductHookCache['html'];
            return;
        }
        $__welineProductTabsCache = $GLOBALS['weline_product_hook_cache_facade'] ?? null;
        if (!$__welineProductTabsCache instanceof \Weline\Server\Service\MemoryStateFacade) {
            $__welineProductTabsCache = new \Weline\Server\Service\MemoryStateFacade(array_merge([
                'consumer_code' => 'weshop_product_hook',
                'prefer_direct_connect' => true,
            ], $__welineProductHookMemoryOptions, [
                'pool_size' => 1,
                'auto_start' => false,
            ]));
            $GLOBALS['weline_product_hook_cache_facade'] = $__welineProductTabsCache;
        }
        $__welineCachedProductTabs = $__welineProductTabsCache->get('weshop_product_hook', $__welineProductTabsCacheKey);
        if (is_string($__welineCachedProductTabs)) {
            $GLOBALS['weline_product_hook_output_cache'][$__welineProductTabsCacheKey] = [
                'expires_at' => microtime(true) + $__welineProductHookTtl,
                'html' => $__welineCachedProductTabs,
            ];
            echo $__welineCachedProductTabs;
            return;
        }
        ob_start();
        $__welineProductTabsBufferStarted = true;
    }
} catch (\Throwable) {
    $__welineProductTabsCacheKey = null;
    $__welineProductTabsCache = null;
    $__welineProductTabsBufferStarted = false;
}
?>
<div class="border-b border-border-light dark:border-border-dark">
    <nav aria-label="Tabs" class="-mb-px flex space-x-8">
        <a class="product-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-base text-primary border-primary" href="#description" data-tab="description"><?= __('Product Description') ?></a>
        <a class="product-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-base text-text-secondary-light dark:text-text-secondary-dark border-transparent hover:text-primary hover:border-primary/50" href="#specifications" data-tab="specifications"><?= __('Specifications') ?></a>
        <a class="product-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-base text-text-secondary-light dark:text-text-secondary-dark border-transparent hover:text-primary hover:border-primary/50" href="#qa" data-tab="qa"><?= __('Q&A') ?><?= $qa ? ' (' . count($qa) . ')' : '' ?></a>
        <a class="product-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-base text-text-secondary-light dark:text-text-secondary-dark border-transparent hover:text-primary hover:border-primary/50" href="#reviews" data-tab="reviews"><?= __('Reviews') ?><?= $reviews ? ' (' . count($reviews) . ')' : '' ?></a>
    </nav>
</div>

<div class="tab-content py-10" id="description-content">
    <h3 class="text-xl font-bold mb-4"><?= htmlspecialchars((string) ($product['description_title'] ?? __('Product Description')), ENT_QUOTES) ?></h3>
    <div class="text-text-secondary-light dark:text-text-secondary-dark leading-relaxed prose dark:prose-invert max-w-none">
        <?= (string) ($product['description'] ?? '') ?>
    </div>
</div>

<div class="tab-content py-10 hidden" id="specifications-content">
    <table class="w-full text-left">
        <tbody>
        <?php foreach ($specifications as $spec): ?>
            <tr class="border-b border-border-light dark:border-border-dark">
                <th class="py-3 pr-4 font-medium text-text-primary-light dark:text-text-primary-dark w-1/3"><?= htmlspecialchars((string) ($spec['label'] ?? ''), ENT_QUOTES) ?></th>
                <td class="py-3 text-text-secondary-light dark:text-text-secondary-dark"><?= htmlspecialchars((string) ($spec['value'] ?? ''), ENT_QUOTES) ?></td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>
</div>

<div class="tab-content py-10 hidden" id="qa-content">
    <w:hook name="WeShop_QA::frontend::layouts::product-questions::content"/>
</div>

<div class="tab-content py-10 hidden" id="reviews-content">
    <w:hook name="WeShop_Review::frontend::layouts::product-reviews::content"/>
</div>
<?php
if (isset($__welineProductTabsCacheKey, $__welineProductTabsCache)
    && $__welineProductTabsCacheKey
    && $__welineProductTabsCache instanceof \Weline\Server\Service\MemoryStateFacade
    && $__welineProductTabsBufferStarted
    && ob_get_level() > 0) {
    $__welineProductTabsHtml = ob_get_clean();
    echo $__welineProductTabsHtml;
    $GLOBALS['weline_product_hook_output_cache'][$__welineProductTabsCacheKey] = [
        'expires_at' => microtime(true) + $__welineProductHookTtl,
        'html' => $__welineProductTabsHtml,
    ];
    try {
        $__welineProductTabsCache->set('weshop_product_hook', $__welineProductTabsCacheKey, $__welineProductTabsHtml, $__welineProductHookTtl);
    } catch (\Throwable) {
    }
}
?>
