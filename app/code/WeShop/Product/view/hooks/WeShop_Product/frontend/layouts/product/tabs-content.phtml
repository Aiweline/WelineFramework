                            <th><?= htmlspecialchars((string)($spec['label'] ?? ''), ENT_QUOTES) ?></th>
                            <td><?= htmlspecialchars((string)($spec['value'] ?? ''), ENT_QUOTES) ?></td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php else: ?>
                <p class="product-tab-empty"><?= __('No specifications available.') ?></p>
            <?php endif; ?>
        </w:hook>
