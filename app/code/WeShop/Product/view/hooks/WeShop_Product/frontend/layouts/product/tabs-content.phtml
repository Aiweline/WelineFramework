<script>
(function () {
    function getProductSection(sectionName) {
        return document.querySelector('[data-product-section="' + sectionName + '"]')
            || document.getElementById(sectionName + '-content');
    }

    function activateProductSection(sectionName) {
        var targetContent = getProductSection(sectionName);
        if (!targetContent) {
            return false;
        }

        targetContent.scrollIntoView({behavior: 'smooth', block: 'start', inline: 'nearest'});
        return true;
    }

    function getReviewDeepLinkTargetId() {
        var params = new URLSearchParams(window.location.search || '');
        var replyId = Number(params.get('reply_id') || 0);
        if (replyId > 0) {
            return 'review-reply-' + replyId;
        }

        var reviewId = Number(params.get('review_id') || 0);
        if (reviewId > 0) {
            return 'review-' + reviewId;
        }

        var hash = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : '';
        return /^review(?:-reply)?-\d+$/.test(hash) ? hash : '';
    }

    function focusReviewDeepLink() {
        var targetId = getReviewDeepLinkTargetId();
        if (!targetId) {
            return;
        }

        window.setTimeout(function () {
            var node = document.getElementById(targetId);
            if (!node) {
                return;
            }
            document.querySelectorAll('[data-review-deep-link-target="1"]').forEach(function (item) {
                item.removeAttribute('data-review-deep-link-target');
                item.classList.remove('ring-2', 'ring-primary/30', 'border-primary');
            });
            node.classList.add('ring-2', 'ring-primary/30', 'border-primary');
            node.setAttribute('data-review-deep-link-target', '1');
            if (!node.hasAttribute('tabindex')) {
                node.setAttribute('tabindex', '-1');
            }
            node.scrollIntoView({behavior: 'auto', block: 'center', inline: 'nearest'});
            try {
                node.focus({preventScroll: true});
            } catch (error) {
                node.focus();
            }
        }, 160);
    }

    window.WeShopProductTabs = {
        activate: activateProductSection,
        focusReviewDeepLink: focusReviewDeepLink
    };
    focusReviewDeepLink();
    window.addEventListener('load', focusReviewDeepLink);
    window.addEventListener('hashchange', focusReviewDeepLink);
})();
</script>
