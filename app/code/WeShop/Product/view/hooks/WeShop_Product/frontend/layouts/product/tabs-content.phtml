<?php
/**
 * Product detail tabs hook for default-theme product layout variants.
 */

$product = (array) ($this->getData('product') ?? []);
$reviews = (array) ($this->getData('reviews') ?? []);
$qa = (array) ($this->getData('qa') ?? []);
$specifications = (array) ($product['specifications'] ?? []);
$description = (string) ($product['description'] ?? '');
$productId = (int) ($product['product_id'] ?? 0);

if ($productId <= 0) {
    return;
}

$tabs = [
    [
        'id' => 'description',
        'label' => (string) __('Product Details'),
        'active' => true,
    ],
    [
        'id' => 'specifications',
        'label' => (string) __('Specifications'),
        'active' => false,
    ],
    [
        'id' => 'reviews',
        'label' => (string) __('Reviews') . (!empty($reviews) ? ' (' . count($reviews) . ')' : ''),
        'active' => false,
    ],
    [
        'id' => 'qa',
        'label' => (string) __('Q&A') . (!empty($qa) ? ' (' . count($qa) . ')' : ''),
        'active' => false,
    ],
];
?>

<div class="weshop-product-tabs" data-product-id="<?= $productId ?>">
    <div class="weshop-product-tabs-nav" role="tablist" aria-label="<?= htmlspecialchars((string) __('Product sections'), ENT_QUOTES) ?>">
        <?php foreach ($tabs as $tab): ?>
            <button
                type="button"
                class="weshop-product-tab-button<?= !empty($tab['active']) ? ' is-active' : '' ?>"
                data-tab="<?= htmlspecialchars((string) $tab['id'], ENT_QUOTES) ?>"
            >
                <?= htmlspecialchars((string) $tab['label'], ENT_QUOTES) ?>
            </button>
        <?php endforeach; ?>
    </div>

    <div class="weshop-product-tab-panels">
        <section class="weshop-product-tab-panel is-active" id="tab-description">
            <?php if ($description !== ''): ?>
                <div class="weshop-product-description">
                    <?= $description ?>
                </div>
            <?php else: ?>
                <div class="weshop-product-tab-empty"><?= __('No product details are available yet.') ?></div>
            <?php endif; ?>
        </section>

        <section class="weshop-product-tab-panel" id="tab-specifications">
            <?php if ($specifications): ?>
                <table class="weshop-product-specifications">
                    <tbody>
                    <?php foreach ($specifications as $specification): ?>
                        <tr>
                            <th><?= htmlspecialchars((string) ($specification['label'] ?? ''), ENT_QUOTES) ?></th>
                            <td><?= htmlspecialchars((string) ($specification['value'] ?? ''), ENT_QUOTES) ?></td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            <?php else: ?>
                <div class="weshop-product-tab-empty"><?= __('No specifications are available yet.') ?></div>
            <?php endif; ?>
        </section>

        <section class="weshop-product-tab-panel" id="tab-reviews">
            <w:hook name="WeShop_Review::frontend::layouts::product-reviews::content"/>
        </section>

        <section class="weshop-product-tab-panel" id="tab-qa">
            <w:hook name="WeShop_QA::frontend::layouts::product-questions::content"/>
        </section>
    </div>
</div>

<style>
.weshop-product-tabs-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid var(--color-border-light, #e5e7eb);
    padding-bottom: 0.75rem;
}

.weshop-product-tab-button {
    border: none;
    background: transparent;
    color: var(--color-text-secondary, #6b7280);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.5rem 0.25rem;
    position: relative;
}

.weshop-product-tab-button.is-active {
    color: var(--color-accent, #2563eb);
}

.weshop-product-tab-button.is-active::after {
    background: var(--color-accent, #2563eb);
    bottom: -0.8rem;
    content: '';
    height: 2px;
    left: 0;
    position: absolute;
    right: 0;
}

.weshop-product-tab-panels {
    padding-top: 1.5rem;
}

.weshop-product-tab-panel {
    display: none;
}

.weshop-product-tab-panel.is-active {
    display: block;
}

.weshop-product-description {
    color: var(--color-text-primary, #111827);
    line-height: 1.7;
}

.weshop-product-description img {
    height: auto;
    max-width: 100%;
}

.weshop-product-specifications {
    border-collapse: collapse;
    width: 100%;
}

.weshop-product-specifications th,
.weshop-product-specifications td {
    border-bottom: 1px solid var(--color-border-light, #e5e7eb);
    font-size: 0.9rem;
    padding: 0.85rem 1rem;
    text-align: left;
}

.weshop-product-specifications th {
    color: var(--color-text-secondary, #6b7280);
    font-weight: 600;
    width: 30%;
}

.weshop-product-tab-empty {
    color: var(--color-text-secondary, #6b7280);
    font-size: 0.95rem;
    padding: 1rem 0;
}
</style>

<script>
(function () {
    document.querySelectorAll('.weshop-product-tabs').forEach(function (wrapper) {
        var buttons = wrapper.querySelectorAll('.weshop-product-tab-button');
        var panels = wrapper.querySelectorAll('.weshop-product-tab-panel');

        buttons.forEach(function (button) {
            button.addEventListener('click', function () {
                var tab = button.dataset.tab;

                buttons.forEach(function (item) {
                    item.classList.remove('is-active');
                });
                panels.forEach(function (panel) {
                    panel.classList.remove('is-active');
                });

                button.classList.add('is-active');
                var panel = wrapper.querySelector('#tab-' + tab);
                if (panel) {
                    panel.classList.add('is-active');
                }
            });
        });
    });
})();
</script>
