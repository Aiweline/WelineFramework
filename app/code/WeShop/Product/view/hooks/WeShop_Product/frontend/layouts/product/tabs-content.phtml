<?php
/**
 * WeShop Product模块 - 产品详情标签区域Hook
 * 
 * 在产品详情页标签区域渲染产品描述、规格、评价、问答等内容
 * Hook名称：WeShop_Product::frontend::layouts::product::tabs-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品数据（由控制器传递）
$product = $this->getData('product');
$attributes = $this->getData('attributes') ?? [];
$reviews = $this->getData('reviews') ?? [];
$qa = $this->getData('qa') ?? [];

// 如果没有产品数据，不渲染任何内容（让fallback显示）
if (empty($product) || empty($product['product_id'])) {
    return;
}

// 获取产品详情
$description = $product['description'] ?? '';
$productId = $product['product_id'] ?? 0;

// 构建标签页数据
$tabs = [
    [
        'id' => 'description',
        'label' => __('商品详情'),
        'active' => true,
    ],
    [
        'id' => 'specifications',
        'label' => __('规格参数'),
        'active' => false,
    ],
    [
        'id' => 'reviews',
        'label' => __('用户评价') . (!empty($reviews) ? ' (' . count($reviews) . ')' : ''),
        'active' => false,
    ],
    [
        'id' => 'qa',
        'label' => __('问答') . (!empty($qa) ? ' (' . count($qa) . ')' : ''),
        'active' => false,
    ],
];
?>

<div class="product-tabs-wrapper" data-product-id="<?= (int)$productId ?>">
    <!-- 标签导航 -->
    <div class="tabs-nav">
        <?php foreach ($tabs as $index => $tab): ?>
        <button type="button" 
                class="tab-btn <?= $tab['active'] ? 'active' : '' ?>" 
                data-tab="<?= htmlspecialchars($tab['id']) ?>">
            <?= htmlspecialchars($tab['label']) ?>
        </button>
        <?php endforeach; ?>
    </div>
    
    <!-- 标签内容 -->
    <div class="tabs-content">
        <!-- 商品详情 -->
        <div class="tab-pane active" id="tab-description">
            <?php if (!empty($description)): ?>
            <div class="product-description-content">
                <?= $description ?>
            </div>
            <?php else: ?>
            <div class="tab-empty">
                <span class="empty-icon">📝</span>
                <span class="empty-text"><?= __('暂无商品详情') ?></span>
            </div>
            <?php endif; ?>
        </div>
        
        <!-- 规格参数 -->
        <div class="tab-pane" id="tab-specifications">
            <?php if (!empty($attributes)): ?>
            <div class="specifications-content">
                <table class="specs-table">
                    <tbody>
                        <?php foreach ($attributes as $attr): ?>
                        <tr>
                            <th><?= htmlspecialchars($attr['label'] ?? $attr['code'] ?? '') ?></th>
                            <td><?= htmlspecialchars($attr['value'] ?? '') ?></td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
            <?php else: ?>
            <div class="tab-empty">
                <span class="empty-icon">📋</span>
                <span class="empty-text"><?= __('暂无规格参数') ?></span>
            </div>
            <?php endif; ?>
        </div>
        
        <!-- 用户评价 -->
        <div class="tab-pane" id="tab-reviews">
            <?php if (!empty($reviews)): ?>
            <div class="reviews-content">
                <div class="reviews-summary">
                    <div class="rating-average">
                        <span class="rating-score">4.8</span>
                        <span class="rating-stars">★★★★★</span>
                        <span class="rating-count"><?= count($reviews) ?> <?= __('条评价') ?></span>
                    </div>
                </div>
                <div class="reviews-list">
                    <?php foreach ($reviews as $review): ?>
                    <div class="review-item">
                        <div class="review-header">
                            <span class="reviewer-name"><?= htmlspecialchars($review['user_name'] ?? __('匿名用户')) ?></span>
                            <span class="review-date"><?= htmlspecialchars($review['created_at'] ?? '') ?></span>
                        </div>
                        <div class="review-rating">
                            <?php for ($i = 1; $i <= 5; $i++): ?>
                            <span class="star <?= $i <= ($review['rating'] ?? 5) ? 'filled' : '' ?>">★</span>
                            <?php endfor; ?>
                        </div>
                        <div class="review-content"><?= htmlspecialchars($review['content'] ?? '') ?></div>
                    </div>
                    <?php endforeach; ?>
                </div>
            </div>
            <?php else: ?>
            <div class="tab-empty">
                <span class="empty-icon">💬</span>
                <span class="empty-text"><?= __('暂无用户评价') ?></span>
                <button type="button" class="btn-write-review" data-product-id="<?= (int)$productId ?>">
                    <?= __('写评价') ?>
                </button>
            </div>
            <?php endif; ?>
        </div>
        
        <!-- 问答 -->
        <div class="tab-pane" id="tab-qa">
            <?php if (!empty($qa)): ?>
            <div class="qa-content">
                <div class="qa-list">
                    <?php foreach ($qa as $item): ?>
                    <div class="qa-item">
                        <div class="question">
                            <span class="qa-icon">Q</span>
                            <span class="qa-text"><?= htmlspecialchars($item['question'] ?? '') ?></span>
                        </div>
                        <?php if (!empty($item['answer'])): ?>
                        <div class="answer">
                            <span class="qa-icon">A</span>
                            <span class="qa-text"><?= htmlspecialchars($item['answer'] ?? '') ?></span>
                        </div>
                        <?php endif; ?>
                    </div>
                    <?php endforeach; ?>
                </div>
            </div>
            <?php else: ?>
            <div class="tab-empty">
                <span class="empty-icon">❓</span>
                <span class="empty-text"><?= __('暂无问答') ?></span>
                <button type="button" class="btn-ask-question" data-product-id="<?= (int)$productId ?>">
                    <?= __('提问') ?>
                </button>
            </div>
            <?php endif; ?>
        </div>
    </div>
</div>

