<script>
var productDetailCurrencyConfig = {
    baseCurrency: <?= json_encode($baseCurrencyCode, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    currentCurrency: <?= json_encode($currentCurrencyCode, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    currencyDefinition: <?= json_encode($displayCurrencyDefinition, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    factor: <?= json_encode($currencyDisplayFactor, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    locale: <?= json_encode(str_replace('_', '-', \Weline\Framework\App\State::getLangLocal()), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>
};
var productDetailConfigurableVariants = <?= json_encode($configurableVariants, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: '[]' ?>;

(function() {
    var productDetailRoot = document.querySelector('.product-detail-view[data-product-id="<?= (int)$productId ?>"]');

    function formatConvertedCurrency(amount) {
        var definition = productDetailCurrencyConfig.currencyDefinition || {};
        var formatParts = String(definition.format || '2,0').split(',');
        var decimals = parseInt(formatParts[0], 10);
        if (!Number.isFinite(decimals)) {
            decimals = 2;
        }

        var thousandSeparator = typeof definition.thousand_separator === 'string' && definition.thousand_separator !== ''
            ? definition.thousand_separator
            : ',';
        var decimalSeparator = typeof definition.decimal_separator === 'string' && definition.decimal_separator !== ''
            ? definition.decimal_separator
            : '.';
        var icon = definition.icon || definition.symbol || productDetailCurrencyConfig.currentCurrency || '';
        var position = String(definition.position || 'left').toLowerCase();
        var normalizedAmount = Number(amount);

        if (!Number.isFinite(normalizedAmount)) {
            normalizedAmount = 0;
        }

        var parts = normalizedAmount.toFixed(decimals).split('.');
        parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousandSeparator);
        var formatted = parts.length > 1 ? parts[0] + decimalSeparator + parts[1] : parts[0];

        if (!icon) {
            return formatted;
        }

        return position === 'right' ? formatted + icon : icon + formatted;
    }

    // 图片切换

    function normalizeWidgetPrices() {
        if (!productDetailCurrencyConfig.currentCurrency
            || productDetailCurrencyConfig.currentCurrency === productDetailCurrencyConfig.baseCurrency
            || !(Number(productDetailCurrencyConfig.factor) > 0)) {
            return;
        }

        [
            '.widget-products .price-current',
            '.widget-products .price-original',
            '.widget-recently-viewed .price-current'
        ].forEach(function(selector) {
            document.querySelectorAll(selector).forEach(function(node) {
                if (node.dataset.currencyNormalized === '1') {
                    return;
                }

                var raw = String(node.textContent || '').replace(/[^0-9.,-]/g, '').replace(/,/g, '');
                var amount = parseFloat(raw);
                if (!Number.isFinite(amount)) {
                    return;
                }

                node.textContent = formatConvertedCurrency(amount * Number(productDetailCurrencyConfig.factor));
                node.dataset.currencyNormalized = '1';
            });
        });
    }

    document.querySelectorAll('.thumbnail-item').forEach(function(thumb) {
        thumb.addEventListener('click', function() {
            var src = this.dataset.src;
            var mainImg = document.getElementById('main-product-image');
            if (mainImg && src) {
                mainImg.src = src;
                document.querySelectorAll('.thumbnail-item').forEach(function(t) {
                    t.classList.remove('active');
                });
                this.classList.add('active');
            }
        });
    });
    
    // 数量加减
    document.querySelectorAll('.qty-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var input = this.parentElement.querySelector('.qty-input');
            if (!input) return;
            var val = parseInt(input.value) || 1;
            var min = parseInt(input.min) || 1;
            var max = parseInt(input.max) || 99;
            
            if (this.dataset.action === 'minus') {
                val = Math.max(min, val - 1);
            } else if (this.dataset.action === 'plus') {
                val = Math.min(max, val + 1);
            }
            input.value = val;
        });
    });
    
    function getProductOptionState() {
        var selected = [];
        var labels = [];
        var missing = [];
        if (!productDetailRoot) {
            return { selectedOptions: selected, labels: labels, missing: missing };
        }
        productDetailRoot.querySelectorAll('.product-option-group').forEach(function(group) {
            var title = group.querySelector('.product-option-title');
            var selectedButton = group.querySelector('.product-option-choice.is-selected');
            var titleText = title ? String(title.childNodes[0].textContent || '').trim() : group.dataset.attributeId;
            if (!selectedButton) {
                missing.push(titleText);
                return;
            }
            selected.push(Number(selectedButton.dataset.optionId));
            labels.push(titleText + ': ' + selectedButton.dataset.optionLabel);
        });
        return { selectedOptions: selected.filter(Boolean), labels: labels, missing: missing };
    }

    function updateVariantState() {
        if (!productDetailRoot) {
            return;
        }
        var state = getProductOptionState();
        var statusNode = productDetailRoot.querySelector('[data-option-status]');
        var complete = state.missing.length === 0;
        productDetailRoot.querySelectorAll('.product-actions .btn-add-to-cart, .product-actions .btn-buy-now').forEach(function(button) {
            button.dataset.selectedOptions = JSON.stringify(state.selectedOptions);
            button.dataset.selectedOptionLabels = state.labels.join(' / ');
            button.disabled = !complete || button.hasAttribute('data-stock-disabled');
        });
        if (statusNode) {
            statusNode.classList.toggle('is-error', !complete);
            statusNode.textContent = complete ? state.labels.join(' / ') : '请选择：' + state.missing.join('、');
        }
        if (complete) {
            updateSelectedVariantImage(state.selectedOptions);
        }
    }

    function updateSelectedVariantImage(selectedOptions) {
        if (!Array.isArray(productDetailConfigurableVariants) || productDetailConfigurableVariants.length === 0) {
            return;
        }
        var selected = selectedOptions.map(Number).sort(function(a, b) { return a - b; });
        var variant = productDetailConfigurableVariants.find(function(item) {
            var optionIds = Array.isArray(item.option_ids) ? item.option_ids.map(Number).sort(function(a, b) { return a - b; }) : [];
            return optionIds.length === selected.length && optionIds.every(function(optionId, index) {
                return optionId === selected[index];
            });
        });
        if (!variant || !variant.image) {
            return;
        }
        var mainImg = document.getElementById('main-product-image');
        if (mainImg) {
            mainImg.src = variant.image;
        }
        productDetailRoot.querySelectorAll('.thumbnail-item').forEach(function(item) {
            item.classList.toggle('active', item.dataset.src === variant.image);
        });
    }

    var productDetailCartApiPromise = null;

    function normalizeCartPayload(payload) {
        if (!payload || typeof payload !== 'object') {
            return payload || {};
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'code') && payload.data && typeof payload.data === 'object') {
            var code = Number(payload.code || 0);
            return Object.assign({
                code: code,
                message: payload.msg || payload.data.message || '',
                success: code >= 200 && code < 300 && payload.data.success !== false
            }, payload.data);
        }
        return payload;
    }

    function loadProductDetailScript(src) {
        return new Promise(function(resolve, reject) {
            var existing = document.querySelector('script[src^="' + src.split('?')[0] + '"]');
            if (existing) {
                existing.addEventListener('load', resolve, { once: true });
                existing.addEventListener('error', reject, { once: true });
                if (existing.dataset.loaded === '1' || existing.readyState === 'complete') {
                    resolve();
                }
                return;
            }
            var script = document.createElement('script');
            script.src = src;
            script.async = false;
            script.onload = function() {
                script.dataset.loaded = '1';
                resolve();
            };
            script.onerror = reject;
            document.head.appendChild(script);
        });
    }

    function getProductDetailCartApi() {
        if (!productDetailCartApiPromise) {
            productDetailCartApiPromise = Promise.resolve().then(function() {
                if (window.WelineApiModule && typeof window.WelineApiModule.resource === 'function' && window.WelineApiModule.__full === true) {
                    return window.WelineApiModule.resource('cart');
                }
                if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                    return window.Weline.Api.resource('cart');
                }
                return loadProductDetailScript('/Weline/Frontend/view/statics/js/weline-api.js?v=20260517-product-cart-api').then(function() {
                    if (window.WelineApiModule && typeof window.WelineApiModule.resource === 'function') {
                        return window.WelineApiModule.resource('cart');
                    }
                    if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                        return window.Weline.Api.resource('cart');
                    }
                    throw new Error('购物车 API 未初始化');
                });
            });
        }
        return productDetailCartApiPromise;
    }

    function showProductDetailCartMessage(message, type) {
        if (window.Weline && window.Weline.Toast && typeof window.Weline.Toast.show === 'function') {
            window.Weline.Toast.show(message, type || 'info');
            return;
        }
        var toast = document.createElement('div');
        toast.className = 'product-cart-toast product-cart-toast--' + (type || 'info');
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(function() {
            toast.classList.add('is-visible');
        });
        setTimeout(function() {
            toast.classList.remove('is-visible');
            setTimeout(function() {
                toast.remove();
            }, 180);
        }, 2200);
    }

    function updateProductDetailCartCount(count) {
        if (!Number.isFinite(Number(count))) {
            return;
        }
        document.querySelectorAll('.cart-count, [data-cart-count]').forEach(function(node) {
            node.textContent = String(count);
            node.style.display = Number(count) > 0 ? '' : 'none';
            node.classList.toggle('has-items', Number(count) > 0);
        });
    }

    function setProductDetailCartButtonLoading(button, loading) {
        button.disabled = loading;
        button.classList.toggle('is-loading', loading);
    }

    function addProductDetailToCart(button, productId, qty, selectedOptions, selectedOptionLabels) {
        setProductDetailCartButtonLoading(button, true);
        return getProductDetailCartApi()
            .then(function(CartApi) {
                if (!CartApi || typeof CartApi.add !== 'function') {
                    throw new Error('购物车 API 不支持 add 操作');
                }
                return CartApi.add({
                    product_id: Number(productId),
                    qty: qty,
                    selected_options: selectedOptions
                });
            })
            .then(normalizeCartPayload)
            .then(function(result) {
                if (!result || result.success === false) {
                    throw new Error((result && (result.message || result.msg)) || '加入购物车失败');
                }
                updateProductDetailCartCount(result.cart_count);
                document.dispatchEvent(new CustomEvent('weshop:cart:added', {
                    detail: {
                        product_id: Number(productId),
                        productId: Number(productId),
                        qty: qty,
                        quantity: qty,
                        selected_options: selectedOptions,
                        selectedOptions: selectedOptions,
                        selected_option_labels: selectedOptionLabels || [],
                        cart_item_id: result.cart_item_id,
                        cartItemId: result.cart_item_id,
                        cart_count: result.cart_count,
                        cartCount: result.cart_count,
                        cart_total: result.cart_total,
                        cartTotal: result.cart_total,
                        subtotal: result.cart_total,
                        subtotal_formatted: result.cart_total_formatted,
                        product: result.product
                    }
                }));
                document.dispatchEvent(new CustomEvent('weshop:cart:updated', {
                    detail: {
                        count: result.cart_count,
                        cart_count: result.cart_count,
                        subtotal: result.cart_total,
                        subtotal_formatted: result.cart_total_formatted
                    }
                }));
                showProductDetailCartMessage(result.message || '已加入购物车', 'success');
                return result;
            })
            .catch(function(error) {
                console.error('[WeShop Product] Add to cart failed:', error);
                document.dispatchEvent(new CustomEvent('weshop:cart:error', {
                    detail: {
                        product_id: Number(productId),
                        productId: Number(productId),
                        error: error.message || String(error)
                    }
                }));
                showProductDetailCartMessage(error.message || '加入购物车失败', 'error');
                throw error;
            })
            .finally(function() {
                setProductDetailCartButtonLoading(button, false);
            });
    }

    if (productDetailRoot) productDetailRoot.querySelectorAll('.product-option-choice').forEach(function(choice) {
        choice.addEventListener('click', function() {
            var group = this.closest('.product-option-group');
            if (!group) {
                return;
            }
            group.querySelectorAll('.product-option-choice').forEach(function(item) {
                item.classList.remove('is-selected');
                item.setAttribute('aria-pressed', 'false');
            });
            this.classList.add('is-selected');
            this.setAttribute('aria-pressed', 'true');
            var label = productDetailRoot.querySelector('[data-selected-label-for="' + this.dataset.attributeId + '"]');
            if (label) {
                label.textContent = this.dataset.optionLabel ? '已选 ' + this.dataset.optionLabel : '';
            }
            updateVariantState();
        });
    });

    if (productDetailRoot) productDetailRoot.querySelectorAll('.product-option-group').forEach(function(group) {
        var firstAvailable = group.querySelector('.product-option-choice:not(:disabled)');
        if (firstAvailable) {
            firstAvailable.click();
        }
    });
    updateVariantState();

    // 加入购物车
    if (productDetailRoot) productDetailRoot.querySelectorAll('.product-actions .btn-add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var button = this;
            var productId = button.dataset.productId;
            var qtyInput = document.getElementById('product-qty');
            var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
            var optionState = getProductOptionState();
            if (optionState.missing.length > 0) {
                updateVariantState();
                return;
            }

            var textNode = button.querySelector('.btn-text');
            var originalText = textNode ? textNode.textContent : '';
            if (textNode) {
                textNode.textContent = '<?= __('添加中') ?>...';
            }
            addProductDetailToCart(button, productId, qty, optionState.selectedOptions, optionState.labels)
                .then(function() {
                    if (textNode) {
                        textNode.textContent = '<?= __('已添加') ?>';
                        setTimeout(function() {
                            textNode.textContent = originalText || '<?= __('加入购物车') ?>';
                        }, 1500);
                    }
                })
                .catch(function() {
                    if (textNode) {
                        textNode.textContent = originalText || '<?= __('加入购物车') ?>';
                    }
                });
        });
    });
    
    // 立即购买
    if (productDetailRoot) productDetailRoot.querySelectorAll('.product-actions .btn-buy-now').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var qtyInput = document.getElementById('product-qty');
            var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
            var optionState = getProductOptionState();
            if (optionState.missing.length > 0) {
                updateVariantState();
                return;
            }
            
            // 触发自定义事件
            var event = new CustomEvent('weshop:buyNow', {
                detail: {
                    productId: productId,
                    qty: qty,
                    selectedOptions: optionState.selectedOptions,
                    selectedOptionLabels: optionState.labels
                }
            });
            document.dispatchEvent(event);
        });
    });
    
    // 收藏
    document.querySelectorAll('.btn-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var icon = this.querySelector('.btn-icon');
            
            // 触发自定义事件
            var event = new CustomEvent('weshop:addToWishlist', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
            
            // 切换图标
            if (icon.textContent === '❤') {
                icon.textContent = '💖';
            } else {
                icon.textContent = '❤';
            }
        });
    });
    if (document.readyState === 'complete') {
        setTimeout(normalizeWidgetPrices, 0);
    } else {
        window.addEventListener('load', normalizeWidgetPrices, { once: true });
    }
})();
</script>
