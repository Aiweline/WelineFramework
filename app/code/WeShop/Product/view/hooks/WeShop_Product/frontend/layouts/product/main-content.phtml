<?php
/**
 * WeShop Product模块 - 产品详情主内容区域Hook
 * 
 * 在产品详情页主内容区域渲染产品图片、信息、购买选项等
 * Hook名称：WeShop_Product::frontend::layouts::product::main-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品数据（由控制器传递）
$product = $this->getData('product');
$attributes = $this->getData('attributes') ?? [];
$configurableOptions = is_array($product['configurable_options'] ?? null) ? $product['configurable_options'] : [];
$configurableAttributes = is_array($configurableOptions['attributes'] ?? null) ? $configurableOptions['attributes'] : [];
$configurableVariants = is_array($configurableOptions['variants'] ?? null) ? $configurableOptions['variants'] : [];

// 如果没有产品数据，不渲染任何内容（让fallback显示）
if (empty($product) || empty($product['product_id'])) {
    return;
}

// 获取产品基本信息
$productId = $product['product_id'] ?? 0;
$name = $product['name'] ?? '';
$shortDescription = $product['short_description'] ?? '';
$price = (float)($product['price'] ?? 0);
$originalPrice = (float)($product['original_price'] ?? $product['cost'] ?? $price);
$cost = $originalPrice;
$sku = $product['sku'] ?? '';
$stock = (int)($product['stock'] ?? 0);
$inStock = $product['in_stock'] ?? ($stock > 0);
$stockStatus = $product['stock_status'] ?? ($inStock ? 'in_stock' : 'out_of_stock');
$weight = (float)($product['weight'] ?? 0);
$mainImage = $product['image'] ?? '';
$images = $product['images'] ?? [];
$formattedPrice = \Weline\Currency\Helper\CurrencyFormatter::formatConverted($price);
$formattedOriginalPrice = \Weline\Currency\Helper\CurrencyFormatter::formatConverted($originalPrice);
$currencyRateService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Currency\Service\CurrencyRateService::class);
$baseCurrencyCode = $currencyRateService->getBaseCurrency();
$currentCurrencyCode = \Weline\Framework\App\State::getCurrency();
$displayCurrencyDefinition = $currencyRateService->getCurrencyDefinition($currentCurrencyCode);
$currencyDisplayFactor = \Weline\Currency\Helper\CurrencyFormatter::convert(1.0, $baseCurrencyCode, $currentCurrencyCode);

if ($configurableAttributes === [] && $productId > 0) {
    try {
        $pdo = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Model\Product::class)->getConnection()->getConnector()->getLink();
        $childrenStmt = $pdo->prepare('SELECT product_id, sku, name, price, stock, image FROM "m_weshop_product" WHERE parent_id = ? AND status = 1 ORDER BY product_id ASC');
        $childrenStmt->execute([$productId]);
        $children = $childrenStmt->fetchAll(\PDO::FETCH_ASSOC);
        if ($children) {
            $childIds = array_map(static fn(array $row): int => (int)$row['product_id'], $children);
            $childMap = [];
            foreach ($children as $child) {
                $childMap[(int)$child['product_id']] = $child;
            }
            $placeholders = implode(',', array_fill(0, count($childIds), '?'));
            $optionStmt = $pdo->prepare(
                'SELECT po.product_id, po.attribute_id, po.option_id, a.code AS attribute_code, a.name AS attribute_name, '
                . 'o.code AS option_code, o.value AS option_value, o.swatch_color, o.swatch_image, o.swatch_text '
                . 'FROM "m_weshop_product_option_id" po '
                . 'JOIN "m_eav_attribute" a ON a.attribute_id = po.attribute_id '
                . 'JOIN "m_eav_attribute_option" o ON o.option_id = po.option_id '
                . "WHERE po.product_id IN ({$placeholders}) ORDER BY a.attribute_id, o.option_id"
            );
            $optionStmt->execute($childIds);
            $attributeMap = [];
            $variantOptionMap = [];
            foreach ($optionStmt->fetchAll(\PDO::FETCH_ASSOC) as $row) {
                $attributeId = (int)$row['attribute_id'];
                $optionId = (int)$row['option_id'];
                $childId = (int)$row['product_id'];
                $variantOptionMap[$childId][] = $optionId;
                $attributeMap[$attributeId] ??= [
                    'attribute_id' => $attributeId,
                    'code' => (string)$row['attribute_code'],
                    'name' => (string)$row['attribute_name'],
                    'origin_name' => (string)$row['attribute_name'],
                    'options' => [],
                ];
                $attributeMap[$attributeId]['options'][$optionId] ??= [
                    'option_id' => $optionId,
                    'code' => (string)$row['option_code'],
                    'value' => (string)$row['option_value'],
                    'origin_value' => (string)$row['option_value'],
                    'swatch_type' => $row['swatch_image'] !== '' ? 'image' : ($row['swatch_color'] !== '' ? 'color' : ($row['swatch_text'] !== '' ? 'text' : null)),
                    'swatch_value' => (string)($row['swatch_image'] ?: ($row['swatch_color'] ?: $row['swatch_text'])),
                    'option_image' => (string)($childMap[$childId]['image'] ?? ''),
                    'available_product_ids' => [],
                ];
                $attributeMap[$attributeId]['options'][$optionId]['available_product_ids'][] = $childId;
            }
            foreach ($attributeMap as &$attribute) {
                $attribute['options'] = array_values($attribute['options']);
            }
            unset($attribute);
            $configurableAttributes = array_values($attributeMap);
            $configurableVariants = array_map(static function (array $child) use ($variantOptionMap): array {
                $childId = (int)$child['product_id'];
                return [
                    'product_id' => $childId,
                    'sku' => (string)$child['sku'],
                    'name' => (string)$child['name'],
                    'price' => (float)$child['price'],
                    'stock' => (int)$child['stock'],
                    'image' => (string)$child['image'],
                    'option_ids' => $variantOptionMap[$childId] ?? [],
                ];
            }, $children);
        }
    } catch (\Throwable) {
    }
}

$__welineProductMainCacheKey = null;
$__welineProductMainCache = null;
$__welineProductMainBufferStarted = false;
$__welineProductHookTtl = 120;
$__welineProductHookMemoryOptions = [
    'connect_timeout' => 0.08,
    'timeout' => 0.12,
    'acquire_timeout' => 0.08,
];
try {
    $__welineProductHookPolicy = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\CacheManager\Service\RuntimeCachePolicy::class);
    $__welineProductHookTtl = $__welineProductHookPolicy->ttl('page.product_view_ttl', $__welineProductHookTtl);
    $__welineProductHookMemoryOptions = $__welineProductHookPolicy->memoryOptions($__welineProductHookMemoryOptions);
} catch (\Throwable) {
}
try {
    if (\class_exists(\Weline\Framework\Runtime\Runtime::class, false)
        && \Weline\Framework\Runtime\Runtime::isPersistent()
        && \class_exists(\Weline\Server\Service\MemoryStateFacade::class)) {
        $__welineProductMainCacheKey = 'product.main.' . sha1(json_encode([
            'view_version' => 14,
            'product_id' => $productId,
            'lang' => \Weline\Framework\App\State::getLang(),
            'lang_local' => \Weline\Framework\App\State::getLangLocal(),
            'currency' => $currentCurrencyCode,
            'product_sig' => [
                $product['updated_at'] ?? null,
                $product['price'] ?? null,
                $product['stock'] ?? null,
                $product['image'] ?? null,
                $product['images'] ?? null,
            ],
            'attributes_sig' => md5(json_encode($attributes, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: ''),
            'configurable_sig' => md5(json_encode($configurableOptions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: ''),
        ], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: (string)$productId);
        $__welineLocalProductHookCache = $GLOBALS['weline_product_hook_output_cache'][$__welineProductMainCacheKey] ?? null;
        if (is_array($__welineLocalProductHookCache)
            && (float)($__welineLocalProductHookCache['expires_at'] ?? 0) >= microtime(true)
            && is_string($__welineLocalProductHookCache['html'] ?? null)) {
            echo $__welineLocalProductHookCache['html'];
            return;
        }
        $__welineProductMainCache = $GLOBALS['weline_product_hook_cache_facade'] ?? null;
        if (!$__welineProductMainCache instanceof \Weline\Server\Service\MemoryStateFacade) {
            $__welineProductMainCache = new \Weline\Server\Service\MemoryStateFacade(array_merge([
                'consumer_code' => 'weshop_product_hook',
                'prefer_direct_connect' => true,
            ], $__welineProductHookMemoryOptions, [
                'pool_size' => 1,
                'auto_start' => false,
            ]));
            $GLOBALS['weline_product_hook_cache_facade'] = $__welineProductMainCache;
        }
        $__welineCachedProductMain = $__welineProductMainCache->get('weshop_product_hook', $__welineProductMainCacheKey);
        if (is_string($__welineCachedProductMain)) {
            $GLOBALS['weline_product_hook_output_cache'][$__welineProductMainCacheKey] = [
                'expires_at' => microtime(true) + $__welineProductHookTtl,
                'html' => $__welineCachedProductMain,
            ];
            echo $__welineCachedProductMain;
            return;
        }
        ob_start();
        $__welineProductMainBufferStarted = true;
    }
} catch (\Throwable) {
    $__welineProductMainCacheKey = null;
    $__welineProductMainCache = null;
    $__welineProductMainBufferStarted = false;
}

// 确保images是数组
if (is_string($images)) {
    $images = json_decode($images, true) ?: [];
}
if (empty($images) && !empty($mainImage)) {
    $images = [$mainImage];
}
?>

