                swatch_type: selectedButton.dataset.swatchType || '',
                swatch_value: selectedButton.dataset.swatchValue || '',
                option_image: selectedButton.dataset.optionImage || ''
            });
        });
        var codes = getProductOptionCodesFromDetails(details);
        if (codes.color) {
            updateProductStyleImagesForColor(codes.color);
