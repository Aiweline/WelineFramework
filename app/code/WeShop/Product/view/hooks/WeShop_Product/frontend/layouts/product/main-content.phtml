    '添加购物车失败' => (string) __('添加购物车失败'),
], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

(function() {
    var productDetailRoot = document.querySelector('.product-detail-view[data-product-id="<?= (int)$productId ?>"]');

    function productDetailText(key) {
        return productDetailI18n[key] || key;
    }

    function productDetailMessage(message, fallbackKey) {
        var text = String(message || '').trim();
        if (!text) {
            return productDetailText(fallbackKey);
        }
        return productDetailApiMessageI18n[text] || text;
    }

    function normalizeProductDetailUrlKey(value) {
        var normalized = String(value || '').trim().toLowerCase()
            .replace(/[^a-z0-9_]+/g, '_')
            .replace(/^_+|_+$/g, '');
        return normalized;
    }

    function normalizeProductDetailUrlToken(value) {
        return String(value || '').trim().toLowerCase()
            .replace(/\s+/g, '-')
            .replace(/_/g, '-');
    }

    function getProductOptionUrlKey(group) {
        var code = normalizeProductDetailUrlKey(group && group.dataset ? group.dataset.attributeCode : '');
        if (code) {
            return code;
        }
        var attributeId = group && group.dataset ? String(group.dataset.attributeId || '').trim() : '';
        return attributeId ? 'attribute_' + attributeId : '';
    }

    function getProductDetailUrlParam(params, keys) {
        var entries = Array.from(params.entries());
        for (var i = 0; i < keys.length; i++) {
            if (params.has(keys[i])) {
                return params.get(keys[i]);
            }
        }
        var lowerKeys = keys.map(function(key) { return String(key).toLowerCase(); });
        for (var entryIndex = 0; entryIndex < entries.length; entryIndex++) {
            if (lowerKeys.indexOf(String(entries[entryIndex][0]).toLowerCase()) !== -1) {
                return entries[entryIndex][1];
            }
        }
        return null;
    }

    function getProductOptionChoiceUrlValue(choice) {
        return String(choice.dataset.optionCode || choice.dataset.optionId || choice.dataset.optionLabel || '').trim();
    }

    function optionChoiceMatchesUrlValue(choice, value) {
        var wanted = normalizeProductDetailUrlToken(value);
        if (!wanted) {
            return false;
        }
        return [
            choice.dataset.optionId,
            choice.dataset.optionCode,
            choice.dataset.optionLabel
        ].some(function(candidate) {
            return normalizeProductDetailUrlToken(candidate) === wanted;
        });
    }

    function parseProductDetailOptionIds(value) {
        var text = String(value || '').trim();
        if (!text) {
            return [];
        }
        if (text.charAt(0) === '[') {
            try {
                var decoded = JSON.parse(text);
                if (Array.isArray(decoded)) {
                    return decoded.map(Number).filter(Boolean);
                }
            } catch (error) {
                return [];
            }
        }
        return text.split(',').map(function(item) {
            return Number(String(item).trim());
        }).filter(Boolean);
    }

    function findProductDetailVariantByOptions(selectedOptions) {
        var selected = selectedOptions.map(Number).filter(Boolean).sort(function(a, b) { return a - b; });
        if (selected.length === 0) {
            return null;
        }
        if (Array.isArray(productDetailConfigurableVariants) && productDetailConfigurableVariants.length > 0) {
            return productDetailConfigurableVariants.find(function(item) {
                var optionIds = Array.isArray(item.option_ids) ? item.option_ids.map(Number).filter(Boolean).sort(function(a, b) { return a - b; }) : [];
                return optionIds.length === selected.length && optionIds.every(function(optionId, index) {
                    return optionId === selected[index];
                });
            }) || null;
        }

        return null;
    }

    function findProductDetailVariantByUrlValue(value) {
        var wanted = normalizeProductDetailUrlToken(value);
        if (!wanted) {
            return null;
        }
        if (Array.isArray(productDetailConfigurableVariants) && productDetailConfigurableVariants.length > 0) {
            return productDetailConfigurableVariants.find(function(item) {
                return normalizeProductDetailUrlToken(item.product_id) === wanted
                    || normalizeProductDetailUrlToken(item.sku) === wanted;
            }) || null;
        }
        return null;
    }

    function formatConvertedCurrency(amount) {
        var definition = productDetailCurrencyConfig.currencyDefinition || {};
        var formatParts = String(definition.format || '2,0').split(',');
        var decimals = parseInt(formatParts[0], 10);
        if (!Number.isFinite(decimals)) {
            decimals = 2;
        }

        var thousandSeparator = typeof definition.thousand_separator === 'string' && definition.thousand_separator !== ''
            ? definition.thousand_separator
            : ',';
        var decimalSeparator = typeof definition.decimal_separator === 'string' && definition.decimal_separator !== ''
            ? definition.decimal_separator
            : '.';
        var icon = definition.icon || definition.symbol || productDetailCurrencyConfig.currentCurrency || '';
        var position = String(definition.position || 'left').toLowerCase();
        var normalizedAmount = Number(amount);

        if (!Number.isFinite(normalizedAmount)) {
            normalizedAmount = 0;
        }

        var parts = normalizedAmount.toFixed(decimals).split('.');
        parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousandSeparator);
        var formatted = parts.length > 1 ? parts[0] + decimalSeparator + parts[1] : parts[0];

        if (!icon) {
            return formatted;
        }

        return position === 'right' ? formatted + icon : icon + formatted;
    }

    // 图片切换
    var productDetailMainImage = document.getElementById('main-product-image');
    var productDetailMainImageFrame = productDetailMainImage ? productDetailMainImage.closest('.product-main-image') : null;
    var productDetailLens = productDetailMainImageFrame ? productDetailMainImageFrame.querySelector('.product-image-lens') : null;
    var productDetailZoomPreview = productDetailMainImageFrame ? productDetailMainImageFrame.querySelector('.product-image-zoom-preview') : null;

    function syncZoomPreviewImage() {
        if (!productDetailMainImage || !productDetailZoomPreview) {
            return;
        }
        productDetailZoomPreview.style.backgroundImage = 'url("' + productDetailMainImage.currentSrc + '")';
    }

    function disableImageZoom() {
        if (!productDetailMainImageFrame || !productDetailLens || !productDetailZoomPreview) {
            return;
        }
        productDetailMainImageFrame.classList.remove('is-zooming');
        productDetailLens.style.opacity = '0';
        productDetailZoomPreview.style.opacity = '0';
    }

    function updateImageZoom(event) {
        if (!productDetailMainImageFrame || !productDetailMainImage || !productDetailLens || !productDetailZoomPreview) {
            return;
        }
        if (window.matchMedia('(hover: none), (pointer: coarse)').matches || !productDetailMainImage.naturalWidth || !productDetailMainImage.naturalHeight) {
            disableImageZoom();
            return;
        }

        var frameRect = productDetailMainImageFrame.getBoundingClientRect();
        var imageRect = productDetailMainImage.getBoundingClientRect();
        var lensWidth = productDetailLens.offsetWidth || 176;
        var lensHeight = productDetailLens.offsetHeight || 176;
        var pointerX = event.clientX - frameRect.left;
        var pointerY = event.clientY - frameRect.top;

        if (pointerX < 0 || pointerY < 0 || pointerX > frameRect.width || pointerY > frameRect.height) {
            disableImageZoom();
            return;
        }

        var lensX = Math.max(0, Math.min(pointerX - (lensWidth / 2), frameRect.width - lensWidth));
        var lensY = Math.max(0, Math.min(pointerY - (lensHeight / 2), frameRect.height - lensHeight));
        productDetailLens.style.left = lensX + 'px';
        productDetailLens.style.top = lensY + 'px';

        var fitScale = Math.min(imageRect.width / productDetailMainImage.naturalWidth, imageRect.height / productDetailMainImage.naturalHeight);
        var renderedWidth = productDetailMainImage.naturalWidth * fitScale;
        var renderedHeight = productDetailMainImage.naturalHeight * fitScale;
        var imageOffsetX = (imageRect.width - renderedWidth) / 2;
        var imageOffsetY = (imageRect.height - renderedHeight) / 2;
        var relativeX = Math.max(0, Math.min(pointerX - imageOffsetX, renderedWidth));
        var relativeY = Math.max(0, Math.min(pointerY - imageOffsetY, renderedHeight));
        var zoomX = renderedWidth > 0 ? relativeX / renderedWidth : 0.5;
        var zoomY = renderedHeight > 0 ? relativeY / renderedHeight : 0.5;

        productDetailZoomPreview.style.backgroundSize = (renderedWidth * 2.4) + 'px ' + (renderedHeight * 2.4) + 'px';
        productDetailZoomPreview.style.backgroundPosition = (zoomX * 100) + '% ' + (zoomY * 100) + '%';
        productDetailMainImageFrame.classList.add('is-zooming');
        productDetailLens.style.opacity = '1';
        productDetailZoomPreview.style.opacity = '1';
    }

    if (productDetailMainImage) {
        syncZoomPreviewImage();
        if (productDetailMainImage.complete) {
            syncZoomPreviewImage();
        } else {
            productDetailMainImage.addEventListener('load', syncZoomPreviewImage);
        }
    }

    if (productDetailMainImageFrame) {
        productDetailMainImageFrame.addEventListener('mouseenter', updateImageZoom);
        productDetailMainImageFrame.addEventListener('mousemove', updateImageZoom);
        productDetailMainImageFrame.addEventListener('mouseleave', disableImageZoom);
    }

    function normalizeWidgetPrices() {
        if (!productDetailCurrencyConfig.currentCurrency
            || productDetailCurrencyConfig.currentCurrency === productDetailCurrencyConfig.baseCurrency
            || !(Number(productDetailCurrencyConfig.factor) > 0)) {
            return;
        }

        [
            '.widget-products .price-current',
            '.widget-products .price-original',
            '.widget-recently-viewed .price-current'
        ].forEach(function(selector) {
            document.querySelectorAll(selector).forEach(function(node) {
                if (node.dataset.currencyNormalized === '1') {
                    return;
                }

                var raw = String(node.textContent || '').replace(/[^0-9.,-]/g, '').replace(/,/g, '');
                var amount = parseFloat(raw);
                if (!Number.isFinite(amount)) {
                    return;
                }

                node.textContent = formatConvertedCurrency(amount * Number(productDetailCurrencyConfig.factor));
                node.dataset.currencyNormalized = '1';
            });
        });
    }

    function parseProductGalleryOptionSelection(thumb) {
        var raw = thumb && thumb.dataset ? String(thumb.dataset.optionSelection || '').trim() : '';
        if (!raw) {
            return {};
        }

        try {
            var parsed = JSON.parse(raw);
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
        } catch (error) {
            return {};
        }
    }

    function findProductGallerySelectionChoice(attributeCode, optionCode) {
        var normalizedAttributeCode = normalizeProductOptionMatrixCode(attributeCode);
        if (!productDetailRoot || !normalizedAttributeCode || !String(optionCode || '').trim()) {
            return null;
        }

        var groups = productDetailRoot.querySelectorAll('.product-option-group');
        for (var groupIndex = 0; groupIndex < groups.length; groupIndex++) {
            var group = groups[groupIndex];
            var groupCode = normalizeProductOptionMatrixCode(group.dataset.attributeCode || getProductOptionUrlKey(group));
            var groupAttributeKey = normalizeProductOptionMatrixCode('attribute_' + String(group.dataset.attributeId || '').trim());
            if (groupCode !== normalizedAttributeCode && groupAttributeKey !== normalizedAttributeCode) {
                continue;
            }

            var choices = group.querySelectorAll('.product-option-choice:not(:disabled)');
            for (var choiceIndex = 0; choiceIndex < choices.length; choiceIndex++) {
                if (optionChoiceMatchesUrlValue(choices[choiceIndex], optionCode)) {
                    return choices[choiceIndex];
                }
            }
        }

        return null;
    }

    function applyProductGalleryOptionSelection(thumb) {
        var selection = parseProductGalleryOptionSelection(thumb);
        var changed = false;
        Object.keys(selection).forEach(function(attributeCode) {
            var choice = findProductGallerySelectionChoice(attributeCode, selection[attributeCode]);
            if (choice && !choice.classList.contains('is-selected') && selectProductOptionChoice(choice)) {
                changed = true;
            }
        });

        if (changed) {
            updateVariantState();
        }

        return changed;
    }

    document.querySelectorAll('.thumbnail-item').forEach(function(thumb) {
        thumb.addEventListener('click', function() {
            var src = this.dataset.src;
            if (setProductDetailMainImage(src)) {
                applyProductGalleryOptionSelection(this);
            }
        });
    });
    
    // 数量加减
    document.querySelectorAll('.qty-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var input = this.parentElement.querySelector('.qty-input');
            if (!input) return;
            var val = parseInt(input.value) || 1;
            var min = parseInt(input.min) || 1;
            var max = parseInt(input.max) || 99;
            
            if (this.dataset.action === 'minus') {
