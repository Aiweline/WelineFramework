<?php
/**
 * WeShop Product模块 - 产品详情主内容区域Hook
 * 
 * 在产品详情页主内容区域渲染产品图片、信息、购买选项等
 * Hook名称：WeShop_Product::frontend::layouts::product::main-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品数据（由控制器传递）
$product = $this->getData('product');
$attributes = $this->getData('attributes') ?? [];

// 如果没有产品数据，不渲染任何内容（让fallback显示）
if (empty($product) || empty($product['product_id'])) {
    return;
}

// 获取产品基本信息
$productId = $product['product_id'] ?? 0;
$name = $product['name'] ?? '';
$shortDescription = $product['short_description'] ?? '';
$price = (float)($product['price'] ?? 0);
$originalPrice = (float)($product['original_price'] ?? $product['cost'] ?? $price);
$cost = $originalPrice;
$sku = $product['sku'] ?? '';
$stock = (int)($product['stock'] ?? 0);
$inStock = $product['in_stock'] ?? ($stock > 0);
$stockStatus = $product['stock_status'] ?? ($inStock ? 'in_stock' : 'out_of_stock');
$weight = (float)($product['weight'] ?? 0);
$mainImage = $product['image'] ?? '';
$images = $product['images'] ?? [];

// 确保images是数组
if (is_string($images)) {
    $images = json_decode($images, true) ?: [];
}
if (empty($images) && !empty($mainImage)) {
    $images = [$mainImage];
}
?>

<div class="product-detail-view" data-product-id="<?= (int)$productId ?>">
    <div class="product-detail-row">
        <!-- 产品图片区域 -->
        <div class="product-gallery">
            <div class="product-main-image">
                <?php if (!empty($images)): ?>
                <img id="main-product-image" 
                     src="<?= htmlspecialchars($images[0] ?? '') ?>" 
                     alt="<?= htmlspecialchars($name) ?>"
                     class="product-image-main" />
                <?php else: ?>
                <div class="product-image-placeholder">
                    <span class="placeholder-icon">📷</span>
                    <span class="placeholder-text"><?= __('暂无图片') ?></span>
                </div>
                <?php endif; ?>
            </div>
            
            <?php if (count($images) > 1): ?>
            <div class="product-thumbnails">
                <?php foreach ($images as $index => $img): ?>
                <div class="thumbnail-item <?= $index === 0 ? 'active' : '' ?>" 
                     data-index="<?= $index ?>" 
                     data-src="<?= htmlspecialchars($img) ?>">
                    <img src="<?= htmlspecialchars($img) ?>" alt="<?= htmlspecialchars($name) ?> - <?= $index + 1 ?>" />
                </div>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
        </div>
        
        <!-- 产品信息区域 -->
        <div class="product-info-section">
            <h1 class="product-title"><?= htmlspecialchars($name) ?></h1>
            
            <?php if (!empty($shortDescription)): ?>
            <p class="product-short-description"><?= htmlspecialchars($shortDescription) ?></p>
            <?php endif; ?>
            
            <div class="product-meta">
                <?php if (!empty($sku)): ?>
                <div class="product-sku">
                    <span class="meta-label"><?= __('SKU') ?>:</span>
                    <span class="meta-value"><?= htmlspecialchars($sku) ?></span>
                </div>
                <?php endif; ?>
                
                <div class="product-availability <?= $inStock ? 'in-stock' : 'out-of-stock' ?>">
                    <span class="meta-label"><?= __('库存状态') ?>:</span>
                    <span class="meta-value"><?= $inStock ? __('有货') : __('缺货') ?></span>
                    <?php if ($inStock && $stock > 0): ?>
                    <span class="stock-count">(<?= $stock ?> <?= __('件') ?>)</span>
                    <?php endif; ?>
                </div>
            </div>
            
            <div class="product-price-box">
                <span class="product-price-label"><?= __('价格') ?>:</span>
                <span class="product-price-value">
                    <span class="currency-symbol">¥</span>
                    <span class="price-amount"><?= number_format($price, 2) ?></span>
                </span>
                <?php if ($originalPrice > $price): ?>
                <span class="product-original-price">
                    <span class="currency-symbol">¥</span>
                    <span class="price-amount"><?= number_format($originalPrice, 2) ?></span>
                </span>
                <span class="product-discount"><?= round((1 - $price / $cost) * 100) ?>% <?= __('优惠') ?></span>
                <?php endif; ?>
            </div>
            
            <!-- 购买区域 -->
            <div class="product-actions">
                <div class="quantity-selector">
                    <label for="product-qty"><?= __('数量') ?>:</label>
                    <div class="qty-input-group">
                        <button type="button" class="qty-btn qty-minus" data-action="minus">-</button>
                        <input type="number" id="product-qty" name="qty" value="1" min="1" max="<?= $stock > 0 ? $stock : 99 ?>" class="qty-input" />
                        <button type="button" class="qty-btn qty-plus" data-action="plus">+</button>
                    </div>
                </div>
                
                <div class="action-buttons">
                    <button type="button" 
                            class="btn btn-primary btn-add-to-cart" 
                            data-product-id="<?= (int)$productId ?>"
                            <?= !$inStock ? 'disabled' : '' ?>>
                        <span class="btn-icon">🛒</span>
                        <span class="btn-text"><?= $inStock ? __('加入购物车') : __('缺货') ?></span>
                    </button>
                    
                    <button type="button" 
                            class="btn btn-secondary btn-buy-now" 
                            data-product-id="<?= (int)$productId ?>"
                            <?= !$inStock ? 'disabled' : '' ?>>
                        <span class="btn-text"><?= __('立即购买') ?></span>
                    </button>
                    
                    <button type="button" 
                            class="btn btn-outline btn-wishlist" 
                            data-product-id="<?= (int)$productId ?>">
                        <span class="btn-icon">❤</span>
                    </button>
                </div>
            </div>
            
            <!-- 产品属性列表 -->
            <?php if (!empty($attributes)): ?>
            <div class="product-attributes">
                <h3 class="attributes-title"><?= __('产品规格') ?></h3>
                <table class="attributes-table">
                    <tbody>
                        <?php foreach ($attributes as $attr): ?>
                        <tr>
                            <th><?= htmlspecialchars($attr['label'] ?? $attr['code'] ?? '') ?></th>
                            <td><?= htmlspecialchars($attr['value'] ?? '') ?></td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
            <?php endif; ?>
        </div>
    </div>
</div>

