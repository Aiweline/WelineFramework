                    <span class="price-amount weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)$price, ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars($formattedPrice, ENT_QUOTES, 'UTF-8') ?></span>
