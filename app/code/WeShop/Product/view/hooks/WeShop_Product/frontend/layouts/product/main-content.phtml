<?php
/**
 * WeShop Product模块 - 产品详情主内容区域Hook
 * 
 * 在产品详情页主内容区域渲染产品图片、信息、购买选项等
 * Hook名称：WeShop_Product::frontend::layouts::product::main-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品数据（由控制器传递）
$product = $this->getData('product');
$attributes = $this->getData('attributes') ?? [];
$pageConfigurableOptions = $this->getData('configurable_options');
$configurableOptions = is_array($product['configurable_options'] ?? null)
    ? $product['configurable_options']
    : (is_array($pageConfigurableOptions) ? $pageConfigurableOptions : []);
$configurableAttributes = is_array($configurableOptions['attributes'] ?? null) ? $configurableOptions['attributes'] : [];
$configurableVariants = is_array($configurableOptions['variants'] ?? null) ? $configurableOptions['variants'] : [];
$productDetailOptionImageMatrix = is_array($configurableOptions['image_matrix'] ?? null) ? $configurableOptions['image_matrix'] : [];

// 如果没有产品数据，不渲染任何内容（让fallback显示）
if (empty($product) || empty($product['product_id'])) {
    return;
}

// 获取产品基本信息
$productId = $product['product_id'] ?? 0;
$name = $product['name'] ?? '';
$shortDescription = $product['short_description'] ?? '';
$price = (float)($product['price'] ?? 0);
$originalPrice = (float)($product['original_price'] ?? $product['cost'] ?? $price);
$cost = $originalPrice;
$sku = $product['sku'] ?? '';
$stock = (int)($product['stock'] ?? 0);
$inStock = $product['in_stock'] ?? ($stock > 0);
$stockStatus = $product['stock_status'] ?? ($inStock ? 'in_stock' : 'out_of_stock');
$weight = (float)($product['weight'] ?? 0);
$mainImage = $product['image'] ?? '';
$images = $product['images'] ?? [];
$fullDescription = trim((string)($product['description'] ?? ''));
$reviewsPayload = $this->getData('reviews');
$reviewItems = is_array($reviewsPayload['items'] ?? null)
    ? $reviewsPayload['items']
    : (is_array($reviewsPayload) ? $reviewsPayload : []);
$reviewTotal = is_array($reviewsPayload) ? (int)($reviewsPayload['total'] ?? 0) : 0;
$reviewAverage = is_array($reviewsPayload) ? (float)($reviewsPayload['average'] ?? 0) : 0.0;
if (($reviewTotal <= 0 || $reviewAverage <= 0.0) && $productId > 0) {
    try {
        $reviewService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Review\Service\ReviewService::class);
        if ($reviewTotal <= 0) {
            $reviewResult = $reviewService->getProductReviews((int)$productId, 1, 1);
            $reviewTotal = (int)($reviewResult['total'] ?? count($reviewItems));
        }
        if ($reviewAverage <= 0.0 && $reviewTotal > 0) {
            $reviewAverage = (float)$reviewService->getAverageRating((int)$productId);
        }
    } catch (\Throwable) {
        $reviewTotal = $reviewTotal > 0 ? $reviewTotal : count($reviewItems);
    }
}
$qaItems = is_array($this->getData('qa') ?? null) ? $this->getData('qa') : [];
$productRating = (float)($product['rating'] ?? 0);
$rating = $productRating > 0.0 ? $productRating : $reviewAverage;
$productReviewCount = (int)($product['review_count'] ?? 0);
$reviewCount = $productReviewCount > 0 ? $productReviewCount : ($reviewTotal > 0 ? $reviewTotal : count($reviewItems));
$ratingDistribution = is_array($product['rating_distribution'] ?? null) ? $product['rating_distribution'] : [];
if ($ratingDistribution === [] && $reviewItems !== []) {
    $ratingDistribution = array_fill(1, 5, 0);
    foreach ($reviewItems as $reviewItem) {
        $reviewRating = max(1, min(5, (int)round((float)($reviewItem['rating'] ?? 0))));
        ++$ratingDistribution[$reviewRating];
    }
    $distributionBase = count($reviewItems);
    foreach ($ratingDistribution as $star => $ratingCount) {
        $ratingDistribution[$star] = $distributionBase > 0 ? (int)round(($ratingCount / $distributionBase) * 100) : 0;
    }
}
$formattedPrice = \Weline\Currency\Helper\CurrencyFormatter::formatConverted($price);
$formattedOriginalPrice = \Weline\Currency\Helper\CurrencyFormatter::formatConverted($originalPrice);
$currencyRateService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Currency\Service\CurrencyRateService::class);
$baseCurrencyCode = $currencyRateService->getBaseCurrency();
$currentCurrencyCode = \Weline\Framework\App\State::getCurrency();
$displayCurrencyDefinition = $currencyRateService->getCurrencyDefinition($currentCurrencyCode);
$currencyDisplayFactor = \Weline\Currency\Helper\CurrencyFormatter::convert(1.0, $baseCurrencyCode, $currentCurrencyCode);
$renderStars = static function (float $value): string {
    $safeValue = max(0.0, min(5.0, $value));
    $filled = (int)floor($safeValue);
    $half = ($safeValue - $filled) >= 0.5;
    $html = '<span class="product-stars" aria-label="' . htmlspecialchars((string)__('评分'), ENT_QUOTES, 'UTF-8') . ' ' . htmlspecialchars(number_format($safeValue, 1), ENT_QUOTES, 'UTF-8') . '">';
    for ($star = 1; $star <= 5; $star++) {
        $class = $star <= $filled ? 'is-filled' : ($star === ($filled + 1) && $half ? 'is-half' : '');
        $html .= '<span class="' . $class . '">★</span>';
    }
    return $html . '</span>';
};

$descriptionText = trim(strip_tags(str_replace(['<br>', '<br/>', '<br />', '</p>'], "\n", $fullDescription)));

if ($configurableAttributes === [] && $productId > 0) {
    try {
        $pdo = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Model\Product::class)->getConnection()->getConnector()->getLink();
        $childrenStmt = $pdo->prepare('SELECT product_id, sku, name, price, stock, image FROM "m_weshop_product" WHERE parent_id = ? AND status = 1 ORDER BY product_id ASC');
        $childrenStmt->execute([$productId]);
        $children = $childrenStmt->fetchAll(\PDO::FETCH_ASSOC);
        if ($children) {
            $childIds = array_map(static fn(array $row): int => (int)$row['product_id'], $children);
            $childMap = [];
            foreach ($children as $child) {
                $childMap[(int)$child['product_id']] = $child;
            }
            $placeholders = implode(',', array_fill(0, count($childIds), '?'));
            $optionStmt = $pdo->prepare(
                'SELECT po.product_id, po.attribute_id, po.option_id, a.code AS attribute_code, a.name AS attribute_name, '
                . 'o.code AS option_code, o.value AS option_value, o.swatch_color, o.swatch_image, o.swatch_text '
                . 'FROM "m_weshop_product_option_id" po '
                . 'JOIN "m_eav_attribute" a ON a.attribute_id = po.attribute_id '
                . 'JOIN "m_eav_attribute_option" o ON o.option_id = po.option_id '
                . "WHERE po.product_id IN ({$placeholders}) ORDER BY a.attribute_id, o.option_id"
            );
            $optionStmt->execute($childIds);
            $attributeMap = [];
            $variantOptionMap = [];
            foreach ($optionStmt->fetchAll(\PDO::FETCH_ASSOC) as $row) {
                $attributeId = (int)$row['attribute_id'];
                $optionId = (int)$row['option_id'];
                $childId = (int)$row['product_id'];
                $variantOptionMap[$childId][] = $optionId;
                $attributeMap[$attributeId] ??= [
                    'attribute_id' => $attributeId,
                    'code' => (string)$row['attribute_code'],
                    'name' => (string)$row['attribute_name'],
                    'origin_name' => (string)$row['attribute_name'],
                    'options' => [],
                ];
                $attributeMap[$attributeId]['options'][$optionId] ??= [
                    'option_id' => $optionId,
                    'code' => (string)$row['option_code'],
                    'value' => (string)$row['option_value'],
                    'origin_value' => (string)$row['option_value'],
                    'swatch_type' => $row['swatch_image'] !== '' ? 'image' : ($row['swatch_color'] !== '' ? 'color' : ($row['swatch_text'] !== '' ? 'text' : null)),
                    'swatch_value' => (string)($row['swatch_image'] ?: ($row['swatch_color'] ?: $row['swatch_text'])),
                    'option_image' => (string)($childMap[$childId]['image'] ?? ''),
                    'available_product_ids' => [],
                ];
                $attributeMap[$attributeId]['options'][$optionId]['available_product_ids'][] = $childId;
            }
            foreach ($attributeMap as &$attribute) {
                $attribute['options'] = array_values($attribute['options']);
            }
            unset($attribute);
            $configurableAttributes = array_values($attributeMap);
            $configurableVariants = array_map(static function (array $child) use ($variantOptionMap): array {
                $childId = (int)$child['product_id'];
                return [
                    'product_id' => $childId,
                    'sku' => (string)$child['sku'],
                    'name' => (string)$child['name'],
                    'price' => (float)$child['price'],
                    'stock' => (int)$child['stock'],
                    'image' => (string)$child['image'],
                    'option_ids' => $variantOptionMap[$childId] ?? [],
                ];
            }, $children);
        }
    } catch (\Throwable) {
    }
}

// 确保images是数组
if (is_string($images)) {
    $images = json_decode($images, true) ?: [];
}
if (empty($images) && !empty($mainImage)) {
    $images = [$mainImage];
}

$optionMetaByOptionId = [];
foreach ($configurableAttributes as $attribute) {
    if (!is_array($attribute)) {
        continue;
    }
    $attributeId = (int)($attribute['attribute_id'] ?? 0);
    $attributeCode = (string)($attribute['code'] ?? ($attributeId > 0 ? 'attribute_' . $attributeId : ''));
    $options = is_array($attribute['options'] ?? null) ? $attribute['options'] : [];
    foreach ($options as $option) {
        if (!is_array($option)) {
            continue;
        }
        $optionId = (int)($option['option_id'] ?? 0);
        if ($optionId <= 0 || $attributeCode === '') {
            continue;
        }
        $optionMetaByOptionId[$optionId] = [
            'attribute_code' => $attributeCode,
            'option_code' => (string)($option['code'] ?? $option['value'] ?? $optionId),
        ];
    }
}

$optionVariantByOptionId = [];
$galleryVariantImages = [];
$gallerySelectionCandidates = [];
$galleryImageSelections = [];
$addGallerySelectionCandidate = static function (string $image, string $attributeCode, string $optionCode) use (&$gallerySelectionCandidates): void {
    $image = trim($image);
    $attributeCode = trim($attributeCode);
    $optionCode = trim($optionCode);
    if ($image === '' || $attributeCode === '' || $optionCode === '') {
        return;
    }
    $gallerySelectionCandidates[$image][$attributeCode][$optionCode] = true;
};

foreach ($configurableVariants as $variant) {
    if (!is_array($variant)) {
        continue;
    }
    $variantImage = trim((string)($variant['image'] ?? ''));
    if ($variantImage !== '') {
        $galleryVariantImages[] = $variantImage;
    }
    $variantOptionIds = is_array($variant['option_ids'] ?? null) ? $variant['option_ids'] : [];
    foreach ($variantOptionIds as $variantOptionId) {
        $variantOptionId = (int)$variantOptionId;
        if ($variantOptionId > 0 && !isset($optionVariantByOptionId[$variantOptionId])) {
            $optionVariantByOptionId[$variantOptionId] = $variant;
        }
        if ($variantImage === '' || empty($optionMetaByOptionId[$variantOptionId])) {
            continue;
        }
        $optionMeta = $optionMetaByOptionId[$variantOptionId];
        $addGallerySelectionCandidate(
            $variantImage,
            (string)$optionMeta['attribute_code'],
            (string)$optionMeta['option_code']
        );
    }
}

foreach ($productDetailOptionImageMatrix as $colorCode => $styleImages) {
    if (!is_array($styleImages)) {
        continue;
    }
    foreach ($styleImages as $styleCode => $styleImage) {
        $styleImage = (string)$styleImage;
        $addGallerySelectionCandidate($styleImage, 'color', (string)$colorCode);
        $addGallerySelectionCandidate($styleImage, 'style', (string)$styleCode);
    }
}

foreach ($gallerySelectionCandidates as $image => $attributeSelections) {
    $selection = $galleryImageSelections[$image] ?? [];
    foreach ($attributeSelections as $attributeCode => $optionCodes) {
        $optionCodes = array_keys($optionCodes);
        if (count($optionCodes) === 1 && !isset($selection[$attributeCode])) {
            $selection[$attributeCode] = (string)$optionCodes[0];
        }
    }
    if ($selection !== []) {
        $galleryImageSelections[$image] = $selection;
    }
}

$images = array_values(array_unique(array_filter(array_merge(
    array_map(static fn($image): string => is_scalar($image) ? trim((string)$image) : '', $images),
    $galleryVariantImages,
    array_keys($galleryImageSelections)
), static fn(string $image): bool => $image !== '')));

$productImageVariant = static function (string $url, int $width): string {
    $url = trim($url);
    if ($url === '' || $width <= 0) {
        return $url;
    }

    $parts = parse_url($url);
    if (!is_array($parts) || empty($parts['scheme']) || empty($parts['host'])) {
        return $url;
    }

    $host = strtolower((string)$parts['host']);
    if (!str_contains($host, 'pexels.com') && !str_contains($host, 'unsplash.com')) {
        return $url;
    }

    $query = [];
    if (!empty($parts['query'])) {
        parse_str((string)$parts['query'], $query);
    }
    $query['w'] = (string)$width;

    if (str_contains($host, 'unsplash.com')) {
        $query['q'] = (string)min(80, (int)($query['q'] ?? 70));
    }

    $rebuilt = (string)$parts['scheme'] . '://';
    if (isset($parts['user'])) {
        $rebuilt .= (string)$parts['user'];
        if (isset($parts['pass'])) {
            $rebuilt .= ':' . (string)$parts['pass'];
        }
        $rebuilt .= '@';
    }
    $rebuilt .= (string)$parts['host'];
    if (isset($parts['port'])) {
        $rebuilt .= ':' . (string)$parts['port'];
    }
    $rebuilt .= (string)($parts['path'] ?? '');
    $rebuilt .= '?' . http_build_query($query, '', '&', PHP_QUERY_RFC3986);

    return $rebuilt;
};
?>

<script src="/WeShop/Cart/view/statics/js/cart.js?v=20260517-product-cart-1"></script>

<div class="product-detail-view" data-product-id="<?= (int)$productId ?>">
    <div class="product-detail-row">
        <!-- 产品图片区域 -->
        <div class="product-gallery <?= count($images) > 1 ? 'has-thumbnails' : '' ?>">
            <?php if (count($images) > 1): ?>
            <div class="product-thumbnails">
                <?php foreach ($images as $index => $img): ?>
                <?php
                $img = (string)$img;
                $thumbnailImage = $productImageVariant($img, 180);
                $thumbnailSelection = $galleryImageSelections[trim($img)] ?? [];
                $thumbnailSelectionJson = $thumbnailSelection !== []
                    ? (json_encode($thumbnailSelection, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: '{}')
                    : '{}';
                ?>
                <button type="button"
                        class="thumbnail-item <?= $index === 0 ? 'active' : '' ?>"
                        data-index="<?= $index ?>"
                        data-src="<?= htmlspecialchars($img, ENT_QUOTES, 'UTF-8') ?>"
                        data-option-selection="<?= htmlspecialchars($thumbnailSelectionJson, ENT_QUOTES, 'UTF-8') ?>">
                    <img src="<?= htmlspecialchars($thumbnailImage, ENT_QUOTES, 'UTF-8') ?>"
                         alt="<?= htmlspecialchars($name, ENT_QUOTES, 'UTF-8') ?> - <?= $index + 1 ?>"
                         loading="lazy"
                         decoding="async"
                         fetchpriority="low" />
                </button>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>

            <div class="product-main-image">
                <?php if (!empty($images)): ?>
                <button type="button" class="product-zoom-indicator" aria-label="<?= htmlspecialchars((string) __('放大查看'), ENT_QUOTES, 'UTF-8') ?>">
                    <span aria-hidden="true">⌕</span>
                </button>
                <div class="product-image-lens" aria-hidden="true"></div>
                <div class="product-image-zoom-preview" aria-hidden="true"></div>
                <img id="main-product-image"
                     src="<?= htmlspecialchars($images[0] ?? '', ENT_QUOTES, 'UTF-8') ?>"
                     alt="<?= htmlspecialchars($name, ENT_QUOTES, 'UTF-8') ?>"
                     class="product-image-main"
                     loading="eager"
                     decoding="async"
                     fetchpriority="high" />
                <?php else: ?>
                <div class="product-image-placeholder">
                    <span class="placeholder-icon">📷</span>
                    <span class="placeholder-text"><?= __('暂无图片') ?></span>
                </div>
                <?php endif; ?>
            </div>
        </div>

        <!-- 产品信息区域 -->
        <div class="product-info-section">
            <div class="product-title-block">
                <h1 class="product-title"><?= htmlspecialchars($name, ENT_QUOTES, 'UTF-8') ?></h1>

                <?php if ($rating > 0 || $reviewCount > 0): ?>
                <div class="product-rating-summary">
                    <?= $renderStars($rating) ?>
                    <span class="product-rating-score"><?= htmlspecialchars(number_format($rating, 1), ENT_QUOTES, 'UTF-8') ?></span>
                    <?php if ($reviewCount > 0): ?>
                    <span class="product-rating-count"><?= htmlspecialchars((string)__('基于 %{1} 条评价', [$reviewCount]), ENT_QUOTES, 'UTF-8') ?></span>
                    <?php endif; ?>
                </div>
                <?php endif; ?>

                <?php if (!empty($shortDescription)): ?>
                <p class="product-short-description"><?= htmlspecialchars($shortDescription, ENT_QUOTES, 'UTF-8') ?></p>
                <?php endif; ?>
            </div>

            <div class="product-meta">
                <?php if (!empty($sku)): ?>
                <div class="product-sku">
                    <span class="meta-label"><?= __('SKU') ?>:</span>
                    <span class="meta-value"><?= htmlspecialchars($sku, ENT_QUOTES, 'UTF-8') ?></span>
                </div>
                <?php endif; ?>

                <div class="product-availability <?= $inStock ? 'in-stock' : 'out-of-stock' ?>">
                    <span class="meta-label"><?= __('库存状态') ?>:</span>
                    <span class="meta-value"><?= $inStock ? __('有货') : __('缺货') ?></span>
                    <?php if ($inStock && $stock > 0): ?>
                    <span class="stock-count">(<?= $stock ?> <?= __('件') ?>)</span>
                    <?php endif; ?>
                </div>
            </div>

            <?php if ($configurableAttributes !== []): ?>
            <div class="product-configurable-options">
                <?php foreach ($configurableAttributes as $attribute): ?>
                    <?php
                    $attributeId = (int)($attribute['attribute_id'] ?? 0);
                    $attributeCode = (string)($attribute['code'] ?? ('attribute_' . $attributeId));
                    $attributeName = (string)($attribute['name'] ?? $attributeCode);
                    $options = is_array($attribute['options'] ?? null) ? $attribute['options'] : [];
                    $isColorAttribute = stripos($attributeCode, 'color') !== false || str_contains($attributeName, '色');
                    $hasImageOptions = false;
                    foreach ($options as $optionCandidate) {
                        if ((string)($optionCandidate['option_image'] ?? '') !== ''
                            || ((string)($optionCandidate['swatch_type'] ?? '') === 'image' && (string)($optionCandidate['swatch_value'] ?? '') !== '')
                        ) {
                            $hasImageOptions = true;
                            break;
                        }
                    }
                    $optionCount = count($options);
                    $optionPageSize = $hasImageOptions ? 12 : 16;
                    $isPagedOptionList = $optionCount > $optionPageSize;
                    $usesOptionCardGrid = $isPagedOptionList || ($hasImageOptions && $optionCount > 6);
                    $optionListClass = ($isColorAttribute && !$usesOptionCardGrid)
                        ? 'product-option-swatches'
                        : ($hasImageOptions ? 'product-option-image-swatches' : 'product-option-pills');
                    $optionListClass .= $usesOptionCardGrid ? ' product-option-card-grid' : '';
                    $optionChoiceClass = ($isColorAttribute && !$usesOptionCardGrid)
                        ? 'product-option-choice--swatch'
                        : ($hasImageOptions ? 'product-option-choice--image' : 'product-option-choice--pill');
                    $optionChoiceClass .= $usesOptionCardGrid ? ' product-option-choice--card' : '';
                    ?>
                    <?php if ($attributeId > 0 && $options !== []): ?>
                    <fieldset class="product-option-group"
                              data-attribute-id="<?= $attributeId ?>"
                              data-attribute-code="<?= htmlspecialchars($attributeCode, ENT_QUOTES, 'UTF-8') ?>"
                              data-option-paged="<?= $isPagedOptionList ? '1' : '0' ?>"
                              data-option-page-size="<?= $isPagedOptionList ? $optionPageSize : 0 ?>">
                        <legend class="product-option-title">
                            <?= htmlspecialchars($attributeName, ENT_QUOTES, 'UTF-8') ?>
                            <span class="product-option-selected" data-selected-label-for="<?= $attributeId ?>"></span>
                        </legend>
                        <div class="<?= $optionListClass ?>"<?= $isPagedOptionList ? ' data-option-page-list' : '' ?>>
                            <?php foreach ($options as $option): ?>
                                <?php
                                $optionId = (int)($option['option_id'] ?? 0);
                                $optionCode = (string)($option['code'] ?? '');
                                $optionLabel = (string)($option['value'] ?? $option['code'] ?? $optionId);
                                $swatchType = (string)($option['swatch_type'] ?? '');
                                $swatchValue = (string)($option['swatch_value'] ?? '');
                                $optionImage = (string)($option['option_image'] ?? '');
                                $choiceImage = $optionImage !== '' ? $optionImage : ($swatchType === 'image' ? $swatchValue : '');
                                $optionVariant = $optionVariantByOptionId[$optionId] ?? null;
                                $optionPrice = is_array($optionVariant) ? (float)($optionVariant['price'] ?? 0) : $price;
                                $optionOriginalPrice = is_array($optionVariant)
                                    ? (float)($optionVariant['original_price'] ?? 0)
                                    : $originalPrice;
                                $optionFormattedPrice = $usesOptionCardGrid && $optionPrice > 0
                                    ? \Weline\Currency\Helper\CurrencyFormatter::formatConverted($optionPrice)
                                    : '';
                                $optionFormattedOriginalPrice = $usesOptionCardGrid
                                    && $optionOriginalPrice > $optionPrice
                                    && $optionFormattedPrice !== ''
                                    ? \Weline\Currency\Helper\CurrencyFormatter::formatConverted($optionOriginalPrice)
                                    : '';
                                ?>
                                <?php if ($optionId > 0): ?>
                                <button type="button"
                                        class="product-option-choice <?= $optionChoiceClass ?>"
                                        data-option-id="<?= $optionId ?>"
                                        data-option-code="<?= htmlspecialchars($optionCode, ENT_QUOTES, 'UTF-8') ?>"
                                        data-option-label="<?= htmlspecialchars($optionLabel, ENT_QUOTES, 'UTF-8') ?>"
                                        data-option-image="<?= htmlspecialchars($optionImage, ENT_QUOTES, 'UTF-8') ?>"
                                        data-swatch-type="<?= htmlspecialchars($swatchType, ENT_QUOTES, 'UTF-8') ?>"
                                        data-swatch-value="<?= htmlspecialchars($swatchValue, ENT_QUOTES, 'UTF-8') ?>"
                                        data-attribute-id="<?= $attributeId ?>"
                                        data-attribute-code="<?= htmlspecialchars($attributeCode, ENT_QUOTES, 'UTF-8') ?>"
                                        aria-pressed="false">
                                    <?php if ($isColorAttribute && $swatchType === 'color'): ?>
                                        <span class="product-option-color" style="background: <?= htmlspecialchars($swatchValue !== '' ? $swatchValue : '#d1d5db', ENT_QUOTES, 'UTF-8') ?>"></span>
                                    <?php elseif ($isColorAttribute): ?>
                                        <?php if ($optionImage !== ''): ?>
                                            <span class="product-option-image" style="background-image: url('<?= htmlspecialchars($optionImage, ENT_QUOTES, 'UTF-8') ?>')"></span>
                                        <?php elseif ($swatchType === 'image' && $swatchValue !== ''): ?>
                                            <span class="product-option-image" style="background-image: url('<?= htmlspecialchars($swatchValue, ENT_QUOTES, 'UTF-8') ?>')"></span>
                                        <?php else: ?>
                                            <span class="product-option-color" style="background: <?= htmlspecialchars($swatchValue !== '' ? $swatchValue : '#d1d5db', ENT_QUOTES, 'UTF-8') ?>"></span>
                                        <?php endif; ?>
                                    <?php elseif ($choiceImage !== ''): ?>
                                        <span class="product-option-image" style="background-image: url('<?= htmlspecialchars($choiceImage, ENT_QUOTES, 'UTF-8') ?>')"></span>
                                    <?php endif; ?>
                                    <span class="product-option-text"><?= htmlspecialchars($optionLabel, ENT_QUOTES, 'UTF-8') ?></span>
                                    <?php if ($usesOptionCardGrid && ($optionFormattedPrice !== '' || $optionFormattedOriginalPrice !== '')): ?>
                                    <span class="product-option-card-meta">
                                        <?php if ($optionFormattedPrice !== ''): ?>
                                        <span class="product-option-card-price"><?= htmlspecialchars($optionFormattedPrice, ENT_QUOTES, 'UTF-8') ?></span>
                                        <?php endif; ?>
                                        <?php if ($optionFormattedOriginalPrice !== ''): ?>
                                        <span class="product-option-card-original"><?= htmlspecialchars($optionFormattedOriginalPrice, ENT_QUOTES, 'UTF-8') ?></span>
                                        <?php endif; ?>
                                    </span>
