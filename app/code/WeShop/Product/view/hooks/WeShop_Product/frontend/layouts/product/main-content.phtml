                updateVariantState();
                return;
            }

            var textNode = button.querySelector('.btn-text');
            var originalText = textNode ? textNode.textContent : '';
            if (textNode) {
                textNode.textContent = '<?= __('跳转结算中') ?>...';
            }

            addProductDetailToCart(button, productId, qty, optionState.selectedOptions, optionState.labels, optionState.details)
                .then(function() {
                    document.dispatchEvent(new CustomEvent('weshop:buyNow', {
                        detail: {
                            productId: Number(productId),
                            qty: qty,
                            selectedOptions: optionState.selectedOptions,
                            selectedOptionLabels: optionState.labels,
                            selectedOptionDetails: optionState.details,
                            checkoutUrl: productDetailCheckoutUrl
                        }
                    }));
                    redirectToProductDetailCheckout();
                })
                .catch(function() {
                    if (textNode) {
                        textNode.textContent = originalText || '<?= __('立即购买') ?>';
                    }
                });
        });
    });
    
    // 收藏
    document.querySelectorAll('.btn-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var icon = this.querySelector('.btn-icon');
            
            // 触发自定义事件
            var event = new CustomEvent('weshop:addToWishlist', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
            
            // 切换图标
            if (icon.textContent === '❤') {
                icon.textContent = '💖';
            } else {
                icon.textContent = '❤';
            }
        });
    });
    if (document.readyState === 'complete') {
        setTimeout(normalizeWidgetPrices, 0);
    } else {
        window.addEventListener('load', normalizeWidgetPrices, { once: true });
    }
})();
</script>
