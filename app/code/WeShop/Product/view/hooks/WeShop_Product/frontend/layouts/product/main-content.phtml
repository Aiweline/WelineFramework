    function renderProductOptionPagination(group, currentPage, pageCount) {
        var pager = group ? group.querySelector('[data-option-pagination]') : null;
        if (!pager) {
            return;
        }

        var prev = pager.querySelector('[data-option-page-prev]');
        var next = pager.querySelector('[data-option-page-next]');
        var numbers = pager.querySelector('[data-option-page-numbers]');
        if (prev) {
            prev.disabled = currentPage <= 1;
        }
        if (next) {
            next.disabled = currentPage >= pageCount;
        }
        if (!numbers) {
            return;
        }

        numbers.textContent = '';
        var lastRenderedPage = 0;
        for (var page = 1; page <= pageCount; page++) {
            var shouldRender = page === 1
                || page === pageCount
                || Math.abs(page - currentPage) <= 1
                || (currentPage <= 3 && page <= 4)
                || (currentPage >= pageCount - 2 && page >= pageCount - 3);
            if (!shouldRender) {
                if (lastRenderedPage !== -1) {
                    appendProductOptionPageEllipsis(numbers);
                    lastRenderedPage = -1;
                }
                continue;
            }

            appendProductOptionPageNumber(group, numbers, page, currentPage);
            lastRenderedPage = page;
        }
    }

    function setProductOptionGroupPage(group, page) {
        if (!group || group.dataset.optionPaged !== '1') {
            return;
        }

        var choices = getProductOptionPagedChoices(group);
        var pageSize = getProductOptionPageSize(group);
        var pageCount = Math.max(1, Math.ceil(choices.length / pageSize));
        var currentPage = Math.max(1, Math.min(pageCount, parseInt(page, 10) || 1));
        var start = (currentPage - 1) * pageSize;
        var end = start + pageSize;
        group.dataset.optionPage = String(currentPage);

        choices.forEach(function(choice, index) {
            var isVisible = index >= start && index < end;
            choice.classList.toggle('is-option-page-hidden', !isVisible);
            if (isVisible) {
                choice.removeAttribute('aria-hidden');
            } else {
                choice.setAttribute('aria-hidden', 'true');
            }
        });

        renderProductOptionPagination(group, currentPage, pageCount);
