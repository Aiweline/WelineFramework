                <div class="product-configurable-options">
                    <?php foreach ($configurableAttributes as $attribute): ?>
                        <?php
                        $attributeId = (int)($attribute['attribute_id'] ?? 0);
                        $attributeCode = (string)($attribute['code'] ?? ('attribute_' . $attributeId));
                        $attributeName = (string)($attribute['name'] ?? $attributeCode);
