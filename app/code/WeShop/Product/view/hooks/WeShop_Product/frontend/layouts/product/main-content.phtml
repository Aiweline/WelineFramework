<script>
var productDetailCurrencyConfig = {
    baseCurrency: <?= json_encode($baseCurrencyCode, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    currentCurrency: <?= json_encode($currentCurrencyCode, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    currencyDefinition: <?= json_encode($displayCurrencyDefinition, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    factor: <?= json_encode($currencyDisplayFactor, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>,
    locale: <?= json_encode(str_replace('_', '-', \Weline\Framework\App\State::getLangLocal()), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>
};

(function() {
    // 图片切换
    function formatConvertedCurrency(amount) {
        var definition = productDetailCurrencyConfig.currencyDefinition || {};
        var formatParts = String(definition.format || '2,0').split(',');
        var decimals = parseInt(formatParts[0], 10);
        if (!Number.isFinite(decimals)) {
            decimals = 2;
        }

        var thousandSeparator = typeof definition.thousand_separator === 'string' && definition.thousand_separator !== ''
            ? definition.thousand_separator
            : ',';
        var decimalSeparator = typeof definition.decimal_separator === 'string' && definition.decimal_separator !== ''
            ? definition.decimal_separator
            : '.';
        var icon = definition.icon || definition.symbol || productDetailCurrencyConfig.currentCurrency || '';
        var position = String(definition.position || 'left').toLowerCase();
        var normalizedAmount = Number(amount);

        if (!Number.isFinite(normalizedAmount)) {
            normalizedAmount = 0;
        }

        var parts = normalizedAmount.toFixed(decimals).split('.');
        parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousandSeparator);
        var formatted = parts.length > 1 ? parts[0] + decimalSeparator + parts[1] : parts[0];

        if (!icon) {
            return formatted;
        }

        return position === 'right' ? formatted + icon : icon + formatted;
    }

    function normalizeWidgetPrices() {
        if (!productDetailCurrencyConfig.currentCurrency
            || productDetailCurrencyConfig.currentCurrency === productDetailCurrencyConfig.baseCurrency
            || !(Number(productDetailCurrencyConfig.factor) > 0)) {
            return;
        }

        [
            '.widget-products .price-current',
            '.widget-products .price-original',
            '.widget-recently-viewed .price-current'
        ].forEach(function(selector) {
            document.querySelectorAll(selector).forEach(function(node) {
                if (node.dataset.currencyNormalized === '1') {
                    return;
                }

                var raw = String(node.textContent || '').replace(/[^0-9.,-]/g, '').replace(/,/g, '');
                var amount = parseFloat(raw);
                if (!Number.isFinite(amount)) {
                    return;
                }

                node.textContent = formatConvertedCurrency(amount * Number(productDetailCurrencyConfig.factor));
                node.dataset.currencyNormalized = '1';
            });
        });
    }

    document.querySelectorAll('.thumbnail-item').forEach(function(thumb) {
        thumb.addEventListener('click', function() {
            var src = this.dataset.src;
            var mainImg = document.getElementById('main-product-image');
            if (mainImg && src) {
                mainImg.src = src;
                document.querySelectorAll('.thumbnail-item').forEach(function(t) {
                    t.classList.remove('active');
                });
                this.classList.add('active');
            }
        });
    });
    
    // 数量加减
    document.querySelectorAll('.qty-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var input = this.parentElement.querySelector('.qty-input');
            if (!input) return;
            var val = parseInt(input.value) || 1;
            var min = parseInt(input.min) || 1;
            var max = parseInt(input.max) || 99;
            
            if (this.dataset.action === 'minus') {
                val = Math.max(min, val - 1);
            } else if (this.dataset.action === 'plus') {
                val = Math.min(max, val + 1);
            }
            input.value = val;
        });
    });
    
    // 加入购物车
    document.querySelectorAll('.btn-add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var qtyInput = document.getElementById('product-qty');
            var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
            
            // 触发自定义事件，让购物车模块处理
            var event = new CustomEvent('weshop:addToCart', {
                detail: { productId: productId, qty: qty }
            });
            document.dispatchEvent(event);
            
            // 显示提示
            this.querySelector('.btn-text').textContent = '<?= __('已添加') ?>';
            setTimeout(function() {
                btn.querySelector('.btn-text').textContent = '<?= __('加入购物车') ?>';
            }, 1500);
        });
    });
    
    // 立即购买
    document.querySelectorAll('.btn-buy-now').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var qtyInput = document.getElementById('product-qty');
            var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
            
            // 触发自定义事件
            var event = new CustomEvent('weshop:buyNow', {
                detail: { productId: productId, qty: qty }
            });
            document.dispatchEvent(event);
        });
    });
    
    // 收藏
    document.querySelectorAll('.btn-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var productId = this.dataset.productId;
            var icon = this.querySelector('.btn-icon');
            
            // 触发自定义事件
            var event = new CustomEvent('weshop:addToWishlist', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
            
            // 切换图标
            if (icon.textContent === '❤') {
                icon.textContent = '💖';
            } else {
                icon.textContent = '❤';
            }
        });
    });
    if (document.readyState === 'complete') {
        setTimeout(normalizeWidgetPrices, 0);
    } else {
        window.addEventListener('load', normalizeWidgetPrices, { once: true });
    }
})();
</script>
