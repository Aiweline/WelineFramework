<?php
/**
 * WeShop Product模块 - 产品列表网格Hook
 * 
 * 在产品列表页网格区域渲染产品列表
 * Hook名称：WeShop_Product::frontend::layouts::product-list::grid-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Product\Service\ConfigurableProductService;

// 获取产品列表数据（由控制器传递）
$products = $this->getData('products') ?? [];
$currentView = $this->getData('current_view') ?? 'grid';

// 如果没有产品数据，不渲染任何内容（让fallback显示）
if (empty($products)) {
    return;
}

// 获取可配置产品服务
/** @var ConfigurableProductService $configurableService */
$configurableService = ObjectManager::getInstance(ConfigurableProductService::class);
?>

<div class="product-grid-container view-<?= htmlspecialchars($currentView) ?>">
    <?php foreach ($products as $product): ?>
    <?php
    $productId = (int)($product['product_id'] ?? 0);
    $name = $product['name'] ?? '';
    $shortDescription = $product['short_description'] ?? '';
    $price = (float)($product['price'] ?? 0);
    $originalPrice = (float)($product['original_price'] ?? $product['cost'] ?? 0);
    $image = $product['image'] ?? '';
    $sku = $product['sku'] ?? '';
    $handle = $product['handle'] ?? '';
    $inStock = $product['in_stock'] ?? ((int)($product['stock'] ?? 0) > 0);
    $rating = (float)($product['rating'] ?? 0);
    $reviewCount = (int)($product['review_count'] ?? 0);
    
    // 检查是否为可配置产品（有子产品）
    $isConfigurable = $productId > 0 ? $configurableService->isConfigurable($productId) : false;
    
    // 构建产品链接（使用 /product/{handle} 格式）
    $productUrl = !empty($handle) ? $this->getUrl('product/' . $handle) : $this->getUrl('weshop/product/view', ['id' => $productId]);
    ?>
    <div class="product-card" data-product-id="<?= $productId ?>">
        <div class="product-card-image">
            <a href="<?= htmlspecialchars($productUrl) ?>" class="product-image-link">
                <?php if (!empty($image)): ?>
                <img src="<?= htmlspecialchars($image) ?>" 
                     alt="<?= htmlspecialchars($name) ?>" 
                     class="product-image"
                     loading="lazy" />
                <?php else: ?>
                <div class="product-image-placeholder">
                    <span>📷</span>
                </div>
                <?php endif; ?>
            </a>
            
            <?php if (!$inStock): ?>
            <div class="product-badge out-of-stock"><?= __('缺货') ?></div>
            <?php elseif ($originalPrice > 0 && $originalPrice > $price): ?>
            <div class="product-badge sale"><?= round((1 - $price / $originalPrice) * 100) ?>% OFF</div>
            <?php endif; ?>
            
            <div class="product-actions-overlay">
                <button type="button" 
                        class="action-btn btn-quick-view" 
                        data-product-id="<?= $productId ?>"
                        title="<?= __('快速查看') ?>">
                    👁
                </button>
                <button type="button" 
                        class="action-btn btn-add-wishlist" 
                        data-product-id="<?= $productId ?>"
                        title="<?= __('收藏') ?>">
                    ❤
                </button>
                <button type="button" 
                        class="action-btn btn-add-compare" 
                        data-product-id="<?= $productId ?>"
                        title="<?= __('对比') ?>">
                    ⚖
                </button>
            </div>
        </div>
        
        <div class="product-card-info">
            <h3 class="product-name">
                <a href="<?= htmlspecialchars($productUrl) ?>"><?= htmlspecialchars($name) ?></a>
            </h3>
            
            <?php if ($rating > 0): ?>
            <div class="product-rating">
                <span class="rating-stars">
                    <?php for ($i = 1; $i <= 5; $i++): ?>
                    <span class="star <?= $i <= round($rating) ? 'filled' : '' ?>">★</span>
                    <?php endfor; ?>
                </span>
                <?php if ($reviewCount > 0): ?>
                <span class="review-count">(<?= $reviewCount ?>)</span>
                <?php endif; ?>
            </div>
            <?php endif; ?>
            
            <p class="product-description"><?= htmlspecialchars(mb_substr($shortDescription, 0, 80)) ?><?= mb_strlen($shortDescription) > 80 ? '...' : '' ?></p>
            
            <div class="product-price-box">
                <span class="product-price">¥<?= number_format($price, 2) ?></span>
                <?php if ($originalPrice > 0 && $originalPrice > $price): ?>
                <span class="product-original-price">¥<?= number_format($originalPrice, 2) ?></span>
                <?php endif; ?>
            </div>
            
            <div class="product-card-actions">
                <?php 
                // 使用hook渲染加购按钮（支持slot替换）
                echo $this->getHook('WeShop_Product::frontend::product::add-to-cart::button', [
                    'product' => $product,
                    'product_id' => $productId,
                    'in_stock' => $inStock,
                    'is_configurable' => $isConfigurable,
                    'button_class' => 'btn btn-primary btn-add-to-cart',
                ]);
                ?>
            </div>
        </div>
    </div>
    <?php endforeach; ?>
</div>

<?php 
// 渲染规格选择弹窗（只渲染一次）
echo $this->getHook('WeShop_Product::frontend::product::add-to-cart::options-popup');
?>

