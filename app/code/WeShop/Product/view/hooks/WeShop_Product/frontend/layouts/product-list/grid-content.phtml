<script>
(function() {
    // 加入购物车由 cart.js 模块通过事件委托处理
    // 按钮使用 data-action="add-to-cart" 属性
    
    // 快速查看
    document.querySelectorAll('.btn-quick-view').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.dataset.productId;
            var event = new CustomEvent('weshop:quickView', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
        });
    });
    
    // 加入收藏
    document.querySelectorAll('.btn-add-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.dataset.productId;
            var event = new CustomEvent('weshop:addToWishlist', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
            
            // 切换图标
            if (this.textContent.trim() === '❤') {
                this.textContent = '💖';
            } else {
                this.textContent = '❤';
            }
        });
    });
    
    // 加入对比
    document.querySelectorAll('.btn-add-compare').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.dataset.productId;
            var event = new CustomEvent('weshop:addToCompare', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
        });
    });
    
    // 确保购物车模块已加载
    if (window.Weline && window.Weline.declare) {
        window.Weline.declare('cart', true); // 声明并立即加载购物车模块
    }
})();
</script>
