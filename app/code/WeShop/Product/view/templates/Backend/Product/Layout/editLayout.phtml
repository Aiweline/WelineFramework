<?php
/**
 * @var \Weline\Framework\View\Template $this
 */
$context = is_array($layout_context ?? null) ? $layout_context : [];
$params = is_array($context['redirect_params'] ?? null) ? $context['redirect_params'] : [];
$layoutType = (string)($layout_type ?? 'product');
$layoutCode = (string)($layout_code ?? '');
$layoutSource = (string)($layout_source ?? '');
$layoutVersions = is_array($layout_versions ?? null) ? $layout_versions : [];
$hiddenContext = static function () use ($params): void {
    foreach ($params as $key => $value) {
        echo '<input type="hidden" name="' . htmlspecialchars((string)$key, ENT_QUOTES, 'UTF-8') . '" value="' . htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8') . '">' . PHP_EOL;
    }
};
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><lang>编辑自定义布局</lang></h4>
            <div class="page-title-right">
                <?php if ($params !== []): ?>
                    <a class="btn btn-outline-secondary btn-sm" href="<?= $this->getBackendUrl('*/backend/product/layout', $params) ?>">
                        <lang>返回布局管理</lang>
                    </a>
                <?php endif; ?>
            </div>
        </div>
        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title"><lang>Layout versions</lang></h5>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead>
                        <tr>
                            <th><lang>Version</lang></th>
                            <th><lang>Status</lang></th>
                            <th><lang>Asset ID</lang></th>
                            <th><lang>Version ID</lang></th>
                            <th><lang>Reason</lang></th>
                            <th><lang>Action</lang></th>
                        </tr>
                        </thead>
                        <tbody>
                        <?php foreach ($layoutVersions as $version): ?>
                            <?php
                            $assetId = (int)($version['asset_id'] ?? 0);
                            $versionId = (int)($version['version_id'] ?? 0);
                            $publishedVersionId = (int)($version['published_version_id'] ?? 0);
                            $isPublished = $publishedVersionId > 0 && $publishedVersionId === $versionId;
                            ?>
                            <tr>
                                <td><?= htmlspecialchars((string)($version['version_no'] ?? ''), ENT_QUOTES, 'UTF-8') ?></td>
                                <td>
                                    <span class="badge <?= $isPublished ? 'bg-success' : 'bg-secondary' ?>">
                                        <?= htmlspecialchars((string)($version['status'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
                                    </span>
                                    <?php if ($isPublished): ?>
                                        <span class="badge bg-info ms-1"><lang>Current</lang></span>
                                    <?php endif; ?>
                                </td>
                                <td><code><?= $assetId ?></code></td>
                                <td><code><?= $versionId ?></code></td>
                                <td><?= htmlspecialchars((string)($version['reason'] ?? ''), ENT_QUOTES, 'UTF-8') ?></td>
                                <td>
                                    <?php if ($assetId > 0 && $versionId > 0 && !$isPublished): ?>
                                        <form method="post" class="d-inline" action="<?= $this->getBackendUrl('*/backend/product/layout/save-layout', $params) ?>">
                                            <?php $hiddenContext(); ?>
                                            <input type="hidden" name="layout_action" value="rollback">
                                            <input type="hidden" name="layout_type" value="<?= htmlspecialchars($layoutType, ENT_QUOTES, 'UTF-8') ?>">
                                            <input type="hidden" name="layout_code" value="<?= htmlspecialchars($layoutCode, ENT_QUOTES, 'UTF-8') ?>">
                                            <input type="hidden" name="asset_id" value="<?= $assetId ?>">
                                            <input type="hidden" name="version_id" value="<?= $versionId ?>">
                                            <button class="btn btn-outline-warning btn-sm" type="submit">
                                                <lang>Rollback</lang>
                                            </button>
                                        </form>
                                    <?php endif; ?>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                        <?php if ($layoutVersions === []): ?>
                            <tr><td colspan="6" class="text-muted"><lang>Save this layout to create rollbackable versions.</lang></td></tr>
                        <?php endif; ?>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form method="post" action="<?= $this->getBackendUrl('*/backend/product/layout/save-layout', $params) ?>">
                    <?php $hiddenContext(); ?>
                    <input type="hidden" name="layout_type" value="<?= htmlspecialchars($layoutType, ENT_QUOTES, 'UTF-8') ?>">
                    <div class="mb-3">
                        <label class="form-label" for="weshop-edit-layout-code"><lang>布局代码</lang></label>
                        <input class="form-control" id="weshop-edit-layout-code" name="layout_code"
                               value="<?= htmlspecialchars($layoutCode, ENT_QUOTES, 'UTF-8') ?>"
                               placeholder="mother_day_2026" required>
                        <small class="text-muted"><lang>只能使用小写字母、数字、中划线和下划线；default 不能覆盖。</lang></small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="weshop-edit-layout-source"><lang>布局源码</lang></label>
                        <textarea class="form-control font-monospace" id="weshop-edit-layout-source" name="layout_source" rows="28" spellcheck="false" required><?= htmlspecialchars($layoutSource, ENT_QUOTES, 'UTF-8') ?></textarea>
                    </div>
                    <button class="btn btn-primary" type="submit"><lang>保存布局模板</lang></button>
                </form>
            </div>
        </div>
    </div>
</div>
