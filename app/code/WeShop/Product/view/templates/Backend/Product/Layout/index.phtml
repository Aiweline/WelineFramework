$withParams = static function (array $extra = []) use ($params): array {
    return array_merge($params, $extra);
};
$themeEditorParams = static function (string $code) use ($context, $editorLayoutType): array {
    return [
        'lock_layout' => 1,
        'lock_source' => 'weshop_layout',
        'editor_area' => 'frontend',
        'page_type' => $editorLayoutType,
        'layout_type' => $editorLayoutType,
        'layout_option' => $code !== '' ? $code : 'default',
        'target_type' => (string)($context['entity_type'] ?? ''),
        'virtual_target_type' => (string)($context['entity_type'] ?? ''),
        'target_id' => (int)($context['entity_id'] ?? 0),
        'virtual_target_id' => (int)($context['entity_id'] ?? 0),
        'scope' => 'default.default.default',
    ];
};
$hiddenContext = static function () use ($params): void {
    foreach ($params as $key => $value) {
        echo '<input type="hidden" name="' . htmlspecialchars((string)$key, ENT_QUOTES, 'UTF-8') . '" value="' . htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8') . '">' . PHP_EOL;
    }
};
