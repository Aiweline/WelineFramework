<script>
    // 产品关联弹窗逻辑
    $('#productLinksModal').on('show.bs.modal', function (event) {
        const button = $(event.relatedTarget);
        const productId = button.data('product-id');
        const productName = button.data('product-name');
        const childrenCount = button.data('children-count');
        
        // 设置产品名称
        $('#productLinksName').text(productName);
        $('#children-count-badge').text(childrenCount);
        
        // 重置状态
        $('#children-loading').removeClass('d-none');
        $('#children-empty').addClass('d-none');
        $('#children-table-wrapper').addClass('d-none');
        $('#children-table-body').empty();
        
        // 加载子产品
        loadChildren(productId);
    });
    
    function loadChildren(productId) {
        $.ajax({
            url: '@backend-url("*/backend/product/getChildren")',
            data: { product_id: productId },
            success: function(res) {
                $('#children-loading').addClass('d-none');
                
                if (res.items && res.items.length > 0) {
                    $('#children-table-wrapper').removeClass('d-none');
                    
                    let tbody = '';
                    res.items.forEach(function(product) {
                        const statusHtml = product.status == 1 
                            ? '<span class="badge bg-success">' + __('启用') + '</span>'
                            : '<span class="badge bg-danger">' + __('禁用') + '</span>';
                        
                        const imageHtml = product.image 
                            ? '<img src="' + product.image + '" alt="" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">'
                            : '<div style="width: 50px; height: 50px; background: #f5f5f5;" class="rounded d-flex align-items-center justify-content-center"><i class="bx bx-image text-muted"></i></div>';
                        
                        tbody += `
                            <tr>
                                <td>${product.product_id}</td>
                                <td>${imageHtml}</td>
                                <td>${product.local_name || product.name}</td>
                                <td><code>${product.sku}</code></td>
                                <td>¥${parseFloat(product.price || 0).toFixed(2)}</td>
                                <td>${product.stock || 0}</td>
                                <td>${statusHtml}</td>
                                <td>
                                    <a href="@backend-url('*/backend/product/edit')?product_id=${product.product_id}" 
                                       class="btn btn-sm btn-outline-primary" target="_blank">
                                        <i class="bx bx-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        `;
                    });
                    
                    $('#children-table-body').html(tbody);
                } else {
                    $('#children-empty').removeClass('d-none');
                }
            },
            error: function() {
                $('#children-loading').addClass('d-none');
                $('#children-empty').removeClass('d-none').find('p').text(__('加载失败，请重试'));
            }
        });
    }
    
    $('#optionConfig').on('show.bs.modal', function (event) {
        showLoading();
        // 触发的按钮
        let button = event.relatedTarget
        let product_code = button.getproduct('data-code')
        let entity_id = button.getproduct('data-entity_id')
        $.ajax({
            url: '@backend-url("*/backend/product/option/search")?entity_id={entity_id}&product_code={product_code}'.replace
            ('{entity_id}', entity_id).replace('{product_code}', product_code)
            , success: (res) => {
                let productOption = $('#productOption')
                productOption.empty()
                let options = res['option']
                if (options) {
                    for (let option in options) {
                        console.log()
                        productOption.append()
                    }
                }
                productOption.append('')
                console.log(res)
            }
        })
        hideLoading();
    })
    $("*[w-ajax]").on('click', function (event) {
        event.preventDefault()
        const target = $(this)
        let reload = target.data('reload')
        let action = target.attr('w-ajax')
        if (action.indexOf('?') < 0) {
            action += '?isAjax=true'
        } else {
            action += '&isAjax=true'
        }
        let data = target.data()
        $.ajax({
            url: action,
            data: data,
            success: (res) => {
                if (res.status !== 200) {
                    Swal.fire({
                        title: res.title,
                        text: res.message,
                        icon: 'error',
                        confirmButtonText: '@lang{好的}'
                    })
                } else {
                    Swal.fire({
                        title: res.title,
                        text: __('操作成功!'),
                        icon: 'success',
                        confirmButtonText: '@lang{好的}'
                    })
                }
                if (reload) {
                    location.reload()
                }
            }, error: function (res) {
                console.log(res)
            }
        })
    })
</script>
