<script>
(function() {
    'use strict';
    
    var WeShopProduct = {
        backendUrl: '<?= $this->getBackendUrl('*/backend/product') ?>',
        
        loadChildren: function(productId) {
            $.ajax({
                url: '<?= $this->getBackendUrl('*/backend/product/getChildren') ?>',
                data: { product_id: productId },
                success: function(res) {
                    $('#children-loading').addClass('d-none');
                    
                    if (res.items && res.items.length > 0) {
                        $('#children-table-wrapper').removeClass('d-none');
                        
                        var tbody = '';
                        res.items.forEach(function(product) {
                            var statusHtml = product.status == 1 
                                ? '<span class="badge bg-success">' + __('启用') + '</span>'
                                : '<span class="badge bg-danger">' + __('禁用') + '</span>';
                            
                            var imageHtml = product.image 
                                ? '<img src="' + product.image + '" alt="" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">'
                                : '<div style="width: 50px; height: 50px; background: var(--backend-color-bg-secondary);" class="rounded d-flex align-items-center justify-content-center"><i class="bx bx-image text-muted"></i></div>';
                            
                            tbody += '<tr>' +
                                '<td>' + product.product_id + '</td>' +
                                '<td>' + imageHtml + '</td>' +
                                '<td>' + (product.local_name || product.name) + '</td>' +
                                '<td><code>' + product.sku + '</code></td>' +
                                '<td>¥' + parseFloat(product.price || 0).toFixed(2) + '</td>' +
                                '<td>' + (product.stock || 0) + '</td>' +
                                '<td>' + statusHtml + '</td>' +
                                '<td>' +
                                    '<a href="<?= $this->getBackendUrl('*/backend/product/edit') ?>?product_id=' + product.product_id + '" ' +
                                       'class="btn btn-sm btn-outline-primary" target="_blank">' +
                                        '<i class="bx bx-edit"></i>' +
                                    '</a>' +
                                '</td>' +
                            '</tr>';
                        });
                        
                        $('#children-table-body').html(tbody);
                    } else {
                        $('#children-empty').removeClass('d-none');
                    }
                },
                error: function() {
                    $('#children-loading').addClass('d-none');
                    $('#children-empty').removeClass('d-none').find('p').text(__('加载失败，请重试'));
                }
            });
        },
        
        init: function() {
            var self = this;
            
            // 产品关联弹窗逻辑
            $('#productLinksModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var productId = button.data('product-id');
                var productName = button.data('product-name');
                var childrenCount = button.data('children-count');
                
                $('#productLinksName').text(productName);
                $('#children-count-badge').text(childrenCount);
                
                $('#children-loading').removeClass('d-none');
                $('#children-empty').addClass('d-none');
                $('#children-table-wrapper').addClass('d-none');
                $('#children-table-body').empty();
                
                self.loadChildren(productId);
            });
            
            // 配置项弹窗
            $('#optionConfig').on('show.bs.modal', function (event) {
                showLoading();
                var button = event.relatedTarget;
                var product_code = button.getAttribute('data-code');
                var entity_id = button.getAttribute('data-entity_id');
                $.ajax({
                    url: '<?= $this->getBackendUrl('*/backend/product/option/search') ?>?entity_id=' + entity_id + '&product_code=' + product_code,
                    success: function(res) {
                        var productOption = $('#productOption');
                        productOption.empty();
                        var options = res['option'];
                        if (options) {
                            for (var option in options) {
                                productOption.append('');
                            }
                        }
                        productOption.append('');
                    }
                });
                hideLoading();
            });
            
            // w-ajax 点击处理
            $("*[w-ajax]").on('click', function (event) {
                event.preventDefault();
                var target = $(this);
                var reload = target.data('reload');
                var action = target.attr('w-ajax');
                if (action.indexOf('?') < 0) {
                    action += '?isAjax=true';
                } else {
                    action += '&isAjax=true';
                }
                var data = target.data();
                $.ajax({
                    url: action,
                    data: data,
                    success: function(res) {
                        if (res.status !== 200) {
                            Swal.fire({
                                title: res.title,
                                text: res.message,
                                icon: 'error',
                                confirmButtonText: '<?= __('好的') ?>'
                            });
                        } else {
                            Swal.fire({
                                title: res.title,
                                text: __('操作成功!'),
                                icon: 'success',
                                confirmButtonText: '<?= __('好的') ?>'
                            });
                        }
                        if (reload) {
                            location.reload();
                        }
                    },
                    error: function(res) {
                        console.log(res);
                    }
                });
            });
        }
    };
    
    window.WeShopProduct = WeShopProduct;
    
    $(document).ready(function() {
        WeShopProduct.init();
    });
})();
</script>
