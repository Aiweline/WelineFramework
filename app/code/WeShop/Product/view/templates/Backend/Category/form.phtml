<script>
(function() {
    'use strict';
    
    var debounce = function(func, delay) {
        var timeoutId;
        return function() {
            var context = this;
            var args = arguments;
            if (timeoutId) {
                clearTimeout(timeoutId);
            }
            timeoutId = setTimeout(function() {
                func.apply(context, args);
                timeoutId = null;
            }, delay);
        };
    };

    var debounceProgressAttributeCode = debounce(function(e) {
        var target = $(e.target);
        var search = target.val();
        $.ajax({
            url: '<?= $this->getBackendUrl('*/backend/category/search') ?>' +
                '?id={{category.category_id}}&field=name&limit=10&search=' + search,
            success: function(res) {
                if (res['msg']) {
                    Swal.fire({
                        title: '<?= __('警告！') ?>',
                        text: res['msg'],
                        icon: 'error',
                        dangerMode: true,
                        confirmButtonText: '<?= __('好的') ?>'
                    });
                    return false;
                }
                var items = res['items'];
                var validationCategorySelect = $('#validationCategorySelect');
                validationCategorySelect.empty();
                if (items.length) {
                    for (var i = 0; i < items.length; i++) {
                        var item = items[i];
                        validationCategorySelect.append("<option " +
                            "value='" + item['category_id'] + "'>" +
                            (item['local_name'] || item['name']) + "</option>");
                    }
                    target.removeClass('border-danger');
                    target.addClass('border-success');
                } else {
                    validationCategorySelect.append('<option value="0"><?= __('顶层分类') ?></option>');
                    target.removeClass('border-success');
                    target.addClass('border-danger');
                }
            }
        });
    }, 500);
    
    $('#validationCategorySearch').on('input', debounceProgressAttributeCode);
    
    // 检测是否有成功消息，通知父窗口刷新
    $(document).ready(function() {
        var successMessage = $('.alert-success');
        if (successMessage.length > 0 && window.parent !== window) {
            window.parent.postMessage({ type: 'category_saved' }, '*');
        }
    });
})();
</script>
