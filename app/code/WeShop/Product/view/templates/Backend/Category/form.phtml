                                    <h5 class='mb-3'><lang>SEO 设置</lang></h5>
                                </div>
                                <div class='col-md-4'>
                                    <div class='mb-4'>
                                        <label class='form-label' for='validationMetaTitle'>
                                            <lang>Meta 标题</lang>
                                        </label>
                                        <input type='text' class='form-control' name='meta_title' id='validationMetaTitle'
                                               value='{{category.meta_title}}' maxlength='255'>
                                    </div>
                                </div>
                                <div class='col-md-4'>
                                    <div class='mb-4'>
                                        <label class='form-label' for='validationMetaKeywords'>
                                            <lang>Meta 关键词</lang>
                                        </label>
                                        <input type='text' class='form-control' name='meta_keywords' id='validationMetaKeywords'
                                               value='{{category.meta_keywords}}' maxlength='500'>
                                    </div>
                                </div>
                                <div class='col-md-4'>
                                    <div class='mb-4'>
                                        <label class='form-label' for='validationMetaDescription'>
                                            <lang>Meta 描述</lang>
                                        </label>
                                        <textarea class='form-control' name='meta_description' id='validationMetaDescription' rows='2'>{{category.meta_description}}</textarea>
                                    </div>
                                </div>
                            </div>
                            <!-- EAV 属性设置 -->
                            <div class='row'>
