                                    <h5 class='mb-3'><lang>分类属性设置</lang></h5>
                                </div>
                                <div class='col-md-6'>
                                    <div class='mb-4'>
                                        <div class='form-check form-switch'>
                                            <input class='form-check-input' type='checkbox' name='is_right_menu' id='validationIsRightMenu' 
                                                   value='1' <if condition="category.is_right_menu == 1">checked</if>>
                                            <label class='form-check-label' for='validationIsRightMenu'>
