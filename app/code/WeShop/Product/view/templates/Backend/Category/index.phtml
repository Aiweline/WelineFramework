<script>
(function() {
    'use strict';
    
    var WeShopCategory = {
        flushIframe: function() {
            var iframe = $('#categoryAddIframe');
            iframe.attr('src', iframe.attr('src'));
        },
        
        init: function() {
            var self = this;
            
            // offcanvas 显示时加载 iframe
            var offcanvasRightCategoryForm = $('#offcanvasRightCategoryForm');
            offcanvasRightCategoryForm.on('show.bs.offcanvas', function () {
                var categoryAddIframe = $('#categoryAddIframe');
                categoryAddIframe.attr('src', categoryAddIframe.attr('data-src'));
            });
            
            // 删除确认
            $('a.weshop-category-delete').click(function(event) {
                event.preventDefault();
                var href = $(this).attr('href');
                showLoading();
                Swal.fire({
                    title: '<?= __('确定删除吗?') ?>',
                    text: "<?= __('删除后不可恢复') ?>",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: '<?= __('确定') ?>',
                    cancelButtonText: '<?= __('取消') ?>'
                }).then(function(result) {
                    hideLoading();
                    if (result.value) {
                        window.location.href = href;
                    }
                });
            });
        }
    };
    
    window.WeShopCategory = WeShopCategory;
    
    $(document).ready(function() {
        WeShopCategory.init();
    });
})();
</script>
