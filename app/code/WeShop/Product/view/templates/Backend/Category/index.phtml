    <div class='col-12'>
        <div class='card'>
            <div class='card-body'>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class='card-title mb-1'><lang>分类管理</lang></h4>
                        <p class='card-title-desc mb-0'><?= __('树形结构管理分类，最多支持 %{1} 级分类', $maxLevel) ?></p>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="weshop-category-expand-all">
                            <i class="ri-add-box-line"></i> <lang>全部展开</lang>
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="weshop-category-collapse-all">
                            <i class="ri-checkbox-indeterminate-line"></i> <lang>全部收起</lang>
                        </button>
                        <button class='btn btn-primary btn-sm' type='button' id="weshop-category-add-root">
                            <i class="ri-add-line"></i> <lang>添加根分类</lang>
                        </button>
                    </div>
                </div>
                
                <!-- 分类树容器 -->
                <div class="weshop-category-tree-wrapper">
                    <?php if (empty($categoryTree)): ?>
                    <div class="weshop-category-tree-empty">
                        <i class="ri-folder-open-line"></i>
                        <p><lang>暂无分类数据</lang></p>
                        <button type="button" class="btn btn-primary" id="weshop-category-add-first">
                            <i class="ri-add-line"></i> <lang>添加第一个分类</lang>
                        </button>
                    </div>
                    <?php else: ?>
                    <ul class="weshop-category-tree" id="weshop-category-tree">
                        <?php
                        $renderNode = function (array $category, int $level = 1) use (&$renderNode, $maxLevel): void {
                            $categoryId = (int)($category['category_id'] ?? 0);
                            $displayName = htmlspecialchars($category['display_name'] ?? $category['name'] ?? '', ENT_QUOTES);
                            $hasChildren = !empty($category['children']);
                            $canAddChild = $level < $maxLevel;
                            $isActive = (int)($category['is_active'] ?? 1);
                            $sortOrder = (int)($category['sort_order'] ?? 0);
                            ?>
                            <li class="weshop-category-tree-item<?= $hasChildren ? ' has-children' : '' ?>" 
                                data-id="<?= $categoryId ?>" 
                                data-level="<?= $level ?>"
                                data-expanded="true">
                                <div class="weshop-category-tree-node">
                                    <div class="weshop-category-tree-toggle">
                                        <?php if ($hasChildren): ?>
                                        <i class="ri-arrow-down-s-line toggle-icon"></i>
                                        <?php else: ?>
                                        <i class="ri-subtract-line toggle-placeholder"></i>
                                        <?php endif; ?>
                                    </div>
                                    <div class="weshop-category-tree-content">
                                        <span class="weshop-category-tree-name"><?= $displayName ?></span>
                                        <?php if (!$isActive): ?>
                                        <span class="badge bg-secondary ms-2"><lang>已禁用</lang></span>
                                        <?php endif; ?>
                                        <span class="weshop-category-tree-meta">
                                            <small class="text-muted">ID: <?= $categoryId ?></small>
                                            <small class="text-muted ms-2"><lang>排序</lang>: <?= $sortOrder ?></small>
                                        </span>
                                    </div>
                                    <div class="weshop-category-tree-actions">
                                        <?php if ($canAddChild): ?>
                                        <button type="button" class="btn btn-sm btn-outline-success weshop-category-add-child" 
                                                data-parent-id="<?= $categoryId ?>"
                                                data-parent-name="<?= $displayName ?>"
                                                title="<?= __('添加子分类') ?>">
                                            <i class="ri-add-line"></i>
                                        </button>
                                        <?php endif; ?>
                                        <button type="button" class="btn btn-sm btn-outline-primary weshop-category-edit" 
                                                data-id="<?= $categoryId ?>"
                                                title="<?= __('编辑') ?>">
                                            <i class="ri-edit-line"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger weshop-category-delete" 
                                                data-id="<?= $categoryId ?>"
                                                data-name="<?= $displayName ?>"
                                                data-has-children="<?= $hasChildren ? '1' : '0' ?>"
                                                title="<?= __('删除') ?>">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </div>
                                </div>
                                <?php if ($hasChildren): ?>
                                <ul class="weshop-category-tree-children">
                                    <?php foreach ($category['children'] as $child): ?>
                                        <?php $renderNode($child, $level + 1); ?>
                                    <?php endforeach; ?>
                                </ul>
                                <?php endif; ?>
                            </li>
                            <?php
                        };
                        
                        foreach ($categoryTree as $rootCategory):
                            $renderNode($rootCategory, 1);
                        endforeach;
                        ?>
                    </ul>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</div>

