<?php
/**
 * 分类管理 - 树形结构
 * @var \Weline\Framework\View\Template $this
 * @var array $categoryTree 分类树数据
 * @var int $maxLevel 最大层级
 */

$categoryTree = $categoryTree ?? [];
$maxLevel = $maxLevel ?? 4;
?>

