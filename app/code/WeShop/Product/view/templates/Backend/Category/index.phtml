</style>

<script>
(function() {
    'use strict';
    
    var STORAGE_KEY = 'weshop_category_tree_state';
    
    var WeShopCategoryTree = {
        offcanvas: null,
        iframe: null,
        
        init: function() {
            var self = this;
            
            this.offcanvas = new bootstrap.Offcanvas(document.getElementById('offcanvasCategoryForm'));
            this.iframe = document.getElementById('categoryFormIframe');
            
            this.restoreExpandState();
            this.bindEvents();
        },
        
        bindEvents: function() {
            var self = this;
            
            document.querySelectorAll('.weshop-category-tree-toggle').forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var item = this.closest('.weshop-category-tree-item');
                    if (item && item.classList.contains('has-children')) {
                        self.toggleItem(item);
                    }
                });
            });
            
            document.querySelectorAll('.weshop-category-add-child').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var parentId = this.dataset.parentId;
                    var parentName = this.dataset.parentName;
                    self.openAddForm(parentId, parentName);
                });
            });
            
            document.querySelectorAll('.weshop-category-edit').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var id = this.dataset.id;
                    self.openEditForm(id);
                });
            });
            
            document.querySelectorAll('.weshop-category-delete').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var id = this.dataset.id;
                    var name = this.dataset.name;
                    var hasChildren = this.dataset.hasChildren === '1';
                    self.confirmDelete(id, name, hasChildren);
                });
            });
            
            var addRootBtn = document.getElementById('weshop-category-add-root');
            if (addRootBtn) {
                addRootBtn.addEventListener('click', function() {
                    self.openAddForm(0, '');
                });
            }
            
            var addFirstBtn = document.getElementById('weshop-category-add-first');
            if (addFirstBtn) {
                addFirstBtn.addEventListener('click', function() {
                    self.openAddForm(0, '');
                });
            }
            
            var expandAllBtn = document.getElementById('weshop-category-expand-all');
            if (expandAllBtn) {
                expandAllBtn.addEventListener('click', function() {
                    self.expandAll();
                });
            }
            
            var collapseAllBtn = document.getElementById('weshop-category-collapse-all');
            if (collapseAllBtn) {
                collapseAllBtn.addEventListener('click', function() {
                    self.collapseAll();
                });
            }
            
            window.addEventListener('message', function(e) {
                if (e.data && e.data.type === 'category_saved') {
                    self.offcanvas.hide();
                    location.reload();
                }
            });
        },
        
        toggleItem: function(item) {
            var isExpanded = item.dataset.expanded === 'true';
            item.dataset.expanded = isExpanded ? 'false' : 'true';
            this.saveExpandState();
        },
        
        expandAll: function() {
            document.querySelectorAll('.weshop-category-tree-item.has-children').forEach(function(item) {
                item.dataset.expanded = 'true';
            });
            this.saveExpandState();
        },
        
        collapseAll: function() {
            document.querySelectorAll('.weshop-category-tree-item.has-children').forEach(function(item) {
                item.dataset.expanded = 'false';
            });
            this.saveExpandState();
        },
        
        saveExpandState: function() {
            var state = {};
            document.querySelectorAll('.weshop-category-tree-item[data-id]').forEach(function(item) {
                state[item.dataset.id] = item.dataset.expanded === 'true';
            });
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
            } catch (e) {}
        },
        
        restoreExpandState: function() {
            try {
                var state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
                document.querySelectorAll('.weshop-category-tree-item[data-id]').forEach(function(item) {
                    var id = item.dataset.id;
                    if (state.hasOwnProperty(id)) {
                        item.dataset.expanded = state[id] ? 'true' : 'false';
                    }
                });
            } catch (e) {}
        },
        
        openAddForm: function(parentId, parentName) {
            var url = '<?= $this->getBackendUrl('*/backend/category/add') ?>';
            url += (url.indexOf('?') > -1 ? '&' : '?') + 'parent_id=' + parentId;
            if (parentName) {
                url += '&parent_name=' + encodeURIComponent(parentName);
            }
            
            document.getElementById('offcanvasCategoryFormLabel').textContent = 
                parentId > 0 ? '<?= __('添加子分类') ?>' : '<?= __('添加根分类') ?>';
            this.iframe.src = url;
            this.offcanvas.show();
        },
        
        openEditForm: function(id) {
            var url = '<?= $this->getBackendUrl('*/backend/category/edit') ?>';
            url += (url.indexOf('?') > -1 ? '&' : '?') + 'id=' + id;
            
            document.getElementById('offcanvasCategoryFormLabel').textContent = '<?= __('编辑分类') ?>';
            this.iframe.src = url;
            this.offcanvas.show();
        },
        
        confirmDelete: function(id, name, hasChildren) {
            var message = '<?= __('确定要删除分类') ?> "' + name + '" <?= __('吗？') ?>';
            if (hasChildren) {
                message += '\n\n<?= __('警告：该分类包含子分类，删除后子分类也会被删除！') ?>';
            }
            
            BackendConfirm.show(message, {
                title: '<?= __('确认删除') ?>',
                confirmText: '<?= __('删除') ?>',
                cancelText: '<?= __('取消') ?>',
                type: hasChildren ? 'danger' : 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    window.location.href = '<?= $this->getBackendUrl('*/backend/category/delete') ?>?id=' + id;
                }
            });
        }
    };
    
    window.WeShopCategoryTree = WeShopCategoryTree;
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            WeShopCategoryTree.init();
        });
    } else {
        WeShopCategoryTree.init();
    }
})();
</script>
