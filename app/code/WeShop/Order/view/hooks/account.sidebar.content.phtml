 *
 * Hook: account.sidebar.content
 *
 * @hook-priority 5
 * @hook-sort-order 999
 * @hook-solo false
 */
use Weline\Customer\Service\AccountSidebarContentGate;

if (!AccountSidebarContentGate::accepts('orders')) {
