}

if (!empty($GLOBALS['__weline_order_account_sidebar_content_rendered'])) {
    return;
}

$GLOBALS['__weline_order_account_sidebar_content_rendered'] = true;
?>
<section class="account-hook-section account-index__section d-none motor-account-section" id="orders-section" data-account-section="orders" hidden>
    <?= $this->getHook('Weline_Order::frontend::account::index::orders') ?>
</section>
