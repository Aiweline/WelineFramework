<script>
(function () {
    var orderText = <?= json_encode($orderJsText, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>;
    var orderApiPromise = null;
    var noticeTimer = 0;
    var noticeResolver = null;
    var noticeLastTrigger = null;

    function getOrderApi() {
        if (!orderApiPromise) {
            orderApiPromise = Promise.resolve(window.Weline.Api.resource('order'));
        }
        return orderApiPromise;
    }

    function getNoticeParts() {
        var root = document.querySelector('[data-order-notice]');
        if (!root) return null;

        return {
            root: root,
            badge: root.querySelector('[data-order-notice-badge]'),
            title: root.querySelector('[data-order-notice-title]'),
            message: root.querySelector('[data-order-notice-message]'),
            cancel: root.querySelector('[data-order-notice-cancel]'),
            confirm: root.querySelector('[data-order-notice-confirm]')
        };
    }

    function normalizeNoticeType(type) {
        return ['success', 'warning', 'error'].indexOf(type) !== -1 ? type : 'info';
    }

    function resetNoticeClasses(element) {
        if (!element) return;
        element.classList.remove('is-success', 'is-warning', 'is-error');
    }

    function closeNotice(result) {
        var parts = getNoticeParts();
        if (!parts) return;

        window.clearTimeout(noticeTimer);
        noticeTimer = 0;
        parts.root.classList.remove('is-visible');

        window.setTimeout(function () {
            if (!parts.root.classList.contains('is-visible')) {
                parts.root.hidden = true;
            }
        }, 220);

        if (noticeLastTrigger && noticeLastTrigger.isConnected && typeof noticeLastTrigger.focus === 'function') {
            noticeLastTrigger.focus({ preventScroll: true });
        }
        noticeLastTrigger = null;

        if (noticeResolver) {
            var resolver = noticeResolver;
            noticeResolver = null;
            resolver(result);
        }
    }

    function openNotice(options) {
        var parts = getNoticeParts();
        if (!parts) {
            return Promise.resolve(false);
        }

        var type = normalizeNoticeType(options && options.type);
        var mode = options && options.mode === 'confirm' ? 'confirm' : 'notice';
        var iconMap = {
            info: 'ri-information-line',
            success: 'ri-checkbox-circle-line',
            warning: 'ri-error-warning-line',
            error: 'ri-close-circle-line'
        };

        window.clearTimeout(noticeTimer);
        noticeTimer = 0;
        noticeResolver = null;

        resetNoticeClasses(parts.badge);
        resetNoticeClasses(parts.confirm);

        if (type !== 'info') {
            parts.badge.classList.add('is-' + type);
            parts.confirm.classList.add('is-' + type);
        }

        parts.badge.innerHTML = '<i class="' + iconMap[type] + '"></i>';
        parts.title.textContent = (options && options.title) || orderText.noticeTitle;
        parts.message.textContent = (options && options.message) || '';
        parts.confirm.textContent = (options && options.confirmText) || orderText.confirmText;
        parts.cancel.textContent = (options && options.cancelText) || orderText.cancelText;
        parts.cancel.hidden = mode !== 'confirm';

        parts.root.hidden = false;
        window.requestAnimationFrame(function () {
            parts.root.classList.add('is-visible');
        });

        if (mode === 'confirm') {
            return new Promise(function (resolve) {
                noticeResolver = resolve;
            });
        }

        if (options && options.duration > 0) {
            noticeTimer = window.setTimeout(function () {
                closeNotice(true);
            }, options.duration);
        }

        return Promise.resolve(true);
    }

    function notifyOrder(message, type, duration) {
        var titleMap = {
            info: orderText.noticeTitle,
            success: orderText.noticeSuccessTitle,
            warning: orderText.noticeWarningTitle,
            error: orderText.noticeErrorTitle
        };
        var normalizedType = normalizeNoticeType(type);
        return openNotice({
            mode: 'notice',
            type: normalizedType,
            title: titleMap[normalizedType] || titleMap.info,
            message: message,
            duration: duration
        });
    }

    function togglePanel(button) {
        var card = button.closest('[data-order-card]');
        var panelName = button.getAttribute('data-order-toggle');
        var panel = card && card.querySelector('[data-order-panel="' + panelName + '"]');
        if (!card || !panel) return;

        var open = panel.hidden;
        card.querySelectorAll('[data-order-panel]').forEach(function (item) { item.hidden = true; });
        card.querySelectorAll('[data-order-toggle]').forEach(function (item) { item.setAttribute('aria-expanded', 'false'); });
        panel.hidden = !open;
        button.setAttribute('aria-expanded', open ? 'true' : 'false');

        if (open && panelName === 'payment') {
            var frame = panel.querySelector('iframe[data-src]');
            if (frame && !frame.getAttribute('src')) {
                frame.setAttribute('src', button.getAttribute('data-checkout-url') || frame.getAttribute('data-src'));
            }
        }
    }

    function closePanel(button) {
        var card = button.closest('[data-order-card]');
        if (!card) return;

        card.querySelectorAll('[data-order-panel]').forEach(function (item) { item.hidden = true; });
        card.querySelectorAll('[data-order-toggle]').forEach(function (item) { item.setAttribute('aria-expanded', 'false'); });

        var detailsButton = card.querySelector('[data-order-toggle="details"]');
        if (detailsButton && typeof detailsButton.focus === 'function') {
            detailsButton.focus({ preventScroll: true });
        }
        card.scrollIntoView({ block: 'nearest' });
    }

    function confirmCancel(message) {
        return openNotice({
            mode: 'confirm',
            type: 'warning',
            title: orderText.cancelOrderTitle,
            message: message,
            confirmText: orderText.confirmCancelText,
            cancelText: orderText.rethinkText
        });
    }

    function cancelOrder(button) {
        var card = button.closest('[data-order-card]');
        var orderId = parseInt(card && card.getAttribute('data-order-id') || '0', 10);
        if (!card || !orderId || button.disabled) return;
        noticeLastTrigger = button;

        confirmCancel(button.getAttribute('data-confirm-message') || '').then(function (confirmed) {
            if (!confirmed) return;
            button.disabled = true;
            notifyOrder(orderText.cancellingOrder, 'info', 1200);
            getOrderApi()
                .then(function (OrderApi) { return OrderApi.cancel({ order_id: orderId }); })
                .then(function (payload) {
                    if (!payload || payload.success === false) {
                        throw new Error((payload && payload.message) || orderText.cancelOrderFailed);
                    }
                    var statusBadge = card.querySelector('.weshop-status-badge');
                    if (statusBadge) {
                        statusBadge.textContent = orderText.statusCancelled;
                        statusBadge.className = 'weshop-status-badge status-cancelled';
                    }
                    card.classList.remove('unpaid');
                    var paymentBadge = card.querySelector('.weshop-payment-badge');
                    if (paymentBadge) paymentBadge.remove();
                    card.querySelectorAll('[data-order-cancel], [data-order-toggle="payment"]').forEach(function (item) { item.remove(); });
                    notifyOrder((payload && payload.message) || orderText.orderCancelled, 'success', 2200);
                })
                .catch(function (error) {
                    button.disabled = false;
                    notifyOrder(error && error.message ? error.message : orderText.cancelOrderFailed, 'error', 3200);
                });
        });
    }

    function executeInsertedScripts(container) {
        if (!container) return;
        Array.prototype.slice.call(container.querySelectorAll('script')).forEach(function (oldScript) {
            var script = document.createElement('script');
            Array.prototype.slice.call(oldScript.attributes).forEach(function (attribute) {
                script.setAttribute(attribute.name, attribute.value);
            });
            script.text = oldScript.textContent || '';
            oldScript.parentNode.replaceChild(script, oldScript);
        });
    }

    function escapeOrdersHtml(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatOrdersLabel(pattern, arg) {
        return String(pattern || '').replace('%{1}', String(arg == null ? '' : arg));
    }

    function renderSummaryItems(order, labels) {
        if (!order.summary_items || order.summary_items.length === 0) {
            return '<span class="weshop-order-muted">' + escapeOrdersHtml(labels.items_missing) + '</span>';
        }
        var html = '';
        order.summary_items.forEach(function (item) {
            html += '<div class="weshop-order-product-row">'
                + '<div class="weshop-order-product-image">'
                + (item.image
                    ? '<img src="' + escapeOrdersHtml(item.image) + '" alt="' + escapeOrdersHtml(item.name) + '" loading="lazy">'
                    : '<i class="ri-image-line" aria-hidden="true"></i>')
                + '</div>'
                + '<div class="weshop-order-product-main"><strong>' + escapeOrdersHtml(item.name) + '</strong>'
                + (item.sku ? '<span>SKU: ' + escapeOrdersHtml(item.sku) + '</span>' : '')
                + '</div><span>x' + escapeOrdersHtml(item.qty) + '</span>'
                + '<span>' + escapeOrdersHtml(item.price_formatted) + '</span>'
                + '<strong>' + escapeOrdersHtml(item.total_formatted) + '</strong></div>';
        });
        if (order.remaining_item_count > 0) {
            html += '<button type="button" class="weshop-order-more-items" data-order-toggle="details">'
                + escapeOrdersHtml(formatOrdersLabel(labels.more_items, order.remaining_item_count))
                + '</button>';
        }
        return html;
    }

    function renderDetailItems(order, labels) {
        if (!order.has_detail_items) {
            return '<p class="weshop-order-muted">' + escapeOrdersHtml(labels.items_missing) + '</p>';
        }
        var html = '';
        (order.detail_items || []).forEach(function (item) {
            html += '<div class="weshop-order-item-line">'
                + '<div class="weshop-order-product-image">'
                + (item.image
                    ? '<img src="' + escapeOrdersHtml(item.image) + '" alt="' + escapeOrdersHtml(item.name) + '" loading="lazy">'
                    : '<i class="ri-image-line" aria-hidden="true"></i>')
                + '</div><div><strong>' + escapeOrdersHtml(item.name) + '</strong><span>' + escapeOrdersHtml(item.sku) + '</span></div>'
                + '<div>' + escapeOrdersHtml(formatOrdersLabel(labels.qty, item.qty)) + '</div>'
                + '<div>' + escapeOrdersHtml(item.total_formatted) + '</div></div>';
        });
        return html;
    }

    function renderOrderCard(order, labels) {
        var unpaidClass = order.is_unpaid ? ' unpaid' : '';
        var html = '<article class="weshop-order-item' + unpaidClass + '" id="' + escapeOrdersHtml(order.card_id)
            + '" data-order-card data-order-id="' + escapeOrdersHtml(order.order_id) + '">'
            + '<div class="weshop-order-header"><div class="weshop-order-info">'
            + '<span class="weshop-order-number">' + escapeOrdersHtml(formatOrdersLabel(labels.order_number, order.increment_id)) + '</span>'
            + '<span class="weshop-order-date">' + escapeOrdersHtml(order.created_label) + '</span></div>'
            + '<div class="weshop-order-status"><span class="weshop-status-badge status-' + escapeOrdersHtml(order.status) + '">'
            + escapeOrdersHtml(order.status_label) + '</span>'
            + (order.is_unpaid ? '<span class="weshop-payment-badge payment-failed">' + escapeOrdersHtml(labels.pending_payment) + '</span>' : '')
            + '</div></div><div class="weshop-order-content"><div class="weshop-order-amount">'
            + '<span class="weshop-amount-label">' + escapeOrdersHtml(labels.amount_label) + '</span>'
            + '<span class="weshop-amount-value">' + escapeOrdersHtml(order.total_formatted) + '</span></div>'
            + '<div class="weshop-order-products-summary">' + renderSummaryItems(order, labels) + '</div></div>'
            + '<div class="weshop-order-actions"><button type="button" class="weshop-action-link" data-order-toggle="details" aria-expanded="false">'
            + escapeOrdersHtml(labels.view_details) + '</button>';
        if (order.can_retry_payment) {
            html += '<button type="button" class="weshop-action-button weshop-retry-payment-button" data-order-toggle="payment" data-checkout-url="'
                + escapeOrdersHtml(order.checkout_url) + '" aria-expanded="false"><i class="ri-bank-card-line" aria-hidden="true"></i>'
                + escapeOrdersHtml(labels.continue_payment) + '</button>';
        }
        if (order.can_cancel) {
            html += '<button type="button" class="weshop-action-button weshop-cancel-button" data-order-cancel data-confirm-message="'
                + escapeOrdersHtml(order.cancel_confirm_message) + '"><i class="ri-close-circle-line" aria-hidden="true"></i>'
                + escapeOrdersHtml(labels.cancel_order) + '</button>';
        } else if (order.require_return) {
            html += '<a href="' + escapeOrdersHtml(order.return_link) + '" class="weshop-action-button weshop-return-button js-account-rma-trigger" data-account-nav-link="true" data-section="returns" data-order-id="'
                + escapeOrdersHtml(order.order_id) + '" data-order-increment-id="' + escapeOrdersHtml(order.increment_id) + '" data-return-anchor="'
                + escapeOrdersHtml(order.card_id) + '" data-return-url="' + escapeOrdersHtml(order.return_url) + '" title="'
                + escapeOrdersHtml(order.cancel_reason) + '"><i class="ri-exchange-line" aria-hidden="true"></i>'
                + escapeOrdersHtml(labels.request_return) + '</a>';
        } else if (order.cancel_reason) {
            html += '<span class="weshop-cancel-disabled" title="' + escapeOrdersHtml(order.cancel_reason) + '">'
                + escapeOrdersHtml(labels.cannot_cancel) + '</span>';
        }
        html += '</div><section class="weshop-order-panel" data-order-panel="details" hidden><div class="weshop-order-panel__header"><h3>'
            + escapeOrdersHtml(labels.order_details) + '</h3><div class="weshop-order-panel__meta"><span>'
            + escapeOrdersHtml(order.increment_id) + '</span><button type="button" class="weshop-order-panel__close" data-order-close>'
            + escapeOrdersHtml(labels.back_to_order) + '</button></div></div><div class="weshop-order-detail-grid">'
            + '<div><span>' + escapeOrdersHtml(labels.order_status) + '</span><strong>' + escapeOrdersHtml(order.status_label) + '</strong></div>'
            + '<div><span>' + escapeOrdersHtml(labels.payment_status) + '</span><strong>'
            + escapeOrdersHtml(order.is_unpaid ? labels.pending_payment : order.payment_status) + '</strong></div>'
            + '<div><span>' + escapeOrdersHtml(labels.fulfillment_status) + '</span><strong>' + escapeOrdersHtml(order.fulfillment_status) + '</strong></div>'
            + '<div><span>' + escapeOrdersHtml(labels.payment_method) + '</span><strong>' + escapeOrdersHtml(order.payment_method) + '</strong></div>'
            + '<div><span>' + escapeOrdersHtml(labels.shipping_method) + '</span><strong>' + escapeOrdersHtml(order.shipping_method) + '</strong></div>'
            + '<div><span>' + escapeOrdersHtml(labels.order_amount) + '</span><strong>' + escapeOrdersHtml(order.total_formatted) + '</strong></div>'
            + '</div><div class="weshop-order-items-inline"><h4>' + escapeOrdersHtml(labels.order_items) + '</h4>'
            + renderDetailItems(order, labels) + '</div></section>';
        if (order.can_retry_payment) {
            html += '<section class="weshop-order-panel weshop-order-payment-panel" data-order-panel="payment" hidden><div class="weshop-order-panel__header"><h3>'
                + escapeOrdersHtml(labels.continue_payment) + '</h3><span>' + escapeOrdersHtml(formatOrdersLabel(labels.order_number, order.increment_id)) + '</span></div>'
                + '<p class="weshop-order-muted">' + escapeOrdersHtml(labels.payment_panel_hint) + '</p>'
                + '<iframe class="weshop-order-checkout-frame" title="' + escapeOrdersHtml(labels.continue_payment) + '" data-src="'
                + escapeOrdersHtml(order.checkout_url) + '"></iframe></section>';
        }
        html += '</article>';
        return html;
    }

    function renderOrdersPagination(payload, labels) {
        if (!payload || payload.total_pages <= 1) {
            return '';
        }
        var currentPage = payload.current_page || 1;
        var totalPages = payload.total_pages || 1;
        var html = '<nav class="weshop-order-pagination" aria-label="' + escapeOrdersHtml(labels.pagination) + '">';
        if (currentPage > 1) {
            html += '<button type="button" data-order-page="' + (currentPage - 1) + '">' + escapeOrdersHtml(labels.prev) + '</button>';
        } else {
            html += '<span class="is-disabled">' + escapeOrdersHtml(labels.prev) + '</span>';
        }
        for (var page = 1; page <= totalPages; page++) {
            if (page === currentPage) {
                html += '<span class="is-active">' + page + '</span>';
            } else {
                html += '<button type="button" data-order-page="' + page + '">' + page + '</button>';
            }
        }
        if (currentPage < totalPages) {
            html += '<button type="button" data-order-page="' + (currentPage + 1) + '">' + escapeOrdersHtml(labels.next) + '</button>';
        } else {
            html += '<span class="is-disabled">' + escapeOrdersHtml(labels.next) + '</span>';
        }
        html += '</nav>';
        return html;
    }

    function renderOrdersBody(bodyMount, payload) {
        var labels = payload.labels || {};
        var html = '<div class="weshop-orders-list">';
        if (!payload.orders || payload.orders.length === 0) {
            html += '<div class="weshop-empty-orders"><i class="ri-shopping-bag-line weshop-empty-orders-icon" aria-hidden="true"></i><p>'
                + escapeOrdersHtml(payload.is_filtered_empty ? labels.empty_filtered : labels.empty_all) + '</p>';
            if (payload.is_filtered_empty) {
                html += '<button type="button" class="weshop-shopping-button" data-order-status-filter data-order-status="">'
                    + escapeOrdersHtml(labels.view_all_orders) + '</button>';
            } else {
                html += '<a href="' + escapeOrdersHtml(payload.shop_url || '/') + '" class="weshop-shopping-button">'
                    + escapeOrdersHtml(labels.go_shopping) + '</a>';
            }
            html += '</div>';
        } else {
            payload.orders.forEach(function (order) {
                html += renderOrderCard(order, labels);
            });
        }
        html += '</div>' + renderOrdersPagination(payload, labels);
        bodyMount.innerHTML = html;
    }

    function renderUnpaidAlert(root, unpaidCount) {
        if (!root) {
            return;
        }

        var alertMount = root.querySelector('[data-weshop-unpaid-alert]');
        if (!alertMount) {
            return;
        }

        var count = Math.max(0, parseInt(unpaidCount || 0, 10) || 0);
        if (count <= 0) {
            alertMount.hidden = true;
            alertMount.innerHTML = '';
            return;
        }

        alertMount.hidden = false;
        alertMount.innerHTML = '<div class="weshop-alert-content">'
            + '<i class="ri-error-warning-line weshop-alert-icon" aria-hidden="true"></i>'
            + '<div class="weshop-alert-text"><strong>'
            + escapeOrdersHtml(formatOrdersLabel(orderText.unpaidAlertTitle, count))
            + '</strong><p>' + escapeOrdersHtml(orderText.unpaidAlertHint) + '</p></div></div>';
    }

    function initOrderFragmentLoader() {
        var root = document.getElementById('weshop-account-orders');
        if (!root || root.dataset.fragmentLoaderReady === '1') return;
        root.dataset.fragmentLoaderReady = '1';

        var bodyMount = root.querySelector('[data-weshop-orders-body]');
        var fragmentLoading = false;
        var fragmentRequestId = 0;

        function getActiveOrderStatus() {
            return root.getAttribute('data-active-order-status') || '';
        }

        function setActiveOrderStatus(status) {
            root.setAttribute('data-active-order-status', status || '');
        }

        function setActiveOrderFilter(status) {
            setActiveOrderStatus(status);
            root.querySelectorAll('[data-order-status-filter]').forEach(function (button) {
                var code = button.getAttribute('data-order-status') || '';
                var active = code === (status || '');
                button.classList.toggle('is-active', active);
                button.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
        }

        function syncOrdersUrlState(status, page) {
            var url = new URL(window.location.href);
            if (status) {
                url.searchParams.set('order_status', status);
            } else {
                url.searchParams.delete('order_status');
            }
            if (page > 1) {
                url.searchParams.set('order_page', String(page));
            } else {
                url.searchParams.delete('order_page');
            }
            var pageSize = root.getAttribute('data-order-page-size') || '';
            if (pageSize !== '') {
                url.searchParams.set('order_page_size', pageSize);
            }
            var nextUrl = url.pathname + url.search + '#orders';
            history.replaceState({
                order_status: status || '',
                order_page: page
            }, '', nextUrl);
        }

        function readOrdersStateFromUrl() {
            var url = new URL(window.location.href);
            return {
                status: url.searchParams.get('order_status') || '',
                page: Math.max(1, parseInt(url.searchParams.get('order_page') || '1', 10) || 1)
            };
        }

        function loadOrdersFragment(status, page, options) {
            if (!bodyMount || fragmentLoading) {
                return Promise.resolve(false);
            }

            options = options || {};
            var requestId = ++fragmentRequestId;
            fragmentLoading = true;
            bodyMount.classList.add('is-loading');
            root.querySelectorAll('[data-order-status-filter]').forEach(function (button) {
                button.disabled = true;
            });

            return getOrderApi()
                .then(function (OrderApi) {
                    return OrderApi.accountListFragment({
                        order_status: status || '',
                        order_page: Math.max(1, page || 1),
                        order_page_size: parseInt(root.getAttribute('data-order-page-size') || '10', 10) || 10
                    });
                })
                .then(function (payload) {
                    if (!payload || requestId !== fragmentRequestId) {
                        return false;
                    }
                    if (payload.success === false) {
                        if (payload.redirect_url) {
                            window.location.href = payload.redirect_url;
                            return false;
                        }
                        throw new Error(payload.message || orderText.ordersFragmentFailed);
                    }
                    renderOrdersBody(bodyMount, payload);
                    renderUnpaidAlert(root, payload.unpaid_count);
                    executeInsertedScripts(bodyMount);
                    var nextStatus = payload.active_order_status || status || '';
                    var nextPage = payload.current_page || page || 1;
                    setActiveOrderFilter(nextStatus);
                    if (!options.skipUrlSync) {
                        syncOrdersUrlState(nextStatus, nextPage);
                    }
                    return true;
                })
                .catch(function (error) {
                    if (requestId === fragmentRequestId) {
                        notifyOrder(error && error.message ? error.message : orderText.ordersFragmentFailed, 'error', 3200);
                    }
                    return false;
                })
                .finally(function () {
                    if (requestId !== fragmentRequestId) {
                        return;
                    }
                    fragmentLoading = false;
                    bodyMount.classList.remove('is-loading');
                    root.querySelectorAll('[data-order-status-filter]').forEach(function (button) {
                        button.disabled = false;
                    });
                });
        }

        root.addEventListener('click', function (event) {
            var statusFilter = event.target.closest('[data-order-status-filter]');
            if (statusFilter && root.contains(statusFilter)) {
                event.preventDefault();
                var nextStatus = statusFilter.getAttribute('data-order-status') || '';
                if (nextStatus === getActiveOrderStatus()) {
                    return;
                }
                loadOrdersFragment(nextStatus, 1);
                return;
            }

            var pageButton = event.target.closest('[data-order-page]');
            if (pageButton && bodyMount && bodyMount.contains(pageButton)) {
                event.preventDefault();
                var targetPage = parseInt(pageButton.getAttribute('data-order-page') || '1', 10);
                if (!targetPage || targetPage < 1) {
                    return;
                }
                loadOrdersFragment(getActiveOrderStatus(), targetPage);
            }
        });

        window.addEventListener('popstate', function () {
            if (!window.location.hash || window.location.hash.indexOf('orders') === -1) {
                return;
            }
            var state = readOrdersStateFromUrl();
            loadOrdersFragment(state.status, state.page, { skipUrlSync: true }).then(function () {
                setActiveOrderFilter(state.status);
            });
        });

        function bootstrapOrdersData() {
            if (root.dataset.ordersBootstrapped === '1') {
                return;
            }
            root.dataset.ordersBootstrapped = '1';
            var state = readOrdersStateFromUrl();
            loadOrdersFragment(state.status, state.page);
        }

        window.addEventListener('weshop:orders-viewed', bootstrapOrdersData);
        if (root.dataset.ordersDeferred === '1') {
            bootstrapOrdersData();
        }
    }

    function initOrderInlineActions() {
        var root = document.getElementById('weshop-account-orders');
        if (!root) {
            return;
        }
        if (root.dataset.inlineActionsReady === '1') {
            return;
        }
        root.dataset.inlineActionsReady = '1';
        initOrderFragmentLoader();
        root.addEventListener('click', function (event) {
            var dismiss = event.target.closest('[data-order-notice-dismiss]');
            if (dismiss) {
                event.preventDefault();
                closeNotice(false);
            }
        });
        root.addEventListener('click', function (event) {
            var toggle = event.target.closest('[data-order-toggle]');
            if (toggle && root.contains(toggle)) {
                event.preventDefault();
                togglePanel(toggle);
                return;
            }
            var cancel = event.target.closest('[data-order-cancel]');
            if (cancel && root.contains(cancel)) {
                event.preventDefault();
                cancelOrder(cancel);
                return;
            }
            var close = event.target.closest('[data-order-close]');
            if (close && root.contains(close)) {
                event.preventDefault();
                closePanel(close);
            }
        });

        document.addEventListener('keydown', function (event) {
            var notice = document.querySelector('[data-order-notice]');
            if (!notice || notice.hidden || event.key !== 'Escape') return;
            event.preventDefault();
            closeNotice(false);
        });

        var notice = document.querySelector('[data-order-notice]');
        if (notice) {
            var cancel = notice.querySelector('[data-order-notice-cancel]');
            var confirm = notice.querySelector('[data-order-notice-confirm]');

            if (cancel) {
                cancel.addEventListener('click', function () {
                    closeNotice(false);
                });
            }

            if (confirm) {
                confirm.addEventListener('click', function () {
                    closeNotice(true);
                });
            }
        }
    }

    function bootstrapAccountOrders() {
        initOrderInlineActions();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootstrapAccountOrders);
    } else {
        bootstrapAccountOrders();
    }

    window.addEventListener('weline:account-sidebar-content-loaded', bootstrapAccountOrders);
})();
</script>
