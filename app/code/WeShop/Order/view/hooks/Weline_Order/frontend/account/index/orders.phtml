$GLOBALS['__weshop_order_account_orders_rendered'] = true;

use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;
use WeShop\Order\Service\OrderService;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

/** @var OrderService $orderService */
$orderService = ObjectManager::getInstance(OrderService::class);
$statusFilterOptions = $orderService->getAvailableStatuses();
$requestParams = $this->request->getParams();
$requestedOrderStatus = trim((string)($requestParams['order_status'] ?? ''));
$activeOrderStatus = $requestedOrderStatus !== '' && isset($statusFilterOptions[$requestedOrderStatus])
    ? $requestedOrderStatus
    : '';
$pageSize = min(50, max(10, (int)($requestParams['order_page_size'] ?? 10)));
$escape = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$orderJsText = [
    'noticeTitle' => __('订单通知'),
    'noticeSuccessTitle' => __('订单已更新'),
    'noticeWarningTitle' => __('请确认操作'),
    'noticeErrorTitle' => __('操作失败'),
    'confirmText' => __('知道了'),
    'cancelText' => __('取消'),
    'cancelOrderTitle' => __('取消订单'),
    'confirmCancelText' => __('确认取消'),
    'rethinkText' => __('再想想'),
    'cancellingOrder' => __('正在取消订单...'),
    'cancelOrderFailed' => __('取消订单失败'),
    'statusCancelled' => __('已取消'),
    'orderCancelled' => __('订单已取消。'),
    'ordersFragmentFailed' => __('订单列表加载失败，请稍后重试'),
    'ordersLoading' => __('订单加载中...'),
    'unpaidAlertTitle' => __('您有 %{1} 个订单待支付'),
    'unpaidAlertHint' => __('请及时完成支付，避免订单自动取消。支付流程会在当前个人中心页面打开。'),
];
?>

