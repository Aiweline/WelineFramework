    .weshop-order-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .weshop-action-link { background: transparent; border: 0; color: var(--weshop-primary); cursor: pointer; padding: 0; text-decoration: none; font-size: var(--weshop-font-size-sm); font-weight: var(--weshop-font-weight-medium); }
    .weshop-action-link:hover { color: var(--weshop-primary-hover); text-decoration: underline; }
    .weshop-action-button { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: var(--weshop-border-radius-lg); font-size: var(--weshop-font-size-sm); font-weight: var(--weshop-font-weight-medium); text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; }
    .weshop-retry-payment-button { background-color: var(--weshop-primary); color: white; }
    .weshop-retry-payment-button:hover { background-color: var(--weshop-primary-hover); transform: translateY(-1px); box-shadow: var(--weshop-shadow-md); }
    .weshop-cancel-button { background-color: transparent; color: var(--weshop-text-secondary); border: 1px solid var(--weshop-border); }
    .weshop-return-button { background-color: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3); }
    .weshop-cancel-disabled { display: inline-block; padding: 0.5rem 1rem; color: var(--weshop-text-secondary); font-size: var(--weshop-font-size-sm); cursor: not-allowed; opacity: 0.6; }
    .weshop-order-inline-message { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: var(--weshop-border-radius-lg); background: rgba(34, 197, 94, 0.12); color: #15803d; font-size: var(--weshop-font-size-sm); }
    .weshop-order-inline-message.is-error { background: rgba(239, 68, 68, 0.12); color: #b91c1c; }
    .weshop-order-panel { margin-top: 1rem; padding: 1rem; border: 1px solid var(--weshop-border); border-radius: var(--weshop-border-radius-lg); background: rgba(var(--weshop-background-rgb), 0.35); }
    .weshop-order-panel__header { display: flex; justify-content: space-between; gap: 1rem; align-items: center; margin-bottom: 1rem; }
    .weshop-order-panel__meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end; }
    .weshop-order-panel__close { border: 1px solid var(--weshop-border); background: var(--weshop-surface); color: var(--weshop-text-primary); border-radius: var(--weshop-border-radius-full); cursor: pointer; font-size: var(--weshop-font-size-xs); padding: 0.35rem 0.75rem; }
    .weshop-order-panel__header h3, .weshop-order-items-inline h4 { margin: 0; color: var(--weshop-text-primary); font-size: var(--weshop-font-size-base); }
    .weshop-order-detail-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; }
