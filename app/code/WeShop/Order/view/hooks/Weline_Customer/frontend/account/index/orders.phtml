<?php
/**
 * Account-center orders section embedded in Weline_Customer account index.
 *
 * Hook: Weline_Customer::frontend::account::index::orders
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;
use WeShop\Order\Model\Order;
use WeShop\Order\Model\OrderItem;
use WeShop\Order\Service\OrderService;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

/** @var OrderService $orderService */
$orderService = ObjectManager::getInstance(OrderService::class);
$customerId = (int)$customer->getId();
$currentPage = max(1, (int)($this->request->getParam('order_page') ?? 1));
$defaultPageSize = 10;
$maxPageSize = 50;
$requestedPageSize = (int)($this->request->getParam('order_page_size') ?? $defaultPageSize);
$pageSize = min($maxPageSize, max($defaultPageSize, $requestedPageSize));
$result = $orderService->getCustomerOrders($customerId, $currentPage, $pageSize);
$unpaidOrders = $orderService->getUnpaidOrders($customerId);
$orders = (array)($result['items'] ?? []);
$totalOrders = max(0, (int)($result['total'] ?? count($orders)));
$pagination = (array)($result['pagination'] ?? []);
$totalPages = max(1, (int)($pagination['total_pages'] ?? (int)ceil($totalOrders / $pageSize)));
if ($currentPage > $totalPages) {
    $currentPage = $totalPages;
    $result = $orderService->getCustomerOrders($customerId, $currentPage, $pageSize);
    $orders = (array)($result['items'] ?? []);
    $totalOrders = max(0, (int)($result['total'] ?? count($orders)));
    $pagination = (array)($result['pagination'] ?? []);
    $totalPages = max(1, (int)($pagination['total_pages'] ?? (int)ceil($totalOrders / $pageSize)));
}
$escape = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$buildPageUrl = static function (int $page) use ($pageSize): string {
    $query = http_build_query([
        'order_page' => max(1, $page),
        'order_page_size' => $pageSize,
    ]);

    return '/customer/account/index?' . $query . '#orders';
};
$buildReturnsUrl = static function (int $orderId, string $orderIncrementId, string $returnAnchor, int $orderPage, int $orderPageSize): string {
    $context = [
        'order_id' => $orderId,
    ];
    if ($orderIncrementId !== '') {
        $context['order_increment_id'] = $orderIncrementId;
    }

    if ($returnAnchor !== '') {
        $context['return_anchor'] = $returnAnchor;
    }

    $returnUrl = '/customer/account/index?' . http_build_query([
        'order_page' => max(1, $orderPage),
        'order_page_size' => max(1, $orderPageSize),
    ]) . '#orders';

    $context['return_url'] = $returnUrl;

    return '/customer/account/index?' . http_build_query($context) . '#returns';
};
$statusText = [
    OrderService::STATUS_PENDING => __('待处理'),
    OrderService::STATUS_PROCESSING => __('处理中'),
    OrderService::STATUS_PAID => __('已支付'),
    OrderService::STATUS_FULFILLED => __('已发货'),
    OrderService::STATUS_COMPLETED => __('已完成'),
    OrderService::STATUS_CANCELLED => __('已取消'),
    OrderService::STATUS_REFUNDED => __('已退款'),
];
?>

<div class="weshop-account-orders" id="weshop-account-orders">
    <?php if ($unpaidOrders !== []): ?>
        <div class="weshop-unpaid-orders-alert">
            <div class="weshop-alert-content">
                <i class="ri-error-warning-line weshop-alert-icon" aria-hidden="true"></i>
                <div class="weshop-alert-text">
                    <strong><?= __('您有 %{1} 个订单待支付', [count($unpaidOrders)]) ?></strong>
                    <p><?= __('请及时完成支付，避免订单自动取消。支付流程会在当前个人中心页面打开。') ?></p>
                </div>
            </div>
        </div>
    <?php endif; ?>

    <div class="weshop-orders-header">
        <h2 class="weshop-orders-title"><?= __('我的订单') ?></h2>
        <a href="/customer/account/index#orders" class="weshop-view-all-link" data-account-nav-link="true" data-section="orders">
            <?= __('查看全部') ?>
            <i class="ri-arrow-right-s-line weshop-view-all-icon" aria-hidden="true"></i>
        </a>
    </div>

    <div class="weshop-orders-list">
        <?php if ($orders === []): ?>
            <div class="weshop-empty-orders">
                <i class="ri-shopping-bag-line weshop-empty-orders-icon" aria-hidden="true"></i>
                <p><?= __('您还没有订单') ?></p>
                <a href="<?= $this->getUrl('weshop') ?>" class="weshop-shopping-button"><?= __('去购物') ?></a>
            </div>
        <?php else: ?>
            <?php foreach ($orders as $orderIndex => $order): ?>
                <?php
                $orderId = (int)($order['order_id'] ?? $order[Order::schema_fields_ID] ?? 0);
                $incrementId = (string)($order['increment_id'] ?? $order[Order::schema_fields_increment_id] ?? $orderId);
                $orderCardId = 'order-card-' . ($orderId > 0 ? $orderId : ((int)$orderIndex + 1));
                $status = (string)($order['status'] ?? $order[Order::schema_fields_status] ?? OrderService::STATUS_PENDING);
                $paymentStatus = (string)($order['payment_status'] ?? $order[Order::schema_fields_payment_status] ?? OrderService::PAYMENT_STATUS_PENDING);
                $total = (float)($order['total'] ?? $order[Order::schema_fields_total] ?? 0);
                $createdAt = (string)($order['created_at'] ?? $order[Order::schema_fields_created_at] ?? '');
                $paymentMethod = (string)($order['payment_method'] ?? $order[Order::schema_fields_payment_method] ?? '');
                $shippingMethod = (string)($order['shipping_method'] ?? $order[Order::schema_fields_shipping_method] ?? '');
                $fulfillmentStatus = (string)($order['fulfillment_status'] ?? $order[Order::schema_fields_fulfillment_status] ?? '');
                $statusLabel = $statusText[$status] ?? $status;
                $isUnpaid = in_array($paymentStatus, [OrderService::PAYMENT_STATUS_PENDING, OrderService::PAYMENT_STATUS_FAILED], true);
                $canRetryPayment = $orderId > 0 && $orderService->canRetryPayment($orderId, $customerId);
                $cancelCheck = $orderId > 0 ? $orderService->canCancelOrder($orderId, $customerId) : ['can_cancel' => false];
                $canCancel = !empty($cancelCheck['can_cancel']);
                $cancelReason = (string)($cancelCheck['reason'] ?? '');
                $requireReturn = !empty($cancelCheck['require_return']);
                $requireRefund = !empty($cancelCheck['require_refund']);
                $orderItems = $orderId > 0 ? $orderService->getOrderItems($orderId) : [];
                $visibleOrderItems = array_slice($orderItems, 0, 3);
                $remainingItemCount = max(0, count($orderItems) - count($visibleOrderItems));
                $checkoutUrl = $this->getUrl('checkout', ['order_id' => $orderId]);
                $createdLabel = $createdAt !== '' ? date('Y-m-d H:i', strtotime($createdAt)) : '-';
                $returnLink = $buildReturnsUrl($orderId, $incrementId, $orderCardId, $currentPage, $pageSize);
                $returnUrl = $buildPageUrl($currentPage);
                ?>
                <article class="weshop-order-item <?= $isUnpaid ? 'unpaid' : '' ?>" id="<?= $escape($orderCardId) ?>" data-order-card data-order-id="<?= $orderId ?>">
                    <div class="weshop-order-header">
                        <div class="weshop-order-info">
                            <span class="weshop-order-number"><?= __('订单号：%{1}', [$incrementId]) ?></span>
                            <span class="weshop-order-date"><?= $escape($createdLabel) ?></span>
                        </div>
                        <div class="weshop-order-status">
                            <span class="weshop-status-badge status-<?= $escape($status) ?>"><?= $statusLabel ?></span>
                            <?php if ($isUnpaid): ?>
                                <span class="weshop-payment-badge payment-failed"><?= __('待支付') ?></span>
                            <?php endif; ?>
                        </div>
                    </div>

                    <div class="weshop-order-content">
                        <div class="weshop-order-amount">
                            <span class="weshop-amount-label"><?= __('订单金额：') ?></span>
                            <span class="weshop-amount-value"><?= $this->formatPrice($total) ?></span>
                        </div>
                        <div class="weshop-order-products-summary">
                            <?php if ($visibleOrderItems === []): ?>
                                <span class="weshop-order-muted"><?= __('订单商品快照缺失，请重新导入订单数据') ?></span>
                            <?php else: ?>
                                <?php foreach ($visibleOrderItems as $summaryItem): ?>
                                    <?php
                                    $summaryName = (string)($summaryItem[OrderItem::schema_fields_PRODUCT_NAME] ?? $summaryItem['product_name'] ?? '');
                                    $summarySku = (string)($summaryItem[OrderItem::schema_fields_PRODUCT_SKU] ?? $summaryItem['product_sku'] ?? '');
                                    $summaryImage = (string)($summaryItem[OrderItem::schema_fields_PRODUCT_IMAGE] ?? $summaryItem['product_image'] ?? $summaryItem['image'] ?? '');
                                    $summaryQty = (int)($summaryItem[OrderItem::schema_fields_QUANTITY] ?? $summaryItem['quantity'] ?? 1);
                                    $summaryPrice = (float)($summaryItem[OrderItem::schema_fields_PRICE] ?? $summaryItem['price'] ?? 0);
                                    $summaryTotal = (float)($summaryItem[OrderItem::schema_fields_TOTAL] ?? $summaryItem['total'] ?? 0);
                                    ?>
                                    <div class="weshop-order-product-row">
                                        <div class="weshop-order-product-image">
                                            <?php if ($summaryImage !== ''): ?>
                                                <img src="<?= $escape($summaryImage) ?>" alt="<?= $escape($summaryName) ?>" loading="lazy">
                                            <?php else: ?>
                                                <i class="ri-image-line" aria-hidden="true"></i>
                                            <?php endif; ?>
                                        </div>
                                        <div class="weshop-order-product-main">
                                            <strong><?= $escape($summaryName !== '' ? $summaryName : '-') ?></strong>
                                            <?php if ($summarySku !== ''): ?><span>SKU: <?= $escape($summarySku) ?></span><?php endif; ?>
                                        </div>
                                        <span>x<?= $summaryQty ?></span>
                                        <span><?= $this->formatPrice($summaryPrice) ?></span>
                                        <strong><?= $this->formatPrice($summaryTotal) ?></strong>
                                    </div>
                                <?php endforeach; ?>
                                <?php if ($remainingItemCount > 0): ?>
                                    <button type="button" class="weshop-order-more-items" data-order-toggle="details"><?= __('还有 %{1} 件商品，查看详情', [$remainingItemCount]) ?></button>
                                <?php endif; ?>
                            <?php endif; ?>
                        </div>
                    </div>

                    <div class="weshop-order-actions">
                        <button type="button" class="weshop-action-link" data-order-toggle="details" aria-expanded="false"><?= __('查看详情') ?></button>

                        <?php if ($canRetryPayment): ?>
                            <button type="button" class="weshop-action-button weshop-retry-payment-button" data-order-toggle="payment" data-checkout-url="<?= $escape($checkoutUrl) ?>" aria-expanded="false">
                                <i class="ri-bank-card-line" aria-hidden="true"></i>
                                <?= __('继续支付') ?>
                            </button>
                        <?php endif; ?>

                        <?php if ($canCancel): ?>
                            <?php $cancelConfirmMessage = $requireRefund ? __('确定要取消此订单吗？取消后将自动退款。') : __('确定要取消此订单吗？'); ?>
                            <button type="button" class="weshop-action-button weshop-cancel-button" data-order-cancel data-confirm-message="<?= $escape($cancelConfirmMessage) ?>">
                                <i class="ri-close-circle-line" aria-hidden="true"></i>
                                <?= __('取消订单') ?>
                            </button>
                        <?php elseif ($requireReturn): ?>
                            <a href="<?= $escape($returnLink) ?>" class="weshop-action-button weshop-return-button js-account-rma-trigger" data-account-nav-link="true" data-section="returns" data-order-id="<?= (int)$orderId ?>" data-order-increment-id="<?= $escape($incrementId) ?>" data-return-anchor="<?= $escape($orderCardId) ?>" data-return-url="<?= $escape($returnUrl) ?>" title="<?= $escape($cancelReason) ?>">
                                <i class="ri-exchange-line" aria-hidden="true"></i>
                                <?= __('申请退货') ?>
                            </a>
                        <?php elseif ($cancelReason !== ''): ?>
                            <span class="weshop-cancel-disabled" title="<?= $escape($cancelReason) ?>"><?= __('不可取消') ?></span>
                        <?php endif; ?>
                    </div>

                    <div class="weshop-order-inline-message" data-order-message hidden></div>

                    <section class="weshop-order-panel" data-order-panel="details" hidden>
                        <div class="weshop-order-panel__header">
                            <h3><?= __('订单详情') ?></h3>
                            <div class="weshop-order-panel__meta">
                                <span><?= $escape($incrementId) ?></span>
                                <button type="button" class="weshop-order-panel__close" data-order-close><?= __('返回订单位置') ?></button>
                            </div>
                        </div>
                        <div class="weshop-order-detail-grid">
                            <div><span><?= __('订单状态') ?></span><strong><?= $statusLabel ?></strong></div>
                            <div><span><?= __('支付状态') ?></span><strong><?= $isUnpaid ? __('待支付') : $escape($paymentStatus) ?></strong></div>
                            <div><span><?= __('配送状态') ?></span><strong><?= $escape($fulfillmentStatus !== '' ? $fulfillmentStatus : '-') ?></strong></div>
                            <div><span><?= __('支付方式') ?></span><strong><?= $escape($paymentMethod !== '' ? $paymentMethod : '-') ?></strong></div>
                            <div><span><?= __('配送方式') ?></span><strong><?= $escape($shippingMethod !== '' ? $shippingMethod : '-') ?></strong></div>
                            <div><span><?= __('订单金额') ?></span><strong><?= $this->formatPrice($total) ?></strong></div>
                        </div>
                        <div class="weshop-order-items-inline">
                            <h4><?= __('订单商品') ?></h4>
                            <?php if ($orderItems === []): ?>
                                <p class="weshop-order-muted"><?= __('订单商品快照缺失，请重新导入订单数据') ?></p>
                            <?php else: ?>
                                <?php foreach ($orderItems as $item): ?>
                                    <?php
                                    $itemName = (string)($item[OrderItem::schema_fields_PRODUCT_NAME] ?? $item['product_name'] ?? '');
                                    $itemSku = (string)($item[OrderItem::schema_fields_PRODUCT_SKU] ?? $item['product_sku'] ?? '');
                                    $itemImage = (string)($item[OrderItem::schema_fields_PRODUCT_IMAGE] ?? $item['product_image'] ?? $item['image'] ?? '');
                                    $itemQty = (int)($item[OrderItem::schema_fields_QUANTITY] ?? $item['quantity'] ?? 1);
                                    $itemTotal = (float)($item[OrderItem::schema_fields_TOTAL] ?? $item['total'] ?? 0);
                                    ?>
                                    <div class="weshop-order-item-line">
                                        <div class="weshop-order-product-image">
                                            <?php if ($itemImage !== ''): ?>
                                                <img src="<?= $escape($itemImage) ?>" alt="<?= $escape($itemName) ?>" loading="lazy">
                                            <?php else: ?>
                                                <i class="ri-image-line" aria-hidden="true"></i>
                                            <?php endif; ?>
                                        </div>
                                        <div>
                                            <strong><?= $escape($itemName !== '' ? $itemName : '-') ?></strong>
                                            <span><?= $escape($itemSku) ?></span>
                                        </div>
                                        <div><?= __('x%{1}', [$itemQty]) ?></div>
                                        <div><?= $this->formatPrice($itemTotal) ?></div>
                                    </div>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </div>
                    </section>

                    <?php if ($canRetryPayment): ?>
                        <section class="weshop-order-panel weshop-order-payment-panel" data-order-panel="payment" hidden>
                            <div class="weshop-order-panel__header">
                                <h3><?= __('继续支付') ?></h3>
                                <span><?= __('订单号：%{1}', [$incrementId]) ?></span>
                            </div>
                            <p class="weshop-order-muted"><?= __('支付流程会嵌入当前个人中心页面，不再跳到独立订单页。') ?></p>
                            <iframe class="weshop-order-checkout-frame" title="<?= $escape(__('继续支付')) ?>" data-src="<?= $escape($checkoutUrl) ?>"></iframe>
                        </section>
                    <?php endif; ?>
                </article>
            <?php endforeach; ?>
        <?php endif; ?>
    </div>
    <?php if ($totalPages > 1): ?>
        <nav class="weshop-order-pagination" aria-label="Order pagination">
            <?php if ($currentPage > 1): ?>
                <a href="<?= $escape($buildPageUrl($currentPage - 1)) ?>">Prev</a>
            <?php else: ?>
                <span class="is-disabled">Prev</span>
            <?php endif; ?>

            <?php for ($page = 1; $page <= $totalPages; $page++): ?>
                <?php if ($page === $currentPage): ?>
                    <span class="is-active"><?= $page ?></span>
                <?php else: ?>
                    <a href="<?= $escape($buildPageUrl($page)) ?>"><?= $page ?></a>
                <?php endif; ?>
            <?php endfor; ?>

            <?php if ($currentPage < $totalPages): ?>
                <a href="<?= $escape($buildPageUrl($currentPage + 1)) ?>">Next</a>
            <?php else: ?>
                <span class="is-disabled">Next</span>
            <?php endif; ?>
        </nav>
    <?php endif; ?>
</div>

