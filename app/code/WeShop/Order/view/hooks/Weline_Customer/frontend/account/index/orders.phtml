    .weshop-empty-orders-icon { display: inline-block; font-size: 3rem; line-height: 1; color: var(--weshop-text-secondary); }
    .weshop-empty-orders p { color: var(--weshop-text-secondary); margin: 1rem 0; }
    .weshop-shopping-button { display: inline-block; padding: 0.75rem 2rem; background-color: var(--weshop-primary); color: white; text-decoration: none; border-radius: var(--weshop-border-radius-lg); font-weight: var(--weshop-font-weight-medium); }
