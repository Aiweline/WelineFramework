<?php
/**
 * 账户首页「我的订单」分区（嵌入 Weline_Customer account/index.phtml 的 orders-section）
 *
 * Hook：Weline_Customer::frontend::account::index::orders
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\Session\SessionFactory;
use WeShop\Order\Service\OrderService;
use Weline\Framework\Manager\ObjectManager;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

/** @var OrderService $orderService */
$orderService = ObjectManager::getInstance(OrderService::class);

// 获取订单列表（最近10条）
$result = $orderService->getCustomerOrders($customer->getId(), 1, 10);

// 获取未支付订单
$unpaidOrders = $orderService->getUnpaidOrders($customer->getId());
?>

<!-- 订单列表区域 -->
<div class="weshop-account-orders" id="weshop-account-orders">
    
    <!-- 未支付订单提示 -->
    <?php if (!empty($unpaidOrders)): ?>
        <div class="weshop-unpaid-orders-alert">
            <div class="weshop-alert-content">
                <i class="ri-error-warning-line weshop-alert-icon" aria-hidden="true"></i>
                <div class="weshop-alert-text">
                    <strong><?= __('您有 %1 个订单待支付', count($unpaidOrders)) ?></strong>
                    <p><?= __('请及时完成支付，避免订单自动取消') ?></p>
                </div>
            </div>
        </div>
    <?php endif; ?>
    
    <!-- 订单列表标题 -->
    <div class="weshop-orders-header">
        <h2 class="weshop-orders-title"><?= __('我的订单') ?></h2>
        <a href="/customer/account/index#orders" class="weshop-view-all-link" data-account-nav-link="true" data-section="orders">
            <?= __('查看全部') ?>
            <i class="ri-arrow-right-s-line weshop-view-all-icon" aria-hidden="true"></i>
        </a>
    </div>
    
    <!-- 订单列表 -->
    <div class="weshop-orders-list">
        <?php if (empty($result['items'])): ?>
            <div class="weshop-empty-orders">
                <i class="ri-shopping-bag-line weshop-empty-orders-icon" aria-hidden="true"></i>
                <p><?= __('您还没有订单') ?></p>
                <a href="<?= $this->getUrl('weshop') ?>" class="weshop-shopping-button">
                    <?= __('去购物') ?>
                </a>
            </div>
        <?php else: ?>
            <?php foreach ($result['items'] as $order): ?>
                <?php
                $orderId = $order['order_id'] ?? $order[\WeShop\Order\Model\Order::schema_fields_ID] ?? 0;
                $incrementId = $order['increment_id'] ?? $order[\WeShop\Order\Model\Order::schema_fields_increment_id] ?? '';
                $status = $order['status'] ?? $order[\WeShop\Order\Model\Order::schema_fields_status] ?? 'pending';
                $paymentStatus = $order['payment_status'] ?? \WeShop\Order\Service\OrderService::PAYMENT_STATUS_PENDING;
                $total = $order['total'] ?? $order[\WeShop\Order\Model\Order::schema_fields_total] ?? 0;
                $createdAt = $order['created_at'] ?? $order[\WeShop\Order\Model\Order::schema_fields_created_at] ?? '';
                
                // 判断是否可以继续支付
                $canRetryPayment = $orderService->canRetryPayment($orderId, $customer->getId());
                
                // 判断是否可以取消（使用新的检查方法）
                $cancelCheck = $orderService->canCancelOrder($orderId, $customer->getId());
                $canCancel = $cancelCheck['can_cancel'];
                $cancelReason = $cancelCheck['reason'] ?? null;
                $requireReturn = $cancelCheck['require_return'] ?? false;
                $requireRefund = $cancelCheck['require_refund'] ?? false;
                
                // 状态显示文本
                $statusText = [
                    \WeShop\Order\Service\OrderService::STATUS_PENDING => __('待处理'),
                    \WeShop\Order\Service\OrderService::STATUS_PROCESSING => __('处理中'),
                    \WeShop\Order\Service\OrderService::STATUS_PAID => __('已支付'),
                    \WeShop\Order\Service\OrderService::STATUS_FULFILLED => __('已发货'),
                    \WeShop\Order\Service\OrderService::STATUS_COMPLETED => __('已完成'),
                    \WeShop\Order\Service\OrderService::STATUS_CANCELLED => __('已取消'),
                    \WeShop\Order\Service\OrderService::STATUS_REFUNDED => __('已退款'),
                ];
                
                $statusLabel = $statusText[$status] ?? $status;
                
                // 支付状态显示
                $isUnpaid = in_array($paymentStatus, [
                    \WeShop\Order\Service\OrderService::PAYMENT_STATUS_PENDING,
                    \WeShop\Order\Service\OrderService::PAYMENT_STATUS_FAILED
                ]);
                ?>
                
                <div class="weshop-order-item <?= $isUnpaid ? 'unpaid' : '' ?>">
                    <div class="weshop-order-header">
                        <div class="weshop-order-info">
                            <span class="weshop-order-number">
                                <?= __('订单号：%1', $incrementId) ?>
                            </span>
                            <span class="weshop-order-date">
                                <?= date('Y-m-d H:i', strtotime($createdAt)) ?>
                            </span>
                        </div>
                        <div class="weshop-order-status">
                            <span class="weshop-status-badge status-<?= $status ?>">
                                <?= $statusLabel ?>
                            </span>
                            <?php if ($isUnpaid): ?>
                                <span class="weshop-payment-badge payment-failed">
                                    <?= __('待支付') ?>
                                </span>
                            <?php endif; ?>
                        </div>
                    </div>
                    
                    <div class="weshop-order-content">
                        <div class="weshop-order-amount">
                            <span class="weshop-amount-label"><?= __('订单金额：') ?></span>
                            <span class="weshop-amount-value"><?= $this->formatPrice($total) ?></span>
                        </div>
                    </div>
                    
                    <div class="weshop-order-actions">
                        <a href="<?= $this->getUrl('weshop/order/view', ['id' => $orderId]) ?>" class="weshop-action-link">
                            <?= __('查看详情') ?>
                        </a>
                        
                        <?php if ($canRetryPayment): ?>
                            <a href="<?= $this->getUrl('weshop/order/retry-payment', ['order_id' => $orderId]) ?>" class="weshop-action-button weshop-retry-payment-button">
                                <i class="ri-bank-card-line" style="font-size: 1rem;" aria-hidden="true"></i>
                                <?= __('继续支付') ?>
                            </a>
                        <?php endif; ?>
                        
                        <?php if ($canCancel): ?>
                            <?php
                                $cancelConfirmMessage = $requireRefund
                                    ? __('确定要取消此订单吗？取消后将自动退款。')
                                    : __('确定要取消此订单吗？');
                            ?>
                            <form
                                method="POST"
                                action="<?= $this->getUrl('weshop/order/cancel') ?>"
                                class="weshop-cancel-form"
                                data-weshop-confirm-message="<?= htmlspecialchars($cancelConfirmMessage, ENT_QUOTES, 'UTF-8') ?>"
                            >
                                <input type="hidden" name="order_id" value="<?= $orderId ?>">
                                <button type="submit" class="weshop-action-button weshop-cancel-button">
                                    <i class="ri-close-circle-line" style="font-size: 1rem;" aria-hidden="true"></i>
                                    <?= __('取消订单') ?>
                                </button>
                            </form>
                        <?php elseif ($requireReturn): ?>
                            <a href="<?= $this->getUrl('rma/create', ['order_id' => $orderId]) ?>" class="weshop-action-button weshop-return-button" title="<?= htmlspecialchars($cancelReason ?? '') ?>">
                                <i class="ri-exchange-line" style="font-size: 1rem;" aria-hidden="true"></i>
                                <?= __('申请退货') ?>
                            </a>
                        <?php elseif ($cancelReason): ?>
                            <span class="weshop-cancel-disabled" title="<?= htmlspecialchars($cancelReason) ?>">
                                <?= __('不可取消') ?>
                            </span>
                        <?php endif; ?>
                    </div>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>
