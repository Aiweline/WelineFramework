    .weshop-order-item-line > div:nth-child(2) { display: flex; flex-direction: column; gap: 0.25rem; }
    .weshop-order-checkout-frame { width: 100%; min-height: 760px; border: 1px solid var(--weshop-border); border-radius: var(--weshop-border-radius-lg); background: #fff; }
