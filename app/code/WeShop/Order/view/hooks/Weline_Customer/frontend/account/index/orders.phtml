<script>
(function () {
    function initCancelOrderConfirm() {
        var forms = document.querySelectorAll('form.weshop-cancel-form[data-weshop-confirm-message]');
        if (!forms || !forms.length) return;

        forms.forEach(function (form) {
            form.addEventListener('submit', function (e) {
                // 避免在已确认并通过 submit() 再次触发这里
                if (form.dataset && form.dataset.weshopConfirmHandled === '1') {
                    return;
                }

                var msg = form.getAttribute('data-weshop-confirm-message') || '';
                e.preventDefault();

                if (typeof BackendConfirm !== 'undefined' && typeof BackendConfirm.show === 'function') {
                    BackendConfirm.show(msg, { type: 'warning' }).then(function (confirmed) {
                        if (!confirmed) return;
                        if (form.dataset) form.dataset.weshopConfirmHandled = '1';
                        form.submit();
                    });
                } else {
                    // 如果确认组件不可用，直接提交以避免阻塞用户取消订单。
                    if (form.dataset) form.dataset.weshopConfirmHandled = '1';
                    form.submit();
                }
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCancelOrderConfirm);
    } else {
        initCancelOrderConfirm();
    }
})();
</script>
