<?php
/**
 * WeShop Order hook for account center cards host:
 * WeShop_Customer::frontend::account::orders::cards
 *
 * @hook-priority 200
 * @hook-sort-order 20
 * @hook-solo false
 */

use Weline\Framework\Session\SessionFactory;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

$dashboard = w_query('order', 'getCustomerDashboardOrders', [
    'customer_id' => (int) $customer->getId(),
    'page' => 1,
    'page_size' => 3,
]);
$dashboard = is_array($dashboard) ? $dashboard : [];
$recentOrders = (array) ($dashboard['recent_orders'] ?? []);
$orderCount = (int) ($dashboard['order_count'] ?? count($recentOrders));
$unpaidCount = (int) ($dashboard['unpaid_count'] ?? 0);
?>

<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Order Snapshot') ?></p>
            <h3 class="mt-2 text-2xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Recent Orders') ?></h3>
        </div>
        <a href="<?= $this->getUrl('weshop/order/list') ?>" class="text-sm font-semibold text-primary hover:underline" data-account-nav-link="true" data-section="orders"><?= __('View All') ?></a>
    </div>

    <div class="mt-5 grid grid-cols-2 gap-3">
        <div class="rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-text-secondary-light dark:text-text-secondary-dark"><?= __('Total') ?></p>
            <p class="mt-2 text-2xl font-black text-text-primary-light dark:text-text-primary-dark"><?= $orderCount ?></p>
        </div>
        <div class="rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-text-secondary-light dark:text-text-secondary-dark"><?= __('Unpaid') ?></p>
            <p class="mt-2 text-2xl font-black text-text-primary-light dark:text-text-primary-dark"><?= $unpaidCount ?></p>
        </div>
    </div>

    <?php if ($recentOrders !== []): ?>
        <div class="mt-5 space-y-3">
            <?php foreach ($recentOrders as $order): ?>
                <?php
                $orderId = (int) ($order['order_id'] ?? 0);
                $incrementId = trim((string) ($order['increment_id'] ?? ''));
                $status = trim((string) ($order['status'] ?? 'pending'));
                ?>
                <a href="<?= $this->getUrl('weshop/order/view', ['id' => $orderId]) ?>" class="block rounded-2xl border border-border-light bg-background-light p-4 transition hover:border-primary hover:shadow-sm dark:border-border-dark dark:bg-background-dark">
                    <div class="flex items-center justify-between gap-3">
                        <span class="font-semibold text-text-primary-light dark:text-text-primary-dark">#<?= htmlspecialchars($incrementId !== '' ? $incrementId : (string) $orderId, ENT_QUOTES) ?></span>
                        <span class="text-xs font-semibold uppercase tracking-[0.1em] text-text-secondary-light dark:text-text-secondary-dark"><?= htmlspecialchars($status, ENT_QUOTES) ?></span>
                    </div>
                    <p class="mt-1 text-sm text-text-secondary-light dark:text-text-secondary-dark">
                        <?= __('Total') ?>: <?= $this->formatPrice((float) ($order['total'] ?? 0)) ?>
                    </p>
                </a>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="mt-5 rounded-2xl border border-dashed border-border-light bg-background-light px-4 py-5 text-sm text-text-secondary-light dark:border-border-dark dark:bg-background-dark dark:text-text-secondary-dark">
            <?= __('No orders yet. Place your first order to see activity here.') ?>
        </div>
    <?php endif; ?>
</article>
