<div class="modal fade" id="order-detail-confirm-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><lang>确认</lang></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="order-detail-confirm-modal-message"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><lang>取消</lang></button>
                <button type="button" class="btn btn-danger" id="order-detail-confirm-modal-ok"><lang>确认</lang></button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var modalEl = document.getElementById('order-detail-confirm-modal');
    var modal = modalEl ? new bootstrap.Modal(modalEl) : null;
    var okBtn = document.getElementById('order-detail-confirm-modal-ok');
    var currentForm = null;

    if (okBtn && modal) {
        okBtn.addEventListener('click', function() {
            if (!currentForm) return;
            modal.hide();
            currentForm.submit();
        });
    }

    document.querySelectorAll('.order-detail__cancel-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            var confirmMsg = e.submitter ? e.submitter.dataset.confirm : '<?= htmlspecialchars((string) __('Cancel this order?'), ENT_QUOTES) ?>';
            if (!modal) return;
            e.preventDefault();
            currentForm = form;
            var msgEl = document.getElementById('order-detail-confirm-modal-message');
            if (msgEl) {
                msgEl.textContent = confirmMsg;
            }
            modal.show();
        });
    });
})();
</script>
