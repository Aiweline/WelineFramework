<!-- 原生确认对话框（无 Bootstrap 依赖） -->
<div class="order-detail__confirm-overlay" id="od-confirm-overlay" role="dialog" aria-modal="true"
     aria-labelledby="od-confirm-title">
    <div class="order-detail__confirm-box">
        <h5 class="order-detail__confirm-title" id="od-confirm-title"><?= __('确认') ?></h5>
        <p class="order-detail__confirm-message" id="od-confirm-message"></p>
        <div class="order-detail__confirm-actions">
            <button type="button" class="order-detail__btn order-detail__btn--secondary" id="od-confirm-cancel">
                <?= __('取消') ?>
            </button>
            <button type="button" class="order-detail__btn order-detail__btn--danger" id="od-confirm-ok">
                <?= __('确认') ?>
            </button>
        </div>
    </div>
</div>

<script>
(function() {
    var overlay = document.getElementById('od-confirm-overlay');
    var msgEl = document.getElementById('od-confirm-message');
    var okBtn = document.getElementById('od-confirm-ok');
    var cancelBtn = document.getElementById('od-confirm-cancel');
    var currentForm = null;

    function openConfirm(message, form) {
        if (!overlay) return false;
        currentForm = form;
        if (msgEl) msgEl.textContent = message;
        overlay.classList.add('is-open');
        if (okBtn) okBtn.focus();
        return true;
    }

    function closeConfirm() {
        if (overlay) overlay.classList.remove('is-open');
        currentForm = null;
    }

    if (okBtn) {
        okBtn.addEventListener('click', function() {
            if (!currentForm) return;
            closeConfirm();
            currentForm.submit();
        });
    }

    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeConfirm);
    }

    if (overlay) {
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeConfirm();
        });
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeConfirm();
    });

    document.querySelectorAll('.order-detail__cancel-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            var confirmMsg = (e.submitter && e.submitter.dataset.confirm)
                ? e.submitter.dataset.confirm
                : '<?= $escape((string) __('确定要取消此订单吗？此操作不可恢复。')) ?>';
            e.preventDefault();
            openConfirm(confirmMsg, form);
        });
    });
})();
</script>
