<?php
/**
 * WeShop Order storefront list template.
 */
$orders = (array) ($this->getData('orders') ?? []);
$orderCount = (int) ($this->getData('order_count') ?? count($orders));
$unpaidCount = (int) ($this->getData('unpaid_count') ?? 0);
$pagination = (array) ($this->getData('pagination') ?? []);
$currentPage = max(1, (int) ($pagination['current_page'] ?? $pagination['page'] ?? 1));
$pageSize = max(1, (int) ($pagination['page_size'] ?? $pagination['per_page'] ?? $this->getData('page_size') ?? 20));
$totalPages = max(1, (int) ($pagination['total_pages'] ?? $pagination['last_page'] ?? $this->getData('page_count') ?? 1));

$buildPaginationUrl = function (int $targetPage) use ($pageSize): string {
    return (string) $this->getUrl('weshop/order/list', [
        'page' => max(1, $targetPage),
        'page_size' => $pageSize,
    ]);
};
?>
<section class="order-list">
    <w:hook name="WeShop_Order::frontend::pages::order::list-before"/>

    <header class="order-list__header">
        <div class="order-list__header-content">
            <p class="order-list__subtitle"><?= __('Order Center') ?></p>
            <h1 class="order-list__title"><?= __('My Orders') ?></h1>
            <p class="order-list__desc">
                <?= __('Track your purchases, complete unpaid orders, and review delivery progress in one place.') ?>
            </p>
            <div class="order-list__actions">
                <a href="<?= $this->getUrl('weshop') ?>" class="order-list__btn order-list__btn--primary">
                    <?= __('Continue Shopping') ?>
                </a>
                <a href="<?= $this->getUrl('weshop/customer/account/index') ?>" class="order-list__btn order-list__btn--secondary">
                    <?= __('Back to Account') ?>
                </a>
            </div>
        </div>

        <div class="order-list__stats">
            <article class="order-list__stat-card">
                <p class="order-list__stat-label"><?= __('Total Orders') ?></p>
                <p class="order-list__stat-value"><?= $orderCount ?></p>
            </article>
            <article class="order-list__stat-card order-list__stat-card--highlight">
                <p class="order-list__stat-label"><?= __('Awaiting Payment') ?></p>
                <p class="order-list__stat-value"><?= $unpaidCount ?></p>
            </article>
        </div>
    </header>

    <?php if ($orders === []): ?>
        <section class="order-list__empty">
            <span class="material-symbols-outlined order-list__empty-icon">package_2</span>
            <h2 class="order-list__empty-title"><?= __('No orders yet') ?></h2>
            <p class="order-list__empty-text">
                <?= __('Your order history will appear here after you place your first purchase.') ?>
            </p>
            <a href="<?= $this->getUrl('weshop') ?>" class="order-list__btn order-list__btn--primary">
                <?= __('Browse Products') ?>
            </a>
        </section>
    <?php else: ?>
        <section class="order-list__items">
            <?php foreach ($orders as $order): ?>
                <?php
                $orderId = (int) ($order['order_id'] ?? 0);
                $incrementId = trim((string) ($order['increment_id'] ?? ''));
                $statusLabel = trim((string) ($order['status_label'] ?? ucfirst((string) ($order['status'] ?? 'pending'))));
                $paymentStatusLabel = trim((string) ($order['payment_status_label'] ?? ucfirst((string) ($order['payment_status'] ?? 'pending'))));
                $createdAt = trim((string) ($order['created_at'] ?? ''));
                $canRetry = !empty($order['can_retry_payment']);
                $canCancel = !empty($order['can_cancel']);
                $requireReturn = !empty($order['require_return']);
                $cancelReason = trim((string) ($order['cancel_reason'] ?? ''));
                $requiresPayment = in_array(strtolower((string) ($order['payment_status'] ?? 'pending')), ['pending', 'failed'], true);
                ?>
                <article class="order-card">
                    <div class="order-card__header">
                        <div class="order-card__info">
                            <p class="order-card__label"><?= __('Order') ?></p>
                            <h2 class="order-card__id">#<?= htmlspecialchars($incrementId !== '' ? $incrementId : (string) $orderId, ENT_QUOTES) ?></h2>
                            <?php if ($createdAt !== ''): ?>
                                <p class="order-card__date"><?= htmlspecialchars($createdAt, ENT_QUOTES) ?></p>
                            <?php endif; ?>
                        </div>

                        <div class="order-card__badges">
                            <span class="order-card__badge order-card__badge--status">
                                <?= htmlspecialchars($statusLabel, ENT_QUOTES) ?>
                            </span>
                            <span class="order-card__badge order-card__badge--payment <?= $requiresPayment ? 'order-card__badge--pending' : 'order-card__badge--paid' ?>">
                                <?= htmlspecialchars($paymentStatusLabel, ENT_QUOTES) ?>
                            </span>
                        </div>
                    </div>

                    <div class="order-card__footer">
                        <p class="order-card__total">
                            <?= __('Grand Total') ?>:
                            <span class="order-card__price">
                                <?= $this->formatPrice((float) ($order['total'] ?? 0)) ?>
                            </span>
                        </p>

                        <div class="order-card__actions">
                            <a href="<?= $this->getUrl('weshop/order/view', ['id' => $orderId]) ?>" class="order-card__btn order-card__btn--secondary">
                                <?= __('View Details') ?>
                            </a>

                            <?php if ($canRetry): ?>
                                <a href="<?= $this->getUrl('weshop/order/retry-payment', ['order_id' => $orderId]) ?>" class="order-card__btn order-card__btn--primary">
                                    <?= __('Pay Now') ?>
                                </a>
                            <?php endif; ?>

                            <?php if ($canCancel): ?>
                                <form class="order-card__form" method="post" action="<?= $this->getUrl('weshop/order/cancel') ?>">
                                    <?= $this->getFormKey($this->getUrl('weshop/order/cancel')) ?>
                                    <input type="hidden" name="order_id" value="<?= $orderId ?>">
                                    <button type="submit" class="order-card__btn order-card__btn--danger" data-confirm="<?= htmlspecialchars((string) __('Cancel this order?'), ENT_QUOTES) ?>">
                                        <?= __('Cancel Order') ?>
                                    </button>
                                </form>
                            <?php elseif ($requireReturn): ?>
                                <a href="<?= $this->getUrl('rma/create', ['order_id' => $orderId]) ?>" class="order-card__btn order-card__btn--secondary" title="<?= htmlspecialchars($cancelReason, ENT_QUOTES) ?>">
                                    <?= __('Request Return') ?>
                                </a>
                            <?php elseif ($cancelReason !== ''): ?>
                                <span class="order-card__badge order-card__badge--disabled" title="<?= htmlspecialchars($cancelReason, ENT_QUOTES) ?>">
                                    <?= __('Not Cancellable') ?>
                                </span>
                            <?php endif; ?>
                        </div>
                    </div>
                </article>
            <?php endforeach; ?>
        </section>
    <?php endif; ?>

    <?php if ($totalPages > 1): ?>
        <nav class="order-list__pagination">
            <?php for ($page = 1; $page <= $totalPages; $page++): ?>
                <?php if ($page === $currentPage): ?>
                    <span class="order-list__page order-list__page--active"><?= $page ?></span>
                <?php else: ?>
                    <a href="<?= htmlspecialchars($buildPaginationUrl($page), ENT_QUOTES) ?>" class="order-list__page">
                        <?= $page ?>
                    </a>
                <?php endif; ?>
            <?php endfor; ?>
        </nav>
    <?php endif; ?>

    <w:hook name="WeShop_Order::frontend::pages::order::list-after"/>
</section>

