<?php
/**
 * WeShop Order storefront list template.
 */
$orders = (array) ($this->getData('orders') ?? []);
$orderCount = (int) ($this->getData('order_count') ?? count($orders));
$unpaidCount = (int) ($this->getData('unpaid_count') ?? 0);
$pagination = (array) ($this->getData('pagination') ?? []);
$currentPage = max(1, (int) ($pagination['current_page'] ?? $pagination['page'] ?? 1));
$pageSize = max(1, (int) ($pagination['page_size'] ?? $pagination['per_page'] ?? $this->getData('page_size') ?? 20));
$totalPages = max(1, (int) ($pagination['total_pages'] ?? $pagination['last_page'] ?? $this->getData('page_count') ?? 1));

$buildPaginationUrl = function (int $targetPage) use ($pageSize): string {
    return (string) $this->getUrl('weshop/order/list', [
        'page' => max(1, $targetPage),
        'page_size' => $pageSize,
    ]);
};
?>
<main class="mx-auto flex w-full max-w-7xl flex-1 flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <w:hook name="WeShop_Order::frontend::pages::order::list-before"/>

    <section class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark">
        <div class="grid gap-0 lg:grid-cols-[1.2fr_0.8fr]">
            <div class="bg-gradient-to-br from-primary/10 via-primary/5 to-transparent p-8 sm:p-10">
                <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary"><?= __('Order Center') ?></p>
                <h1 class="mt-4 text-3xl font-black tracking-tight text-text-primary-light dark:text-text-primary-dark sm:text-4xl"><?= __('My Orders') ?></h1>
                <p class="mt-3 max-w-2xl text-base leading-7 text-text-secondary-light dark:text-text-secondary-dark">
                    <?= __('Track your purchases, complete unpaid orders, and review delivery progress in one place.') ?>
                </p>
                <div class="mt-8 flex flex-wrap gap-3 text-sm">
