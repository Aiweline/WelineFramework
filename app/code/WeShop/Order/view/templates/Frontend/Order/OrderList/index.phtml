<!-- 原生确认对话框 -->
<div class="order-list__confirm-overlay" id="ol-confirm-overlay" role="dialog" aria-modal="true"
     aria-labelledby="ol-confirm-title">
    <div class="order-list__confirm-box">
        <h5 class="order-list__confirm-title" id="ol-confirm-title"><?= __('确认') ?></h5>
        <p class="order-list__confirm-message" id="ol-confirm-message"></p>
        <div class="order-list__confirm-actions">
            <button type="button" class="order-card__btn order-card__btn--secondary" id="ol-confirm-cancel">
                <?= __('取消') ?>
            </button>
            <button type="button" class="order-card__btn order-card__btn--danger" id="ol-confirm-ok">
                <?= __('确认') ?>
            </button>
        </div>
    </div>
</div>

<script>
(function() {
    var overlay = document.getElementById('ol-confirm-overlay');
    var msgEl = document.getElementById('ol-confirm-message');
    var okBtn = document.getElementById('ol-confirm-ok');
    var cancelBtn = document.getElementById('ol-confirm-cancel');
    var currentForm = null;

    function openConfirm(message, form) {
        if (!overlay) return false;
        currentForm = form;
        if (msgEl) msgEl.textContent = message;
        overlay.classList.add('is-open');
        if (okBtn) okBtn.focus();
        return true;
    }

    function closeConfirm() {
        if (overlay) overlay.classList.remove('is-open');
        currentForm = null;
    }

    if (okBtn) {
        okBtn.addEventListener('click', function() {
            if (!currentForm) return;
            closeConfirm();
            currentForm.submit();
        });
    }

    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeConfirm);
    }

    if (overlay) {
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeConfirm();
        });
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeConfirm();
    });

    document.querySelectorAll('.order-card__form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            var confirmMsg = (e.submitter && e.submitter.dataset.confirm)
                ? e.submitter.dataset.confirm
                : '<?= $escape((string) __('确定要取消此订单吗？取消后将自动退款。')) ?>';
            e.preventDefault();
            openConfirm(confirmMsg, form);
        });
    });
})();
</script>
