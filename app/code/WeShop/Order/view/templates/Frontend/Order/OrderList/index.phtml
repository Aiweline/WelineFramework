$orders = (array) ($this->getData('orders') ?? []);
$orderCount = (int) ($this->getData('order_count') ?? count($orders));
$unpaidCount = (int) ($this->getData('unpaid_count') ?? 0);
$pagination = (array) ($this->getData('pagination') ?? []);
$currentPage = max(1, (int) ($pagination['current_page'] ?? $pagination['page'] ?? 1));
$pageSize = max(1, (int) ($pagination['page_size'] ?? $pagination['per_page'] ?? $this->getData('page_size') ?? 20));
$totalPages = max(1, (int) ($pagination['total_pages'] ?? $pagination['last_page'] ?? $this->getData('page_count') ?? 1));
$escape = static fn(mixed $value): string => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$formatPrice = static function (float $amount): string {
    return \Weline\Currency\Helper\CurrencyFormatter::formatConverted($amount);
};

$buildPaginationUrl = function (int $targetPage) use ($pageSize): string {
    return (string) $this->getUrl('weshop/order/list', [
        'page' => max(1, $targetPage),
        'page_size' => $pageSize,
    ]);
};
