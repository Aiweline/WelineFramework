<js:part name="w-delete"/>

<script>
(function() {
    'use strict';

    var WeShopOrderDetail = {
        updateStatusUrl: '<?= $updateStatusUrl ?>',
        orderId: <?= $orderId ?>,

        init: function() {
            var self = this;

            // Handle status update offcanvas
            var offcanvasEl = document.getElementById('orderStatusOffcanvas');
            if (offcanvasEl) {
                offcanvasEl.addEventListener('show.bs.offcanvas', function(event) {
                    var form = offcanvasEl.querySelector('form');
                    if (form) {
                        // Add hidden order_id field if not exists
                        var orderIdInput = form.querySelector('input[name="id"]');
                        if (!orderIdInput) {
                            orderIdInput = document.createElement('input');
                            orderIdInput.type = 'hidden';
                            orderIdInput.name = 'id';
                            orderIdInput.value = self.orderId;
                            form.appendChild(orderIdInput);
                        } else {
                            orderIdInput.value = self.orderId;
                        }

                        // Add redirect back URL
                        var redirectInput = form.querySelector('input[name="back_url"]');
                        if (!redirectInput) {
                            redirectInput = document.createElement('input');
                            redirectInput.type = 'hidden';
                            redirectInput.name = 'back_url';
                            form.appendChild(redirectInput);
                        }
                        // Keep redirect as relative path to pass backend safe URL checks.
                        redirectInput.value = window.location.pathname + window.location.search + window.location.hash;
                    }
                });
            }
        }
    };

    window.WeShopOrderDetail = WeShopOrderDetail;

    document.addEventListener('DOMContentLoaded', function() {
        WeShopOrderDetail.init();
    });
})();
</script>
