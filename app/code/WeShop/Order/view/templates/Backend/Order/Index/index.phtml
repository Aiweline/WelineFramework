       close-button-text='@lang(关闭)'
       direction='right'
       class-names='w-50'
       off-canvas-body-style=''/>

<js:part name="w-delete"/>

<script>
(function() {
    'use strict';

    var WeShopOrder = {
        backendUrl: '<?= $orderIndexUrl ?>',
        statusUpdateUrl: '<?= $this->getBackendUrl('*/backend/order/update-status') ?>',
        viewUrl: '<?= $this->getBackendUrl('*/backend/order/view') ?>',

        openStatusUpdate: function(orderId, currentStatus) {
            var offcanvasEl = document.getElementById('orderStatusOffcanvas');
            if (!offcanvasEl) return;

            offcanvasEl.dataset.orderId = String(orderId || 0);

            var triggerBtn = offcanvasEl.querySelector('[data-bs-target]') || offcanvasEl.querySelector('.btn');
            if (triggerBtn) {
                var bsOffcanvas = new bootstrap.Offcanvas(offcanvasEl);
                bsOffcanvas.show();
            }
        },

        init: function() {
            var self = this;

            // Initialize offcanvas for status updates
            var offcanvasEl = document.getElementById('orderStatusOffcanvas');
            if (offcanvasEl) {
                offcanvasEl.addEventListener('show.bs.offcanvas', function(event) {
                    var relatedTarget = event.relatedTarget;
                    var orderId = relatedTarget ? relatedTarget.dataset.orderId : offcanvasEl.dataset.orderId;

                    // Update form action if needed
                    var form = offcanvasEl.querySelector('form');
                    if (form) {
                        form.action = self.statusUpdateUrl + (orderId ? '?id=' + orderId : '');

                        var idInput = form.querySelector('input[name="id"]');
                        if (!idInput) {
                            idInput = document.createElement('input');
                            idInput.type = 'hidden';
                            idInput.name = 'id';
                            form.appendChild(idInput);
                        }
                        idInput.value = String(orderId || '');

                        var redirectInput = form.querySelector('input[name="back_url"]');
                        if (!redirectInput) {
                            redirectInput = document.createElement('input');
                            redirectInput.type = 'hidden';
                            redirectInput.name = 'back_url';
                            form.appendChild(redirectInput);
                        }
                        redirectInput.value = window.location.pathname + window.location.search + window.location.hash;
                    }
                });
            }
        }
    };

    window.WeShopOrder = WeShopOrder;

    document.addEventListener('DOMContentLoaded', function() {
        WeShopOrder.init();
    });
})();
</script>
