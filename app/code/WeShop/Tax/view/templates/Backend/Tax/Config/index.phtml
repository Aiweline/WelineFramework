<script>
    (function () {
        var form = document.getElementById('tax-config-form');
        var saveUrl = <?= json_encode($saveUrl) ?>;
        var testResult = document.getElementById('test-result');
        var testResultGrid = document.getElementById('test-result-grid');

        function addRateRow(tableBodyId) {
            var tbody = document.getElementById(tableBodyId);
            if (!tbody) return;

            var rows = tbody.querySelectorAll('tr');
            var newIndex = rows.length;
            var lastRow = rows[rows.length - 1];
            var isRegion = tableBodyId === 'region-rates-body';
            var codePlaceholder = isRegion ? '<?= __('e.g. US-CA') ?>' : '<?= __('e.g. US') ?>';

            var newRow = document.createElement('tr');
            newRow.setAttribute('data-index', newIndex);
            newRow.innerHTML = '<td><input type="text" name="' + (isRegion ? 'region_rates' : 'country_rates') + '[' + newIndex + '][code]" placeholder="' + codePlaceholder + '"></td>'
                + '<td><input type="number" name="' + (isRegion ? 'region_rates' : 'country_rates') + '[' + newIndex + '][rate]" step="0.0001" min="0" max="1" placeholder="<?= __('e.g. 0.08') ?>"></td>'
                + '<td><button type="button" class="btn btn-sm btn-outline-danger remove-rate-btn"><i class="mdi mdi-delete"></i></button></td>';
            tbody.appendChild(newRow);
        }

        function removeRateRow(button) {
            var row = button.closest('tr');
            var tbody = row.parentElement;
            if (tbody.querySelectorAll('tr').length > 1) {
                row.remove();
            }
        }

        document.getElementById('add-country-rate-btn').addEventListener('click', function () {
            addRateRow('country-rates-body');
        });

        document.getElementById('add-region-rate-btn').addEventListener('click', function () {
            addRateRow('region-rates-body');
        });

        document.addEventListener('click', function (e) {
            if (e.target.closest('.remove-rate-btn')) {
                removeRateRow(e.target.closest('.remove-rate-btn'));
            }
        });

        function formatRate(rate) {
            var num = Number(rate || 0);
            return (num * 100).toFixed(2) + '%';
        }

        function formatPrice(amount) {
            var num = Number(amount || 0);
            if (window.Intl && typeof window.Intl.NumberFormat === 'function') {
                try {
                    return new Intl.NumberFormat(undefined, {
                        style: 'currency',
                        currency: 'USD',
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(num);
                } catch (e) {}
            }
            return num.toFixed(2);
        }

        function renderTestResult(data) {
            if (!testResult || !testResultGrid || !data) return;

            var html = '<div class="test-result-item">'
                + '<div class="test-result-item-label"><?= __('Subtotal') ?></div>'
                + '<div class="test-result-item-value">' + formatPrice(data.subtotal || 0) + '</div>'
                + '</div>'
                + '<div class="test-result-item">'
                + '<div class="test-result-item-label"><?= __('Country') ?></div>'
                + '<div class="test-result-item-value">' + (data.country || '-') + '</div>'
                + '</div>'
                + '<div class="test-result-item">'
                + '<div class="test-result-item-label"><?= __('Region') ?></div>'
                + '<div class="test-result-item-value">' + (data.region || '-') + '</div>'
                + '</div>'
                + '<div class="test-result-item">'
                + '<div class="test-result-item-label"><?= __('Tax Rate') ?></div>'
                + '<div class="test-result-item-value">' + formatRate(data.tax_rate) + '</div>'
                + '</div>'
                + '<div class="test-result-item">'
                + '<div class="test-result-item-label"><?= __('Tax Amount') ?></div>'
                + '<div class="test-result-item-value">' + formatPrice(data.tax_amount) + '</div>'
                + '</div>';

            testResultGrid.innerHTML = html;
            testResult.classList.add('is-visible');
        }

        document.getElementById('test-calculate-btn').addEventListener('click', function () {
            var formData = new FormData(form);
            var params = new URLSearchParams();
            formData.forEach(function (value, key) {
                if (value !== '' && value !== null) {
                    params.append(key, String(value));
                }
            });

            fetch(saveUrl + '?' + params.toString(), {
                method: 'GET',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (payload && payload.success && payload.data && payload.data.test_result) {
                    renderTestResult(payload.data.test_result);
                } else {
                    var msg = (payload && payload.message) || <?= json_encode(__('Test calculation failed')) ?>;
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(msg);
                    } else {
                        console.error(msg);
                    }
                }
            }).catch(function (error) {
                console.error('Test calculation error:', error);
                var msg = <?= json_encode(__('Test calculation failed')) ?>;
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error(msg);
                } else {
                    console.error(msg);
                }
            });
        });

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            var formData = new FormData(form);
            var submitBtn = document.getElementById('save-config-btn');
            submitBtn.disabled = true;

            fetch(saveUrl, {
                method: 'POST',
                body: formData,
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (payload && payload.success) {
                    var msg = <?= json_encode(__('Configuration saved successfully!')) ?>;
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success(msg);
                    } else {
                        console.log(msg);
                    }
                    if (payload.data && payload.data.test_result) {
                        renderTestResult(payload.data.test_result);
                    }
                } else {
                    var msg = (payload && payload.message) || <?= json_encode(__('Failed to save configuration')) ?>;
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(msg);
                    } else {
                        console.error(msg);
                    }
                }
            }).catch(function (error) {
                console.error('Save configuration error:', error);
                var msg = <?= json_encode(__('Failed to save configuration')) ?>;
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error(msg);
                } else {
                    console.error(msg);
                }
            }).finally(function () {
                submitBtn.disabled = false;
            });
        });

        document.getElementById('reset-form-btn').addEventListener('click', function () {
            var msg = <?= json_encode(__('Are you sure you want to reset the form?')) ?>;
            if (typeof BackendConfirm === 'undefined') {
                form.reset();
                if (testResult) {
                    testResult.classList.remove('is-visible');
                }
                return;
            }
            BackendConfirm.show(msg, { type: 'warning' }).then(function (confirmed) {
                if (!confirmed) return;
                form.reset();
                if (testResult) {
                    testResult.classList.remove('is-visible');
                }
            });
        });
    })();
</script>
