<script>
    (function () {
        var form = document.getElementById('tax-calculator-form');
        var resultContainer = document.getElementById('tax-calculator-result');
        var resultBreakdown = document.getElementById('tax-result-breakdown');
        var errorBox = document.getElementById('tax-calculator-error');
        var calculateUrl = <?= json_encode($calculate_url) ?>;
        var defaultFailedMessage = <?= json_encode(__('Failed to calculate tax')) ?>;
        var taxApiPromise = null;

        function showError(message) {
            if (!resultContainer || !errorBox) {
                return;
            }
            var safeMessage = (message === null || message === undefined || message === '') ? defaultFailedMessage : String(message);
            errorBox.textContent = safeMessage;
            errorBox.classList.add('is-visible');
            if (resultBreakdown) {
                resultBreakdown.innerHTML = '';
            }
            resultContainer.classList.add('is-visible');
        }

        function clearError() {
            if (!errorBox) {
                return;
            }
            errorBox.textContent = '';
            errorBox.classList.remove('is-visible');
        }

        function getTaxApi() {
            if (!taxApiPromise) {
                taxApiPromise = Promise.resolve(window.Weline.Api.resource('tax'));
            }

            return taxApiPromise;
        }

        function formatPrice(amount) {
            var num = Number(amount || 0);
            var currency = <?= json_encode($currency) ?>;
            if (window.Intl && typeof window.Intl.NumberFormat === 'function') {
                try {
                    return new Intl.NumberFormat(undefined, {
                        style: 'currency',
                        currency: currency,
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(num);
                } catch (e) {
                    console.warn('Currency formatting fallback:', e);
                }
            }
            return num.toFixed(2);
        }

        function renderBreakdown(data) {
            if (!resultBreakdown || !data) {
                return;
            }

            clearError();
            var rows = [
                {label: <?= json_encode(__('Subtotal')) ?>, value: formatPrice(data.subtotal || 0)},
                {label: <?= json_encode(__('Tax Rate')) ?>, value: ((Number(data.tax_rate || 0)) * 100).toFixed(2) + '%'},
                {label: <?= json_encode(__('Taxable Amount')) ?>, value: formatPrice(data.taxable_amount || 0)},
                {label: <?= json_encode(__('Tax Amount')) ?>, value: formatPrice(data.tax_amount || 0), highlight: true}
            ];

            if (data.included_tax > 0) {
                rows.push({label: <?= json_encode(__('Included Tax')) ?>, value: formatPrice(data.included_tax)});
            }
            if (data.chargeable_tax > 0) {
                rows.push({label: <?= json_encode(__('Chargeable Tax')) ?>, value: formatPrice(data.chargeable_tax)});
            }

            var html = '';
            rows.forEach(function (row) {
                var highlightClass = row.highlight ? ' tax-info-page__row-value--highlight' : '';
                html += '<div class="tax-info-page__row">'
                    + '<span class="tax-info-page__row-label">' + row.label + '</span>'
                    + '<span class="tax-info-page__row-value' + highlightClass + '">' + row.value + '</span>'
                    + '</div>';
            });

            resultBreakdown.innerHTML = html;
            resultContainer.classList.add('is-visible');
        }

        if (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();

                var formData = new FormData(form);
                var params = {};
                formData.forEach(function (value, key) {
                    if (value !== '' && value !== null && value !== undefined) {
                        params[key] = isNaN(Number(value)) ? String(value) : Number(value);
                    }
                });

                getTaxApi().then(function (TaxApi) {
                    return TaxApi.calculateTaxBreakdown(params, {silent: true});
                }).then(function (payload) {
                    renderBreakdown(payload || {});
                }).catch(function (error) {
                    console.error('Tax calculation error:', error);
                    showError(defaultFailedMessage);
                });
            });
        }
    })();
</script>
