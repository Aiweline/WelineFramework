<?php
/**
 * @hook-priority 200
 * @hook-sort-order 1
 * @hook-solo false
 */
$renderFlag = '__weshop_analytics_hook_footer_rendered';
if (!empty($GLOBALS[$renderFlag])) {
    return;
}
$GLOBALS[$renderFlag] = true;

$snippets = w_query('analytics', 'getFrontendPixelSnippetsBySlot', [
    'slot' => 'footer',
]);
$snippets = is_array($snippets) ? $snippets : [];
?>
<?php foreach ($snippets as $snippet): ?>
    <?php
    if (!is_array($snippet)) {
        continue;
    }
    $content = trim((string) ($snippet['snippet'] ?? ''));
    if ($content === '') {
        continue;
    }
    ?>
    <?= $content ?>
<?php endforeach; ?>
