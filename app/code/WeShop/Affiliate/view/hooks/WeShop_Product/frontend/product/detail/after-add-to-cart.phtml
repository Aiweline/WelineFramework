    --affiliate-share-primary-hover: var(--color-primary-hover, var(--color-accent-hover, var(--weline-theme-primary-hover, #005f6b)));
    --affiliate-share-primary-soft: var(--color-primary-bg-subtle, color-mix(in srgb, var(--affiliate-share-primary) 12%, #fff));
    --affiliate-share-primary-border: var(--color-primary-border-subtle, color-mix(in srgb, var(--affiliate-share-primary) 34%, #d5d9d9));
    --affiliate-share-surface: var(--color-bg-primary, var(--weline-theme-surface, #fff));
    --affiliate-share-surface-subtle: var(--color-bg-secondary, var(--weline-theme-surface-subtle, #f7fafa));
    --affiliate-share-border: var(--color-border-light, var(--weline-theme-border-color, #d5d9d9));
    --affiliate-share-text: var(--color-text-primary, var(--weline-theme-text, #0f1111));
    --affiliate-share-muted: var(--color-text-secondary, var(--weline-theme-text-muted, #565959));
    --affiliate-share-on-primary: var(--color-primary-contrast, var(--weline-theme-on-primary, #fff));
    --affiliate-share-success: var(--color-success, var(--weline-theme-success, #0f5132));
    --affiliate-share-success-soft: var(--color-success-bg-subtle, var(--weline-theme-success-subtle, #e7f4ea));
    --affiliate-share-warning: var(--color-warning, var(--weline-theme-warning, #7a3e00));
    --affiliate-share-warning-soft: var(--color-warning-bg-subtle, var(--weline-theme-warning-subtle, #fff4e5));
    margin-top: 1rem;
    padding: .9rem;
    border: var(--weline-theme-border-width, 1px) var(--weline-theme-border-style, solid) var(--affiliate-share-border);
    border-radius: var(--weline-theme-radius-lg, 8px);
    background: var(--affiliate-share-surface);
    box-shadow: var(--weline-theme-shadow-sm, 0 1px 2px rgba(15, 17, 17, .08));
}
