<?php
/**
 * Affiliate share entry for product detail pages.
 *
 * @hook-priority 180
 * @hook-sort-order 0
 * @hook-solo false
 */
$product = (array) ($this->getData('product') ?? []);
$productId = (int) ($product['product_id'] ?? $this->getData('product_id') ?? 0);
if ($productId <= 0) {
    return;
}
$rootId = 'affiliate-share-' . $productId . '-' . substr(sha1((string) $productId), 0, 8);
?>
<div id="<?= htmlspecialchars($rootId, ENT_QUOTES, 'UTF-8') ?>"
     class="affiliate-share-panel"
     data-affiliate-share-root="1"
     data-product-id="<?= (int) $productId ?>">
    <div class="affiliate-share-head">
        <span class="affiliate-share-title"><?= __('分销分享') ?></span>
        <span class="affiliate-share-status" data-affiliate-share-status aria-live="polite"></span>
    </div>
    <div class="affiliate-share-body">
        <input class="affiliate-share-link"
               type="text"
               value=""
               readonly
               aria-label="<?= htmlspecialchars((string) __('分销分享链接'), ENT_QUOTES, 'UTF-8') ?>"
               data-affiliate-share-link />
        <button type="button" class="affiliate-share-copy" data-affiliate-share-copy disabled><?= __('复制') ?></button>
        <button type="button" class="affiliate-share-native" data-affiliate-share-native disabled><?= __('分享') ?></button>
    </div>
    <div class="affiliate-share-platforms" data-affiliate-share-platforms></div>
</div>

<style>
.affiliate-share-panel {
    margin-top: 1rem;
    padding: .9rem;
    border: 1px solid #d5d9d9;
    border-radius: 8px;
    background: linear-gradient(180deg, #ffffff 0%, #f7fafa 100%);
    box-shadow: 0 1px 2px rgba(15, 17, 17, .08);
}
.affiliate-share-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .65rem;
}
.affiliate-share-title {
    color: #0f1111;
    font-size: .95rem;
    font-weight: 700;
    line-height: 1.25;
}
.affiliate-share-status {
    min-height: 1.15rem;
    padding: .1rem .45rem;
    border-radius: 999px;
    color: #565959;
    font-size: .78rem;
    line-height: 1.2;
    text-align: right;
    white-space: nowrap;
}
.affiliate-share-status.is-loading {
    background: #f7fafa;
    color: #565959;
}
.affiliate-share-status.is-success {
    background: #e7f4ea;
    color: #0f5132;
}
.affiliate-share-status.is-error {
    background: #fff4e5;
    color: #7a3e00;
}
.affiliate-share-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: .5rem;
}
.affiliate-share-link {
    grid-column: 1 / -1;
    min-width: 0;
    height: 2.35rem;
    padding: 0 .65rem;
    border: 1px solid #888c8c;
    border-radius: 6px;
    background: #fff;
    color: #0f1111;
    font-size: .85rem;
    line-height: 1.2;
}
.affiliate-share-copy,
.affiliate-share-native,
.affiliate-share-platform {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0 .7rem;
    border: 1px solid #007185;
    border-radius: 6px;
    background: #fff;
    color: #007185;
    cursor: pointer;
    font-size: .85rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    transition: background-color .15s ease, border-color .15s ease, color .15s ease, box-shadow .15s ease;
}
.affiliate-share-copy:hover:not(:disabled),
.affiliate-share-native:hover:not(:disabled),
.affiliate-share-platform:hover {
    border-color: #004f5f;
    background: #e6f2f4;
    color: #004f5f;
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(15, 17, 17, .12);
}
.affiliate-share-copy:disabled,
.affiliate-share-native:disabled,
.affiliate-share-platform:disabled {
    border-color: #d5d9d9;
    color: #888c8c;
    cursor: not-allowed;
}
.affiliate-share-platforms {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .45rem;
    margin-top: .6rem;
}
.affiliate-share-platform {
    min-width: 0;
}
@media (max-width: 640px) {
    .affiliate-share-head {
        align-items: flex-start;
        flex-direction: column;
    }
    .affiliate-share-status {
        text-align: left;
        white-space: normal;
    }
    .affiliate-share-body,
    .affiliate-share-platforms {
        grid-template-columns: 1fr;
    }
    .affiliate-share-copy,
    .affiliate-share-native,
    .affiliate-share-platform {
        width: 100%;
    }
}
</style>

<script>
(function() {
    var root = document.getElementById(<?= json_encode($rootId, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
    if (!root) return;

    var productId = Number(root.getAttribute('data-product-id') || 0);
    var linkInput = root.querySelector('[data-affiliate-share-link]');
    var copyButton = root.querySelector('[data-affiliate-share-copy]');
    var nativeButton = root.querySelector('[data-affiliate-share-native]');
    var statusNode = root.querySelector('[data-affiliate-share-status]');
    var platformsNode = root.querySelector('[data-affiliate-share-platforms]');
    var shareData = null;

    function setStatus(message, type) {
        if (!statusNode) return;
        statusNode.textContent = message || '';
        statusNode.classList.remove('is-loading', 'is-success', 'is-error');
        if (type) statusNode.classList.add('is-' + type);
    }

    function getAffiliateApi() {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
            return Promise.resolve(window.Weline.Api.resource('affiliate'));
        }
        return Promise.reject(new Error(<?= json_encode((string) __('分销 API 未初始化'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>));
    }

    function normalizeResponse(response) {
        if (!response || response.success === false) {
            throw new Error((response && (response.message || response.msg)) || <?= json_encode((string) __('分销数据加载失败'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
        }
        return response.data || response;
    }

    function recordOutbound(platform) {
        if (!shareData || !shareData.share_code) return Promise.resolve();
        return getAffiliateApi().then(function(api) {
            if (!api || typeof api.recordOutboundShare !== 'function') return null;
            return api.recordOutboundShare({
                share_code: shareData.share_code,
                platform: platform || 'copy'
            });
        }).catch(function() {
            return null;
        });
    }

    function fallbackCopyShareLink() {
        if (linkInput) {
            linkInput.focus();
            linkInput.select();
            document.execCommand('copy');
        }
        return null;
    }

    function writeShareLinkToClipboard() {
        return new Promise(function(resolve) {
            var resolved = false;
            var finish = function() {
                if (resolved) return;
                resolved = true;
                resolve(null);
            };
            var fallback = function() {
                fallbackCopyShareLink();
                finish();
            };

            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                var timer = window.setTimeout(fallback, 800);
                navigator.clipboard.writeText(shareData.tracking_url).then(function() {
                    window.clearTimeout(timer);
                    finish();
                }).catch(function() {
                    window.clearTimeout(timer);
                    fallback();
                });
                return;
            }

            fallback();
        });
    }

    function copyShareLink() {
        if (!shareData || !shareData.tracking_url) return;
        recordOutbound('copy').then(function() {
            return writeShareLinkToClipboard();
        }).then(function() {
            setStatus(<?= json_encode((string) __('已复制'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
        });
    }

    function nativeShare() {
        if (!shareData || !shareData.tracking_url || !navigator.share) {
            copyShareLink();
            return;
        }
        recordOutbound('native').then(function() {
            return navigator.share({
                title: document.title || '',
                url: shareData.tracking_url
            });
        }).then(function() {
            setStatus(<?= json_encode((string) __('已分享'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
        }).catch(function() {});
    }

    function renderPlatforms(platforms) {
        if (!platformsNode) return;
        platformsNode.innerHTML = '';
        (platforms || []).forEach(function(item) {
            if (!item || item.platform === 'copy' || !item.url) return;
            var button = document.createElement('a');
            button.className = 'affiliate-share-platform';
            button.href = item.url;
            button.target = '_blank';
            button.rel = 'noopener noreferrer';
            button.textContent = item.label || item.platform;
            button.addEventListener('click', function() {
                recordOutbound(item.platform || 'social');
            });
            platformsNode.appendChild(button);
        });
    }

    function enableControls() {
        if (copyButton) copyButton.disabled = false;
        if (nativeButton) nativeButton.disabled = false;
    }

    if (copyButton) copyButton.addEventListener('click', copyShareLink);
    if (nativeButton) nativeButton.addEventListener('click', nativeShare);

    setStatus(<?= json_encode((string) __('加载中'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'loading');
    getAffiliateApi()
        .then(function(api) {
            if (!api || typeof api.getProductShareLinks !== 'function') {
                throw new Error(<?= json_encode((string) __('分销 API 不支持分享链接操作'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
            }
            return api.getProductShareLinks({ product_id: productId, channel: 'product_detail' });
        })
        .then(normalizeResponse)
        .then(function(data) {
            shareData = data || {};
            if (linkInput) linkInput.value = shareData.tracking_url || '';
            renderPlatforms(shareData.platform_urls || []);
            enableControls();
            setStatus('');
        })
        .catch(function(error) {
            setStatus(error && error.message ? error.message : <?= json_encode((string) __('暂不可用'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'error');
        });
})();
</script>
