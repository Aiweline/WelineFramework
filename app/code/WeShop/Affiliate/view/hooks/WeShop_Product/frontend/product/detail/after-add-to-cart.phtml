</style>

<script>
(function() {
    var root = document.getElementById(<?= json_encode($rootId, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
    if (!root) return;

    var productId = Number(root.getAttribute('data-product-id') || 0);
    var linkInput = root.querySelector('[data-affiliate-share-link]');
    var copyButton = root.querySelector('[data-affiliate-share-copy]');
    var nativeButton = root.querySelector('[data-affiliate-share-native]');
    var statusNode = root.querySelector('[data-affiliate-share-status]');
    var platformsNode = root.querySelector('[data-affiliate-share-platforms]');
    var shareData = null;

    function setStatus(message, type) {
        if (!statusNode) return;
        statusNode.textContent = message || '';
        statusNode.classList.remove('is-loading', 'is-success', 'is-error');
        if (type) statusNode.classList.add('is-' + type);
    }

    function getAffiliateApi() {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
            return Promise.resolve(window.Weline.Api.resource('affiliate'));
        }
        return Promise.reject(new Error(<?= json_encode((string) __('分销 API 未初始化'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>));
    }

    function normalizeResponse(response) {
        if (!response || response.success === false) {
            throw new Error((response && (response.message || response.msg)) || <?= json_encode((string) __('分销数据加载失败'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
        }
        return response.data || response;
    }

    function recordOutbound(platform) {
        if (!shareData || !shareData.share_code) return Promise.resolve();
        return getAffiliateApi().then(function(api) {
            if (!api || typeof api.recordOutboundShare !== 'function') return null;
            return api.recordOutboundShare({
                share_code: shareData.share_code,
                platform: platform || 'copy'
            });
        }).catch(function() {
            return null;
        });
    }

    function fallbackCopyShareLink() {
        if (linkInput) {
            linkInput.focus();
            linkInput.select();
            document.execCommand('copy');
        }
        return null;
    }

    function writeShareLinkToClipboard() {
        return new Promise(function(resolve) {
            var resolved = false;
            var finish = function() {
                if (resolved) return;
                resolved = true;
                resolve(null);
            };
            var fallback = function() {
                fallbackCopyShareLink();
                finish();
            };

            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                var timer = window.setTimeout(fallback, 800);
                navigator.clipboard.writeText(shareData.tracking_url).then(function() {
                    window.clearTimeout(timer);
                    finish();
                }).catch(function() {
                    window.clearTimeout(timer);
                    fallback();
                });
                return;
            }

            fallback();
        });
    }

    function copyShareLink() {
        if (!shareData || !shareData.tracking_url) return;
        recordOutbound('copy').then(function() {
            return writeShareLinkToClipboard();
        }).then(function() {
            setStatus(<?= json_encode((string) __('已复制'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
        });
    }

    function nativeShare() {
        if (!shareData || !shareData.tracking_url || !navigator.share) {
            copyShareLink();
            return;
        }
        recordOutbound('native').then(function() {
            return navigator.share({
                title: document.title || '',
                url: shareData.tracking_url
            });
        }).then(function() {
            setStatus(<?= json_encode((string) __('已分享'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
        }).catch(function() {});
    }

    function renderPlatforms(platforms) {
        if (!platformsNode) return;
        platformsNode.innerHTML = '';
        (platforms || []).forEach(function(item) {
            if (!item || item.platform === 'copy' || !item.url) return;
            var button = document.createElement('a');
            button.className = 'affiliate-share-platform';
            button.href = item.url;
            button.target = '_blank';
            button.rel = 'noopener noreferrer';
            button.textContent = item.label || item.platform;
            button.addEventListener('click', function() {
                recordOutbound(item.platform || 'social');
            });
            platformsNode.appendChild(button);
        });
    }

    function enableControls() {
        if (copyButton) copyButton.disabled = false;
        if (nativeButton) nativeButton.disabled = false;
    }

    if (copyButton) copyButton.addEventListener('click', copyShareLink);
    if (nativeButton) nativeButton.addEventListener('click', nativeShare);

    setStatus(<?= json_encode((string) __('加载中'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'loading');
    getAffiliateApi()
        .then(function(api) {
            if (!api || typeof api.getProductShareLinks !== 'function') {
                throw new Error(<?= json_encode((string) __('分销 API 不支持分享链接操作'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
            }
            return api.getProductShareLinks({ product_id: productId, channel: 'product_detail' });
        })
        .then(normalizeResponse)
        .then(function(data) {
            shareData = data || {};
            if (linkInput) linkInput.value = shareData.tracking_url || '';
            renderPlatforms(shareData.platform_urls || []);
            enableControls();
            setStatus('');
        })
        .catch(function(error) {
            setStatus(error && error.message ? error.message : <?= json_encode((string) __('暂不可用'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'error');
        });
})();
</script>
