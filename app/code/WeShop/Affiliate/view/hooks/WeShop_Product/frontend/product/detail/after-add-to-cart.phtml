.affiliate-share-copy:hover:not(:disabled) {
    background: var(--affiliate-share-primary-hover);
    color: var(--affiliate-share-on-primary);
}
.affiliate-share-copy:disabled,
.affiliate-share-native:disabled,
.affiliate-share-platform:disabled {
    border-color: var(--affiliate-share-border);
    background: var(--affiliate-share-surface-subtle);
    color: var(--affiliate-share-muted);
    cursor: not-allowed;
}
.affiliate-share-platforms {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
