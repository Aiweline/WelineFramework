<?php
/**
 * Account sidebar content bridge.
 *
 * Hook: account.sidebar.content
 *
 * @hook-priority 165
 * @hook-sort-order 18
 * @hook-solo false
 */
use Weline\Customer\Service\AccountSidebarContentGate;
use Weline\Framework\Runtime\RequestContext;

if (!AccountSidebarContentGate::accepts('affiliate')) {
    return;
}

$renderKey = 'weshop_affiliate.account_sidebar_content.rendered';
if (RequestContext::get($renderKey, false)) {
    return;
}

RequestContext::set($renderKey, true);
?>
<section class="account-hook-section account-index__section d-none motor-account-section" id="affiliate-section" data-account-section="affiliate" hidden>
    <?= $this->getHook('WeShop_Affiliate::frontend::account::index::affiliate') ?>
</section>
