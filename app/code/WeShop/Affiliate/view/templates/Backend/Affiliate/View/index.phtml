<script>
    (function () {
        const root = document.querySelector('[data-affiliate-detail]');
        if (!root) {
            return;
        }

        const status = root.querySelector('[data-copy-status]');
        const copiedMessage = <?= json_encode((string) __('Copied to clipboard.')) ?>;
        const failedMessage = <?= json_encode((string) __('Copy failed. Select the value and copy manually.')) ?>;

        function setCopyStatus(message, tone) {
            if (status) {
                status.textContent = message;
                status.dataset.tone = tone;
            }

            if (window.BackendToast && typeof window.BackendToast.show === 'function') {
                window.BackendToast.show(message);
            }
        }

        function copyWithTextarea(value) {
            const textarea = document.createElement('textarea');
            textarea.value = value;
            textarea.setAttribute('readonly', 'readonly');
            textarea.style.position = 'fixed';
            textarea.style.top = '-1000px';
            textarea.style.left = '-1000px';
            document.body.appendChild(textarea);
            textarea.select();

            try {
                return document.execCommand('copy');
            } finally {
                document.body.removeChild(textarea);
            }
        }

        function writeClipboard(value) {
            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                return navigator.clipboard.writeText(value).catch(function () {
                    if (!copyWithTextarea(value)) {
                        throw new Error('copy failed');
                    }
                });
            }

            if (copyWithTextarea(value)) {
                return Promise.resolve();
            }

            return Promise.reject(new Error('copy failed'));
        }

        root.addEventListener('click', function (event) {
            const button = event.target.closest('[data-copy-value]');
            if (!button || !root.contains(button)) {
                return;
            }

            const value = button.getAttribute('data-copy-value') || '';
            writeClipboard(value).then(function () {
                setCopyStatus(copiedMessage, 'success');
            }).catch(function () {
                setCopyStatus(failedMessage, 'error');
            });
        });
    }());
</script>
