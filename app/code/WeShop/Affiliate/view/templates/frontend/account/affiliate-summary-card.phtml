<?php
/**
 * Shared account-center affiliate summary card.
 *
 * This template is rendered only from customer account hooks. The standalone
 * /affiliate route redirects back to the account center for theme consistency.
 */
/** @var \Weline\Framework\View\Template $this */
$affiliateResponse = [];
try {
    $affiliateResponse = w_query('affiliate', 'getMySummary');
} catch (\Throwable) {
    return;
}

if (!is_array($affiliateResponse) || empty($affiliateResponse['success'])) {
    return;
}

$affiliate = is_array($affiliateResponse['data'] ?? null) ? $affiliateResponse['data'] : [];
$referralCode = trim((string) ($affiliate['referral_code'] ?? ''));
$referralLink = trim((string) ($affiliate['referral_link'] ?? ''));
$defaultShareLink = is_array($affiliate['default_share_link'] ?? null) ? $affiliate['default_share_link'] : [];
$defaultTrackingUrl = trim((string) ($defaultShareLink['tracking_url'] ?? ''));
$shareLinks = is_array($affiliate['share_links'] ?? null) ? $affiliate['share_links'] : [];
$referredCustomers = is_array($affiliate['referred_customers'] ?? null) ? $affiliate['referred_customers'] : [];
$promotedProducts = is_array($affiliate['promoted_products'] ?? null) ? $affiliate['promoted_products'] : [];
$affiliateOrders = is_array($affiliate['affiliate_orders'] ?? null) ? $affiliate['affiliate_orders'] : [];
$commissionLedger = is_array($affiliate['commission_ledger'] ?? null) ? $affiliate['commission_ledger'] : [];
$withdrawalSummary = is_array($affiliate['withdrawal_summary'] ?? null) ? $affiliate['withdrawal_summary'] : [];
$withdrawalRecords = is_array($affiliate['withdrawal_records'] ?? null) ? $affiliate['withdrawal_records'] : [];
$summaryCurrency = strtoupper(trim((string) ($affiliate['currency_code'] ?? 'USD')));
$catalogUrl = $this->getUrl('catalog/category');
$homeUrl = $this->getUrl('');
$formatAmount = function (mixed $amount, mixed $currency = '') {
    $value = (float) $amount;
    if (method_exists($this, 'formatPrice')) {
        $formatted = $this->formatPrice($value);
    } else {
        $formatted = number_format($value, 2);
    }

    $currency = strtoupper(trim((string) $currency));
    return $currency !== '' ? htmlspecialchars($currency . ' ', ENT_QUOTES) . $formatted : $formatted;
};
$formatPercent = static function (mixed $rate): string {
    return number_format(((float) $rate) * 100, 2) . '%';
};
$formatDate = static function (mixed $date): string {
    $value = trim((string) $date);
    if ($value === '') {
        return '-';
    }
    $timestamp = strtotime($value);
    return $timestamp ? date('Y-m-d H:i', $timestamp) : $value;
};
$statusLabel = static function (mixed $status): string {
    $status = trim((string) $status);
    $withdrawalLabels = [
        'requested' => (string) __('已申请'),
        'processing' => (string) __('处理中'),
        'rejected' => (string) __('已驳回'),
    ];
    if (isset($withdrawalLabels[$status])) {
        return $withdrawalLabels[$status];
    }
    return match ($status) {
        'pending' => (string) __('待结算'),
        'approved' => (string) __('已确认'),
        'paid' => (string) __('已打款'),
        'cancelled' => (string) __('已取消'),
        'reversed' => (string) __('已冲销'),
        'active' => (string) __('启用中'),
        'disabled' => (string) __('已停用'),
        'paid,pending' => (string) __('部分确认'),
        default => $status !== '' ? $status : '-',
    };
};
$emptyText = (string) __('暂无数据');
$stats = [
    ['label' => __('分享'), 'value' => (int) ($affiliate['share_count'] ?? 0)],
    ['label' => __('点击'), 'value' => (int) ($affiliate['click_count'] ?? 0)],
    ['label' => __('收藏'), 'value' => (int) ($affiliate['wishlist_count'] ?? 0)],
    ['label' => __('加购'), 'value' => (int) ($affiliate['add_to_cart_count'] ?? 0)],
    ['label' => __('下单'), 'value' => (int) ($affiliate['order_count'] ?? 0)],
    ['label' => __('支付'), 'value' => (int) ($affiliate['paid_count'] ?? 0)],
];
$rootId = 'weshop-affiliate-account-' . substr(sha1($referralCode !== '' ? $referralCode : (string) ($affiliate['affiliate_id'] ?? '0')), 0, 10);
