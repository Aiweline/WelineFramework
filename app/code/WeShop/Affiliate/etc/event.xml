<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <event name="WeShop_Social::share_after">
        <observer name="weshop_affiliate_social_share_after" instance="WeShop\Affiliate\Observer\SocialShareAfterObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Product::product_viewed">
        <observer name="weshop_affiliate_product_viewed" instance="WeShop\Affiliate\Observer\ProductViewedObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Wishlist::add_to_wishlist_after">
        <observer name="weshop_affiliate_wishlist_add_after" instance="WeShop\Affiliate\Observer\WishlistAddAfterObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Review::review_created">
        <observer name="weshop_affiliate_review_created" instance="WeShop\Affiliate\Observer\ReviewCreatedObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Cart::add_to_cart_after">
        <observer name="weshop_affiliate_cart_add_after" instance="WeShop\Affiliate\Observer\CartAddAfterObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Checkout::order_created">
        <observer name="weshop_affiliate_checkout_order_created" instance="WeShop\Affiliate\Observer\CheckoutOrderCreatedObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Order::payment_status_changed">
        <observer name="weshop_affiliate_order_payment_status_changed" instance="WeShop\Affiliate\Observer\OrderPaymentStatusChangedObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Order::order_status_changed">
        <observer name="weshop_affiliate_order_status_changed" instance="WeShop\Affiliate\Observer\OrderStatusChangedObserver" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="WeShop_Order::cancelled">
        <observer name="weshop_affiliate_order_cancelled" instance="WeShop\Affiliate\Observer\OrderCancelledObserver" disabled="false" shared="true" sort="100"/>
    </event>
</config>
