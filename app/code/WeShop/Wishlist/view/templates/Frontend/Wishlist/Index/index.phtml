<?php
/**
 * Wishlist Index Template
 * 愿望清单页面模板
 *
 * @meta-description Wishlist page showing customer's saved products
 * @meta-keywords wishlist, saved products, favorites
 */
?>
<div class="wishlist-page">
    <div class="wishlist-page__header">
        <h1 class="wishlist-page__title"><?= __('My Wishlist') ?></h1>
        <p class="wishlist-page__subtitle"><?= __('Products you\'ve saved for later') ?></p>
    </div>

    <?php if (empty($items)): ?>
        <div class="wishlist-page__empty">
            <div class="wishlist-page__empty-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
            </div>
            <h2 class="wishlist-page__empty-title"><?= __('Your wishlist is empty') ?></h2>
            <p class="wishlist-page__empty-text"><?= __('Browse our products and add items you love to your wishlist.') ?></p>
            <a href="/" class="wishlist-page__empty-action btn btn-primary">
                <?= __('Start Shopping') ?>
            </a>
        </div>
    <?php else: ?>
        <div class="wishlist-page__items">
            <?php foreach ($items as $item): ?>
                <div class="wishlist-item" data-item-id="<?= $item['id'] ?? '' ?>">
                    <div class="wishlist-item__image">
                        <?php if (!empty($item['image'])): ?>
                            <img src="<?= $item['image'] ?>" alt="<?= $item['name'] ?? '' ?>"/>
                        <?php else: ?>
                            <div class="wishlist-item__no-image">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21,15 16,10 5,21"/>
                                </svg>
                            </div>
                        <?php endif; ?>
                    </div>
                    <div class="wishlist-item__details">
                        <h3 class="wishlist-item__name">
                            <a href="<?= $item['url'] ?? '#' ?>"><?= $item['name'] ?? '' ?></a>
                        </h3>
                        <p class="wishlist-item__description"><?= $item['description'] ?? '' ?></p>
                        <div class="wishlist-item__price">
                            <?php if (!empty($item['special_price'])): ?>
                                <span class="wishlist-item__price-current"><?= $item['formatted_price'] ?? $item['special_price'] ?></span>
                                <span class="wishlist-item__price-old"><?= $item['formatted_regular_price'] ?? '' ?></span>
                            <?php else: ?>
                                <span class="wishlist-item__price-current"><?= $item['formatted_price'] ?? '' ?></span>
                            <?php endif; ?>
                        </div>
                        <div class="wishlist-item__stock">
                            <?php if ($item['in_stock'] ?? true): ?>
                                <span class="wishlist-item__stock-status wishlist-item__stock-status--in"><?= __('In Stock') ?></span>
                            <?php else: ?>
                                <span class="wishlist-item__stock-status wishlist-item__stock-status--out"><?= __('Out of Stock') ?></span>
                            <?php endif; ?>
                        </div>
                    </div>
                    <div class="wishlist-item__actions">
                        <button type="button" class="btn btn-secondary wishlist-item__add-to-cart" data-product-id="<?= $item['product_id'] ?? '' ?>">
                            <?= __('Add to Cart') ?>
                        </button>
                        <button type="button" class="btn btn-outline wishlist-item__remove" data-item-id="<?= $item['id'] ?? '' ?>">
                            <?= __('Remove') ?>
                        </button>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
