<?php
/**
 * Wishlist quick-link tile for the storefront account center.
 *
 * @hook-priority 205
 * @hook-sort-order 25
 * @hook-solo false
 */

use WeShop\Wishlist\Service\WishlistPageDataService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$customer = $session->getCustomer();
if (!$customer || !$customer->getId()) {
    return;
}

/** @var WishlistPageDataService $pageDataService */
$pageDataService = ObjectManager::getInstance(WishlistPageDataService::class);
$data = $pageDataService->buildAccountQuickLink((int) $customer->getId());
$wishlistCount = (int) ($data['wishlist_count'] ?? 0);
$wishlistUrl = (string) ($data['wishlist_url'] ?? $this->getUrl('wishlist'));
?>
<a href="<?= htmlspecialchars($wishlistUrl, ENT_QUOTES) ?>" class="group rounded-2xl border border-border-light bg-background-light p-4 transition hover:border-primary hover:shadow-sm dark:border-border-dark dark:bg-background-dark">
    <div class="flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
            <span class="material-symbols-outlined text-2xl">favorite</span>
        </div>
        <div>
            <p class="font-semibold text-text-primary-light group-hover:text-primary dark:text-text-primary-dark"><?= __('心愿单') ?></p>
            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">
                <?= __('继续浏览已保存的 %{1} 件商品', $wishlistCount) ?>
            </p>
        </div>
    </div>
</a>
