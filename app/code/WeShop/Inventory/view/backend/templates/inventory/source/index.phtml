<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {
        var forms = document.querySelectorAll('form.inventory-source-delete-form');
        forms.forEach(function (form) {
            form.addEventListener('submit', function (e) {
                // Prevent double-submit when we re-submit programmatically after confirmation.
                if (form.dataset.confirmed === '1') return;
                e.preventDefault();

                if (typeof BackendConfirm === 'undefined') {
                    form.dataset.confirmed = '1';
                    form.submit();
                    return;
                }

                var msg = form.dataset.confirmMessage || '';
                BackendConfirm.show(msg, { type: 'warning' }).then(function (confirmed) {
                    if (!confirmed) return;
                    form.dataset.confirmed = '1';
                    form.submit();
                });
            });
        });
    });
})();
</script>
