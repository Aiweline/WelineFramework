<?php
$sources = $this->getData('sources') ?? [];
$sourceIndexUrl = (string) ($this->getData('sourceIndexUrl') ?? $this->getBackendUrl('*/backend/inventory/source'));
$sourceAddUrl = (string) ($this->getData('sourceAddUrl') ?? $this->getBackendUrl('*/backend/inventory/source/add'));
?>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1"><?= __('Inventory Sources') ?></h1>
            <p class="text-muted mb-0"><?= __('Manage warehouses and inventory source metadata for stock allocation.') ?></p>
        </div>
        <a href="<?= $sourceAddUrl ?>" class="btn btn-primary"><?= __('Add Source') ?></a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <?php if ($sources): ?>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th><?= __('ID') ?></th>
                            <th><?= __('Code') ?></th>
                            <th><?= __('Name') ?></th>
                            <th><?= __('Country / City') ?></th>
                            <th><?= __('Priority') ?></th>
                            <th><?= __('Enabled') ?></th>
                            <th class="text-end"><?= __('Actions') ?></th>
                        </tr>
                        </thead>
                        <tbody>
                        <?php foreach ($sources as $source): ?>
                            <?php
                            $sourceId = (int) ($source['source_id'] ?? 0);
                            $country = (string) ($source['country'] ?? '');
                            $city = (string) ($source['city'] ?? '');
                            ?>
                            <tr>
                                <td><?= $sourceId ?></td>
                                <td><?= htmlspecialchars((string) ($source['code'] ?? ''), ENT_QUOTES) ?></td>
                                <td><?= htmlspecialchars((string) ($source['name'] ?? ''), ENT_QUOTES) ?></td>
                                <td><?= htmlspecialchars(trim($country . ' / ' . $city, ' /'), ENT_QUOTES) ?></td>
                                <td><?= (int) ($source['priority'] ?? 0) ?></td>
                                <td>
                                    <span class="badge text-bg-<?= (int) ($source['is_enabled'] ?? 0) === 1 ? 'success' : 'secondary' ?>">
                                        <?= (int) ($source['is_enabled'] ?? 0) === 1 ? __('Yes') : __('No') ?>
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="<?= $this->getBackendUrl('*/backend/inventory/source/edit', ['id' => $sourceId]) ?>" class="btn btn-sm btn-outline-primary">
                                        <?= __('Edit') ?>
                                    </a>
                                    <form method="post"
                                          action="<?= $this->getBackendUrl('*/backend/inventory/source/delete', ['id' => $sourceId]) ?>"
                                          class="d-inline"
                                          onsubmit="return confirm('<?= addslashes((string) __('Delete this inventory source?')) ?>');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><?= __('Delete') ?></button>
                                    </form>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php else: ?>
                <div class="text-center py-5">
                    <h2 class="h5 mb-2"><?= __('No inventory sources yet.') ?></h2>
                    <p class="text-muted mb-3"><?= __('Create your first source to start multi-source stock management.') ?></p>
                    <a href="<?= $sourceAddUrl ?>" class="btn btn-primary"><?= __('Create Source') ?></a>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
