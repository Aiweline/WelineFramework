<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 监听产品保存后事件，初始化库存记录 -->
    <event name="WeShop_Product::product_save_after">
        <observer name="WeShop_Inventory::product_save_after" instance="WeShop\Inventory\Observer\ProductSaveAfter" disabled="false" shared="true" sort="0"/>
    </event>
    
    <!-- 监听产品删除后事件，清理库存记录 -->
    <event name="WeShop_Product::product_delete_after">
        <observer name="WeShop_Inventory::product_delete_after" instance="WeShop\Inventory\Observer\ProductDeleteAfter" disabled="false" shared="true" sort="0"/>
    </event>
</config>

