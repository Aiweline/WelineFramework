<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <event name="Weline_Framework_Runtime::worker_bootstrap_after">
        <observer name="WeShop_Catalog::worker_bootstrap_warmup"
                  instance="WeShop\Catalog\Observer\WorkerBootstrapWarmup"
                  disabled="false"
                  shared="true"
                  sort="200"/>
    </event>
    <event name="Weline_Server::dispatcher::warmup_paths">
        <observer name="WeShop_Catalog::dispatcher_warmup_paths"
                  instance="WeShop\Catalog\Observer\DispatcherWarmupPaths"
                  disabled="false"
                  shared="true"
                  sort="200"/>
    </event>
</config>
