                    <div class="product-card__content">
                        <h3 class="product-card__title"><?= htmlspecialchars($product['name']) ?></h3>
                        <p class="product-card__description"><?= htmlspecialchars($product['description']) ?></p>
                        
                        <div class="product-card__rating">
                            <?php
                            $rating = $product['rating'] ?? 0;
                            for ($i = 1; $i <= 5; $i++):
                            ?>
                                <span class="star <?= $i <= $rating ? 'star-filled' : '' ?>">★</span>
                            <?php endfor; ?>
                            <span class="product-card__reviews">(<?= $product['reviews'] ?>)</span>
                        </div>
                        
