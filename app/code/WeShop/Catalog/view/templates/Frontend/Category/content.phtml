<?php
/**
 * Catalog category content fallback template.
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

/** @var \Weline\Framework\View\Template $this */

$contentHtmlOverride = $this->request->getData('weshop_category_content_html_override') ?? null;
if (is_string($contentHtmlOverride) && $contentHtmlOverride !== '') {
    echo $contentHtmlOverride;
    return;
}

// WLS workers can reuse template instances across requests, so prefer current request data.
$categoriesCtx = $this->request->getData('categories') ?? null;
$requestCategory = $this->request->getData('category') ?? null;
$category = is_array($requestCategory) && !empty($requestCategory['category_id'])
    ? $requestCategory
    : ($this->getData('category') ?? null);

if ((!is_array($category) || empty($category['category_id']))
    && is_array($categoriesCtx)
    && isset($categoriesCtx['current'])
    && is_array($categoriesCtx['current'])) {
    $category = $categoriesCtx['current'];
}

if (!is_array($category) || empty($category['category_id'])) {
    return;
}

$childCategories = $category['children'] ?? [];
if (!is_array($childCategories) || $childCategories === []) {
    try {
        /** @var CategoryService $categoryService */
        $categoryService = ObjectManager::getInstance(CategoryService::class);
        $childCategories = $categoryService->getChildCategories((int) $category['category_id']);
    } catch (\Throwable) {
        $childCategories = [];
    }
}

$childCategories = is_array($childCategories)
    ? array_values(array_filter($childCategories, static fn (mixed $child): bool => is_array($child) && !empty($child['category_id']) && !empty($child['handle'])))
    : [];

/** @var CategoryService $categoryUrlService */
$categoryUrlService = ObjectManager::getInstance(CategoryService::class);

$currentPath = trim((string) ($category['path'] ?? ''), '/');
if ($currentPath === '') {
    $currentHandle = trim((string) ($category['handle'] ?? ''), '/');
    if ($currentHandle !== '') {
        $currentPath = $currentHandle;
    }
}

$hasValidChildren = $childCategories !== [];
$products = $this->request->getData('products') ?? $this->getData('products') ?? [];
$resolveCategoryCardImage = static function (array $categoryRow): string {
    $image = trim((string) ($categoryRow['image'] ?? ''));
    if ($image !== '') {
        return $image;
    }

    $rawHandle = trim((string) ($categoryRow['handle'] ?? ''), '/');
    $handle = strtolower($rawHandle);
    $handleLeaf = strtolower(basename($rawHandle));
    $name = trim((string) ($categoryRow['name'] ?? ''));
    $fallbacks = [
        'electronics' => 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=1200&q=80',
        'phones' => 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=1200&q=80',
        'computers' => 'https://images.unsplash.com/photo-1496181133206-80ce9b88a853?auto=format&fit=crop&w=1200&q=80',
        'smart-devices' => 'https://images.unsplash.com/photo-1551816230-ef5deaed4a26?auto=format&fit=crop&w=1200&q=80',
        'audio-video' => 'https://images.unsplash.com/photo-1545454675-3531b543be5d?auto=format&fit=crop&w=1200&q=80',
        'smartphones' => 'https://images.unsplash.com/photo-1598327105666-5b89351aff97?auto=format&fit=crop&w=1200&q=80',
        'laptops' => 'https://images.unsplash.com/photo-1496181133206-80ce9b88a853?auto=format&fit=crop&w=1200&q=80',
        'wireless-headphones' => 'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=1200&q=80',
        'fashion' => 'https://images.unsplash.com/photo-1445205170230-053b83016050?auto=format&fit=crop&w=1200&q=80',
        'clothing' => 'https://images.unsplash.com/photo-1445205170230-053b83016050?auto=format&fit=crop&w=1200&q=80',
        'men' => 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80',
        'mens' => 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80',
        'women' => 'https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80',
        'womens' => 'https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80',
        'kids' => 'https://images.unsplash.com/photo-1519238359922-989348752efb?auto=format&fit=crop&w=1200&q=80',
        'sports' => 'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=80',
        'sportswear' => 'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=80',
        'sports-fashion' => 'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=80',
        '电子产品' => 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=1200&q=80',
        '手机通讯' => 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=1200&q=80',
        '电脑办公' => 'https://images.unsplash.com/photo-1496181133206-80ce9b88a853?auto=format&fit=crop&w=1200&q=80',
        '智能设备' => 'https://images.unsplash.com/photo-1551816230-ef5deaed4a26?auto=format&fit=crop&w=1200&q=80',
        '影音娱乐' => 'https://images.unsplash.com/photo-1545454675-3531b543be5d?auto=format&fit=crop&w=1200&q=80',
    ];

    return $fallbacks[$handle] ?? $fallbacks[$handleLeaf] ?? $fallbacks[$name] ?? '';
};

$seoDirectory = is_array($category['seo_directory'] ?? null) ? (array)$category['seo_directory'] : [];
$categoryDisplayName = trim((string)($category['name'] ?? ''));
$flattenSeoDirectory = function (array $items) use (&$flattenSeoDirectory): array {
    $flat = [];
    foreach ($items as $item) {
        if (!is_array($item)) {
            continue;
        }
        $name = trim((string)($item['name'] ?? ''));
        $url = trim((string)($item['url'] ?? ''));
        if ($name !== '' && $url !== '') {
            $flat[] = [
                'name' => $name,
                'url' => $url,
            ];
        }
        $children = $item['children'] ?? [];
        if (is_array($children) && $children !== []) {
            foreach ($flattenSeoDirectory($children) as $childItem) {
                $flat[] = $childItem;
            }
        }
    }

    return $flat;
};
$seoDirectoryFlat = $flattenSeoDirectory($seoDirectory);
$schemaJsonFlags = JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES;
$directoryJsonLd = [];
if ($seoDirectoryFlat !== []) {
    $directoryItems = [];
    foreach ($seoDirectoryFlat as $item) {
        $directoryItems[] = [
            '@type' => 'ListItem',
            'position' => count($directoryItems) + 1,
            'name' => (string)$item['name'],
            'url' => (string)$item['url'],
        ];
    }
    $directoryJsonLd = [
        '@context' => 'https://schema.org',
        '@type' => 'ItemList',
        'name' => trim($categoryDisplayName . ' ' . (string)__('分类目录')),
        'itemListElement' => $directoryItems,
    ];
}

$renderSeoDirectoryItems = function (array $items, bool $root = false) use (&$renderSeoDirectoryItems): void {
    if ($items === []) {
        return;
    }
    ?>
    <ul class="category-seo-directory__list<?= $root ? ' category-seo-directory__list--root' : ' category-seo-directory__children' ?>">
        <?php foreach ($items as $item): ?>
            <?php
            if (!is_array($item)) {
                continue;
            }
            $name = trim((string)($item['name'] ?? ''));
            $url = trim((string)($item['url'] ?? ''));
            if ($name === '' || $url === '') {
                continue;
            }
            $children = is_array($item['children'] ?? null) ? (array)$item['children'] : [];
            $isCurrent = !empty($item['is_current']);
            ?>
            <li class="category-seo-directory__item<?= $isCurrent ? ' category-seo-directory__item--current' : '' ?>" itemscope itemtype="https://schema.org/SiteNavigationElement">
                <a class="category-seo-directory__link" href="<?= htmlspecialchars($url, ENT_QUOTES, 'UTF-8') ?>" itemprop="url"<?= $isCurrent ? ' aria-current="page"' : '' ?>>
                    <span itemprop="name"><?= htmlspecialchars($name, ENT_QUOTES, 'UTF-8') ?></span>
                </a>
                <?php if ($children !== []): ?>
                    <?php $renderSeoDirectoryItems($children, false); ?>
                <?php endif; ?>
            </li>
        <?php endforeach; ?>
    </ul>
    <?php
};
?>

<?php if ($directoryJsonLd !== []): ?>
    <script type="application/ld+json"><?= json_encode($directoryJsonLd, $schemaJsonFlags) ?></script>
<?php endif; ?>

<?php if ($seoDirectory !== []): ?>
    <nav class="category-seo-directory" aria-labelledby="category-seo-directory-title">
        <div class="category-seo-directory__head">
            <p class="category-seo-directory__eyebrow"><?= __('分类目录') ?></p>
            <h2 id="category-seo-directory-title"><?= __('相关分类') ?></h2>
            <?php if ($categoryDisplayName !== ''): ?>
                <p><?= __('浏览 %{category} 的相关分类', ['category' => $categoryDisplayName]) ?></p>
            <?php endif; ?>
        </div>
        <?php $renderSeoDirectoryItems($seoDirectory, true); ?>
    </nav>
<?php endif; ?>

<?php if ($hasValidChildren): ?>
    <div class="category-children-grid">
        <?php foreach ($childCategories as $child): ?>
            <?php
            $childHandle = trim((string) ($child['handle'] ?? ''), '/');
            if ($childHandle === '') {
                continue;
            }

            $childUrl = $this->getUrl($categoryUrlService->buildCategoryPublicPath($child, $currentPath));
            $childName = htmlspecialchars($categoryUrlService->localizeCategoryDisplayName((string) ($child['name'] ?? '')));
            $childDescription = htmlspecialchars((string) ($child['description'] ?? ''));
            $childImage = $resolveCategoryCardImage($child);
            $grandChildren = $child['children'] ?? [];
            $grandChildrenCount = is_array($grandChildren) ? count($grandChildren) : 0;
            $cardClass = $childImage !== '' ? 'has-image' : 'is-placeholder';
            ?>
            <a href="<?= htmlspecialchars($childUrl) ?>" class="category-grid-item <?= $cardClass ?>">
                <div class="category-grid-item__media">
                    <?php if ($childImage !== ''): ?>
                        <div class="category-grid-item__image" style="background-image: url('<?= htmlspecialchars($childImage) ?>');"></div>
                        <div class="category-grid-item__image-overlay"></div>
                    <?php else: ?>
                        <div class="category-grid-item__image category-grid-item__image-placeholder">
                            <span class="category-grid-item__placeholder-orb category-grid-item__placeholder-orb--one"></span>
                            <span class="category-grid-item__placeholder-orb category-grid-item__placeholder-orb--two"></span>
                            <span class="category-grid-item__placeholder-label"><?= __('子分类') ?></span>
                            <div class="category-grid-item__placeholder-icon" aria-hidden="true">
                                <svg width="42" height="42" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M4 8.5C4 7.11929 5.11929 6 6.5 6H17.5C18.8807 6 20 7.11929 20 8.5V16.5C20 17.8807 18.8807 19 17.5 19H6.5C5.11929 19 4 17.8807 4 16.5V8.5Z" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M8 10H16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <path d="M8 14H13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                        </div>
                    <?php endif; ?>

                    <?php if ($grandChildrenCount > 0): ?>
                        <span class="category-grid-item__media-badge">
                            <?= __('%{count} 个子分类', ['count' => $grandChildrenCount]) ?>
                        </span>
                    <?php endif; ?>
                </div>

                <div class="category-grid-item__content">
                    <div class="category-grid-item__eyebrow-row">
                        <span class="category-grid-item__eyebrow"><?= __('子分类') ?></span>
                        <span class="category-grid-item__chevron" aria-hidden="true">
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M6.75 4.5L11.25 9L6.75 13.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </div>
                    <h3 class="category-grid-item__title"><?= $childName ?></h3>
                    <?php if ($childDescription !== ''): ?>
                        <p class="category-grid-item__desc"><?= $childDescription ?></p>
                    <?php endif; ?>

                    <div class="category-grid-item__meta<?= $grandChildrenCount > 0 ? '' : ' category-grid-item__meta--compact' ?>">
                        <?php if ($grandChildrenCount > 0): ?>
                            <span class="category-grid-item__badge">
                                <?= __('%{count} 个子分类', ['count' => $grandChildrenCount]) ?>
                            </span>
                        <?php endif; ?>
                        <span class="category-grid-item__meta-line" aria-hidden="true"></span>
                    </div>
                </div>
            </a>
        <?php endforeach; ?>
    </div>
<?php endif; ?>

<?php if (!is_array($products) || $products === []): ?>
    <?php if (!$hasValidChildren): ?>
        <div class="category-empty">
            <p><?= __('该分类下暂无商品') ?></p>
        </div>
    <?php endif; ?>
<?php else: ?>
        <?php
        $browseProductIdsForDom = array_values(array_filter(array_map(
            static fn (mixed $p): int => (int) (is_array($p) ? ($p['product_id'] ?? $p['entity_id'] ?? 0) : 0),
            is_array($products) ? $products : []
        )));
        ?>
        <div
            class="category-products-grid products-grid"
            data-weshop-filter-products-grid="canonical-category-products"
            data-browse-product-ids="<?= htmlspecialchars(json_encode($browseProductIdsForDom), ENT_QUOTES, 'UTF-8') ?>"
        >
            <?php foreach ($products as $product): ?>
                <?php
                if (!is_array($product)) {
                    continue;
                }

                $productId = (int) ($product['product_id'] ?? $product['entity_id'] ?? 0);
                $productName = htmlspecialchars((string) ($product['name'] ?? ''));
                $productDescription = htmlspecialchars((string) ($product['short_description'] ?? ''));
                $productPrice = (float) ($product['price'] ?? 0);
                $productImage = (string) ($product['image'] ?? '');
                $productHandle = (string) ($product['handle'] ?? '');
                $productSku = htmlspecialchars((string) ($product['sku'] ?? ''));
                $inStock = (bool) ($product['in_stock'] ?? ((int) ($product['stock'] ?? 0) > 0));
                $productUrl = $productHandle !== ''
                    ? $this->getUrl('product/' . $productHandle)
                    : $this->getUrl('weshop/product/view', ['id' => $productId]);
                ?>
                <div class="product-card" data-product-id="<?= $productId ?>">
                    <a href="<?= htmlspecialchars($productUrl) ?>" class="product-card__link">
                        <div class="product-card__image-wrapper">
                            <?php if ($productImage !== ''): ?>
                                <img
                                    src="<?= htmlspecialchars($productImage) ?>"
                                    alt="<?= $productName ?>"
                                    class="product-card__image"
                                    loading="lazy"
                                    decoding="async"
                                    fetchpriority="low"
                                >
                            <?php else: ?>
                                <div class="product-card__image-placeholder">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 7V5C3 3.89543 3.89543 3 5 3H19C20.1046 3 21 3.89543 21 5V7M3 7V19C3 20.1046 3.89543 21 5 21H19C20.1046 21 21 20.1046 21 19V7M3 7H21M7 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    </svg>
                                </div>
                            <?php endif; ?>
                            <?php if (!$inStock): ?>
                                <span class="product-card__out-of-stock"><?= __('缺货') ?></span>
                            <?php endif; ?>
                        </div>
                        <div class="product-card__content">
                            <h3 class="product-card__title"><?= $productName ?></h3>
                            <?php if ($productDescription !== ''): ?>
                                <p class="product-card__description"><?= $productDescription ?></p>
                            <?php endif; ?>

                            <div class="product-card__price">
                                <span class="product-card__price-current"><?= \Weline\Currency\Helper\CurrencyFormatter::formatConverted($productPrice) ?></span>
                            </div>

                            <?php if ($productSku !== ''): ?>
                                <div class="product-card__sku">
                                    <small><?= __('SKU: %{sku}', ['sku' => $productSku]) ?></small>
                                </div>
                            <?php endif; ?>
                        </div>
                    </a>
                </div>
            <?php endforeach; ?>
        </div>
<?php endif; ?>

<style>
.category-seo-directory {
    border-top: 1px solid var(--color-border-light, #e5e7eb);
    border-bottom: 1px solid var(--color-border-light, #e5e7eb);
    padding: 0.95rem 0 1rem;
    margin: 0 0 1.15rem;
}

.category-seo-directory__head {
    margin-bottom: 0.75rem;
}

.category-seo-directory__eyebrow {
    margin: 0 0 0.2rem;
    color: #565959;
    font-size: 0.76rem;
    line-height: 1.3;
}

.category-seo-directory__head h2 {
    margin: 0;
    color: var(--color-text-primary, #111);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
}

.category-seo-directory__head p:last-child {
    margin: 0.25rem 0 0;
    color: #565959;
    font-size: 0.86rem;
    line-height: 1.45;
}

.category-seo-directory__list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.category-seo-directory__list--root {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.65rem 1.35rem;
}

.category-seo-directory__item {
    min-width: 0;
}

.category-seo-directory__link {
    color: #007185;
    display: inline-block;
    font-size: 0.9rem;
    line-height: 1.35;
    text-decoration: none;
}

.category-seo-directory__link:hover,
.category-seo-directory__link:focus-visible {
    color: #c7511f;
    text-decoration: underline;
}

.category-seo-directory__item--current > .category-seo-directory__link {
    color: var(--color-text-primary, #111);
    font-weight: 700;
}

.category-seo-directory__children {
    border-left: 1px solid var(--color-border-light, #e5e7eb);
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
    margin-top: 0.34rem;
    padding-left: 0.75rem;
}

.category-seo-directory__children .category-seo-directory__link {
    font-size: 0.82rem;
}

.category-children-grid {
    --category-grid-gap: 1rem;
    --category-card-media-height: 132px;
    --category-card-content-height: 106px;
    --category-card-height: calc(var(--category-card-media-height) + var(--category-card-content-height));
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(176px, 1fr));
    gap: var(--category-grid-gap);
    width: 100%;
    max-height: calc((var(--category-card-height) * 2) + var(--category-grid-gap) + 0.45rem);
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.1rem 0.35rem 0.35rem 0.05rem;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    scrollbar-color: rgba(148, 163, 184, 0.7) rgba(226, 232, 240, 0.6);
    margin-bottom: 1.1rem;
}

.category-children-grid::-webkit-scrollbar {
    width: 8px;
}

.category-children-grid::-webkit-scrollbar-track {
    background: rgba(226, 232, 240, 0.6);
    border-radius: 999px;
}

.category-children-grid::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.78);
    border-radius: 999px;
}

.category-grid-item {
    --category-card-accent: #0f766e;
    --category-card-accent-soft: #ccfbf1;
    --category-card-accent-strong: #115e59;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.96) 100%);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 16px;
    padding: 0;
    text-decoration: none;
    color: var(--color-text-primary, #111);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: var(--category-card-height);
    min-height: 0;
    position: relative;
    box-shadow: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
}

.category-grid-item:nth-child(4n + 2) {
    --category-card-accent: #b45309;
    --category-card-accent-soft: #fef3c7;
    --category-card-accent-strong: #92400e;
}

.category-grid-item:nth-child(4n + 3) {
    --category-card-accent: #1d4ed8;
    --category-card-accent-soft: #dbeafe;
    --category-card-accent-strong: #1e40af;
}

.category-grid-item:nth-child(4n + 4) {
    --category-card-accent: #be185d;
    --category-card-accent-soft: #fce7f3;
    --category-card-accent-strong: #9d174d;
}

.category-grid-item::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.55);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
}

.category-grid-item:hover {
    border-color: color-mix(in srgb, var(--category-card-accent) 45%, white);
    box-shadow: none;
    transform: translateY(-2px);
    background-color: var(--color-bg-primary, #fff);
    text-decoration: none;
    color: var(--color-text-primary, #111);
}

.category-grid-item:hover::after,
.category-grid-item:focus-visible::after {
    opacity: 1;
}

.category-grid-item:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--category-card-accent) 55%, white);
    outline-offset: 3px;
}

.category-grid-item__media {
    position: relative;
    overflow: hidden;
}

.category-grid-item__image {
    width: 100%;
    height: var(--category-card-media-height);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--color-bg-secondary, #f3f4f6);
    display: flex;
    align-items: center;
    justify-content: center;
}

.category-grid-item__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.02) 0%, rgba(15, 23, 42, 0.18) 100%), linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0) 100%);
    pointer-events: none;
}

.category-grid-item__image-placeholder {
    position: relative;
