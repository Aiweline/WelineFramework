<?php
/**
 * Catalog category content fallback template.
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

/** @var \Weline\Framework\View\Template $this */

// WLS workers can reuse template instances across requests, so prefer current request data.
$categoriesCtx = $this->request->getData('categories') ?? null;
$requestCategory = $this->request->getData('category') ?? null;
$category = is_array($requestCategory) && !empty($requestCategory['category_id'])
    ? $requestCategory
    : ($this->getData('category') ?? null);

if ((!is_array($category) || empty($category['category_id']))
    && is_array($categoriesCtx)
    && isset($categoriesCtx['current'])
    && is_array($categoriesCtx['current'])) {
    $category = $categoriesCtx['current'];
}

if (!is_array($category) || empty($category['category_id'])) {
    return;
}

$childCategories = $category['children'] ?? [];
if (!is_array($childCategories) || $childCategories === []) {
    try {
        /** @var CategoryService $categoryService */
        $categoryService = ObjectManager::getInstance(CategoryService::class);
        $childCategories = $categoryService->getChildCategories((int) $category['category_id']);
    } catch (\Throwable) {
        $childCategories = [];
    }
}

$childCategories = is_array($childCategories)
    ? array_values(array_filter($childCategories, static fn (mixed $child): bool => is_array($child) && !empty($child['category_id']) && !empty($child['handle'])))
    : [];

$currentPath = trim((string) ($category['path'] ?? ''), '/');
if ($currentPath === '') {
    $currentHandle = trim((string) ($category['handle'] ?? ''), '/');
    if ($currentHandle !== '') {
        $currentPath = $currentHandle;
    }
}

$hasValidChildren = $childCategories !== [];
$products = $this->request->getData('products') ?? $this->getData('products') ?? [];
?>

<?php if ($hasValidChildren): ?>
    <div class="category-children-grid">
        <?php foreach ($childCategories as $child): ?>
            <?php
            $childHandle = trim((string) ($child['handle'] ?? ''), '/');
            if ($childHandle === '') {
                continue;
            }

            $childPath = $currentPath !== '' ? $currentPath . '/' . rawurlencode($childHandle) : rawurlencode($childHandle);
            $childUrl = $this->getUrl('catalog/category/' . $childPath);
            $childName = htmlspecialchars((string) ($child['name'] ?? ''));
            $childDescription = htmlspecialchars((string) ($child['description'] ?? ''));
            $childImage = (string) ($child['image'] ?? '');
            $grandChildren = $child['children'] ?? [];
            $grandChildrenCount = is_array($grandChildren) ? count($grandChildren) : 0;
            ?>
            <a href="<?= htmlspecialchars($childUrl) ?>" class="category-grid-item">
                <?php if ($childImage !== ''): ?>
                    <div class="category-grid-item__image" style="background-image: url('<?= htmlspecialchars($childImage) ?>');"></div>
                <?php else: ?>
                    <div class="category-grid-item__image category-grid-item__image-placeholder">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 7V5C3 3.89543 3.89543 3 5 3H19C20.1046 3 21 3.89543 21 5V7M3 7V19C3 20.1046 3.89543 21 5 21H19C20.1046 21 21 20.1046 21 19V7M3 7H21M7 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                <?php endif; ?>

                <div class="category-grid-item__content">
                    <h3 class="category-grid-item__title"><?= $childName ?></h3>
                    <?php if ($childDescription !== ''): ?>
                        <p class="category-grid-item__desc"><?= $childDescription ?></p>
                    <?php endif; ?>

                    <?php if ($grandChildrenCount > 0): ?>
                        <div class="category-grid-item__meta">
                            <span class="category-grid-item__badge">
                                <?= __('%{count} 个子分类', ['count' => $grandChildrenCount]) ?>
                            </span>
                        </div>
                    <?php endif; ?>
                </div>
            </a>
        <?php endforeach; ?>
    </div>
<?php else: ?>
    <?php if (!is_array($products) || $products === []): ?>
        <div class="category-empty">
            <p><?= __('该分类下暂无商品') ?></p>
        </div>
    <?php else: ?>
        <?php
        $browseProductIdsForDom = array_values(array_filter(array_map(
            static fn (mixed $p): int => (int) (is_array($p) ? ($p['product_id'] ?? $p['entity_id'] ?? 0) : 0),
            is_array($products) ? $products : []
        )));
        ?>
        <div
            class="category-products-grid products-grid"
            data-weshop-filter-products-grid="canonical-category-products"
            data-browse-product-ids="<?= htmlspecialchars(json_encode($browseProductIdsForDom), ENT_QUOTES, 'UTF-8') ?>"
        >
            <?php foreach ($products as $product): ?>
                <?php
                if (!is_array($product)) {
                    continue;
                }

                $productId = (int) ($product['product_id'] ?? $product['entity_id'] ?? 0);
                $productName = htmlspecialchars((string) ($product['name'] ?? ''));
                $productDescription = htmlspecialchars((string) ($product['short_description'] ?? ''));
                $productPrice = (float) ($product['price'] ?? 0);
                $productImage = (string) ($product['image'] ?? '');
                $productHandle = (string) ($product['handle'] ?? '');
                $productSku = htmlspecialchars((string) ($product['sku'] ?? ''));
                $inStock = (bool) ($product['in_stock'] ?? ((int) ($product['stock'] ?? 0) > 0));
                $productUrl = $productHandle !== '' ? $this->getUrl('product/' . $productHandle) : $this->getUrl('product/view', ['id' => $productId]);
                ?>
                <div class="product-card" data-product-id="<?= $productId ?>">
                    <a href="<?= htmlspecialchars($productUrl) ?>" class="product-card__link">
                        <div class="product-card__image-wrapper">
                            <?php if ($productImage !== ''): ?>
                                <img
                                    src="<?= htmlspecialchars($productImage) ?>"
                                    alt="<?= $productName ?>"
                                    class="product-card__image"
                                    loading="lazy"
                                >
                            <?php else: ?>
                                <div class="product-card__image-placeholder">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 7V5C3 3.89543 3.89543 3 5 3H19C20.1046 3 21 3.89543 21 5V7M3 7V19C3 20.1046 3.89543 21 5 21H19C20.1046 21 21 20.1046 21 19V7M3 7H21M7 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    </svg>
                                </div>
                            <?php endif; ?>
                            <?php if (!$inStock): ?>
                                <span class="product-card__out-of-stock"><?= __('缺货') ?></span>
                            <?php endif; ?>
                        </div>
                        <div class="product-card__content">
                            <h3 class="product-card__title"><?= $productName ?></h3>
                            <?php if ($productDescription !== ''): ?>
                                <p class="product-card__description"><?= $productDescription ?></p>
                            <?php endif; ?>

                            <div class="product-card__price">
                                <span class="product-card__price-current">¥<?= number_format($productPrice, 2) ?></span>
                            </div>

                            <?php if ($productSku !== ''): ?>
                                <div class="product-card__sku">
                                    <small><?= __('SKU: %{sku}', ['sku' => $productSku]) ?></small>
                                </div>
                            <?php endif; ?>
                        </div>
                    </a>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
<?php endif; ?>

