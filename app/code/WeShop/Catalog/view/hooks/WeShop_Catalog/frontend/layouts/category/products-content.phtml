<?php
/**
 * WeShop Catalog模块 - 分类产品列表Hook
 * 
 * 在分类页产品区域渲染该分类下的产品列表
 * Hook名称：WeShop_Catalog::frontend::layouts::category::products-content
 * 
 * @hook-priority 100      Hook优先级：100
 * @hook-sort-order 1      Hook排序顺序：1
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */

// 获取分类和产品数据（优先从模板数据，其次从 Request）
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Http\Request;
use WeShop\Catalog\Service\CategoryProductListHtmlCache;
use WeShop\Product\Service\ConfigurableProductService;

/** @var Request $request */
$request = ObjectManager::getInstance(Request::class);
$contentHtmlOverride = $request->getData('weshop_category_content_html_override') ?? null;
if (is_string($contentHtmlOverride) && $contentHtmlOverride !== '') {
    echo $contentHtmlOverride;
    return;
}

/** @var ConfigurableProductService $configurableService */
$configurableService = ObjectManager::getInstance(ConfigurableProductService::class);

$category = $request->getData('category') ?? $this->getData('category') ?? [];
$products = $request->getData('products') ?? $this->getData('products') ?? [];
$browseProductIdsForDom = array_values(array_filter(array_map(
    static fn (mixed $p): int => (int) (is_array($p) ? ($p['product_id'] ?? $p['entity_id'] ?? 0) : 0),
    is_array($products) ? $products : []
)));
$__productsHtmlCacheKey = null;
if (is_array($products)) {
    $__productsHtmlCacheKey = sha1((string)json_encode([
        'v' => 1,
        'ids' => $browseProductIdsForDom,
        'lang' => \Weline\Framework\App\State::getLangLocal(),
        'currency' => \Weline\Framework\App\State::getCurrency(),
    ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE));
    $__cachedProductsHtml = CategoryProductListHtmlCache::get($__productsHtmlCacheKey);
    if ($__cachedProductsHtml !== null) {
        echo $__cachedProductsHtml;
        return;
    }
    ob_start();
}
try {
    $request->getResponse()->setHeader(
        'X-WLS-Category-Debug-Hook-Products',
        'products=' . (is_array($products) ? count($products) : 0)
    );
} catch (\Throwable) {
}

// 如果有产品数据，显示产品列表
if (!empty($products)) {
    $configurableMap = $configurableService->getConfigurableMap($browseProductIdsForDom);
    ?>
    <div class="category-products">
        <h2 class="section-title"><?= htmlspecialchars($category['name'] ?? __('商品列表')) ?></h2>
        <p class="products-count"><?= sprintf(__('共 %d 件商品'), count($products)) ?></p>
        
        <div
            id="product-grid"
            class="products-grid"
            data-browse-product-ids="<?= htmlspecialchars(json_encode($browseProductIdsForDom), ENT_QUOTES, 'UTF-8') ?>"
        >
            <?php foreach ($products as $product): ?>
            <?php
            $productId = (int)($product['product_id'] ?? 0);
            $name = $product['name'] ?? '';
            $shortDescription = $product['short_description'] ?? '';
            $price = (float)($product['price'] ?? 0);
            $image = $product['image'] ?? '';
            $sku = $product['sku'] ?? '';
            $handle = $product['handle'] ?? '';
            $inStock = $product['in_stock'] ?? ((int)($product['stock'] ?? 0) > 0);
            
            // 检查是否为可配置产品（有子产品）
            $isConfigurable = $productId > 0 && !empty($configurableMap[$productId]);
            
            // 构建产品链接（使用 /product/{handle} 格式）
            $productUrl = !empty($handle) 
                ? $this->getUrl('product/' . $handle) 
                : $this->getUrl('weshop/product/view', ['id' => $productId]);
            ?>
            <div class="product-card" data-product-id="<?= $productId ?>">
                <div class="product-card-image">
                    <a href="<?= htmlspecialchars($productUrl) ?>" class="product-image-link">
                        <?php if (!empty($image)): ?>
                        <img src="<?= htmlspecialchars($image) ?>" 
                             alt="<?= htmlspecialchars($name) ?>" 
                             class="product-image"
                             loading="lazy" />
                        <?php else: ?>
                        <div class="product-image-placeholder">
                            <span>📷</span>
                        </div>
                        <?php endif; ?>
                    </a>
                    
                    <?php if (!$inStock): ?>
                    <div class="product-badge out-of-stock"><?= __('缺货') ?></div>
                    <?php endif; ?>
                    
                    <div class="product-quick-actions">
                        <button type="button" 
                                class="quick-action-btn btn-wishlist" 
                                data-product-id="<?= $productId ?>"
                                title="<?= __('收藏') ?>">
                            ❤
                        </button>
                    </div>
                </div>
                
                <div class="product-card-info">
                    <h3 class="product-name">
                        <a href="<?= htmlspecialchars($productUrl) ?>"><?= htmlspecialchars($name) ?></a>
                    </h3>
                    
                    <?php if (!empty($shortDescription)): ?>
                    <p class="product-description"><?= htmlspecialchars(mb_substr($shortDescription, 0, 60)) ?><?= mb_strlen($shortDescription) > 60 ? '...' : '' ?></p>
                    <?php endif; ?>
                    
                    <div class="product-price-row">
                        <span class="product-price"><?= \Weline\Currency\Helper\CurrencyFormatter::formatConverted($price) ?></span>
                    </div>
                    
                    <?php 
                    // 使用hook渲染加购按钮（支持slot替换）
                    echo $this->getHook('WeShop_Product::frontend::product::add-to-cart::button', [
                        'product' => $product,
                        'product_id' => $productId,
                        'in_stock' => $inStock,
                        'is_configurable' => $isConfigurable,
                        'button_class' => 'btn-add-to-cart',
                    ]);
                    ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
    
    <?php 
    // 渲染规格选择弹窗（只渲染一次）
    echo $this->getHook('WeShop_Product::frontend::product::add-to-cart::options-popup');
    ?>
    <?php
} else {
    // 如果没有产品，显示空状态
    ?>
    <div class="no-products">
        <span class="no-products-icon">📭</span>
        <p class="no-products-text"><?= __('该分类下暂无商品') ?></p>
        <a href="<?= $this->getUrl('weshop') ?>" class="btn-back-home"><?= __('返回首页') ?></a>
    </div>
    <?php
}

?>
<?php
if ($__productsHtmlCacheKey !== null) {
    $__productsHtml = (string)ob_get_clean();
    CategoryProductListHtmlCache::set($__productsHtmlCacheKey, $__productsHtml);
    echo $__productsHtml;
}
?>
