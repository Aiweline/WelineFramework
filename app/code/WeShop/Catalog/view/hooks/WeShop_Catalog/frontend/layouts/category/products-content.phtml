<script>
(function() {
    var cartApiPromise = null;

    function getCartApi() {
        if (!cartApiPromise) {
            cartApiPromise = Promise.resolve(window.Weline.Api.resource('cart'));
        }

        return cartApiPromise;
    }

    function updateCartCount(count) {
        document.querySelectorAll('.cart-count, [data-cart-count]').forEach(function(el) {
            el.textContent = count;
            el.style.display = count > 0 ? '' : 'none';
        });
    }

    function addToCart(productId, qty, btn) {
        getCartApi().then(function (CartApi) {
            return CartApi.add({product_id: parseInt(productId, 10), qty: parseInt(qty || 1, 10)}, {silent: true});
        }).then(function(response) {
            var payload = response && response.data ? response.data : (response || {});

            if (payload.success) {
                updateCartCount(parseInt(payload.cart_count || 0, 10));
                btn.classList.add('added');
                var text = btn.querySelector('.btn-text') || btn.querySelector('span');
                if (text) {
                    var originalText = text.textContent;
                    text.textContent = '已加入';
                    setTimeout(function() { text.textContent = originalText; }, 1600);
                }
                document.dispatchEvent(new CustomEvent('weshop:cart:added', { detail: payload }));
            } else {
                document.dispatchEvent(new CustomEvent('weshop:cart:error', { detail: payload }));
            }
        }).catch(function(error) {
            document.dispatchEvent(new CustomEvent('weshop:cart:error', { detail: {message: error && error.message ? error.message : String(error)} }));
        }).finally(function() {
            btn.disabled = false;
            btn.classList.remove('loading');
        });
    }

    document.querySelectorAll('.btn-add-to-cart').forEach(function(btn) {
        if (btn.dataset.weshopCatalogAddBound === '1') {
            return;
        }
        btn.dataset.weshopCatalogAddBound = '1';
        btn.dataset.action = btn.dataset.action || 'add-to-cart';
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var productId = this.dataset.productId;
            if (!productId || this.disabled) {
                return;
            }
            this.disabled = true;
            this.classList.add('loading');
            addToCart(productId, 1, this);
        });
    });

    // 加入购物车由 cart.js 模块通过事件委托处理
    // 按钮使用 data-action="add-to-cart" 属性
    
    // 收藏
    document.querySelectorAll('.btn-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var productId = this.dataset.productId;
            
            var event = new CustomEvent('weshop:addToWishlist', {
                detail: { productId: productId }
            });
            document.dispatchEvent(event);
            
            // 切换图标
            if (this.textContent.trim() === '❤') {
                this.textContent = '💖';
            } else {
                this.textContent = '❤';
            }
        });
    });
    
    // 确保购物车模块已加载
    if (window.Weline && window.Weline.declare) {
        window.Weline.declare('cart', true); // 声明并立即加载购物车模块
    }
})();
</script>
