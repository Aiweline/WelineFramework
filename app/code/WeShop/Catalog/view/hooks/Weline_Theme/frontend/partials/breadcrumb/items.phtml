<?php
/**
 * Catalog 分类面包屑 Hook
 *
 * Hook 名称：Weline_Theme::frontend::partials::breadcrumb::items
 *
 * 作用：
 * - 在主题的面包屑片段中输出「真实的分类面包屑」
 * - 仅在有分类数据时输出；否则交给主题默认面包屑渲染
 *
 * @hook-priority 150      Hook优先级：150（composer 位置默认优先级）
 * @hook-sort-order 0      Hook排序顺序：0（默认值）
 * @hook-solo false        Hook独享：false（不独占，与其它 Hook 共存）
 */

/** @var \Weline\Framework\View\Template $this */

// 分类数据通常由 WeShop\Catalog\Controller\Frontend\Category\View 分配：$this->assign('category', $categoryData);
// 优先从模板数据中获取，如果没有则回退到 Request->categories.current
$category = $this->getData('category') ?? null;

if (!is_array($category) || empty($category['name'])) {
    // 从请求对象中获取 Router 预先挂载的分类数据
    $categoriesCtx = $this->request->getData('categories') ?? null;
    if (is_array($categoriesCtx) && isset($categoriesCtx['current']) && is_array($categoriesCtx['current'])) {
        $category = $categoriesCtx['current'];
        // 如果 Router 同时提供了父级链，则合并到 category['breadcrumbs'] 中，方便统一处理
        if (!isset($category['breadcrumbs']) && isset($categoriesCtx['breadcrumbs']) && is_array($categoriesCtx['breadcrumbs'])) {
            $category['breadcrumbs'] = $categoriesCtx['breadcrumbs'];
        }
    }
}

// 如果最终仍然没有分类数据，直接返回，由主题默认面包屑负责兜底
if (!is_array($category) || empty($category['name'])) {
    return;
}

// 从 meta / 局部数据中读取分隔符（如未配置则使用 /）
$meta = $this->getData('meta') ?? [];
$separator = $meta['separator'] ?? ($this->getData('separator') ?? '/');
// 构建面包屑项（支持层级 URL）
$items = [];

// 1. 首页
$items[] = [
    'text' => (string)__('首页'),
    'url'  => $this->getUrl(''),
];

// 2. 父级分类链（CategoryService 已在控制器里生成 breadcrumbs）
$breadcrumbs = $category['breadcrumbs'] ?? [];
$pathParts = [];
if (is_array($breadcrumbs)) {
    foreach ($breadcrumbs as $bc) {
        if (!is_array($bc)) {
            continue;
        }
        $text = (string)($bc['name'] ?? '');
        if ($text === '') {
            continue;
        }
        $handle = trim((string)($bc['handle'] ?? ''), '/');
        if ($handle !== '') {
            // 每一段单独进行 URL 编码，避免斜杠被转义
            $pathParts[] = rawurlencode($handle);
            $urlPath = implode('/', $pathParts);
            $url = $this->getUrl('catalog/category/' . $urlPath);
        } else {
            $url = '';
        }
        $items[] = [
            'text' => $text,
            'url'  => $url,
        ];
    }
}

// 3. 当前分类（不带链接，作为激活态）
$currentHandle = trim((string)($category['handle'] ?? ''), '/');
if ($currentHandle !== '') {
    $pathParts[] = rawurlencode($currentHandle);
}
$items[] = [
    'text' => (string)($category['name'] ?? ''),
    'url'  => '', // 当前分类不加链接，作为激活项
];

// 如果最终没有有效项，则不输出任何内容
if (empty($items)) {
    return;
}
?>
<ol class="breadcrumb-list">
    <?php foreach ($items as $index => $item): ?>
        <li class="breadcrumb-item <?= empty($item['url']) ? 'active' : '' ?>">
            <?php if (!empty($item['url'])): ?>
                <a href="<?= htmlspecialchars($item['url']) ?>">
                    <?= htmlspecialchars($item['text'] ?? '') ?>
                </a>
            <?php else: ?>
                <span><?= htmlspecialchars($item['text'] ?? '') ?></span>
            <?php endif; ?>
        </li>
        <?php if ($index < count($items) - 1): ?>
            <span class="breadcrumb-separator"><?= htmlspecialchars($separator) ?></span>
        <?php endif; ?>
    <?php endforeach; ?>
</ol>

