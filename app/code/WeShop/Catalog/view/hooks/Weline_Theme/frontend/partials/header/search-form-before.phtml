<?php
/**
 * Search Form Category Dropdown Hook
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

/** @var CategoryService $categoryService */
$categoryService = ObjectManager::getInstance(CategoryService::class);
$categoryOptions = $categoryService->getHeaderSearchCategoryOptions(0);
$selectedCategory = (string)($this->request->getParam('category') ?? '');

if (empty($categoryOptions)) {
    return;
}
?>

<div class="search-category-dropdown">
    <select name="category" class="search-category-select" title="<lang>选择分类</lang>">
        <option value=""><lang>全部分类</lang></option>
        <?php foreach ($categoryOptions as $option): ?>
            <?php
            $rawValue = (string)($option['value'] ?? '');
            $value = htmlspecialchars($rawValue, ENT_QUOTES, 'UTF-8');
            $label = (string)($option['label'] ?? '');
            $selected = ($selectedCategory === $rawValue) ? 'selected' : '';
            ?>
            <option value="<?= $value ?>" <?= $selected ?> data-level="<?= (int)($option['level'] ?? 0) ?>" data-display-label="<?= htmlspecialchars((string)($option['display_label'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"><?= $label ?></option>
        <?php endforeach; ?>
    </select>
    <div class="search-category-facade">
        <span class="search-category-label">
            <?php if ($selectedCategory): ?>
                <?php
                $selectedLabel = '全部分类';
                foreach ($categoryOptions as $option) {
                    if ((string)($option['value'] ?? '') === $selectedCategory) {
                        $selectedLabel = (string)($option['display_label'] ?? $option['label'] ?? '全部分类');
                        break;
                    }
                }
                ?>
                <lang><?= htmlspecialchars($selectedLabel, ENT_QUOTES, 'UTF-8') ?></lang>
            <?php else: ?>
                <lang>全部分类</lang>
            <?php endif; ?>
        </span>
        <i class="fas fa-chevron-down"></i>
    </div>
</div>
