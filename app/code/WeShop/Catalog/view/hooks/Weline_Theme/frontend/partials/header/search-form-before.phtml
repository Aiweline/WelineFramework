<?php
/**
 * Search Form Category Dropdown Hook
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

/** @var CategoryService $categoryService */
$categoryService = ObjectManager::getInstance(CategoryService::class);
$categoryOptions = $categoryService->getHeaderSearchCategoryOptions(0);
$selectedCategory = '';
if (method_exists($this->request, 'getParameterBag')) {
    $selectedCategory = (string)($this->request->getParameterBag()->getQuery('category', '') ?? '');
} else {
    $selectedCategory = (string)(\Weline\Framework\Env\WelineEnv::getGet('category', '') ?? '');
}

if (empty($categoryOptions)) {
    return;
}

$searchCategoryLabel = static function ($value) use ($categoryService): string {
    $key = trim((string)($value ?? ''));
    if ($key === '') {
        return '';
    }
    $translated = (string)__($key);
    if ($translated !== $key) {
        return $translated;
    }
    return $categoryService->localizeCategoryDisplayName($key);
};
$searchCategoryEsc = static function ($value) use ($searchCategoryLabel): string {
    return htmlspecialchars($searchCategoryLabel($value), ENT_QUOTES, 'UTF-8');
};
?>

<div class="search-category-dropdown">
    <select name="category" class="search-category-select" title="<?= $searchCategoryEsc('选择分类') ?>">
        <option value=""><?= $searchCategoryEsc('全部分类') ?></option>
        <?php foreach ($categoryOptions as $option): ?>
            <?php
            $rawValue = (string)($option['value'] ?? '');
            $value = htmlspecialchars($rawValue, ENT_QUOTES, 'UTF-8');
            $label = (string)($option['label'] ?? '');
            $selected = ($selectedCategory === $rawValue) ? 'selected' : '';
            ?>
            <option value="<?= $value ?>" <?= $selected ?> data-level="<?= (int)($option['level'] ?? 0) ?>" data-display-label="<?= htmlspecialchars((string)($option['display_label'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"><?= $label ?></option>
        <?php endforeach; ?>
    </select>
    <div class="search-category-facade">
        <span class="search-category-label">
            <?php if ($selectedCategory): ?>
                <?php
                $selectedLabel = $searchCategoryLabel('全部分类');
                foreach ($categoryOptions as $option) {
                    if ((string)($option['value'] ?? '') === $selectedCategory) {
                        $selectedLabel = $searchCategoryLabel($option['display_label'] ?? $option['label'] ?? '全部分类');
                        break;
                    }
                }
                ?>
                <?= htmlspecialchars($selectedLabel, ENT_QUOTES, 'UTF-8') ?>
            <?php else: ?>
                <?= $searchCategoryEsc('全部分类') ?>
            <?php endif; ?>
        </span>
        <i class="fas fa-chevron-down"></i>
    </div>
</div>
