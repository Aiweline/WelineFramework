<?php
/**
 * Search Form Category Dropdown Hook
 * 在搜索表单之前渲染分类下拉菜单
 * Hook名称：Weline_Theme::frontend::partials::header::search-form-before
 * 
 * @hook-priority 150      Hook优先级：150（composer位置默认优先级）
 * @hook-sort-order 0      Hook排序顺序：0（默认值）
 * @hook-solo false        Hook独享：false（不独占）
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

// 获取分类服务
/** @var CategoryService $categoryService */
$categoryService = ObjectManager::getInstance(CategoryService::class);

// 获取分类树（只获取启用的分类）
$categories = $categoryService->getCategoryTree(0);

// 获取当前选中的分类
$selectedCategory = $this->request->getParam('category') ?? '';

// 递归函数：将分类数据转换为选项格式（支持多级分类）
$convertCategoryToOptions = function($category, $level = 0, $parentPath = '') use (&$convertCategoryToOptions) {
    // 只处理启用的分类，支持所有层级
    if (empty($category['is_active']) || $category['is_active'] != 1) {
        return [];
    }
    
    $options = [];
    
    // 获取分类的 url_key
    $urlKey = $category['url_key'] ?? '';
    
    // 构建完整的路径（用于 value）
    $fullPath = '';
    if (!empty($urlKey)) {
        // 如果有父级路径，拼接完整路径
        if (!empty($parentPath)) {
            $fullPath = $parentPath . '/' . $urlKey;
        } else {
            $fullPath = $urlKey;
        }
    } else {
        // 如果没有 url_key，使用 category_id 构建路径
        $categoryId = $category['category_id'] ?? '';
        if (!empty($parentPath)) {
            $fullPath = $parentPath . '/' . $categoryId;
        } else {
            $fullPath = $categoryId;
        }
    }
    
    // 使用完整路径作为 value，支持多级选择
    $value = $fullPath;
    
    // 构建显示标签（使用缩进显示层级关系）
    $label = $category['name'] ?? '';
    // 如果有层级，添加缩进前缀（使用非断行空格和分隔符）
    if ($level > 0) {
        $indent = str_repeat('&nbsp;&nbsp;&nbsp;', $level); // 每级缩进3个空格
        $separator = $level > 1 ? ' › ' : ' > '; // 多级使用 › 符号
        $label = $indent . $separator . $label;
    }
    
    // 添加当前分类选项
    $options[] = [
        'value' => $value,
        'label' => $label,
        'display_label' => $category['name'] ?? '', // 保存原始标签用于显示
        'level' => $level,
        'full_path' => $fullPath
    ];
    
    // 递归处理子分类（支持所有层级）
    if (!empty($category['children']) && is_array($category['children'])) {
        foreach ($category['children'] as $child) {
            $childOptions = $convertCategoryToOptions($child, $level + 1, $fullPath);
            $options = array_merge($options, $childOptions);
        }
    }
    
    return $options;
};

// 转换分类数据为选项（只包含启用的分类）
$categoryOptions = [];
foreach ($categories as $category) {
    $options = $convertCategoryToOptions($category);
    $categoryOptions = array_merge($categoryOptions, $options);
}

// 如果分类为空，不输出任何内容（让默认的分类下拉菜单显示）
if (empty($categoryOptions)) {
    return;
}
?>

<!-- 分类下拉菜单 -->
<div class="search-category-dropdown">
    <select name="category" class="search-category-select" title="<lang>选择分类</lang>">
        <option value=""><lang>全部分类</lang></option>
        <?php foreach ($categoryOptions as $option): ?>
            <?php
            $value = htmlspecialchars($option['value']);
            // 使用带缩进的标签显示层级关系
            $label = $option['label']; // 已经包含 HTML 实体（&nbsp;），不需要再次转义
            $selected = ($selectedCategory === $value) ? 'selected' : '';
            ?>
            <option value="<?= $value ?>" <?= $selected ?> data-level="<?= $option['level'] ?>" data-display-label="<?= htmlspecialchars($option['display_label']) ?>"><?= $label ?></option>
        <?php endforeach; ?>
    </select>
    <div class="search-category-facade">
        <span class="search-category-label">
            <?php if ($selectedCategory): ?>
                <?php
                $selectedLabel = '全部分类';
                foreach ($categoryOptions as $option) {
                    if (($option['value'] ?? '') === $selectedCategory) {
                        // 使用原始显示标签（不包含缩进），更简洁
                        $selectedLabel = $option['display_label'] ?? $option['label'] ?? '全部分类';
                        break;
                    }
                }
                ?>
                <lang><?= htmlspecialchars($selectedLabel) ?></lang>
            <?php else: ?>
                <lang>全部分类</lang>
            <?php endif; ?>
        </span>
        <i class="fas fa-chevron-down"></i>
    </div>
</div>
