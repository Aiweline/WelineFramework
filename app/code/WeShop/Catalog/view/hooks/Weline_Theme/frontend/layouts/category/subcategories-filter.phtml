<script>
(function() {
    // 展开/折叠函数
    function toggleCategoryItem(element) {
        const targetId = element.getAttribute('data-target');
        if (!targetId) {
            return;
        }
        
        const target = document.getElementById(targetId);
        if (!target) {
            return;
        }
        
        // 找到包装器（wrapper）
        const wrapper = target.parentElement;
        if (!wrapper || !wrapper.classList.contains('category-subcategories-nested-wrapper')) {
            return;
        }
        
        // 找到对应的按钮和 wrapper
        const wrapperElement = element.classList.contains('category-subcategory-wrapper-clickable') 
            ? element 
            : element.closest('.category-subcategory-wrapper-clickable');
        
        if (!wrapperElement) {
            return;
        }
        
        const toggleButton = wrapperElement.querySelector('.category-subcategory-toggle');
        const isExpanded = toggleButton ? toggleButton.getAttribute('aria-expanded') === 'true' : wrapper.classList.contains('expanded');
        
        if (isExpanded) {
            // 折叠
            wrapper.classList.remove('expanded');
            if (toggleButton) {
                toggleButton.setAttribute('aria-expanded', 'false');
            }
        } else {
            // 展开
            wrapper.classList.add('expanded');
            if (toggleButton) {
                toggleButton.setAttribute('aria-expanded', 'true');
            }
        }
    }
    
    // 初始化子分类展开/折叠功能
    document.addEventListener('DOMContentLoaded', function() {
        // 处理按钮点击
        const toggles = document.querySelectorAll('.category-subcategory-toggle');
        toggles.forEach(function(toggle) {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                toggleCategoryItem(this);
            });
        });
        
        // 处理 wrapper 点击（除了链接区域）
        const wrappers = document.querySelectorAll('.category-subcategory-wrapper-clickable');
        wrappers.forEach(function(wrapper) {
            wrapper.addEventListener('click', function(e) {
                // 如果点击的是链接或链接容器，不处理（链接会自己处理跳转）
                if (e.target.closest('.category-subcategory-link') || e.target.closest('.category-subcategory-link-wrapper')) {
                    return;
                }
                // 如果点击的是按钮，不处理（按钮已经处理了）
                if (e.target.closest('.category-subcategory-toggle')) {
                    return;
                }
                // 其他区域点击（包括链接右侧的空白区域），触发展开/折叠
                toggleCategoryItem(this);
            });
        });
    });
})();
</script>
