<?php
/**
 * Catalog 分类子分类筛选 Hook
 *
 * Hook 名称：Weline_Theme::frontend::layouts::category::subcategories-filter
 *
 * 作用：
 * - 在分类筛选侧边栏中显示子分类列表
 * - 如果存在子分类，显示子分类筛选选项
 * - 提供向上返回父分类的链接
 *
 * @hook-priority 150      Hook优先级：150（composer 位置默认优先级）
 * @hook-sort-order 0      Hook排序顺序：0（默认值）
 * @hook-solo false        Hook独享：false（不独占，与其它 Hook 共存）
 */

/** @var \Weline\Framework\View\Template $this */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

// 优先从模板数据中获取分类信息
$category = $this->getData('category') ?? null;

// 如果模板数据中没有，从 Request 中获取
if (!is_array($category) || empty($category['category_id'])) {
    $categoriesCtx = $this->request->getData('categories') ?? null;
    if (is_array($categoriesCtx) && isset($categoriesCtx['current']) && is_array($categoriesCtx['current'])) {
        $category = $categoriesCtx['current'];
    }
}

// 如果没有分类数据，直接返回
if (!is_array($category) || empty($category['category_id'])) {
    return;
}

// 获取子分类树（包含所有层级的子分类）
$childCategories = $category['children'] ?? [];

// 如果子分类为空，尝试从服务中获取完整的分类树
if (empty($childCategories)) {
    try {
        /** @var CategoryService $categoryService */
        $categoryService = ObjectManager::getInstance(CategoryService::class);
        // 获取分类树（递归获取所有子分类）
        $childCategories = $categoryService->getCategoryTree((int)$category['category_id']);
    } catch (\Exception $e) {
        $childCategories = [];
    }
} else {
    // 如果已有子分类数据，但可能没有递归的子分类，尝试补充
    try {
        /** @var CategoryService $categoryService */
        $categoryService = ObjectManager::getInstance(CategoryService::class);
        // 递归补充每个子分类的子分类
        $enrichChildren = function($children) use (&$enrichChildren, $categoryService) {
            foreach ($children as &$child) {
                if (empty($child['children']) || !is_array($child['children'])) {
                    $grandChildren = $categoryService->getCategoryTree((int)($child['category_id'] ?? 0));
                    if (!empty($grandChildren)) {
                        $child['children'] = $grandChildren;
                    }
                }
                if (!empty($child['children']) && is_array($child['children'])) {
                    $child['children'] = $enrichChildren($child['children']);
                }
            }
            return $children;
        };
        $childCategories = $enrichChildren($childCategories);
    } catch (\Exception $e) {
        // 忽略错误，使用原始数据
    }
}

// 获取父分类信息（用于向上返回）
$parentCategory = null;
$parentUrl = '';

// 从 breadcrumbs 中获取直接父分类
$breadcrumbs = $category['breadcrumbs'] ?? [];
if (!empty($breadcrumbs)) {
    // 取最后一个 breadcrumb（直接父分类）
    $parentCategory = end($breadcrumbs);
    if (is_array($parentCategory) && !empty($parentCategory['path'])) {
        // 构建父分类 URL
        $parentPath = $parentCategory['path'];
        $parentUrl = $this->getUrl('catalog/category/' . $parentPath);
    }
} elseif (!empty($category['parent_id']) && (int)$category['parent_id'] > 0) {
    // 如果没有 breadcrumbs，但有 parent_id，尝试查询父分类
    try {
        /** @var CategoryService $categoryService */
        $categoryService = ObjectManager::getInstance(CategoryService::class);
        $parentCat = $categoryService->getCategory((int)$category['parent_id']);
        if ($parentCat && $parentCat->getId()) {
            $parentHandle = trim((string)($parentCat->getData(\WeShop\Catalog\Model\Category::fields_HANDLE) ?? ''), '/');
            if ($parentHandle !== '') {
                $parentCategory = [
                    'category_id' => $parentCat->getId(),
                    'name' => $parentCat->getData(\WeShop\Catalog\Model\Category::fields_NAME) ?? '',
                    'handle' => $parentHandle,
                ];
                $parentUrl = $this->getUrl('catalog/category/' . rawurlencode($parentHandle));
            }
        }
    } catch (\Exception $e) {
        // 忽略错误
    }
}

// 如果既没有子分类，也没有父分类，则不显示任何内容
if (empty($childCategories) && empty($parentCategory)) {
    return;
}
?>

<div class="category-subcategories-filter">
    <?php if (!empty($parentCategory)): ?>
        <!-- 向上返回父分类 -->
        <div class="category-filter-section category-filter-parent">
            <div class="category-filter-section-header">
                <h4 class="category-filter-section-title">
                    <lang>上级分类</lang>
                </h4>
            </div>
            <div class="category-filter-section-content">
                <a href="<?= htmlspecialchars($parentUrl) ?>" class="category-filter-parent-link">
                    <span class="category-filter-parent-icon">←</span>
                    <span class="category-filter-parent-name"><?= htmlspecialchars($parentCategory['name'] ?? '') ?></span>
                </a>
            </div>
        </div>
    <?php endif; ?>
    
    <?php if (!empty($childCategories)): ?>
        <!-- 子分类列表 -->
        <div class="category-filter-section category-filter-subcategories">
            <div class="category-filter-section-header">
                <h4 class="category-filter-section-title">
                    <lang>子分类</lang>
                    <span class="category-filter-count">(<?= count($childCategories) ?>)</span>
                </h4>
            </div>
            <div class="category-filter-section-content">
                <ul class="category-subcategories-list">
                    <?php
                    // 递归渲染子分类的函数
                    $template = $this; // 保存模板实例引用
                    $renderCategoryItem = function($cat, $level = 0, $parentPath = '') use (&$renderCategoryItem, $category, $template) {
                        $catHandle = trim((string)($cat['handle'] ?? ''), '/');
                        if ($catHandle === '') {
                            return '';
                        }
                        
                        // 获取当前分类的路径
                        $currentPath = $parentPath !== '' ? $parentPath : ($category['path'] ?? '');
                        if ($currentPath === '') {
                            $currentHandle = trim((string)($category['handle'] ?? ''), '/');
                            if ($currentHandle !== '') {
                                $currentPath = $currentHandle;
                            }
                        }
                        
                        // 构建完整的层级路径
                        $catPath = $currentPath !== '' ? $currentPath . '/' . rawurlencode($catHandle) : rawurlencode($catHandle);
                        $catUrl = $template->getUrl('catalog/category/' . $catPath);
                        $catName = htmlspecialchars($cat['name'] ?? '');
                        
                        // 获取分类图标（优先从已加载的数据中获取，如果没有则从 EAV 属性获取）
                        $catIcon = $cat['icon'] ?? '';
                        $showIcon = $cat['show_icon'] ?? true;
                        
                        // 如果数据中没有图标信息，尝试从 EAV 属性获取
                        if (empty($catIcon) || !isset($cat['show_icon'])) {
                            try {
                                /** @var \WeShop\Catalog\Model\Category $categoryModel */
                                $categoryModel = ObjectManager::getInstance(\WeShop\Catalog\Model\Category::class);
                                $categoryModel->load((int)($cat['category_id'] ?? 0));
                                
                                if ($categoryModel->getId()) {
                                    // 获取图标属性值
                                    if (empty($catIcon)) {
                                        $iconValue = $categoryModel->getAttributeValue('icon');
                                        $catIcon = $iconValue ?: '';
                                    }
                                    
                                    // 检查是否显示图标（通过 EAV 属性 show_icon 控制，默认为 true）
                                    if (!isset($cat['show_icon'])) {
                                        $showIconValue = $categoryModel->getAttributeValue('show_icon');
                                        $showIcon = $showIconValue !== null ? (bool)$showIconValue : true; // 默认显示图标
                                    }
                                }
                            } catch (\Exception $e) {
                                // 如果获取失败，使用默认值
                                if (empty($catIcon)) {
                                    $catIcon = '';
                                }
                                if (!isset($cat['show_icon'])) {
                                    $showIcon = true; // 默认显示图标
                                }
                            }
                        }
                        
                        // 检查是否有子分类
                        $hasChildren = !empty($cat['children']) && is_array($cat['children']) && count($cat['children']) > 0;
                        $childrenCount = $hasChildren ? count($cat['children']) : 0;
                        $itemId = 'category-filter-item-' . ($cat['category_id'] ?? uniqid());
                        
                        $html = '<li class="category-subcategory-item' . ($hasChildren ? ' has-children' : '') . '" data-level="' . $level . '">';
                        // 如果有子分类，给 wrapper 添加可点击的类和数据属性
                        $wrapperClass = 'category-subcategory-wrapper';
                        $wrapperData = '';
                        if ($hasChildren) {
                            $wrapperClass .= ' category-subcategory-wrapper-clickable';
                            $wrapperData = ' data-target="' . htmlspecialchars($itemId . '-children') . '"';
                        }
                        $html .= '<div class="' . $wrapperClass . '"' . $wrapperData . '>';
                        
                        // 展开/折叠按钮（仅当有子分类时显示）
                        if ($hasChildren) {
                            $html .= '<button type="button" class="category-subcategory-toggle" aria-label="展开/折叠子分类" aria-expanded="false" data-target="' . htmlspecialchars($itemId . '-children') . '">';
                            $html .= '<svg class="category-subcategory-toggle-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">';
                            $html .= '<path d="M4.5 3L7.5 6L4.5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>';
                            $html .= '</svg>';
                            $html .= '</button>';
                        } else {
                            $html .= '<span class="category-subcategory-toggle-spacer"></span>';
                        }
                        
                        // 分类链接容器（链接宽度自适应，容器外可点击展开）
                        $html .= '<span class="category-subcategory-link-wrapper">';
                        $html .= '<a href="' . htmlspecialchars($catUrl) . '" class="category-subcategory-link" onclick="event.stopPropagation();">';
                        
                        // 显示图标（如果启用且有图标值）
                        if ($showIcon && !empty($catIcon)) {
                            $html .= '<i class="category-subcategory-icon ' . htmlspecialchars($catIcon) . '"></i>';
                        }
                        
                        $html .= '<span class="category-subcategory-name">' . $catName . '</span>';
                        
                        // 如果有子分类，显示子分类个数
                        if ($hasChildren && $childrenCount > 0) {
                            $html .= '<span class="category-subcategory-count"> (' . $childrenCount . ')</span>';
                        }
                        $html .= '</a>';
                        $html .= '</span>';
                        
                        $html .= '</div>';
                        
                        // 子分类列表（默认折叠）
                        if ($hasChildren) {
                            $html .= '<div class="category-subcategories-nested-wrapper">';
                            $html .= '<ul class="category-subcategories-list category-subcategories-nested" id="' . htmlspecialchars($itemId . '-children') . '">';
                            foreach ($cat['children'] as $child) {
                                $html .= $renderCategoryItem($child, $level + 1, $catPath);
                            }
                            $html .= '</ul>';
                            $html .= '</div>';
                        }
                        
                        $html .= '</li>';
                        return $html;
                    };
                    
                    foreach ($childCategories as $child):
                        echo $renderCategoryItem($child, 0);
                    endforeach;
                    ?>
                </ul>
            </div>
        </div>
    <?php endif; ?>
</div>

