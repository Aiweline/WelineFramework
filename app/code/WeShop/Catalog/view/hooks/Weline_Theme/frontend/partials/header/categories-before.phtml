<?php
/**
 * Header Categories Menu Hook
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\Event\EventsManager;
use Weline\Framework\Manager\ObjectManager;
use WeShop\Catalog\Service\CategoryService;

/** @var CategoryService $categoryService */
$categoryService = ObjectManager::getInstance(CategoryService::class);
$headerCategoryData = $categoryService->getHeaderNavigationData($this->getUrl('catalog/category'), 0);
$navItems = $headerCategoryData['navItems'] ?? [];
$sidebarShortcuts = $headerCategoryData['sidebarShortcuts'] ?? [];

try {
    /** @var EventsManager $eventsManager */
    $eventsManager = ObjectManager::getInstance(EventsManager::class);
    $eventData = [
        'navItems' => &$navItems,
        'template' => $this,
    ];
    $eventsManager->dispatch('WeShop_Catalog::navItems_configure', $eventData);
    $navItems = $eventData['navItems'];
} catch (\Throwable) {
    // Keep category navigation available even when optional listeners fail.
}

$this->setData('navItems', $navItems);
$this->setData('navItems_set_by_hook', true);
$this->setData('sidebarShortcuts', $sidebarShortcuts);

$meta = $this->getData('meta') ?? [];
$meta['navItems'] = $navItems;
$meta['sidebarShortcuts'] = $sidebarShortcuts;
$this->setData('meta', $meta);

if (empty($navItems)) {
    return;
}

$categoryLabel = static function ($value) use ($categoryService): string {
    $key = trim((string)($value ?? ''));
    if ($key === '') {
        return '';
    }
    $translated = (string)__($key);
    if ($translated !== $key) {
        return $translated;
    }
    return $categoryService->localizeCategoryDisplayName($key);
};
$categoryEsc = static function ($value) use ($categoryLabel): string {
    return htmlspecialchars($categoryLabel($value), ENT_QUOTES, 'UTF-8');
};
?>
<div class="header-categories">
    <nav class="categories-nav">
        <ul class="categories-list" id="categories-list">
            <?php
            $renderMenuItem = function (array $item) use (&$renderMenuItem, $categoryEsc): void {
                $children = $item['children'] ?? [];
                $hasChildren = is_array($children) && !empty($children);
                ?>
                <li class="category-item <?= $hasChildren ? 'has-children' : '' ?>">
                    <div class="category-link-wrapper">
                        <a href="<?= htmlspecialchars((string)($item['url'] ?? '#'), ENT_QUOTES, 'UTF-8') ?>" class="category-link">
                            <?= $categoryEsc($item['text'] ?? '') ?>
                        </a>
                        <?php if ($hasChildren): ?>
                            <span class="category-arrow" role="button" aria-label="<?= $categoryEsc('展开子菜单') ?>"></span>
                        <?php endif; ?>
                    </div>
                    <?php if ($hasChildren): ?>
                        <ul class="category-submenu">
                            <?php foreach ($children as $child): ?>
                                <?php if (is_array($child)) {
                                    $renderMenuItem($child);
                                } ?>
                            <?php endforeach; ?>
                        </ul>
                    <?php endif; ?>
                </li>
            <?php };

            foreach ($navItems as $item):
                if (is_array($item)) {
                    $renderMenuItem($item);
                }
            endforeach;
            ?>
            <li class="categories-overflow-wrapper" id="categories-overflow-wrapper" style="display: none;">
                <button class="categories-overflow-btn" id="categories-overflow-btn" aria-label="<?= $categoryEsc('更多分类') ?>" aria-expanded="false" type="button">
                    <span><?= $categoryEsc('更多') ?></span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <ul class="categories-overflow-dropdown" id="categories-overflow-dropdown" role="menu" aria-hidden="true"></ul>
            </li>
        </ul>
    </nav>
</div>
