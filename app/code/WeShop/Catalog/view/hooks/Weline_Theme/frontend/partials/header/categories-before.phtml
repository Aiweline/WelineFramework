<?php
/**
 * Header Categories Menu Hook
 * 在header-main-nav位置渲染分类菜单
 * Hook名称：Weline_Theme::frontend::partials::header::categories-before
 * 
 * @hook-priority 150      Hook优先级：150（composer位置默认优先级）
 * @hook-sort-order 0      Hook排序顺序：0（默认值）
 * @hook-solo false        Hook独享：false（不独占）
 */

use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Event\EventsManager;
use WeShop\Catalog\Service\CategoryService;

// 获取分类服务
/** @var CategoryService $categoryService */
$categoryService = ObjectManager::getInstance(CategoryService::class);

// 获取分类树（只获取启用的分类）
$categories = $categoryService->getCategoryTree(0);

// 即使分类为空，也要设置 navItems（设置为空数组），这样模板才知道 hook 已经执行
// 如果分类为空，只设置 navItems，不输出 HTML
if (empty($categories)) {
    // 设置空的 navItems，标记 hook 已执行
    $this->setData('navItems', []);
    $this->setData('navItems_set_by_hook', true);
    $meta = $this->getData('meta') ?? [];
    $meta['navItems'] = [];
    $this->setData('meta', $meta);
    
    // 设置空的侧边栏快捷方式
    $this->setData('sidebarShortcuts', []);
    $meta['sidebarShortcuts'] = [];
    $this->setData('meta', $meta);
    
    return;
}

// 获取模板实例引用，用于在闭包中生成 URL
$template = $this;

// 递归函数：将分类数据转换为菜单项格式
$convertCategoryToMenuItem = function($category) use (&$convertCategoryToMenuItem, $template) {
    // 只处理启用的分类
    if (empty($category['is_active']) || $category['is_active'] != 1) {
        return null;
    }
    
    // 使用 getUrl() 方法生成 URL，自动包含当前语言和货币参数
    // 使用友好的URL格式：catalog/category/{handle}，路由重写器会自动处理
    $categoryHandle = $category['handle'] ?? '';
    $categoryUrl = $template->getUrl('catalog/category/' . urlencode($categoryHandle));
    
    $menuItem = [
        'text' => $category['name'] ?? '',
        'url' => $categoryUrl,
    ];
    
    // 如果有子分类，递归处理
    if (!empty($category['children']) && is_array($category['children'])) {
        $menuItem['children'] = [];
        foreach ($category['children'] as $child) {
            $childMenuItem = $convertCategoryToMenuItem($child);
            if ($childMenuItem !== null) {
                $menuItem['children'][] = $childMenuItem;
            }
        }
        // 如果所有子分类都被过滤掉了，移除children数组
        if (empty($menuItem['children'])) {
            unset($menuItem['children']);
        }
    }
    
    return $menuItem;
};

// 转换分类数据为菜单项（只包含启用的分类）
$navItems = [];
foreach ($categories as $category) {
    $menuItem = $convertCategoryToMenuItem($category);
    if ($menuItem !== null) {
        $navItems[] = $menuItem;
    }
}

// 触发 navItems 配置事件，允许其他模块添加导航项
try {
    /** @var EventsManager $eventsManager */
    $eventsManager = ObjectManager::getInstance(EventsManager::class);
    $eventData = [
        'navItems' => &$navItems, // 通过引用传递，允许监听器修改
        'template' => $this,
    ];
    $eventsManager->dispatch('WeShop_Catalog::navItems_configure', $eventData);
    // 事件可能修改了 navItems，使用更新后的值
    $navItems = $eventData['navItems'];
} catch (\Exception $e) {
    // 如果事件系统不可用，继续使用原始 navItems
}

// 设置navItems变量，供header模板使用（水平菜单和汉堡菜单共用）
// 通过 setData 设置到模板数据中，这样模板中的 $navItems 变量会被覆盖
$this->setData('navItems', $navItems);
// 标记 navItems 是由 hook 设置的，这样模板就知道是否使用默认值
$this->setData('navItems_set_by_hook', true);

// 同时设置到 meta 数据中，确保能够被正确使用
$meta = $this->getData('meta') ?? [];
$meta['navItems'] = $navItems;
$this->setData('meta', $meta);

// 获取右侧菜单分类（标记了 is_right_menu 属性的分类），用于侧边栏快捷方式
$rightMenuCategories = $categoryService->getRightMenuCategoryTree(0);

// 转换右侧菜单分类为侧边栏快捷方式格式
$sidebarShortcuts = [];
if (!empty($rightMenuCategories)) {
    // 递归函数：将分类数据转换为侧边栏快捷方式格式（只取第一级，不包含子分类）
    $convertToSidebarShortcut = function($category) use ($template) {
        // 只处理启用的分类
        if (empty($category['is_active']) || $category['is_active'] != 1) {
            return null;
        }
        
        // 侧边栏快捷方式只需要基本信息和图标
        // 尝试从分类的 EAV 属性中获取图标
        $icon = 'fas fa-circle'; // 默认图标
        
        // 尝试获取分类的图标属性
        try {
            /** @var \WeShop\Catalog\Model\Category $categoryModel */
            $categoryModel = ObjectManager::getInstance(\WeShop\Catalog\Model\Category::class);
            $categoryModel->load($category['category_id']);
            $iconValue = $categoryModel->getAttributeValue('icon');
            if (!empty($iconValue)) {
                $icon = $iconValue;
            }
        } catch (\Exception $e) {
            // 如果获取图标失败，使用默认图标
        }
        
        // 使用 getUrl() 方法生成 URL，自动包含当前语言和货币参数
        // 使用友好的URL格式：catalog/category/{handle}，路由重写器会自动处理
        $categoryHandle = $category['handle'] ?? '';
        $categoryUrl = $template->getUrl('catalog/category/' . urlencode($categoryHandle));
        
        return [
            'text' => $category['name'] ?? '',
            'url' => $categoryUrl,
            'icon' => $icon,
        ];
    };
    
    foreach ($rightMenuCategories as $category) {
        $shortcut = $convertToSidebarShortcut($category);
        if ($shortcut !== null) {
            $sidebarShortcuts[] = $shortcut;
        }
    }
}

// 设置侧边栏快捷方式数据
$this->setData('sidebarShortcuts', $sidebarShortcuts);
$meta['sidebarShortcuts'] = $sidebarShortcuts;
$this->setData('meta', $meta);

// 直接输出水平菜单的HTML（参考原始布局）
?>
<div class="header-categories">
    <?php if (!empty($navItems)): ?>
        <nav class="categories-nav">
            <ul class="categories-list" id="categories-list">
                <?php 
                // 递归函数：渲染菜单项（支持多级）
                $renderMenuItem = function($item, $level = 1) use (&$renderMenuItem) {
                    $hasChildren = !empty($item['children']) && is_array($item['children']);
                    ?>
                    <li class="category-item <?= $hasChildren ? 'has-children' : '' ?>">
                        <div class="category-link-wrapper">
                            <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>" class="category-link">
                                <?= htmlspecialchars($item['text'] ?? '') ?>
                            </a>
                            <?php if ($hasChildren): ?>
                                <span class="category-arrow" role="button" aria-label="展开子菜单"></span>
                            <?php endif; ?>
                        </div>
                        <?php if ($hasChildren): ?>
                            <ul class="category-submenu">
                                <?php foreach ($item['children'] as $child): ?>
                                    <?php $renderMenuItem($child, $level + 1); ?>
                                <?php endforeach; ?>
                            </ul>
                        <?php endif; ?>
                    </li>
                <?php };
                
                foreach ($navItems as $item): 
                    $renderMenuItem($item);
                endforeach; 
                ?>
            </ul>
        </nav>
    <?php endif; ?>
</div>
