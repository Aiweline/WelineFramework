<script>
    (function () {
        'use strict';

        var tierContainer = document.getElementById('tier-prices-container');
        var customerContainer = document.getElementById('customer-prices-container');
        var tierIndex = <?= isset($tierPrices) && is_array($tierPrices) ? count($tierPrices) : 0 ?>;
        var customerIndex = <?= isset($customerPrices) && is_array($customerPrices) ? count($customerPrices) : 0 ?>;

        // 重置配置：使用后端确认弹窗
        var resetLink = document.getElementById('price-config-reset-link');
        if (resetLink) {
            resetLink.addEventListener('click', function (e) {
                e.preventDefault();
                var msg = <?= json_encode(__('Are you sure you want to reset price configuration?')) ?>;
                if (typeof BackendConfirm === 'undefined') {
                    window.location.href = resetLink.href;
                    return;
                }
                BackendConfirm.show(msg, { type: 'warning' }).then(function (confirmed) {
                    if (!confirmed) return;
                    window.location.href = resetLink.href;
                });
            });
        }

        document.getElementById('btn-add-tier').addEventListener('click', function () {
            var row = document.createElement('div');
            row.className = 'row mb-2 tier-price-row';
            row.dataset.index = tierIndex++;
            row.innerHTML = '<div class="col-md-4">' +
                '<label class="form-label"><?= __('Min Qty') ?></label>' +
                '<input type="number" min="1" class="form-control" name="tier_price_qty[]" placeholder="<?= __('Min Qty') ?>">' +
                '</div>' +
                '<div class="col-md-4">' +
                '<label class="form-label"><?= __('Price') ?></label>' +
                '<input type="number" step="0.01" min="0" class="form-control" name="tier_price_value[]" placeholder="0.00">' +
                '</div>' +
                '<div class="col-md-4 d-flex align-items-end">' +
                '<button type="button" class="btn btn-danger btn-remove-tier"><i class="bx bx-trash"></i> <?= __('Remove') ?></button>' +
                '</div>';
            tierContainer.appendChild(row);
        });

        tierContainer.addEventListener('click', function (e) {
            if (e.target.closest('.btn-remove-tier')) {
                e.target.closest('.tier-price-row').remove();
            }
        });

        document.getElementById('btn-add-customer').addEventListener('click', function () {
            var row = document.createElement('div');
            row.className = 'row mb-2 customer-price-row';
            row.dataset.index = customerIndex++;
            row.innerHTML = '<div class="col-md-4">' +
                '<label class="form-label"><?= __('Customer ID') ?></label>' +
                '<input type="number" min="1" class="form-control" name="customer_id[]" placeholder="<?= __('Customer ID') ?>">' +
                '</div>' +
                '<div class="col-md-4">' +
                '<label class="form-label"><?= __('Price') ?></label>' +
                '<input type="number" step="0.01" min="0" class="form-control" name="customer_price_value[]" placeholder="0.00">' +
                '</div>' +
                '<div class="col-md-4 d-flex align-items-end">' +
                '<button type="button" class="btn btn-danger btn-remove-customer"><i class="bx bx-trash"></i> <?= __('Remove') ?></button>' +
                '</div>';
            customerContainer.appendChild(row);
        });

        customerContainer.addEventListener('click', function (e) {
            if (e.target.closest('.btn-remove-customer')) {
                e.target.closest('.customer-price-row').remove();
            }
        });
    })();
</script>
