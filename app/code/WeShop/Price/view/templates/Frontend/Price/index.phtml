<?php
/** @var \Weline\Framework\View\Template $this */
/** @var array<string, mixed> $priceData */
$priceData = $this->getData() ?? [];
$price = (float) ($priceData['price'] ?? 0);
$formattedPrice = (string) ($priceData['formatted_price'] ?? $this->formatPrice($price));
$currency = (string) ($priceData['currency'] ?? 'CNY');
$quantity = (int) ($priceData['quantity'] ?? 1);
$productId = (int) ($priceData['product_id'] ?? 0);
?>
<div class="weshop-price-display" data-weshop-price-product="<?= $productId ?>">
    <div class="price-display__main">
        <span class="price-display__amount"><?= $formattedPrice ?></span>
    </div>
    <?php if (isset($priceData['has_discount']) && $priceData['has_discount']): ?>
        <div class="price-display__original">
            <span class="price-display__original-amount">
                <?= $this->formatPrice((float) ($priceData['original_price'] ?? 0)) ?>
            </span>
        </div>
        <div class="price-display__badges">
            <?php if (isset($priceData['discount_percent']) && $priceData['discount_percent'] > 0): ?>
                <span class="price-badge price-badge--discount">
                    -<?= (int) $priceData['discount_percent'] ?>%
                </span>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    <?php if (isset($priceData['tier_prices']) && is_array($priceData['tier_prices']) && count($priceData['tier_prices']) > 0): ?>
        <div class="price-display__tier-info">
            <span class="tier-info__label"><?= __('Volume discount available') ?></span>
        </div>
    <?php endif; ?>
</div>

