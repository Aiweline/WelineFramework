<?php
/**
 * Membership storefront account-center discovery card.
 *
 * @hook-priority 220
 * @hook-sort-order 12
 * @hook-solo false
 */

use WeShop\Membership\Service\MembershipPageDataService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$customer = $session->getCustomer();
if (!$customer || !$customer->getId()) {
    return;
}

/** @var MembershipPageDataService $pageDataService */
$pageDataService = ObjectManager::getInstance(MembershipPageDataService::class);
$data = $pageDataService->build((int) $customer->getId());
$membership = (array) ($data['membership'] ?? []);
$benefits = array_values((array) ($data['benefits'] ?? []));
?>
<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Member Perks') ?></p>
            <h2 class="mt-2 text-2xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Membership') ?></h2>
        </div>
        <a href="<?= $this->getUrl('membership') ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open Membership') ?></a>
    </div>

    <div class="mt-6 rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
        <p class="text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark"><?= __('Current Tier') ?></p>
        <p class="mt-2 text-2xl font-black text-text-primary-light dark:text-text-primary-dark">
            <?= htmlspecialchars((string) ($membership['level_label'] ?? ''), ENT_QUOTES) ?>
        </p>
        <p class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark">
            <?= __('Points: %1', (int) ($membership['points'] ?? 0)) ?>
        </p>
    </div>

    <?php if (!empty($benefits)): ?>
        <ul class="mt-4 space-y-2 text-sm text-text-secondary-light dark:text-text-secondary-dark">
            <?php foreach (array_slice($benefits, 0, 2) as $benefit): ?>
                <li class="flex items-start gap-2">
                    <span class="mt-1 inline-block h-2 w-2 rounded-full bg-primary"></span>
                    <span><?= htmlspecialchars((string) $benefit, ENT_QUOTES) ?></span>
                </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
</article>

