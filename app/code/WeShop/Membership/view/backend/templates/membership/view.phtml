                                    <div>
                                        <strong><?= __('Customer ID') ?></strong>
                                        <p class="text-muted small mb-0"><?= __('Enter the unique customer identifier.') ?></p>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item px-0">
                                <div class="d-flex align-items-start gap-3">
                                    <i class="mdi mdi-star-circle text-warning mt-1"></i>
                                    <div>
                                        <strong><?= __('Membership Level') ?></strong>
                                        <p class="text-muted small mb-0"><?= __('Choose from Bronze, Silver, Gold, or Platinum.') ?></p>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item px-0">
                                <div class="d-flex align-items-start gap-3">
                                    <i class="mdi mdi-trophy text-success mt-1"></i>
                                    <div>
                                        <strong><?= __('Points') ?></strong>
                                        <p class="text-muted small mb-0"><?= __('Assign initial points for the membership.') ?></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
