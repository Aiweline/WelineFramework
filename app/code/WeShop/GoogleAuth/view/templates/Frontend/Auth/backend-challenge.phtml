<?php
/** @var \Weline\Framework\View\Template $this */
$postUrl = (string) ($this->getData('post_url') ?? '');
$challengeToken = (string) ($this->getData('challenge_token') ?? '');
$expiresAt = (int) ($this->getData('expires_at') ?? 0);
$messages = (string) \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\Manager\MessageManager::class);
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= __('Backend Two-Factor Verification') ?></title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #f5f7fa, #e4ecfb);
            color: #1f2937;
        }
        .shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .card {
            width: 100%;
            max-width: 460px;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.15);
            padding: 32px;
        }
        .title {
            margin: 0 0 10px;
            font-size: 28px;
            font-weight: 700;
        }
        .subtitle {
            margin: 0 0 24px;
            color: #6b7280;
            line-height: 1.6;
        }
        label {
            display: block;
            margin-bottom: 10px;
            font-weight: 600;
        }
        input[type="text"] {
            width: 100%;
            box-sizing: border-box;
            height: 48px;
            border: 1px solid #d1d5db;
            border-radius: 12px;
            padding: 0 14px;
            font-size: 16px;
        }
        button {
            width: 100%;
            border: 0;
            border-radius: 12px;
            height: 48px;
            background: #111827;
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 18px;
        }
        .meta {
            margin-top: 16px;
            color: #6b7280;
