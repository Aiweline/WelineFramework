        }
        .message-wrap {
            margin-bottom: 16px;
        }
    </style>
</head>
<body>
<div class="shell">
    <div class="card">
        <h1 class="title"><?= __('Backend Two-Factor Verification') ?></h1>
        <p class="subtitle"><?= __('Enter the 6-digit code from your authenticator app or one of your backup codes to complete backend sign in.') ?></p>

        <?php if ($messages): ?>
            <div class="message-wrap"><?= $messages ?></div>
        <?php endif; ?>

        <form action="<?= htmlspecialchars($postUrl, ENT_QUOTES) ?>" method="post">
            <?= $this->getFormKey($postUrl) ?>
            <input type="hidden" name="challenge_token" value="<?= htmlspecialchars($challengeToken, ENT_QUOTES) ?>">

            <label for="code"><?= __('Verification Code') ?></label>
            <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required placeholder="<?= __('123456') ?>">

            <button type="submit"><?= __('Verify and Sign In') ?></button>
        </form>

        <div class="meta">
            <?= __('Challenge expires at: %{1}', [$expiresAt > 0 ? date('Y-m-d H:i:s', $expiresAt) : __('Unknown')]) ?>
        </div>
    </div>
</div>
