<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \WeShop\GoogleAuth\Service\GoogleOAuthService $oauthService */
$oauthService = w_obj(\WeShop\GoogleAuth\Service\GoogleOAuthService::class);
if (!$oauthService->isConfigured()) {
    return;
}

$redirectUrl = (string) ($this->getData('redirect_url') ?? ($_GET['redirect'] ?? $_GET['redirect_url'] ?? ''));
$startUrl = w_url('weshop_googleauth/frontend/auth/start', [
    'area' => 'frontend',
    'mode' => 'login',
    'redirect_url' => $redirectUrl,
], 'frontend');
?>
