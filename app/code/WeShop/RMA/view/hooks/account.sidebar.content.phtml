        }

        .weshop-empty-returns {
            align-items: center;
            border: 1px dashed var(--weshop-border-color, #d1d5db);
            border-radius: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            padding: 2rem;
            text-align: center;
        }

        .weshop-empty-returns h3,
        .weshop-empty-returns p {
            margin: 0;
        }

        .weshop-empty-returns-icon {
            color: var(--weshop-primary, #2563eb);
