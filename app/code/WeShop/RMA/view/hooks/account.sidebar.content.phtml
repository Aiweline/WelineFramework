use WeShop\RMA\Service\RmaPageDataService;
use WeShop\RMA\Service\RmaService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

$escape = static fn($value): string => htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
$selectedOrderId = (int) ($this->request->getParam('order_id') ?? 0);
$selectedOrderIncrementId = trim((string) ($this->request->getParam('order_increment_id') ?? ''));
$selectedReturnAnchor = trim((string) ($this->request->getParam('return_anchor') ?? ''));
$selectedReturnUrl = trim((string) ($this->request->getParam('return_url') ?? ''));

/** @var RmaPageDataService $rmaPageDataService */
$rmaPageDataService = ObjectManager::getInstance(RmaPageDataService::class);
$data = $rmaPageDataService->build((int) $customer->getId(), $selectedOrderId, $selectedOrderIncrementId);

$order = is_array($data['order'] ?? null) ? $data['order'] : null;
$orderOptions = (array) ($data['order_options'] ?? []);
$rmaList = (array) ($data['rma_list'] ?? []);
$requestTypes = (array) ($data['request_types'] ?? []);
$reasonOptions = (array) ($data['reason_options'] ?? []);
$selectedOrderItems = is_array($order['items'] ?? null) ? (array) $order['items'] : [];
$selectedOrderItemCount = max(0, (int) ($order['item_count'] ?? count($selectedOrderItems)));
$selectedOrderEligible = false;
if ($order) {
    foreach ($orderOptions as $option) {
        if ((int) ($option['order_id'] ?? 0) === (int) ($order['order_id'] ?? 0)) {
            $selectedOrderEligible = (bool) ($option['eligible'] ?? false);
            break;
        }
    }
}
if (!$selectedOrderEligible) {
    $selectedOrderItems = [];
    $selectedOrderItemCount = 0;
}
$feedbackDefault = '提交后会停留在当前个人中心，并自动刷新售后记录。';

$statusLabels = [
    RmaService::STATUS_PENDING => '待处理',
    RmaService::STATUS_APPROVED => '已同意',
    RmaService::STATUS_REJECTED => '已拒绝',
];

$jsText = [
    'recordTitleTemplate' => '售后单 #%{1}',
    'orderNumberTemplate' => '订单号：%{1}',
    'quantityTemplate' => 'x%{1}',
    'moreItemsTemplate' => '还有 %{1} 件商品',
    'selectedOrder' => '已选择订单',
    'selectedReturnOrder' => '已选择售后订单',
    'switchedToReturns' => '已切换到当前页售后区，可直接提交或查看进度。',
    'submitting' => '正在提交售后申请...',
    'submitted' => '售后申请已提交。',
    'submitFailed' => '暂时无法提交售后申请。',
    'selectOrder' => '请选择可售后订单',
    'selectedOrderItems' => '已选订单商品',
    'itemCountTemplate' => '共 %{1} 件',
];

$rmaReasonIcon = static function (string $reason): string {
    $key = strtolower(trim($reason));
    return match ($key) {
        'wrong size' => '&#128207;',
        'damaged in transit' => '&#128666;',
        'defective item' => '&#9888;',
        'item not as described' => '&#128269;',
        'changed my mind' => '&#8634;',
        default => '?',
    };
};
$rmaTypeIcon = static function (string $type): string {
    return match (strtolower(trim($type))) {
        'exchange' => '&#8644;',
        default => '&#8634;',
    };
};
$rmaExtractType = static function (string $description): string {
    if (preg_match('/^\s*\[(return|exchange)\]/i', $description, $matches)) {
        return strtolower($matches[1]);
    }

    return '';
};
$rmaCleanDescription = static function (string $description): string {
    return trim((string) preg_replace('/^(?:\s*\[(?:return|exchange)\])+\s*/i', '', $description));
};
