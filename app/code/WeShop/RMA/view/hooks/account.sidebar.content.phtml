        }

        .weshop-return-status {
            border-radius: 999px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--weshop-primary, #2563eb);
            font-size: 0.78rem;
            font-weight: 700;
            padding: 0.2rem 0.55rem;
        }
    </style>
</section>
