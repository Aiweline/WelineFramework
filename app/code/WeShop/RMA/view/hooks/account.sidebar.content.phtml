<?php
/**
 * WeShop_RMA module - account returns section.
 *
 * Hook: account.sidebar.content
 *
 * @hook-priority 170
 * @hook-sort-order 20
 * @hook-solo false
 */

use WeShop\RMA\Service\RmaService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$customerSession = SessionFactory::getInstance()->createFrontendSession();
$customer = $customerSession->getCustomer();

if (!$customer || !$customer->getId()) {
    return;
}

/** @var RmaService $rmaService */
$rmaService = ObjectManager::getInstance(RmaService::class);
$rmaList = $rmaService->getCustomerRmas((int) $customer->getId());
?>
<section class="account-hook-section account-index__section d-none motor-account-section" id="returns-section" data-account-section="returns" hidden>
    <div class="weshop-account-returns" id="weshop-account-returns">
        <div class="weshop-returns-header">
            <div>
                <h2 class="weshop-returns-title"><?= __('退换货') ?></h2>
                <p class="weshop-returns-subtitle"><?= __('查看退货、换货和售后申请进度。') ?></p>
            </div>
            <a href="<?= $this->getUrl('rma') ?>" class="weshop-view-all-link">
                <?= __('打开售后中心') ?>
                <i class="ri-arrow-right-s-line weshop-view-all-icon" aria-hidden="true"></i>
            </a>
        </div>

        <?php if (empty($rmaList)): ?>
            <div class="weshop-empty-returns">
                <i class="ri-exchange-line weshop-empty-returns-icon" aria-hidden="true"></i>
                <h3><?= __('暂无退换货申请') ?></h3>
                <p><?= __('如果订单需要退货或换货，可以从订单详情或售后中心发起申请。') ?></p>
                <a href="<?= $this->getUrl('rma') ?>" class="weshop-shopping-button">
                    <?= __('去售后中心') ?>
                </a>
            </div>
        <?php else: ?>
            <div class="weshop-returns-list">
                <?php foreach ($rmaList as $rma): ?>
                    <?php
                    $rmaId = (int) ($rma['rma_id'] ?? 0);
                    $orderId = (int) ($rma['order_id'] ?? 0);
                    $reason = trim((string) ($rma['reason'] ?? ''));
                    $status = trim((string) ($rma['status'] ?? RmaService::STATUS_PENDING));
                    $createdAt = trim((string) ($rma['created_at'] ?? ''));
                    $statusLabel = [
                        RmaService::STATUS_PENDING => __('待处理'),
                        RmaService::STATUS_APPROVED => __('已同意'),
                        RmaService::STATUS_REJECTED => __('已拒绝'),
                    ][$status] ?? $status;
                    ?>
                    <a href="<?= $this->getUrl('rma', ['order_id' => $orderId]) ?>" class="weshop-return-item">
                        <div class="weshop-return-item__main">
                            <strong><?= __('售后单 #%1', $rmaId) ?></strong>
                            <span><?= __('订单 #%1', $orderId) ?></span>
                        </div>
                        <div class="weshop-return-item__meta">
                            <span class="weshop-return-status status-<?= htmlspecialchars($status, ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars((string) $statusLabel, ENT_QUOTES, 'UTF-8') ?></span>
                            <?php if ($reason !== ''): ?>
                                <span><?= htmlspecialchars($reason, ENT_QUOTES, 'UTF-8') ?></span>
                            <?php endif; ?>
                            <?php if ($createdAt !== ''): ?>
                                <span><?= htmlspecialchars($createdAt, ENT_QUOTES, 'UTF-8') ?></span>
                            <?php endif; ?>
                        </div>
                    </a>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </div>

