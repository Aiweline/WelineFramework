    <script>
        (function () {
            var text = <?= json_encode($jsText, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
            var orderOptions = <?= json_encode($orderOptions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
            var form = document.getElementById('account-rma-request-form');
            var submit = document.getElementById('account-rma-submit');
            var feedback = document.getElementById('account-rma-feedback');
            var orderSelect = document.querySelector('[data-rma-order-select]');
            var orderIdInput = document.querySelector('[data-rma-order-id-input]');
            var orderIncrementInput = document.querySelector('[data-rma-order-increment-input]');
            var returnAnchorInput = document.querySelector('[data-rma-return-anchor-input]');
            var returnUrlInput = document.querySelector('[data-rma-return-url-input]');
            var selectedOrder = document.querySelector('[data-rma-selected-order]');
            var orderPreview = document.querySelector('[data-rma-order-preview]');
            var orderPreviewCount = document.querySelector('[data-rma-order-preview-count]');
            var orderPreviewList = document.querySelector('[data-rma-order-preview-list]');
            var returnsSection = document.getElementById('returns-section');
            var returnsCards = document.querySelectorAll('.weshop-returns-card');
            var recordsCard = returnsCards.length > 1 ? returnsCards[1] : null;
            var rmaList = document.querySelector('[data-rma-list]');
            var emptyState = document.querySelector('[data-rma-empty-state]');
            var apiPromise = null;

            function getRmaApi() {
                if (!apiPromise) {
                    apiPromise = Promise.resolve(window.Weline.Api.resource('rma'));
                }

                return apiPromise;
            }

            function escapeHtml(value) {
                return String(value || '').replace(/[&<>\"']/g, function (character) {
                    return {
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#039;'
                    }[character] || character;
                });
            }

            function formatTemplate(template, value) {
                return String(template || '').replace('%{1}', String(value));
            }

            function getReasonIcon(reason) {
                switch (String(reason || '').trim().toLowerCase()) {
                    case 'wrong size':
                        return '&#128207;';
                    case 'damaged in transit':
                        return '&#128666;';
                    case 'defective item':
                        return '&#9888;';
                    case 'item not as described':
                        return '&#128269;';
                    case 'changed my mind':
                        return '&#8634;';
                    default:
                        return '?';
                }
            }

            function getTypeIcon(type) {
                return String(type || '').trim().toLowerCase() === 'exchange'
                    ? '&#8644;'
                    : '&#8634;';
            }

            function extractRequestType(description) {
                var match = String(description || '').match(/^\s*\[(return|exchange)\]/i);
                return match ? match[1].toLowerCase() : '';
            }

            function cleanDescription(description) {
                return String(description || '').replace(/^(?:\s*\[(?:return|exchange)\])+\s*/i, '').trim();
            }

            function buildIconChip(iconClass) {
                return '<span class="weshop-return-icon-chip" aria-hidden="true">'
                    + iconClass
                    + '</span>';
            }

            function getOrderOption(orderId) {
                var targetId = parseInt(orderId || 0, 10) || 0;
                for (var index = 0; index < orderOptions.length; index++) {
                    if ((parseInt(orderOptions[index].order_id || 0, 10) || 0) === targetId) {
                        return orderOptions[index];
                    }
                }

                return null;
            }

            function buildOrderItemHtml(item) {
                var itemName = String(item.product_name || '');
                var itemSku = String(item.product_sku || '');
                var itemImage = String(item.product_image || item.image || '');
                var itemQty = parseInt(item.quantity || 1, 10) || 1;
                var html = '';

                html += '<div class="weshop-returns-order-preview__item">';
                html += '<div class="weshop-returns-order-preview__image">';
                if (itemImage) {
                    html += '<img src="' + escapeHtml(itemImage) + '" alt="' + escapeHtml(itemName) + '" loading="lazy">';
                } else {
                    html += '<span aria-hidden="true">?</span>';
                }
                html += '</div>';
                html += '<div class="weshop-returns-order-preview__content">';
                html += '<strong>' + escapeHtml(itemName) + '</strong>';
                if (itemSku) {
                    html += '<span>SKU: ' + escapeHtml(itemSku) + '</span>';
                }
                html += '</div>';
                html += '<span>' + escapeHtml(formatTemplate(text.quantityTemplate, itemQty)) + '</span>';
                html += '</div>';

                return html;
            }

            function updateOrderPreview(option) {
                var items = option && Array.isArray(option.items) ? option.items : [];
                if (orderPreview) {
                    orderPreview.classList.toggle('is-empty', items.length === 0);
                }
                if (orderPreviewCount) {
                    orderPreviewCount.textContent = formatTemplate(text.itemCountTemplate, items.length);
                }
                if (orderPreviewList) {
                    orderPreviewList.innerHTML = items.map(buildOrderItemHtml).join('');
                }
            }

            function applySelectedOrder(option) {
                var orderId = option ? parseInt(option.order_id || 0, 10) || 0 : 0;
                var incrementId = option ? String(option.increment_id || '') : '';

                fillSelectedOrder(orderId || '', incrementId, returnAnchorInput ? returnAnchorInput.value : '', returnUrlInput ? returnUrlInput.value : '');
                updateOrderPreview(option);
            }

            function setValue(input, value) {
                if (input) {
                    input.value = value || '';
                }
            }

            function setFeedback(message, type) {
                if (!feedback) {
                    return;
                }

                feedback.textContent = message || '';
                feedback.classList.remove('is-success', 'is-error');
                if (type) {
                    feedback.classList.add(type);
                }
            }

            function showReturnsSection() {
                var sectionLink = document.querySelector('[data-account-nav-link][data-section="returns"]');
                if (sectionLink) {
                    sectionLink.click();
                }
            }

            function fillSelectedOrder(orderId, incrementId, returnAnchor, returnUrl) {
                setValue(orderIdInput, orderId);
                setValue(orderIncrementInput, incrementId);
                setValue(returnAnchorInput, returnAnchor);
                setValue(returnUrlInput, returnUrl);

                if (selectedOrder) {
                    selectedOrder.textContent = incrementId
                        ? (text.selectedOrder + ' #' + incrementId)
                        : text.selectedReturnOrder;
                }
            }

            function ensureRmaList() {
                if (rmaList) {
                    return rmaList;
                }

                if (!recordsCard) {
                    return null;
                }

                rmaList = document.createElement('div');
                rmaList.className = 'weshop-returns-list';
                rmaList.setAttribute('data-rma-list', '');
                if (emptyState && emptyState.parentNode) {
                    emptyState.parentNode.removeChild(emptyState);
                    emptyState = null;
                }
                recordsCard.appendChild(rmaList);

                return rmaList;
            }

            function buildRecordHtml(record) {
                var rmaId = parseInt(record.rma_id || 0, 10) || 0;
                var orderId = parseInt(record.order_id || 0, 10) || 0;
                var orderIncrementId = String(record.order_increment_id || '');
                var reason = String(record.reason || '');
                var description = String(record.description || '');
                var requestType = extractRequestType(description);
                description = cleanDescription(description);
                var status = String(record.status || 'pending');
                var statusLabel = String(record.status_label || status);
                var createdAt = String(record.created_at || '');
                var items = Array.isArray(record.items) ? record.items : [];
                var itemCount = parseInt(record.item_count || items.length || 0, 10) || 0;
                var html = '';

                html += '<article class="weshop-return-item" data-rma-record>';
                html += '<div class="weshop-return-item__main"><div>';
                html += '<strong>' + escapeHtml(formatTemplate(text.recordTitleTemplate, rmaId)) + '</strong>';
                html += '<span>' + escapeHtml(formatTemplate(text.orderNumberTemplate, orderIncrementId || orderId)) + '</span>';
                html += '</div><span class="weshop-return-status status-' + escapeHtml(status) + '">' + escapeHtml(statusLabel) + '</span></div>';
                html += '<div class="weshop-return-item__meta">';

                if (requestType) {
                    html += buildIconChip(getTypeIcon(requestType));
                }

                if (reason) {
                    html += buildIconChip(getReasonIcon(reason));
                }

                if (createdAt) {
                    html += '<span>' + escapeHtml(createdAt) + '</span>';
                }

                html += '</div>';

                if (description) {
                    html += '<p class="weshop-return-item__description">' + escapeHtml(description) + '</p>';
                }

                if (items.length > 0) {
                    html += '<div class="weshop-return-item__products">';
                    items.forEach(function (item) {
                        var itemName = String(item.product_name || '');
                        var itemSku = String(item.product_sku || '');
                        var itemImage = String(item.product_image || item.image || '');
                        var itemQty = parseInt(item.quantity || 1, 10) || 1;

                        html += '<div class="weshop-return-item__product">';
                        html += '<div class="weshop-return-item__product-image">';
                        if (itemImage) {
                            html += '<img src="' + escapeHtml(itemImage) + '" alt="' + escapeHtml(itemName) + '" loading="lazy">';
                        } else {
                            html += '<i class="ri-image-line" aria-hidden="true"></i>';
                        }
                        html += '</div>';
                        html += '<div class="weshop-return-item__product-main">';
                        html += '<strong>' + escapeHtml(itemName) + '</strong>';
                        if (itemSku) {
                            html += '<span>SKU: ' + escapeHtml(itemSku) + '</span>';
                        }
                        html += '</div>';
                        html += '<span>' + escapeHtml(formatTemplate(text.quantityTemplate, itemQty)) + '</span>';
                        html += '</div>';
                    });

                    if (itemCount > items.length) {
                        html += '<span class="weshop-return-item__more">' + escapeHtml(formatTemplate(text.moreItemsTemplate, itemCount - items.length)) + '</span>';
                    }

                    html += '</div>';
                }

                html += '</article>';

                return html;
            }

            function prependRmaRecord(record) {
                var targetList = ensureRmaList();
                if (!targetList) {
                    return;
                }

                var wrapper = document.createElement('div');
                wrapper.innerHTML = buildRecordHtml(record);
                if (wrapper.firstElementChild) {
                    targetList.insertBefore(wrapper.firstElementChild, targetList.firstChild);
                }
            }

            function buildDefaultReturnUrl() {
                try {
                    var currentUrl = new URL(window.location.href);
                    currentUrl.hash = '#orders';
                    return currentUrl.pathname + currentUrl.search + currentUrl.hash;
                } catch (error) {
                    return '/customer/account/index#orders';
                }
            }

            function shouldNavigate(redirectUrl) {
                return redirectUrl.indexOf('/customer/account/login') !== -1;
            }

            function updateBrowserState(redirectUrl) {
                if (!redirectUrl || !window.history || typeof window.history.replaceState !== 'function') {
                    return;
                }

                try {
                    var parsedUrl = new URL(redirectUrl, window.location.origin);
                    if (parsedUrl.origin !== window.location.origin) {
                        return;
                    }

                    window.history.replaceState(null, '', parsedUrl.pathname + parsedUrl.search + parsedUrl.hash);
                } catch (error) {}
            }

            function resetRequestForm() {
                var reasonSelect = form ? form.querySelector('select[name="reason"]') : null;
                var descriptionInput = form ? form.querySelector('textarea[name="description"]') : null;
                if (reasonSelect) {
                    reasonSelect.value = '';
                }
                if (descriptionInput) {
                    descriptionInput.value = '';
                }
            }

            if (orderSelect) {
                orderSelect.addEventListener('change', function () {
                    var option = getOrderOption(orderSelect.value);
                    applySelectedOrder(option && option.eligible ? option : null);
                });
                applySelectedOrder(getOrderOption(orderSelect.value));
            }

            function normalizeOrderPayload(payload) {
                var rawOrderId = String(payload.order_id || '').trim();
                if (!rawOrderId) {
                    delete payload.order_id;
                    return payload;
                }

                if (!/^\d+$/.test(rawOrderId)) {
                    delete payload.order_id;
                    return payload;
                }

                var numericOrderId = Number(rawOrderId);
                if (!Number.isSafeInteger(numericOrderId)) {
                    payload.order_increment_id = payload.order_increment_id || rawOrderId;
                    delete payload.order_id;
                    return payload;
                }

                payload.order_id = numericOrderId;
                return payload;
            }

            document.addEventListener('click', function (event) {
                var trigger = event.target.closest('a[href*="rma/create"], a[href*="rma?order_id="], .js-account-rma-trigger');
                if (!trigger) {
                    return;
                }

                var href = trigger.getAttribute('href') || '';
                var orderId = trigger.getAttribute('data-order-id') || '';
                var incrementId = trigger.getAttribute('data-order-increment-id') || '';
                var returnAnchor = trigger.getAttribute('data-return-anchor') || '';
                var returnUrl = trigger.getAttribute('data-return-url') || '';

                if (href) {
                    try {
                        var url = new URL(href, window.location.origin);
                        orderId = orderId || url.searchParams.get('order_id') || '';
                        incrementId = incrementId || url.searchParams.get('order_increment_id') || '';
                        returnAnchor = returnAnchor || url.searchParams.get('return_anchor') || '';
                        returnUrl = returnUrl || url.searchParams.get('return_url') || '';
                    } catch (error) {}
                }

                if (!orderId && !incrementId) {
                    return;
                }

                event.preventDefault();
                showReturnsSection();
                fillSelectedOrder(orderId, incrementId, returnAnchor, returnUrl || buildDefaultReturnUrl());
                setFeedback(text.switchedToReturns, '');

                if (returnsSection && typeof returnsSection.scrollIntoView === 'function') {
                    returnsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });

            if (!form || !submit) {
                return;
            }

            submit.addEventListener('click', function () {
                if (typeof form.reportValidity === 'function' && !form.reportValidity()) {
                    return;
                }

                var payload = {};
                new FormData(form).forEach(function (value, key) {
                    if (key === 'form_key' || key === 'csrf_token' || key === '_token') {
                        return;
                    }
                    payload[key] = value;
                });
                payload = normalizeOrderPayload(payload);

                if (!payload.return_url) {
                    payload.return_url = buildDefaultReturnUrl();
                    setValue(returnUrlInput, payload.return_url);
                }

                setFeedback(text.submitting, '');

                getRmaApi().then(function (RmaApi) {
                    return RmaApi.create(payload, { silent: true });
                }).then(function (result) {
                    if (result && result.success) {
                        var record = result.data || {};
                        updateBrowserState(record.redirect_url || '');
                        prependRmaRecord(record);
                        fillSelectedOrder(
                            record.order_id || payload.order_id || '',
                            record.order_increment_id || payload.order_increment_id || '',
                            payload.return_anchor || '',
                            payload.return_url || ''
                        );
                        resetRequestForm();
                        setFeedback(text.submitted, 'is-success');
                        return;
                    }

                    if (result && result.data && shouldNavigate(result.data.redirect_url || '')) {
                        window.location.href = result.data.redirect_url;
                        return;
                    }

                    setFeedback((result && result.message) ? result.message : text.submitFailed, 'is-error');
                }).catch(function (error) {
                    var errorMessage = error && error.response && error.response.data
                        ? (error.response.data.message || error.response.data.msg || '')
                        : '';
                    setFeedback(errorMessage || (error && error.message) || text.submitFailed, 'is-error');
                });
            });
        })();
    </script>

