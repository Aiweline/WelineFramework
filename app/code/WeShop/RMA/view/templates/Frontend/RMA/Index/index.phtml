<script>
    (function () {
        var form = document.getElementById('rma-request-form');
        var submit = document.getElementById('rma-submit');
        var feedback = document.getElementById('rma-feedback');
        var apiPromise = null;

        if (!form || !submit || !feedback) {
            return;
        }

        function getRmaApi() {
            if (!apiPromise) {
                apiPromise = Promise.resolve(window.Weline.Api.resource('rma'));
            }

            return apiPromise;
        }

        function normalizeOrderPayload(payload) {
            var rawOrderId = String(payload.order_id || '').trim();
            if (!rawOrderId) {
                delete payload.order_id;
                return payload;
            }

            if (!/^\d+$/.test(rawOrderId)) {
                delete payload.order_id;
                return payload;
            }

            var numericOrderId = Number(rawOrderId);
            if (!Number.isSafeInteger(numericOrderId)) {
                payload.order_increment_id = payload.order_increment_id || rawOrderId;
                delete payload.order_id;
                return payload;
            }

            payload.order_id = numericOrderId;
            return payload;
        }

        submit.addEventListener('click', function () {
            var payload = {};
            new FormData(form).forEach(function (value, key) {
                if (key === 'form_key' || key === 'csrf_token' || key === '_token') {
                    return;
                }
                payload[key] = value;
            });
            payload = normalizeOrderPayload(payload);

            getRmaApi().then(function (RmaApi) {
                return RmaApi.create(payload, {silent: true});
            }).then(function (result) {
                if (result && result.success) {
                    feedback.textContent = '<?= __('退换货申请已提交。') ?>';
                    feedback.classList.remove('text-red-500');
                    feedback.classList.add('text-emerald-500');
                    window.setTimeout(function () {
                        window.location.href = (result.data && result.data.redirect_url) || '/customer/account/index#returns';
                    }, 300);
                    return;
                }

                if (result && result.data && result.data.redirect_url) {
                    window.location.href = result.data.redirect_url;
                    return;
                }

                feedback.textContent = (result && result.message) ? result.message : '<?= __('暂时无法提交申请。') ?>';
                feedback.classList.remove('text-emerald-500');
                feedback.classList.add('text-red-500');
            }).catch(function (error) {
                var errorMessage = error && error.response && error.response.data
                    ? (error.response.data.message || error.response.data.msg || '')
                    : '';
                feedback.textContent = errorMessage || (error && error.message) || '<?= __('暂时无法提交申请。') ?>';
                feedback.classList.remove('text-emerald-500');
                feedback.classList.add('text-red-500');
            });
        });
    })();
</script>
