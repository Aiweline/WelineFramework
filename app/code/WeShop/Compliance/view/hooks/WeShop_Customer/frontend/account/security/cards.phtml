<?php
/**
 * Compliance storefront account-center security card.
 *
 * @hook-priority 210
 * @hook-sort-order 14
 * @hook-solo false
 */

use WeShop\Compliance\Service\CompliancePageDataService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$customer = $session->getCustomer();
if (!$customer || !$customer->getId()) {
    return;
}

/** @var CompliancePageDataService $pageDataService */
$pageDataService = ObjectManager::getInstance(CompliancePageDataService::class);
$data = $pageDataService->buildConsentPage((int) $customer->getId());
$acceptedCount = (int) ($data['consent_accepted_count'] ?? 0);
$consentCount = (int) ($data['consent_count'] ?? 0);
?>
<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Compliance') ?></p>
            <h2 class="mt-2 text-2xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Consent Center') ?></h2>
        </div>
        <a href="<?= $this->getUrl('compliance') ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open Compliance') ?></a>
    </div>

    <div class="mt-6 rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
        <p class="text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark"><?= __('Accepted Preferences') ?></p>
        <p class="mt-2 text-3xl font-black text-text-primary-light dark:text-text-primary-dark"><?= $acceptedCount ?>/<?= $consentCount ?></p>
        <p class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark">
            <?= __('Review privacy, terms, and communication consent settings from one secure workspace.') ?>
        </p>
    </div>
</article>

