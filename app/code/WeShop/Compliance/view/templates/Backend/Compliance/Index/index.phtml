<script>
document.addEventListener('DOMContentLoaded', function() {
    const policyTypes = <?= json_encode($policyRows, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

    if (typeof DataTable === 'undefined') {
        console.warn('DataTable not loaded');
        return;
    }

    const complianceTable = new DataTable('#compliance-table', {
        processing: true,
        serverSide: false,
        data: policyTypes,
        columns: [
            { data: 'type', name: 'type', render: function(data) {
                const badgeColors = {
                    'privacy': 'bg-primary',
                    'terms': 'bg-info',
                    'cookie': 'bg-warning',
                    'marketing': 'bg-secondary'
                };
                return '<span class="badge ' + (badgeColors[data] || 'bg-secondary') + '">' + htmlEscape(data.toUpperCase()) + '</span>';
            }},
            { data: 'name', name: 'name' },
            { data: 'description', name: 'description' },
            { data: 'required', name: 'required', render: function(data) {
                return data
                    ? '<span class="badge bg-danger"><?= __('Required') ?></span>'
                    : '<span class="badge bg-success"><?= __('Optional') ?></span>';
            }},
            { data: 'last_updated', name: 'last_updated' },
            { data: 'actions', name: 'actions', orderable: false, searchable: false, render: function(data, type, row) {
                const editUrl = '<?= htmlspecialchars($policyEditUrl ?? '', ENT_QUOTES) ?>' + '?type=' + encodeURIComponent(row.type);
                let actions = '<div class="d-flex gap-2">';
                actions += '<a href="' + editUrl + '" class="btn btn-outline-primary btn-sm" title="<?= __('Edit') ?>">';
                actions += '<i class="mdi mdi-pencil-outline"></i></a>';
                actions += '</div>';
                return actions;
            }}
        ],
        order: [[0, 'asc']],
        pageLength: 10,
        language: {
            emptyTable: '<?= __('No compliance policies found') ?>',
            loadingRecords: '<?= __('Loading...') ?>',
            processing: '<?= __('Processing...') ?>'
        }
    });

    function htmlEscape(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
});
</script>
