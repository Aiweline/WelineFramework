$savePolicyUrl = (string) ($this->getData('save_policy_url') ?? '');
$consentExportUrl = (string) ($this->getData('consent_export_url') ?? '');
$policyTypeMeta = [
    'privacy' => [
        'name' => (string) __('Privacy Policy'),
        'description' => (string) __('Data collection, usage, and user privacy controls'),
    ],
    'terms' => [
        'name' => (string) __('Terms of Service'),
        'description' => (string) __('Platform terms and transaction rules'),
    ],
    'cookie' => [
        'name' => (string) __('Cookie Policy'),
        'description' => (string) __('Cookie usage and tracking preferences'),
    ],
    'marketing' => [
        'name' => (string) __('Marketing Policy'),
        'description' => (string) __('Marketing communications consent'),
    ],
];
$policyRows = [];
foreach ($consentTypes as $type) {
    $meta = $policyTypeMeta[$type] ?? [
        'name' => ucfirst((string) $type),
        'description' => '',
    ];
    $policyRows[] = [
        'type' => (string) $type,
        'name' => $meta['name'],
        'description' => $meta['description'],
        'required' => in_array($type, ['privacy', 'terms'], true),
        'last_updated' => date('Y-m-d'),
    ];
}
