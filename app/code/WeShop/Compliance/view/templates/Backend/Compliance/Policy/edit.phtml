$policyTitle = (string) ($this->getData('policy_title') ?? __('Policy'));
$policyContent = $this->getData('policy_content') ?? [];
$saveUrl = (string) ($this->getData('save_url') ?? '');
$backUrl = (string) ($this->getData('back_url') ?? '');
$sectionTitleTemplate = (string) __('Section %{1} Title', ['__SECTION_INDEX__']);
