                    </ol>
                </div>
            </div>
        </div>
    </div>

    <form action="<?= htmlspecialchars($saveUrl, ENT_QUOTES) ?>" method="post">
        <input type="hidden" name="type" value="<?= htmlspecialchars($policyType, ENT_QUOTES) ?>">

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4"><?= __('Policy Content') ?></h4>

                        <div class="mb-4">
                            <label class="form-label fw-semibold"><?= __('Policy Sections') ?></label>
                            <p class="text-muted small"><?= __('Configure the sections displayed on the storefront compliance page.') ?></p>
                        </div>

                        <?php if (is_array($policyContent) && count($policyContent) > 0): ?>
                            <?php foreach ($policyContent as $index => $section): ?>
                                <?php
                                $sectionTitle = is_array($section) ? ($section['title'] ?? '') : '';
                                $sectionBody = is_array($section) ? ($section['body'] ?? '') : '';
                                ?>
                                <div class="border rounded-3 p-4 mb-3">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label"><?= __('Section %{1} Title', [$index + 1]) ?></label>
                                            <input type="text" class="form-control" name="sections[<?= $index ?>][title]" value="<?= htmlspecialchars((string) $sectionTitle, ENT_QUOTES) ?>">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label"><?= __('Section %{1} Content', [$index + 1]) ?></label>
                                            <textarea class="form-control" name="sections[<?= $index ?>][body]" rows="4"><?= htmlspecialchars((string) $sectionBody, ENT_QUOTES) ?></textarea>
                                        </div>
                                    </div>
                                </div>
                            <?php endforeach; ?>
                        <?php else: ?>
                            <div class="alert alert-info">
                                <i class="mdi mdi-information-outline me-2"></i>
                                <?= __('No policy content configured yet. Please add sections below.') ?>
                            </div>
                            <div class="border rounded-3 p-4 mb-3">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label"><?= __('Section 1 Title') ?></label>
                                        <input type="text" class="form-control" name="sections[0][title]" value="">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label"><?= __('Section 1 Content') ?></label>
                                        <textarea class="form-control" name="sections[0][body]" rows="4"></textarea>
                                    </div>
                                </div>
                            </div>
                        <?php endif; ?>

                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-secondary" id="add-section-btn">
                                <i class="mdi mdi-plus me-1"></i><?= __('Add Section') ?>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4"><?= __('Policy Settings') ?></h4>

                        <div class="mb-3">
                            <label class="form-label fw-semibold"><?= __('Policy Type') ?></label>
                            <input type="text" class="form-control" value="<?= htmlspecialchars($policyType, ENT_QUOTES) ?>" disabled>
                            <div class="form-text"><?= __('Policy type cannot be changed after creation.') ?></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold"><?= __('Display Name') ?></label>
                            <input type="text" class="form-control" name="display_name" value="<?= htmlspecialchars($policyTitle, ENT_QUOTES) ?>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold"><?= __('Required Consent') ?></label>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="required-switch" name="required" value="1" <?= in_array($policyType, ['privacy', 'terms'], true) ? 'checked' : '' ?>>
                                <label class="form-check-label" for="required-switch"><?= __('Users must acknowledge this policy') ?></label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold"><?= __('Last Modified') ?></label>
                            <input type="text" class="form-control" value="<?= date('Y-m-d H:i:s') ?>" disabled>
                        </div>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h4 class="card-title mb-3"><?= __('Actions') ?></h4>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-content-save-outline me-1"></i><?= __('Save Policy') ?>
                            </button>
                            <a href="<?= htmlspecialchars($backUrl, ENT_QUOTES) ?>" class="btn btn-outline-secondary">
                                <i class="mdi mdi-arrow-left me-1"></i><?= __('Back to Dashboard') ?>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const addSectionBtn = document.getElementById('add-section-btn');
    const form = addSectionBtn ? addSectionBtn.closest('form') : null;

    if (addSectionBtn && form) {
        addSectionBtn.addEventListener('click', function() {
            const sectionCount = form.querySelectorAll('.border.rounded-3').length;
            const newIndex = sectionCount;

            const template = document.createElement('div');
            template.className = 'border rounded-3 p-4 mb-3';
            template.innerHTML = `
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label"><?= htmlspecialchars($sectionTitleTemplate, ENT_QUOTES) ?></label>
                        <input type="text" class="form-control" name="sections[${newIndex}][title]" value="">
                    </div>
                    <div class="col-12">
                        <label class="form-label"><?= htmlspecialchars($sectionContentTemplate, ENT_QUOTES) ?></label>
                        <textarea class="form-control" name="sections[${newIndex}][body]" rows="4"></textarea>
                    </div>
                </div>
            `;
            template.innerHTML = template.innerHTML
                .replaceAll('__SECTION_INDEX__', String(newIndex + 1));

            addSectionBtn.parentElement.parentElement.insertBefore(template, addSectionBtn.parentElement);
        });
    }
});
</script>
