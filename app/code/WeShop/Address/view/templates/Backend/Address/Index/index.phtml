<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0"><?= htmlspecialchars($page_title ?? __('Address Management')) ?></h4>
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="@backend-url('*/backend')"><?= __('WeShop') ?></a></li>
                        <li class="breadcrumb-item"><a href="@backend-url('*/backend/customer')"><?= __('Customer') ?></a></li>
                        <li class="breadcrumb-item active"><?= __('Address') ?></li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <block class="Weline\Component\Block\OffCanvas"
                   template="Weline_Component::off-canvas.phtml"
                   id="offcanvasRightAddressForm"
                   action="*/backend/address/edit"
                   submit-button-text='<lang>Save</lang>'
                   flush="1"
                   target-button-text='<lang>Add Address</lang>'
                   target-button-class="btn btn-primary"
                   title='<lang>Add Address</lang>'
                   save="1"
                   close-button-show="1"
                   close-button-text='<lang>Close</lang>'
                   direction="right"
                   class-names="w-75"
                   off-canvas-body-style=""/>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title"><?= __('Address List') ?></h4>
                    <p class="card-title-desc"><?= __('Manage customer delivery addresses') ?></p>

                    <div class="table-responsive">
                        <table id="address-table" class="table table-striped table-bordered">
                            <thead>
                            <tr>
                                <th data-priority="1"><?= __('ID') ?></th>
                                <th data-priority="1"><?= __('Customer') ?></th>
                                <th data-priority="1"><?= __('Contact Name') ?></th>
                                <th data-priority="3"><?= __('Phone') ?></th>
                                <th data-priority="2"><?= __('Full Address') ?></th>
                                <th data-priority="3"><?= __('Default') ?></th>
                                <th data-priority="1"><?= __('Actions') ?></th>
                            </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof DataTable === 'undefined') {
        console.warn('DataTable not loaded');
        return;
    }

    const addressTable = new DataTable('#address-table', {
        processing: true,
        serverSide: true,
        ajax: {
            url: '@backend-url("*/api/address/list")',
            type: 'GET',
            data: function(d) {
                d.customer_id = '{{customer_id}}';
            }
        },
        columns: [
            { data: 'address_id', name: 'address_id' },
            { data: 'customer_id', name: 'customer_id' },
            { data: 'contact_name', name: 'contact_name' },
            { data: 'telephone', name: 'telephone' },
            { data: 'full_address', name: 'full_address' },
            { data: 'is_default', name: 'is_default', render: function(data) {
                if (data) {
                    return '<span class="badge bg-primary"><?= __('Default') ?></span>';
                }
                return '';
            }},
            { data: 'actions', name: 'actions', orderable: false, searchable: false, render: function(data, type, row) {
                const editUrl = '<?= $edit_url ?? '' ?>'.replace('id=0', 'id=' + row.address_id);
                const deleteUrl = '<?= $delete_url ?? '' ?>'.replace('id=0', 'id=' + row.address_id);
                const setDefaultUrl = '<?= $set_default_url ?? '' ?>'.replace('id=0', 'id=' + row.address_id);

                let actions = '<div class="d-flex gap-2">';
                actions += '<a href="' + editUrl + '" class="btn btn-outline-primary btn-sm" title="<?= __('Edit') ?>">';
                actions += '<i class="mdi mdi-pencil-outline"></i></a>';

                if (!row.is_default) {
                    actions += '<button class="btn btn-outline-success btn-sm" ';
                    actions += 'w-ajax="' + setDefaultUrl + '" ';
                    actions += 'w-method="post" ';
                    actions += 'w-data=\'{"customer_id":"' + row.customer_id + '"}\' ';
                    actions += 'w-msg="<?= __('Set this as default address?') ?>" ';
                    actions += 'title="<?= __('Set Default') ?>">';
                    actions += '<i class="mdi mdi-star-outline"></i></button>';
                }

                actions += '<button class="btn btn-outline-danger btn-sm" ';
                actions += 'w-ajax="' + deleteUrl + '" ';
                actions += 'w-method="post" ';
                actions += 'w-data=\'{"customer_id":"' + row.customer_id + '"}\' ';
                actions += 'w-delete="true" ';
                actions += 'w-msg="<?= __('Delete this address? This action cannot be undone!') ?>" ';
                actions += 'title="<?= __('Delete') ?>">';
                actions += '<i class="mdi mdi-trash-can-outline"></i></button>';

                actions += '</div>';
                return actions;
            }}
        ],
        order: [[0, 'desc']],
        pageLength: 10,
        language: {
            emptyTable: '<?= __('No addresses found') ?>',
            loadingRecords: '<?= __('Loading...') ?>',
            processing: '<?= __('Processing...') ?>'
        }
    });

    window.addEventListener('message', function(event) {
        if (!event || !event.data || event.data.type !== 'weshop-address:offcanvas-saved') {
            return;
        }
        const activeOffcanvas = document.querySelector('.offcanvas.show');
        if (activeOffcanvas && typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            bootstrap.Offcanvas.getOrCreateInstance(activeOffcanvas).hide();
        }
        if (addressTable && addressTable.ajax && typeof addressTable.ajax.reload === 'function') {
            addressTable.ajax.reload(null, false);
        } else {
            window.location.reload();
        }
    });
});
</script>

<js:part name="w-delete"/>
