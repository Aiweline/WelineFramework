<?php
/**
 * Compare storefront account-center discovery card.
 *
 * @hook-priority 220
 * @hook-sort-order 15
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */
$compareCount = (int) ($this->getData('compare_count') ?? 0);
$comparePreview = (array) ($this->getData('compare_preview') ?? []);
?>
<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Side-by-Side Decisions') ?></p>
            <h2 class="mt-2 text-2xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Compare Products') ?></h2>
        </div>
        <a href="<?= $this->getUrl('compare') ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open Compare') ?></a>
    </div>

    <div class="mt-6 rounded-3xl border border-border-light bg-background-light p-5 dark:border-border-dark dark:bg-background-dark">
        <p class="text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark"><?= __('Products In Compare') ?></p>
        <p class="mt-2 text-3xl font-black text-text-primary-light dark:text-text-primary-dark"><?= $compareCount ?></p>
        <p class="mt-2 text-sm leading-6 text-text-secondary-light dark:text-text-secondary-dark">
            <?= __('Keep your shortlisted products together so price, availability, and key details stay easy to compare before checkout.') ?>
        </p>
    </div>

    <?php if ($comparePreview): ?>
        <div class="mt-6 space-y-3">
            <?php foreach (array_slice($comparePreview, 0, 2) as $product): ?>
                <a href="<?= $this->getUrl('product/view', ['id' => $product['product_id'] ?? 0]) ?>" class="group flex items-center gap-4 rounded-2xl border border-border-light bg-background-light p-3 transition hover:border-primary dark:border-border-dark dark:bg-background-dark">
                    <div class="h-16 w-16 overflow-hidden rounded-2xl bg-surface-light dark:bg-surface-dark">
                        <img src="<?= htmlspecialchars((string) ($product['image'] ?? ''), ENT_QUOTES) ?>" alt="<?= htmlspecialchars((string) ($product['name'] ?? ''), ENT_QUOTES) ?>" class="h-full w-full object-cover">
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate font-semibold text-text-primary-light group-hover:text-primary dark:text-text-primary-dark"><?= htmlspecialchars((string) ($product['name'] ?? ''), ENT_QUOTES) ?></p>
                        <p class="mt-1 text-sm text-text-secondary-light dark:text-text-secondary-dark"><?= $this->formatPrice((float) ($product['price'] ?? 0)) ?></p>
                    </div>
                </a>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="mt-6 rounded-3xl border border-dashed border-border-light bg-background-light px-5 py-8 text-sm leading-6 text-text-secondary-light dark:border-border-dark dark:bg-background-dark dark:text-text-secondary-dark">
            <?= __('Add products from category and product pages to build a side-by-side shortlist inside your account center.') ?>
        </div>
    <?php endif; ?>
</article>
