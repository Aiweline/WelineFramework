<?php
/**
 * Compare CTA for storefront product detail pages.
 *
 * @hook-priority 200
 * @hook-sort-order 0
 * @hook-solo false
 */
$product = (array) ($this->getData('product') ?? []);
$productId = (int) ($product['product_id'] ?? $this->getData('product_id') ?? 0);
if ($productId <= 0) {
    return;
}
$rootId = 'weshop-compare-cta-' . $productId . '-' . substr(sha1((string) $productId), 0, 8);
?>
<div id="<?= $rootId ?>" class="weshop-compare-cta" data-product-id="<?= $productId ?>">
    <button type="button" class="weshop-compare-cta__button add-to-compare" data-compare-button>
        <span class="weshop-compare-cta__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
                <path d="M7 7h11l-3-3 1.4-1.4L21.8 8l-5.4 5.4L15 12l3-3H7V7Zm10 10H6l3 3-1.4 1.4L2.2 16l5.4-5.4L9 12l-3 3h11v2Z"/>
            </svg>
        </span>
        <span data-compare-label><?= __('Add to Compare') ?></span>
    </button>
    <span class="weshop-compare-cta__status" data-compare-status aria-live="polite"></span>
</div>

<style>
.weshop-compare-cta {
    --weshop-compare-primary: var(--color-primary, var(--color-accent, var(--weline-theme-primary, #007185)));
    --weshop-compare-primary-hover: var(--color-primary-hover, var(--color-accent-hover, var(--weline-theme-primary-hover, #005f6b)));
    --weshop-compare-surface: var(--color-bg-primary, var(--weline-theme-surface, #fff));
    --weshop-compare-surface-subtle: var(--color-bg-secondary, var(--weline-theme-surface-subtle, #f7fafa));
    --weshop-compare-primary-soft: var(--color-primary-bg-subtle, color-mix(in srgb, var(--weshop-compare-primary) 12%, var(--weshop-compare-surface)));
    --weshop-compare-primary-border: var(--color-primary-border-subtle, color-mix(in srgb, var(--weshop-compare-primary) 34%, var(--weline-theme-border-color, #d5d9d9)));
    --weshop-compare-border: var(--color-border-light, var(--weline-theme-border-color, #d5d9d9));
    --weshop-compare-text: var(--color-text-primary, var(--weline-theme-text, #0f1111));
    --weshop-compare-text-muted: var(--color-text-secondary, var(--weline-theme-text-muted, #565959));
    --weshop-compare-success: var(--color-success, var(--weline-theme-success, #047857));
    --weshop-compare-danger: var(--color-danger, var(--color-error, var(--weline-theme-danger, #b91c1c)));
    margin-top: .65rem;
}
.weshop-compare-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .45rem;
    width: 100%;
    min-height: 2.65rem;
    padding: 0 .9rem;
    border: var(--weline-theme-border-width, 1px) var(--weline-theme-border-style, solid) var(--weshop-compare-border);
    border-radius: var(--weline-theme-radius-md, 8px);
    background: var(--weshop-compare-surface);
    color: var(--weshop-compare-text);
    cursor: pointer;
    font-size: .9rem;
    font-weight: 750;
    line-height: 1.2;
    text-decoration: none;
    transition: background-color .15s ease, border-color .15s ease, color .15s ease, box-shadow .15s ease, transform .15s ease;
}
.weshop-compare-cta__button:hover:not(:disabled) {
    border-color: var(--weshop-compare-primary);
    background: var(--weshop-compare-primary-soft);
    color: var(--weshop-compare-primary-hover);
    transform: translateY(-1px);
}
.weshop-compare-cta__button:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--weshop-compare-primary) 24%, transparent);
}
.weshop-compare-cta__button:disabled {
    opacity: .65;
    cursor: not-allowed;
}
.weshop-compare-cta__button.is-active {
    border-color: var(--weshop-compare-primary);
    background: var(--weshop-compare-primary-soft);
    color: var(--weshop-compare-primary-hover);
}
.weshop-compare-cta__icon {
    display: inline-flex;
    width: .95rem;
    height: .95rem;
}
.weshop-compare-cta__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
}
.weshop-compare-cta__status {
    display: block;
    min-height: .9rem;
    margin-top: .28rem;
    color: var(--weshop-compare-text-muted);
    font-size: .74rem;
    line-height: 1.2;
}
.weshop-compare-cta__status.is-success {
    color: var(--weshop-compare-success);
}
.weshop-compare-cta__status.is-error {
    color: var(--weshop-compare-danger);
}
</style>

<script>
(function() {
    var root = document.getElementById(<?= json_encode($rootId, JSON_UNESCAPED_SLASHES) ?>);
    if (!root || root.dataset.initialized === '1') return;
    root.dataset.initialized = '1';

    var productId = Number(root.dataset.productId || 0);
    var button = root.querySelector('[data-compare-button]');
    var label = root.querySelector('[data-compare-label]');
    var status = root.querySelector('[data-compare-status]');
    var compareApiPromise = null;

    function setStatus(message, type) {
        if (!status) return;
        status.textContent = message || '';
        status.classList.remove('is-success', 'is-error');
        if (type) status.classList.add('is-' + type);
    }

    function getCompareApi() {
        if (!compareApiPromise) {
            compareApiPromise = Promise.resolve().then(function() {
                if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                    return window.Weline.Api.resource('compare');
                }
                if (window.WelineApiModule && typeof window.WelineApiModule.resource === 'function') {
                    return window.WelineApiModule.resource('compare');
                }
                throw new Error(<?= json_encode((string) __('Compare API is not initialized'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
            });
        }
        return compareApiPromise;
    }

    function normalizePayload(payload) {
        if (!payload || typeof payload !== 'object') return payload || {};
        if (Object.prototype.hasOwnProperty.call(payload, 'code') && payload.data && typeof payload.data === 'object') {
            var code = Number(payload.code || 0);
            return Object.assign({
                code: code,
                message: payload.msg || payload.data.message || '',
                success: code >= 200 && code < 300 && payload.data.success !== false
            }, payload.data);
        }
        return payload;
    }

    function showToast(message, type) {
        if (window.Weline && window.Weline.Toast && typeof window.Weline.Toast.show === 'function') {
            window.Weline.Toast.show(message, type || 'info');
        }
    }

    function addToCompare() {
        if (!button || productId <= 0) return;
        button.disabled = true;
        setStatus(<?= json_encode((string) __('Adding'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, '');
        getCompareApi()
            .then(function(api) {
                if (!api || typeof api.add !== 'function') {
                    throw new Error(<?= json_encode((string) __('Compare API does not support the add operation'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
                }
                return api.add({ product_id: productId });
            })
            .then(normalizePayload)
            .then(function(result) {
                if (!result || result.success === false) {
                    throw new Error(result && result.message ? result.message : <?= json_encode((string) __('Failed to add to compare'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
                }
                button.classList.add('is-active');
                button.setAttribute('aria-pressed', 'true');
                if (label) label.textContent = <?= json_encode((string) __('Added to compare'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
                setStatus(<?= json_encode((string) __('Added to compare list.'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
                showToast(<?= json_encode((string) __('Added to compare list.'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>, 'success');
                document.dispatchEvent(new CustomEvent('weshop:addToCompare', {
                    detail: {
                        product_id: productId,
                        productId: productId,
                        compare_item_id: result.item_id,
                        compareItemId: result.item_id,
                        compare_count: result.compare_count,
                        compareCount: result.compare_count
                    }
                }));
            })
            .catch(function(error) {
                var message = error && error.message ? error.message : <?= json_encode((string) __('Failed to add to compare'), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
                setStatus(message, 'error');
                showToast(message, 'error');
            })
            .finally(function() {
                button.disabled = false;
            });
    }

    if (button) {
        button.setAttribute('aria-pressed', 'false');
        button.addEventListener('click', addToCompare);
    }
})();
</script>
