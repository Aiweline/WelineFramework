<script>
(function() {
    var cards = document.querySelectorAll('.sales-report__card');
    var empty = document.querySelector('.sales-report__empty');
    var hasData = false;

    cards.forEach(function(card) {
        var valueEl = card.querySelector('.sales-report__card-value');
        if (valueEl) {
            var text = valueEl.textContent || '';
            var num = parseFloat(text.replace(/[^0-9.-]/g, ''));
            if (!isNaN(num) && num > 0) {
                hasData = true;
            }
        }
    });

    if (!hasData && empty) {
        empty.style.display = 'block';
    }
})();
</script>
