<script>
(function() {
    'use strict';

    // 折扣类型切换时更新后缀文字
    function updateDiscountValueUI() {
        var discountType = document.getElementById('discount_type').value;
        var suffix = document.getElementById('discountValueSuffix');
        var help = document.getElementById('discountValueHelp');
        var maxDiscountField = document.getElementById('max_discount').closest('.mb-3');

        if (discountType === 'percent') {
            suffix.textContent = '%';
            if (help) {
                help.textContent = '<?= __('百分比折扣（1-100），系统会自动限制最高折扣金额') ?>';
            }
            if (maxDiscountField) {
                maxDiscountField.style.display = '';
            }
        } else {
            suffix.textContent = '<?= __('元') ?>';
            if (help) {
                help.textContent = '<?= __('固定金额时表示减免的金额') ?>';
            }
            if (maxDiscountField) {
                maxDiscountField.style.display = 'none';
            }
        }
    }

    // 生成随机优惠券代码
    function generateCouponCode() {
        var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        var code = '';
        for (var i = 0; i < 8; i++) {
            code += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        // 添加前缀
        var prefixes = ['SAVE', 'DISCOUNT', 'PROMO', 'COUPON'];
        var prefix = prefixes[Math.floor(Math.random() * prefixes.length)];
        code = prefix + code;

        var codeInput = document.getElementById('code');
        if (codeInput) {
            codeInput.value = code;
            codeInput.classList.remove('is-invalid');
            codeInput.classList.add('is-valid');
        }
    }

    // 表单验证
    function validateForm() {
        var form = document.getElementById('couponForm');
        if (!form) return false;

        var name = document.getElementById('name');
        var code = document.getElementById('code');
        var discountValue = document.getElementById('discount_value');
        var startDate = document.getElementById('start_date');
        var endDate = document.getElementById('end_date');

        var isValid = true;

        // 清除之前的验证状态
        form.classList.remove('was-validated');

        // 检查必填字段
        if (!name.value.trim()) {
            name.classList.add('is-invalid');
            isValid = false;
        }

        if (!code.value.trim()) {
            code.classList.add('is-invalid');
            isValid = false;
        }

        if (!discountValue.value || parseFloat(discountValue.value) < 0) {
            discountValue.classList.add('is-invalid');
            isValid = false;
        }

        // 验证百分比折扣范围
        var discountType = document.getElementById('discount_type').value;
        if (discountType === 'percent') {
            var value = parseFloat(discountValue.value);
            if (value <= 0 || value > 100) {
                discountValue.classList.add('is-invalid');
                isValid = false;
                Swal.fire({
                    title: '<?= __('验证错误') ?>',
                    text: '<?= __('百分比折扣值必须在1-100之间') ?>',
                    icon: 'error',
                    confirmButtonText: '<?= __('确定') ?>'
                });
                return false;
            }
        }

        // 验证日期范围
        if (startDate.value && endDate.value) {
            var start = new Date(startDate.value);
            var end = new Date(endDate.value);
            if (start >= end) {
                endDate.classList.add('is-invalid');
                isValid = false;
                Swal.fire({
                    title: '<?= __('验证错误') ?>',
                    text: '<?= __('结束日期必须晚于开始日期') ?>',
                    icon: 'error',
                    confirmButtonText: '<?= __('确定') ?>'
                });
                return false;
            }
        }

        return isValid;
    }

    // 初始化
    document.addEventListener('DOMContentLoaded', function() {
        // 绑定折扣类型切换事件
        var discountTypeSelect = document.getElementById('discount_type');
        if (discountTypeSelect) {
            discountTypeSelect.addEventListener('change', updateDiscountValueUI);
            updateDiscountValueUI();
        }

        // 绑定生成代码按钮
        var generateBtn = document.getElementById('generateCodeBtn');
        if (generateBtn) {
            generateBtn.addEventListener('click', generateCouponCode);
        }

        // 移除输入时的无效状态
        var inputs = document.querySelectorAll('input, select');
        inputs.forEach(function(input) {
            input.addEventListener('input', function() {
                this.classList.remove('is-invalid');
            });
            input.addEventListener('change', function() {
                this.classList.remove('is-invalid');
            });
        });

        // 表单提交验证
        var form = document.getElementById('couponForm');
        if (form) {
            form.addEventListener('submit', function(event) {
                if (!validateForm()) {
                    event.preventDefault();
                    event.stopPropagation();
                    return false;
                }

                // 显示加载状态
                var submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><lang>保存中...</lang>';
                }

                return true;
            });
        }
    });
})();
</script>
