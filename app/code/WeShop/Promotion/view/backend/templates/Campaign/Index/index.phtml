<script>
(function() {
    'use strict';

    var WeShopCampaign = {
        listUrl: '<?= $this->getBackendUrl('*/backend/campaign') ?>',
        editUrl: '<?= $this->getBackendUrl('*/backend/campaign/edit') ?>',
        saveUrl: '<?= $this->getBackendUrl('*/backend/campaign/save') ?>',
        deleteUrl: '<?= $this->getBackendUrl('*/backend/campaign/post-delete') ?>',

        openAddOffcanvas: function() {
            var triggerBtn = document.querySelector('.campaign-add-offcanvas-trigger');
            if (triggerBtn) {
                triggerBtn.click();
            }
        },

        openEditOffcanvas: function(id) {
            var offcanvasElement = document.getElementById('campaignEditOffcanvas');
            var iframe = document.getElementById('campaignEditOffcanvasIframe');

            iframe.src = this.editUrl + '?campaign_id=' + id + '&isIframe=true';

            var offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
            if (!offcanvas) {
                offcanvas = new bootstrap.Offcanvas(offcanvasElement);
            }
            offcanvas.show();
        },

        viewStats: function(id) {
            // 跳转到统计页面
            window.location.href = this.listUrl + '/stats?campaign_id=' + id;
        },

        flushEditIframe: function() {
            showLoading();
            var iframe = $('#campaignEditOffcanvasIframe');
            iframe.attr('src', iframe.attr('src'));
            hideLoading();
        },

        deleteCampaign: function(id, name) {
            var self = this;
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                html: '<?= __('确定要删除促销活动') ?>: <strong>' + name + '</strong>？',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '<?= __('确认删除') ?>',
                cancelButtonText: '<?= __('取消') ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    var url = self.deleteUrl;
                    var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'campaign_id=' + id };
                    window.Weline.Api.request(url, opts)
                    .then(function(res) {
                        var data = (res && res.data) !== undefined ? res.data : res;
                        if (data.status || data.success) {
                            Swal.fire({
                                title: '<?= __('成功') ?>',
                                text: data.message || '<?= __('删除成功') ?>',
                                icon: 'success',
                                confirmButtonText: '<?= __('确定') ?>'
                            }).then(function() {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                title: '<?= __('错误') ?>',
                                text: data.message || '<?= __('删除失败') ?>',
                                icon: 'error',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            title: '<?= __('错误') ?>',
                            text: '<?= __('网络错误，请稍后重试') ?>',
                            icon: 'error',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        },

        initEditSaveButton: function() {
            var self = this;

            $('#campaignEditOffcanvas').on('show.bs.offcanvas', function() {
                var Iframe = $('#campaignEditOffcanvasIframe');
                Iframe.on('load', function() {
                    try {
                        var iframeSrc = Iframe.attr('src') || '';
                        var iframeLocation = Iframe[0].contentWindow.location.href || '';
                        var isOffcanvasResultPage = iframeSrc.indexOf('/component/offcanvas/') !== -1 ||
                                                    iframeLocation.indexOf('/component/offcanvas/') !== -1;

                        if (isOffcanvasResultPage) {
                            return;
                        }

                        var form = Iframe.contents().find('body').find('form');
                        form = (form && form.length > 0) ? form : undefined;
                        if (form !== undefined && form.length > 0) {
                            for (var i = 0; i < form.length; i++) {
                                if ($(form[i]).find(':submit').length === 0) {
                                    form[i].insertAdjacentHTML('beforeend', '<input type="submit" class="sr-only" style="display:none;">')
                                }
                            }
                        }
                    } catch (e) {
                        console.log('OffCanvas form check skipped:', e);
                    }
                });
            });

            $('#campaignEditOffcanvasSave').on('click', function() {
                var iframe = $('#campaignEditOffcanvasIframe');
                var form = iframe.contents().find('body').find('form');
                form = (form && form.length > 0) ? form : undefined;

                try {
                    var iframeSrc = iframe.attr('src') || '';
                    var iframeLocation = '';
                    try {
                        iframeLocation = iframe[0].contentWindow.location.href || '';
                    } catch (e) {}
                    var isOffcanvasResultPage = iframeSrc.indexOf('/component/offcanvas/') !== -1 ||
                                                iframeLocation.indexOf('/component/offcanvas/') !== -1;

                    if (isOffcanvasResultPage) {
                        return;
                    }

                    if (form !== undefined && form.length > 0) {
                        for (var i = 0; i < form.length; i++) {
                            var sub_form = $(form[i]);
                            sub_form.find(':submit').click();
                            showLoading();
                        }
                        hideLoading();
                    } else {
                        console.log('表单未找到');
                    }
                } catch (e) {
                    console.log('OffCanvas form submit check skipped:', e);
                }
            });
        }
    };

    window.WeShopCampaign = WeShopCampaign;

    $(document).ready(function() {
        WeShopCampaign.initEditSaveButton();
    });
})();
</script>
