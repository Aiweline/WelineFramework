<?php
/**
 * WeShop Cart模块 - 产品加入购物车按钮
 * 
 * 实现 WeShop_Product::frontend::product::add-to-cart::button 钩子
 * 此hook为slot类型，Cart模块提供默认实现
 * 
 * 可用变量：
 * - $product: 产品数据数组
 * - $product_id: 产品ID
 * - $in_stock: 是否有库存
 * - $is_configurable: 是否为可配置产品
 * 
 * @hook-priority 100
 * @hook-sort-order 1
 * @hook-solo false
 */

/** @var \Weline\Framework\View\Template $this */

// 获取产品数据
$product = $this->getData('product') ?? [];
$productId = (int)($product['product_id'] ?? $this->getData('product_id') ?? 0);
$inStock = $this->getData('in_stock') ?? ((int)($product['stock'] ?? 0) > 0);
$isConfigurable = $this->getData('is_configurable') ?? false;
$buttonText = $inStock ? __('加入购物车') : __('缺货');
$buttonClass = $this->getData('button_class') ?? 'btn btn-primary btn-add-to-cart';
$pixelValue = (float)($product['price'] ?? $this->getData('price') ?? 0);

if ($productId <= 0) {
    return;
}
?>

<button type="button" 
        class="<?= htmlspecialchars(trim($buttonClass . ' weline-pixel::add_to_cart')) ?>" 
        data-product-id="<?= $productId ?>"
        data-is-configurable="<?= $isConfigurable ? '1' : '0' ?>"
        data-action="add-to-cart"
        <?= !$inStock ? 'disabled' : '' ?>>
    <span class="btn-text weline-pixel::add_to_cart"><?= $buttonText ?></span>
    <span class="weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)$pixelValue, ENT_QUOTES, 'UTF-8') ?>" hidden><?= htmlspecialchars((string)$pixelValue, ENT_QUOTES, 'UTF-8') ?></span>
    <span class="btn-loading" style="display: none;">
        <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <circle class="spinner-circle" cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="60" stroke-dashoffset="20">
                <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/>
            </circle>
        </svg>
    </span>
</button>
