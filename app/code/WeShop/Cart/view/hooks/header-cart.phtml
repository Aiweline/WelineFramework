<?php
/**
 * Header 购物车图标 Hook 实现
 * 
 * 此 Hook 实现替换 Weline_Theme 默认的购物车图标
 * 集成 MiniCart Widget，提供完整的购物车功能
 * 
 * @hook header-cart
 * @hook-priority 100
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Cart\Service\CartService;
use Weline\Framework\Session\SessionFactory;

// 获取购物车数据
$cartCount = 0;

try {
    $session = SessionFactory::getInstance()->createFrontendSession();
    $customerId = (int)($session->getUserId() ?? 0);
    
    if ($customerId > 0) {
        $cartService = ObjectManager::getInstance(CartService::class);
        $cartCount = $cartService->getCartItemCount($customerId);
    }
} catch (\Exception $e) {
    // 忽略错误，使用默认值
}
?>

<!-- Header 购物车按钮 -->
<button type="button" 
        class="action-link cart-link header-cart-trigger" 
        data-action="open-mini-cart"
        aria-label="<?= __('打开购物车') ?>"
        aria-haspopup="dialog"
        aria-expanded="false">
    <span class="cart-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" focusable="false" width="24" height="24">
            <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
            <circle cx="17" cy="20" r="1.5" fill="currentColor"/>
            <path d="M4 4h2l1.5 9h9l2-7H7" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </span>
    <span class="cart-count <?= $cartCount > 0 ? 'has-items' : '' ?>" 
          data-cart-count
          <?= $cartCount === 0 ? 'style="display:none;"' : '' ?>>
        <?= $cartCount > 99 ? '99+' : $cartCount ?>
    </span>
    <span class="action-line-2"><lang>购物车</lang></span>
</button>

<!-- MiniCart Widget -->
<?= $this->fetch('WeShop_Cart::theme/frontend/widgets/mini-cart/drawer.phtml', [
    'position' => 'right',
    'autoOpen' => true,
]) ?>

<script>
(function () {
    function bindHeaderMiniCart() {
        var trigger = document.querySelector('.header-cart-trigger[data-action="open-mini-cart"]');
        var drawer = document.getElementById('mini-cart-drawer');
        var overlay = document.getElementById('mini-cart-overlay');
        if (!trigger || !drawer || !overlay || trigger.dataset.miniCartBound === 'true') {
            return;
        }

        function setOpen(open) {
            drawer.classList.toggle('is-open', open);
            overlay.classList.toggle('is-visible', open);
            overlay.style.display = open ? 'block' : 'none';
            trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
            drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
            overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
        }

        trigger.dataset.miniCartBound = 'true';
        trigger.addEventListener('click', function (event) {
            event.preventDefault();
            setOpen(!drawer.classList.contains('is-open'));
        });

        overlay.addEventListener('click', function () {
            setOpen(false);
        });

        document.querySelectorAll('[data-action="close-mini-cart"]').forEach(function (button) {
            button.addEventListener('click', function (event) {
                event.preventDefault();
                setOpen(false);
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindHeaderMiniCart);
    } else {
        bindHeaderMiniCart();
    }
})();
</script>

