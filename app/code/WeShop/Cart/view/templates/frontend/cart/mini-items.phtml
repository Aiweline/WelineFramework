<?php
/**
 * MiniCart 商品列表模板
 * 
 * 用于 AJAX 加载迷你购物车商品列表
 * 
 * @var array $items 商品列表
 */
$items = $this->getData('items') ?? [];
?>

<?php if (empty($items)): ?>
    <div class="mini-cart-empty" id="mini-cart-empty">
        <div class="empty-state">
            <span class="material-symbols-outlined empty-icon">shopping_cart</span>
            <p class="empty-message"><lang>Your cart is empty</lang></p>
            <a href="<?= $this->getUrl('/') ?>" class="start-shopping-link" data-action="close-mini-cart">
                <lang>Start Shopping</lang>
            </a>
        </div>
    </div>
<?php else: ?>
    <?php foreach ($items as $item): ?>
        <div class="mini-cart-item" 
             data-item-id="<?= htmlspecialchars((string)($item['cart_id'] ?? '')) ?>" 
             data-product-id="<?= htmlspecialchars((string)($item['product_id'] ?? '')) ?>">
            
            <!-- 商品图片 -->
            <div class="mini-cart-item__image">
                <?php if (!empty($item['image'])): ?>
                    <img src="<?= htmlspecialchars($item['image']) ?>" 
                         alt="<?= htmlspecialchars($item['name'] ?? '') ?>" 
                         loading="lazy"/>
                <?php else: ?>
                    <div class="mini-cart-item__placeholder">
                        <span class="material-symbols-outlined">image</span>
                    </div>
                <?php endif; ?>
            </div>
            
            <!-- 商品详情 -->
            <div class="mini-cart-item__details">
                <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>" class="mini-cart-item__name">
                    <?= htmlspecialchars($item['name'] ?? '') ?>
                </a>
                
                <?php if (!empty($item['options'])): ?>
                    <div class="mini-cart-item__options">
                        <?= htmlspecialchars($item['options']) ?>
                    </div>
                <?php endif; ?>
                
                <div class="mini-cart-item__price">
                    <?= $item['price_formatted'] ?? $this->formatPrice($item['price'] ?? 0) ?>
                </div>
                
                <!-- 数量控制 -->
                <div class="mini-cart-item__qty">
                    <button type="button" 
                            class="qty-btn" 
                            data-action="decrease-qty" 
                            data-item-id="<?= htmlspecialchars((string)($item['cart_id'] ?? '')) ?>"
                            aria-label="<lang>Decrease quantity</lang>">
                        <span class="material-symbols-outlined">remove</span>
                    </button>
                    <span class="qty-value"><?= (int)($item['quantity'] ?? 1) ?></span>
                    <button type="button" 
                            class="qty-btn" 
                            data-action="increase-qty" 
                            data-item-id="<?= htmlspecialchars((string)($item['cart_id'] ?? '')) ?>"
                            aria-label="<lang>Increase quantity</lang>">
                        <span class="material-symbols-outlined">add</span>
                    </button>
                </div>
            </div>
            
            <!-- 删除按钮 -->
            <button type="button" 
                    class="mini-cart-item__remove" 
                    data-action="remove-item" 
                    data-item-id="<?= htmlspecialchars((string)($item['cart_id'] ?? '')) ?>"
                    aria-label="<lang>Remove item</lang>">
                <span class="material-symbols-outlined">delete_outline</span>
            </button>
        </div>
    <?php endforeach; ?>
<?php endif; ?>
