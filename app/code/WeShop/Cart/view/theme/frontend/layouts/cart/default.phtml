        justify-content: center;
        background: transparent;
        border: var(--border-width-thin) var(--border-style-solid) transparent;
        border-radius: var(--border-radius-lg);
        cursor: pointer;
        color: var(--color-text-secondary);
        transition: all 0.2s;
    }
    
    .cart-item__action-btn:hover {
        background: var(--color-bg-secondary);
    }
    
    .cart-item__action-btn--remove:hover {
        color: var(--color-error);
        background: var(--color-error-light);
    }
    
    .cart-item__action-btn .material-symbols-outlined {
        font-size: 20px;
    }
    
    /* 继续购物 */
    .cart-continue {
        padding: var(--spacing-lg);
        border-top: var(--border-width-thin) var(--border-style-solid) var(--color-border-light);
    }
    
    .cart-continue__btn {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        color: var(--color-accent);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
    }
    
    .cart-continue__btn:hover {
        gap: calc(var(--spacing-sm) + 0.25rem);
    }
    
    /* ========== 订单摘要侧边栏 ========== */
    .cart-summary-sidebar {
        position: sticky;
        top: 100px;
    }
    
    .cart-summary-card {
        background: var(--color-bg-primary);
        border-radius: var(--border-radius-xl);
        box-shadow: var(--shadow-card);
        padding: var(--spacing-lg);
    }
    
    .cart-summary-card__title {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--color-text-dark);
        margin: 0 0 var(--spacing-lg);
        padding-bottom: var(--spacing-md);
        border-bottom: var(--border-width-thin) var(--border-style-solid) var(--color-border-light);
    }
    
    /* 优惠券 */
    .cart-coupon {
        margin-bottom: var(--spacing-lg);
    }
    
    .cart-coupon__wrapper {
        display: flex;
        gap: var(--spacing-sm);
    }
    
    .cart-coupon__input {
        flex: 1;
        padding: 0.75rem 1rem;
        border: var(--border-input);
        border-radius: var(--border-radius-lg);
        font-size: 0.875rem;
    }
    
    .cart-coupon__input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px var(--color-accent-light);
    }
    
    .cart-coupon__btn {
        padding: 0.75rem 1.25rem;
        background: var(--color-bg-secondary);
        border: var(--border-input);
        border-radius: var(--border-radius-lg);
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .cart-coupon__btn:hover {
        background: var(--color-bg-tertiary);
    }
    
    /* 配送方式 */
    .cart-shipping {
        margin-bottom: var(--spacing-lg);
    }
    
    /* 价格明细 */
    .cart-summary-card__details {
        margin-bottom: var(--spacing-lg);
    }
    
    .cart-summary-card__row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: var(--border-width-thin) var(--border-style-solid) var(--color-border-light);
    }
    
    .cart-summary-card__row:last-child {
        border-bottom: none;
    }
    
    .cart-summary-card__label {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
    }
    
    .cart-summary-card__value {
        font-weight: 500;
        color: var(--color-text-dark);
    }
    
    .cart-summary-card__row--total {
        padding-top: var(--spacing-md);
        margin-top: var(--spacing-xs);
        border-top: var(--border-width-medium) var(--border-style-solid) var(--color-text-dark);
        border-bottom: none;
    }
    
    .cart-summary-card__row--total .cart-summary-card__label {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text-dark);
    }
    
    .cart-summary-card__row--total .cart-summary-card__value {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-accent);
    }
    
    /* 结算按钮 */
    .cart-summary-card__actions {
        margin-bottom: var(--spacing-lg);
    }
    
    .cart-summary-card__checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: var(--spacing-md);
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: var(--border-radius-lg);
        transition: all 0.2s;
        background: var(--color-accent);
        color: var(--color-text-light);
        box-shadow: 0 4px 12px color-mix(in srgb, var(--color-accent) 25%, transparent);
    }
    
    .cart-summary-card__checkout-btn:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px color-mix(in srgb, var(--color-accent) 30%, transparent);
    }
    
    /* 快捷支付 */
    .cart-express-checkout {
        margin-top: var(--spacing-md);
    }
    
    /* 安全保障 */
    .cart-security {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
        padding-top: var(--spacing-md);
        border-top: var(--border-width-thin) var(--border-style-solid) var(--color-border-light);
    }
    
    .cart-security__item {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        font-size: 0.75rem;
        color: var(--color-text-secondary);
    }
    
    .cart-security__item .material-symbols-outlined {
        font-size: 18px;
        color: var(--color-success);
    }
    
    /* 侧边栏扩展区域 */
    .cart-sidebar-extra {
        margin-top: var(--spacing-lg);
    }
    
    /* ========== 空购物车状态 ========== */
    .cart-empty {
        text-align: center;
        padding: var(--spacing-3xl) var(--spacing-lg);
        background: var(--color-bg-primary);
        border-radius: var(--border-radius-xl);
        box-shadow: var(--shadow-card);
    }
    
    .cart-empty__icon {
        margin-bottom: var(--spacing-lg);
    }
    
    .cart-empty__icon .material-symbols-outlined {
        font-size: 80px;
        color: var(--color-text-tertiary);
    }
    
    .cart-empty__title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-text-dark);
        margin: 0 0 var(--spacing-xs);
    }
    
    .cart-empty__message {
        color: var(--color-text-secondary);
        margin: 0 0 var(--spacing-xl);
    }
    
    .cart-empty__btn {
        display: inline-flex;
        padding: var(--spacing-md) var(--spacing-xl);
        background: var(--color-accent);
        color: var(--color-text-light);
        text-decoration: none;
        border-radius: var(--border-radius-lg);
        font-weight: 600;
        transition: all 0.2s;
    }
    
    .cart-empty__btn:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
    }
    
    /* ========== 响应式布局 ========== */
    @media (max-width: 1024px) {
        .cart-page__grid {
            grid-template-columns: 1fr;
        }
        
        .cart-summary-sidebar {
            position: static;
            order: -1;
        }
    }
    
    @media (max-width: 768px) {
        .cart-items-section__header {
            display: none;
        }
        
        .cart-item {
            grid-template-columns: 1fr;
            gap: var(--spacing-md);
        }
        
        .cart-item__product {
            order: 1;
        }
        
        .cart-item__price {
            order: 2;
            text-align: left;
        }
        
        .cart-item__qty {
            order: 3;
            justify-content: flex-start;
        }
        
        .cart-item__total {
            order: 4;
            text-align: left;
        }
        
        .cart-item__actions {
            order: 5;
            justify-content: flex-start;
        }
        
        .cart-page__container {
            padding: 0 var(--spacing-md);
        }
    }
    </style>
</body>
