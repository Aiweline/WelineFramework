.mini-cart-drawer__close { width: 38px; height: 38px; border-radius: 999px; background: var(--color-bg-secondary, #f3f4f6); color: var(--color-text-dark, #111827); }
.mini-cart-drawer__body { flex: 1; overflow: auto; }
.mini-cart-drawer__progress:empty { display: none; }
.mini-cart-item { position: relative; display: flex; gap: 14px; padding: 16px 20px; border-bottom: 1px solid var(--color-border-light, #e5e7eb); }
.mini-cart-item__image { width: 72px; height: 72px; flex: 0 0 72px; overflow: hidden; border-radius: 14px; background: var(--color-bg-secondary, #f3f4f6); }
