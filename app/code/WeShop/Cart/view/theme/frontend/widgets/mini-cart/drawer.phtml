.mini-cart-drawer__actions a { display: flex; justify-content: center; align-items: center; min-height: 44px; border-radius: 12px; font-weight: 800; text-decoration: none; }
.mini-cart-drawer__view-cart { border: 1px solid var(--color-border-default, #d1d5db); color: var(--color-text-dark, #111827); }
