<?php
/**
 * Mini cart drawer widget.
 *
 * @param position {default="right",options=["left","right"],name="Drawer position"}
 * @param width {default="400px",name="Drawer width"}
 * @param showEmptyState {default=true,name="Show empty state"}
 * @param autoOpen {default=true,name="Auto open after add"}
 */

use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;
use WeShop\Cart\Service\CartService;

$renderIcon = static function (string $name): string {
    return match ($name) {
        'close' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6.4 6.4a1 1 0 0 1 1.4 0L12 10.6l4.2-4.2a1 1 0 1 1 1.4 1.4L13.4 12l4.2 4.2a1 1 0 0 1-1.4 1.4L12 13.4l-4.2 4.2a1 1 0 0 1-1.4-1.4l4.2-4.2-4.2-4.2a1 1 0 0 1 0-1.4Z" fill="currentColor"/></svg>',
        'minus' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6 11a1 1 0 0 0 0 2h12a1 1 0 1 0 0-2H6Z" fill="currentColor"/></svg>',
        'plus' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M11 6a1 1 0 1 1 2 0v5h5a1 1 0 1 1 0 2h-5v5a1 1 0 1 1-2 0v-5H6a1 1 0 0 1 0-2h5V6Z" fill="currentColor"/></svg>',
        'trash' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 3a1 1 0 0 0-.8.4L7.4 4H5a1 1 0 1 0 0 2h.5l1 11.1A2 2 0 0 0 8.5 19h7a2 2 0 0 0 2-1.9l1-11.1H19a1 1 0 1 0 0-2h-2.4l-.8-.6A1 1 0 0 0 15 3H9Zm-.5 3h7l-.9 10.9H9.4L8.5 6Zm1.5 2a1 1 0 0 1 1 1v5a1 1 0 1 1-2 0V9a1 1 0 0 1 1-1Zm4 0a1 1 0 0 1 1 1v5a1 1 0 1 1-2 0V9a1 1 0 0 1 1-1Z" fill="currentColor"/></svg>',
        'image' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6 5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3V8a3 3 0 0 0-3-3H6Zm0 2h12a1 1 0 0 1 1 1v5.4l-2.8-2.8a1 1 0 0 0-1.4 0L10 15.4l-1.8-1.8a1 1 0 0 0-1.4 0L5 15.4V8a1 1 0 0 1 1-1Zm0 10 1.5-1.5 1.8 1.8a1 1 0 0 0 1.4 0l4.8-4.8 3.5 3.5a1 1 0 0 1-1 1H6Zm9-7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" fill="currentColor"/></svg>',
        'cart' => '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M3 4a1 1 0 0 1 1-1h1.3a2 2 0 0 1 2 1.6L7.5 6H20a1 1 0 0 1 1 .8 1 1 0 0 1-.1.7l-2.4 5.8A2 2 0 0 1 16.6 15H9a2 2 0 0 1-2-1.6L5.1 5H4a1 1 0 0 1-1-1Zm5 4 .9 4.2H16.6L18.2 8H8ZM9 20a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm8 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" fill="currentColor"/></svg>',
        default => '',
    };
};

$position = $this->getData('position') ?? 'right';
$width = $this->getData('width') ?? '400px';
$showEmptyState = $this->getData('showEmptyState') ?? true;
$autoOpen = $this->getData('autoOpen') ?? true;

$cartCount = 0;
$cartTotal = 0.0;
$cartItems = [];

try {
    $session = SessionFactory::getInstance()->createFrontendSession();
    $customer = $session->getCustomer();
    if ($customer && (int)$customer->getId() > 0) {
        /** @var CartService $cartService */
        $cartService = ObjectManager::getInstance(CartService::class);
        $cartItems = $cartService->getCartItems((int)$customer->getId());
        $totals = $cartService->calculateTotals((int)$customer->getId());
        foreach ($cartItems as $item) {
            $cartCount += max(1, (int)($item['quantity'] ?? $item['qty'] ?? 1));
        }
        $cartTotal = (float)($totals['subtotal'] ?? 0);
    }
} catch (\Throwable) {
    $cartItems = [];
    $cartCount = 0;
    $cartTotal = 0.0;
}
?>

<div class="mini-cart-overlay"
     id="mini-cart-overlay"
     style="display:none;"
     aria-hidden="true"
     data-action="close-mini-cart"></div>

<aside class="mini-cart-drawer mini-cart-drawer--<?= htmlspecialchars((string)$position) ?>"
       id="mini-cart-drawer"
       role="dialog"
       aria-modal="true"
       aria-labelledby="mini-cart-title"
       style="--mini-cart-width: <?= htmlspecialchars((string)$width) ?>;"
       data-auto-open="<?= $autoOpen ? 'true' : 'false' ?>">
    <header class="mini-cart-drawer__header">
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::header-before</w:hook>
        <div class="mini-cart-header-content" data-wslot="mini-cart-header" data-wslot-name="mini-cart-header" data-wslot-multiple="false">
            <h3 id="mini-cart-title" class="mini-cart-drawer__title">
                <?= __('购物车') ?>
                <span class="mini-cart-drawer__count" data-cart-count-badge>
                    (<span data-cart-count><?= $cartCount ?></span>)
                </span>
            </h3>
            <button type="button" class="mini-cart-drawer__close" data-action="close-mini-cart" aria-label="<?= __('Close cart') ?>">
                <span class="mini-cart-icon" aria-hidden="true"><?= $renderIcon('close') ?></span>
            </button>
        </div>
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::header-after</w:hook>
    </header>

    <div class="mini-cart-drawer__body">
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::items-before</w:hook>
        <div class="mini-cart-drawer__progress" data-wslot="mini-cart-progress" data-wslot-name="mini-cart-progress" data-wslot-multiple="false">
            <w:hook>WeShop_Cart::frontend::partials::mini-cart::shipping-progress</w:hook>
        </div>

        <div id="mini-cart-items" class="mini-cart-drawer__items" data-wslot="mini-cart-items" data-wslot-name="mini-cart-items" data-loading="false">
            <?php if ($cartCount > 0): ?>
                <?php foreach ($cartItems as $item): ?>
                    <?php
                    $itemId = (int)($item['cart_id'] ?? $item['id'] ?? 0);
                    $productId = (int)($item['product_id'] ?? 0);
                    $product = is_array($item['product'] ?? null) ? $item['product'] : [];
                    $productName = (string)($product['name'] ?? __('Product') . ' #' . $productId);
                    $productImage = (string)($product['image'] ?? '');
                    $price = (float)($item['price'] ?? 0);
                    $quantity = max(1, (int)($item['quantity'] ?? $item['qty'] ?? 1));
                    ?>
                    <div class="mini-cart-item" data-item-id="<?= $itemId ?>" data-product-id="<?= $productId ?>">
                        <div class="mini-cart-item__image">
                            <?php if ($productImage !== ''): ?>
                                <img src="<?= htmlspecialchars($productImage) ?>" alt="<?= htmlspecialchars($productName) ?>" loading="lazy"/>
                            <?php else: ?>
                                <div class="mini-cart-item__placeholder"><span class="mini-cart-icon" aria-hidden="true"><?= $renderIcon('image') ?></span></div>
                            <?php endif; ?>
                        </div>
                        <div class="mini-cart-item__details">
                            <a href="#" class="mini-cart-item__name"><?= htmlspecialchars($productName) ?></a>
                            <div class="mini-cart-item__price"><?= $this->formatPrice($price) ?></div>
                            <div class="mini-cart-item__qty">
                                <button type="button" class="mini-cart-item__qty-btn" data-action="decrease-qty" data-item-id="<?= $itemId ?>" aria-label="<?= __('Decrease quantity') ?>">
                                    <span class="mini-cart-icon" aria-hidden="true"><?= $renderIcon('minus') ?></span>
                                </button>
                                <span class="mini-cart-item__qty-value"><?= $quantity ?></span>
                                <button type="button" class="mini-cart-item__qty-btn" data-action="increase-qty" data-item-id="<?= $itemId ?>" aria-label="<?= __('Increase quantity') ?>">
                                    <span class="mini-cart-icon" aria-hidden="true"><?= $renderIcon('plus') ?></span>
                                </button>
                            </div>
                        </div>
                        <button type="button" class="mini-cart-item__remove" data-action="remove-item" data-item-id="<?= $itemId ?>" aria-label="<?= __('Remove item') ?>">
                            <span class="mini-cart-icon" aria-hidden="true"><?= $renderIcon('trash') ?></span>
                        </button>
                    </div>
                <?php endforeach; ?>
            <?php elseif ($showEmptyState): ?>
                <div class="mini-cart-items__empty" id="mini-cart-empty">
                    <w:hook>WeShop_Cart::frontend::partials::mini-cart::empty</w:hook>
                    <div class="mini-cart-empty">
                        <span class="mini-cart-empty__icon mini-cart-icon" aria-hidden="true"><?= $renderIcon('cart') ?></span>
                        <p class="mini-cart-empty__message"><?= __('购物车是空的') ?></p>
                        <a href="<?= $this->getUrl('/') ?>" class="mini-cart-empty__link" data-action="close-mini-cart"><?= __('开始购物') ?></a>
                    </div>
                </div>
            <?php endif; ?>
            <div class="mini-cart-drawer__loading" id="mini-cart-loading" style="display:none;">
                <div class="mini-cart-drawer__spinner"></div>
            </div>
        </div>
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::items-after</w:hook>
    </div>

    <footer class="mini-cart-drawer__footer" data-cart-footer <?= $cartCount === 0 ? 'style="display:none;"' : '' ?>>
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::footer-before</w:hook>
        <div class="mini-cart-drawer__footer-content" data-wslot="mini-cart-footer" data-wslot-name="mini-cart-footer" data-wslot-multiple="true" data-wslot-accept="summary,actions,coupon">
            <div class="mini-cart-drawer__summary">
                <div class="mini-cart-drawer__summary-row">
                    <span class="mini-cart-drawer__summary-label"><?= __('小计') ?></span>
                    <span class="mini-cart-drawer__summary-value" data-mini-cart-subtotal><?= $this->formatPrice($cartTotal) ?></span>
                </div>
                <p class="mini-cart-drawer__summary-note"><?= __('运费和税费将在结算时计算') ?></p>
            </div>
            <div class="mini-cart-drawer__actions">
                <a href="<?= $this->getUrl('cart') ?>" class="mini-cart-drawer__view-cart"><?= __('查看购物车') ?></a>
                <a href="<?= $this->getUrl('checkout') ?>" class="mini-cart-drawer__checkout weline-pixel::begin_checkout">
                    <span class="weline-pixel::begin_checkout:value" data-pixel-value="<?= htmlspecialchars((string)(float)$cartTotal, ENT_QUOTES, 'UTF-8') ?>" hidden><?= htmlspecialchars((string)(float)$cartTotal, ENT_QUOTES, 'UTF-8') ?></span>
                    <?= __('去结算') ?>
                </a>
            </div>
            <div class="mini-cart-drawer__express" data-wslot="mini-cart-express" data-wslot-name="mini-cart-express" data-wslot-multiple="true" data-wslot-accept="express-checkout,payment">
                <w:hook>WeShop_Cart::frontend::partials::mini-cart::express-checkout</w:hook>
            </div>
        </div>
        <w:hook>WeShop_Cart::frontend::partials::mini-cart::footer-after</w:hook>
    </footer>
</aside>

<script>
window.__WelineMiniCartConfig = <?= json_encode([
    'position' => $position,
    'width' => $width,
    'autoOpen' => $autoOpen,
    'cart' => [
        'count' => $cartCount,
        'subtotal' => $cartTotal,
        'subtotal_formatted' => $this->formatPrice($cartTotal),
    ],
], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
</script>

<style>
.mini-cart-overlay { position: fixed; inset: 0; z-index: 9998; background: rgba(15, 23, 42, 0.46); opacity: 0; visibility: hidden; transition: opacity .2s ease, visibility .2s ease; }
.mini-cart-overlay.is-visible { opacity: 1; visibility: visible; }
.mini-cart-drawer { position: fixed; top: 0; right: 0; z-index: 9999; width: var(--mini-cart-width, 400px); max-width: 92vw; height: 100dvh; display: flex; flex-direction: column; background: var(--color-bg-primary, #fff); box-shadow: -24px 0 60px rgba(15, 23, 42, .18); transform: translateX(100%); transition: transform .24s ease; }
.mini-cart-drawer--left { left: 0; right: auto; transform: translateX(-100%); }
.mini-cart-drawer.is-open { transform: translateX(0); }
#customer-service-widget .cs-status-dot { bottom: 7px !important; right: 7px !important; width: 10px !important; height: 10px !important; box-sizing: border-box !important; pointer-events: none !important; }
