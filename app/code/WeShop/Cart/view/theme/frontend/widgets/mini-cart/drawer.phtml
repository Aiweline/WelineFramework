.mini-cart-drawer__header, .mini-cart-drawer__footer { flex-shrink: 0; border-color: var(--color-border-light, #e5e7eb); }
.mini-cart-drawer__header { border-bottom: 1px solid var(--color-border-light, #e5e7eb); }
