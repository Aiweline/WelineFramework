<?php
/**
 * MiniCart Drawer Widget - Shopify 风格侧边抽屉购物车
 * 
 * @param position {default="right",options=["left","right"],name="弹出位置",description="迷你购物车从哪侧弹出"}
 * @param width {default="400px",name="宽度",description="迷你购物车宽度"}
 * @param showEmptyState {default=true,name="显示空状态",description="购物车为空时是否显示空状态提示"}
 * @param autoOpen {default=true,name="添加商品后自动打开",description="添加商品到购物车后是否自动打开"}
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Cart\Service\CartService;
use Weline\Framework\Session\SessionFactory;

// 获取参数
$position = $this->getData('position') ?? 'right';
$width = $this->getData('width') ?? '400px';
$showEmptyState = $this->getData('showEmptyState') ?? true;
$autoOpen = $this->getData('autoOpen') ?? true;

// 获取购物车数据
$cartCount = 0;
$cartTotal = 0;
$cartItems = [];

try {
    $session = SessionFactory::getInstance()->createFrontendSession();
    $customer = $session->getCustomer();
    
    if ($customer) {
        $cartService = ObjectManager::getInstance(CartService::class);
        $items = $cartService->getCartItems($customer->getId());
        $totals = $cartService->calculateTotals($customer->getId());
        
        foreach ($items as $item) {
            $cartCount += (int)($item['quantity'] ?? 1);
            $cartItems[] = $item;
        }
        $cartTotal = $totals['subtotal'] ?? 0;
    }
} catch (\Exception $e) {
    // 忽略错误，使用默认值
}
?>

<!-- MiniCart Overlay -->
<div class="mini-cart-overlay" 
     id="mini-cart-overlay" 
     style="display:none;"
     aria-hidden="true"
     data-action="close-mini-cart"></div>

<!-- MiniCart Drawer -->
<div class="mini-cart-drawer mini-cart-drawer--<?= htmlspecialchars($position) ?>" 
     id="mini-cart-drawer"
     role="dialog"
     aria-modal="true"
     aria-labelledby="mini-cart-title"
     style="--mini-cart-width: <?= htmlspecialchars($width) ?>;"
     data-auto-open="<?= $autoOpen ? 'true' : 'false' ?>">
    
    <!-- ========== Header ========== -->
    <div class="mini-cart-drawer__header">
        <w:hook>WeShop_Cart::frontend::mini-cart::header-before</w:hook>
        
        <div class="mini-cart-header-content"
             data-wslot="mini-cart-header"
             data-wslot-name="迷你购物车头部"
             data-wslot-multiple="false">
            <h3 id="mini-cart-title" class="mini-cart-drawer__title">
                <?= __('Shopping Cart') ?>
                <span class="mini-cart-drawer__count" data-cart-count-badge>
                    (<span data-cart-count><?= $cartCount ?></span>)
                </span>
            </h3>
            <button type="button" 
                    class="mini-cart-drawer__close" 
                    data-action="close-mini-cart"
                    aria-label="<?= __('Close cart') ?>">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <w:hook>WeShop_Cart::frontend::mini-cart::header-after</w:hook>
    </div>
    
    <!-- ========== Body (Cart Items) ========== -->
    <div class="mini-cart-drawer__body">
        <w:hook>WeShop_Cart::frontend::mini-cart::items-before</w:hook>
        
        <!-- 免运费进度条（示例 Hook 实现位置） -->
        <div class="mini-cart-drawer__progress"
             data-wslot="mini-cart-progress"
             data-wslot-name="免运费进度"
             data-wslot-multiple="false">
            <w:hook>WeShop_Cart::frontend::mini-cart::shipping-progress</w:hook>
        </div>
        
        <!-- 商品列表容器 -->
        <div id="mini-cart-items" 
             class="mini-cart-drawer__items"
             data-wslot="mini-cart-items"
             data-wslot-name="迷你购物车商品列表"
             data-loading="false">
            
            <if condition="cartCount > 0">
                <!-- 商品列表（服务端渲染，JS 会动态更新） -->
                <foreach data="<?= json_encode($cartItems) ?>" item="item">
                    <div class="mini-cart-item" data-item-id="{{item.cart_id}}" data-product-id="{{item.product_id}}">
                        <div class="mini-cart-item__image">
                            <if condition="isset(item.product) && isset(item.product.image)">
                                <img src="{{item.product.image}}" alt="{{item.product.name}}" loading="lazy"/>
                            <else/>
                                <div class="mini-cart-item__placeholder">
                                    <span class="material-symbols-outlined">image</span>
                                </div>
                            </if>
                        </div>
                        <div class="mini-cart-item__details">
                            <a href="#" class="mini-cart-item__name">
                                <if condition="isset(item.product) && isset(item.product.name)">
                                    {{item.product.name}}
                                <else/>
                                    <?= __('Product') ?> #{{item.product_id}}
                                </if>
                            </a>
                            <div class="mini-cart-item__price">
                                <?= $this->formatPrice($item['price'] ?? 0) ?>
                            </div>
                            <div class="mini-cart-item__qty">
                                <button type="button" class="mini-cart-item__qty-btn" data-action="decrease-qty" data-item-id="{{item.cart_id}}">
                                    <span class="material-symbols-outlined">remove</span>
                                </button>
                                <span class="mini-cart-item__qty-value">{{item.quantity}}</span>
                                <button type="button" class="mini-cart-item__qty-btn" data-action="increase-qty" data-item-id="{{item.cart_id}}">
                                    <span class="material-symbols-outlined">add</span>
                                </button>
                            </div>
                        </div>
                        <button type="button" 
                                class="mini-cart-item__remove" 
                                data-action="remove-item" 
                                data-item-id="{{item.cart_id}}"
                                aria-label="<?= __('Remove item') ?>">
                            <span class="material-symbols-outlined">delete_outline</span>
                        </button>
                    </div>
                </foreach>
            <else/>
                <if condition="showEmptyState">
                    <div class="mini-cart-items__empty" id="mini-cart-empty">
                        <w:hook>WeShop_Cart::frontend::mini-cart::empty<else/>
                            <div class="mini-cart-empty">
                                <span class="mini-cart-empty__icon material-symbols-outlined">shopping_cart</span>
                                <p class="mini-cart-empty__message"><?= __('Your cart is empty') ?></p>
                                <a href="<?= $this->getUrl('/') ?>" class="mini-cart-empty__link" data-action="close-mini-cart">
                                    <?= __('Start Shopping') ?>
                                </a>
                            </div>
                        </w:hook>
                    </div>
                </if>
            </if>
            
            <!-- Loading 状态 -->
            <div class="mini-cart-drawer__loading" id="mini-cart-loading" style="display:none;">
                <div class="mini-cart-drawer__spinner"></div>
            </div>
        </div>
        
        <w:hook>WeShop_Cart::frontend::mini-cart::items-after</w:hook>
    </div>
    
    <!-- ========== Footer (Summary & Actions) ========== -->
    <div class="mini-cart-drawer__footer" data-cart-footer <?= $cartCount === 0 ? 'style="display:none;"' : '' ?>>
        <w:hook>WeShop_Cart::frontend::mini-cart::footer-before</w:hook>
        
        <div class="mini-cart-drawer__footer-content"
             data-wslot="mini-cart-footer"
             data-wslot-name="迷你购物车底部"
             data-wslot-multiple="true"
             data-wslot-accept="summary,actions,coupon">
            
            <!-- 小计 -->
            <div class="mini-cart-drawer__summary">
                <div class="mini-cart-drawer__summary-row">
                    <span class="mini-cart-drawer__summary-label"><?= __('Subtotal') ?></span>
                    <span class="mini-cart-drawer__summary-value" data-mini-cart-subtotal><?= $this->formatPrice($cartTotal) ?></span>
                </div>
                <p class="mini-cart-drawer__summary-note"><?= __('Shipping and taxes calculated at checkout') ?></p>
            </div>
            
            <!-- 操作按钮 -->
            <div class="mini-cart-drawer__actions">
                <a href="<?= $this->getUrl('cart') ?>" class="mini-cart-drawer__view-cart">
                    <?= __('View Cart') ?>
                </a>
                <a href="<?= $this->getUrl('checkout') ?>" class="mini-cart-drawer__checkout">
                    <?= __('Checkout') ?>
                </a>
            </div>
            
            <!-- 快捷支付扩展位置 -->
            <div class="mini-cart-drawer__express"
                 data-wslot="mini-cart-express"
                 data-wslot-name="快捷支付"
                 data-wslot-multiple="true"
                 data-wslot-accept="express-checkout,payment">
                <w:hook>WeShop_Cart::frontend::mini-cart::express-checkout</w:hook>
            </div>
        </div>
        
        <w:hook>WeShop_Cart::frontend::mini-cart::footer-after</w:hook>
    </div>
</div>

<!-- MiniCart 配置 -->
<script>
window.__WelineMiniCartConfig = <?= json_encode([
    'position' => $position,
    'width' => $width,
    'autoOpen' => $autoOpen,
    'api' => [
        'items' => '/api123/api/rest/v1/weshop/cart/mini-items',
        'update' => '/api123/api/rest/v1/weshop/cart',
        'remove' => '/api123/api/rest/v1/weshop/cart/remove',
    ],
    'cart' => [
        'count' => $cartCount,
        'subtotal' => $cartTotal,
        'subtotal_formatted' => $this->formatPrice($cartTotal),
    ],
], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
</script>

<style>
