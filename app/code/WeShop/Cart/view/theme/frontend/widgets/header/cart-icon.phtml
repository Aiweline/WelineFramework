<?php
/**
 * Header 购物车图标 Widget
 * 
 * @param showCount {default=true,name="显示数量",description="是否显示购物车商品数量徽章"}
 * @param showLabel {default=true,name="显示文字",description="是否显示购物车文字标签"}
 * @param triggerAction {default="drawer",options=["drawer","link"],name="点击行为",description="点击购物车图标的行为"}
 */

use Weline\Framework\Manager\ObjectManager;
use WeShop\Cart\Service\CartService;
use Weline\Framework\Session\SessionFactory;

// 获取参数
$showCount = $this->getData('showCount') ?? true;
$showLabel = $this->getData('showLabel') ?? true;
$triggerAction = $this->getData('triggerAction') ?? 'drawer';

// 获取购物车数量
$cartCount = 0;

try {
    $session = SessionFactory::getInstance()->createFrontendSession();
    $customer = $session->getCustomer();
    
    if ($customer) {
        $cartService = ObjectManager::getInstance(CartService::class);
        $cartCount = $cartService->getCartItemCount($customer->getId());
    }
} catch (\Exception $e) {
    // 忽略错误
}

$isDrawer = $triggerAction === 'drawer';
?>

<?php if ($isDrawer): ?>
<button type="button" 
        class="header-cart-icon" 
        data-action="open-mini-cart"
        aria-label="<?= __('Open Cart') ?>"
        aria-haspopup="dialog">
<?php else: ?>
<a href="<?= $this->getUrl('cart') ?>" 
   class="header-cart-icon"
   aria-label="<?= __('View Cart') ?>">
<?php endif; ?>

    <span class="header-cart-icon__wrapper">
        <span class="material-symbols-outlined header-cart-icon__symbol">shopping_cart</span>
        <?php if ($showCount): ?>
            <span class="header-cart-icon__badge <?= $cartCount > 0 ? 'header-cart-icon__badge--has-items' : '' ?>" 
                  data-cart-count
                  <?= $cartCount === 0 ? 'style="display:none;"' : '' ?>>
                <?= $cartCount > 99 ? '99+' : $cartCount ?>
            </span>
        <?php endif; ?>
    </span>
    
    <?php if ($showLabel): ?>
        <span class="header-cart-icon__label"><?= __('Cart') ?></span>
    <?php endif; ?>

<?php if ($isDrawer): ?>
</button>
<?php else: ?>
</a>
<?php endif; ?>

