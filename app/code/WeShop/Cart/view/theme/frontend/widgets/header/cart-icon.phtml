    100% { transform: scale(1); }
}

.cart-label {
    font-size: 0.875rem;
    font-weight: 500;
}

/* 响应式 - 移动端隐藏文字 */
@media (max-width: 768px) {
    .cart-label {
        display: none;
    }
    
    .header-cart-icon {
        padding: 0.5rem;
    }
}
</style>
