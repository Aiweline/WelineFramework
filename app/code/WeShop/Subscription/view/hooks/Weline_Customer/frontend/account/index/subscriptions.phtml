<?php
/**
 * Account subscriptions section embedded in Weline_Customer account/index.
 *
 * Hook: Weline_Customer::frontend::account::index::subscriptions
 *
 * @hook-priority 160
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$user = $this->getData('user');
if (!$user) {
    return;
}

try {
    /** @var \WeShop\Subscription\Service\SubscriptionListPageDataService $subscriptionListPageDataService */
    $subscriptionListPageDataService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Subscription\Service\SubscriptionListPageDataService::class);
    $data = $subscriptionListPageDataService->build((int) $user->getId(), 1, 10, '');
    $data['title'] = __('My Subscriptions');
    echo $this->fetch('WeShop_Subscription::templates/Frontend/Subscription/SubscriptionList/index.phtml', $data);
} catch (\Throwable $exception) {
    ?>
    <div class="account-card weshop-account-subscriptions">
        <header class="account-card__header">
            <h2 class="account-card__title"><?= __('My Subscriptions') ?></h2>
        </header>
        <div class="account-card__body">
            <div class="weshop-subscription-empty">
                <div class="weshop-subscription-empty__mark">S</div>
                <h2><?= __('Subscription info is currently unavailable') ?></h2>
                <p><?= __('The subscription service is temporarily unavailable, please try again later.') ?></p>
            </div>
        </div>
    </div>
    <?php
}
