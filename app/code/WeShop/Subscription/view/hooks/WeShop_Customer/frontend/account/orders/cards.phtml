<?php
/**
 * Subscription storefront account-center order card.
 *
 * @hook-priority 235
 * @hook-sort-order 24
 * @hook-solo false
 */

use WeShop\Subscription\Service\SubscriptionService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$customer = $session->getCustomer();
if (!$customer || !$customer->getId()) {
    return;
}

/** @var SubscriptionService $subscriptionService */
$subscriptionService = ObjectManager::getInstance(SubscriptionService::class);
$summary = $subscriptionService->getCustomerSubscriptions((int) $customer->getId(), 1, 1);
$total = (int) ($summary['total'] ?? 0);
?>
<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Recurring Orders') ?></p>
            <h2 class="mt-2 text-2xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Subscriptions') ?></h2>
        </div>
        <a href="<?= $this->getUrl('subscription') ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open Subscriptions') ?></a>
    </div>

    <div class="mt-6 rounded-3xl border border-border-light bg-background-light p-5 dark:border-border-dark dark:bg-background-dark">
        <p class="text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark"><?= __('Active and historical plans') ?></p>
        <p class="mt-2 text-3xl font-black text-text-primary-light dark:text-text-primary-dark"><?= $total ?></p>
        <p class="mt-2 text-sm leading-6 text-text-secondary-light dark:text-text-secondary-dark">
            <?= __('Review billing cycles, pause or resume plans, and manage renewals from one place.') ?>
        </p>
    </div>
</article>
