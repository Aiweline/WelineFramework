<script>
(function() {
    'use strict';
    
    var WeShopSubscriptionPlan = {
        deleteUrl: '<?= $this->getUrl('*/plan/index/delete') ?>',
        
        deletePlan: function(id) {
            var self = this;
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                text: '<?= __('确认删除此订阅计划？') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '<?= __('确认') ?>',
                cancelButtonText: '<?= __('取消') ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(self.deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'id=' + id
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.code === 200) {
                            location.reload();
                        } else {
                            Swal.fire({
                                title: '<?= __('错误') ?>',
                                text: data.msg,
                                icon: 'error'
                            });
                        }
                    });
                }
            });
        },
        
        init: function() {
            var self = this;
            document.querySelectorAll('.weshop-subscription-delete-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var planId = this.getAttribute('data-plan-id');
                    self.deletePlan(planId);
                });
            });
        }
    };
    
    window.WeShopSubscriptionPlan = WeShopSubscriptionPlan;
    
    document.addEventListener('DOMContentLoaded', function() {
        WeShopSubscriptionPlan.init();
    });
})();
</script>
