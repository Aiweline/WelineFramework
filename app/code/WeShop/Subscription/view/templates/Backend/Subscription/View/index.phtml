<!-- 取消弹窗 -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><?= __('确认取消') ?></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><?= __('确认取消此订阅？取消后将无法继续享受订阅服务。') ?></p>
                <div class="mb-3">
                    <label class="form-label"><?= __('取消原因') ?></label>
                    <textarea class="form-control" id="cancel-reason" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('返回') ?></button>
                <button type="button" class="btn btn-danger" id="confirm-cancel-btn"><?= __('确认取消') ?></button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var WeShopSubscriptionView = {
        cancelUrl: '<?= $this->getUrl('*/subscription/view/cancel') ?>',
        pauseUrl: '<?= $this->getUrl('*/subscription/view/pause') ?>',
        resumeUrl: '<?= $this->getUrl('*/subscription/view/resume') ?>',
        cancelSubscriptionId: 0,
        
        showCancelModal: function(id) {
            this.cancelSubscriptionId = id;
            new bootstrap.Modal(document.getElementById('cancelModal')).show();
        },
        
        confirmCancel: function() {
            var self = this;
            var reason = document.getElementById('cancel-reason').value;
            fetch(self.cancelUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: 'id=' + self.cancelSubscriptionId + '&reason=' + encodeURIComponent(reason)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    location.reload();
                } else {
                    Swal.fire({
                        title: '<?= __('错误') ?>',
                        text: data.msg,
                        icon: 'error'
                    });
                }
            });
        },
        
        pauseSubscription: function(id) {
            var self = this;
            Swal.fire({
                title: '<?= __('确认暂停') ?>',
                text: '<?= __('确认暂停此订阅？') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?= __('确认') ?>',
                cancelButtonText: '<?= __('取消') ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(self.pauseUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'id=' + id
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.code === 200) {
                            location.reload();
                        } else {
                            Swal.fire({
                                title: '<?= __('错误') ?>',
                                text: data.msg,
                                icon: 'error'
                            });
                        }
                    });
                }
            });
        },
        
        resumeSubscription: function(id) {
            var self = this;
            Swal.fire({
                title: '<?= __('确认恢复') ?>',
                text: '<?= __('确认恢复此订阅？') ?>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<?= __('确认') ?>',
                cancelButtonText: '<?= __('取消') ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(self.resumeUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'id=' + id
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.code === 200) {
                            location.reload();
                        } else {
                            Swal.fire({
                                title: '<?= __('错误') ?>',
                                text: data.msg,
                                icon: 'error'
                            });
                        }
                    });
                }
            });
        },
        
        init: function() {
            var self = this;
            
            document.querySelectorAll('.weshop-subscription-cancel-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    self.showCancelModal(this.getAttribute('data-id'));
                });
            });
            
            document.querySelectorAll('.weshop-subscription-pause-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    self.pauseSubscription(this.getAttribute('data-id'));
                });
            });
            
            document.querySelectorAll('.weshop-subscription-resume-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    self.resumeSubscription(this.getAttribute('data-id'));
                });
            });
            
            var confirmCancelBtn = document.getElementById('confirm-cancel-btn');
            if (confirmCancelBtn) {
                confirmCancelBtn.addEventListener('click', function() {
                    self.confirmCancel();
                });
            }
        }
    };
    
    window.WeShopSubscriptionView = WeShopSubscriptionView;
    
    document.addEventListener('DOMContentLoaded', function() {
        WeShopSubscriptionView.init();
    });
})();
</script>
