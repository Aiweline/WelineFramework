<?php
/**
 * @var \Weline\Framework\View\Template $this
 * @var \WeShop\Subscription\Model\Subscription $subscription
 * @var \WeShop\Subscription\Model\SubscriptionPlan $plan
 * @var array $history
 */
$title = $title ?? __('订阅服务详情');

$statusOptions = \WeShop\Subscription\Model\Subscription::getStatusOptions();
$actionOptions = \WeShop\Subscription\Model\SubscriptionHistory::getActionOptions();
$billingCycles = \WeShop\Subscription\Model\SubscriptionPlan::getBillingCycleOptions();

$status = $subscription->getData('status');
$statusLabel = $statusOptions[$status] ?? $status;

$formatPrice = static function (float $amount): string {
    return \Weline\Currency\Helper\CurrencyFormatter::formatConverted($amount);
};

$statusColorMap = [
    'trialing'  => '#3b82f6',
    'active'    => '#22c55e',
    'paused'    => '#f59e0b',
    'past_due'  => '#ef4444',
    'cancelled' => '#6b7280',
    'expired'   => '#374151',
];
$statusColor = $statusColorMap[$status] ?? '#6b7280';
?>

<div class="weshop-subscription-detail" data-subscription-page>
    <div class="weshop-sub-detail-header">
        <a href="<?= $this->getUrl('*/subscription/subscriptionList') ?>" class="weshop-back-link">
            <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_back</span>
            <?= __('返回') ?>
        </a>
        <h2><?= $title ?> #<?= $subscription->getId() ?></h2>
    </div>
    <div class="weshop-subscription-message" data-subscription-message hidden></div>

    <!-- 订阅状态卡片 -->
    <div class="weshop-sub-status-card" style="border-color: <?= $statusColor ?>30;">
        <div class="weshop-sub-status-left">
            <span class="weshop-sub-status-badge" style="background-color: <?= $statusColor ?>20; color: <?= $statusColor ?>;">
                <?= $statusLabel ?>
            </span>
            <div class="weshop-sub-pricing">
                <span class="weshop-sub-amount"><?= $formatPrice((float)$subscription->getData('price')) ?></span>
                <span class="weshop-sub-cycle">
                    / <?php
                    $interval = (int)$subscription->getData('billing_interval');
                    $cycleLabel = $billingCycles[$subscription->getData('billing_cycle')] ?? $subscription->getData('billing_cycle');
                    echo ($interval > 1 ? $interval . ' ' : '') . $cycleLabel;
                    ?>
                </span>
            </div>
        </div>
        <div class="weshop-sub-status-actions">
            <?php if ($subscription->canPause()): ?>
                <button class="weshop-sub-btn weshop-sub-btn-warning" data-subscription-action="pause" data-id="<?= $subscription->getId() ?>">
                    <?= __('暂停') ?>
                </button>
            <?php endif; ?>
            <?php if ($subscription->canResume()): ?>
                <button class="weshop-sub-btn weshop-sub-btn-success" data-subscription-action="resume" data-id="<?= $subscription->getId() ?>">
                    <?= __('恢复') ?>
                </button>
            <?php endif; ?>
            <?php if ($subscription->canCancel()): ?>
                <button class="weshop-sub-btn weshop-sub-btn-danger" data-subscription-cancel-toggle data-id="<?= $subscription->getId() ?>">
                    <?= __('取消订阅') ?>
                </button>
            <?php endif; ?>
        </div>
    </div>

    <?php if ($subscription->canCancel()): ?>
        <form class="weshop-subscription-cancel" data-subscription-cancel-form data-id="<?= $subscription->getId() ?>" hidden>
            <label><?= __('取消原因') ?></label>
            <textarea name="reason" rows="2" placeholder="<?= __('可选，说明取消原因') ?>"></textarea>
            <div>
                <button type="button" data-subscription-cancel-close><?= __('收起') ?></button>
                <button type="submit" class="is-danger"><?= __('确认取消') ?></button>
            </div>
        </form>
    <?php endif; ?>

    <!-- 详细信息 -->
    <div class="weshop-sub-info-grid">
        <div class="weshop-sub-info-card">
            <h3><?= __('当前周期') ?></h3>
            <div class="weshop-sub-info-item">
                <span class="label"><?= __('当前周期') ?></span>
                <span><?= $subscription->getData('current_period_start') ?? '-' ?> ~ <?= $subscription->getData('current_period_end') ?? '-' ?></span>
            </div>
            <div class="weshop-sub-info-item">
                <span class="label"><?= __('下次计费') ?></span>
                <span><?= $subscription->getData('next_billing_at') ?? '-' ?></span>
            </div>
            <div class="weshop-sub-info-item">
                <span class="label"><?= __('续费次数') ?></span>
                <span><?= $subscription->getData('renewal_count') ?? 0 ?></span>
            </div>
            <?php if ($subscription->getData('trial_ends_at')): ?>
                <div class="weshop-sub-info-item">
                    <span class="label"><?= __('试用结束时间') ?></span>
                    <span><?= $subscription->getData('trial_ends_at') ?></span>
                </div>
            <?php endif; ?>
        </div>

        <?php if ($plan && $plan->getId()): ?>
            <div class="weshop-sub-info-card">
                <h3><?= __('订阅计划') ?></h3>
                <div class="weshop-sub-info-item">
                    <span class="label"><?= __('计划名称') ?></span>
                    <span><?= htmlspecialchars($plan->getData('name')) ?></span>
                </div>
                <?php if ($plan->getData('description')): ?>
                    <div class="weshop-sub-info-item">
                        <span class="label"><?= __('计划描述') ?></span>
                        <span><?= htmlspecialchars($plan->getData('description')) ?></span>
                    </div>
                <?php endif; ?>
                <div class="weshop-sub-info-item">
                    <span class="label"><?= __('试用天数') ?></span>
                    <span><?= $plan->getData('trial_days') ?? 0 ?> <?= __('天') ?></span>
                </div>
            </div>
        <?php endif; ?>
    </div>

    <!-- 历史记录 -->
    <div class="weshop-sub-history">
        <h3><?= __('历史记录') ?></h3>
        <?php if (empty($history['items'])): ?>
            <p class="weshop-empty-text"><?= __('暂无历史记录') ?></p>
        <?php else: ?>
            <div class="weshop-sub-timeline">
                <?php foreach ($history['items'] as $h): ?>
                    <div class="weshop-timeline-item">
                        <div class="weshop-timeline-dot"></div>
                        <div class="weshop-timeline-content">
                            <div class="weshop-timeline-header">
                                <span class="weshop-timeline-action"><?= $actionOptions[$h['action']] ?? $h['action'] ?></span>
                                <span class="weshop-timeline-date"><?= $h['created_at'] ?></span>
                            </div>
                            <?php if (!empty($h['note'])): ?>
                                <p class="weshop-timeline-note"><?= htmlspecialchars($h['note']) ?></p>
                            <?php endif; ?>
                            <?php if ((float)($h['amount'] ?? 0) > 0): ?>
                                <span class="weshop-timeline-amount"><?= $formatPrice((float)$h['amount']) ?></span>
                            <?php endif; ?>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </div>
</div>

