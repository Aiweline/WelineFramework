<?php
/**
 * @var \Weline\Framework\View\Template $this
 * @var array $items
 * @var array $status_options
 * @var string $current_status
 */
$title = $title ?? __('My Subscriptions');
if ((string) $title === 'WeShop_Subscription') {
    $title = __('My Subscriptions');
}
$items = $items ?? [];
$status_options = $status_options ?? [];
$current_status = $current_status ?? '';
$total = (int) ($total ?? count($items));
$listUrl = $list_url ?? $this->getUrl('subscription');
$viewUrl = $view_url ?? $this->getUrl('subscription/view');
$pauseUrl = $pause_url ?? $this->getUrl('subscription/pause');
$resumeUrl = $resume_url ?? $this->getUrl('subscription/pause/resume');
$cancelUrl = $cancel_url ?? $this->getUrl('subscription/cancel');

$formatPrice = static function (float $amount): string {
    return \Weline\Currency\Helper\CurrencyFormatter::formatConverted($amount);
};

$statusColorMap = [
    'trialing' => '#2563eb',
    'active' => '#16a34a',
    'paused' => '#d97706',
    'past_due' => '#dc2626',
    'cancelled' => '#64748b',
    'expired' => '#475569',
];

$activeCount = 0;
$attentionCount = 0;
foreach ($items as $item) {
    $status = (string) ($item['status'] ?? '');
    if (in_array($status, ['active', 'trialing'], true)) {
        $activeCount++;
    }
    if (in_array($status, ['past_due', 'paused'], true)) {
        $attentionCount++;
    }
}
?>

<section class="weshop-subscription-page" data-subscription-page>
    <div class="weshop-subscription-hero">
        <div>
            <p class="weshop-subscription-kicker"><?= __('Subscription Service') ?></p>
            <h1><?= $title ?></h1>
            <p><?= __('View membership, VIP, subscription, and auto-renewal services. Renewal cycles, status, and cancellation operations can all be completed on this page.') ?></p>
        </div>
        <div class="weshop-subscription-summary">
            <div>
                <strong><?= $total ?></strong>
                <span><?= __('All Subscriptions') ?></span>
            </div>
            <div>
                <strong><?= $activeCount ?></strong>
                <span><?= __('Active Subscriptions') ?></span>
            </div>
            <div>
                <strong><?= $attentionCount ?></strong>
                <span><?= __('Needs Attention') ?></span>
            </div>
        </div>
    </div>

    <div class="weshop-subscription-toolbar">
        <div class="weshop-subscription-tabs">
            <a class="<?= $current_status === '' ? 'is-active' : '' ?>" href="<?= htmlspecialchars($listUrl, ENT_QUOTES, 'UTF-8') ?>"><?= __('All') ?></a>
            <?php foreach ($status_options as $key => $label): ?>
                <?php $statusUrl = $listUrl . (str_contains($listUrl, '?') ? '&' : '?') . 'status=' . urlencode((string) $key); ?>
                <a class="<?= $current_status === (string) $key ? 'is-active' : '' ?>" href="<?= htmlspecialchars($statusUrl, ENT_QUOTES, 'UTF-8') ?>"><?= $label ?></a>
            <?php endforeach; ?>
        </div>
        <div class="weshop-subscription-message" data-subscription-message hidden></div>
    </div>

    <?php if (empty($items)): ?>
        <div class="weshop-subscription-empty">
            <div class="weshop-subscription-empty__mark">S</div>
            <h2><?= __('No subscription services') ?></h2>
            <p><?= __('You have not yet subscribed to any membership, VIP, recurring purchase, or other periodic services. Once you do, the service plan, price, cycle, next billing date, and available actions will be displayed here.') ?></p>
            <a href="<?= $this->getUrl('customer/account/index') ?>" class="weshop-subscription-empty__link"><?= __('Return to Account Center') ?></a>
        </div>
    <?php else: ?>
        <div class="weshop-subscription-grid">
            <?php foreach ($items as $item): ?>
                <?php
                $id = (int) ($item['subscription_id'] ?? 0);
                $status = (string) ($item['status'] ?? '');
                $statusLabel = $item['status_label'] ?? ($status_options[$status] ?? $status);
                $statusColor = $statusColorMap[$status] ?? '#64748b';
                $detailUrl = $viewUrl . (str_contains($viewUrl, '?') ? '&' : '?') . 'id=' . $id;
                ?>
                <article class="weshop-subscription-card" data-subscription-card data-subscription-id="<?= $id ?>">
                    <header class="weshop-subscription-card__header">
                        <div>
                            <span class="weshop-subscription-id">#<?= $id ?></span>
                            <h2><?= __('Subscription Plans') ?></h2>
                        </div>
                        <span class="weshop-subscription-badge" style="--sub-status-color: <?= htmlspecialchars($statusColor, ENT_QUOTES, 'UTF-8') ?>"><?= $statusLabel ?></span>
                    </header>

                    <div class="weshop-subscription-price">
                        <strong><?= $formatPrice((float) ($item['price'] ?? 0)) ?></strong>
                        <span><?= htmlspecialchars((string) ($item['billing_label'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span>
                    </div>

                    <div class="weshop-subscription-meta">
                        <div>
                            <span class="weshop-subscription-meta__label"><?= __('Current Period') ?></span>
                            <span class="weshop-subscription-meta__value"><?= htmlspecialchars((string) ($item['current_period_start'] ?: '-'), ENT_QUOTES, 'UTF-8') ?> ~ <?= htmlspecialchars((string) ($item['current_period_end'] ?: '-'), ENT_QUOTES, 'UTF-8') ?></span>
                        </div>
                        <div>
                            <span class="weshop-subscription-meta__label"><?= __('Next Billing') ?></span>
                            <span class="weshop-subscription-meta__value"><?= htmlspecialchars((string) ($item['next_billing_at'] ?: '-'), ENT_QUOTES, 'UTF-8') ?></span>
                        </div>
                        <div>
                            <span class="weshop-subscription-meta__label"><?= __('Renewal Count') ?></span>
                            <span class="weshop-subscription-meta__value"><?= (int) ($item['renewal_count'] ?? 0) ?></span>
                        </div>
                    </div>

                    <footer class="weshop-subscription-actions">
                        <a href="<?= htmlspecialchars($detailUrl, ENT_QUOTES, 'UTF-8') ?>" class="weshop-subscription-link"><?= __('View Details') ?></a>
                        <?php if (!empty($item['can_pause'])): ?>
                            <button type="button" data-subscription-action="pause" data-id="<?= $id ?>"><?= __('Pause') ?></button>
                        <?php endif; ?>
                        <?php if (!empty($item['can_resume'])): ?>
                            <button type="button" data-subscription-action="resume" data-id="<?= $id ?>"><?= __('Resume') ?></button>
                        <?php endif; ?>
                        <?php if (!empty($item['can_cancel'])): ?>
                            <button type="button" class="is-danger" data-subscription-cancel-toggle data-id="<?= $id ?>"><?= __('Cancel') ?></button>
                        <?php endif; ?>
                    </footer>

                    <?php if (!empty($item['can_cancel'])): ?>
                        <form class="weshop-subscription-cancel" data-subscription-cancel-form data-id="<?= $id ?>" hidden>
                            <label><?= __('Cancel Reason') ?></label>
                            <textarea name="reason" rows="2" placeholder="<?= __('Optional, explain the reason for cancellation') ?>"></textarea>
                            <div>
                                <button type="button" data-subscription-cancel-close><?= __('Collapse') ?></button>
                                <button type="submit" class="is-danger"><?= __('Confirm Cancel') ?></button>
                            </div>
                        </form>
                    <?php endif; ?>
                </article>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</section>

<link href="@static(WeShop_Subscription::frontend/css/subscription-list.css)" rel="stylesheet" type="text/css"/>
<script src="@static(WeShop_Subscription::frontend/js/subscription-list.js)"></script>
