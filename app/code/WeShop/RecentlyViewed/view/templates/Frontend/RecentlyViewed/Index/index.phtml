<?php
/**
 * Recently Viewed Products Template
 * 最近浏览产品模板
 *
 * @meta-description Recently viewed products page
 * @meta-keywords recently viewed, browsing history, products
 */
?>
<div class="recently-viewed-page">
    <div class="recently-viewed-page__header">
        <h1 class="recently-viewed-page__title"><?= __('Recently Viewed Products') ?></h1>
        <p class="recently-viewed-page__subtitle"><?= __('Products you\'ve recently viewed') ?></p>
    </div>

    <?php if (empty($items)): ?>
        <div class="recently-viewed-page__empty">
            <div class="recently-viewed-page__empty-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12,6 12,12 16,14"/>
                </svg>
            </div>
            <h2 class="recently-viewed-page__empty-title"><?= __('No recently viewed products') ?></h2>
            <p class="recently-viewed-page__empty-text"><?= __('Start browsing to see products here.') ?></p>
            <a href="/" class="recently-viewed-page__empty-action btn btn-primary">
                <?= __('Start Shopping') ?>
            </a>
        </div>
    <?php else: ?>
        <div class="recently-viewed-page__items recently-viewed-page__items--grid">
            <?php foreach ($items as $item): ?>
                <div class="product-card" data-product-id="<?= $item['id'] ?? '' ?>">
                    <div class="product-card__image">
                        <?php if (!empty($item['image'])): ?>
                            <img src="<?= $item['image'] ?>" alt="<?= $item['name'] ?? '' ?>"/>
                        <?php else: ?>
                            <div class="product-card__no-image">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21,15 16,10 5,21"/>
                                </svg>
                            </div>
                        <?php endif; ?>
                        <?php if (!empty($item['badge'])): ?>
                            <span class="product-card__badge"><?= $item['badge'] ?></span>
                        <?php endif; ?>
                    </div>
                    <div class="product-card__details">
                        <h3 class="product-card__name">
                            <a href="<?= $item['url'] ?? '#' ?>"><?= $item['name'] ?? '' ?></a>
                        </h3>
                        <div class="product-card__price">
                            <?php if (!empty($item['special_price'])): ?>
                                <span class="product-card__price-current"><?= $item['formatted_price'] ?? $item['special_price'] ?></span>
                                <span class="product-card__price-old"><?= $item['formatted_regular_price'] ?? '' ?></span>
                            <?php else: ?>
                                <span class="product-card__price-current"><?= $item['formatted_price'] ?? '' ?></span>
                            <?php endif; ?>
                        </div>
                        <?php if ($item['in_stock'] ?? true): ?>
                            <span class="product-card__stock product-card__stock--in"><?= __('In Stock') ?></span>
                        <?php else: ?>
                            <span class="product-card__stock product-card__stock--out"><?= __('Out of Stock') ?></span>
                        <?php endif; ?>
                        <button type="button" class="btn btn-primary product-card__action" data-product-id="<?= $item['product_id'] ?? '' ?>">
                            <?= __('Add to Cart') ?>
                        </button>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
