<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 店铺事件定义请参见 event.php 规约文件 -->
    
    <!-- 事件观察者注册 -->
    <event name="Weline_AutoLeadAgent::lead_search_task::collect_source_types">
        <observer name="WeShop_Store::lead_search_source_type_collector"
                  instance="WeShop\Store\Observer\LeadSearchSourceTypeCollector"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>

    <!-- 监听网站事件：保持原有配置 -->
    <event name="Weline_Websites::website_save_after">
        <observer name="WeShop_Store::website_save_after"
                  instance="WeShop\Store\Observer\WebsiteSaveAfter"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
</config>

