<script>
(function() {
    'use strict';
    
    var WeShopStore = {
        editUrl: '<?= $this->getBackendUrl('*/backend/store/edit') ?>',
        deleteUrl: '<?= $this->getBackendUrl('*/backend/store/post-delete') ?>',
        
        openAddOffcanvas: function() {
            var triggerBtn = document.querySelector('.store-add-offcanvas-trigger');
            if (triggerBtn) {
                triggerBtn.click();
            }
        },
        
        openEditOffcanvas: function(id) {
            var offcanvasElement = document.getElementById('storeEditOffcanvas');
            var iframe = document.getElementById('storeEditOffcanvasIframe');
            
            iframe.src = this.editUrl + '?id=' + id + '&isIframe=true';
            
            var offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
            if (!offcanvas) {
                offcanvas = new bootstrap.Offcanvas(offcanvasElement);
            }
            offcanvas.show();
        },
        
        flushEditIframe: function() {
            showLoading();
            var iframe = $('#storeEditOffcanvasIframe');
            iframe.attr('src', iframe.attr('src'));
            hideLoading();
        },
        
        deleteStore: function(id, name) {
            var self = this;
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                html: '<?= __('确定要删除店铺') ?>: <strong>' + name + '</strong>？',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '<?= __('确认删除') ?>',
                cancelButtonText: '<?= __('取消') ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(self.deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'id=' + id
                    })
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.status) {
                            Swal.fire({
                                title: '<?= __('成功') ?>',
                                text: data.message || '<?= __('删除成功') ?>',
                                icon: 'success',
                                confirmButtonText: '<?= __('确定') ?>'
                            }).then(function() {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                title: '<?= __('错误') ?>',
                                text: data.message || '<?= __('删除失败') ?>',
                                icon: 'error',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            title: '<?= __('错误') ?>',
                            text: '<?= __('网络错误，请稍后重试') ?>',
                            icon: 'error',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        },
        
        initEditSaveButton: function() {
            var self = this;
            
            $('#storeEditOffcanvas').on('show.bs.offcanvas', function() {
                var Iframe = $('#storeEditOffcanvasIframe');
                Iframe.on('load', function() {
                    try {
                        var iframeSrc = Iframe.attr('src') || '';
                        var iframeLocation = Iframe[0].contentWindow.location.href || '';
                        var isOffcanvasResultPage = iframeSrc.indexOf('/component/offcanvas/') !== -1 || 
                                                    iframeLocation.indexOf('/component/offcanvas/') !== -1;
                        
                        if (isOffcanvasResultPage) {
                            return;
                        }
                        
                        var form = Iframe.contents().find('body').find('form');
                        form = (form && form.length > 0) ? form : undefined;
                        if (form !== undefined && form.length > 0) {
                            for (var i = 0; i < form.length; i++) {
                                if ($(form[i]).find(':submit').length === 0) {
                                    form[i].insertAdjacentHTML('beforeend', '<input type="submit" class="sr-only" style="display:none;">')
                                }
                            }
                        }
                    } catch (e) {
                        console.log('OffCanvas form check skipped:', e);
                    }
                });
            });
            
            $('#storeEditOffcanvasSave').on('click', function() {
                var iframe = $('#storeEditOffcanvasIframe');
                var form = iframe.contents().find('body').find('form');
                form = (form && form.length > 0) ? form : undefined;

                try {
                    var iframeSrc = iframe.attr('src') || '';
                    var iframeLocation = '';
                    try {
                        iframeLocation = iframe[0].contentWindow.location.href || '';
                    } catch (e) {}
                    var isOffcanvasResultPage = iframeSrc.indexOf('/component/offcanvas/') !== -1 || 
                                                iframeLocation.indexOf('/component/offcanvas/') !== -1;
                    
                    if (isOffcanvasResultPage) {
                        return;
                    }
                    
                    if (form !== undefined && form.length > 0) {
                        for (var i = 0; i < form.length; i++) {
                            var sub_form = $(form[i]);
                            sub_form.find(':submit').click();
                            showLoading();
                        }
                        hideLoading();
                    } else {
                        console.log('表单未找到');
                    }
                } catch (e) {
                    console.log('OffCanvas form submit check skipped:', e);
                }
            });
        }
    };
    
    window.WeShopStore = WeShopStore;
    
    $(document).ready(function() {
        WeShopStore.initEditSaveButton();
    });
})();
</script>
