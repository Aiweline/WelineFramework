<script>
/**
 * 打开店铺表单 Offcanvas
 */
function openStoreForm(mode, id) {
    const offcanvasElement = document.getElementById('storeFormOffcanvas');
    const iframe = document.getElementById('storeFormIframe');
    const titleElement = document.getElementById('storeFormTitle');
    
    // 设置标题
    if (mode === 'add') {
        titleElement.innerHTML = '<?= __('添加店铺') ?>';
        iframe.src = '<?= $this->getBackendUrl('*/backend/store/get-add') ?>';
    } else if (mode === 'edit' && id) {
        titleElement.innerHTML = '<?= __('编辑店铺') ?>';
        iframe.src = '<?= $this->getBackendUrl('*/backend/store/edit') ?>?id=' + id;
    }
    
    // 显示 offcanvas
    let offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
    if (!offcanvas) {
        offcanvas = new bootstrap.Offcanvas(offcanvasElement);
    }
    offcanvas.show();
    
    // 重置 iframe 加载状态
    iframe.onload = null;
    
    // 监听 iframe 加载完成
    iframe.onload = function() {
        try {
            const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
            const form = iframeDoc.querySelector('form');
            
            if (form) {
                // 移除之前的事件监听器（如果存在）
                const newForm = form.cloneNode(true);
                form.parentNode.replaceChild(newForm, form);
                
                // 拦截表单提交
                newForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    submitStoreForm(newForm, mode, id);
                    return false;
                });
                
                // 也监听表单内的提交按钮
                const submitBtns = newForm.querySelectorAll('button[type="submit"], input[type="submit"], button.btn-primary');
                submitBtns.forEach(btn => {
                    btn.addEventListener('click', function(e) {
                        if (newForm.checkValidity && !newForm.checkValidity()) {
                            e.preventDefault();
                            e.stopPropagation();
                            return false;
                        }
                        e.preventDefault();
                        e.stopPropagation();
                        submitStoreForm(newForm, mode, id);
                        return false;
                    });
                });
            }
        } catch (error) {
            // 跨域或其他错误，使用消息传递
            console.log('无法访问 iframe 内容，将使用消息传递方式');
        }
    };
}

/**
 * 提交店铺表单
 */
function submitStoreForm(form, mode, id) {
    const formData = new FormData(form);
    const action = form.action || (mode === 'add' 
        ? '<?= $this->getBackendUrl('*/backend/store/post-add') ?>' 
        : '<?= $this->getBackendUrl('*/backend/store/edit') ?>?id=' + id);
    
    // 显示加载提示
    Swal.fire({
        title: '<?= __('处理中') ?>',
        text: '<?= __('正在保存，请稍候...') ?>',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
    
    // 提交表单
    fetch(action, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData
    })
    .then(response => {
        // 尝试解析 JSON
        return response.text().then(text => {
            try {
                const json = JSON.parse(text);
                return json;
            } catch {
                // 如果不是 JSON，检查是否是成功页面
                if (text.includes('success') || response.ok) {
                    return { status: true, success: true, message: mode === 'add' ? '<?= __('添加成功') ?>' : '<?= __('编辑成功') ?>' };
                }
                return { status: false, success: false, message: '<?= __('保存失败') ?>' };
            }
        });
    })
    .then(data => {
        Swal.close();
        if (data.status !== false && data.success !== false) {
            Swal.fire({
                title: '<?= __('成功') ?>',
                text: data.message || (mode === 'add' ? '<?= __('添加成功') ?>' : '<?= __('编辑成功') ?>'),
                icon: 'success',
                confirmButtonText: '<?= __('确定') ?>',
                timer: 1500,
                timerProgressBar: true
            }).then(() => {
                // 关闭 offcanvas
                const offcanvasElement = document.getElementById('storeFormOffcanvas');
                const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
                if (offcanvas) {
                    offcanvas.hide();
                }
                // 刷新页面
                setTimeout(() => {
                    location.reload();
                }, 100);
            });
        } else {
            Swal.fire({
                title: '<?= __('错误') ?>',
                text: data.message || '<?= __('保存失败') ?>',
                icon: 'error',
                confirmButtonText: '<?= __('确定') ?>'
            });
        }
    })
    .catch(error => {
        Swal.close();
        Swal.fire({
            title: '<?= __('错误') ?>',
            text: '<?= __('网络错误，请稍后重试') ?>: ' + error.message,
            icon: 'error',
            confirmButtonText: '<?= __('确定') ?>'
        });
    });
}

/**
 * 删除店铺
 */
function deleteStore(id, name) {
    Swal.fire({
        title: '<?= __('确认删除') ?>',
        html: `<?= __('确定要删除店铺') ?>: <strong>${name}</strong>？`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: '<?= __('确认删除') ?>',
        cancelButtonText: '<?= __('取消') ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            // 发送删除请求
            fetch('<?= $this->getBackendUrl('*/backend/store/post-delete') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id
            })
            .then(response => response.json())
            .then(data => {
                if (data.status) {
                    Swal.fire({
                        title: '<?= __('成功') ?>',
                        text: data.message || '<?= __('删除成功') ?>',
                        icon: 'success',
                        confirmButtonText: '<?= __('确定') ?>'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        title: '<?= __('错误') ?>',
                        text: data.message || '<?= __('删除失败') ?>',
                        icon: 'error',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: '<?= __('错误') ?>',
                    text: '<?= __('网络错误，请稍后重试') ?>',
                    icon: 'error',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        }
    });
}
</script>

