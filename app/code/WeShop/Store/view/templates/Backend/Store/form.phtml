                        <?php
                        // 构建搜索选择组件的options字符串
                        $localOptions = [];
                        $locals = $this->getData('locals') ?? [];
                        if (is_array($locals)) {
                            foreach ($locals as $local) {
                                if (!is_array($local)) {
                                    continue;
                                }
                                // 确保code和display_name都是字符串
                                $codeValue = $local['code'] ?? '';
                                $code = is_array($codeValue) ? '' : (string)$codeValue;
                                $code = htmlspecialchars($code);
                                
                                $displayNameValue = $local['display_name'] ?? '';
                                $displayName = is_array($displayNameValue) ? '' : (string)$displayNameValue;
                                $displayName = htmlspecialchars($displayName . '：' . $code);
                                
                                if ($code) {
                                    $localOptions[] = $code . ':' . $displayName;
                                }
                            }
                        }
                        $localOptionsStr = implode(',', $localOptions);
                        
                        // 获取当前选中的地区码，确保是字符串类型
                        $store = $this->getData('store');
                        $currentLocal = '';
                        if ($store) {
                            if (is_array($store) && isset($store['local'])) {
                                $currentLocal = is_array($store['local']) ? '' : (string)$store['local'];
                            } elseif (is_object($store) && method_exists($store, 'getLocal')) {
                                $currentLocal = (string)$store->getLocal();
                            } elseif (is_object($store) && isset($store->local)) {
                                $localValue = $store->local;
                                $currentLocal = is_array($localValue) ? '' : (string)$localValue;
                            }
                        }
                        $currentLocal = (string)$currentLocal;
                        $localValue = htmlspecialchars($currentLocal);
                        ?>
