<script>
(function() {
    'use strict';
    
    var debounce = function(fn, delay) {
        var timer = null;
        return function() {
            var context = this;
            var args = arguments;
            clearTimeout(timer);
            timer = setTimeout(function() {
                fn.apply(context, args);
            }, delay);
        };
    };
    
    // 检测编码是否重复
    $('#storeCode').on('input', debounce(function () {
        var code = $(this).val();
        $.ajax({
            url: '<?= $this->getBackendUrl('*/backend/store/ajax-code-exist') ?>',
            type: 'POST',
            dataType: 'json',
            data: {code: code}
        }).done(function (res) {
            var input = $('#storeCode');
            if (input.next()) {
                input.next().remove();
            }
            if (res) {
                input.css({border: "1px solid var(--backend-color-success, green)"});
            } else {
                input.css({border: "1px solid var(--backend-color-danger, red)"});
            }
        });
    }, 500));
})();
</script>
