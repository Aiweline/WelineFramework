<?php
/**
 * B2B storefront account-center order card.
 *
 * @hook-priority 220
 * @hook-sort-order 25
 * @hook-solo false
 */

use WeShop\B2B\Service\CompanyService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$customer = $session->getCustomer();
if (!$customer || !$customer->getId()) {
    return;
}

$contactEmail = trim((string) ($customer->getUsername() ?? ''));

/** @var CompanyService $companyService */
$companyService = ObjectManager::getInstance(CompanyService::class);
$summary = $contactEmail !== ''
    ? $companyService->getCompanySummaryByContactEmail($contactEmail)
    : ['total' => 0, 'status_breakdown' => [], 'primary_status' => ''];
$total = (int) ($summary['total'] ?? 0);
$statusKey = (string) ($summary['primary_status'] ?? '');
$statusLabel = $statusKey !== '' ? __($statusKey) : __('Awaiting link');
?>
<article class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary"><?= __('B2B account access') ?></p>
            <h2 class="mt-1 text-2xl font-black text-text-primary-light dark:text-text-primary-dark"><?= __('Linked companies') ?></h2>
        </div>
        <a href="<?= $this->getUrl('b2b') ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open B2B center') ?></a>
    </div>

    <p class="mt-4 text-sm leading-6 text-text-secondary-light dark:text-text-secondary-dark">
        <?= __('Review company records matched to your current account email and jump into the B2B hub.') ?>
    </p>

    <p class="mt-3 text-sm text-text-secondary-light dark:text-text-secondary-dark">
        <?= __('Linked companies: %1 (%2)', $total, $statusLabel) ?>
    </p>
</article>
