<?php
$items = $this->getData('items') ?? [];
$accountSaveUrl = (string) ($this->getData('accountSaveUrl') ?? '');
$accountIndexUrl = (string) ($this->getData('accountIndexUrl') ?? '');
$paymentTerms = $this->getData('paymentTerms') ?? [];
?>
<div class="container-fluid py-3">
    <h1 class="h3 mb-3"><?= __('B2B Trade Accounts') ?></h1>
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5"><?= __('Create / update account') ?></h2>
            <form method="post" action="<?= htmlspecialchars($accountSaveUrl, ENT_QUOTES) ?>" class="row g-2 align-items-end">
                <input type="hidden" name="back_url" value="<?= htmlspecialchars($accountIndexUrl, ENT_QUOTES) ?>">
                <div class="col-md-2">
                    <label class="form-label"><?= __('Customer ID') ?></label>
                    <input type="number" name="customer_id" class="form-control" required min="1">
                </div>
                <div class="col-md-3">
                    <label class="form-label"><?= __('Payment term') ?></label>
                    <select name="payment_term_id" class="form-select">
                        <option value="0"><?= __('—') ?></option>
                        <?php foreach ($paymentTerms as $t): ?>
                            <?php if (!is_array($t)) {
                                continue;
                            } ?>
                            <option value="<?= (int) ($t['term_id'] ?? 0) ?>"><?= htmlspecialchars((string) ($t['term_name'] ?? ''), ENT_QUOTES) ?></option>
                        <?php endforeach; ?>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label"><?= __('Period days override') ?></label>
                    <input type="number" name="credit_period_days" class="form-control" min="0" value="0">
                </div>
                <div class="col-md-3">
                    <label class="form-label"><?= __('Auto approve under') ?></label>
                    <input type="number" step="0.01" name="auto_approve_limit" class="form-control" min="0" value="0">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary"><?= __('Save') ?></button>
                </div>
            </form>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
            <tr>
                <th><?= __('Customer ID') ?></th>
                <th><?= __('Term') ?></th>
                <th><?= __('Balance') ?></th>
                <th><?= __('Auto approve') ?></th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($items as $row): ?>
                <?php if (!is_array($row)) {
                    continue;
                } ?>
                <tr>
                    <td><?= (int) ($row['customer_id'] ?? 0) ?></td>
                    <td><?= (int) ($row['payment_term_id'] ?? 0) ?></td>
                    <td><?= htmlspecialchars((string) ($row['account_balance'] ?? ''), ENT_QUOTES) ?></td>
                    <td><?= htmlspecialchars((string) ($row['auto_approve_limit'] ?? ''), ENT_QUOTES) ?></td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>
</div>
