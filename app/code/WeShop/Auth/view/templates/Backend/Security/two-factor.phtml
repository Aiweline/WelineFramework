                        <dt class="col-sm-5"><?= __('Backup Codes') ?></dt>
                        <dd class="col-sm-7"><?= (int) ($config['backup_codes_count'] ?? 0) ?></dd>
                    </dl>
                <?php else: ?>
                    <p class="text-muted mb-0">
                        <?= __('Enable an authenticator app for this backend account so future password and Google sign-ins can require a second verification step.') ?>
                    </p>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <?php if ($isEnabled): ?>
            <div class="card mb-4">
