            <div class="alert alert-info">
                <strong><?= __('Challenge policy reminder') ?></strong><br>
                <?= __('Your backend authenticator can be configured now, while enforcement stays off until the password or Google login flow is enabled in configuration.') ?><br>
                <?= __('Password login') ?>: <?= (bool) ($flowStatus['password'] ?? false) ? __('Enabled') : __('Disabled by default') ?>,
                <?= __('Google login') ?>: <?= (bool) ($flowStatus['google'] ?? false) ? __('Enabled') : __('Disabled by default') ?>
            </div>
        </div>
    </div>
<?php endif; ?>

<div class="row">
    <div class="col-xl-4">
        <div class="card">
