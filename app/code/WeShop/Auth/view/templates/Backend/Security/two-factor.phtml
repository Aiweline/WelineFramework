                <div class="card-body">
                    <p class="text-muted"><?= __('Disabling two-factor authentication removes the second verification step for future backend sign-ins. Use this only if you are rotating to another device or method.') ?></p>
                    <form action="<?= htmlspecialchars($postUrl, ENT_QUOTES) ?>" method="post" class="row g-3">
                        <?= $this->getFormKey($postUrl) ?>
                        <input type="hidden" name="form_action" value="disable">
