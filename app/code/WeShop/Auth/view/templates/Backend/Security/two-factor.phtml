                            </div>
                            <div class="mt-3">
                                <strong><?= __('Manual Setup Secret') ?></strong>
                                <code class="d-block mt-2"><?= htmlspecialchars((string) ($setup['formatted_secret'] ?? ''), ENT_QUOTES) ?></code>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <p class="text-muted">
                                <?= __('Scan the QR code with Google Authenticator, Microsoft Authenticator, 1Password, or another TOTP-compatible app. Then confirm the current 6-digit code to finish setup.') ?>
                            </p>

                            <div class="row g-2 mb-4">
                                <?php foreach ($backupCodes as $backupCode): ?>
                                    <div class="col-sm-6 col-xl-4">
                                        <code class="d-block rounded bg-light p-3 text-center"><?= htmlspecialchars((string) $backupCode, ENT_QUOTES) ?></code>
                                    </div>
                                <?php endforeach; ?>
                            </div>

                            <form action="<?= htmlspecialchars($postUrl, ENT_QUOTES) ?>" method="post" class="row g-3">
                                <?= $this->getFormKey($postUrl) ?>
                                <input type="hidden" name="form_action" value="enable">
                                <input type="hidden" name="secret" value="<?= htmlspecialchars((string) ($setup['secret'] ?? ''), ENT_QUOTES) ?>">
