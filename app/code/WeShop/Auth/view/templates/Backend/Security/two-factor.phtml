                            <label class="form-label"><?= __('Authenticator Code') ?></label>
                            <input type="text" name="code" class="form-control" autocomplete="one-time-code" placeholder="<?= __('Enter the current 6-digit code') ?>">
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-outline-danger w-100"><?= __('Disable 2FA') ?></button>
                        </div>
                    </form>
                </div>
            </div>
        <?php else: ?>
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0"><?= __('Set Up an Authenticator App') ?></h5>
