                        <?= __('和') ?>
                        <a href="<?= $this->getUrl('cms/page/privacy') ?>"><?= __('隐私政策') ?></a>。
                    </span>
                </label>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::place-order-button-before"/>
                <button
                    class="weshop-checkout-submit weline-pixel::begin_checkout"
                    type="submit"
                    data-weshop-place-order
                    data-guest-label="<?= $escape(__('匿名支付')) ?>"
                    data-customer-label="<?= $escape(__('提交订单')) ?>"
                >
                    <?= $isGuestCheckout ? __('匿名支付') : __('提交订单') ?>
