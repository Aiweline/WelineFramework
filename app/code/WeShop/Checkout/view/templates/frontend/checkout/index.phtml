<?php
$cartItems = $this->getData('cart_items') ?? [];
$cartSummary = $this->getData('cart_summary') ?? [];
$customer = $this->getData('customer') ?? null;
$savedAddresses = $this->getData('saved_addresses') ?? [];
$selectedShippingAddressId = (int) ($this->getData('selected_shipping_address_id') ?? 0);
$shippingMethods = $this->getData('shipping_methods') ?? [];
$paymentMethods = $this->getData('payment_methods') ?? [];
$countries = $this->getData('countries') ?? [];
$isRetryPayment = (bool) ($this->getData('is_retry_payment') ?? false);
$isGuestCheckout = (bool) ($this->getData('is_guest_checkout') ?? !$customer);
$retryOrderId = (int) ($this->getData('retry_order_id') ?? 0);
$retryOrderIncrementId = (string) ($this->getData('retry_order_increment_id') ?? '');
$checkoutCurrency = strtoupper((string)\w_env('user.currency', 'USD'));
$customerEmail = '';
if ($customer && method_exists($customer, 'getEmail')) {
    $customerEmail = (string) $customer->getEmail();
}
if ($customerEmail === '' && $customer && method_exists($customer, 'getUsername')) {
    $candidateEmail = (string) $customer->getUsername();
    $customerEmail = filter_var($candidateEmail, FILTER_VALIDATE_EMAIL) ? $candidateEmail : '';
}
$formatCheckoutPrice = static function (float $amount) use ($checkoutCurrency): string {
    $symbols = [
        'CNY' => '¥',
        'USD' => '$',
        'EUR' => '€',
        'GBP' => '£',
        'JPY' => '¥',
    ];
    $symbol = $symbols[$checkoutCurrency] ?? ($checkoutCurrency . ' ');
    return $symbol . number_format($amount, 2);
};
