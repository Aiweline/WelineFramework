                        <?php foreach ($countries as $country): ?>
                            <option value="<?= htmlspecialchars((string) ($country['code'] ?? '')) ?>"><?= htmlspecialchars((string) ($country['name'] ?? '')) ?></option>
                        <?php endforeach; ?>
                    </select>
                </div>
            </div>
        </section>

        <section class="checkout-form__card">
            <div class="checkout-form__section-heading">
                <h2 class="checkout-form__card-title"><?= __('Shipping Method') ?></h2>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::shipping-methods-before"/>
            <div data-weshop-shipping-method-host>
                <w:hook name="Weline_Checkout::frontend::partials::checkout::shipping-methods"/>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::shipping-methods-after"/>
        </section>

        <section class="checkout-form__card">
            <div class="checkout-form__section-heading">
                <h2 class="checkout-form__card-title"><?= __('Payment Method') ?></h2>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::payment-methods-before"/>
            <div data-weshop-payment-method-host>
                <w:hook name="Weline_Checkout::frontend::partials::checkout::payment-methods"/>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::payment-methods-after"/>
            <div class="checkout-form__submit-area">
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::review-before"/>
            <label class="checkout-form__terms">
                <input type="checkbox" name="agree_terms" required>
                <span>
                    <?= __('I agree to the') ?>
                    <a href="<?= $this->getUrl('cms/page/terms') ?>"><?= __('Terms of Service') ?></a>
                    <?= __('and') ?>
                    <a href="<?= $this->getUrl('cms/page/privacy') ?>"><?= __('Privacy Policy') ?></a>.
                </span>
            </label>
            <div style="margin-top: var(--spacing-md);">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::place-order-button-before"/>
                <button class="checkout-form__submit weline-pixel::begin_checkout" type="submit"><?= __('Place Order') ?></button>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::place-order-button-after"/>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::review-after"/>
            </div>
        </section>
    </form>

    <aside class="checkout-form__card checkout-summary" data-weshop-summary-panel>
        <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-before"/>
        <h2 class="checkout-form__card-title"><?= __('Order Summary') ?></h2>
        <div class="checkout-summary__list">
            <?php foreach ($cartItems as $item): ?>
                <div class="checkout-summary__item">
                    <div class="checkout-summary__thumb">
                        <img src="<?= htmlspecialchars((string) ($item['image'] ?? '')) ?>" alt="<?= htmlspecialchars((string) ($item['name'] ?? '')) ?>">
                        <span class="checkout-summary__qty"><?= (int) ($item['qty'] ?? 0) ?></span>
                    </div>
                    <div>
                        <div class="checkout-summary__item-name"><?= htmlspecialchars((string) ($item['name'] ?? '')) ?></div>
                        <div class="checkout-summary__item-meta"><?= __('Qty: %{1}', (int) ($item['qty'] ?? 0)) ?></div>
                    </div>
                    <div><?= $formatCheckoutPrice((float) ($item['row_total'] ?? 0)) ?></div>
                </div>
            <?php endforeach; ?>
        </div>

        <div class="checkout-summary__totals" data-weshop-summary-host data-weshop-summary-currency="<?= htmlspecialchars($checkoutCurrency) ?>">
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-rows-before"/>
            <div class="checkout-summary__row">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-subtotal-before"/>
                <span><?= __('Subtotal') ?></span>
                <span data-weshop-summary-subtotal><?= $formatCheckoutPrice((float) ($cartSummary['subtotal'] ?? 0)) ?></span>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-subtotal-after"/>
            </div>
            <div class="checkout-summary__row">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-shipping-before"/>
                <span><?= __('Shipping') ?></span>
                <span data-weshop-summary-shipping><?= $formatCheckoutPrice((float) ($cartSummary['shipping'] ?? 0)) ?></span>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-shipping-after"/>
            </div>
            <div class="checkout-summary__row">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-tax-before"/>
                <span><?= __('Tax') ?></span>
                <span data-weshop-summary-tax><?= $formatCheckoutPrice((float) ($cartSummary['tax'] ?? 0)) ?></span>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-tax-after"/>
            </div>
            <div class="checkout-summary__row" data-weshop-summary-discount-row <?= (float) ($cartSummary['discount'] ?? 0) > 0 ? '' : 'hidden' ?>>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-discount-before"/>
                <span><?= __('Discount') ?></span>
                <span data-weshop-summary-discount>-<?= $formatCheckoutPrice((float) ($cartSummary['discount'] ?? 0)) ?></span>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-discount-after"/>
            </div>
            <div class="checkout-summary__row checkout-summary__row--total">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-grand-total-before"/>
                <span><?= __('Grand Total') ?></span>
                <span data-weshop-summary-grand-total><?= $formatCheckoutPrice((float) ($cartSummary['grand_total'] ?? 0)) ?></span>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-grand-total-after"/>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-rows-after"/>
        </div>
        <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-after"/>
    </aside>
</div>
</div>

<script>
    (function () {
        var radios = document.querySelectorAll('input[name="shipping_address_id"]');
        var newAddressFields = document.querySelectorAll('[data-new-address-field]');
        var form = document.getElementById('weshop-checkout-form');
        var submitButton = form ? form.querySelector('button[type="submit"]') : null;
        var successUrl = '<?= $this->getUrl('checkout/success') ?>';
        var methodsUrl = '<?= $this->getUrl('checkout/methods') ?>';
        var shippingMethodHost = document.querySelector('[data-weshop-shipping-method-host]');
        var paymentMethodHost = document.querySelector('[data-weshop-payment-method-host]');
        var summaryHost = document.querySelector('[data-weshop-summary-host]');
        var subtotalValue = document.querySelector('[data-weshop-summary-subtotal]');
        var shippingValue = document.querySelector('[data-weshop-summary-shipping]');
        var taxValue = document.querySelector('[data-weshop-summary-tax]');
        var discountRow = document.querySelector('[data-weshop-summary-discount-row]');
        var discountValue = document.querySelector('[data-weshop-summary-discount]');
        var grandTotalValue = document.querySelector('[data-weshop-summary-grand-total]');
        var summaryToggle = document.querySelector('[data-weshop-summary-toggle]');
        var summaryPanel = document.querySelector('[data-weshop-summary-panel]');
        var summaryToggleLabel = document.querySelector('[data-weshop-summary-toggle-label]');
        var summaryToggleTotal = document.querySelector('[data-weshop-summary-toggle-total]');
        var initialCartSummary = <?= json_encode($cartSummary, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
        var refreshTimer = null;

        function syncSummaryToggle(expanded) {
            if (summaryToggle) {
                summaryToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            }

            if (summaryToggleLabel) {
                summaryToggleLabel.textContent = expanded ? '<?= __('Hide order summary') ?>' : '<?= __('Show order summary') ?>';
            }
        }

        if (summaryToggle && summaryPanel) {
            summaryToggle.addEventListener('click', function () {
                var expanded = !summaryPanel.classList.contains('is-open');
                summaryPanel.classList.toggle('is-open', expanded);
                syncSummaryToggle(expanded);
            });
        }

        function syncNewAddressRequirement() {
            var hasSavedAddress = false;
            radios.forEach(function (radio) {
                if (radio.checked) {
                    hasSavedAddress = true;
                }
            });

            newAddressFields.forEach(function (field) {
                if (hasSavedAddress) {
                    field.removeAttribute('required');
                }
            });
        }

        radios.forEach(function (radio) {
            radio.addEventListener('change', syncNewAddressRequirement);
        });

        function showCheckoutMessage(message, type) {
            if (window.WeShop && typeof window.WeShop.showNotification === 'function') {
                window.WeShop.showNotification(message, type);
                return;
            }

            console.error(message);
        }

        function escapeHtml(value) {
            return String(value || '').replace(/[&<>"']/g, function (character) {
                return {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                }[character] || character;
            });
        }

        function getCheckedValue(name) {
            if (!form) {
                return '';
            }

            var checked = form.querySelector('input[name="' + name + '"]:checked');
            return checked ? checked.value : '';
        }

        function formatSummaryAmount(value) {
            var amount = Number(value || 0);
            var currency = summaryHost ? String(summaryHost.getAttribute('data-weshop-summary-currency') || 'USD') : 'USD';

            if (window.Intl && typeof window.Intl.NumberFormat === 'function') {
                try {
                    return new Intl.NumberFormat(undefined, {
                        style: 'currency',
                        currency: currency,
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(amount);
                } catch (error) {
                    console.warn('Checkout summary currency formatting fallback:', error);
                }
            }

            return amount.toFixed(2);
        }

        function renderCartSummary(summary) {
            if (!summaryHost || !summary) {
                return;
            }

            var normalized = {
                subtotal: Number(summary.subtotal || 0),
                shipping: Number(summary.shipping || 0),
                discount: Number(summary.discount || 0),
                tax: Number(summary.tax || 0),
                grand_total: Number(summary.grand_total || summary.total || 0)
            };

            if (subtotalValue) {
                subtotalValue.textContent = formatSummaryAmount(normalized.subtotal);
            }

            if (shippingValue) {
                shippingValue.textContent = formatSummaryAmount(normalized.shipping);
            }

            if (taxValue) {
                taxValue.textContent = formatSummaryAmount(normalized.tax);
            }

            if (discountValue) {
                discountValue.textContent = '-' + formatSummaryAmount(normalized.discount);
            }

            if (discountRow) {
                discountRow.hidden = normalized.discount <= 0;
            }

            if (grandTotalValue) {
                var grandTotalText = formatSummaryAmount(normalized.grand_total);
                grandTotalValue.textContent = grandTotalText;

                if (summaryToggleTotal) {
                    summaryToggleTotal.textContent = grandTotalText;
                }
            }
        }

        function renderShippingMethods(methods) {
            if (!shippingMethodHost) {
                return;
            }

            if (!Array.isArray(methods) || methods.length === 0) {
                shippingMethodHost.innerHTML = '<div class="weshop-checkout-empty"><?= __('No shipping methods are available for the current checkout context.') ?></div>';
                return;
            }

            var html = '<div class="checkout-form__choice-list" data-weshop-shipping-method-list>';
            methods.forEach(function (method) {
                if (!method || !method.code) {
                    return;
                }

                html += '<label class="checkout-form__choice">'
                    + '<input type="radio" name="shipping_method" value="' + escapeHtml(method.code) + '"' + (method.is_default ? ' checked' : '') + ' required>'
                    + '<span>'
                    + '<div class="weshop-checkout-choice-title">' + escapeHtml(method.name || method.title || method.code) + '</div>';

                if (method.description) {
                    html += '<div class="weshop-checkout-choice-meta">' + escapeHtml(method.description) + '</div>';
                }

                html += '</span></label>';
            });
            html += '</div>';
            shippingMethodHost.innerHTML = html;
        }

        function renderPaymentMethods(methods) {
            if (!paymentMethodHost) {
                return;
            }

            if (!Array.isArray(methods) || methods.length === 0) {
                paymentMethodHost.innerHTML = '<div class="weshop-checkout-empty"><?= __('No payment methods are available for the current checkout context.') ?></div>';
                return;
            }

            var html = '<div class="checkout-form__choice-list" data-weshop-payment-method-list>';
            methods.forEach(function (method) {
                if (!method || !method.code) {
                    return;
                }

                html += '<label class="checkout-form__choice">'
                    + '<input type="radio" name="payment_method" value="' + escapeHtml(method.code) + '"' + (method.is_default ? ' checked' : '') + ' required>'
                    + '<span>'
                    + '<div class="weshop-checkout-choice-title">' + escapeHtml(method.title || method.name || method.code) + '</div>';

                var helperText = method.checkout_note || method.description || '';
                if (helperText) {
                    html += '<div class="weshop-checkout-choice-meta">' + escapeHtml(helperText) + '</div>';
                }

                html += '</span></label>';
            });
            html += '</div>';
            paymentMethodHost.innerHTML = html;
        }

        function refreshCheckoutMethods() {
            if (!form) {
                return Promise.resolve();
            }

            return fetch(methodsUrl, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (!payload || !payload.success) {
                    showCheckoutMessage((payload && payload.message) || 'Unable to refresh checkout methods right now.', 'error');
                    return;
                }

                var data = payload.data || {};
                renderShippingMethods(Array.isArray(data.shipping_methods) ? data.shipping_methods : []);
                renderPaymentMethods(Array.isArray(data.payment_methods) ? data.payment_methods : []);
                renderCartSummary(data.cart_summary || {});
            }).catch(function (error) {
                console.error('Checkout method refresh error:', error);
                showCheckoutMessage('Unable to refresh checkout methods right now.', 'error');
            });
        }

        function scheduleCheckoutMethodRefresh() {
            if (refreshTimer) {
                window.clearTimeout(refreshTimer);
            }

            refreshTimer = window.setTimeout(function () {
                refreshCheckoutMethods();
            }, 180);
        }

        if (form) {
            form.addEventListener('change', function (event) {
                var target = event.target;
                if (!target || !target.name) {
                    return;
                }

                if (target.name === 'payment_method') {
                    return;
                }

                if (target.name === 'shipping_address_id'
                    || target.name === 'shipping_method'
                    || target.name === 'shipping_address[country_id]'
                    || target.name === 'shipping_address[region]') {
                    scheduleCheckoutMethodRefresh();
                }
            });

            form.addEventListener('submit', function (event) {
                event.preventDefault();

                if (submitButton) {
                    submitButton.disabled = true;
                }

                fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                }).then(function (response) {
                    return response.json();
                }).then(function (payload) {
                    if (!payload || !payload.success) {
                        showCheckoutMessage((payload && payload.message) || 'Unable to place the order right now.', 'error');
                        return;
                    }

                    var redirectUrl = payload.data && payload.data.redirect_url ? payload.data.redirect_url : '';
                    if (!redirectUrl && payload.data && payload.data.order_id) {
                        redirectUrl = successUrl + (successUrl.indexOf('?') === -1 ? '?' : '&') + 'order_id=' + encodeURIComponent(payload.data.order_id);
                    }
                    window.location.href = redirectUrl || successUrl;
                }).catch(function (error) {
                    console.error('Checkout submit error:', error);
                    showCheckoutMessage('Unable to place the order right now.', 'error');
                }).finally(function () {
                    if (submitButton) {
                        submitButton.disabled = false;
                    }
                });
            });
        }

        newAddressFields.forEach(function (field) {
            field.addEventListener('input', scheduleCheckoutMethodRefresh);
            field.addEventListener('change', scheduleCheckoutMethodRefresh);
        });

        radios.forEach(function (radio) {
            radio.addEventListener('change', scheduleCheckoutMethodRefresh);
        });

        syncNewAddressRequirement();
        renderCartSummary(initialCartSummary);
})();
</script>

<w:hook name="Weline_Checkout::frontend::layouts::checkout::content-after"/>
