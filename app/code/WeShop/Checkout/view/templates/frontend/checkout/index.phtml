        <aside class="weshop-checkout-summary" data-weshop-summary-panel>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-before"/>
            <h2><?= __('订单摘要') ?></h2>
            <div class="weshop-checkout-summary-list">
                <?php foreach ($cartItems as $item): ?>
                    <div class="weshop-checkout-summary-item">
                        <div class="weshop-checkout-summary-thumb">
                            <img src="<?= $escape($item['image'] ?? '') ?>" alt="<?= $escape($item['name'] ?? '') ?>">
                            <span class="weshop-checkout-summary-qty"><?= (int) ($item['qty'] ?? 0) ?></span>
                        </div>
                        <div>
                            <div class="weshop-checkout-summary-item-name"><?= $escape($item['name'] ?? '') ?></div>
                            <div class="weshop-checkout-summary-item-meta"><?= __('数量：%{1}', (int) ($item['qty'] ?? 0)) ?></div>
                        </div>
                        <div class="weshop-checkout-summary-price"><?= $formatCheckoutPrice((float) ($item['row_total'] ?? 0)) ?></div>
                    </div>
                <?php endforeach; ?>
            </div>

            <div class="weshop-checkout-summary-totals" data-weshop-summary-host data-weshop-summary-currency="<?= $escape($checkoutCurrency) ?>">
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-rows-before"/>
                <div class="weshop-checkout-summary-row">
                    <span><?= __('小计') ?></span>
                    <span data-weshop-summary-subtotal><?= $formatCheckoutPrice((float) ($cartSummary['subtotal'] ?? 0)) ?></span>
                </div>
                <div class="weshop-checkout-summary-row">
                    <span><?= __('运费') ?></span>
                    <span data-weshop-summary-shipping><?= $formatCheckoutPrice((float) ($cartSummary['shipping'] ?? 0)) ?></span>
                </div>
                <div class="weshop-checkout-summary-row">
                    <span><?= __('税费') ?></span>
                    <span data-weshop-summary-tax><?= $formatCheckoutPrice((float) ($cartSummary['tax'] ?? 0)) ?></span>
                </div>
                <div class="weshop-checkout-summary-row" data-weshop-summary-discount-row <?= (float) ($cartSummary['discount'] ?? 0) > 0 ? '' : 'hidden' ?>>
                    <span><?= __('优惠') ?></span>
                    <span data-weshop-summary-discount>-<?= $formatCheckoutPrice((float) ($cartSummary['discount'] ?? 0)) ?></span>
                </div>
                <div class="weshop-checkout-summary-row weshop-checkout-summary-total">
                    <span><?= __('合计') ?></span>
                    <span data-weshop-summary-grand-total><?= $formatCheckoutPrice((float) ($cartSummary['grand_total'] ?? 0)) ?></span>
                </div>
                <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-rows-after"/>
            </div>
            <w:hook name="Weline_Checkout::frontend::layouts::checkout::summary-after"/>
        </aside>
    </div>
</div>

<script>
    (function () {
        var form = document.getElementById('weshop-checkout-form');
        if (!form) {
            return;
        }

        var successUrl = '<?= $this->getUrl('checkout/success') ?>';
        var methodsUrl = '<?= $this->getUrl('checkout/methods') ?>';
        var submitButton = form.querySelector('[data-weshop-place-order]');
        var alertBox = form.querySelector('[data-weshop-checkout-alert]');
        var shippingMethodHost = document.querySelector('[data-weshop-shipping-method-host]');
        var paymentMethodHost = document.querySelector('[data-weshop-payment-method-host]');
        var summaryHost = document.querySelector('[data-weshop-summary-host]');
        var summaryPanel = document.querySelector('[data-weshop-summary-panel]');
        var summaryToggle = document.querySelector('[data-weshop-summary-toggle]');
        var summaryToggleLabel = document.querySelector('[data-weshop-summary-toggle-label]');
        var summaryToggleTotal = document.querySelector('[data-weshop-summary-toggle-total]');
        var summaryFields = {
            subtotal: document.querySelector('[data-weshop-summary-subtotal]'),
            shipping: document.querySelector('[data-weshop-summary-shipping]'),
            tax: document.querySelector('[data-weshop-summary-tax]'),
            discount: document.querySelector('[data-weshop-summary-discount]'),
            discountRow: document.querySelector('[data-weshop-summary-discount-row]'),
            grandTotal: document.querySelector('[data-weshop-summary-grand-total]')
        };
        var checkoutShell = document.querySelector('[data-weshop-checkout-mode]');
        var modeBadge = document.querySelector('[data-weshop-checkout-mode-badge]');
        var checkoutModeInputs = Array.prototype.slice.call(form.querySelectorAll('input[name="checkout_mode"]'));
        var contactModeLabel = document.querySelector('[data-weshop-contact-mode-label]');
        var contactHelp = document.querySelector('[data-weshop-contact-help]');
        var savedAddressList = document.querySelector('[data-weshop-saved-address-list]');
        var addressFields = Array.prototype.slice.call(form.querySelectorAll('[data-new-address-field]'));
        var requiredAddressFields = Array.prototype.slice.call(form.querySelectorAll('[data-guest-address-required]'));
        var refreshTimer = null;
        var initialCartSummary = <?= json_encode($cartSummary, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

        function escapeHtml(value) {
            return String(value || '').replace(/[&<>"']/g, function (character) {
                return {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                }[character] || character;
            });
        }

        function showCheckoutMessage(message, type) {
            if (!alertBox) {
                console.error(message);
                return;
            }

            alertBox.textContent = message || '';
            alertBox.classList.toggle('is-visible', Boolean(message));
            alertBox.classList.toggle('is-error', type === 'error');
        }

        function selectedCheckoutMode() {
            var checked = form.querySelector('input[name="checkout_mode"]:checked');
            return checked ? checked.value : 'guest';
        }

        function isGuestCheckoutMode() {
            return selectedCheckoutMode() === 'guest';
        }

        function syncCheckoutModeState(shouldRefresh) {
            var guestMode = isGuestCheckoutMode();
            if (checkoutShell) {
                checkoutShell.setAttribute('data-weshop-checkout-mode', guestMode ? 'guest' : 'customer');
            }
            if (modeBadge) {
                modeBadge.textContent = guestMode ? '<?= __('匿名结账') ?>' : '<?= __('账户结账') ?>';
            }
            if (contactModeLabel) {
                contactModeLabel.textContent = guestMode ? '<?= __('无需账户') ?>' : '<?= __('账户邮箱') ?>';
            }
            if (contactHelp) {
                contactHelp.textContent = guestMode
                    ? (contactHelp.getAttribute('data-guest-help') || '')
                    : (contactHelp.getAttribute('data-customer-help') || '');
            }
            if (submitButton) {
                submitButton.textContent = guestMode
                    ? (submitButton.getAttribute('data-guest-label') || submitButton.textContent)
                    : (submitButton.getAttribute('data-customer-label') || submitButton.textContent);
            }
            if (savedAddressList) {
                savedAddressList.hidden = guestMode;
            }
            if (guestMode) {
                var newAddressOption = form.querySelector('input[name="shipping_address_id"][value="0"]');
                if (newAddressOption) {
                    newAddressOption.checked = true;
                }
            }

            syncAddressRequiredState();
            if (shouldRefresh !== false) {
                scheduleCheckoutMethodRefresh();
            }
        }

        function selectedSavedAddressId() {
            if (isGuestCheckoutMode()) {
                return 0;
            }

            var checked = form.querySelector('input[name="shipping_address_id"]:checked');
            if (checked) {
                return parseInt(checked.value || '0', 10) || 0;
            }

            var hidden = form.querySelector('input[type="hidden"][name="shipping_address_id"]');
            return hidden ? (parseInt(hidden.value || '0', 10) || 0) : 0;
        }

        function syncAddressRequiredState() {
            var useSavedAddress = selectedSavedAddressId() > 0;
            requiredAddressFields.forEach(function (field) {
                if (useSavedAddress) {
                    field.removeAttribute('required');
                } else {
                    field.setAttribute('required', 'required');
                }
            });
        }

        function formatSummaryAmount(value) {
            var amount = Number(value || 0);
            var currency = summaryHost ? String(summaryHost.getAttribute('data-weshop-summary-currency') || 'USD') : 'USD';

            if (window.Intl && typeof window.Intl.NumberFormat === 'function') {
                try {
                    return new Intl.NumberFormat(undefined, {
                        style: 'currency',
                        currency: currency,
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(amount);
                } catch (error) {
                    return amount.toFixed(2);
                }
            }

            return amount.toFixed(2);
        }

        function renderCartSummary(summary) {
            if (!summary) {
                return;
            }

            var normalized = {
                subtotal: Number(summary.subtotal || 0),
                shipping: Number(summary.shipping || 0),
                discount: Number(summary.discount || 0),
                tax: Number(summary.tax || 0),
                grand_total: Number(summary.grand_total || summary.total || 0)
            };

            if (summaryFields.subtotal) {
                summaryFields.subtotal.textContent = formatSummaryAmount(normalized.subtotal);
            }
            if (summaryFields.shipping) {
                summaryFields.shipping.textContent = formatSummaryAmount(normalized.shipping);
            }
            if (summaryFields.tax) {
                summaryFields.tax.textContent = formatSummaryAmount(normalized.tax);
            }
            if (summaryFields.discount) {
                summaryFields.discount.textContent = '-' + formatSummaryAmount(normalized.discount);
            }
            if (summaryFields.discountRow) {
                summaryFields.discountRow.hidden = normalized.discount <= 0;
            }
            if (summaryFields.grandTotal) {
                var grandTotalText = formatSummaryAmount(normalized.grand_total);
                summaryFields.grandTotal.textContent = grandTotalText;
                if (summaryToggleTotal) {
                    summaryToggleTotal.textContent = grandTotalText;
                }
            }
        }

        function renderMethodList(host, methods, inputName, emptyMessage) {
            if (!host) {
                return;
            }

            if (!Array.isArray(methods) || methods.length === 0) {
                host.innerHTML = '<div class="weshop-checkout-empty">' + escapeHtml(emptyMessage) + '</div>';
                return;
            }

            var html = '<div class="weshop-checkout-choice-list">';
            methods.forEach(function (method, index) {
                if (!method || !method.code) {
                    return;
                }

                var title = method.title || method.name || method.code;
                var helper = method.checkout_note || method.description || '';
                var checked = method.is_default || index === 0;
                html += '<label class="weshop-checkout-choice">'
                    + '<input type="radio" name="' + inputName + '" value="' + escapeHtml(method.code) + '"' + (checked ? ' checked' : '') + ' required>'
                    + '<span><span class="weshop-checkout-choice-title">' + escapeHtml(title) + '</span>';
                if (helper) {
                    html += '<span class="weshop-checkout-choice-meta">' + escapeHtml(helper) + '</span>';
                }
                html += '</span></label>';
            });
            html += '</div>';
            host.innerHTML = html;
        }

        function refreshCheckoutMethods() {
            return fetch(methodsUrl, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (!payload || !payload.success) {
                    showCheckoutMessage((payload && payload.message) || '暂时无法刷新结账方式。', 'error');
                    return;
                }

                var data = payload.data || {};
                renderMethodList(shippingMethodHost, data.shipping_methods || [], 'shipping_method', '当前收货地址没有可用配送方式。');
                renderMethodList(paymentMethodHost, data.payment_methods || [], 'payment_method', '当前没有可用的匿名支付方式。');
                renderCartSummary(data.cart_summary || {});
            }).catch(function (error) {
                console.error('Checkout method refresh error:', error);
                showCheckoutMessage('暂时无法刷新结账方式。', 'error');
            });
        }

        function scheduleCheckoutMethodRefresh() {
            if (refreshTimer) {
                window.clearTimeout(refreshTimer);
            }

            refreshTimer = window.setTimeout(refreshCheckoutMethods, 180);
        }

        if (summaryToggle && summaryPanel) {
            summaryToggle.addEventListener('click', function () {
                var expanded = !summaryPanel.classList.contains('is-open');
                summaryPanel.classList.toggle('is-open', expanded);
                summaryToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                if (summaryToggleLabel) {
                    summaryToggleLabel.textContent = expanded ? '<?= __('收起订单摘要') ?>' : '<?= __('查看订单摘要') ?>';
                }
            });
        }

        form.addEventListener('change', function (event) {
            var target = event.target;
            if (!target || !target.name) {
                return;
            }

            if (target.name === 'checkout_mode') {
                syncCheckoutModeState(true);
                return;
            }

            if (target.name === 'shipping_address_id') {
                if (isGuestCheckoutMode()) {
                    var newAddressOption = form.querySelector('input[name="shipping_address_id"][value="0"]');
                    if (newAddressOption) {
                        newAddressOption.checked = true;
                    }
                }
                syncAddressRequiredState();
                scheduleCheckoutMethodRefresh();
                return;
            }

            if (target.name === 'shipping_method' || target.name === 'payment_method') {
                return;
            }

            if (target.name === 'shipping_address[country_id]' || target.name === 'shipping_address[region]') {
                scheduleCheckoutMethodRefresh();
            }
        });

        addressFields.forEach(function (field) {
            field.addEventListener('input', scheduleCheckoutMethodRefresh);
        });

        form.addEventListener('submit', function (event) {
            event.preventDefault();
            showCheckoutMessage('', '');
            syncCheckoutModeState(false);

            if (!form.reportValidity()) {
                return;
            }

            if (submitButton) {
                submitButton.disabled = true;
            }

            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (!payload || !payload.success) {
                    showCheckoutMessage((payload && payload.message) || '暂时无法提交订单。', 'error');
                    return;
                }

                var data = payload.data || {};
                var redirectUrl = data.redirect_url || '';
                if (!redirectUrl && data.order_id) {
                    redirectUrl = successUrl + (successUrl.indexOf('?') === -1 ? '?' : '&') + 'order_id=' + encodeURIComponent(data.order_id);
                }
                window.location.href = redirectUrl || successUrl;
            }).catch(function (error) {
                console.error('Checkout submit error:', error);
                showCheckoutMessage('暂时无法提交订单。', 'error');
            }).finally(function () {
                if (submitButton) {
                    submitButton.disabled = false;
                }
            });
        });

        syncCheckoutModeState(false);
        renderCartSummary(initialCartSummary);
    })();
</script>

<w:hook name="Weline_Checkout::frontend::layouts::checkout::content-after"/>
