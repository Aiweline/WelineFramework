<?php
/**
 * Checkout payment method radios.
 *
 * @hook-priority 200
 * @hook-sort-order 10
 * @hook-solo false
 */
$paymentMethods = $this->getData('payment_methods') ?? [];
if (!is_array($paymentMethods) || $paymentMethods === []) {
    ?>
    <div class="weshop-checkout-empty"><?= __('No payment methods are available for the current checkout context.') ?></div>
    <?php
    return;
}

$hasExplicitDefault = false;
foreach ($paymentMethods as $paymentMethod) {
    if (is_array($paymentMethod) && !empty($paymentMethod['is_default'])) {
        $hasExplicitDefault = true;
        break;
    }
}
?>
<style>
    .weshop-checkout-payment-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: #ccfbf1;
        color: #115e59;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.2rem 0.55rem;
    }
</style>
<div class="weshop-checkout-choice-list" data-weshop-payment-method-list>
    <?php foreach ($paymentMethods as $index => $method): ?>
        <?php
        if (!is_array($method)) {
            continue;
        }
        $code = (string) ($method['code'] ?? '');
        $title = (string) ($method['title'] ?? $method['name'] ?? $code);
        $description = trim((string) ($method['description'] ?? ''));
        $checkoutNote = trim((string) ($method['checkout_note'] ?? ''));
        $badge = trim((string) ($method['badge'] ?? ''));
        $checked = !empty($method['is_default']) || (!$hasExplicitDefault && $index === 0);
        ?>
        <label class="weshop-checkout-choice">
            <input
                type="radio"
                name="payment_method"
                value="<?= htmlspecialchars($code, ENT_QUOTES) ?>"
                <?= $checked ? 'checked' : '' ?>
                required
            >
            <span style="flex: 1; min-width: 0;">
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
                    <div class="weshop-checkout-choice-title"><?= htmlspecialchars($title, ENT_QUOTES) ?></div>
                    <?php if ($badge !== ''): ?>
                        <span class="weshop-checkout-payment-badge"><?= htmlspecialchars($badge, ENT_QUOTES) ?></span>
                    <?php endif; ?>
                </div>
                <?php if ($description !== ''): ?>
                    <div class="weshop-checkout-choice-meta"><?= htmlspecialchars($description, ENT_QUOTES) ?></div>
                <?php endif; ?>
                <?php if ($checkoutNote !== ''): ?>
                    <div class="weshop-checkout-choice-meta"><?= htmlspecialchars($checkoutNote, ENT_QUOTES) ?></div>
                <?php endif; ?>
            </span>
        </label>
    <?php endforeach; ?>
</div>
