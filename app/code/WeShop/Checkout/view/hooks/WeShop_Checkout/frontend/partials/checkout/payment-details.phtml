<?php
/**
 * Checkout payment detail panels.
 *
 * @hook-priority 200
 * @hook-sort-order 20
 * @hook-solo false
 */
$paymentMethods = $this->getData('payment_methods') ?? [];
if (!is_array($paymentMethods) || $paymentMethods === []) {
    return;
}

$hasExplicitDefault = false;
foreach ($paymentMethods as $paymentMethod) {
    if (is_array($paymentMethod) && !empty($paymentMethod['is_default'])) {
        $hasExplicitDefault = true;
        break;
    }
}
?>
<style>
    .weshop-checkout-payment-details {
        display: grid;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .weshop-checkout-payment-detail {
        display: none;
        border: 1px solid #dbe2ea;
        border-radius: 0.95rem;
        background: #f8fafc;
        padding: 1rem 1.1rem;
    }

    .weshop-checkout-payment-detail.is-active {
        display: block;
    }

    .weshop-checkout-payment-detail-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
    }

    .weshop-checkout-payment-detail-meta {
        margin-top: 0.5rem;
        font-size: 0.875rem;
        line-height: 1.6;
        color: #475569;
    }
</style>
<div class="weshop-checkout-payment-details" data-weshop-payment-detail-list>
    <?php foreach ($paymentMethods as $index => $method): ?>
        <?php
        if (!is_array($method)) {
            continue;
        }
        $code = (string) ($method['code'] ?? '');
        $title = (string) ($method['title'] ?? $method['name'] ?? $code);
        $flowLabel = trim((string) ($method['flow_label'] ?? ''));
        $checkoutNote = trim((string) ($method['checkout_note'] ?? ''));
        $description = trim((string) ($method['description'] ?? ''));
        $checked = !empty($method['is_default']) || (!$hasExplicitDefault && $index === 0);
        ?>
        <article
            class="weshop-checkout-payment-detail<?= $checked ? ' is-active' : '' ?>"
            data-weshop-payment-detail="<?= htmlspecialchars($code, ENT_QUOTES) ?>"
        >
            <div class="weshop-checkout-payment-detail-title"><?= htmlspecialchars($title, ENT_QUOTES) ?></div>
            <?php if ($flowLabel !== ''): ?>
                <div class="weshop-checkout-payment-detail-meta"><?= __('Payment flow: %{1}', $flowLabel) ?></div>
            <?php endif; ?>
            <?php if ($checkoutNote !== ''): ?>
                <div class="weshop-checkout-payment-detail-meta"><?= htmlspecialchars($checkoutNote, ENT_QUOTES) ?></div>
            <?php elseif ($description !== ''): ?>
                <div class="weshop-checkout-payment-detail-meta"><?= htmlspecialchars($description, ENT_QUOTES) ?></div>
            <?php endif; ?>
        </article>
    <?php endforeach; ?>
</div>
<script>
    (function () {
        function bindPaymentDetails(container) {
            var form = container.closest('form') || document;
            var radios = form.querySelectorAll('input[name="payment_method"]');

            function sync() {
                var checked = form.querySelector('input[name="payment_method"]:checked');
                var selectedCode = checked ? checked.value : '';

                container.querySelectorAll('[data-weshop-payment-detail]').forEach(function (panel) {
                    var isActive = panel.getAttribute('data-weshop-payment-detail') === selectedCode;
                    panel.classList.toggle('is-active', isActive);
                });
            }

            radios.forEach(function (radio) {
                radio.addEventListener('change', sync);
            });

            sync();
        }

        document.querySelectorAll('[data-weshop-payment-detail-list]').forEach(bindPaymentDetails);
    })();
</script>
