<?php
/**
 * Checkout layout payment section for theme layout variants.
 *
 * @hook-priority 200
 * @hook-sort-order 10
 * @hook-solo false
 */
$paymentMethods = $this->getData('payment_methods') ?? [];
$paymentMethods = is_array($paymentMethods) ? $paymentMethods : [];
$hasExplicitDefault = false;
foreach ($paymentMethods as $paymentMethod) {
    if (is_array($paymentMethod) && !empty($paymentMethod['is_default'])) {
        $hasExplicitDefault = true;
        break;
    }
}
?>
<style>
    .weshop-checkout-layout-payment-list {
        display: grid;
        gap: 0.875rem;
    }

    .weshop-checkout-layout-payment-option {
        border: 1px solid var(--weshop-border);
        border-radius: 1rem;
        background: var(--weshop-background);
        padding: 1rem;
    }

    .weshop-checkout-layout-payment-option input {
        margin-right: 0.75rem;
        margin-top: 0.2rem;
    }

    .weshop-checkout-layout-payment-option-head {
