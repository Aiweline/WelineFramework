        font-weight: var(--weshop-font-weight-bold);
        padding: 0.2rem 0.55rem;
    }

    .weshop-checkout-layout-payment-text {
        margin-top: 0.45rem;
        font-size: var(--weshop-font-size-sm);
        line-height: 1.6;
        color: var(--weshop-text-secondary);
