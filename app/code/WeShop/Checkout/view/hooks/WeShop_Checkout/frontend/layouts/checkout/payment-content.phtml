        padding: 1rem;
    }

    .weshop-checkout-layout-payment-guide.is-active {
        display: block;
    }
</style>
<div class="weshop-checkout-section">
    <div class="weshop-checkout-section-header">
        <h3 class="weshop-checkout-section-title"><?= __('2. Payment Method') ?></h3>
    </div>
    <div class="weshop-checkout-section-content">
        <?php if ($paymentMethods === []): ?>
            <div class="weshop-checkout-section-info">
                <span class="material-symbols-outlined" style="font-size: var(--weshop-font-size-base);">payments</span>
                <p><?= __('No payment methods are available for the current checkout context.') ?></p>
            </div>
        <?php else: ?>
            <div class="weshop-checkout-layout-payment-list" data-weshop-layout-payment-list>
                <?php foreach ($paymentMethods as $index => $method): ?>
                    <?php
                    if (!is_array($method)) {
                        continue;
                    }
                    $code = (string) ($method['code'] ?? '');
                    $title = (string) ($method['title'] ?? $method['name'] ?? $code);
                    $badge = trim((string) ($method['badge'] ?? ''));
                    $description = trim((string) ($method['description'] ?? ''));
                    $checkoutNote = trim((string) ($method['checkout_note'] ?? ''));
                    $flowLabel = trim((string) ($method['flow_label'] ?? ''));
                    $checked = !empty($method['is_default']) || (!$hasExplicitDefault && $index === 0);
                    ?>
                    <label class="weshop-checkout-layout-payment-option">
                        <div style="display: flex; align-items: flex-start;">
                            <input
                                type="radio"
                                name="payment_method"
                                value="<?= htmlspecialchars($code, ENT_QUOTES) ?>"
                                <?= $checked ? 'checked' : '' ?>
                            >
                            <span style="flex: 1; min-width: 0;">
                                <span class="weshop-checkout-layout-payment-option-head">
                                    <span><?= htmlspecialchars($title, ENT_QUOTES) ?></span>
                                    <?php if ($badge !== ''): ?>
                                        <span class="weshop-checkout-layout-payment-badge"><?= htmlspecialchars($badge, ENT_QUOTES) ?></span>
                                    <?php endif; ?>
                                </span>
                                <?php if ($description !== ''): ?>
                                    <div class="weshop-checkout-layout-payment-text"><?= htmlspecialchars($description, ENT_QUOTES) ?></div>
                                <?php endif; ?>
                                <?php if ($checkoutNote !== ''): ?>
                                    <div class="weshop-checkout-layout-payment-text"><?= htmlspecialchars($checkoutNote, ENT_QUOTES) ?></div>
                                <?php endif; ?>
                                <?php if ($flowLabel !== ''): ?>
                                    <div class="weshop-checkout-layout-payment-text"><?= __('Payment flow: %{1}', $flowLabel) ?></div>
                                <?php endif; ?>
                            </span>
                        </div>
                    </label>
                <?php endforeach; ?>
            </div>
            <div class="weshop-checkout-layout-payment-guidance" data-weshop-layout-payment-guidance>
                <?php foreach ($paymentMethods as $index => $method): ?>
                    <?php
                    if (!is_array($method)) {
                        continue;
                    }
                    $code = (string) ($method['code'] ?? '');
                    $title = (string) ($method['title'] ?? $method['name'] ?? $code);
                    $checkoutNote = trim((string) ($method['checkout_note'] ?? ''));
                    $checked = !empty($method['is_default']) || (!$hasExplicitDefault && $index === 0);
                    ?>
                    <div
                        class="weshop-checkout-layout-payment-guide<?= $checked ? ' is-active' : '' ?>"
                        data-weshop-layout-payment-guide="<?= htmlspecialchars($code, ENT_QUOTES) ?>"
                    >
                        <strong><?= htmlspecialchars($title, ENT_QUOTES) ?></strong>
                        <div class="weshop-checkout-layout-payment-text">
                            <?= htmlspecialchars($checkoutNote !== '' ? $checkoutNote : (string) __('Complete this payment flow after confirming the order.'), ENT_QUOTES) ?>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </div>
</div>
<script>
    (function () {
        function bindLayoutPayment(container) {
            var scope = container.parentElement || document;
            var radios = scope.querySelectorAll('input[name="payment_method"]');
            var guides = scope.querySelectorAll('[data-weshop-layout-payment-guide]');

            function sync() {
                var checked = scope.querySelector('input[name="payment_method"]:checked');
                var selectedCode = checked ? checked.value : '';

                guides.forEach(function (guide) {
                    var isActive = guide.getAttribute('data-weshop-layout-payment-guide') === selectedCode;
                    guide.classList.toggle('is-active', isActive);
                });
            }

            radios.forEach(function (radio) {
                radio.addEventListener('change', sync);
            });

            sync();
        }

        document.querySelectorAll('[data-weshop-layout-payment-guidance]').forEach(bindLayoutPayment);
    })();
</script>
