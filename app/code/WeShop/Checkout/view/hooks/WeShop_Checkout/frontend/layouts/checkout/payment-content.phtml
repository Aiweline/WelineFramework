        gap: 0.5rem;
        font-weight: var(--weshop-font-weight-semibold);
        color: var(--weshop-text-primary);
    }

    .weshop-checkout-layout-payment-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: rgba(var(--weshop-primary-rgb), 0.12);
        color: var(--weshop-primary);
