<!-- 客户列表区域 -->
<div class='row'>
    <div class='col-12'>
        <div class='card'>
            <div class='card-body'>
                <h4 class='card-title'>
                    <lang>客户列表</lang>
                </h4>
                <p class='card-title-desc'>
                    <lang>管理店铺客户信息</lang>
                </p>
                <div class='table-rep-plugin'>
                    <!-- search form -->
                    <div class='row align-items-center'>
                        <div class='col-3'>
                            <block class='Weline\Component\Block\Form\Search'
                                   id='entity-customer-search' action='*/backend/customer' method='get'
                                   keyword='search' value=''
                                   placeholder='@lang{请输入客户名称或邮箱回车搜索}'></block>
                        </div>
                        <div class='col-9'>
                            <block class='Weline\Component\Block\OffCanvas'
                                   template='Weline_Component::off-canvas.phtml'
                                   cache='0'
                                   id='offcanvasRightCustomerForm'
                                   action="*/backend/customer/add"
                                   submit-button-text='<lang>保存</lang>'
                                   flush='1'
                                   target-button-text='<lang>新增客户</lang>'
                                   target-button-class='btn btn-primary'
                                   title='<lang>新增客户</lang>'
                                   save="1"
                                   close-button-show='1'
                                   close-button-text='<lang>关闭</lang>'
                                   direction='right'
                                   class-names='w-75'
                                   off-canvas-body-style=''/>
                        </div>
                    </div>
                    <!-- end search form -->
                    <div class='table-responsive mb-0' data-pattern='priority-columns'>
                        <table id='tech-companies-1' class='table table-striped table-bordered'>
                            <thead>
                            <tr>
                                <th data-priority='3'>
                                    <lang>ID</lang>
                                </th>
                                <th data-priority='3'>
                                    <lang>头像</lang>
                                </th>
                                <th data-priority='1'>
                                    <lang>姓名</lang>
                                </th>
                                <th data-priority='3'>
                                    <lang>邮箱</lang>
                                </th>
                                <th data-priority='3'>
                                    <lang>电话</lang>
                                </th>
                                <th data-priority='3'>
                                    <lang>状态</lang>
                                </th>
                                <th data-priority='3'>
                                    <lang>注册时间</lang>
                                </th>
                                <th data-priority='1'>
                                    <lang>操作</lang>
                                </th>
                            </tr>
                            </thead>
                            <tbody>
                            <foreach name="customers" item="customer" key="key">
                                <tr>
                                    <td>{{customer.customer_id}}</td>
                                    <td>
                                        <if condition="customer.avatar">
                                            <img src="{{customer.avatar}}" alt="" class="rounded-circle avatar-sm">
                                        <else/>
                                            <div class="avatar-sm rounded-circle bg-primary bg-soft">
                                                <span class="avatar-title bg-primary rounded-circle text-white font-size-12">
                                                    {{customer.firstname|substring=0,1|customer.lastname|substring=0,1}}
                                                </span>
                                            </div>
                                        </if>
                                    </td>
                                    <td>
                                        <a href="@backend-url('*/backend/customer/view')?id={{customer.customer_id}}" class="text-body text-decoration-none">
                                            {{customer.firstname}} {{customer.lastname}}
                                        </a>
                                    </td>
                                    <td>{{customer.email}}</td>
                                    <td>{{customer.phone|default:'--'}}</td>
                                    <td>
                                        <if condition="customer.is_active">
                                            <span class="badge bg-success"><lang>活跃</lang></span>
                                        <else/>
                                            <span class="badge bg-secondary"><lang>禁用</lang></span>
                                        </if>
                                    </td>
                                    <td>{{customer.created_at}}</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="@backend-url('*/backend/customer/view')?id={{customer.customer_id}}"
                                               class="btn btn-outline-primary btn-sm"
                                               title="<lang>查看详情</lang>">
                                                <i class="mdi mdi-eye-outline"></i>
                                            </a>
                                            <block class='Weline\Component\Block\OffCanvas'
                                                   template='Weline_Component::off-canvas.phtml'
                                                   target-tag='button'
                                                   target-button-class="btn btn-outline-info btn-sm"
                                                   cache='0' id='off_canvas_customer_edit'
                                                   action="*/backend/customer/edit"
                                                   action-params="{customer_id: customer.customer_id}"
                                                   submit-button-text='<lang>保存</lang>' target-button-text='<i class="mdi mdi-pencil-outline"></i>'
                                                   title='<lang>编辑客户</lang>' close-button-show='1'
                                                   save="1"
                                                   close-button-text='<lang>关闭</lang>' direction='right'
                                                   class-names='w-75' off-canvas-body-style=''/>
                                            <if condition="customer.is_active">
                                                <button class="btn btn-outline-warning btn-sm"
                                                        w-ajax="@backend-url('*/backend/customer/disable')"
                                                        w-method="post"
                                                        w-data='{"customer_id":"{{customer.customer_id}}"}'
                                                        w-msg="<lang>你确定要禁用该客户么？</lang>"
                                                        title="<lang>禁用</lang>">
                                                    <i class="mdi mdi-account-off-outline"></i>
                                                </button>
                                            <else/>
                                                <button class="btn btn-outline-success btn-sm"
                                                        w-ajax="@backend-url('*/backend/customer/enable')"
                                                        w-method="post"
                                                        w-data='{"customer_id":"{{customer.customer_id}}"}'
                                                        w-msg="<lang>你确定要启用该客户么？</lang>"
                                                        title="<lang>启用</lang>">
                                                    <i class="mdi mdi-account-check-outline"></i>
                                                </button>
                                            </if>
                                            <button class="btn btn-outline-danger btn-sm"
                                                    w-ajax="@backend-url('*/backend/customer/delete')"
                                                    w-method="post"
                                                    w-data='{"customer_id":"{{customer.customer_id}}"}'
                                                    w-delete="true"
                                                    w-msg="<lang>你确定要删除该客户么？此操作不可恢复！</lang>"
                                                    title="<lang>删除</lang>">
                                                <i class="mdi mdi-trash-can-outline"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </foreach>
                            </tbody>
                        </table>
                        {{pagination}}
                    </div>
                </div>
            </div>
        </div>
    </div> <!-- end col -->
</div> <!-- end row -->

<js:part name="w-delete"/>
