       id="header-account-link">
        <span class="action-line-1">
            <?= __('您好, %1', $customer->getUsername() ?? __('用户')) ?>
            <!-- 未支付订单消息红点（异步加载） -->
            <span class="unpaid-orders-badge" id="unpaid-orders-badge" style="display: none;">
                <span class="badge-count" id="badge-count">0</span>
            </span>
        </span>
        <span class="action-line-2"><?= __('我的账户') ?></span>
    </a>
    
    <!-- 账户下拉菜单 -->
