                <span class="unpaid-orders-indicator" id="unpaid-orders-indicator" style="display: none;">
                    <span class="indicator-count" id="indicator-count">0</span>
                </span>
            </a>
            <a href="<?= $frontendUrl ?>weshop/wishlist" class="dropdown-item">
                <span class="material-symbols-outlined">favorite</span>
                <?= __('我的收藏') ?>
            </a>
            <div class="dropdown-divider"></div>
            <a href="<?= $frontendUrl ?>weshop/customer/account/logout" class="dropdown-item">
                <span class="material-symbols-outlined">logout</span>
                <?= __('退出登录') ?>
            </a>
        </div>
        
        <!-- 未支付订单列表（异步加载） -->
        <div class="unpaid-orders-section" id="unpaid-orders-section" style="display: none;">
            <div class="unpaid-orders-header">
                <strong><?= __('待支付订单') ?></strong>
            </div>
            <div class="unpaid-orders-list" id="unpaid-orders-list">
                <!-- 订单列表将通过JavaScript异步加载 -->
            </div>
            <div class="unpaid-orders-footer">
                <a href="<?= $frontendUrl ?>weshop/order/list" class="view-all-orders-link">
                    <?= __('查看全部订单') ?>
                </a>
            </div>
        </div>
    </div>
    
    <script>
        (function() {
            // 异步加载未支付订单数量
            function loadUnpaidOrdersCount() {
                fetch('<?= $frontendUrl ?>api/rest/v1/weshop_order/order/unpaid-count')
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 200 && data.data.count > 0) {
                            const count = data.data.count;
                            
                            // 显示消息红点
                            const badge = document.getElementById('unpaid-orders-badge');
                            const badgeCount = document.getElementById('badge-count');
                            const indicator = document.getElementById('unpaid-orders-indicator');
                            const indicatorCount = document.getElementById('indicator-count');
                            
                            if (badge && badgeCount) {
                                badgeCount.textContent = count > 99 ? '99+' : count;
                                badge.style.display = 'inline-block';
                            }
                            
                            if (indicator && indicatorCount) {
                                indicatorCount.textContent = count > 99 ? '99+' : count;
                                indicator.style.display = 'inline-block';
                            }
                            
                            // 加载未支付订单列表
                            loadUnpaidOrdersList();
                        }
                    })
                    .catch(error => {
                        console.error('加载未支付订单数量失败:', error);
                    });
            }
            
            // 异步加载未支付订单列表
            function loadUnpaidOrdersList() {
                fetch('<?= $frontendUrl ?>api/rest/v1/weshop_order/order/unpaid-list')
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 200 && data.data.orders.length > 0) {
                            const orders = data.data.orders;
                            const listContainer = document.getElementById('unpaid-orders-list');
                            const section = document.getElementById('unpaid-orders-section');
                            
                            if (listContainer && section) {
                                // 清空现有内容
                                listContainer.innerHTML = '';
                                
                                // 显示最多3条订单
                                const displayOrders = orders.slice(0, 3);
                                
                                displayOrders.forEach(order => {
                                    const orderItem = document.createElement('div');
                                    orderItem.className = 'unpaid-order-item';
                                    orderItem.innerHTML = `
                                        <div class="order-item-info">
                                            <span class="order-item-number">${order.increment_id}</span>
                                            <span class="order-item-amount"><?= __('金额：') ?>${formatPrice(order.total)}</span>
                                        </div>
                                        <a href="<?= $frontendUrl ?>weshop/order/retryPayment?order_id=${order.order_id}" class="retry-payment-link">
                                            <?= __('继续支付') ?>
                                        </a>
                                    `;
                                    listContainer.appendChild(orderItem);
                                });
                                
                                // 显示未支付订单区域
                                section.style.display = 'block';
                            }
                        }
                    })
                    .catch(error => {
                        console.error('加载未支付订单列表失败:', error);
                    });
            }
            
            // 格式化价格
            function formatPrice(price) {
                return new Intl.NumberFormat('zh-CN', {
                    style: 'currency',
                    currency: 'CNY'
                }).format(price);
            }
            
            // 页面加载完成后执行
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadUnpaidOrdersCount);
            } else {
                loadUnpaidOrdersCount();
            }
            
            // 定期刷新（每30秒）
            setInterval(loadUnpaidOrdersCount, 30000);
        })();
    </script>
    
