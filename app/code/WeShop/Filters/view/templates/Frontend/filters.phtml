<?php
/**
 * 筛选主模板
 * 
 * 此模板渲染完整的筛选侧边栏
 * 
 * 可用变量:
 * - $filters: 筛选组数据数组
 * - $appliedFilters: 已应用的筛选条件
 * - $categoryId: 当前分类ID
 * - $clearAllUrl: 清除所有筛选的URL
 */

/** @var \Weline\Framework\View\Template $this */
/** @var array $filters */
/** @var array $appliedFilters */
/** @var int $categoryId */
/** @var string $clearAllUrl */

$filters = $this->getData('filters') ?? [];
$appliedFilters = $this->getData('applied_filters') ?? [];
$categoryId = $this->getData('category_id') ?? 0;
$clearAllUrl = $this->getData('clear_all_url') ?? '';

if (empty($filters) && empty($appliedFilters)) {
    return;
}
?>

<div class="category-filter-mock" data-category-id="<?= $categoryId ?>">
    <!-- 筛选头部 Hook -->
    <?= $this->getHook('WeShop_Filters::frontend::partials::filters::header') ?>
    
    <?php if (empty($this->getHook('WeShop_Filters::frontend::partials::filters::header'))): ?>
    <div class="category-filter-header">
        <div class="category-filter-title"><lang>筛选条件</lang></div>
        <?php if (!empty($appliedFilters)): ?>
        <a href="<?= htmlspecialchars($clearAllUrl) ?>" class="category-filter-clear"><lang>清除全部</lang></a>
        <?php endif; ?>
    </div>
    <?php endif; ?>

    <!-- 已选条件 Hook -->
    <?= $this->getHook('WeShop_Filters::frontend::partials::filters::applied') ?>
    
    <?php if (empty($this->getHook('WeShop_Filters::frontend::partials::filters::applied')) && !empty($appliedFilters)): ?>
    <div class="category-filter-applied">
        <?php foreach ($appliedFilters as $filter): ?>
        <span class="filter-chip is-active" data-filter-code="<?= htmlspecialchars($filter['filter_code']) ?>" data-value="<?= htmlspecialchars($filter['value']) ?>">
            <?= htmlspecialchars($filter['label']) ?>
            <button type="button" class="chip-remove" aria-label="<lang>移除</lang>">×</button>
        </span>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>

    <!-- 筛选组 -->
    <?php foreach ($filters as $filter): ?>
    <?php
        $filterCode = $filter['code'] ?? '';
        $filterName = $filter['name'] ?? '';
        $displayType = $filter['display_type'] ?? 'list';
        $collapsed = $filter['collapsed'] ?? false;
        $options = $filter['options'] ?? [];
        
        if (empty($options)) {
            continue;
        }
        
        // 尝试使用特定的 Hook
        $hookName = 'WeShop_Filters::frontend::partials::filters::' . $filterCode;
        $hookContent = $this->getHook($hookName);
    ?>
    
    <?php if (!empty($hookContent)): ?>
        <?= $hookContent ?>
    <?php else: ?>
    <div class="category-filter-group <?= $collapsed ? 'is-collapsed' : '' ?>" data-filter-code="<?= htmlspecialchars($filterCode) ?>">
        <div class="category-filter-group-title"><?= htmlspecialchars($filterName) ?></div>
        
        <?php if ($displayType === 'slider' && isset($options[0]['slider'])): ?>
            <!-- 滑块模式 -->
            <?php $slider = $options[0]['slider']; ?>
            <div class="price-slider-container">
                <div class="price-slider-wrapper">
                    <div class="price-slider-track"></div>
                    <div class="price-slider-range"></div>
                    <input type="range" class="price-slider-min" 
                           min="<?= $slider['min'] ?>" 
                           max="<?= $slider['max'] ?>" 
                           value="<?= $slider['current_min'] ?>"
                           step="<?= $slider['step'] ?>">
                    <input type="range" class="price-slider-max" 
                           min="<?= $slider['min'] ?>" 
                           max="<?= $slider['max'] ?>" 
                           value="<?= $slider['current_max'] ?>"
                           step="<?= $slider['step'] ?>">
                </div>
                <div class="price-slider-labels">
                    <span><?= $slider['currency'] ?><span class="price-min-display"><?= $slider['current_min'] ?></span></span>
                    <span><?= $slider['currency'] ?><span class="price-max-display"><?= $slider['current_max'] ?></span></span>
                </div>
            </div>
        
        <?php elseif ($displayType === 'swatch'): ?>
            <!-- 色块模式 -->
            <ul class="category-filter-list swatch-list">
                <?php foreach ($options as $option): ?>
                <li>
                    <a href="javascript:void(0)" 
                       class="category-filter-item <?= $option['selected'] ? 'is-active' : '' ?>"
                       data-value="<?= htmlspecialchars($option['value']) ?>"
                       title="<?= htmlspecialchars($option['label']) ?>">
                        <?php if (isset($option['swatch'])): ?>
                            <?php if ($option['swatch']['type'] === 'color'): ?>
                            <span class="filter-swatch <?= $option['selected'] ? 'is-selected' : '' ?>" 
                                  style="background-color: <?= htmlspecialchars($option['swatch']['value']) ?>"></span>
                            <?php elseif ($option['swatch']['type'] === 'image'): ?>
                            <img class="filter-swatch <?= $option['selected'] ? 'is-selected' : '' ?>" 
                                 src="<?= htmlspecialchars($option['swatch']['value']) ?>" 
                                 alt="<?= htmlspecialchars($option['label']) ?>">
                            <?php else: ?>
                            <span class="filter-swatch <?= $option['selected'] ? 'is-selected' : '' ?>"><?= htmlspecialchars($option['swatch']['value']) ?></span>
                            <?php endif; ?>
                        <?php else: ?>
                            <span class="label"><?= htmlspecialchars($option['label']) ?></span>
                        <?php endif; ?>
                    </a>
                </li>
                <?php endforeach; ?>
            </ul>
        
        <?php else: ?>
            <!-- 列表模式 -->
            <ul class="category-filter-list">
                <?php foreach ($options as $option): ?>
                <li>
                    <a href="javascript:void(0)" 
                       class="category-filter-item <?= $option['selected'] ? 'is-active' : '' ?>"
                       data-value="<?= htmlspecialchars($option['value']) ?>">
                        <span class="label">
                            <?php if (isset($option['stars_filled'])): ?>
                            <span class="stars"><?= str_repeat('★', $option['stars_filled']) . str_repeat('☆', $option['stars_empty']) ?></span>
                            <lang>及以上</lang>
                            <?php else: ?>
                            <?= htmlspecialchars($option['label']) ?>
                            <?php endif; ?>
                        </span>
                        <span class="count"><?= $option['count'] ?></span>
                    </a>
                </li>
                <?php endforeach; ?>
            </ul>
        <?php endif; ?>
    </div>
    <?php endif; ?>
    <?php endforeach; ?>
    
    <!-- 筛选底部 Hook -->
    <?= $this->getHook('WeShop_Filters::frontend::partials::filters::footer') ?>
</div>

<!-- 移动端遮罩 -->
<div class="filter-mobile-overlay"></div>

<script>
// 初始化筛选控制器
document.addEventListener('DOMContentLoaded', function() {
    if (window.WeShopFilters) {
        window.weShopFilterController = WeShopFilters.init({
            categoryId: <?= (int)$categoryId ?>,
            filterContainer: '.category-filter-mock',
            enableAjax: true,
            updateUrl: true
        });
    }
});
</script>
