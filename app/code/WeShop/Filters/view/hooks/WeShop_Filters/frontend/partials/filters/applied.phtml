<?php
/**
 * 已选筛选条件 Hook 默认实现
 * 
 * @hook-priority 100
 * @hook-sort-order 1
 * @hook-solo false
 */

/** @var \Weline\Framework\View\Template $this */

$appliedFilters = $this->getData('applied_filters') ?? [];

if (empty($appliedFilters)) {
    return;
}
?>

<div class="category-filter-applied">
    <?php foreach ($appliedFilters as $filter): ?>
    <span class="filter-chip is-active" 
          data-filter-code="<?= htmlspecialchars($filter['filter_code'] ?? '') ?>" 
          data-value="<?= htmlspecialchars($filter['value'] ?? '') ?>">
        <?= htmlspecialchars($filter['label'] ?? $filter['value'] ?? '') ?>
        <button type="button" class="chip-remove" aria-label="<lang>移除</lang>">×</button>
    </span>
    <?php endforeach; ?>
</div>
