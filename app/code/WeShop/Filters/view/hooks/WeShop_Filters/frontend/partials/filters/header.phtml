<?php
/**
 * 筛选头部 Hook 默认实现
 * 
 * @hook-priority 100
 * @hook-sort-order 1
 * @hook-solo false
 */

/** @var \Weline\Framework\View\Template $this */

$appliedFilters = $this->getData('applied_filters') ?? [];
$clearAllUrl = $this->getData('clear_all_url') ?? '';
$hasFilters = !empty($appliedFilters);
?>

<div class="category-filter-header">
    <div class="category-filter-title"><lang>筛选条件</lang></div>
    <?php if ($hasFilters): ?>
    <a href="<?= htmlspecialchars($clearAllUrl) ?>" class="category-filter-clear"><lang>清除全部</lang></a>
    <?php endif; ?>
</div>
