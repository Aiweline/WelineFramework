<?xml version="1.0"?>
<!--
 * WeShop_Filters 模块事件配置
 * 
 * 本文件定义了筛选模块的事件观察者
-->
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- 分类页面加载后收集筛选器 -->
    <event name="WeShop_Catalog::category_load_after">
        <observer name="WeShop_Filters::collect_filters" 
                  instance="WeShop\Filters\Observer\CollectFiltersObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="100"/>
    </event>
    
    <!-- 产品保存后清除筛选缓存 -->
    <event name="WeShop_Product::product_save_after">
        <observer name="WeShop_Filters::clear_filter_cache" 
                  instance="WeShop\Filters\Observer\ClearFilterCacheObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="200"/>
    </event>
    
    <!-- 分类保存后清除筛选缓存 -->
    <event name="WeShop_Catalog::category_save_after">
        <observer name="WeShop_Filters::clear_category_filter_cache" 
                  instance="WeShop\Filters\Observer\ClearFilterCacheObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="200"/>
    </event>
    
</config>
