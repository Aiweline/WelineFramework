<?php
/**
 * WeShop Base模块 - 全局货币配置注入
 *
 * 在所有前台页面的 <head> 中注入货币配置和 JS 侧格式化函数，
 * 确保前端 JS 代码使用与 PHP CurrencyFormatter 一致的货币格式。
 *
 * Hook名称：Weline_Theme::frontend::layouts::base::head-after
 *
 * @hook-priority 10       高优先级，确保在其他 JS 之前加载
 * @hook-sort-order 0      最先执行
 * @hook-solo false        Hook独享：false（不独占）
 */

/** @var \Weline\Framework\View\Template $this */
use Weline\Currency\Service\CurrencyRateService;

$currencyRateService = $this->getData('currency_rate_service');
if (!$currencyRateService || !method_exists($currencyRateService, 'getCurrencyDefinition')) {
    // 尝试从 ObjectManager 获取
    try {
        $currencyRateService = \Weline\Framework\Manager\ObjectManager::getInstance(CurrencyRateService::class);
    } catch (\Throwable $e) {
        $currencyRateService = null;
    }
}

$currentCurrencyCode = 'CNY';
$currencyDefinition = [];
$baseCurrency = 'CNY';
$currentRate = 1.0;

if ($currencyRateService) {
    try {
        $currentCurrencyCode = $currencyRateService->getCurrentCurrency();
        $currencyDefinition = $currencyRateService->getCurrencyDefinition($currentCurrencyCode);
        $baseCurrency = $currencyRateService->getBaseCurrency();
        $currentRate = (float) ($currencyRateService->getCurrentRate() ?: 1.0);
    } catch (\Throwable $e) {
        // 降级使用默认 CNY 配置
        $currencyDefinition = [
            'code' => 'CNY',
            'symbol' => '¥',
            'icon' => '¥',
            'position' => 'left',
            'format' => '2,0',
            'thousand_separator' => ',',
            'decimal_separator' => '.',
        ];
    }
}
?>
<script>
// 全局货币配置 - 供前端 JS 使用
window.__currencyConfig = {
    currentCurrency: <?= json_encode($currentCurrencyCode, JSON_UNESCAPED_UNICODE) ?>,
    baseCurrency: <?= json_encode($baseCurrency, JSON_UNESCAPED_UNICODE) ?>,
    factor: <?= json_encode($currentRate, JSON_UNESCAPED_UNICODE) ?>,
    currencyDefinition: <?= json_encode($currencyDefinition, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>
};

/**
 * 全局货币格式化函数 - 与 PHP CurrencyFormatter::formatConverted 保持一致
 * 任何前端 JS 文件都应使用此函数格式化货币金额，禁止硬编码符号 + toFixed(2)
 *
 * @param {number|string} amount - 基础货币金额（将自动乘以汇率）
 * @param {boolean} skipConversion - 是否跳过汇率转换（默认 false）
 * @returns {string} 格式化后的货币字符串
 */
window.formatConvertedCurrency = function(amount, skipConversion) {
    var config = window.__currencyConfig || {};
    var definition = config.currencyDefinition || {};
    var formatParts = String(definition.format || '2,0').split(',');
    var decimals = parseInt(formatParts[0], 10);
    if (!Number.isFinite(decimals)) {
        decimals = 2;
    }

    var thousandSeparator = typeof definition.thousand_separator === 'string' && definition.thousand_separator !== ''
        ? definition.thousand_separator
        : ',';
    var decimalSeparator = typeof definition.decimal_separator === 'string' && definition.decimal_separator !== ''
        ? definition.decimal_separator
        : '.';
    var icon = definition.icon || definition.symbol || config.currentCurrency || '';
    var position = String(definition.position || 'left').toLowerCase();
    var normalizedAmount = Number(amount);

    if (!Number.isFinite(normalizedAmount)) {
        normalizedAmount = 0;
    }

    // 汇率转换
    if (!skipConversion && config.currentCurrency !== config.baseCurrency) {
        var factor = Number(config.factor);
        if (Number.isFinite(factor) && factor > 0) {
            normalizedAmount = normalizedAmount * factor;
        }
    }

    var parts = normalizedAmount.toFixed(decimals).split('.');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousandSeparator);
    var formatted = parts.length > 1 ? parts[0] + decimalSeparator + parts[1] : parts[0];

    if (!icon) {
        return formatted;
    }

    return position === 'right' ? formatted + icon : icon + formatted;
};
</script>
