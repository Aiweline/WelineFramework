<?php
/**
 * Hook: account.sidebar
 *
 * @hook-priority 185
 * @hook-sort-order 18
 * @hook-solo false
 */

use WeShop\Customer\Api\CustomerContextInterface;
use WeShop\Notification\Service\NotificationPageDataService;
use Weline\Framework\Manager\ObjectManager;

$accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
if (!is_string($accountIndexPath) || $accountIndexPath === '') {
    $accountIndexPath = '/customer/account/index';
}
$accountIndexPath = rtrim($accountIndexPath, '/');
$customerContext = ObjectManager::getInstance(CustomerContextInterface::class);
$notificationPageDataService = ObjectManager::getInstance(NotificationPageDataService::class);
$customerId = (int) ($customerContext->getUserId() ?? 0);
$notificationData = $customerId > 0 ? $notificationPageDataService->build($customerId) : [];
$unreadCount = (int) ($notificationData['notification_unread_count'] ?? 0);
?>
<a class="account-hook-nav-link" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#notification-preferences" data-section="notification-preferences" data-account-nav-link="true">
    <span class="account-hook-nav-link__label">
        <i class="ri-notification-3-line" aria-hidden="true"></i>
        <span class="account-hook-nav-link__text">
            <strong><?= __('通知设置') ?></strong>
            <span><?= __('管理订单、支付与售后消息提醒') ?></span>
        </span>
    </span>
    <?php if ($unreadCount > 0): ?>
        <span class="account-hook-nav-link__badge" data-notification-unread-badge data-notification-unread-count><?= $unreadCount > 99 ? '99+' : $unreadCount ?></span>
    <?php endif; ?>
    <span class="account-hook-nav-link__arrow" aria-hidden="true">
        <i class="fa fa-angle-right"></i>
    </span>
</a>
