<script>
    (function () {
        var notificationApiPromise = null;

        function getNotificationApi() {
            if (!notificationApiPromise) {
                notificationApiPromise = window.Weline && window.Weline.Api
                    ? Promise.resolve(window.Weline.Api.resource('notification'))
                    : Promise.reject(new Error('Weline.Api is unavailable.'));
            }

            return notificationApiPromise;
        }

        function updateUnreadCount(nextCount) {
            var normalizedCount = Math.max(0, nextCount || 0);
            var displayCount = normalizedCount > 99 ? '99+' : String(normalizedCount);

            document.querySelectorAll('[data-notification-unread-count]').forEach(function (element) {
                element.textContent = displayCount;
            });

            document.querySelectorAll('[data-notification-unread-badge]').forEach(function (badge) {
                badge.hidden = normalizedCount <= 0;
                if (badge.style) {
                    badge.style.display = normalizedCount > 0 ? '' : 'none';
                }
            });
        }

        document.querySelectorAll('[data-notification-mark-read]').forEach(function (button) {
            button.addEventListener('click', function () {
                var notificationId = parseInt(button.getAttribute('data-notification-mark-read') || '0', 10);
                if (!notificationId) {
                    return;
                }

                button.disabled = true;
                getNotificationApi()
                    .then(function (NotificationApi) {
                        return NotificationApi.markRead({ notification_id: notificationId }, { silent: true });
                    })
                    .then(function (payload) {
                        if (!payload || !payload.success) {
                            button.disabled = false;
                            return;
                        }

                        if (payload.data && typeof payload.data.unread_count !== 'undefined') {
                            updateUnreadCount(parseInt(payload.data.unread_count, 10));
                        }

                        var item = button.closest('[data-notification-item]');
                        if (item) {
                            item.setAttribute('data-notification-read', '1');
                        }
                        button.remove();
                    })
                    .catch(function () {
                        button.disabled = false;
                    });
            });
        });
    })();
</script>
