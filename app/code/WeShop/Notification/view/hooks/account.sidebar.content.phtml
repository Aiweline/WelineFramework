use Weline\Customer\Service\AccountSidebarContentGate;

if (!AccountSidebarContentGate::accepts('notification-preferences')) {
    return;
}

use WeShop\Customer\Api\CustomerContextInterface;
use WeShop\Notification\Model\CustomerNotificationContact;
use WeShop\Notification\Service\CustomerNotificationPreferenceService;
use WeShop\Notification\Service\NotificationPageDataService;
use Weline\Framework\Manager\ObjectManager;

$customerContext = ObjectManager::getInstance(CustomerContextInterface::class);
$preferenceService = ObjectManager::getInstance(CustomerNotificationPreferenceService::class);
$notificationPageDataService = ObjectManager::getInstance(NotificationPageDataService::class);
$customerId = (int) ($customerContext->getUserId() ?? 0);
$channels = $preferenceService->getAvailableChannels();
$contactsGrouped = $preferenceService->getContactsGrouped($customerId);
$preferredChannels = $preferenceService->getPreferredChannels($customerId);
$saveUrl = (string) $this->getUrl('notification/frontend/notification/preference/save');
$externalChannels = array_filter($channels, static fn(array $channel): bool => !empty($channel['requires_contact']));
$notificationData = $customerId > 0 ? $notificationPageDataService->build($customerId) : [];
$notifications = (array) ($notificationData['notifications'] ?? []);
$notificationCount = (int) ($notificationData['notification_count'] ?? 0);
$unreadCount = (int) ($notificationData['notification_unread_count'] ?? 0);
