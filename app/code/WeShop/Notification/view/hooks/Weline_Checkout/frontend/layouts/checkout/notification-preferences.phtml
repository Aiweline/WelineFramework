<?php
/**
 * Hook: Weline_Checkout::frontend::layouts::checkout::notification-preferences
 *
 * @hook-priority 140
 * @hook-sort-order 14
 * @hook-solo false
 */

use WeShop\Customer\Api\CustomerContextInterface;
use WeShop\Notification\Service\CustomerNotificationPreferenceService;
use Weline\Framework\Manager\ObjectManager;

$customerContext = ObjectManager::getInstance(CustomerContextInterface::class);
$preferenceService = ObjectManager::getInstance(CustomerNotificationPreferenceService::class);
$customerId = (int) ($customerContext->getUserId() ?? 0);
$options = $preferenceService->buildCheckoutOptions($customerId, $customerId <= 0);
$channels = (array) ($options['available_channels'] ?? []);
$preferredChannels = (array) ($options['preferred_channels'] ?? []);
$contactsGrouped = (array) ($options['contacts_grouped'] ?? []);
$manageUrl = (string) $this->getUrl('customer/account/index#notification-preferences');
$selectedLabels = [];

foreach ($channels as $code => $channel) {
    $code = (string) $code;
    $configured = $customerId <= 0
        ? $code === 'email'
        : ($code === CustomerNotificationPreferenceService::CHANNEL_INBOX || !empty($contactsGrouped[$code]));

    if ($configured && in_array($code, $preferredChannels, true)) {
        $selectedLabels[] = (string) ($channel['name'] ?? $code);
    }
}
?>
<details class="weshop-checkout-notification-preferences">
    <summary class="weshop-checkout-notification-summary">
        <span class="weshop-checkout-notification-title">&#35746;&#21333;&#36890;&#30693;&#28192;&#36947;</span>
        <span class="weshop-checkout-notification-tags" aria-label="&#24050;&#36873;&#36890;&#30693;&#28192;&#36947;">
            <?php if ($selectedLabels): ?>
                <?php foreach ($selectedLabels as $label): ?>
                    <span class="weshop-checkout-notification-tag"><?= htmlspecialchars($label, ENT_QUOTES, 'UTF-8') ?></span>
                <?php endforeach; ?>
            <?php else: ?>
                <span class="weshop-checkout-notification-tag weshop-checkout-notification-tag-empty">&#26410;&#36873;&#25321;</span>
            <?php endif; ?>
        </span>
    </summary>
    <div class="weshop-checkout-notification-body">
        <div class="weshop-checkout-notification-grid">
            <?php foreach ($channels as $code => $channel): ?>
                <?php
                $code = (string) $code;
                $configured = $customerId <= 0
                    ? $code === 'email'
                    : ($code === CustomerNotificationPreferenceService::CHANNEL_INBOX || !empty($contactsGrouped[$code]));
                $checked = in_array($code, $preferredChannels, true) && $configured;
                ?>
                <label class="weshop-checkout-choice">
                    <input type="checkbox" name="notification_channels[]" value="<?= htmlspecialchars($code, ENT_QUOTES, 'UTF-8') ?>" <?= $checked ? 'checked' : '' ?> <?= $configured ? '' : 'disabled' ?>>
                    <span>
                        <span class="weshop-checkout-choice-title"><?= htmlspecialchars((string) ($channel['name'] ?? $code), ENT_QUOTES, 'UTF-8') ?></span>
                        <span class="weshop-checkout-choice-meta">
                            <?= $configured ? '&#21487;&#29992;&#20110;&#26412;&#27425;&#35746;&#21333;&#36890;&#30693;&#12290;' : '&#35831;&#20808;&#22312;&#20010;&#20154;&#20013;&#24515;&#37197;&#32622;&#35813;&#28192;&#36947;&#12290;' ?>
                        </span>
                    </span>
                </label>
            <?php endforeach; ?>
        </div>
        <?php if ($customerId > 0): ?>
            <p class="weshop-checkout-notification-help">
                <a href="<?= htmlspecialchars($manageUrl, ENT_QUOTES, 'UTF-8') ?>" class="font-semibold text-primary hover:underline">&#21435;&#20010;&#20154;&#20013;&#24515;&#31649;&#29702;&#36890;&#30693;&#28192;&#36947;</a>
            </p>
        <?php else: ?>
            <p class="weshop-checkout-notification-help">
                &#35775;&#23458;&#32467;&#36134;&#20165;&#20351;&#29992;&#37038;&#31665;&#25509;&#25910;&#26412;&#27425;&#35746;&#21333;&#36890;&#30693;&#65292;&#30331;&#24405;&#21518;&#21487;&#20197;&#20445;&#23384;&#26356;&#22810;&#36890;&#30693;&#28192;&#36947;&#12290;
            </p>
        <?php endif; ?>
    </div>
</details>
