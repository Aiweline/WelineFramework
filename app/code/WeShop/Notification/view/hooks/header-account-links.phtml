use WeShop\Customer\Api\CustomerContextInterface;
use WeShop\Notification\Service\NotificationPageDataService;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;

$session = SessionFactory::getInstance()->createFrontendSession();
$isLoggedIn = $session->isLoggedIn();
if (!$isLoggedIn) {
    return;
}

$customerContext = ObjectManager::getInstance(CustomerContextInterface::class);
$notificationPageDataService = ObjectManager::getInstance(NotificationPageDataService::class);
$customerId = (int) ($customerContext->getUserId() ?? 0);
$notificationData = $customerId > 0 ? $notificationPageDataService->build($customerId) : [];
$unreadCount = (int) ($notificationData['notification_unread_count'] ?? 0);
?>
<li role="none">
    <a href="@url{'customer/account/index'}#notification-preferences" role="menuitem" class="header-account-menu-link-with-badge">
        <span><?= __('通知设置') ?></span>
        <?php if ($unreadCount > 0): ?>
            <span class="header-account-menu-badge" data-notification-unread-badge data-notification-unread-count><?= $unreadCount > 99 ? '99+' : $unreadCount ?></span>
        <?php endif; ?>
    </a>
</li>
