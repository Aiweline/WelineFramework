<?php
/** @var \Weline\Framework\View\Template $this */
$notification = $this->getData('notification') ?? [];
$notificationIndexUrl = (string) ($this->getData('notificationIndexUrl') ?? $this->getBackendUrl('*/backend/notification'));
$notificationMarkReadUrl = (string) ($this->getData('notificationMarkReadUrl') ?? $this->getBackendUrl('*/backend/notification/mark-read'));
$notificationId = (int) ($notification['notification_id'] ?? 0);
?>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <a href="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>" class="text-decoration-none small text-muted"><?= __('Back to Notifications') ?></a>
            <h1 class="h3 mb-1"><?= __('Notification Detail') ?> #<?= $notificationId ?></h1>
            <p class="text-muted mb-0"><?= __('Review notification metadata and content before support follow-up.') ?></p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3"><?= __('Basic Information') ?></h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-5"><?= __('ID') ?></dt>
                        <dd class="col-sm-7">#<?= $notificationId ?></dd>

                        <dt class="col-sm-5"><?= __('Customer ID') ?></dt>
                        <dd class="col-sm-7"><?= (int) ($notification['customer_id'] ?? 0) ?></dd>

                        <dt class="col-sm-5"><?= __('Type') ?></dt>
                        <dd class="col-sm-7"><?= htmlspecialchars((string) ($notification['type_label'] ?? $notification['type'] ?? ''), ENT_QUOTES) ?></dd>

                        <dt class="col-sm-5"><?= __('Status') ?></dt>
                        <dd class="col-sm-7">
                            <span class="badge text-bg-<?= (int) ($notification['is_read'] ?? 0) === 1 ? 'success' : 'warning' ?>">
                                <?= htmlspecialchars((string) ($notification['read_label'] ?? ''), ENT_QUOTES) ?>
                            </span>
                        </dd>

                        <dt class="col-sm-5"><?= __('Created At') ?></dt>
                        <dd class="col-sm-7"><?= htmlspecialchars((string) ($notification['created_at'] ?? ''), ENT_QUOTES) ?></dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3"><?= __('Title') ?></h2>
                    <div class="fw-semibold"><?= htmlspecialchars((string) ($notification['title'] ?? ''), ENT_QUOTES) ?></div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3"><?= __('Content') ?></h2>
                    <div class="text-break"><?= nl2br(htmlspecialchars((string) ($notification['content'] ?? ''), ENT_QUOTES)) ?></div>
                </div>
            </div>

            <?php if ((int) ($notification['is_read'] ?? 0) !== 1): ?>
                <form method="post" action="<?= htmlspecialchars($notificationMarkReadUrl, ENT_QUOTES) ?>" class="d-inline-flex gap-2">
                    <input type="hidden" name="notification_id" value="<?= $notificationId ?>">
                    <input type="hidden" name="back_url" value="<?= htmlspecialchars($this->getBackendUrl('*/backend/notification/view', ['id' => $notificationId]), ENT_QUOTES) ?>">
                    <button type="submit" class="btn btn-success"><?= __('Mark as Read') ?></button>
                    <a href="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>" class="btn btn-outline-secondary"><?= __('Back to Notifications') ?></a>
                </form>
            <?php else: ?>
                <div class="alert alert-success mb-0">
                    <?= __('Already marked as read.') ?>
                </div>
                <div class="mt-3">
                    <a href="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>" class="btn btn-outline-secondary"><?= __('Back to Notifications') ?></a>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
