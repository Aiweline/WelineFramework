<?php
/** @var \Weline\Framework\View\Template $this */
$notifications = $this->getData('notifications') ?? [];
$filters = $this->getData('filters') ?? [];
$summary = $this->getData('summary') ?? [];
$typeOptions = $this->getData('typeOptions') ?? [];
$readOptions = $this->getData('readOptions') ?? [];
$notificationIndexUrl = (string) ($this->getData('notificationIndexUrl') ?? $this->getBackendUrl('*/backend/notification'));
$notificationMarkReadUrl = (string) ($this->getData('notificationMarkReadUrl') ?? $this->getBackendUrl('*/backend/notification/mark-read'));
?>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1"><?= __('Notification Management') ?></h1>
            <p class="text-muted mb-0"><?= __('Manage customer notifications, read status, and delivery visibility for support teams.') ?></p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1"><?= __('Total Notifications') ?></div>
                    <div class="display-6"><?= (int) ($summary['total_count'] ?? 0) ?></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1"><?= __('Unread Notifications') ?></div>
                    <div class="display-6 text-warning"><?= (int) ($summary['unread_count'] ?? 0) ?></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1"><?= __('Read Notifications') ?></div>
                    <div class="display-6 text-success"><?= (int) ($summary['read_count'] ?? 0) ?></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label"><?= __('Customer ID') ?></label>
                    <input type="number"
                           name="customer_id"
                           value="<?= htmlspecialchars((string) ($filters['customer_id'] ?? ''), ENT_QUOTES) ?>"
                           class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label"><?= __('Type') ?></label>
                    <select name="type" class="form-select">
                        <option value=""><?= __('All types') ?></option>
                        <?php foreach ($typeOptions as $code => $label): ?>
                            <option value="<?= htmlspecialchars((string) $code, ENT_QUOTES) ?>" <?= ($filters['type'] ?? '') === $code ? 'selected' : '' ?>>
                                <?= htmlspecialchars((string) $label, ENT_QUOTES) ?>
                            </option>
                        <?php endforeach; ?>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label"><?= __('Status') ?></label>
                    <select name="is_read" class="form-select">
                        <option value=""><?= __('All statuses') ?></option>
                        <?php foreach ($readOptions as $value => $label): ?>
                            <option value="<?= htmlspecialchars((string) $value, ENT_QUOTES) ?>" <?= (string) ($filters['is_read'] ?? '') === (string) $value ? 'selected' : '' ?>>
                                <?= htmlspecialchars((string) $label, ENT_QUOTES) ?>
                            </option>
                        <?php endforeach; ?>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label"><?= __('Title') ?></label>
                    <input type="text"
                           name="title"
                           value="<?= htmlspecialchars((string) ($filters['title'] ?? ''), ENT_QUOTES) ?>"
                           class="form-control"
                           placeholder="<?= __('Search by title') ?>">
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><?= __('Apply Filters') ?></button>
                    <a href="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>" class="btn btn-outline-secondary"><?= __('Reset') ?></a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <?php if ($notifications): ?>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th><?= __('ID') ?></th>
                            <th><?= __('Customer') ?></th>
                            <th><?= __('Type') ?></th>
                            <th><?= __('Title') ?></th>
                            <th><?= __('Read State') ?></th>
                            <th><?= __('Created At') ?></th>
                            <th class="text-end"><?= __('Actions') ?></th>
                        </tr>
                        </thead>
                        <tbody>
                        <?php foreach ($notifications as $notification): ?>
                            <tr>
                                <td>#<?= (int) ($notification['notification_id'] ?? 0) ?></td>
                                <td><?= (int) ($notification['customer_id'] ?? 0) ?></td>
                                <td><?= htmlspecialchars((string) ($typeOptions[$notification['type'] ?? ''] ?? ucfirst((string) ($notification['type'] ?? ''))), ENT_QUOTES) ?></td>
                                <td class="text-truncate" style="max-width: 300px;"><?= htmlspecialchars((string) ($notification['title'] ?? ''), ENT_QUOTES) ?></td>
                                <td>
                                    <span class="badge text-bg-<?= htmlspecialchars((string) ($notification['read_badge_class'] ?? 'secondary'), ENT_QUOTES) ?>">
                                        <?= htmlspecialchars((string) ($notification['read_label'] ?? ''), ENT_QUOTES) ?>
                                    </span>
                                </td>
                                <td><?= htmlspecialchars((string) ($notification['created_at'] ?? ''), ENT_QUOTES) ?></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a href="<?= htmlspecialchars($this->getBackendUrl('*/backend/notification/view', ['id' => $notification['notification_id'] ?? 0]), ENT_QUOTES) ?>" class="btn btn-sm btn-outline-primary">
                                            <?= __('View') ?>
                                        </a>
                                        <?php if ((int) ($notification['is_read'] ?? 0) !== 1): ?>
                                            <form method="post" action="<?= htmlspecialchars($notificationMarkReadUrl, ENT_QUOTES) ?>">
                                                <input type="hidden" name="notification_id" value="<?= (int) ($notification['notification_id'] ?? 0) ?>">
                                                <input type="hidden" name="back_url" value="<?= htmlspecialchars($notificationIndexUrl, ENT_QUOTES) ?>">
                                                <button type="submit" class="btn btn-sm btn-outline-success"><?= __('Mark as Read') ?></button>
                                            </form>
                                        <?php endif; ?>
                                    </div>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php else: ?>
                <div class="text-center py-5">
                    <h2 class="h5 mb-2"><?= __('No notifications found.') ?></h2>
                    <p class="text-muted mb-0"><?= __('Try adjusting filters or wait for new customer events.') ?></p>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>
