<?php
/**
 * Product edit review management panel.
 *
 * @hook-priority 220
 * @hook-sort-order 20
 * @hook-solo false
 */
use Weline\Framework\Manager\ObjectManager;
use WeShop\Review\Model\Review;
use WeShop\Review\Service\ReviewAdminPageDataService;

$this->request->addModule('WeShop_Review');
\Weline\Framework\Phrase\Parser::$loaded = false;

$product = $this->getData('product');
$productId = 0;
$progress = '';
if (is_object($product)) {
    if (method_exists($product, 'getId')) {
        $productId = (int) $product->getId();
    }
    if ($productId <= 0 && method_exists($product, 'getData')) {
        $productId = (int) ($product->getData('product_id') ?? 0);
    }
    if (method_exists($product, 'getData')) {
        $progress = (string) ($product->getData('progress') ?? '');
    }
} elseif (is_array($product)) {
    $productId = (int) ($product['product_id'] ?? $product['id'] ?? 0);
    $progress = (string) ($product['progress'] ?? '');
}

$reviews = [];
$summary = ['total' => 0, 'pending' => 0, 'approved' => 0, 'rejected' => 0];
$statusOptions = [];
$loadError = '';
$reviewListUrl = $this->getBackendUrl('*/backend/review', ['product_id' => $productId]);
$reviewConfigUrl = $this->getBackendUrl('*/backend/review/config');
$reviewApproveUrl = $this->getBackendUrl('*/backend/review/approve');
$reviewRejectUrl = $this->getBackendUrl('*/backend/review/reject');
$reviewDeleteUrl = $this->getBackendUrl('*/backend/review/delete');

if ($productId > 0) {
    try {
        /** @var ReviewAdminPageDataService $reviewAdminPageDataService */
        $reviewAdminPageDataService = ObjectManager::getInstance(ReviewAdminPageDataService::class);
        $reviewData = $reviewAdminPageDataService->getListData(1, 8, ['product_id' => $productId]);
        $reviews = is_array($reviewData['reviews'] ?? null) ? $reviewData['reviews'] : [];
        $summary = is_array($reviewData['summary'] ?? null) ? array_merge($summary, $reviewData['summary']) : $summary;
        $statusOptions = is_array($reviewData['statusOptions'] ?? null) ? $reviewData['statusOptions'] : [];
    } catch (\Throwable $throwable) {
        $loadError = (string) __('加载当前产品评价失败：%{1}', [$throwable->getMessage()]);
    }
}

$statusBadgeMap = [
    Review::STATUS_PENDING => 'bg-warning',
    Review::STATUS_APPROVED => 'bg-success',
    Review::STATUS_REJECTED => 'bg-danger',
];
$ratingStarsMap = [
    1 => '⭐',
    2 => '⭐⭐',
    3 => '⭐⭐⭐',
    4 => '⭐⭐⭐⭐',
    5 => '⭐⭐⭐⭐⭐',
];

$jsText = [
    'approveTitle' => (string) __('Approve Review'),
    'approveMessage' => (string) __('Are you sure you want to approve this review?'),
    'approveText' => (string) __('Approve'),
    'approveSuccess' => (string) __('Review approved successfully'),
    'approveFailed' => (string) __('Failed to approve review'),
    'rejectTitle' => (string) __('Reject Review'),
    'rejectMessage' => (string) __('Are you sure you want to reject this review?'),
    'rejectText' => (string) __('Reject'),
    'rejectSuccess' => (string) __('Review rejected successfully'),
    'rejectFailed' => (string) __('Failed to reject review'),
    'deleteTitle' => (string) __('Delete Review'),
    'deleteMessage' => (string) __('Are you sure you want to delete this review? This action cannot be undone.'),
    'deleteText' => (string) __('Delete'),
    'deleteSuccess' => (string) __('Review deleted successfully'),
    'deleteFailed' => (string) __('Failed to delete review'),
    'requestFailed' => (string) __('Request failed'),
];
?>
<div class='tab-pane <?= $progress === 'product_reviews' ? 'active' : '' ?>' id='product_reviews'>
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <h5 class="mb-1"><i class="mdi mdi-comment-star-outline me-2"></i><?= __('当前产品评价') ?></h5>
                    <p class="text-muted mb-0"><?= __('在产品编辑时查看并处理当前产品的买家评价。') ?></p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a href="<?= htmlspecialchars($reviewListUrl, ENT_QUOTES, 'UTF-8') ?>" class="btn btn-outline-primary btn-sm">
                        <i class="mdi mdi-open-in-new me-1"></i><?= __('查看全部评价') ?>
                    </a>
                    <a href="<?= htmlspecialchars($reviewConfigUrl, ENT_QUOTES, 'UTF-8') ?>" class="btn btn-outline-secondary btn-sm">
                        <i class="mdi mdi-tune-variant me-1"></i><?= __('评价设置') ?>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <?php if ($productId <= 0): ?>
        <div class="alert alert-info mb-0">
            <i class="mdi mdi-information-outline me-1"></i><?= __('保存产品后即可管理评价。') ?>
        </div>
    <?php elseif ($loadError !== ''): ?>
        <div class="alert alert-danger mb-0">
            <i class="mdi mdi-alert-circle-outline me-1"></i><?= htmlspecialchars($loadError, ENT_QUOTES, 'UTF-8') ?>
        </div>
    <?php else: ?>
        <div class="row mb-3">
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Total Reviews') ?></div>
                    <div class="fs-4 fw-semibold"><?= (int) ($summary['total'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Pending') ?></div>
                    <div class="fs-4 fw-semibold text-warning"><?= (int) ($summary['pending'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Approved') ?></div>
                    <div class="fs-4 fw-semibold text-success"><?= (int) ($summary['approved'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Rejected') ?></div>
                    <div class="fs-4 fw-semibold text-danger"><?= (int) ($summary['rejected'] ?? 0) ?></div>
                </div>
            </div>
        </div>

        <?php if ($reviews === []): ?>
            <div class="text-center text-muted py-5 border rounded">
                <i class="mdi mdi-comment-star-outline font-size-48 d-block mb-3"></i>
                <p class="mb-0"><?= __('当前产品暂无评价。') ?></p>
            </div>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th><?= __('Review ID') ?></th>
                        <th><?= __('Rating') ?></th>
                        <th><?= __('细分评分') ?></th>
                        <th><?= __('媒体') ?></th>
                        <th><?= __('Content') ?></th>
                        <th><?= __('Status') ?></th>
                        <th><?= __('Created At') ?></th>
                        <th><?= __('Actions') ?></th>
                    </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($reviews as $review): ?>
                        <?php
                        $reviewId = (int) ($review['review_id'] ?? $review['id'] ?? 0);
                        $status = (string) ($review['status'] ?? Review::STATUS_PENDING);
                        $badgeClass = $statusBadgeMap[$status] ?? 'bg-secondary';
                        $statusLabel = (string) ($statusOptions[$status] ?? ucfirst($status));
                        $rating = max(1, min(5, (int) ($review['rating'] ?? 5)));
                        $ratingStars = $ratingStarsMap[$rating] ?? str_repeat('⭐', $rating);
                        $scoreLabels = is_array($review['rating_score_labels'] ?? null) ? $review['rating_score_labels'] : [];
                        $mediaItems = is_array($review['media_items'] ?? null) ? $review['media_items'] : [];
                        ?>
                        <tr>
                            <td><strong>#<?= $reviewId ?></strong></td>
                            <td>
                                <span class="text-warning"><?= $ratingStars ?></span>
                                <span class="text-muted ms-1">(<?= $rating ?>)</span>
                            </td>
                            <td>
                                <?php if ($scoreLabels): ?>
                                    <div class="d-flex flex-column gap-1">
                                        <?php foreach ($scoreLabels as $scoreItem): ?>
                                            <span class="small">
                                                <?= htmlspecialchars((string) __((string) ($scoreItem['label'] ?? '')), ENT_QUOTES, 'UTF-8') ?>:
                                                <strong><?= (int) ($scoreItem['score'] ?? 0) ?></strong>
                                            </span>
                                        <?php endforeach; ?>
                                    </div>
                                <?php else: ?>
                                    <span class="text-muted">-</span>
                                <?php endif; ?>
                            </td>
                            <td>
                                <?php if ($mediaItems): ?>
                                    <div class="d-flex align-items-center gap-2">
                                        <?php $firstMedia = $mediaItems[0]; ?>
                                        <?php if (($firstMedia['type'] ?? '') === 'video'): ?>
                                            <span class="badge bg-primary"><i class="mdi mdi-video-outline me-1"></i><?= __('视频') ?></span>
                                        <?php else: ?>
                                            <img src="<?= htmlspecialchars((string) ($firstMedia['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                                                 alt=""
                                                 class="rounded border"
                                                 style="width: 42px; height: 42px; object-fit: cover;">
                                        <?php endif; ?>
                                        <span class="small text-muted"><?= count($mediaItems) ?></span>
                                    </div>
                                <?php else: ?>
                                    <span class="text-muted">-</span>
                                <?php endif; ?>
                            </td>
                            <td style="max-width: 280px;">
                                <div class="fw-semibold text-truncate">
                                    <?= htmlspecialchars((string) ($review['title'] ?? __('Rating')), ENT_QUOTES, 'UTF-8') ?>
                                </div>
                                <div class="small text-muted text-truncate">
                                    <?= htmlspecialchars((string) ($review['content'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
                                </div>
                            </td>
                            <td>
                                <span class="badge <?= $badgeClass ?>"><?= htmlspecialchars($statusLabel, ENT_QUOTES, 'UTF-8') ?></span>
                            </td>
                            <td><?= htmlspecialchars((string) ($review['created_at'] ?? '-'), ENT_QUOTES, 'UTF-8') ?></td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="<?= $this->getBackendUrl('*/backend/review/view', ['id' => $reviewId]) ?>"
                                       class="btn btn-outline-info"
                                       title="<?= __('View') ?>">
                                        <i class="mdi mdi-eye"></i>
                                    </a>
                                    <?php if ($status === Review::STATUS_PENDING): ?>
                                        <button type="button"
                                                class="btn btn-outline-success"
                                                title="<?= __('Approve') ?>"
                                                onclick="productReviewAction(<?= $reviewId ?>, 'approve')">
                                            <i class="mdi mdi-check"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger"
                                                title="<?= __('Reject') ?>"
                                                onclick="productReviewAction(<?= $reviewId ?>, 'reject')">
                                            <i class="mdi mdi-close"></i>
                                        </button>
                                    <?php endif; ?>
                                    <button type="button"
                                            class="btn btn-outline-danger"
                                            title="<?= __('Delete') ?>"
                                            onclick="productReviewAction(<?= $reviewId ?>, 'delete')">
                                        <i class="mdi mdi-trash-can-outline"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
    <?php endif; ?>
</div>

<script>
(function () {
    var urls = {
        approve: <?= json_encode($reviewApproveUrl, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>,
        reject: <?= json_encode($reviewRejectUrl, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>,
        delete: <?= json_encode($reviewDeleteUrl, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>
    };
    var text = <?= json_encode($jsText, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT) ?>;
    var actionText = {
        approve: {
            title: text.approveTitle,
            message: text.approveMessage,
            confirmText: text.approveText,
            success: text.approveSuccess,
            failed: text.approveFailed
        },
        reject: {
            title: text.rejectTitle,
            message: text.rejectMessage,
            confirmText: text.rejectText,
            success: text.rejectSuccess,
            failed: text.rejectFailed
        },
        delete: {
            title: text.deleteTitle,
            message: text.deleteMessage,
            confirmText: text.deleteText,
            success: text.deleteSuccess,
            failed: text.deleteFailed
        }
    };

    window.productReviewAction = function (reviewId, action) {
        if (!urls[action] || !actionText[action]) {
            return;
        }

        BackendConfirm({
            title: actionText[action].title,
            message: actionText[action].message,
            confirmText: actionText[action].confirmText,
            onConfirm: function () {
                fetch(urls[action] + '?id=' + encodeURIComponent(reviewId), {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'}
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            BackendToast.success(data.message || actionText[action].success);
                            setTimeout(function () { window.location.reload(); }, 1000);
                            return;
                        }
                        BackendToast.error(data.message || actionText[action].failed);
                    })
                    .catch(function (error) {
                        BackendToast.error(text.requestFailed + ': ' + error.message);
                    });
            }
        });
    };
})();
</script>
