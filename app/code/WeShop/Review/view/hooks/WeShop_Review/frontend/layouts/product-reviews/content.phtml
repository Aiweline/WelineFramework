<?php
/**
 * Review product tab hook.
 *
 * @hook-priority 220
 * @hook-sort-order 11
 * @hook-solo false
 */
$product = (array) ($this->getData('product') ?? []);
$productId = (int) ($product['product_id'] ?? 0);
$reviews = (array) ($this->getData('reviews') ?? []);
$ratingOptions = is_array($this->getData('rating_options') ?? null) ? $this->getData('rating_options') : [];
$ratingOptions = array_values(array_map(static function (array $option): array {
    $label = trim((string) ($option['label'] ?? ''));
    if ($label !== '') {
        $option['label'] = (string) __($label);
    }

    return $option;
}, array_filter($ratingOptions, 'is_array')));
?>
<section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Customer Voices') ?></p>
            <h3 class="mt-2 text-xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Latest Reviews') ?></h3>
        </div>
        <?php if ($productId > 0): ?>
            <a href="<?= $this->getUrl('review', ['product_id' => $productId]) ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('View All Reviews') ?></a>
        <?php endif; ?>
    </div>

    <?php if ($reviews): ?>
        <div class="mt-5 space-y-3">
            <?php foreach (array_slice($reviews, 0, 3) as $review): ?>
                <article class="rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
                    <div class="flex items-center justify-between gap-3">
                        <p class="font-semibold text-text-primary-light dark:text-text-primary-dark"><?= htmlspecialchars((string) ($review['title'] ?? __('Rating')), ENT_QUOTES) ?></p>
                        <span class="text-sm font-semibold text-primary"><?= number_format((float) ($review['rating'] ?? 0), 1) ?></span>
                    </div>
                    <p class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark"><?= htmlspecialchars((string) ($review['content'] ?? ''), ENT_QUOTES) ?></p>
                    <?php $ratingScores = is_array($review['rating_scores'] ?? null) ? $review['rating_scores'] : []; ?>
                    <?php if ($ratingScores && $ratingOptions): ?>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <?php foreach ($ratingOptions as $option): ?>
                                <?php
                                $optionCode = (string) ($option['code'] ?? '');
                                if ($optionCode === '' || !isset($ratingScores[$optionCode])) {
                                    continue;
                                }
                                ?>
                                <span class="rounded-full border border-border-light px-3 py-1 text-xs font-semibold text-text-secondary-light dark:border-border-dark dark:text-text-secondary-dark">
                                    <?= htmlspecialchars((string) ($option['label'] ?? $optionCode), ENT_QUOTES) ?> <?= (int) $ratingScores[$optionCode] ?>/5
                                </span>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                    <?php $mediaItems = is_array($review['media_items'] ?? null) ? $review['media_items'] : []; ?>
                    <?php if ($mediaItems): ?>
                        <div class="mt-3 grid grid-cols-3 gap-2">
                            <?php foreach (array_slice($mediaItems, 0, 3) as $media): ?>
                                <?php
                                $mediaType = (string) ($media['type'] ?? '');
                                $mediaUrl = (string) ($media['url'] ?? '');
                                if ($mediaUrl === '') {
                                    continue;
                                }
                                ?>
                                <?php if ($mediaType === 'video'): ?>
                                    <video class="aspect-square w-full rounded-xl border border-border-light object-cover dark:border-border-dark" controls preload="metadata" src="<?= htmlspecialchars($mediaUrl, ENT_QUOTES) ?>"></video>
                                <?php else: ?>
                                    <img class="aspect-square w-full rounded-xl border border-border-light object-cover dark:border-border-dark" src="<?= htmlspecialchars($mediaUrl, ENT_QUOTES) ?>" alt="">
                                <?php endif; ?>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </article>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="mt-5 rounded-2xl border border-dashed border-border-light bg-background-light px-5 py-8 text-sm leading-6 text-text-secondary-light dark:border-border-dark dark:bg-background-dark dark:text-text-secondary-dark">
            <?= __('No product reviews yet. Be the first to share your experience.') ?>
        </div>
    <?php endif; ?>
</section>
