        </div>
        <script>
            (function () {
                var root = document.querySelector('[data-review-write-widget="product-<?= $productId ?>"]');
                if (!root) {
                    return;
                }

                var productId = <?= $productId ?>;
                var reviewMode = <?= json_encode($reviewMode, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: '"order"' ?>;
                var isCustomerLoggedIn = <?= $isCustomerLoggedIn ? 'true' : 'false' ?>;
                var ratingOptions = <?= $ratingOptionsJson ?>;
                var texts = <?= $reviewUiTextJson ?>;
                var writeTrigger = root.querySelector('[data-review-write-trigger]');
                var writePanel = root.querySelector('[data-review-write-panel]');
                var form = root.querySelector('[data-review-write-form]');
                var submit = root.querySelector('[data-review-submit]');
                var feedback = root.querySelector('[data-review-feedback]');
                var modeInput = root.querySelector('[data-review-mode-input]');
                var modeIcon = root.querySelector('[data-review-mode-icon]');
                var modeLabel = root.querySelector('[data-review-mode-label]');
                var modeDescription = root.querySelector('[data-review-mode-description]');
                var loginTrigger = root.querySelector('[data-review-login-trigger]');
                var formTokenInput = root.querySelector('[data-review-form-token]');
                var reviewList = root.querySelector('[data-review-inline-list]');
                var emptyState = root.querySelector('[data-review-empty-state]');
                var authModal = root.querySelector('[data-review-auth-modal]');
                var authForm = root.querySelector('[data-review-auth-form]');
                var authAlert = root.querySelector('[data-review-auth-alert]');
                var authSubmit = root.querySelector('[data-review-auth-submit]');
                var apiPromise = null;
                var accountApiPromise = null;
                var tokenPromise = null;
                var modePromise = null;
                var storageKey = 'weshop.review.pending.' + productId;
                var indexedDbName = 'weshop_review_pending';
                var indexedDbStore = 'reviews';
                var seenReviews = {};
                var translationCache = {};
                var translatorCache = {};
                var languageDetectorPromise = null;
                var browserTranslatorSupported = Boolean(self.Translator && typeof self.Translator.create === 'function');
                var browserLanguageDetectorSupported = Boolean(self.LanguageDetector && typeof self.LanguageDetector.create === 'function');
                var languageDetectorCreateTimeout = 3000;
                var languageDetectorDetectTimeout = 3000;
                var translatorAvailabilityTimeout = 3000;
                var translatorCreateTimeout = 15000;
                var translatorTranslateTimeout = 20000;
                var afterLoginCallback = null;
                window.__weshopReviewTranslatorSupported = browserTranslatorSupported;

                window.setTimeout(function () {
                    browserTranslatorSupported = Boolean(self.Translator && typeof self.Translator.create === 'function');
                    browserLanguageDetectorSupported = Boolean(self.LanguageDetector && typeof self.LanguageDetector.create === 'function');
                    window.__weshopReviewTranslatorSupported = browserTranslatorSupported;
                }, 0);

                if (!form || !submit) {
                    return;
                }

                function escapeHtml(value) {
                    return String(value == null ? '' : value)
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#039;');
                }

                function normalizeLanguageCode(value) {
                    value = String(value || '').trim().replace(/_/g, '-');
                    if (!value) {
                        return 'zh';
                    }
                    var lower = value.toLowerCase();
                    if (lower.indexOf('zh-hant') === 0 || lower.indexOf('zh-tw') === 0 || lower.indexOf('zh-hk') === 0) {
                        return 'zh-Hant';
                    }
                    if (lower.indexOf('zh') === 0) {
                        return 'zh';
                    }
                    return lower.split('-')[0] || 'zh';
                }

                function getCurrentLanguage() {
                    var htmlLang = document.documentElement ? document.documentElement.getAttribute('lang') : '';
                    var metaLang = document.querySelector('meta[name="language"], meta[name="locale"]');
                    var cookieMatch = document.cookie.match(/(?:^|;\s*)(?:WELINE_USER_LANG|weline_locale|locale)=([^;]+)/i);
                    return normalizeLanguageCode(
                        htmlLang
                        || (metaLang ? metaLang.getAttribute('content') : '')
                        || (cookieMatch ? decodeURIComponent(cookieMatch[1]) : '')
                    );
                }

                function setTranslateStatus(button, message) {
                    var selector = button ? button.getAttribute('data-review-translate-status') : '';
                    var statusNode = selector ? document.querySelector(selector) : null;
                    if (statusNode) {
                        statusNode.textContent = message || '';
                    }
                }

                function setTranslateLabel(button, message) {
                    var label = button ? button.querySelector('[data-review-translate-label]') : null;
                    if (label) {
                        label.textContent = message || texts.translate;
                    }
                }

                function getLanguageDetector() {
                    if (!browserLanguageDetectorSupported) {
                        return Promise.resolve(null);
                    }
                    if (!languageDetectorPromise) {
                        languageDetectorPromise = withTimeout(
                            self.LanguageDetector.create(),
                            languageDetectorCreateTimeout,
                            'Language detector create timeout'
                        ).catch(function () {
                            languageDetectorPromise = null;
                            return null;
                        });
                    }
                    return languageDetectorPromise;
                }

                function withTimeout(promise, timeoutMs, message) {
                    return new Promise(function (resolve, reject) {
                        var settled = false;
                        var timer = window.setTimeout(function () {
                            if (!settled) {
                                settled = true;
                                reject(new Error(message || 'timeout'));
                            }
                        }, timeoutMs);
                        Promise.resolve(promise).then(function (value) {
                            if (settled) {
                                return;
                            }
                            settled = true;
                            window.clearTimeout(timer);
                            resolve(value);
                        }).catch(function (error) {
                            if (settled) {
                                return;
                            }
                            settled = true;
                            window.clearTimeout(timer);
                            reject(error);
                        });
                    });
                }

                function detectTextLanguage(text, targetLanguage) {
                    return getLanguageDetector().then(function (detector) {
                        if (!detector || typeof detector.detect !== 'function') {
                            return targetLanguage === 'zh' || targetLanguage === 'zh-Hant' ? 'en' : 'zh';
                        }
                        return withTimeout(
                            detector.detect(text),
                            languageDetectorDetectTimeout,
                            'Language detector detect timeout'
                        ).then(function (results) {
                            var result = Array.isArray(results) && results.length ? results[0] : null;
                            return normalizeLanguageCode((result && result.detectedLanguage) || '');
                        }).catch(function () {
                            return targetLanguage === 'zh' || targetLanguage === 'zh-Hant' ? 'en' : 'zh';
                        });
                    });
                }

                function getTranslator(sourceLanguage, targetLanguage, button) {
                    if (!browserTranslatorSupported || !window.__weshopReviewTranslatorSupported) {
                        return Promise.reject(new Error('Translator API unavailable'));
                    }
                    var key = sourceLanguage + ':' + targetLanguage;
                    if (translatorCache[key]) {
                        return translatorCache[key];
                    }
                    translatorCache[key] = Promise.resolve()
                        .then(function () {
                            if (typeof self.Translator.availability !== 'function') {
                                return 'available';
                            }
                            return withTimeout(self.Translator.availability({
                                sourceLanguage: sourceLanguage,
                                targetLanguage: targetLanguage
                            }), translatorAvailabilityTimeout, 'Translator availability timeout');
                        })
                        .then(function (availability) {
                            if (availability === 'unavailable') {
                                throw new Error('Translation pair unavailable');
                            }
                            return withTimeout(self.Translator.create({
                                sourceLanguage: sourceLanguage,
                                targetLanguage: targetLanguage,
                                monitor: function (monitor) {
                                    if (monitor && typeof monitor.addEventListener === 'function') {
                                        monitor.addEventListener('downloadprogress', function (event) {
                                            var percent = Math.round(Number(event.loaded || 0) * 100);
                                            setTranslateStatus(button, texts.translating + (percent > 0 ? ' ' + percent + '%' : ''));
                                        });
                                    }
                                }
                            }), translatorCreateTimeout, 'Translator create timeout');
                        })
                        .catch(function (error) {
                            translatorCache[key] = null;
                            throw error;
                        });
                    return translatorCache[key];
                }

                function translateReviewNode(button) {
                    var selector = button.getAttribute('data-review-translate-source') || '';
                    var sourceNode = selector ? document.querySelector(selector) : null;
                    if (!sourceNode) {
                        return;
                    }
                    var original = sourceNode.getAttribute('data-review-original-text') || sourceNode.textContent || '';
                    var cacheKey = selector + ':' + getCurrentLanguage();
                    if (button.getAttribute('data-review-translation-visible') === '1') {
                        sourceNode.textContent = original;
                        button.setAttribute('data-review-translation-visible', '0');
                        setTranslateLabel(button, texts.showTranslation);
                        setTranslateStatus(button, '');
                        return;
                    }
                    if (!sourceNode.getAttribute('data-review-original-text')) {
                        sourceNode.setAttribute('data-review-original-text', original);
                    }
                    if (translationCache[cacheKey]) {
                        sourceNode.textContent = translationCache[cacheKey];
                        button.setAttribute('data-review-translation-visible', '1');
                        setTranslateLabel(button, texts.showOriginal);
                        setTranslateStatus(button, '');
                        return;
                    }
                    if (!browserTranslatorSupported || !window.__weshopReviewTranslatorSupported) {
                        setTranslateLabel(button, texts.translate);
                        setTranslateStatus(button, texts.translateUnavailable);
                        return;
                    }
                    button.disabled = true;
                    button.classList.add('opacity-60');
                    setTranslateLabel(button, texts.translating);
                    setTranslateStatus(button, '');
                    var targetLanguage = getCurrentLanguage();
                    detectTextLanguage(original, targetLanguage)
                        .then(function (sourceLanguage) {
                            if (sourceLanguage === targetLanguage) {
                                throw new Error('same-language');
                            }
                            return getTranslator(sourceLanguage, targetLanguage, button);
                        })
                        .then(function (translator) {
                            return withTimeout(
                                translator.translate(original),
                                translatorTranslateTimeout,
                                'Translator translate timeout'
                            );
                        })
                        .then(function (translated) {
                            translationCache[cacheKey] = translated || original;
                            sourceNode.textContent = translationCache[cacheKey];
                            button.setAttribute('data-review-translation-visible', '1');
                            setTranslateLabel(button, texts.showOriginal);
                            setTranslateStatus(button, '');
                        })
                        .catch(function (error) {
                            setTranslateLabel(button, texts.translate);
                            setTranslateStatus(button, error && error.message === 'same-language' ? texts.translateSameLanguage : texts.translateUnavailable);
                        })
                        .finally(function () {
                            button.disabled = false;
                            button.classList.remove('opacity-60');
                        });
                }

                function resolveThemeApiResource(provider) {
                    if (window.WelineApiModule && window.WelineApiModule.__full === true && typeof window.WelineApiModule.resource === 'function') {
                        return Promise.resolve(window.WelineApiModule.resource(provider));
                    }
                    if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                        return Promise.resolve(window.Weline.Api.resource(provider));
                    }
                    if (window.Weline && typeof window.Weline.use === 'function') {
                        return Promise.resolve(window.Weline.use('api')).then(function () {
                            if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                                return window.Weline.Api.resource(provider);
                            }
                            if (window.WelineApiModule && typeof window.WelineApiModule.resource === 'function') {
                                return window.WelineApiModule.resource(provider);
                            }
                            throw new Error('Weline.Api.resource is not available.');
                        });
                    }

                    return Promise.reject(new Error('Weline.Api.resource is not available.'));
                }

                function getReviewApi() {
                    if (!apiPromise) {
                        apiPromise = resolveThemeApiResource('review').catch(function (error) {
                            apiPromise = null;
                            throw error;
                        });
                    }
                    return apiPromise;
                }

                function getAccountApi() {
                    if (!accountApiPromise) {
                        accountApiPromise = resolveThemeApiResource('account').catch(function (error) {
                            accountApiPromise = null;
                            throw error;
                        });
                    }
                    return accountApiPromise;
                }

                function ensureAccountObject() {
                    var account = window.account || window.Account || window.WelineAccountModule || null;
                    if (account && typeof account === 'object') {
                        return account;
                    }

                    account = {
                        isLogin: Boolean(isCustomerLoggedIn),
                        logged_in: Boolean(isCustomerLoggedIn),
                        isLoggedIn: function () {
                            return Boolean(this.isLogin || this.logged_in);
                        }
                    };
                    window.account = account;
                    return account;
                }

                function getAccountObject() {
                    return ensureAccountObject();
                }

                function isAccountLoggedInSync() {
                    var account = getAccountObject();
                    var value;
                    if (account) {
                        if (typeof account.isLoggedIn === 'function') {
                            try {
                                value = account.isLoggedIn();
                                if (typeof value === 'boolean') {
                                    return value;
                                }
                            } catch (error) {
                            }
                        }
                        if (typeof account.isLogin === 'boolean') {
                            return account.isLogin;
                        }
                        if (typeof account.logged_in === 'boolean') {
                            return account.logged_in;
                        }
                        if (typeof account.getFrontendUser === 'function') {
                            try {
                                if (account.getFrontendUser()) {
                                    return true;
                                }
                            } catch (error) {
                            }
                        }
                        if (account.user || account.customer || account.frontendUser) {
                            return true;
                        }
                    }
                    return Boolean(isCustomerLoggedIn);
                }

                function markLoggedIn(user) {
                    isCustomerLoggedIn = true;
                    modePromise = null;
                    var account = getAccountObject();
                    if (account && typeof account === 'object') {
                        account.isLogin = true;
                        account.logged_in = true;
                        if (user && !account.user) {
                            account.user = user;
                        }
                    }
                    window.dispatchEvent(new CustomEvent('weshop:review-login', {detail: {user: user || null}}));
                }

                function updateMode(mode, description, icon) {
                    reviewMode = mode === 'order' ? 'order' : 'anonymous';
                    if (modeInput) {
                        modeInput.value = reviewMode;
                    }
                    if (modeLabel) {
                        modeLabel.textContent = reviewMode === 'order' ? texts.orderMode : texts.anonymousMode;
                    }
                    if (modeDescription) {
                        modeDescription.textContent = description || (reviewMode === 'order' ? texts.modeOrderDescription : texts.modeAnonymousDescription);
                    }
                    if (modeIcon) {
                        modeIcon.textContent = icon || (reviewMode === 'order' ? 'verified_user' : 'edit_note');
                    }
                    if (loginTrigger) {
                        var hideLoginTrigger = isAccountLoggedInSync();
                        loginTrigger.hidden = hideLoginTrigger;
                        loginTrigger.classList.toggle('hidden', hideLoginTrigger);
                    }
                }

                function ensureFormToken() {
                    if (formTokenInput && formTokenInput.value) {
                        return Promise.resolve(formTokenInput.value);
                    }
                    if (!tokenPromise) {
                        tokenPromise = getReviewApi().then(function (ReviewApi) {
                            return ReviewApi.formToken({path: form.getAttribute('action') || 'review/create'}, {silent: true});
                        }).then(function (result) {
                            var token = result && result.data ? (result.data.value || '') : '';
                            if (formTokenInput && token) {
                                formTokenInput.value = token;
                            }
                            return token;
                        }).catch(function () {
                            tokenPromise = null;
                            return '';
                        });
                    }
                    return tokenPromise;
                }

                function resolveModeForIntent() {
                    if (modePromise) {
                        return modePromise;
                    }
                    isCustomerLoggedIn = isAccountLoggedInSync();
                    if (!isCustomerLoggedIn) {
                        updateMode('anonymous', texts.modeAnonymousDescription, 'edit_note');
                        modePromise = Promise.resolve(reviewMode);
                        return modePromise;
                    }
                    if (modeDescription) {
                        modeDescription.textContent = texts.modeChecking;
                    }
                    if (modeIcon) {
                        modeIcon.textContent = 'sync';
                    }
                    modePromise = getReviewApi().then(function (ReviewApi) {
                        return ReviewApi.resolveMode({product_id: productId}, {silent: true});
                    }).then(function (result) {
                        var data = result && result.data ? result.data : {};
                        if (result && result.success && data.selected_mode === 'order') {
                            updateMode('order', texts.modeOrderDescription, 'verified_user');
                            return reviewMode;
                        }
                        updateMode('anonymous', texts.modeFallbackDescription, 'edit_note');
                        return reviewMode;
                    }).catch(function () {
                        updateMode('anonymous', texts.modeFallbackDescription, 'edit_note');
                        return reviewMode;
                    });
                    return modePromise;
                }

                function showPanel() {
                    if (writePanel) {
                        writePanel.hidden = false;
                        writePanel.classList.remove('hidden');
                    }
                    if (writeTrigger) {
                        writeTrigger.hidden = true;
                        writeTrigger.classList.add('hidden');
                    }
                    return resolveModeForIntent().then(function () {
                        return ensureFormToken();
                    });
                }

                function handleReviewWriteIntent(event) {
                    if (event) {
                        event.preventDefault();
                    }
                    if (!isAccountLoggedInSync()) {
                        openAuthModal(function () {
                            showPanel();
                        });
                        return;
                    }
                    showPanel();
                }

                function activateProductDetailTab(tabName) {
                    var targetContent = document.getElementById(tabName + '-content');
                    if (!targetContent) {
                        return false;
                    }

                    document.querySelectorAll('.product-tab').forEach(function (tab) {
                        tab.classList.remove('text-primary', 'border-primary');
                        tab.classList.add('text-text-secondary-light', 'dark:text-text-secondary-dark', 'border-transparent');
                        if (tab.dataset.tab === tabName) {
                            tab.classList.add('text-primary', 'border-primary');
                            tab.classList.remove('text-text-secondary-light', 'dark:text-text-secondary-dark', 'border-transparent');
                        }
                    });

                    document.querySelectorAll('.tab-content').forEach(function (content) {
                        content.classList.add('hidden');
                    });
                    targetContent.classList.remove('hidden');

                    return true;
                }

                function bindProductDetailTabs() {
                    if (window.__weshopProductTabsBound) {
                        return;
                    }

                    window.__weshopProductTabsBound = true;
                    document.querySelectorAll('.product-tab').forEach(function (tab) {
                        tab.addEventListener('click', function (event) {
                            event.preventDefault();
                            activateProductDetailTab(this.dataset.tab);
                        });
                    });
                    window.WeShopProductTabs = {
                        activate: activateProductDetailTab,
                        focusReviewDeepLink: focusDeepLinkedReviewNode
                    };
                }

                function findDeepLinkedReviewNode() {
                    var hash = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : '';
                    if (hash) {
                        var hashNode = document.getElementById(hash);
                        if (hashNode) {
                            return hashNode;
                        }
                    }

                    var params = new URLSearchParams(window.location.search || '');
                    var replyId = Number(params.get('reply_id') || 0);
                    if (replyId > 0) {
                        var replyNode = document.getElementById('review-reply-' + replyId);
                        if (replyNode) {
                            return replyNode;
                        }
                    }

                    var reviewId = Number(params.get('review_id') || 0);
                    return reviewId > 0 ? document.getElementById('review-' + reviewId) : null;
                }

                function applyDeepLinkedReviewFocus() {
                    activateProductDetailTab('reviews');
                    var node = findDeepLinkedReviewNode();
                    if (!node) {
                        return;
                    }

                    root.querySelectorAll('[data-review-deep-link-target="1"]').forEach(function (item) {
                        item.removeAttribute('data-review-deep-link-target');
                        item.classList.remove('ring-2', 'ring-primary/30', 'border-primary');
                    });
                    node.classList.add('ring-2', 'ring-primary/30', 'border-primary');
                    node.setAttribute('data-review-deep-link-target', '1');
                    if (!node.hasAttribute('tabindex')) {
                        node.setAttribute('tabindex', '-1');
                    }
                    node.scrollIntoView({behavior: 'auto', block: 'center', inline: 'nearest'});
                    try {
                        node.focus({preventScroll: true});
                    } catch (error) {
                        node.focus();
                    }
                }

                function focusDeepLinkedReviewNode() {
                    activateProductDetailTab('reviews');
                    if (!findDeepLinkedReviewNode()) {
                        return;
                    }

                    [120, 360, 900, 1600].forEach(function (delay) {
                        window.setTimeout(applyDeepLinkedReviewFocus, delay);
                    });
                }

                function setFeedback(message, success) {
                    if (!feedback) {
                        return;
                    }
                    feedback.textContent = message || '';
                    feedback.classList.toggle('text-emerald-500', Boolean(success));
                    feedback.classList.toggle('text-red-500', !success && Boolean(message));
                }

                function ensureReviewList() {
                    if (reviewList) {
                        return reviewList;
                    }
                    reviewList = document.createElement('div');
                    reviewList.className = 'mt-5 space-y-3';
                    reviewList.setAttribute('data-review-inline-list', '');
                    if (emptyState && emptyState.parentNode) {
                        emptyState.parentNode.insertBefore(reviewList, emptyState);
                    } else {
                        root.appendChild(reviewList);
                    }
                    return reviewList;
                }

                function updateEmptyState() {
                    if (emptyState) {
                        emptyState.classList.toggle('hidden', ensureReviewList().children.length > 0);
                    }
                }

                function ensureLocalKey(review) {
                    if (review.review_id && Number(review.review_id) > 0) {
                        review.local_key = 'review-' + Number(review.review_id);
                    }
                    if (!review.local_key) {
                        review.local_key = 'pending-' + productId + '-' + Date.now() + '-' + Math.random().toString(36).slice(2);
                    }
                    return review.local_key;
                }

                function isSafeMediaUrl(url) {
                    url = String(url || '').trim();
                    if (!url || /^\s*javascript:/i.test(url)) {
                        return false;
                    }
                    if (/^[a-z][a-z0-9+.-]*:/i.test(url)) {
                        return /^https?:\/\//i.test(url);
                    }
                    return true;
                }

                function buildRatingScoreHtml(review) {
                    var scores = review.rating_scores || {};
                    var html = '';
                    ratingOptions.forEach(function (option) {
                        var code = option && option.code ? String(option.code) : '';
                        if (!code || scores[code] == null || scores[code] === '') {
                            return;
                        }
                        html += '<span class="rounded-full border border-border-light px-3 py-1 text-xs font-semibold text-text-secondary-light dark:border-border-dark dark:text-text-secondary-dark">'
                            + escapeHtml(option.label || code) + ' ' + escapeHtml(scores[code]) + '/5</span>';
                    });
                    return html ? '<div class="mt-3 flex flex-wrap gap-2" data-review-score-pills>' + html + '</div>' : '';
                }

                function buildMediaHtml(review) {
                    var html = '';
                    (Array.isArray(review.media_items) ? review.media_items : []).slice(0, 3).forEach(function (media) {
                        var type = media && media.type ? String(media.type) : '';
                        var url = media && media.url ? String(media.url).trim() : '';
                        if (!isSafeMediaUrl(url)) {
                            return;
                        }
                        if (type === 'video') {
                            html += '<video class="aspect-square w-full rounded-xl border border-border-light object-cover dark:border-border-dark" controls preload="metadata" src="' + escapeHtml(url) + '"></video>';
                            return;
                        }
                        html += '<img class="aspect-square w-full rounded-xl border border-border-light object-cover dark:border-border-dark" src="' + escapeHtml(url) + '" alt="">';
                    });
                    return html ? '<div class="mt-3 grid grid-cols-3 gap-2" data-review-media-grid>' + html + '</div>' : '';
                }

                function renderReview(review) {
                    var rating = Number(review.rating || 0);
                    var key = ensureLocalKey(review);
                    if (!Number.isFinite(rating)) {
                        rating = 0;
                    }
                    var customerName = review.customer_name || texts.anonymous;
                    var initial = customerName ? String(customerName).trim().charAt(0) : 'U';
                    return '<article id="' + escapeHtml(key) + '" class="rounded-2xl border border-border-light bg-background-light p-4 ring-1 ring-amber-200/60 dark:border-border-dark dark:bg-background-dark dark:ring-amber-500/20" data-review-id="' + escapeHtml(key) + '" data-review-author-name="' + escapeHtml(customerName) + '" data-review-initial="' + escapeHtml(initial || 'U') + '">'
                        + '<div class="flex items-center justify-between gap-3">'
                        + '<p class="font-semibold text-text-primary-light dark:text-text-primary-dark">' + escapeHtml(review.title || texts.rating) + '</p>'
                        + '<span class="text-sm font-semibold text-primary" data-review-rating-badge>' + rating.toFixed(1) + '</span>'
                        + '</div>'
                        + '<p id="' + escapeHtml(key) + '-body" class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark" data-review-translate-source>' + escapeHtml(review.content || '') + '</p>'
                        + '<div class="mt-2 flex flex-wrap items-center gap-2 text-xs">'
                        + '<button type="button" class="inline-flex items-center gap-1 font-semibold text-primary hover:underline" data-review-translate data-review-translate-source="#' + escapeHtml(key) + '-body" data-review-translate-status="#' + escapeHtml(key) + '-translate-status">'
                        + '<span class="material-symbols-outlined text-sm">translate</span><span data-review-translate-label>' + escapeHtml(texts.translate) + '</span></button>'
                        + '<span id="' + escapeHtml(key) + '-translate-status" class="text-text-secondary-light dark:text-text-secondary-dark" data-review-translate-status></span>'
                        + '</div>'
                        + buildRatingScoreHtml(review)
                        + buildMediaHtml(review)
                        + '<div class="mt-3 flex items-center justify-between text-xs text-text-secondary-light dark:text-text-secondary-dark" data-review-meta>'
                        + '<span>' + escapeHtml(customerName) + '</span>'
                        + '<span>' + escapeHtml(review.created_at || '') + '</span>'
                        + '</div>'
                        + '<div class="mt-2 text-xs font-semibold text-amber-600 dark:text-amber-400">' + escapeHtml(texts.pending) + ' · ' + escapeHtml(texts.visibleToYou) + '</div>'
                        + '</article>';
                }

                function findReviewArticle(reviewId) {
                    if (!reviewList) {
                        return null;
                    }

                    return reviewList.querySelector('[data-review-id="review-' + Number(reviewId) + '"]');
                }

                function buildReplyHtml(reply) {
                    var replyId = Number(reply.reply_id || 0);
                    var parentReplyId = Number(reply.parent_reply_id || 0);
                    var createdAt = reply.created_at || new Date().toLocaleString();
                    var customerName = reply.customer_name || texts.customer || '客户';
                    var replyInitial = customerName ? String(customerName).trim().charAt(0) : 'C';
                    var parentHtml = parentReplyId > 0
                        ? '<span class="ml-2 font-normal text-text-secondary-light dark:text-text-secondary-dark">' + escapeHtml(texts.replyTo) + ' #' + parentReplyId + '</span>'
                        : '';

                    return '<div id="review-reply-' + replyId + '" class="scroll-mt-24 rounded-2xl bg-surface-light p-3 text-sm dark:bg-surface-dark" data-review-reply-id="' + replyId + '" data-review-reply-author-id="' + Number(reply.customer_id || 0) + '" data-review-reply-author-name="' + escapeHtml(customerName) + '" data-review-reply-initial="' + escapeHtml(replyInitial || 'C') + '">'
                        + '<div class="flex items-center justify-between gap-3 text-xs text-text-secondary-light dark:text-text-secondary-dark">'
                        + '<span class="font-semibold text-text-primary-light dark:text-text-primary-dark">' + escapeHtml(customerName) + parentHtml + '</span>'
                        + '<span>' + escapeHtml(createdAt) + '</span>'
                        + '</div>'
                        + '<p id="review-reply-body-' + replyId + '" class="mt-2 text-text-secondary-light dark:text-text-secondary-dark" data-review-translate-source>' + escapeHtml(reply.content || '') + '</p>'
                        + '<div class="mt-2 flex flex-wrap items-center gap-2 text-xs">'
                        + '<button type="button" class="inline-flex items-center gap-1 font-semibold text-primary hover:underline" data-review-translate data-review-translate-source="#review-reply-body-' + replyId + '" data-review-translate-status="#review-reply-translate-status-' + replyId + '">'
                        + '<span class="material-symbols-outlined text-sm">translate</span><span data-review-translate-label>' + escapeHtml(texts.translate) + '</span></button>'
                        + '<span id="review-reply-translate-status-' + replyId + '" class="text-text-secondary-light dark:text-text-secondary-dark" data-review-translate-status></span>'
                        + '</div>'
                        + '<button type="button" class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-primary" data-review-reply-toggle data-review-id-value="' + Number(reply.review_id || 0) + '" data-parent-reply-id="' + replyId + '" data-mention-customer-id="' + Number(reply.customer_id || 0) + '" data-mention-label="' + escapeHtml(customerName) + '">'
                        + '<span class="material-symbols-outlined text-sm">reply</span>'
                        + escapeHtml(texts.reply) + '</button>'
                        + '</div>';
                }

                function appendReply(reply) {
                    var article = findReviewArticle(Number(reply.review_id || 0));
                    var replyList = article ? article.querySelector('[data-review-replies]') : null;
                    if (!replyList) {
                        return;
                    }

                    replyList.insertAdjacentHTML('beforeend', buildReplyHtml(reply));
                }

                function setReplyFeedback(formNode, message, isSuccess) {
                    var feedbackNode = formNode ? formNode.querySelector('[data-review-reply-feedback]') : null;
                    if (!feedbackNode) {
                        return;
                    }

                    feedbackNode.textContent = message || '';
                    feedbackNode.classList.toggle('text-emerald-500', Boolean(isSuccess));
                    feedbackNode.classList.toggle('text-red-500', !isSuccess && Boolean(message));
                }

                function extractMentionedCustomerIds(content) {
                    var ids = [];
                    String(content || '').replace(/@(?:customer:|客户|用户|#)?(\d{1,10})/ig, function (_, id) {
                        id = Number(id || 0);
                        if (id > 0 && ids.indexOf(id) === -1) {
                            ids.push(id);
                        }
                        return _;
                    });

                    return ids.slice(0, 20);
                }

                function resolveMentionTarget(button) {
                    var customerId = Number(button.getAttribute('data-mention-customer-id') || 0);
                    if (customerId <= 0) {
                        return null;
                    }

                    return {
                        customerId: customerId,
                        label: button.getAttribute('data-mention-label') || ('#' + customerId)
                    };
                }

                function updateMentionHint(formNode, target) {
                    var hintNode = formNode ? formNode.querySelector('[data-review-reply-mention-hint]') : null;
                    if (!hintNode) {
                        return;
                    }
                    if (!target) {
                        hintNode.textContent = '';
                        return;
                    }
                    var mentionLabel = '@' + target.label;
                    var template = String(texts.mentionHint || '');
                    hintNode.textContent = template.indexOf('__REVIEW_MENTION__') !== -1
                        ? template.replace('__REVIEW_MENTION__', mentionLabel)
                        : template.replace('%{1}', mentionLabel);
                }

                function insertMentionToken(textarea, target) {
                    if (!textarea || !target) {
                        return;
                    }
                    var token = '@customer:' + target.customerId;
                    var value = textarea.value || '';
                    if (value.indexOf(token) !== -1) {
                        return;
                    }
                    textarea.value = token + (value.trim() ? ' ' + value.trim() : ' ');
                }

                function toggleReplyForm(button) {
                    if (!isAccountLoggedInSync()) {
                        openAuthModal(function () {
                            toggleReplyForm(button);
                        });
                        return;
                    }

                    var reviewId = Number(button.getAttribute('data-review-id-value') || 0);
                    var parentReplyId = Number(button.getAttribute('data-parent-reply-id') || 0);
                    var article = findReviewArticle(reviewId);
                    var formNode = article ? article.querySelector('[data-review-reply-form]') : null;
                    if (!formNode) {
                        return;
                    }

                    var mentionTarget = resolveMentionTarget(button);
                    formNode.classList.remove('hidden');
                    formNode.setAttribute('data-review-id-value', String(reviewId));
                    var parentInput = formNode.querySelector('[name="parent_reply_id"]');
                    var mentionInput = formNode.querySelector('[name="mentioned_customer_ids"]');
                    var textarea = formNode.querySelector('[name="content"]');
                    if (parentInput) {
                        parentInput.value = String(parentReplyId);
                    }
                    if (mentionInput) {
                        mentionInput.value = mentionTarget ? String(mentionTarget.customerId) : '';
                    }
                    if (textarea) {
                        textarea.placeholder = parentReplyId > 0
                            ? texts.replyTo + ' #' + parentReplyId + '. ' + texts.replyPlaceholder
                            : texts.replyPlaceholder;
                        insertMentionToken(textarea, mentionTarget);
                        textarea.focus();
                    }
                    updateMentionHint(formNode, mentionTarget);
                    setReplyFeedback(formNode, '', true);
                }

                function submitReply(formNode, button) {
                    var textarea = formNode.querySelector('[name="content"]');
                    var content = textarea ? textarea.value.trim() : '';
                    if (!content) {
                        setReplyFeedback(formNode, texts.replyContentRequired, false);
                        return;
                    }

                    var payload = {
                        review_id: Number(formNode.getAttribute('data-review-id-value') || 0),
                        parent_reply_id: Number((formNode.querySelector('[name="parent_reply_id"]') || {}).value || 0),
                        content: content,
                        mentioned_customer_ids: extractMentionedCustomerIds(content)
                    };
                    var mentionInput = formNode.querySelector('[name="mentioned_customer_ids"]');
                    if (mentionInput && mentionInput.value) {
                        String(mentionInput.value).split(/\s*,\s*/).forEach(function (id) {
                            id = Number(id || 0);
                            if (id > 0 && payload.mentioned_customer_ids.indexOf(id) === -1) {
                                payload.mentioned_customer_ids.push(id);
                            }
                        });
                    }

                    button.disabled = true;
                    button.classList.add('opacity-60');
                    getReviewApi().then(function (ReviewApi) {
                        return ReviewApi.reply(payload, {silent: true});
                    }).then(function (result) {
                        if (result && result.success) {
                            var reply = result.data && result.data.reply ? result.data.reply : payload;
                            reply.reply_id = Number(reply.reply_id || (result.data && result.data.reply_id) || 0);
                            reply.review_id = Number(reply.review_id || payload.review_id);
                            reply.parent_reply_id = Number(reply.parent_reply_id || payload.parent_reply_id || 0);
                            reply.content = reply.content || payload.content;
                            appendReply(reply);
                            if (textarea) {
                                textarea.value = '';
                            }
                            setReplyFeedback(formNode, result.message || texts.replySubmitted, true);
                            return;
                        }
                        if (result && result.data && result.data.redirect_url) {
                            openAuthModal(function () {
                                toggleReplyForm(button);
                            });
                            return;
                        }
                        setReplyFeedback(formNode, (result && result.message) || texts.replyUnable, false);
                    }).catch(function () {
                        setReplyFeedback(formNode, texts.replyUnable, false);
                    }).finally(function () {
                        button.disabled = false;
                        button.classList.remove('opacity-60');
                    });
                }

                function prependReview(review) {
                    if (Number(review.product_id || 0) !== productId) {
                        return;
                    }
                    var key = ensureLocalKey(review);
                    if (seenReviews[key]) {
                        return;
                    }
                    seenReviews[key] = true;
                    ensureReviewList().insertAdjacentHTML('afterbegin', renderReview(review));
                    updateEmptyState();
                }

                function readLocalReviews() {
                    try {
                        var decoded = JSON.parse(localStorage.getItem(storageKey) || '[]');
                        return Array.isArray(decoded) ? decoded : [];
                    } catch (error) {
                        return [];
                    }
                }

                function writeLocalReview(review) {
                    try {
                        var key = ensureLocalKey(review);
                        var reviews = readLocalReviews().filter(function (item) {
                            return item && item.local_key !== key && 'review-' + Number(item.review_id || 0) !== key;
                        });
                        reviews.unshift(review);
                        localStorage.setItem(storageKey, JSON.stringify(reviews.slice(0, 20)));
                    } catch (error) {
                    }
                }

                function openPendingReviewDb() {
                    if (!window.indexedDB) {
                        return Promise.resolve(null);
                    }
                    return new Promise(function (resolve) {
                        var request = indexedDB.open(indexedDbName, 1);
                        request.onupgradeneeded = function () {
                            var db = request.result;
                            if (!db.objectStoreNames.contains(indexedDbStore)) {
                                var store = db.createObjectStore(indexedDbStore, {keyPath: 'local_key'});
                                store.createIndex('product_id', 'product_id', {unique: false});
                            }
                        };
                        request.onsuccess = function () {
                            resolve(request.result);
                        };
                        request.onerror = function () {
                            resolve(null);
                        };
                    });
                }

                function writeIndexedDbReview(review) {
                    openPendingReviewDb().then(function (db) {
                        if (!db) {
                            return;
                        }
                        db.transaction(indexedDbStore, 'readwrite').objectStore(indexedDbStore).put(review);
                    });
                }

                function persistReview(review) {
                    writeLocalReview(review);
                    writeIndexedDbReview(review);
                }

                function loadIndexedDbReviews() {
                    openPendingReviewDb().then(function (db) {
                        if (!db) {
                            return;
                        }
                        var store = db.transaction(indexedDbStore, 'readonly').objectStore(indexedDbStore);
                        var request;
                        try {
                            request = store.index('product_id').getAll(IDBKeyRange.only(productId));
                        } catch (error) {
                            request = store.getAll();
                        }
                        request.onsuccess = function () {
                            (Array.isArray(request.result) ? request.result : []).forEach(prependReview);
                        };
                    });
                }

                function buildPayload() {
                    var payload = {rating_scores: {}, media_items: []};
                    new FormData(form).forEach(function (value, key) {
                        var scoreMatch = key.match(/^rating_scores\[([^\]]+)\]$/);
                        if (scoreMatch) {
                            if (value !== '') {
                                payload.rating_scores[scoreMatch[1]] = value;
                            }
                            return;
                        }
                        if (key === 'image_urls' || key === 'video_urls') {
                            String(value).split(/[\r\n,]+/).forEach(function (url) {
                                url = url.trim();
                                if (url) {
                                    payload.media_items.push({type: key === 'video_urls' ? 'video' : 'image', url: url, label: ''});
                                }
                            });
                            return;
                        }
                        payload[key] = value;
                    });
                    return payload;
                }

                function normalizeReview(rawReview, payload, result) {
                    var data = result && result.data ? result.data : {};
                    var review = rawReview && typeof rawReview === 'object' ? rawReview : {};
                    review.review_id = Number(review.review_id || data.review_id || 0);
                    review.product_id = Number(review.product_id || payload.product_id || productId);
                    review.customer_name = review.customer_name || texts.anonymous;
                    review.rating = Number(review.rating || payload.rating || 5);
                    review.title = review.title || payload.title || texts.rating;
                    review.content = review.content || payload.content || '';
                    review.media_items = Array.isArray(review.media_items) ? review.media_items : (payload.media_items || []);
                    review.rating_scores = review.rating_scores && typeof review.rating_scores === 'object' ? review.rating_scores : (payload.rating_scores || {});
                    review.created_at = review.created_at || new Date().toLocaleString();
                    review.status = review.status || 'pending';
                    review.pending = true;
                    review.verified_purchase = Boolean(review.verified_purchase || reviewMode === 'order');
                    ensureLocalKey(review);
                    return review;
                }

                function showAuthAlert(message) {
                    if (authAlert) {
                        authAlert.textContent = message || '';
                    }
                }

                function openAuthModal(callback) {
                    if (!authModal) {
                        return;
                    }
                    afterLoginCallback = typeof callback === 'function' ? callback : null;
                    authModal.hidden = false;
                    authModal.classList.remove('hidden');
                    authModal.classList.add('flex');
                    authModal.setAttribute('aria-hidden', 'false');
                    showAuthAlert('');
                    var username = authForm ? authForm.querySelector('[name="username"]') : null;
                    if (username) {
                        window.setTimeout(function () {
                            username.focus();
                        }, 0);
                    }
                }

                function closeAuthModal() {
                    if (!authModal) {
                        return;
                    }
                    authModal.hidden = true;
                    authModal.classList.add('hidden');
                    authModal.classList.remove('flex');
                    authModal.setAttribute('aria-hidden', 'true');
                }

                function submitAuth(event) {
                    event.preventDefault();
                    var username = (authForm.querySelector('[name="username"]') || {}).value || '';
                    var password = (authForm.querySelector('[name="password"]') || {}).value || '';
                    username = username.trim();
                    if (!username) {
                        showAuthAlert(texts.loginUsernameRequired);
                        return;
                    }
                    if (!password) {
                        showAuthAlert(texts.loginPasswordRequired);
                        return;
                    }
                    if (authSubmit) {
                        authSubmit.disabled = true;
                        authSubmit.classList.add('opacity-60');
                    }
                    var account = getAccountObject();
                    var loginPromise;
                    if (account && typeof account.frontendUserLogin === 'function') {
                        loginPromise = account.frontendUserLogin(username, password, Number((authForm.querySelector('[name="remember_duration"]') || {}).value || 0));
                    } else if (account && typeof account.frontendLogin === 'function') {
                        loginPromise = account.frontendLogin(username, password, Number((authForm.querySelector('[name="remember_duration"]') || {}).value || 0));
                    } else {
                        loginPromise = getAccountApi().then(function (AccountApi) {
                            return AccountApi.login({
                                username: username,
                                password: password,
                                remember_duration: Number((authForm.querySelector('[name="remember_duration"]') || {}).value || 0),
                                redirect_url: window.location.pathname + window.location.search
                            }, {silent: true});
                        });
                    }
                    Promise.resolve(loginPromise).then(function (result) {
                        var data = result && result.data ? result.data : result;
                        if (!data || data.success === false || data.status === 'challenge_required') {
                            throw new Error((data && data.message) || texts.loginFailed);
                        }
                        markLoggedIn(data.user || null);
                        var callback = afterLoginCallback;
                        afterLoginCallback = null;
                        closeAuthModal();
                        if (typeof callback === 'function') {
                            callback();
                        } else {
                            showPanel();
                        }
                    }).catch(function (error) {
                        showAuthAlert((error && error.message) || texts.loginFailed);
                    }).finally(function () {
                        if (authSubmit) {
                            authSubmit.disabled = false;
                            authSubmit.classList.remove('opacity-60');
                        }
                    });
                }

                function submitReview() {
                    submit.disabled = true;
                    submit.classList.add('opacity-60');
                    var payload;
                    showPanel().then(ensureFormToken).then(function () {
                        payload = buildPayload();
                        return getReviewApi();
                    }).then(function (ReviewApi) {
                        return ReviewApi.create(payload, {silent: true});
                    }).then(function (result) {
                        if (result && result.success) {
                            var review = normalizeReview(result.data && result.data.review, payload, result);
                            persistReview(review);
                            prependReview(review);
                            setFeedback(result.message || texts.thankYou, true);
                            form.reset();
                            if (modeInput) {
                                modeInput.value = reviewMode;
                            }
                            return;
                        }
                        setFeedback((result && result.message) || texts.unable, false);
                    }).catch(function () {
                        setFeedback(texts.unable, false);
                    }).finally(function () {
                        submit.disabled = false;
                        submit.classList.remove('opacity-60');
                    });
                }

                if (reviewList) {
                    reviewList.querySelectorAll('[data-review-id]').forEach(function (item) {
                        var key = item.getAttribute('data-review-id');
                        if (key) {
                            seenReviews[key] = true;
                        }
                    });
                }
                readLocalReviews().forEach(prependReview);
                loadIndexedDbReviews();
                updateEmptyState();

                if (writeTrigger) {
                    writeTrigger.addEventListener('click', handleReviewWriteIntent);
                }
                if (loginTrigger) {
                    loginTrigger.addEventListener('click', function () {
                        openAuthModal();
                    });
                }
                if (authForm) {
                    authForm.addEventListener('submit', submitAuth);
                }
                if (authModal) {
                    authModal.querySelectorAll('[data-review-auth-close]').forEach(function (button) {
                        button.addEventListener('click', closeAuthModal);
                    });
                }
                root.addEventListener('click', function (event) {
                    if (!event.target || typeof event.target.closest !== 'function') {
                        return;
                    }
                    var translateButton = event.target.closest('[data-review-translate]');
                    if (translateButton && root.contains(translateButton)) {
                        event.preventDefault();
                        translateReviewNode(translateButton);
                        return;
                    }
                    var toggleButton = event.target.closest('[data-review-reply-toggle]');
                    if (toggleButton && root.contains(toggleButton)) {
                        event.preventDefault();
                        toggleReplyForm(toggleButton);
                        return;
                    }
                    var submitButton = event.target.closest('[data-review-reply-submit]');
                    if (submitButton && root.contains(submitButton)) {
                        event.preventDefault();
                        var replyForm = submitButton.closest('[data-review-reply-form]');
                        if (replyForm) {
                            submitReply(replyForm, submitButton);
                        }
                    }
                });
                submit.addEventListener('click', submitReview);
                bindProductDetailTabs();
                focusDeepLinkedReviewNode();
                window.addEventListener('load', focusDeepLinkedReviewNode);
                window.addEventListener('hashchange', focusDeepLinkedReviewNode);
            })();
        </script>
    <?php endif; ?>
</section>
