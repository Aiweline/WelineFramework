<?php
/**
 * Product review frontend assets.
 *
 * @hook-priority 180
 * @hook-sort-order 20
 * @hook-solo false
 */
try {
    $productReviewCssUrl = (string) $this->fetchTagSource('statics', 'WeShop_Review::css/product-reviews.css', false);
} catch (\Throwable) {
    $productReviewCssUrl = '';
}

if ($productReviewCssUrl === '') {
    return;
}

$productReviewCssUrl .= str_contains($productReviewCssUrl, '?') ? '&v=20260530-product-review-responsive-stack-1' : '?v=20260530-product-review-responsive-stack-1';
?>
<link rel="stylesheet" href="<?= htmlspecialchars($productReviewCssUrl, ENT_QUOTES, 'UTF-8') ?>">
