<script>
function approveReview(reviewId) {
    BackendConfirm({
        title: '<?= __('Approve Review') ?>',
        message: '<?= __('Are you sure you want to approve this review?') ?>',
        confirmText: '<?= __('Approve') ?>',
        onConfirm: function() {
            fetch('<?= htmlspecialchars($reviewApproveUrl) ?>?id=' + reviewId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('Review approved successfully') ?>');
                    setTimeout(function() {
                        window.location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message || '<?= __('Failed to approve review') ?>');
                }
            })
            .catch(error => {
                BackendToast.error('<?= __('Request failed') ?>: ' + error.message);
            });
        }
    });
}

function rejectReview(reviewId) {
    BackendConfirm({
        title: '<?= __('Reject Review') ?>',
        message: '<?= __('Are you sure you want to reject this review?') ?>',
        confirmText: '<?= __('Reject') ?>',
        onConfirm: function() {
            fetch('<?= htmlspecialchars($reviewRejectUrl) ?>?id=' + reviewId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('Review rejected successfully') ?>');
                    setTimeout(function() {
                        window.location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message || '<?= __('Failed to reject review') ?>');
                }
            })
            .catch(error => {
                BackendToast.error('<?= __('Request failed') ?>: ' + error.message);
            });
        }
    });
}

function deleteReview(reviewId) {
    BackendConfirm({
        title: '<?= __('Delete Review') ?>',
        message: '<?= __('Are you sure you want to delete this review? This action cannot be undone.') ?>',
        confirmText: '<?= __('Delete') ?>',
        onConfirm: function() {
            fetch('<?= htmlspecialchars($reviewDeleteUrl) ?>?id=' + reviewId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('Review deleted successfully') ?>');
                    setTimeout(function() {
                        window.location.href = '<?= htmlspecialchars($reviewIndexUrl) ?>';
                    }, 1000);
                } else {
                    BackendToast.error(data.message || '<?= __('Failed to delete review') ?>');
                }
            })
            .catch(error => {
                BackendToast.error('<?= __('Request failed') ?>: ' + error.message);
            });
        }
    });
}
</script>
