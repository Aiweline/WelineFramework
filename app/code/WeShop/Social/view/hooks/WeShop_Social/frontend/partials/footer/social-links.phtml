<?php
/**
 * @hook-priority 120
 * @hook-sort-order 10
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */
$links = w_query('social', 'getFooterSocialLinks');
$links = is_array($links) ? $links : [];

if ($links === []) {
    return;
}
?>
<div class="weshop-social-footer-links flex flex-wrap gap-3" data-weshop-social-footer-links>
    <?php foreach ($links as $link): ?>
        <?php
        $platform = (string) ($link['platform'] ?? '');
        $label = (string) ($link['label'] ?? ucfirst($platform));
        $url = (string) ($link['url'] ?? '');
        if ($url === '') {
            continue;
        }
        ?>
        <a
            class="inline-flex items-center gap-2 text-sm hover:text-primary transition-colors"
            href="<?= $url ?>"
            target="_blank"
            rel="noopener noreferrer"
            data-social-platform="<?= $platform ?>"
            aria-label="<?= __('Follow us on %{1}', [$label]) ?>"
        >
            <span class="material-symbols-outlined text-base">share</span>
            <span><?= $label ?></span>
        </a>
    <?php endforeach; ?>
</div>
