<script>
(function () {
    var copyBtn = document.getElementById('weshop-copy-btn');
    var shareUrlInput = document.getElementById('weshop-share-url');

    if (!copyBtn || !shareUrlInput) {
        return;
    }

    copyBtn.addEventListener('click', function () {
        var url = shareUrlInput.value;
        if (!url) {
            return;
        }

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url).then(function () {
                showCopySuccess();
            }).catch(function () {
                fallbackCopy(url);
            });
        } else {
            fallbackCopy(url);
        }
    });

    function fallbackCopy(text) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        try {
            document.execCommand('copy');
            showCopySuccess();
        } catch (err) {
            console.error('Copy failed:', err);
        }
        document.body.removeChild(textarea);
    }

    function showCopySuccess() {
        var originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg><?= __('Copied!') ?>';
        copyBtn.style.background = 'var(--color-success)';
        setTimeout(function () {
            copyBtn.innerHTML = originalText;
            copyBtn.style.background = '';
        }, 2000);
    }

    var platforms = document.querySelectorAll('.social-share__platform');
    platforms.forEach(function (platform) {
        platform.addEventListener('click', function (e) {
            var targetPlatform = this.getAttribute('data-platform');
            var targetUrl = shareUrlInput ? shareUrlInput.value : '';

            recordShare(targetPlatform, targetUrl);
        });
    });

    function recordShare(platform, url) {
        var productId = <?= $productId ?>;
        if (!window.Weline || !window.Weline.Api) {
            return;
        }

        Promise.resolve(window.Weline.Api.resource('social')).then(function (SocialApi) {
            return SocialApi.recordShare({
                platform: platform || '',
                url: url || '',
                product_id: productId || 0
            }, {silent: true});
        }).catch(function () {});
    }
})();
</script>

