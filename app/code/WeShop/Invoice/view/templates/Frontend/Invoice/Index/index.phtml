<?php
$invoices = (array) ($this->getData('invoices') ?? []);
$invoiceCount = (int) ($this->getData('invoice_count') ?? count($invoices));
$pendingCount = (int) ($this->getData('invoice_pending_count') ?? 0);
$issuedCount = (int) ($this->getData('invoice_issued_count') ?? 0);
$page = (int) ($this->getData('page') ?? 1);
$pageCount = max(1, (int) ($this->getData('page_count') ?? 1));
$hasPrevious = (bool) ($this->getData('has_previous') ?? false);
$hasNext = (bool) ($this->getData('has_next') ?? false);
$pageSize = (int) ($this->getData('page_size') ?? 20);

$invoiceUrl = (string) $this->getUrl('invoice');
$buildPaginationUrl = function (int $targetPage) use ($invoiceUrl, $pageSize): string {
    $query = http_build_query([
        'page' => max(1, $targetPage),
        'page_size' => $pageSize,
    ]);
    return $invoiceUrl . ($query !== '' ? '?' . $query : '');
};
$formatPrice = static function (float $amount): string {
    return \Weline\Currency\Helper\CurrencyFormatter::formatConverted($amount);
};
