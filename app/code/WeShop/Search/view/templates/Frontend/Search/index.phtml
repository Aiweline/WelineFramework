                                ?>
                                <details class="group border-t border-border-light py-4 first:mt-4 first:border-t-0 first:pt-0" <?= $isOpen ? 'open' : '' ?>>
                                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                                        <span class="text-sm font-semibold text-text-primary-light"><?= htmlspecialchars((string) ($facet['name'] ?? '')) ?></span>
                                        <span class="text-xs font-semibold uppercase tracking-[0.16em] text-text-secondary-light transition group-open:rotate-180">+</span>
                                    </summary>

                                    <?php if (($facet['display_type'] ?? 'list') === 'swatch'): ?>
