<?php
/**
 * WeShop Search content template.
 */
$keyword = trim((string) ($this->getData('keyword') ?? ''));
$hasKeyword = (bool) ($this->getData('has_keyword') ?? false);
$products = is_array($this->getData('products')) ? $this->getData('products') : [];
$popularKeywords = is_array($this->getData('popular_keywords')) ? $this->getData('popular_keywords') : [];
$facets = is_array($this->getData('filters')) ? $this->getData('filters') : [];
$appliedFilters = is_array($this->getData('applied_filters')) ? $this->getData('applied_filters') : [];
$searchSummary = is_array($this->getData('search_summary')) ? $this->getData('search_summary') : [];
$engine = (string) ($this->getData('engine') ?? 'mysql');
$clearAllUrl = (string) ($this->getData('clear_all_url') ?? '/search');
$paginationHtml = (string) ($this->getData('pagination_html') ?? $this->getData('pagination') ?? '');
$paginationData = is_array($this->getData('pagination_data')) ? $this->getData('pagination_data') : [];
$hasBrowseContext = $hasKeyword || $appliedFilters !== [] || $facets !== [] || $products !== [];
$buildSearchPageUrl = function (int $targetPage) {
    $query = method_exists($this->request, 'getQuery') && is_array($this->request->getQuery())
        ? $this->request->getQuery()
        : [];
    $query['page'] = max(1, $targetPage);

    return $this->getUrl('search', $query);
};
?>
<div class="weshop-search-page">
    <w:hook name="WeShop_Search::frontend::layouts::search-page::before"/>

    <section class="weshop-search-hero">
        <div class="weshop-search-hero__content">
            <div class="weshop-search-hero__eyebrow"><?= __('Catalog Search') ?></div>
            <h1 class="weshop-search-hero__title">
                <?= $hasKeyword ? __('Results for "%{1}"', [$keyword]) : __('Search the catalog') ?>
            </h1>
            <p class="weshop-search-hero__summary">
                <?= htmlspecialchars((string) ($searchSummary['label'] ?? __('Search for products, brands, and categories.'))) ?>
            </p>
        </div>

        <form action="<?= $this->getUrl('search') ?>" method="get" class="weshop-search-form">
            <label class="weshop-search-form__label" for="default-search-keyword"><?= __('Search keyword') ?></label>
            <div class="weshop-search-form__control">
                <input
                    id="default-search-keyword"
                    type="text"
                    name="q"
                    value="<?= htmlspecialchars($keyword) ?>"
                    class="weshop-search-form__input"
                    placeholder="<?= __('Search products, brands, categories...') ?>"
                />
                <button type="submit" class="weshop-search-form__button"><?= __('Search') ?></button>
            </div>
        </form>

        <div class="weshop-search-trends">
            <div class="weshop-search-trends__header">
                <span><?= __('Trending Searches') ?></span>
                <span class="weshop-search-trends__engine"><?= htmlspecialchars(strtoupper($engine)) ?></span>
            </div>
            <div class="weshop-search-trends__list">
                <?php foreach ($popularKeywords as $item): ?>
                    <a href="<?= $this->getUrl('search', ['q' => $item['keyword'] ?? '']) ?>" class="weshop-search-chip">
                        <span><?= htmlspecialchars((string) ($item['keyword'] ?? '')) ?></span>
                        <?php if (!empty($item['count'])): ?>
                            <span class="weshop-search-chip__count"><?= (int) $item['count'] ?></span>
                        <?php endif; ?>
                    </a>
                <?php endforeach; ?>
            </div>
        </div>
    </section>

    <?php if (!empty($appliedFilters)): ?>
        <div class="weshop-search-applied">
            <?php foreach ($appliedFilters as $filter): ?>
                <?php
                $removeUrl = (string) ($filter['remove_url'] ?? '');
                $filterName = (string) ($filter['filter_name'] ?? '');
                $filterLabel = (string) ($filter['label'] ?? $filter['value'] ?? '');
                ?>
                <a href="<?= htmlspecialchars($removeUrl !== '' ? $removeUrl : $clearAllUrl) ?>" class="weshop-search-applied__item">
                    <strong><?= htmlspecialchars($filterName) ?>:</strong>
                    <span><?= htmlspecialchars($filterLabel) ?></span>
                </a>
            <?php endforeach; ?>
            <a href="<?= htmlspecialchars($clearAllUrl) ?>" class="weshop-search-applied__clear"><?= __('Clear all') ?></a>
        </div>
    <?php endif; ?>

    <section class="weshop-search-results">
        <?php if ($hasBrowseContext): ?>
            <div class="weshop-search-results__layout <?= (!empty($facets) || !empty($appliedFilters)) ? '' : 'weshop-search-results__layout--single' ?>">
                <?php if (!empty($facets) || !empty($appliedFilters)): ?>
                    <aside class="weshop-search-filters">
                        <div class="weshop-search-filters__header">
                            <h2><?= __('Filters') ?></h2>
                            <?php if (!empty($appliedFilters)): ?>
                                <a href="<?= htmlspecialchars($clearAllUrl) ?>"><?= __('Clear all') ?></a>
                            <?php endif; ?>
                        </div>

                        <?php foreach ($facets as $facet): ?>
                            <?php
                            $options = is_array($facet['options'] ?? null) ? $facet['options'] : [];
                            if ($options === []) {
                                continue;
                            }
                            $isOpen = empty($facet['collapsed']);
                            foreach ($options as $option) {
                                if (!empty($option['selected'])) {
                                    $isOpen = true;
                                    break;
                                }
                            }
                            ?>
                            <details class="weshop-search-filter" <?= $isOpen ? 'open' : '' ?>>
                                <summary class="weshop-search-filter__summary">
                                    <span><?= htmlspecialchars((string) ($facet['name'] ?? '')) ?></span>
                                    <span class="weshop-search-filter__icon">+</span>
                                </summary>
                                <div class="weshop-search-filter__options">
                                    <?php foreach ($options as $option): ?>
                                        <?php $toggleUrl = (string) ($option['toggle_url'] ?? '#'); ?>
                                        <a
                                            href="<?= htmlspecialchars($toggleUrl) ?>"
                                            class="weshop-search-filter__option <?= !empty($option['selected']) ? 'is-selected' : '' ?>"
                                        >
                                            <span><?= htmlspecialchars((string) ($option['label'] ?? '')) ?></span>
                                            <span><?= (int) ($option['count'] ?? 0) ?></span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </details>
                        <?php endforeach; ?>
                    </aside>
                <?php endif; ?>

                <div class="weshop-search-results__content">
                    <?php if (!empty($products)): ?>
                        <div class="weshop-search-grid weshop-products-grid">
                            <?php foreach ($products as $product): ?>
                                <article class="weshop-search-product weshop-product-card">
                                    <div class="weshop-product-image-wrapper">
                                        <a
                                            href="<?= $this->getUrl('product/view', ['id' => $product['product_id'] ?? 0]) ?>"
                                            class="weshop-search-product__image weshop-product-image"
                                            style="background-image: url('<?= htmlspecialchars((string) ($product['image'] ?? '')) ?>');"
                                            aria-label="<?= htmlspecialchars((string) ($product['name'] ?? '')) ?>"
                                        ></a>
                                    </div>
                                    <div class="weshop-search-product__body weshop-product-info">
                                        <a href="<?= $this->getUrl('product/view', ['id' => $product['product_id'] ?? 0]) ?>" class="weshop-search-product__name weshop-product-name">
                                            <?= htmlspecialchars((string) ($product['name'] ?? '')) ?>
                                        </a>
                                        <?php if (!empty($product['short_description'])): ?>
                                            <p class="weshop-search-product__desc"><?= htmlspecialchars((string) $product['short_description']) ?></p>
                                        <?php endif; ?>
                                        <div class="weshop-search-product__footer">
                                            <span class="weshop-search-product__price weshop-product-price"><?= $this->formatPrice((float) ($product['price'] ?? 0)) ?></span>
                                            <a href="<?= $this->getUrl('product/view', ['id' => $product['product_id'] ?? 0]) ?>" class="weshop-search-product__link weshop-product-button">
                                                <?= __('View') ?>
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>

                        <?php if ($paginationHtml !== '' || ((int) ($paginationData['pages'] ?? 0)) > 1): ?>
                            <div class="weshop-search-pagination">
                                <?php if ($paginationHtml !== ''): ?>
                                    <?= $paginationHtml ?>
                                <?php else: ?>
                                    <?php
                                    $currentPage = (int) ($paginationData['page'] ?? 1);
                                    $totalPages = (int) ($paginationData['pages'] ?? 1);
                                    ?>
                                    <a href="<?= htmlspecialchars($currentPage > 1 ? $buildSearchPageUrl($currentPage - 1) : '#') ?>" class="<?= $currentPage > 1 ? '' : 'is-disabled' ?>">
                                        <?= __('Previous') ?>
                                    </a>
                                    <span><?= __('Page %{1} of %{2}', [$currentPage, $totalPages]) ?></span>
                                    <a href="<?= htmlspecialchars($currentPage < $totalPages ? $buildSearchPageUrl($currentPage + 1) : '#') ?>" class="<?= $currentPage < $totalPages ? '' : 'is-disabled' ?>">
                                        <?= __('Next') ?>
                                    </a>
                                <?php endif; ?>
                            </div>
                        <?php endif; ?>
                    <?php else: ?>
                        <div class="weshop-search-empty">
                            <div class="weshop-search-empty__icon" aria-hidden="true">⌕</div>
                            <h2><?= __('No matching products yet') ?></h2>
                            <p><?= __('Try another keyword, browse a trending term, or remove filters to widen the catalog results.') ?></p>
                            <div class="weshop-search-empty__actions">
                                <?php foreach ($popularKeywords as $item): ?>
                                    <a href="<?= $this->getUrl('search', ['q' => $item['keyword'] ?? '']) ?>" class="weshop-search-chip">
                                        <?= htmlspecialchars((string) ($item['keyword'] ?? '')) ?>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        <?php else: ?>
            <div class="weshop-search-empty">
                <div class="weshop-search-empty__icon" aria-hidden="true">⌕</div>
                <h2><?= __('Start with a product, brand, or category') ?></h2>
                <p><?= __('Use the search bar above to explore your catalog. Popular shopper queries are ready as one-click shortcuts.') ?></p>
            </div>
        <?php endif; ?>

        <w:hook name="WeShop_Search::frontend::layouts::search-page::results-after"/>
    </section>
</div>

