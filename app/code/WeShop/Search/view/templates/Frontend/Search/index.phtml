                                                        <img src="<?= htmlspecialchars($swatchValue) ?>" alt="<?= htmlspecialchars((string) ($option['label'] ?? '')) ?>" class="h-4 w-4 rounded-full border border-border-light object-cover" />
                                                    <?php elseif ($swatchType === 'text' && $swatchValue !== ''): ?>
                                                        <span class="inline-flex min-w-6 items-center justify-center rounded-full bg-background-light px-1.5 py-0.5 text-[10px] font-bold text-text-primary-light"><?= htmlspecialchars($swatchValue) ?></span>
