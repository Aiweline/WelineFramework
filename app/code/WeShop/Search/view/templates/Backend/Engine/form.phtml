<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 更新引擎配置显示
function updateEngineConfig() {
    const engineType = document.getElementById('engine_type').value;
    const description = document.getElementById('engine_type').options[document.getElementById('engine_type').selectedIndex]?.dataset.description || '';
    
    // 隐藏所有配置面板
    document.querySelectorAll('[id^="config-"]').forEach(el => {
        el.style.display = 'none';
    });
    
    // 显示描述
    document.getElementById('engine-description').textContent = description;
    
    // 显示对应引擎的配置面板
    if (engineType) {
        const configPanel = document.getElementById('config-' + engineType);
        if (configPanel) {
            configPanel.style.display = 'block';
        }
    }
}

// 初始化
document.addEventListener('DOMContentLoaded', function() {
    updateEngineConfig();
    
    // 表单提交
    document.getElementById('search-engine-form').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        
        fetch(this.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('保存成功') ?>',
                        text: '<?= __('配置已成功保存') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '<?= $this->getUrl('search/backend/engine/index', ['scope' => $scope]) ?>';
                    });
                } else {
                    console.log('<?= __('保存成功！') ?>');
                    window.location.href = '<?= $this->getUrl('search/backend/engine/index', ['scope' => $scope]) ?>';
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.message || '<?= __('未知错误') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('保存失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                }
            }
        })
        .catch(error => {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('保存请求失败：') ?>' + error.message);
            }
        });
    });
});
</script>
