<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('search-engine-form');
    const engineSelect = document.getElementById('engine_type');
    const engineDescription = document.getElementById('engine-description');
    const panels = Array.from(document.querySelectorAll('[data-engine-panel]'));

    function toggleEnginePanelInputs(panel, isActivePanel) {
        panel.style.display = isActivePanel ? 'block' : 'none';
        panel.querySelectorAll('input, select, textarea, button').forEach(function (input) {
            input.disabled = !isActivePanel;
            if (input.dataset.required === '1') {
                input.required = isActivePanel;
            }
        });
    }

    function updateEngineConfig() {
        const option = engineSelect.options[engineSelect.selectedIndex];
        const currentEngine = engineSelect.value;

        engineDescription.textContent = option ? (option.dataset.description || '') : '';

        panels.forEach(function (panel) {
            toggleEnginePanelInputs(panel, panel.dataset.enginePanel === currentEngine);
        });
    }

    function showAlert(icon, title, text) {
        const message = text ? (title + "\n" + text) : title;
        if (typeof BackendToast !== 'undefined') {
            if (icon === 'success') {
                BackendToast.success(message);
            } else if (icon === 'error') {
                BackendToast.error(message);
            } else {
                // warning/info/unknown 等统一走通用 toast
                BackendToast.show(message);
            }
        }

        // 保持和 Swal.fire().then(...) 语义相近：给用户一点时间看到提示再继续下一步
        return new Promise(function (resolve) {
            setTimeout(resolve, 1200);
        });
    }

    function extractResponseData(response) {
        return (response && response.data) || response || {};
    }

    function testSearchEngineConnection(engine) {
        if (!engine) {
            showAlert('warning', '<?= __('请选择搜索引擎') ?>', '');
            return;
        }

        const formData = new FormData(form);
        formData.set('engine_type', engine);
        const payload = new URLSearchParams();
        formData.forEach(function (value, key) {
            payload.append(key, value);
        });

        if (typeof BackendToast !== 'undefined') {
            BackendToast.show('<?= __('正在测试连接...') ?>');
        }

        window.Weline.Api.request('<?= $this->getUrl('search/backend/engine/test') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: payload
        }).then(function (response) {
            const data = extractResponseData(response);
            return showAlert(
                data.success ? 'success' : 'error',
                data.success ? '<?= __('连接测试成功') ?>' : '<?= __('连接测试失败') ?>',
                data.message || ''
            );
        }).catch(function (error) {
            return showAlert('error', '<?= __('测试请求失败') ?>', error.message || '');
        });
    }

    const engineConnectionTestHandlers = {
        opensearch: function () {
            return testSearchEngineConnection('opensearch');
        },
        meilisearch: function () {
            return testSearchEngineConnection('meilisearch');
        },
        mysql: function () {
            return testSearchEngineConnection('mysql');
        },
        elasticsearch: function () {
            return testSearchEngineConnection('elasticsearch');
        },
        algolia: function () {
            return testSearchEngineConnection('algolia');
        }
    };

    engineSelect.addEventListener('change', updateEngineConfig);

    form.addEventListener('submit', function (event) {
        event.preventDefault();

        const formData = new FormData(form);
        window.Weline.Api.request(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        }).then(function (response) {
            const data = extractResponseData(response);
            if (!data.success) {
                return showAlert('error', '<?= __('保存失败') ?>', data.message || '<?= __('未知错误') ?>');
            }

            return showAlert('success', '<?= __('保存成功') ?>', data.message || '<?= __('配置已成功保存') ?>')
                .then(function () {
                    window.location.href = '<?= $this->getUrl('search/backend/engine/index', ['scope' => $scope]) ?>';
                });
        }).catch(function (error) {
            return showAlert('error', '<?= __('保存请求失败') ?>', error.message || '');
        });
    });

    document.querySelectorAll('.js-test-connection').forEach(function (button) {
        button.addEventListener('click', function () {
            const engine = button.dataset.engine || engineSelect.value;
            const handler = engineConnectionTestHandlers[engine];
            if (handler) {
                handler();
                return;
            }

            testSearchEngineConnection(engine);
        });
    });

    updateEngineConfig();
});
</script>
