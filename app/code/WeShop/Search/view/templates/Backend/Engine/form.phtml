$scopes = $this->getData('scopes') ?? ['default'];
$availableEngines = $this->getData('availableEngines') ?? [];

$isEdit = !empty($config);
$configData = [];
if ($isEdit && !empty($config[SearchEngineConfig::schema_fields_CONFIG_DATA])) {
    $configData = json_decode((string) $config[SearchEngineConfig::schema_fields_CONFIG_DATA], true) ?? [];
}

/** @var SearchEngineEnvConfig $envConfig */
$envConfig = ObjectManager::getInstance(SearchEngineEnvConfig::class);
$engineType = (string) ($config[SearchEngineConfig::schema_fields_ENGINE_TYPE] ?? $envConfig->getDefaultEngineType());

$opensearchConfig = $envConfig->getEngineConfig(SearchEngineConfig::ENGINE_OPENSEARCH);
$meilisearchConfig = $envConfig->getEngineConfig(SearchEngineConfig::ENGINE_MEILISEARCH);
$elasticsearchConfig = $envConfig->getEngineConfig(SearchEngineConfig::ENGINE_ELASTICSEARCH);
$algoliaConfig = $envConfig->getEngineConfig(SearchEngineConfig::ENGINE_ALGOLIA);

if ($engineType === SearchEngineConfig::ENGINE_OPENSEARCH) {
    $opensearchConfig = array_replace($opensearchConfig, $configData);
} elseif ($engineType === SearchEngineConfig::ENGINE_MEILISEARCH) {
    $meilisearchConfig = array_replace($meilisearchConfig, $configData);
} elseif ($engineType === SearchEngineConfig::ENGINE_ELASTICSEARCH) {
    $elasticsearchConfig = array_replace($elasticsearchConfig, $configData);
} elseif ($engineType === SearchEngineConfig::ENGINE_ALGOLIA) {
    $algoliaConfig = array_replace($algoliaConfig, $configData);
}
