$scope = $this->getData('scope') ?? 'default';
$scopes = $this->getData('scopes') ?? ['default'];
$configs = $this->getData('configs') ?? [];
$availableEngines = $this->getData('availableEngines') ?? [];
?>
<div class="content-header">
    <h1 class="page-title"><?= __('搜索引擎配置管理') ?></h1>
</div>

<div class="content">
    <div class="row">
        <div class="col-md-12">
            <!-- Scope选择器 -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title"><?= __('作用域选择') ?></h5>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="scope-select"><?= __('当前作用域') ?>:</label>
                        <select id="scope-select" class="form-control" style="max-width: 300px;">
                            <?php foreach ($scopes as $s): ?>
                                <option value="<?= htmlspecialchars($s) ?>" <?= $s === $scope ? 'selected' : '' ?>>
                                    <?= htmlspecialchars($s) ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                        <button type="button" class="btn btn-primary btn-sm mt-2" onclick="addNewScope()">
                            <i class="mdi mdi-plus"></i> <?= __('新增作用域') ?>
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- 配置列表 -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><?= __('搜索引擎配置列表') ?></h5>
                    <a href="<?= $this->getUrl('search/backend/engine/form', ['scope' => $scope]) ?>" class="btn btn-primary btn-sm">
                        <i class="mdi mdi-plus"></i> <?= __('新增配置') ?>
                    </a>
                </div>
                <div class="card-body">
                    <?php if (empty($configs)): ?>
                        <div class="alert alert-info">
                            <?= __('当前作用域暂无配置，请添加搜索引擎配置') ?>
                        </div>
                    <?php else: ?>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th><?= __('引擎类型') ?></th>
                                        <th><?= __('引擎名称') ?></th>
                                        <th><?= __('作用域') ?></th>
                                        <th><?= __('状态') ?></th>
                                        <th><?= __('优先级') ?></th>
                                        <th><?= __('操作') ?></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <?php foreach ($configs as $config): ?>
                                        <?php
                                        $engineType = $config[SearchEngineConfig::schema_fields_ENGINE_TYPE];
                                        $engineInfo = $availableEngines[$engineType] ?? null;
                                        $isActive = (int)($config[SearchEngineConfig::schema_fields_IS_ACTIVE] ?? 0);
                                        ?>
                                        <tr>
                                            <td><?= htmlspecialchars($engineType) ?></td>
                                            <td><?= htmlspecialchars($engineInfo['name'] ?? $engineType) ?></td>
                                            <td><?= htmlspecialchars($config[SearchEngineConfig::schema_fields_SCOPE] ?? 'default') ?></td>
                                            <td>
                                                <?php if ($isActive): ?>
                                                    <span class="badge badge-success"><?= __('启用') ?></span>
                                                <?php else: ?>
                                                    <span class="badge badge-secondary"><?= __('禁用') ?></span>
                                                <?php endif; ?>
                                            </td>
                                            <td><?= htmlspecialchars($config[SearchEngineConfig::schema_fields_PRIORITY] ?? 0) ?></td>
                                            <td>
                                                <a href="<?= $this->getUrl('search/backend/engine/form', ['id' => $config[SearchEngineConfig::schema_fields_ID], 'scope' => $scope]) ?>" 
                                                   class="btn btn-sm btn-info">
                                                    <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                                                </a>
                                                <button type="button" 
                                                        class="btn btn-sm btn-warning" 
                                                        onclick="testConnection('<?= htmlspecialchars($engineType) ?>', '<?= htmlspecialchars($scope) ?>')">
                                                    <i class="mdi mdi-test-tube"></i> <?= __('测试') ?>
                                                </button>
                                                <button type="button" 
                                                        class="btn btn-sm btn-danger" 
                                                        onclick="deleteConfig(<?= $config[SearchEngineConfig::schema_fields_ID] ?>)">
                                                    <i class="mdi mdi-delete"></i> <?= __('删除') ?>
                                                </button>
                                            </td>
                                        </tr>
                                    <?php endforeach; ?>
                                </tbody>
                            </table>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// Scope切换
document.getElementById('scope-select').addEventListener('change', function() {
    const scope = this.value;
    window.location.href = '<?= $this->getUrl('search/backend/engine/index') ?>?scope=' + encodeURIComponent(scope);
});

// 新增作用域
function addNewScope() {
    const scope = prompt('<?= __('请输入新的作用域名称') ?>:', '');
    if (scope && scope.trim()) {
        window.location.href = '<?= $this->getUrl('search/backend/engine/index') ?>?scope=' + encodeURIComponent(scope.trim());
    }
}

// 测试连接
function testConnection(engineType, scope) {
    if (!confirm('<?= __('确定要测试连接吗？') ?>')) {
        return;
    }
    
    var url = '<?= $this->getUrl('search/backend/engine/test') ?>?engine_type=' + encodeURIComponent(engineType) + '&scope=' + encodeURIComponent(scope);
    var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } };
    window.Weline.Api.get(url, { silent: true })
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('连接测试成功') ?>',
                    text: '<?= __('连接正常') ?>',
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log('<?= __('连接测试成功！') ?>');
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('连接测试失败') ?>',
                    text: data.message || '<?= __('未知错误') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('连接测试失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
            }
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('测试请求失败') ?>',
                text: error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('测试请求失败：') ?>' + error.message);
        }
    });
}

// 删除配置
function deleteConfig(configId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认删除') ?>',
            text: '<?= __('确定要删除此配置吗？') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定删除") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#d33'
        }).then((result) => {
            if (result.isConfirmed) {
                performDelete(configId);
            }
        });
    } else {
        if (!confirm('<?= __('确定要删除此配置吗？') ?>')) {
            return;
        }
        performDelete(configId);
    }
}

function performDelete(configId) {
    var url = '<?= $this->getUrl('search/backend/engine/delete') ?>?id=' + configId;
    var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } };
    window.Weline.Api.get(url, { silent: true })
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('删除成功！') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log('<?= __('删除成功！') ?>');
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('删除失败') ?>',
                    text: data.message || '<?= __('未知错误') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('删除失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
            }
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('删除请求失败') ?>',
                text: error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('删除请求失败：') ?>' + error.message);
        }
    });
}
</script>
