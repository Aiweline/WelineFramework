<script>
// 全局 HTML 转义函数（供所有配置渲染函数使用）
function escapeHtml(text) {
    if (text === null || text === undefined) return '';
    return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

// CKEditor 初始化
document.addEventListener('DOMContentLoaded', function() {
    // 存储所有编辑器实例
    window.pageEditors = {};
    
    // 初始化所有带 tinymce-editor 类的 textarea
    const editors = document.querySelectorAll('.tinymce-editor');
    
    editors.forEach(function(textarea) {
        ClassicEditor
            .create(textarea, {
                language: 'zh-cn',
                minHeight: '400px',
                toolbar: [
                    'heading', '|',
                    'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|',
                    'outdent', 'indent', '|',
                    'imageUpload', 'blockQuote', 'insertTable', 'mediaEmbed', '|',
                    'undo', 'redo', '|',
                    'sourceEditing'
                ],
                heading: {
                    options: [
                        { model: 'paragraph', title: '段落', class: 'ck-heading_paragraph' },
                        { model: 'heading1', view: 'h1', title: '标题 1', class: 'ck-heading_heading1' },
                        { model: 'heading2', view: 'h2', title: '标题 2', class: 'ck-heading_heading2' },
                        { model: 'heading3', view: 'h3', title: '标题 3', class: 'ck-heading_heading3' }
                    ]
                },
                image: {
                    toolbar: [
                        'imageTextAlternative', 'imageStyle:inline', 'imageStyle:block', 'imageStyle:side'
                    ]
                },
                table: {
                    contentToolbar: [
                        'tableColumn', 'tableRow', 'mergeTableCells'
                    ]
                }
            })
            .then(editor => {
                // 保存编辑器实例
                window.pageEditors[textarea.id] = editor;
                
                // 设置编辑器最小高度
                const editableElement = editor.ui.view.editable.element;
                if (editableElement) {
                    editableElement.style.minHeight = '400px';
                }
                
                console.log('CKEditor 初始化成功:', textarea.id);
            })
            .catch(error => {
                console.error('CKEditor 初始化失败:', error);
            });
    });
});

// 表单验证和提交
(function() {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.prototype.slice.call(forms).forEach(function(form) {
        form.addEventListener('submit', function(event) {
            // 同步所有 CKEditor 编辑器的内容到 textarea
            if (window.pageEditors) {
                for (let editorId in window.pageEditors) {
                    const editor = window.pageEditors[editorId];
                    const textarea = document.getElementById(editorId);
                    if (textarea) {
                        textarea.value = editor.getData();
                    }
                }
            }
            
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
                form.classList.add('was-validated');
                return false;
            }
            form.classList.add('was-validated');
        }, false);
    });
})();

// 页面句柄自动生成（可选）
document.getElementById('name')?.addEventListener('blur', function() {
    var handleInput = document.getElementById('handle');
    if (!handleInput.value) {
        var name = this.value.toLowerCase()
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9-]/g, '');
        handleInput.value = name;
    }
});

// ==================== 默认语言选择功能 ====================

/**
 * 选择默认语言
 */
function selectDefaultLocale(localeCode, localeName) {
    // 更新搜索框显示
    document.getElementById('defaultLocaleSearch').value = `${localeName} (${localeCode})`;
    
    // 更新隐藏的input值
    document.getElementById('default_locale').value = localeCode;
    
    // 更新下拉列表中的active状态
    document.querySelectorAll('.default-locale-option').forEach(option => {
        const optionCode = option.getAttribute('data-locale-code');
        if (optionCode === localeCode) {
            option.classList.add('active');
            // 添加勾选图标
            if (!option.querySelector('.mdi-check')) {
                option.innerHTML += '<i class="mdi mdi-check float-end"></i>';
            }
        } else {
            option.classList.remove('active');
            // 移除勾选图标
            const checkIcon = option.querySelector('.mdi-check');
            if (checkIcon) {
                checkIcon.remove();
            }
        }
    });
    
    // 自动勾选对应的翻译语言
    const localeCheckbox = document.getElementById('locale_' + localeCode);
    if (localeCheckbox && !localeCheckbox.checked) {
        localeCheckbox.checked = true;
        // 添加标签
        addLocaleTag(localeCode, localeName);
    }
    
    // 关闭下拉列表
    const dropdownBtn = document.getElementById('defaultLocaleDropdownBtn');
    if (dropdownBtn) {
        const dropdown = bootstrap.Dropdown.getInstance(dropdownBtn);
        if (dropdown) {
            dropdown.hide();
        }
    }
}

/**
 * 搜索默认语言
 */
document.getElementById('defaultLocaleSearch')?.addEventListener('input', function() {
    const searchText = this.value.toLowerCase();
    const options = document.querySelectorAll('.default-locale-option');
    
    options.forEach(option => {
        const localeCode = option.getAttribute('data-locale-code');
        const localeName = option.getAttribute('data-locale-name');
        const text = `${localeName} ${localeCode}`.toLowerCase();
        
        // 根据搜索文本显示/隐藏
        const parentLi = option.parentElement;
        if (text.includes(searchText)) {
            parentLi.style.display = 'block';
        } else {
            parentLi.style.display = 'none';
        }
    });
});

/**
 * 点击搜索框时自动展开下拉列表
 */
document.getElementById('defaultLocaleSearch')?.addEventListener('focus', function() {
    const dropdownBtn = document.getElementById('defaultLocaleDropdownBtn');
    if (dropdownBtn && !dropdownBtn.classList.contains('show')) {
        dropdownBtn.click();
    }
});

/**
 * 清空搜索框时恢复当前选中的语言显示
 */
document.getElementById('defaultLocaleSearch')?.addEventListener('blur', function(e) {
    // 延迟执行，避免点击下拉选项时被清空
    setTimeout(() => {
        const currentCode = document.getElementById('default_locale').value;
        if (currentCode) {
            const currentOption = document.querySelector(`.default-locale-option[data-locale-code="${currentCode}"]`);
            if (currentOption) {
                const localeName = currentOption.getAttribute('data-locale-name');
                this.value = `${localeName} (${currentCode})`;
            }
        }
    }, 200);
});

// ==================== 语言标签管理功能 ====================

/**
 * 添加语言标签
 */
function addLocaleTag(localeCode, localeName) {
    // 检查是否已存在
    if (document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`)) {
        return;
    }
    
    // 创建标签
    const tag = document.createElement('span');
    tag.className = 'badge bg-primary me-2 mb-2 py-2 px-3 selected-locale-tag';
    tag.setAttribute('data-locale-code', localeCode);
    tag.style.fontSize = '0.875rem';
    tag.innerHTML = `
        ${localeName} (${localeCode})
        <i class="mdi mdi-close ms-1" 
           style="cursor: pointer;"
           onclick="removeLocaleTag('${localeCode}')"></i>
    `;
    
    // 添加到标签区域
    document.getElementById('selectedLocalesTags').appendChild(tag);
    
    // 勾选对应的checkbox
    const checkbox = document.getElementById('locale_' + localeCode);
    if (checkbox) {
        checkbox.checked = true;
    }
    
    // 隐藏下拉列表中的选项
    const option = document.querySelector(`.locale-option[data-locale-code="${localeCode}"]`);
    if (option) {
        option.style.display = 'none';
    }
    
    // 清空搜索框
    const searchInput = document.getElementById('localeSearch');
    searchInput.value = '';
    
    // 重置下拉列表显示
    resetLocaleDropdown();
    
    // 隐藏提示信息（如果存在）
    updateLocalesHint();
    
    // 保持下拉列表打开并聚焦搜索框，方便继续选择
    const dropdown = document.getElementById('localeDropdown');
    if (dropdown.style.display === 'block') {
        searchInput.focus();
    }
}

/**
 * 移除语言标签
 */
function removeLocaleTag(localeCode) {
    // 移除标签
    const tag = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
    if (tag) {
        tag.remove();
    }
    
    // 取消勾选checkbox
    const checkbox = document.getElementById('locale_' + localeCode);
    if (checkbox) {
        checkbox.checked = false;
    }
    
    // 显示下拉列表中的选项
    const option = document.querySelector(`.locale-option[data-locale-code="${localeCode}"]`);
    if (option) {
        option.style.display = 'block';
    }
    
    // 重置下拉列表显示
    resetLocaleDropdown();
    
    // 更新提示信息（如果没有标签了则显示提示）
    updateLocalesHint();
}

/**
 * 更新语言选择提示信息的显示/隐藏
 */
function updateLocalesHint() {
    const tagsContainer = document.getElementById('selectedLocalesTags');
    const existingHint = document.getElementById('noLocalesHint');
    const selectedTags = document.querySelectorAll('.selected-locale-tag');
    
    if (selectedTags.length === 0) {
        // 没有选择任何语言，显示提示
        if (!existingHint) {
            const hint = document.createElement('div');
            hint.className = 'alert alert-info py-2 px-3 mb-0';
            hint.id = 'noLocalesHint';
            hint.style.fontSize = '0.875rem';
            hint.innerHTML = '<i class="mdi mdi-information-outline me-1"></i>暂未选择支持的语言，请使用下方搜索框添加语言';
            tagsContainer.appendChild(hint);
        }
    } else {
        // 已有选择的语言，隐藏提示
        if (existingHint) {
            existingHint.remove();
        }
    }
}

/**
 * 切换语言下拉列表显示/隐藏
 */
function toggleLocaleDropdown() {
    const dropdown = document.getElementById('localeDropdown');
    const btn = document.getElementById('localeDropdownBtn');
    const icon = btn.querySelector('i');
    
    if (dropdown.style.display === 'none' || dropdown.style.display === '') {
        dropdown.style.display = 'block';
        icon.classList.remove('mdi-chevron-down');
        icon.classList.add('mdi-chevron-up');
        // 自动聚焦搜索框
        document.getElementById('localeSearch').focus();
    } else {
        dropdown.style.display = 'none';
        icon.classList.remove('mdi-chevron-up');
        icon.classList.add('mdi-chevron-down');
    }
}

/**
 * 搜索语言功能
 */
document.getElementById('localeSearch')?.addEventListener('input', function() {
    const searchText = this.value.toLowerCase();
    const options = document.querySelectorAll('.locale-option');
    const dropdown = document.getElementById('localeDropdown');
    const noMatchHint = document.getElementById('noMatchHint');
    
    let hasVisibleOptions = false;
    
    options.forEach(option => {
        const localeCode = option.getAttribute('data-locale-code');
        const localeName = option.getAttribute('data-locale-name');
        const text = `${localeName} ${localeCode}`.toLowerCase();
        
        // 如果已被选中，不显示
        const isSelected = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
        if (isSelected) {
            option.style.display = 'none';
            return;
        }
        
        // 根据搜索文本显示/隐藏
        if (text.includes(searchText)) {
            option.style.display = 'block';
            hasVisibleOptions = true;
        } else {
            option.style.display = 'none';
        }
    });
    
    // 显示/隐藏"未找到匹配"提示
    if (!hasVisibleOptions && searchText) {
        noMatchHint.style.display = 'block';
    } else {
        noMatchHint.style.display = 'none';
    }
    
    // 自动展开下拉列表
    if (dropdown.style.display === 'none' && searchText) {
        dropdown.style.display = 'block';
        const btn = document.getElementById('localeDropdownBtn');
        const icon = btn.querySelector('i');
        icon.classList.remove('mdi-chevron-down');
        icon.classList.add('mdi-chevron-up');
    }
});

/**
 * 点击搜索框时自动展开下拉列表
 */
document.getElementById('localeSearch')?.addEventListener('focus', function() {
    const dropdown = document.getElementById('localeDropdown');
    const btn = document.getElementById('localeDropdownBtn');
    const icon = btn.querySelector('i');
    
    // 先过滤一遍选项（隐藏已选中的）
    resetLocaleDropdown();
    
    // 展开下拉列表
    dropdown.style.display = 'block';
    icon.classList.remove('mdi-chevron-down');
    icon.classList.add('mdi-chevron-up');
});

/**
 * 点击页面其他地方关闭下拉列表
 */
document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('localeDropdown');
    const searchInput = document.getElementById('localeSearch');
    const dropdownBtn = document.getElementById('localeDropdownBtn');
    
    // 如果点击的不是下拉列表、搜索框或按钮，则关闭下拉列表
    if (dropdown && 
        !dropdown.contains(event.target) && 
        event.target !== searchInput && 
        event.target !== dropdownBtn &&
        !dropdownBtn.contains(event.target)) {
        dropdown.style.display = 'none';
        const btn = document.getElementById('localeDropdownBtn');
        const icon = btn.querySelector('i');
        icon.classList.remove('mdi-chevron-up');
        icon.classList.add('mdi-chevron-down');
        // 清空搜索框
        if (searchInput) {
            searchInput.value = '';
            resetLocaleDropdown();
        }
    }
});

/**
 * 重置下拉列表显示（过滤已选中的）
 */
function resetLocaleDropdown() {
    const options = document.querySelectorAll('.locale-option');
    options.forEach(option => {
        const localeCode = option.getAttribute('data-locale-code');
        const isSelected = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
        
        if (isSelected) {
            option.style.display = 'none';
        } else {
            // 如果有搜索文本，按搜索文本过滤
            const searchText = document.getElementById('localeSearch').value.toLowerCase();
            if (searchText) {
                const localeName = option.getAttribute('data-locale-name');
                const text = `${localeName} ${localeCode}`.toLowerCase();
                option.style.display = text.includes(searchText) ? 'block' : 'none';
            } else {
                option.style.display = 'block';
            }
        }
    });
}

