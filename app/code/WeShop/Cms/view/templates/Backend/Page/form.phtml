<script>
// 可视化配置相关的JavaScript函数
(function() {
    // 全局变量
    const visualPageId = <?= $visualPageId ? (int)$visualPageId : 'null' ?>;
    let visualAutoSaveTimer = null;
    const VISUAL_AUTO_SAVE_DELAY = 1000; // 1秒
    let visualConfigGroups = null;
    let currentVisualLanguage = '<?= $pageDefaultLocale ?: '' ?>'; // 当前选择的语言
    const defaultLanguage = '<?= $pageDefaultLocale ?: '' ?>'; // 页面默认语言
    
    // 调试信息
    console.log('📋 可视化配置初始化', {
        visualPageId: visualPageId,
        pageIdType: typeof visualPageId,
        pageIdValid: visualPageId > 0,
        currentLanguage: currentVisualLanguage,
        defaultLanguage: defaultLanguage
    });

    // 打开可视化配置
    window.openVisualConfig = function() {
        document.getElementById('visualConfigWrapper').classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // 始终重新加载配置以确保获取最新的语言配置
        loadVisualStyleConfig();
    };

    // 关闭可视化配置
    window.closeVisualConfig = function() {
        document.getElementById('visualConfigWrapper').classList.remove('active');
        document.body.style.overflow = '';
    };

    // 切换配置区域
    window.toggleSection = function(sectionId) {
        const section = document.getElementById(sectionId);
        if (section) {
            section.classList.toggle('collapsed');
        }
    };

    // 切换设备视图
    window.switchDevice = function(device) {
        // 更新按钮状态
        document.querySelectorAll('.device-btn').forEach(btn => {
            btn.classList.toggle('active', btn.getAttribute('data-device') === device);
        });
        
        // 更新预览容器
        const container = document.getElementById('visualPreviewContainer');
        container.className = 'preview-container device-' + device;
    };

    // 切换全屏模式
    window.toggleFullscreen = function() {
        const wrapper = document.getElementById('visualConfigWrapper');
        const btn = document.getElementById('fullscreenBtn');
        const icon = btn.querySelector('i');
        const panel = document.getElementById('configPanel');
        const floatingBtn = document.getElementById('floatingExpandBtn');
        
        wrapper.classList.toggle('fullscreen-mode');
        btn.classList.toggle('active');
        
        // 切换图标
        if (wrapper.classList.contains('fullscreen-mode')) {
            icon.className = 'mdi mdi-fullscreen-exit';
            btn.title = '<?= __('退出全屏') ?>';
            // 进入全屏时立即收起配置面板
            panel.classList.add('collapsed');
            // 显示悬浮展开按钮
            floatingBtn.style.display = 'block';
            console.log('🖥️ 进入全屏模式 - 配置面板已自动收起');
        } else {
            icon.className = 'mdi mdi-fullscreen';
            btn.title = '<?= __('全屏模式') ?>';
            // 退出全屏时展开配置面板
            panel.classList.remove('collapsed');
            // 隐藏悬浮展开按钮
            floatingBtn.style.display = 'none';
            console.log('🖥️ 退出全屏模式 - 配置面板已展开');
        }
    };

    // 切换配置面板（收起/展开）
    window.toggleConfigPanel = function() {
        const panel = document.getElementById('configPanel');
        const btn = document.getElementById('configPanelToggle');
        const floatingBtn = document.getElementById('floatingExpandBtn');
        const wrapper = document.getElementById('visualConfigWrapper');
        
        panel.classList.toggle('collapsed');
        
        // 更新面板内的收起按钮图标
        if (btn) {
            const icon = btn.querySelector('i');
            if (panel.classList.contains('collapsed')) {
                icon.className = 'mdi mdi-chevron-right';
                btn.title = '<?= __('展开面板') ?>';
            } else {
                icon.className = 'mdi mdi-chevron-left';
                btn.title = '<?= __('收起面板') ?>';
            }
        }
        
        // 控制悬浮展开按钮的显示（仅全屏模式下）
        if (wrapper.classList.contains('fullscreen-mode')) {
            if (panel.classList.contains('collapsed')) {
                floatingBtn.style.display = 'block';
            } else {
                floatingBtn.style.display = 'none';
            }
        }
    };

    // 切换语言
    window.switchVisualLanguage = function(language) {
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log('🌐 语言切换开始');
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log('旧语言:', currentVisualLanguage);
        console.log('新语言:', language);
        
        // 更新当前语言
        currentVisualLanguage = language;
        console.log('✅ 当前语言已更新为:', currentVisualLanguage);
        
        // 显示加载提示
        document.getElementById('visualConfigFields').innerHTML = 
            '<div class="alert alert-info m-3"><i class="mdi mdi-loading mdi-spin"></i> 正在加载 ' + language + ' 语言配置...</div>';
        
        // 重新加载配置（加载指定语言的配置）
        console.log('🔄 开始重新加载配置...');
        loadVisualStyleConfig().then(() => {
            console.log('✅ 配置加载完成');
            // 刷新预览（传递语言参数）
            console.log('🔄 开始刷新预览...');
            refreshVisualPreview();
            console.log('✅ 预览刷新完成');
            console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
            console.log('🎉 语言切换完成！');
            console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        }).catch(error => {
            console.error('❌ 语言切换失败:', error);
        });
    };

    // 更新保存状态
    function updateVisualSaveStatus(status, text) {
        const statusEl = document.getElementById('visualSaveStatus');
        const textEl = document.getElementById('visualSaveStatusText');
        
        statusEl.className = 'save-status ' + status;
        textEl.textContent = text;
    }

    // 自动保存配置
    function autoSaveVisualConfig() {
        // 清除之前的定时器
        if (visualAutoSaveTimer) {
            clearTimeout(visualAutoSaveTimer);
        }
        
        // 设置新的定时器
        visualAutoSaveTimer = setTimeout(async () => {
            updateVisualSaveStatus('saving', '<?= __('保存中...') ?>');
            
            try {
                // 收集所有配置
                const config = {};
                document.querySelectorAll('#visualConfigFields .auto-save-field').forEach(field => {
                    const key = field.getAttribute('data-config-key');
                    config[key] = field.value;
                });
                
                // 准备请求数据（包含样式代码和语言参数）
                const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
                const requestData = {
                    page_id: visualPageId,
                    style_code: styleCode, // 添加样式代码
                    style_config: config,
                    locale: currentVisualLanguage || defaultLanguage // 添加语言参数
                };
                
                console.log('💾 自动保存配置', {
                    url: '<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>',
                    pageId: visualPageId,
                    styleCode: styleCode,
                    locale: currentVisualLanguage,
                    configKeys: Object.keys(config),
                    requestData: requestData
                });
                
                // 发送保存请求
                var saveUrl = '<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>';
                var saveOpts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestData) };
                var response = await window.Weline.Api.request(saveUrl, saveOpts);
                var result = (response && response.data) !== undefined ? response.data : response;
                
                console.log('✅ 保存响应', {
                    success: result.success,
                    message: result.message,
                    debug: result.debug,
                    fullResult: result
                });
                
                if (result.success) {
                    updateVisualSaveStatus('saved', '<?= __('已保存') ?>');
                    
                    // 自动刷新预览
                    refreshVisualPreview();
                } else {
                    updateVisualSaveStatus('error', '<?= __('保存失败') ?>: ' + result.message);
                    console.error('❌ 保存失败:', result);
                }
            } catch (error) {
                updateVisualSaveStatus('error', '<?= __('保存失败') ?>');
                console.error('保存异常:', error);
            }
        }, VISUAL_AUTO_SAVE_DELAY);
    }

    // 刷新预览
    window.refreshVisualPreview = function() {
        const loading = document.getElementById('visualPreviewLoading');
        const iframe = document.getElementById('visualPreviewIframe');
        
        loading.classList.add('active');
        
        // 构建URL，包含语言参数
        let url = iframe.src.split('?')[0] + '?page_id=' + visualPageId;
        if (currentVisualLanguage) {
            url += '&locale=' + currentVisualLanguage;
        }
        url += '&t=' + Date.now();
        
        console.log('🔄 刷新预览:', url);
        
        // 重新加载iframe
        iframe.src = url;
        
        // 监听加载完成
        iframe.onload = function() {
            loading.classList.remove('active');
        };
    };

    // 刷新样式配置（重新扫描模板）
    window.refreshVisualStyleConfig = async function() {
        const btn = event.target.closest('button');
        const icon = btn.querySelector('i');
        
        // 禁用按钮并显示加载动画
        btn.disabled = true;
        icon.classList.remove('mdi-refresh');
        icon.classList.add('mdi-loading', 'mdi-spin');
        
        try {
            console.log('🔄 刷新样式配置...');
            
            // 重新加载配置（这会触发后端的forceScan）
            await loadVisualStyleConfig();
            
            console.log('✅ 样式配置刷新成功');
        } catch (error) {
            console.error('❌ 刷新失败:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('刷新失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('刷新失败：' + error.message);
            }
        } finally {
            // 恢复按钮状态
            btn.disabled = false;
            icon.classList.remove('mdi-loading', 'mdi-spin');
            icon.classList.add('mdi-refresh');
        }
    };

    // 加载样式配置
    async function loadVisualStyleConfig() {
        try {
            const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
            
            if (!styleCode) {
                console.error('样式代码为空');
                document.getElementById('visualConfigFields').innerHTML = 
                    '<div class="alert alert-warning m-3"><?= __('请先选择样式模板') ?></div>';
                return;
            }
            
            // 构建URL，包含 page_id 和 locale 参数
            let url = '<?= $this->getBackendUrl('cms/backend/page/styleConfig') ?>?style_code=' + styleCode;
            if (visualPageId) {
                url += '&page_id=' + visualPageId;
            }
            if (currentVisualLanguage) {
                url += '&locale=' + currentVisualLanguage;
            }
            
            console.log('🔄 正在加载样式配置:', {
                styleCode: styleCode,
                pageId: visualPageId,
                locale: currentVisualLanguage,
                url: url
            });
            
            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            
            console.log('API响应状态:', response.status);
            
            const result = await response.json();
            console.log('📦 API返回结果:', result);
            
            // 显示调试信息
            if (result.debug) {
                console.log('🐛 调试信息:', result.debug);
                console.log('📊 数据结构:', {
                    'all_settings': result.debug.all_settings_structure,
                    'style_settings': result.debug.style_settings_structure,
                    'page_settings_keys': result.debug.page_settings ? Object.keys(result.debug.page_settings) : []
                });
            }
            
            if (result.success && result.data) {
                visualConfigGroups = result.data;
                console.log('配置分组数量:', Object.keys(visualConfigGroups).length);
                renderVisualConfig(visualConfigGroups);
            } else {
                console.error('配置加载失败:', result);
                document.getElementById('visualConfigFields').innerHTML = 
                    '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?>: ' + (result.message || '未知错误') + '</div>';
            }
        } catch (error) {
            console.error('加载配置异常:', error);
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?>: ' + error.message + '</div>';
        }
    }

    // 渲染配置表单（支持两级分组：文件 -> 分组）
    function renderVisualConfig(configGroups) {
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log('🎨 开始渲染可视化配置表单');
        console.log('当前语言:', currentVisualLanguage);
        console.log('配置文件数量:', Object.keys(configGroups || {}).length);
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        
        // 验证数据
        if (!configGroups || typeof configGroups !== 'object') {
            console.error('❌ 配置分组数据无效:', configGroups);
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-danger m-3"><?= __('配置数据格式错误') ?></div>';
            return;
        }
        
        let html = '';
        let configCount = 0;
        
        // 遍历文件级别（header, content, footer）
        for (const fileKey in configGroups) {
            const fileGroup = configGroups[fileKey];
            
            // 跳过没有分组的文件
            if (!fileGroup || !fileGroup.groups || Object.keys(fileGroup.groups).length === 0) {
                console.log('跳过空文件分组:', fileKey);
                continue;
            }
            
            const fileIcon = fileGroup.icon || 'mdi-file';
            
            // 文件级别的大区块（一级折叠，默认展开）
            html += `
                <div class="config-file-section config-section" id="visual_${fileKey}_file">
                    <div class="config-section-header bg-primary text-white" onclick="toggleSection('visual_${fileKey}_file')">
                        <span><i class="mdi ${fileIcon}"></i> ${fileGroup.label || fileKey}</span>
                        <i class="mdi mdi-chevron-down"></i>
                    </div>
                    <div class="config-section-body">
            `;
            
            // 遍历该文件下的分组（layout, style, size等）
            for (const groupKey in fileGroup.groups) {
                const group = fileGroup.groups[groupKey];
                
                if (!group || !group.configs || Object.keys(group.configs).length === 0) {
                    console.log('跳过空分组:', groupKey);
                    continue;
                }
                
                configCount++;
                const icon = group.icon || 'mdi-cog';
                
                // 分组级别的二级折叠（默认收起）
                // 使用 fileKey + groupKey 确保ID唯一性
                html += `
                    <div class="config-section collapsed ms-3" id="visual_${fileKey}_${groupKey}_config">
                        <div class="config-section-header bg-light" onclick="toggleSection('visual_${fileKey}_${groupKey}_config')">
                            <span><i class="mdi ${icon}"></i> ${group.label || groupKey}</span>
                            <i class="mdi mdi-chevron-down"></i>
                        </div>
                        <div class="config-section-body">
                `;
                
                for (const configKey in group.configs) {
                    const config = group.configs[configKey];
                // 优先使用 config.value（后端已合并的值），否则使用 config.default
                const rawValue = config.value !== undefined ? config.value : (config.default || '');
                const currentValue = escapeHtml(rawValue); // 转义 HTML 特殊字符
                const fieldId = `visual_config_${configKey.replace(/\./g, '_')}`;
                
                // 调试日志：显示配置值
                if (config.value !== undefined) {
                    console.log(`✅ [${currentVisualLanguage}] ${configKey}: "${config.value}" (来自页面配置)`);
                } else if (config.default) {
                    console.log(`⚪ [${currentVisualLanguage}] ${configKey}: "${config.default}" (使用模板默认值)`);
                } else {
                    console.log(`❌ [${currentVisualLanguage}] ${configKey}: 无值`);
                }
                
                html += `<div class="mb-3">`;
                html += `<label for="${fieldId}" class="form-label">${escapeHtml(config.label)}</label>`;
                
                switch (config.type) {
                    case 'color':
                        // 处理颜色值：如果是 transparent 或空值，使用 #ffffff 作为默认显示
                        let colorValue = currentValue;
                        let displayValue = currentValue;
                        if (!colorValue || colorValue === 'transparent' || colorValue === '') {
                            displayValue = '#ffffff';
                            colorValue = config.default || '';
                        }
                        // 确保颜色值是有效的hex格式（HTML color input要求）
                        if (!displayValue.startsWith('#')) {
                            displayValue = '#' + displayValue;
                        }
                        
                        html += `
                            <div class="input-group">
                                <input type="color" 
                                       class="form-control form-control-color auto-save-field" 
                                       id="${fieldId}_picker"
                                       data-config-key="${configKey}"
                                       data-linked-input="${fieldId}_text"
                                       value="${displayValue}">
                                <input type="text" 
                                       class="form-control auto-save-field" 
                                       id="${fieldId}_text"
                                       data-config-key="${configKey}"
                                       data-linked-picker="${fieldId}_picker"
                                       value="${escapeHtml(colorValue)}"
                                       placeholder="${escapeHtml(config.default || '')}"
                                       style="flex: 1;">
                            </div>
                        `;
                        break;
                        
                    case 'select':
                        html += `<select class="form-select auto-save-field" id="${fieldId}" data-config-key="${configKey}">`;
                        if (config.options && config.options.length > 0) {
                            config.options.forEach(opt => {
                                const selected = opt === rawValue ? 'selected' : '';
                                html += `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(opt)}</option>`;
                            });
                        }
                        html += `</select>`;
                        break;
                        
                    case 'number':
                        html += `
                            <div class="input-group">
                                <input type="number" 
                                       class="form-control auto-save-field" 
                                       id="${fieldId}"
                                       data-config-key="${configKey}"
                                       value="${currentValue}"
                                       placeholder="${escapeHtml(config.default)}">
                                ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit)}</span>` : ''}
                            </div>
                        `;
                        break;
                        
                    case 'textarea':
                        html += `
                            <textarea class="form-control auto-save-field" 
                                      id="${fieldId}"
                                      data-config-key="${configKey}"
                                      rows="3">${currentValue}</textarea>
                        `;
                        break;
                        
                    default: // text
                        html += `
                            <input type="text" 
                                   class="form-control auto-save-field" 
                                   id="${fieldId}"
                                   data-config-key="${configKey}"
                                   value="${currentValue}"
                                   placeholder="${escapeHtml(config.default || '')}">
                        `;
                }
                
                html += `</div>`;
                }
                
                // 关闭分组
                html += `
                        </div>
                    </div>
                `;
            }
            
            // 关闭文件分组
            html += `
                    </div>
                </div>
            `;
        }
        
        // 检查是否有配置
        if (configCount === 0) {
            console.warn('⚠️ 没有找到任何配置分组');
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-warning m-3"><?= __('当前样式模板没有可配置项') ?></div>';
            return;
        }
        
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log(`✅ 配置表单渲染完成`);
        console.log(`   - 语言: ${currentVisualLanguage}`);
        console.log(`   - 配置分组数: ${configCount}`);
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        document.getElementById('visualConfigFields').innerHTML = html;
        
        // 监听所有自动保存字段
        document.querySelectorAll('#visualConfigFields .auto-save-field').forEach(field => {
            // 颜色选择器和文本框的同步
            if (field.type === 'color') {
                field.addEventListener('input', function() {
                    const linkedInput = this.getAttribute('data-linked-input');
                    if (linkedInput) {
                        const textField = document.getElementById(linkedInput);
                        if (textField) {
                            textField.value = this.value;
                        }
                    }
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            } else if (field.type === 'text' && field.hasAttribute('data-linked-picker')) {
                field.addEventListener('input', function() {
                    const linkedPicker = this.getAttribute('data-linked-picker');
                    if (linkedPicker && this.value.startsWith('#')) {
                        const pickerField = document.getElementById(linkedPicker);
                        if (pickerField) {
                            pickerField.value = this.value;
                        }
                    }
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            } else {
                field.addEventListener('input', function() {
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            }
            
            field.addEventListener('change', function() {
                updateVisualSaveStatus('', '<?= __('未保存') ?>');
                autoSaveVisualConfig();
            });
        });
    }

    // 键盘快捷键
    document.addEventListener('keydown', function(e) {
        // ESC 退出全屏
        if (e.key === 'Escape') {
            const wrapper = document.getElementById('visualConfigWrapper');
            if (wrapper.classList.contains('active')) {
                closeVisualConfig();
            }
        }
    });
})();
</script>
