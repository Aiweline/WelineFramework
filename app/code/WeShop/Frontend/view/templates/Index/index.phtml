<?php
/**
 * WeShop frontend homepage fallback template.
 *
 * This keeps the default storefront homepage usable even when module-relative
 * template resolution is used before a theme page override kicks in.
 */
?>
<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="w-full rounded-xl overflow-hidden mb-12">
        <w:hook name="WeShop_Promotion::frontend::layouts::homepage::hero-banner"/>
        <div class="relative w-full h-[400px] bg-cover bg-center flex items-center p-12 rounded-xl text-white" style="background-image: url('<?= $this->getStaticUrl('assets/images/hero-banner.jpg') ?>');">
            <div class="absolute inset-0 bg-black/40"></div>
            <div class="relative z-10 max-w-md">
                <h1 class="text-4xl font-bold mb-4"><?= __('Summer Sale: Up to 50% Off') ?></h1>
                <p class="text-lg mb-6"><?= __('Find the best deals on your favorite summer items and refresh your space.') ?></p>
                <a href="<?= $this->getUrl('promotion/sale') ?>" class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-6 bg-primary text-white text-base font-bold tracking-[0.015em] hover:bg-blue-600 transition-colors">
                    <span class="truncate"><?= __('Shop Now') ?></span>
                </a>
            </div>
        </div>
    </div>

    <section class="mb-12">
        <w:hook name="WeShop_Promotion::frontend::layouts::homepage::deals-before"/>
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-2xl font-bold tracking-tight text-text-primary-light dark:text-text-primary-dark"><?= __('Deals of the Day') ?></h2>
            <a class="text-sm font-medium text-primary hover:underline" href="<?= $this->getUrl('promotion/deals') ?>"><?= __('View All') ?></a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
            <?php $deals = $this->getData('deals') ?? []; ?>
            <?php foreach ($deals as $product): ?>
                <div class="flex flex-col gap-3 rounded-lg bg-surface-light dark:bg-surface-dark p-4 border border-border-light dark:border-border-dark group transition-shadow hover:shadow-lg">
                    <a href="<?= $this->getUrl('product/view', ['id' => $product['product_id']]) ?>" class="w-full bg-center bg-no-repeat aspect-square bg-cover rounded-lg overflow-hidden" style='background-image: url("<?= $product['image'] ?? '' ?>");'></a>
                    <div>
                        <a href="<?= $this->getUrl('product/view', ['id' => $product['product_id']]) ?>" class="text-base font-medium text-text-primary-light dark:text-text-primary-dark truncate block hover:text-primary"><?= htmlspecialchars($product['name'] ?? '') ?></a>
                        <div class="flex items-center gap-2">
                            <?php
                            $currentPrice = (float) ($product['price'] ?? 0);
                            $originalPrice = (float) ($product['original_price'] ?? $currentPrice);
                            $hasDiscount = $originalPrice > $currentPrice;
                            ?>
                            <?php if ($hasDiscount): ?>
                                <p class="text-lg font-bold text-secondary-dark line-through"><?= $this->formatPrice($originalPrice) ?></p>
                                <p class="text-lg font-bold text-red-500"><?= $this->formatPrice($currentPrice) ?></p>
                            <?php else: ?>
                                <p class="text-lg font-bold text-text-primary-light dark:text-text-primary-dark"><?= $this->formatPrice($currentPrice) ?></p>
                            <?php endif; ?>
                        </div>
                        <?php if ($product['discount_percent'] ?? null): ?>
                            <span class="text-xs font-bold px-2 py-1 bg-secondary text-white rounded-full"><?= $product['discount_percent'] ?>% <?= __('OFF') ?></span>
                        <?php endif; ?>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
        <w:hook name="WeShop_Promotion::frontend::layouts::homepage::deals-after"/>
    </section>

    <section class="mb-12">
        <w:hook name="WeShop_Catalog::frontend::layouts::homepage::categories-before"/>
        <h2 class="text-2xl font-bold tracking-tight text-text-primary-light dark:text-text-primary-dark mb-4"><?= __('Shop by Category') ?></h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <?php $categories = $this->getData('categories') ?? []; ?>
            <?php foreach ($categories as $category): ?>
                <a class="group" href="<?= $this->getUrl('catalog/category/view', ['id' => $category['category_id']]) ?>">
                    <div class="w-full bg-center bg-no-repeat aspect-video bg-cover rounded-xl flex flex-col justify-end p-4 text-white font-bold text-lg transition-transform group-hover:scale-105" style='background-image: linear-gradient(to top, rgba(0,0,0,0.7), transparent), url("<?= $category['image'] ?? '' ?>");'>
                        <?= htmlspecialchars($category['name'] ?? '') ?>
                    </div>
                </a>
            <?php endforeach; ?>
        </div>
        <w:hook name="WeShop_Catalog::frontend::layouts::homepage::categories-after"/>
    </section>

    <w:hook name="WeShop_Frontend::frontend::layouts::homepage::content-after"/>
</div>
