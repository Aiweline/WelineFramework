<script>
(function () {
    var form = document.getElementById('weshop-shipping-form');
    var methodHost = document.querySelector('[data-shipping-methods-host]');
    var submitButton = form ? form.querySelector('button[type="submit"]') : null;
    var toastHost = document.getElementById('weline-notification-container');
    var shippingApiPromise = null;

    if (!form || !methodHost) {
        return;
    }

    function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, function (character) {
            return {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            }[character] || character;
        });
    }

    function showNotification(message, type) {
        if (!toastHost) {
            return;
        }

        var toast = document.createElement('div');
        var toastType = (type && String(type)) ? String(type) : 'info';
        toast.className = 'weline-toast weline-toast--' + toastType;
        toast.textContent = String(message ?? '');

        toastHost.appendChild(toast);
        window.setTimeout(function () {
            toast.remove();
        }, 3500);
    }

    function getShippingApi() {
        if (!shippingApiPromise) {
            shippingApiPromise = Promise.resolve(window.Weline.Api.resource('shipping'));
        }

        return shippingApiPromise;
    }

    function getSelectedMethod() {
        var checked = form.querySelector('input[name="shipping_method"]:checked');
        return checked ? checked.value : '';
    }

    function syncSelectionState() {
        var selected = getSelectedMethod();
        if (!selected) {
            submitButton.disabled = true;
        } else {
            submitButton.disabled = false;
        }
    }

    if (submitButton) {
        submitButton.disabled = true;
    }

    form.addEventListener('change', function (event) {
        var target = event.target;
        if (target && target.name === 'shipping_method') {
            syncSelectionState();
        }
    });

    form.addEventListener('submit', function (event) {
        event.preventDefault();

        var selectedMethod = getSelectedMethod();
        if (!selectedMethod) {
            showNotification('<?= __('Please select a shipping method.') ?>', 'warning');
            return;
        }

        if (submitButton) {
            submitButton.disabled = true;
        }

        getShippingApi().then(function (ShippingApi) {
            return ShippingApi.calculate({shipping_method: selectedMethod}, {silent: true});
        }).then(function (payload) {
            if (payload && payload.success) {
                var nextUrl = '<?= $this->getUrl('checkout') ?>';
                if (payload.data && payload.data.redirect_url) {
                    nextUrl = payload.data.redirect_url;
                }
                window.location.href = nextUrl;
            } else {
                showNotification((payload && payload.message) || '<?= __('Unable to process shipping method.') ?>', 'error');
            }
        }).catch(function (error) {
            console.error('Shipping form error:', error);
            showNotification('<?= __('Unable to process shipping method.') ?>', 'error');
        }).finally(function () {
            if (submitButton) {
                submitButton.disabled = false;
            }
        });
    });

    syncSelectionState();
})();
</script>

