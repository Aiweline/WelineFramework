<link href="@static(WeShop_QA::css/qa.css)" rel="stylesheet" type="text/css"/>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0"><?= htmlspecialchars($page_title ?? __('Q&A Management')) ?></h4>
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="@backend-url('*/backend')"><?= __('WeShop') ?></a></li>
                        <li class="breadcrumb-item"><a href="@backend-url('*/backend/qa')"><?= __('Q&A') ?></a></li>
                        <li class="breadcrumb-item active"><?= __('List') ?></li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title"><?= __('Questions List') ?></h4>
                    <p class="card-title-desc"><?= __('Review and manage customer questions') ?></p>

                    <div class="table-responsive">
                        <table id="qa-table" class="table table-striped table-bordered">
                            <thead>
                            <tr>
                                <th data-priority="1"><?= __('ID') ?></th>
                                <th data-priority="1"><?= __('Product ID') ?></th>
                                <th data-priority="1"><?= __('Customer ID') ?></th>
                                <th data-priority="2"><?= __('Question') ?></th>
                                <th data-priority="2"><?= __('Answer') ?></th>
                                <th data-priority="3"><?= __('Status') ?></th>
                                <th data-priority="3"><?= __('Created') ?></th>
                                <th data-priority="1"><?= __('Actions') ?></th>
                            </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof DataTable === 'undefined') {
        console.warn('DataTable not loaded');
        return;
    }

    const qaTable = new DataTable('#qa-table', {
        processing: true,
        serverSide: true,
        ajax: {
            url: '@backend-url("*/api/qa/list")',
            type: 'GET',
            data: function(d) {
                d.status = '{{status}}';
            }
        },
        columns: [
            { data: 'question_id', name: 'question_id' },
            { data: 'product_id', name: 'product_id' },
            { data: 'customer_id', name: 'customer_id' },
            { data: 'question', name: 'question', render: function(data) {
                if (data && data.length > 100) {
                    return '<span title="' + htmlEscape(data) + '">' + htmlEscape(data.substring(0, 100)) + '...</span>';
                }
                return htmlEscape(data || '');
            }},
            { data: 'answer', name: 'answer', render: function(data) {
                if (!data) {
                    return '<span class="text-muted"><?= __('Not answered yet') ?></span>';
                }
                if (data.length > 100) {
                    return '<span title="' + htmlEscape(data) + '">' + htmlEscape(data.substring(0, 100)) + '...</span>';
                }
                return htmlEscape(data);
            }},
            { data: 'status', name: 'status', render: function(data) {
                const statusMap = {
                    'pending': '<span class="badge bg-warning"><?= __('Pending') ?></span>',
                    'approved': '<span class="badge bg-success"><?= __('Approved') ?></span>',
                    'rejected': '<span class="badge bg-danger"><?= __('Rejected') ?></span>'
                };
                return statusMap[data] || '<span class="badge bg-secondary">' + htmlEscape(data) + '</span>';
            }},
            { data: 'created_at', name: 'created_at' },
            { data: 'actions', name: 'actions', orderable: false, searchable: false, render: function(data, type, row) {
                const viewUrl = '<?= $view_url ?? '' ?>'.replace('id=0', 'id=' + row.question_id);
                const approveUrl = '<?= $approve_url ?? '' ?>'.replace('id=0', 'id=' + row.question_id);
                const rejectUrl = '<?= $reject_url ?? '' ?>'.replace('id=0', 'id=' + row.question_id);

                let actions = '<div class="d-flex gap-2">';
                actions += '<a href="' + viewUrl + '" class="btn btn-outline-primary btn-sm" title="<?= __('View') ?>">';
                actions += '<i class="mdi mdi-eye-outline"></i></a>';

                if (row.status === 'pending') {
                    actions += '<button class="btn btn-outline-success btn-sm" ';
                    actions += 'w-ajax="' + approveUrl + '" ';
                    actions += 'w-method="post" ';
                    actions += 'w-msg="<?= __('Are you sure you want to approve this question?') ?>" ';
                    actions += 'title="<?= __('Approve') ?>">';
                    actions += '<i class="mdi mdi-check"></i></button>';

                    actions += '<button class="btn btn-outline-danger btn-sm" ';
                    actions += 'w-ajax="' + rejectUrl + '" ';
                    actions += 'w-method="post" ';
                    actions += 'w-msg="<?= __('Are you sure you want to reject this question?') ?>" ';
                    actions += 'title="<?= __('Reject') ?>">';
                    actions += '<i class="mdi mdi-close"></i></button>';
                }

                actions += '</div>';
                return actions;
            }}
        ],
        order: [[0, 'desc']],
        pageLength: 10,
        language: {
            emptyTable: '<?= __('No questions found') ?>',
            loadingRecords: '<?= __('Loading...') ?>',
            processing: '<?= __('Processing...') ?>'
        }
    });

    function htmlEscape(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
});
</script>

<js:part name="w-delete"/>
