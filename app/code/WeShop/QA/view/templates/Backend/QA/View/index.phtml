<script>
document.addEventListener('DOMContentLoaded', function() {
    const answerForm = document.getElementById('answer-form');
    const approveUrl = '<?= $approve_url ?? '' ?>'.replace('id=0', 'id=<?= $questionId ?>');
    const rejectUrl = '<?= $reject_url ?? '' ?>'.replace('id=0', 'id=<?= $questionId ?>');

    // Approve with answer form
    if (answerForm) {
        answerForm.addEventListener('submit', function(event) {
            event.preventDefault();

            if (!answerForm.checkValidity()) {
                answerForm.classList.add('was-validated');
                return;
            }

            const formData = new FormData(answerForm);
            const data = {};
            formData.forEach((value, key) => {
                data[key] = value;
            });

            fetch(approveUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (result.success || result.redirect) {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success('<?= __('Question approved successfully') ?>');
                    }
                    setTimeout(function() {
                        window.location.href = '<?= $back_url ?? '' ?>';
                    }, 500);
                } else {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(result.message || '<?= __('Failed to approve question') ?>');
                    }
                }
            })
            .catch(error => {
                console.error('Approve error:', error);
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('An error occurred') ?>');
                }
            });
        });
    }

    // Quick approve button
    const quickApproveBtn = document.getElementById('quick-approve-btn');
    if (quickApproveBtn) {
        quickApproveBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show({
                    title: '<?= __('Confirm Approve') ?>',
                    message: '<?= __('Are you sure you want to approve this question without an answer?') ?>',
                    onConfirm: function() {
                        fetch(approveUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({ id: <?= $questionId ?> })
                        })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success || result.redirect) {
                                if (typeof BackendToast !== 'undefined') {
                                    BackendToast.success('<?= __('Question approved successfully') ?>');
                                }
                                setTimeout(function() {
                                    window.location.href = '<?= $back_url ?? '' ?>';
                                }, 500);
                            }
                        });
                    }
                });
            } else {
                // BackendConfirm 未加载时，避免使用浏览器原生确认弹窗
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('Confirmation dialog is not available') ?>');
                }
            }
        });
    }

    // Quick reject button
    const quickRejectBtn = document.getElementById('quick-reject-btn');
    if (quickRejectBtn) {
        quickRejectBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show({
                    title: '<?= __('Confirm Reject') ?>',
                    message: '<?= __('Are you sure you want to reject this question? This action cannot be undone.') ?>',
                    onConfirm: function() {
                        fetch(rejectUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({ id: <?= $questionId ?> })
                        })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success || result.redirect) {
                                if (typeof BackendToast !== 'undefined') {
                                    BackendToast.success('<?= __('Question rejected successfully') ?>');
                                }
                                setTimeout(function() {
                                    window.location.href = '<?= $back_url ?? '' ?>';
                                }, 500);
                            }
                        });
                    }
                });
            } else {
                // BackendConfirm 未加载时，避免使用浏览器原生确认弹窗
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('Confirmation dialog is not available') ?>');
                }
            }
        });
    }

    // Reject button in form
    const rejectBtn = document.getElementById('reject-btn');
    if (rejectBtn) {
        rejectBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show({
                    title: '<?= __('Confirm Reject') ?>',
                    message: '<?= __('Are you sure you want to reject this question? This action cannot be undone.') ?>',
                    onConfirm: function() {
                        fetch(rejectUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({ id: <?= $questionId ?> })
                        })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success || result.redirect) {
                                if (typeof BackendToast !== 'undefined') {
                                    BackendToast.success('<?= __('Question rejected successfully') ?>');
                                }
                                setTimeout(function() {
                                    window.location.href = '<?= $back_url ?? '' ?>';
                                }, 500);
                            }
                        });
                    }
                });
            } else {
                // BackendConfirm 未加载时，避免使用浏览器原生确认弹窗
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('Confirmation dialog is not available') ?>');
                }
            }
        });
    }
});
</script>
