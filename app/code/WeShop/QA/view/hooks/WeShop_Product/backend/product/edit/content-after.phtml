<?php
/**
 * Product edit QA management panel.
 *
 * @hook-priority 230
 * @hook-sort-order 30
 * @hook-solo false
 */
use WeShop\QA\Model\Question;
use WeShop\QA\Service\QAService;
use Weline\Framework\Manager\ObjectManager;

$this->request->addModule('WeShop_QA');
\Weline\Framework\Phrase\Parser::$loaded = false;

$product = $this->getData('product');
$productId = 0;
$progress = '';
if (is_object($product)) {
    if (method_exists($product, 'getId')) {
        $productId = (int) $product->getId();
    }
    if ($productId <= 0 && method_exists($product, 'getData')) {
        $productId = (int) ($product->getData('product_id') ?? 0);
    }
    if (method_exists($product, 'getData')) {
        $progress = (string) ($product->getData('progress') ?? '');
    }
} elseif (is_array($product)) {
    $productId = (int) ($product['product_id'] ?? $product['id'] ?? 0);
    $progress = (string) ($product['progress'] ?? '');
}

$questions = [];
$summary = [
    'total' => 0,
    'pending' => 0,
    'approved' => 0,
    'rejected' => 0,
    'recommended' => 0,
    'system' => 0,
    'customer' => 0,
    'order' => 0,
    'anonymous' => 0,
];
$loadError = '';
$qaListUrl = $this->getBackendUrl('*/backend/qa', ['product_id' => $productId]);

if ($productId > 0) {
    try {
        /** @var QAService $qaService */
        $qaService = ObjectManager::getInstance(QAService::class);
        $questions = $qaService->getProductQuestionAdminList($productId, 12);
        $summary = array_merge($summary, $qaService->getProductQuestionSummary($productId));
    } catch (\Throwable $throwable) {
        $loadError = (string) __('加载当前商品问答失败：%{1}', [$throwable->getMessage()]);
    }
}

$statusBadgeMap = [
    QAService::STATUS_PENDING => 'bg-warning',
    QAService::STATUS_APPROVED => 'bg-success',
    QAService::STATUS_REJECTED => 'bg-danger',
];
$statusLabelMap = [
    QAService::STATUS_PENDING => (string) __('Pending'),
    QAService::STATUS_APPROVED => (string) __('Approved'),
    QAService::STATUS_REJECTED => (string) __('Rejected'),
];
?>
<div class='tab-pane <?= $progress === 'product_qa' ? 'active' : '' ?>' id='product_qa'>
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <h5 class="mb-1"><i class="mdi mdi-comment-question-outline me-2"></i><?= __('当前商品问答') ?></h5>
                    <p class="text-muted mb-0"><?= __('在商品编辑页查看系统 FAQ、客户问答和已下单用户问答。') ?></p>
                </div>
                <?php if ($productId > 0): ?>
                    <a href="<?= htmlspecialchars($qaListUrl, ENT_QUOTES, 'UTF-8') ?>" class="btn btn-outline-primary btn-sm">
                        <i class="mdi mdi-open-in-new me-1"></i><?= __('查看全部问答') ?>
                    </a>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <?php if ($productId <= 0): ?>
        <div class="alert alert-info mb-0">
            <i class="mdi mdi-information-outline me-1"></i><?= __('保存商品后即可查看问答。') ?>
        </div>
    <?php elseif ($loadError !== ''): ?>
        <div class="alert alert-danger mb-0">
            <i class="mdi mdi-alert-circle-outline me-1"></i><?= htmlspecialchars($loadError, ENT_QUOTES, 'UTF-8') ?>
        </div>
    <?php else: ?>
        <div class="row mb-3">
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Total Questions') ?></div>
                    <div class="fs-4 fw-semibold"><?= (int) ($summary['total'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('推荐') ?></div>
                    <div class="fs-4 fw-semibold text-primary"><?= (int) ($summary['recommended'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('已下单用户') ?></div>
                    <div class="fs-4 fw-semibold text-success"><?= (int) ($summary['order'] ?? 0) ?></div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small"><?= __('Pending') ?></div>
                    <div class="fs-4 fw-semibold text-warning"><?= (int) ($summary['pending'] ?? 0) ?></div>
                </div>
            </div>
        </div>

        <?php if ($questions === []): ?>
            <div class="text-center text-muted py-5 border rounded">
                <i class="mdi mdi-comment-question-outline font-size-48 d-block mb-3"></i>
                <p class="mb-0"><?= __('暂无商品问答。') ?></p>
            </div>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th><?= __('来源') ?></th>
                        <th><?= __('问题') ?></th>
                        <th><?= __('回复') ?></th>
                        <th><?= __('Status') ?></th>
                        <th><?= __('Created At') ?></th>
                        <th><?= __('Actions') ?></th>
                    </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($questions as $question): ?>
                        <?php
                        $questionId = (int) ($question[Question::schema_fields_ID] ?? 0);
                        $sourceType = (string) ($question[Question::schema_fields_SOURCE_TYPE] ?? QAService::SOURCE_CUSTOMER);
                        $status = (string) ($question[Question::schema_fields_STATUS] ?? QAService::STATUS_PENDING);
                        $badgeClass = $statusBadgeMap[$status] ?? 'bg-secondary';
                        $statusLabel = $statusLabelMap[$status] ?? ucfirst($status);
                        $sourceLabel = $qaService->getSourceTypeLabel($sourceType);
                        $displayName = trim((string) ($question[Question::schema_fields_DISPLAY_NAME] ?? ''));
                        $detailUrl = $this->getBackendUrl('*/backend/qa/view', ['id' => $questionId]);
                        ?>
                        <tr>
                            <td><strong>#<?= $questionId ?></strong></td>
                            <td>
                                <span class="badge bg-light text-dark border"><?= htmlspecialchars($sourceLabel, ENT_QUOTES, 'UTF-8') ?></span>
                                <?php if ((int) ($question[Question::schema_fields_IS_RECOMMENDED] ?? 0) === 1): ?>
                                    <span class="badge bg-primary ms-1"><?= __('推荐') ?></span>
                                <?php endif; ?>
                                <?php if ($displayName !== ''): ?>
                                    <div class="small text-muted mt-1"><?= htmlspecialchars($displayName, ENT_QUOTES, 'UTF-8') ?></div>
                                <?php endif; ?>
                            </td>
                            <td style="max-width: 320px;">
                                <div class="fw-semibold text-truncate"><?= htmlspecialchars((string) ($question[Question::schema_fields_QUESTION] ?? ''), ENT_QUOTES, 'UTF-8') ?></div>
                            </td>
                            <td style="max-width: 320px;">
                                <?php $answer = trim((string) ($question[Question::schema_fields_ANSWER] ?? '')); ?>
                                <?php if ($answer !== ''): ?>
                                    <div class="small text-muted text-truncate"><?= htmlspecialchars($answer, ENT_QUOTES, 'UTF-8') ?></div>
                                <?php else: ?>
                                    <span class="text-muted">-</span>
                                <?php endif; ?>
                            </td>
                            <td>
                                <span class="badge <?= $badgeClass ?>"><?= htmlspecialchars($statusLabel, ENT_QUOTES, 'UTF-8') ?></span>
                            </td>
                            <td><?= htmlspecialchars((string) ($question[Question::schema_fields_CREATED_AT] ?? '-'), ENT_QUOTES, 'UTF-8') ?></td>
                            <td>
                                <a href="<?= htmlspecialchars($detailUrl, ENT_QUOTES, 'UTF-8') ?>" class="btn btn-outline-info btn-sm" title="<?= __('View') ?>">
                                    <i class="mdi mdi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
    <?php endif; ?>
</div>
