<?php
/**
 * Product edit QA tab navigation.
 *
 * @hook-priority 230
 * @hook-sort-order 30
 * @hook-solo false
 */
$this->request->addModule('WeShop_QA');
\Weline\Framework\Phrase\Parser::$loaded = false;

$product = $this->getData('product');
$type = (string) ($this->getData('type') ?? 'simple');
$stepNumber = $type === 'configurable' ? 6 : 5;
$progress = '';
if (is_object($product) && method_exists($product, 'getData')) {
    $progress = (string) ($product->getData('progress') ?? '');
} elseif (is_array($product)) {
    $progress = (string) ($product['progress'] ?? '');
}
?>
<li class='nav-item'>
    <a href='#product_qa'
       class='nav-link <?= $progress === 'product_qa' ? 'active' : '' ?>'
       scope="edit_product"
       name="progress"
       value="product_qa"
       data-index="5"
       data-toggle='tab'>
        <span class='step-number'><?= $stepNumber ?></span>
        <span class='step-title'><lang>问答/FAQ</lang></span>
        <span class='help-block'>
            <span class='text-primary'><lang>当前商品</lang></span>
        </span>
    </a>
</li>
