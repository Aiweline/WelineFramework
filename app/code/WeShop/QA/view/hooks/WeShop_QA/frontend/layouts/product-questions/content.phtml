<?php
/**
 * QA product tab hook.
 *
 * @hook-priority 220
 * @hook-sort-order 12
 * @hook-solo false
 */
$product = (array) ($this->getData('product') ?? []);
$qaList = (array) ($this->getData('qa_list') ?? $this->getData('qa') ?? []);
$productId = (int) ($product['product_id'] ?? $this->getData('product_id') ?? 0);
?>
<section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
    <div class="flex items-center justify-between gap-4">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><?= __('Questions & Answers') ?></p>
            <h3 class="mt-2 text-xl font-bold text-text-primary-light dark:text-text-primary-dark"><?= __('Community Q&A') ?></h3>
        </div>
        <?php if ($productId > 0): ?>
            <a href="<?= $this->getUrl('qa', ['product_id' => $productId]) ?>" class="text-sm font-semibold text-primary hover:underline"><?= __('Open Full Q&A') ?></a>
        <?php endif; ?>
    </div>

    <?php if ($qaList): ?>
        <div class="mt-5 space-y-3">
            <?php foreach (array_slice($qaList, 0, 3) as $qaItem): ?>
                <article class="rounded-2xl border border-border-light bg-background-light p-4 dark:border-border-dark dark:bg-background-dark">
                    <p class="font-semibold text-text-primary-light dark:text-text-primary-dark"><?= htmlspecialchars((string) ($qaItem['question'] ?? ''), ENT_QUOTES) ?></p>
                    <?php if (!empty($qaItem['answer'])): ?>
                        <p class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark"><?= htmlspecialchars((string) $qaItem['answer'], ENT_QUOTES) ?></p>
                    <?php else: ?>
                        <p class="mt-2 text-sm text-text-secondary-light dark:text-text-secondary-dark"><?= __('Awaiting a verified answer from the store team.') ?></p>
                    <?php endif; ?>
                </article>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="mt-5 rounded-2xl border border-dashed border-border-light bg-background-light px-5 py-8 text-sm leading-6 text-text-secondary-light dark:border-border-dark dark:bg-background-dark dark:text-text-secondary-dark">
            <?= __('No questions yet. Start the first question to help future buyers.') ?>
        </div>
    <?php endif; ?>
</section>
