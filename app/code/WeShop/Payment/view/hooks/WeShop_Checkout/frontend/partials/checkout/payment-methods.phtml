<?php
/**
 * Checkout payment method radios.
 *
 * @hook-priority 200
 * @hook-sort-order 10
 * @hook-solo false
 */
$paymentMethods = $this->getData('payment_methods') ?? [];
if (!is_array($paymentMethods) || $paymentMethods === []) {
    ?>
    <div class="weshop-checkout-empty"><?= __('当前结账上下文没有可用支付方式。') ?></div>
    <?php
    return;
}

$hasExplicitDefault = false;
foreach ($paymentMethods as $paymentMethod) {
    if (is_array($paymentMethod) && !empty($paymentMethod['is_default'])) {
        $hasExplicitDefault = true;
        break;
    }
}
?>
<div class="weshop-checkout-choice-list" data-weshop-payment-method-list>
    <?php foreach ($paymentMethods as $index => $method): ?>
        <?php
        if (!is_array($method)) {
            continue;
        }
        $code = (string) ($method['code'] ?? '');
        $title = (string) ($method['title'] ?? $method['name'] ?? $code);
        $description = trim((string) ($method['description'] ?? ''));
        $checkoutNote = trim((string) ($method['checkout_note'] ?? ''));
        $helperText = $checkoutNote !== '' ? $checkoutNote : $description;
        $checked = !empty($method['is_default']) || (!$hasExplicitDefault && $index === 0);
        ?>
        <label class="weshop-checkout-choice">
            <input
                type="radio"
                name="payment_method"
                value="<?= htmlspecialchars($code, ENT_QUOTES) ?>"
                <?= $checked ? 'checked' : '' ?>
                required
            >
            <span>
                <div class="weshop-checkout-choice-title"><?= htmlspecialchars($title, ENT_QUOTES) ?></div>
                <?php if ($helperText !== ''): ?>
                    <div class="weshop-checkout-choice-meta"><?= htmlspecialchars($helperText, ENT_QUOTES) ?></div>
                <?php endif; ?>
            </span>
        </label>
    <?php endforeach; ?>
</div>
