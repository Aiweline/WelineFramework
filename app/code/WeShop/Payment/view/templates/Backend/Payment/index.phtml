        return (string) $documentation['html'];
    }

    return '<p>' . htmlspecialchars((string) __('该支付方式缺少完整配置文档，不能启用。'), ENT_QUOTES, 'UTF-8') . '</p>';
};
$tabUrl = static function (string $tab) use ($filterUrl, $filters): string {
    $query = $filters;
    $query['tab'] = $tab;

    return $filterUrl . ($query !== [] ? '?' . http_build_query($query) : '');
};
