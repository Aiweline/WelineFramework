    return $providerBrands[$providerCode] ?? ['mark' => strtoupper(substr($providerCode, 0, 2)), 'bg' => '#475569', 'fg' => '#ffffff', 'icon' => 'mdi-credit-card-settings-outline'];
};
$methodIcon = static function (string $methodType): string {
    return match ($methodType) {
        'bank' => 'mdi-bank-transfer',
        'wallet' => 'mdi-wallet-outline',
        'card' => 'mdi-credit-card-outline',
        'bnpl' => 'mdi-calendar-clock-outline',
        'cash' => 'mdi-cash',
        'credit' => 'mdi-account-credit-card-outline',
        default => 'mdi-credit-card-settings-outline',
    };
};

$renderConfigFields = static function (array $method) use ($h): void {
    $code = (string) ($method['code'] ?? '');
    $config = is_array($method['config'] ?? null) ? $method['config'] : [];
    $configFields = is_array($method['config_fields'] ?? null) ? $method['config_fields'] : [];
    if ($configFields === []) {
        return;
    }
    ?>
    <div class="row g-3 mt-2">
        <?php foreach ($configFields as $field): ?>
            <?php
            if (!is_array($field)) {
                continue;
            }
            $fieldKey = (string) ($field['key'] ?? '');
            if ($fieldKey === '') {
                continue;
            }
            $fieldType = (string) ($field['type'] ?? 'text');
            $fieldLabel = (string) ($field['label'] ?? $fieldKey);
            $fieldHelp = (string) ($field['help'] ?? '');
            $fieldValue = $config[$fieldKey] ?? '';
            $inputName = 'methods[' . $code . '][config][' . $fieldKey . ']';
            ?>
            <div class="col-md-6 col-xl-4">
                <label class="form-label fw-semibold"><?= $h($fieldLabel) ?></label>
                <?php if ($fieldType === 'textarea'): ?>
                    <textarea class="form-control" rows="3" name="<?= $h($inputName) ?>"><?= $h($fieldValue) ?></textarea>
                <?php elseif ($fieldType === 'checkbox'): ?>
                    <input type="hidden" name="<?= $h($inputName) ?>" value="0">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" role="switch" name="<?= $h($inputName) ?>" value="1" <?= !empty($fieldValue) ? 'checked' : '' ?>>
                    </div>
                <?php elseif ($fieldType === 'select'): ?>
                    <select class="form-select" name="<?= $h($inputName) ?>">
                        <?php foreach ((array) ($field['options'] ?? []) as $optionValue => $optionLabel): ?>
                            <option value="<?= $h($optionValue) ?>" <?= (string) $fieldValue === (string) $optionValue ? 'selected' : '' ?>><?= $h($optionLabel) ?></option>
                        <?php endforeach; ?>
                    </select>
                <?php else: ?>
                    <input
                        class="form-control"
                        type="<?= $h($fieldType) ?>"
                        name="<?= $h($inputName) ?>"
                        value="<?= $fieldType === 'password' ? '' : $h($fieldValue) ?>"
                        <?= $fieldType === 'password' ? 'autocomplete="off" placeholder="' . $h(__('留空表示不修改')) . '"' : '' ?>
                        <?php if (!empty($field['step'])): ?>step="<?= $h($field['step']) ?>"<?php endif; ?>
                    >
                <?php endif; ?>
                <?php if ($fieldHelp !== ''): ?>
                    <div class="form-text"><?= $h($fieldHelp) ?></div>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>
    </div>
    <?php
};

$renderMethod = static function (array $method, bool $showConfig = true) use ($h, $docHtml, $methodIcon, $providerBrand, $renderConfigFields, $selectedCountry): void {
    $code = (string) ($method['code'] ?? '');
    if ($code === '') {
        return;
    }
    $providerCode = (string) ($method['provider_code'] ?? '');
    $brand = $providerBrand($providerCode);
    $iconClass = (string) ($brand['icon'] ?? $methodIcon((string) ($method['method_type'] ?? '')));
    $countryTags = array_values(array_filter(array_map(static fn(mixed $value): string => strtoupper((string) $value), (array) ($method['country_tags'] ?? []))));
    if ($selectedCountry !== '' && in_array($selectedCountry, $countryTags, true)) {
        $countryTags = array_values(array_unique(array_merge([$selectedCountry], $countryTags)));
    }
    $visibleTags = array_slice($countryTags, 0, 18);
    $hiddenTagCount = max(0, count($countryTags) - count($visibleTags));
    $missingConfig = (array) ($method['missing_config'] ?? []);
    $documentation = is_array($method['documentation'] ?? null) ? $method['documentation'] : [];
    $testStatus = (string) ($method['config_test_status'] ?? 'untested');
    $testMessage = (string) ($method['config_test_message'] ?? '');
    $testedAt = (string) ($method['config_tested_at'] ?? '');
    $testBadgeClass = match ($testStatus) {
        'passed' => 'bg-success-subtle text-success',
        'failed' => 'bg-danger-subtle text-danger',
        default => 'bg-secondary-subtle text-secondary',
    };
    $testBadgeLabel = match ($testStatus) {
        'passed' => __('配置已测试'),
        'failed' => __('测试失败'),
        default => __('未测试'),
    };
    ?>
    <div class="border rounded-2 bg-white p-3 payment-method-item" data-payment-method="<?= $h($code) ?>">
        <div class="d-flex flex-column flex-xl-row justify-content-between gap-3">
            <div class="payment-brand-mark flex-shrink-0" style="--payment-brand-bg: <?= $h((string) $brand['bg']) ?>; --payment-brand-fg: <?= $h((string) $brand['fg']) ?>;">
                <span class="payment-brand-text"><?= $h((string) $brand['mark']) ?></span>
                <i class="mdi <?= $h($iconClass) ?> payment-brand-icon"></i>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <h5 class="mb-0"><?= $h((string) ($method['title'] ?? $code)) ?></h5>
                    <span class="badge bg-secondary-subtle text-secondary"><?= $h((string) ($method['provider_title'] ?? $method['provider_code'] ?? '')) ?></span>
                    <span class="badge bg-info-subtle text-info"><?= $h(strtoupper((string) ($method['environment'] ?? 'sandbox'))) ?></span>
                    <?php if (!empty($method['enabled'])): ?>
                        <span class="badge bg-success-subtle text-success"><?= __('已启用') ?></span>
                    <?php else: ?>
                        <span class="badge bg-warning-subtle text-warning"><?= __('未启用') ?></span>
                    <?php endif; ?>
                    <?php if (!empty($method['is_default'])): ?>
                        <span class="badge bg-primary-subtle text-primary"><?= __('默认') ?></span>
                    <?php endif; ?>
                    <?php if (empty($method['has_documentation'])): ?>
                        <span class="badge bg-danger-subtle text-danger"><?= __('缺文档') ?></span>
                    <?php endif; ?>
                    <?php if (empty($method['is_configured'])): ?>
                        <span class="badge bg-danger-subtle text-danger"><?= __('缺配置') ?></span>
                    <?php endif; ?>
                    <span class="badge <?= $h($testBadgeClass) ?>"><?= $h($testBadgeLabel) ?></span>
                </div>
                <div class="text-muted mb-2"><?= $h((string) ($method['description'] ?? '')) ?></div>
                <div class="small text-muted d-flex flex-wrap gap-3">
                    <span><?= __('代码') ?>: <code><?= $h($code) ?></code></span>
                    <span><?= __('类型') ?>: <?= $h((string) ($method['method_type'] ?? '')) ?></span>
                    <span><?= __('热度') ?>: <?= (int) ($method['popularity_score'] ?? 0) ?></span>
                    <span><?= __('币种') ?>: <?= $h(implode(', ', (array) ($method['currencies'] ?? []))) ?></span>
                </div>
                <div class="d-flex flex-wrap gap-1 mt-2">
                    <?php foreach ($visibleTags as $tag): ?>
                        <span class="badge rounded-pill bg-light text-dark border payment-country-chip"><?= $h($tag) ?></span>
                    <?php endforeach; ?>
                    <?php if ($hiddenTagCount > 0): ?>
                        <span class="badge rounded-pill bg-light text-muted border payment-country-chip">+<?= (int) $hiddenTagCount ?></span>
                    <?php endif; ?>
                </div>
                <?php if ($missingConfig !== []): ?>
                    <div class="small text-danger mt-2"><?= __('缺少必填字段') ?>: <?= $h(implode(', ', $missingConfig)) ?></div>
                <?php endif; ?>
                <?php if ($testMessage !== ''): ?>
                    <div class="small <?= $testStatus === 'passed' ? 'text-success' : 'text-danger' ?> mt-2">
                        <?= $h($testMessage) ?><?= $testedAt !== '' ? ' · ' . $h($testedAt) : '' ?>
                    </div>
                <?php endif; ?>
            </div>

            <div class="d-flex flex-column gap-2" style="min-width: 260px;">
                <button
                    class="btn btn-outline-secondary btn-sm payment-doc-button"
                    type="button"
                    data-doc-id="payment-doc-<?= $h($code) ?>"
                    data-doc-title="<?= $h((string) ($method['title'] ?? $code)) ?>"
                    data-doc-path="<?= $h((string) ($documentation['relative_path'] ?? '')) ?>"
                >
                    <i class="mdi mdi-file-document-outline me-1"></i><?= __('查看配置指南') ?>
                </button>
                <button class="btn btn-outline-primary btn-sm" type="submit" name="test_method" value="<?= $h($code) ?>" formnovalidate>
                    <i class="mdi mdi-shield-check-outline me-1"></i><?= __('测试当前 scope 配置') ?>
                </button>
                <div class="row g-2">
                    <div class="col-4">
                        <label class="form-label small fw-semibold"><?= __('启用') ?></label>
                        <input type="hidden" name="methods[<?= $h($code) ?>][enabled]" value="0">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" name="methods[<?= $h($code) ?>][enabled]" value="1" <?= !empty($method['enabled']) ? 'checked' : '' ?> <?= (empty($method['has_documentation']) || $testStatus !== 'passed') ? 'disabled' : '' ?>>
                        </div>
                    </div>
                    <div class="col-4">
                        <label class="form-label small fw-semibold"><?= __('默认') ?></label>
                        <div class="form-check mt-1">
                            <input class="form-check-input" type="radio" name="default_method" value="<?= $h($code) ?>" <?= !empty($method['is_default']) ? 'checked' : '' ?> <?= empty($method['enabled']) ? 'disabled' : '' ?>>
                        </div>
                    </div>
                    <div class="col-4">
                        <label class="form-label small fw-semibold"><?= __('排序') ?></label>
                        <input class="form-control form-control-sm" type="number" name="methods[<?= $h($code) ?>][sort_order]" value="<?= (int) ($method['sort_order'] ?? 0) ?>">
                    </div>
                </div>
            </div>
        </div>

        <?php if ($showConfig): ?>
            <?php $renderConfigFields($method); ?>
        <?php endif; ?>

        <textarea hidden class="payment-doc-source" id="payment-doc-<?= $h($code) ?>"><?= $h($docHtml($documentation)) ?></textarea>
    </div>
    <?php
};
?>
