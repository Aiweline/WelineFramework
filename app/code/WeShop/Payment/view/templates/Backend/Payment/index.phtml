<script>
function closePaymentDocPanel() {
    const panel = document.getElementById('payment-doc-panel');
    document.body.classList.remove('payment-doc-open');
    if (panel) {
        panel.setAttribute('aria-hidden', 'true');
    }
}

document.addEventListener('click', function (event) {
    const button = event.target.closest('.payment-doc-button');
    const closeButton = event.target.closest('[data-payment-doc-close]');
    if (closeButton) {
        event.preventDefault();
        closePaymentDocPanel();
        return;
    }
    if (!button) {
        return;
    }
    event.preventDefault();
    const docSource = document.getElementById(button.getAttribute('data-doc-id'));
    const panel = document.getElementById('payment-doc-panel');
    if (!docSource || !panel) {
        return;
    }
    const title = panel.querySelector('#payment-doc-title');
    const path = panel.querySelector('#payment-doc-path');
    const content = panel.querySelector('.payment-doc-content');
    if (title) {
        title.textContent = button.getAttribute('data-doc-title') || '<?= $h((string) __('配置指南')) ?>';
    }
    if (path) {
        path.textContent = button.getAttribute('data-doc-path') || '';
    }
    if (content) {
        content.innerHTML = docSource.value;
    }
    panel.setAttribute('aria-hidden', 'false');
    document.body.classList.add('payment-doc-open');
});

document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
        closePaymentDocPanel();
    }
});
</script>
