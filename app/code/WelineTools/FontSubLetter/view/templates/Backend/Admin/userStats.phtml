<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
(function() {
    'use strict';

    // 每日上传趋势图
    var dailyData = {
        labels: [
            <?php foreach ($dailyStats as $stat): ?>
                '<?= $stat['date'] ?>',
            <?php endforeach; ?>
        ],
        datasets: [{
            label: '<?= __('上传数量') ?>',
            data: [
                <?php foreach ($dailyStats as $stat): ?>
                    <?= $stat['count'] ?>,
                <?php endforeach; ?>
            ],
            borderColor: 'rgb(75, 192, 192)',
            backgroundColor: 'rgba(75, 192, 192, 0.2)',
            tension: 0.1
        }]
    };

    var dailyCtx = document.getElementById('dailyChart').getContext('2d');
    new Chart(dailyCtx, {
        type: 'line',
        data: dailyData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    });

    // 用户活跃度分布图
    var activityData = {
        labels: ['<?= __('高活跃用户') ?>', '<?= __('中活跃用户') ?>', '<?= __('低活跃用户') ?>'],
        datasets: [{
            data: [
                <?php
                $highCount = 0;
                $mediumCount = 0;
                $lowCount = 0;
                foreach ($userStats as $user) {
                    $level = $this->getActivityLevel($user['upload_count']);
                    switch ($level) {
                        case 'high': $highCount++; break;
                        case 'medium': $mediumCount++; break;
                        case 'low': $lowCount++; break;
                    }
                }
                echo "$highCount, $mediumCount, $lowCount";
                ?>
            ],
            backgroundColor: [
                '#28a745',
                '#ffc107',
                '#6c757d'
            ]
        }]
    };

    var activityCtx = document.getElementById('activityChart').getContext('2d');
    new Chart(activityCtx, {
        type: 'doughnut',
        data: activityData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
})();
</script>
