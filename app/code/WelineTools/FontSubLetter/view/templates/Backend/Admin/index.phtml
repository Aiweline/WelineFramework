<script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" rel="stylesheet">

<script>
(function() {
    'use strict';

    // 初始化日期选择器
    $('#dateRange').daterangepicker({
        locale: {
            format: 'YYYY-MM-DD',
            applyLabel: '<?= __('确定') ?>',
            cancelLabel: '<?= __('取消') ?>',
            fromLabel: '<?= __('从') ?>',
            toLabel: '<?= __('到') ?>',
            customRangeLabel: '<?= __('自定义') ?>',
            daysOfWeek: ['<?= __('日') ?>', '<?= __('一') ?>', '<?= __('二') ?>', '<?= __('三') ?>', '<?= __('四') ?>', '<?= __('五') ?>', '<?= __('六') ?>'],
            monthNames: ['<?= __('一月') ?>', '<?= __('二月') ?>', '<?= __('三月') ?>', '<?= __('四月') ?>', '<?= __('五月') ?>', '<?= __('六月') ?>', '<?= __('七月') ?>', '<?= __('八月') ?>', '<?= __('九月') ?>', '<?= __('十月') ?>', '<?= __('十一月') ?>', '<?= __('十二月') ?>']
        }
    });

    // 加载图表数据
    function loadChartData() {
        // 每日上传趋势图
        var dailyUrl = '<?= $this->getUrl("fontsubletter/backend/admin/getChartData", ["type" => "daily"]) ?>';
        window.Weline.Api.get(dailyUrl, { silent: true })
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.code === 200) {
                    var ctx = document.getElementById('dailyChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.data.labels,
                            datasets: [{
                                label: '<?= __('上传数量') ?>',
                                data: data.data.data,
                                borderColor: 'rgb(75, 192, 192)',
                                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                                tension: 0.1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false
                        }
                    });
                }
            });

        // 格式分布图
        var formatUrl = '<?= $this->getUrl("fontsubletter/backend/admin/getChartData", ["type" => "format"]) ?>';
        window.Weline.Api.get(formatUrl, { silent: true })
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.code === 200) {
                    var ctx = document.getElementById('formatChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: data.data.labels,
                            datasets: [{
                                data: data.data.data,
                                backgroundColor: [
                                    '#FF6384',
                                    '#36A2EB',
                                    '#FFCE56',
                                    '#4BC0C0'
                                ]
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false
                        }
                    });
                }
            });
    }

    // 暴露给全局的模块接口
    window.FslAdmin = {
        deleteRecord: function(id) {
            if (confirm('<?= __('确定要删除这条记录吗？') ?>')) {
                var url = '<?= $this->getUrl("fontsubletter/backend/record/delete") ?>';
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'id=' + id };
                window.Weline.Api.request(url, opts)
                .then(function(res) {
                    var data = (res && res.data) !== undefined ? res.data : res;
                    if (data.code === 200) {
                        AdminToast.success('<?= __('删除成功') ?>');
                        setTimeout(function() { location.reload(); }, 1000);
                    } else {
                        AdminToast.error(data.msg || '<?= __('删除失败') ?>');
                    }
                })
                .catch(function(error) {
                    AdminToast.error('<?= __('删除失败') ?>: ' + error.message);
                });
            }
        }
    };

    // 页面加载完成后初始化图表
    document.addEventListener('DOMContentLoaded', function() {
        loadChartData();
    });
})();
</script>
