    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 字符类型分布图
        const charTypeData = {
            labels: [
                <?php foreach ($charTypeStats as $type => $stats): ?>
                    <?php if ($stats['count'] > 0): ?>
                        '<?= $typeLabels[$type] ?>',
                    <?php endif; ?>
                <?php endforeach; ?>
            ],
            datasets: [{
                data: [
                    <?php foreach ($charTypeStats as $type => $stats): ?>
                        <?php if ($stats['count'] > 0): ?>
                            <?= $stats['count'] ?>,
                        <?php endif; ?>
                    <?php endforeach; ?>
                ],
                backgroundColor: [
                    <?php foreach ($charTypeStats as $type => $stats): ?>
                        <?php if ($stats['count'] > 0): ?>
                            '<?= $typeColors[$type] ?>',
                        <?php endif; ?>
                    <?php endforeach; ?>
                ]
            }]
        };

        const charTypeCtx = document.getElementById('charTypeChart').getContext('2d');
        new Chart(charTypeCtx, {
            type: 'doughnut',
            data: charTypeData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // 热门字符排行图
        const topCharsData = {
            labels: [
                <?php 
                $top10Chars = array_slice($topChars, 0, 10, true);
                foreach ($top10Chars as $char => $count): 
                ?>
                    '<?= htmlspecialchars($char) ?>',
                <?php endforeach; ?>
            ],
            datasets: [{
                label: '使用次数',
                data: [
                    <?php foreach ($top10Chars as $char => $count): ?>
                        <?= $count ?>,
                    <?php endforeach; ?>
                ],
                backgroundColor: 'rgba(54, 162, 235, 0.8)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        };

        const topCharsCtx = document.getElementById('topCharsChart').getContext('2d');
        new Chart(topCharsCtx, {
            type: 'bar',
            data: topCharsData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
