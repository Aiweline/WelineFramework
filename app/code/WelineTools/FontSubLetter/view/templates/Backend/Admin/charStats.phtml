<script>
(function() {
    'use strict';
    
    var typeLabels = <?= json_encode(array_values($typeLabels)) ?>;
    var typeColors = <?= json_encode(array_values($typeColors)) ?>;
    
    var charTypeData = {
        labels: [
            <?php foreach ($charTypeStats as $type => $stats): ?>
                <?php if ($stats['count'] > 0): ?>
                    '<?= addslashes($typeLabels[$type]) ?>',
                <?php endif; ?>
            <?php endforeach; ?>
        ],
        datasets: [{
            data: [
                <?php foreach ($charTypeStats as $type => $stats): ?>
                    <?php if ($stats['count'] > 0): ?>
                        <?= $stats['count'] ?>,
                    <?php endif; ?>
                <?php endforeach; ?>
            ],
            backgroundColor: [
                <?php foreach ($charTypeStats as $type => $stats): ?>
                    <?php if ($stats['count'] > 0): ?>
                        '<?= $typeColors[$type] ?>',
                    <?php endif; ?>
                <?php endforeach; ?>
            ]
        }]
    };

    var charTypeCtx = document.getElementById('fontsub-charTypeChart').getContext('2d');
    new Chart(charTypeCtx, {
        type: 'doughnut',
        data: charTypeData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });

    var topCharsData = {
        labels: [
            <?php 
            $top10Chars = array_slice($topChars, 0, 10, true);
            foreach ($top10Chars as $char => $count): 
            ?>
                '<?= addslashes(htmlspecialchars($char)) ?>',
            <?php endforeach; ?>
        ],
        datasets: [{
            label: '<?= __('使用次数') ?>',
            data: [
                <?php foreach ($top10Chars as $char => $count): ?>
                    <?= $count ?>,
                <?php endforeach; ?>
            ],
            backgroundColor: 'rgba(54, 162, 235, 0.8)',
            borderColor: 'rgba(54, 162, 235, 1)',
            borderWidth: 1
        }]
    };

    var topCharsCtx = document.getElementById('fontsub-topCharsChart').getContext('2d');
    new Chart(topCharsCtx, {
        type: 'bar',
        data: topCharsData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: { y: { beginAtZero: true } }
        }
    });
})();
</script>
