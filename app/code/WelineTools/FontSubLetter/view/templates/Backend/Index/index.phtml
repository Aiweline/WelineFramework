<script>
(function() {
    'use strict';
    
    var currentRecordId = null;
    var selectedCharacters = new Set();
    var allCharacters = [];
    var STORAGE_KEY = 'font_subset_data';

    // 本地存储管理类
    function LocalStorageManager() {
        this.storageKey = STORAGE_KEY;
    }

    LocalStorageManager.prototype.save = function(data) {
        try {
            var storageData = {
                customChars: data.customChars || '',
                selectedChars: data.selectedChars || [],
                timestamp: Date.now(),
                recordId: currentRecordId
            };
            localStorage.setItem(this.storageKey, JSON.stringify(storageData));
            this.showStorageInfo('<?= __('数据已保存到本地存储') ?>');
            return true;
        } catch (error) {
            console.error('保存到本地存储失败:', error);
            this.showStorageInfo('<?= __('保存失败') ?>: ' + error.message, 'danger');
            return false;
        }
    };

    LocalStorageManager.prototype.load = function() {
        try {
            var data = localStorage.getItem(this.storageKey);
            if (data) {
                return JSON.parse(data);
            }
            return null;
        } catch (error) {
            console.error('从本地存储加载失败:', error);
            return null;
        }
    };

    LocalStorageManager.prototype.clear = function() {
        try {
            localStorage.removeItem(this.storageKey);
            this.showStorageInfo('<?= __('本地存储数据已清理') ?>');
            return true;
        } catch (error) {
            console.error('清理本地存储失败:', error);
            this.showStorageInfo('<?= __('清理失败') ?>: ' + error.message, 'danger');
            return false;
        }
    };

    LocalStorageManager.prototype.hasData = function() {
        return this.load() !== null;
    };

    LocalStorageManager.prototype.showStorageInfo = function(message, type) {
        type = type || 'info';
        var storageInfo = document.getElementById('storageInfo');
        var storageStatus = document.getElementById('storageStatus');
        
        storageStatus.textContent = message;
        storageInfo.className = 'fsl-storage-info alert alert-' + type;
        storageInfo.style.display = 'block';
        
        setTimeout(function() {
            storageInfo.style.display = 'none';
        }, 3000);
    };

    var storageManager = new LocalStorageManager();

    // 页面加载时检查本地存储
    document.addEventListener('DOMContentLoaded', function() {
        if (storageManager.hasData()) {
            var storageInfo = document.getElementById('storageInfo');
            storageInfo.style.display = 'block';
            document.getElementById('storageStatus').textContent = '<?= __('检测到本地存储数据，可以加载使用') ?>';
        }
    });

    // 上传区域事件
    document.getElementById('uploadArea').addEventListener('click', function() {
        document.getElementById('fontFile').click();
    });

    document.getElementById('uploadArea').addEventListener('dragover', function(e) {
        e.preventDefault();
        e.currentTarget.classList.add('dragover');
    });

    document.getElementById('uploadArea').addEventListener('dragleave', function(e) {
        e.currentTarget.classList.remove('dragover');
    });

    document.getElementById('uploadArea').addEventListener('drop', function(e) {
        e.preventDefault();
        e.currentTarget.classList.remove('dragover');
        var files = e.dataTransfer.files;
        if (files.length > 0) {
            handleFileUpload(files[0]);
        }
    });

    document.getElementById('fontFile').addEventListener('change', function(e) {
        if (e.target.files.length > 0) {
            handleFileUpload(e.target.files[0]);
        }
    });

    // 文件上传处理
    function handleFileUpload(file) {
        var formData = new FormData();
        formData.append('font_file', file);

        showProgress();
        
        var url = '<?= $this->getUrl("*/backend/upload") ?>';
        var opts = { method: 'POST', body: formData };
        window.Weline.Api.request(url, opts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            hideProgress();
            if (data.code === 200) {
                showFileInfo(data.data);
                currentRecordId = data.data.id;
            } else {
                BackendToast.error(data.msg || '<?= __('上传失败') ?>');
            }
        })
        .catch(function(error) {
            hideProgress();
            BackendToast.error('<?= __('上传失败') ?>: ' + error.message);
        });
    }

    function showProgress() {
        document.getElementById('progressContainer').style.display = 'block';
        document.getElementById('progressBar').style.width = '0%';
        document.getElementById('progressText').textContent = '<?= __('上传中...') ?>';
    }

    function hideProgress() {
        document.getElementById('progressContainer').style.display = 'none';
    }

    function showFileInfo(fileInfo) {
        document.getElementById('fileName').textContent = fileInfo.filename;
        document.getElementById('fileFormat').textContent = fileInfo.format.toUpperCase();
        document.getElementById('fileSize').textContent = fileInfo.size;
        document.getElementById('fileInfo').style.display = 'block';
    }

    // 提取字符
    document.getElementById('extractBtn').addEventListener('click', function() {
        if (!currentRecordId) {
            BackendToast.warning('<?= __('请先上传字体文件') ?>');
            return;
        }

        showProgress();
        document.getElementById('progressText').textContent = '<?= __('提取字符中...') ?>';

        var extractUrl = '<?= $this->getUrl("*/backend/extract") ?>?record_id=' + currentRecordId;
        window.Weline.Api.get(extractUrl, { silent: true })
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            hideProgress();
            
            if (data.code === 200) {
                if (data.data && data.data.characters && Array.isArray(data.data.characters)) {
                    showCharacterGrid(data.data.characters);
                } else {
                    BackendToast.error('<?= __('字符数据格式错误') ?>');
                }
            } else {
                BackendToast.error(data.msg || '<?= __('提取失败') ?>');
            }
        })
        .catch(function(error) {
            hideProgress();
            BackendToast.error('<?= __('提取失败') ?>: ' + error.message);
        });
    });

    // 显示字符网格
    function showCharacterGrid(characters) {
        if (!Array.isArray(characters) || characters.length === 0) {
            BackendToast.warning('<?= __('没有可显示的字符') ?>');
            return;
        }

        allCharacters = characters;
        var grid = document.getElementById('characterGrid');
        grid.innerHTML = '';

        var fontUrl = '<?= $this->getUrl("*/backend/download") ?>?record_id=' + currentRecordId + '&preview=1';
        var fontFamily = 'CustomFont_' + currentRecordId;
        
        var style = document.createElement('style');
        style.textContent = '@font-face { font-family: "' + fontFamily + '"; src: url("' + fontUrl + '") format("opentype"); } .fsl-character-item { font-family: "' + fontFamily + '", sans-serif !important; }';
        document.head.appendChild(style);

        var validCharacters = 0;
        characters.forEach(function(char) {
            if (char && typeof char === 'object' && char.value !== undefined && char.code !== undefined) {
                var item = document.createElement('div');
                item.className = 'fsl-character-item';
                item.textContent = char.value;
                item.dataset.code = char.code;
                item.style.fontFamily = '"' + fontFamily + '", sans-serif';
                item.addEventListener('click', function() { toggleCharacter(char.code, char.value); });
                grid.appendChild(item);
                validCharacters++;
            }
        });

        if (validCharacters > 0) {
            document.getElementById('characterCard').style.display = 'block';
            updateSelectedCount();
        } else {
            BackendToast.warning('<?= __('没有有效的字符可以显示') ?>');
        }
    }

    function toggleCharacter(code) {
        var item = document.querySelector('[data-code="' + code + '"]');
        if (selectedCharacters.has(code)) {
            selectedCharacters.delete(code);
            item.classList.remove('selected');
        } else {
            selectedCharacters.add(code);
            item.classList.add('selected');
        }
        updateSelectedCount();
    }

    function updateSelectedCount() {
        document.getElementById('selectedCount').textContent = selectedCharacters.size;
    }

    // 全选
    document.getElementById('selectAllBtn').addEventListener('click', function() {
        document.querySelectorAll('.fsl-character-item').forEach(function(item) {
            var code = item.dataset.code;
            selectedCharacters.add(code);
            item.classList.add('selected');
        });
        updateSelectedCount();
    });

    // 取消全选
    document.getElementById('deselectAllBtn').addEventListener('click', function() {
        selectedCharacters.clear();
        document.querySelectorAll('.fsl-character-item').forEach(function(item) {
            item.classList.remove('selected');
        });
        updateSelectedCount();
    });

    // 添加到自定义字符
    document.getElementById('addToCustomBtn').addEventListener('click', function() {
        if (selectedCharacters.size === 0) {
            BackendToast.warning('<?= __('请先选择字符') ?>');
            return;
        }

        var customCharsTextarea = document.getElementById('customChars');
        var currentCustomChars = customCharsTextarea.value;
        
        var selectedCharValues = Array.from(selectedCharacters).map(function(code) {
            var char = allCharacters.find(function(c) { return c.code == code; });
            return char ? char.value : String.fromCharCode(code);
        });

        customCharsTextarea.value = currentCustomChars + selectedCharValues.join('');
        storageManager.showStorageInfo('<?= __('已添加') ?> ' + selectedCharValues.length + ' <?= __('个字符到自定义区域') ?>');
    });

    // 清空自定义字符
    document.getElementById('clearCustomBtn').addEventListener('click', function() {
        if (confirm('<?= __('确定要清空自定义字符吗？') ?>')) {
            document.getElementById('customChars').value = '';
            storageManager.showStorageInfo('<?= __('自定义字符已清空') ?>');
        }
    });

    // 加载本地存储数据
    document.getElementById('loadStorageBtn').addEventListener('click', function() {
        var data = storageManager.load();
        if (data) {
            if (data.customChars) {
                document.getElementById('customChars').value = data.customChars;
            }

            if (data.selectedChars && data.selectedChars.length > 0 && allCharacters.length > 0) {
                selectedCharacters.clear();
                data.selectedChars.forEach(function(code) {
                    selectedCharacters.add(code);
                    var item = document.querySelector('[data-code="' + code + '"]');
                    if (item) {
                        item.classList.add('selected');
                    }
                });
                updateSelectedCount();
            }

            storageManager.showStorageInfo('<?= __('数据加载成功') ?>');
        } else {
            storageManager.showStorageInfo('<?= __('没有找到存储数据') ?>', 'warning');
        }
    });

    // 保存到本地存储
    document.getElementById('saveStorageBtn').addEventListener('click', function() {
        var customChars = document.getElementById('customChars').value;
        var selectedChars = Array.from(selectedCharacters);
        
        storageManager.save({
            customChars: customChars,
            selectedChars: selectedChars
        });
    });

    // 清理本地存储
    document.getElementById('clearStorageBtn').addEventListener('click', function() {
        if (confirm('<?= __('确定要清理本地存储数据吗？此操作不可恢复。') ?>')) {
            if (storageManager.clear()) {
                document.getElementById('customChars').value = '';
                selectedCharacters.clear();
                document.querySelectorAll('.fsl-character-item').forEach(function(item) {
                    item.classList.remove('selected');
                });
                updateSelectedCount();
                document.getElementById('storageInfo').style.display = 'none';
            }
        }
    });

    // 生成字体
    document.getElementById('generateBtn').addEventListener('click', function() {
        if (!currentRecordId) {
            BackendToast.warning('<?= __('请先上传字体文件') ?>');
            return;
        }

        var customChars = document.getElementById('customChars').value.trim();
        var selectedCharsArray = Array.from(selectedCharacters);
        
        if (selectedCharsArray.length === 0 && !customChars) {
            BackendToast.warning('<?= __('请选择要包含的字符或输入自定义字符') ?>');
            return;
        }

        var allChars = selectedCharsArray;
        
        if (customChars) {
            var customCharCodes = Array.from(customChars).map(function(char) { return char.charCodeAt(0); });
            allChars = allChars.concat(customCharCodes);
        }

        storageManager.save({
            customChars: customChars,
            selectedChars: selectedCharsArray
        });

        showProgress();
        document.getElementById('progressText').textContent = '<?= __('生成字体中...') ?>';

        var formData = new FormData();
        formData.append('record_id', currentRecordId);
        formData.append('selected_chars', JSON.stringify(allChars));

        var genUrl = '<?= $this->getUrl("*/backend/generate") ?>';
        var genOpts = { method: 'POST', body: formData };
        window.Weline.Api.request(genUrl, genOpts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            hideProgress();
            if (data.code === 200) {
                BackendToast.success('<?= __('子集字体生成成功') ?>');
                var downloadUrl = '<?= $this->getUrl("*/backend/download") ?>?record_id=' + currentRecordId;
                window.open(downloadUrl, '_blank');
            } else {
                BackendToast.error(data.msg || '<?= __('生成失败') ?>');
            }
        })
        .catch(function(error) {
            hideProgress();
            BackendToast.error('<?= __('生成失败') ?>: ' + error.message);
        });
    });
})();
</script>
