    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 CSS -->
    <link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
    <!-- SweetAlert2 JS -->
    <script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
    <script>
        let currentRecordId = null;
        let selectedCharacters = new Set();
        let allCharacters = [];
        const STORAGE_KEY = 'font_subset_data';

        // 本地存储管理类
        class LocalStorageManager {
            constructor() {
                this.storageKey = STORAGE_KEY;
            }

            // 保存数据
            save(data) {
                try {
                    const storageData = {
                        customChars: data.customChars || '',
                        selectedChars: data.selectedChars || [],
                        timestamp: Date.now(),
                        recordId: currentRecordId
                    };
                    localStorage.setItem(this.storageKey, JSON.stringify(storageData));
                    this.showStorageInfo('数据已保存到本地存储');
                    return true;
                } catch (error) {
                    console.error('保存到本地存储失败:', error);
                    this.showStorageInfo('保存失败: ' + error.message, 'danger');
                    return false;
                }
            }

            // 加载数据
            load() {
                try {
                    const data = localStorage.getItem(this.storageKey);
                    if (data) {
                        const parsedData = JSON.parse(data);
                        return parsedData;
                    }
                    return null;
                } catch (error) {
                    console.error('从本地存储加载失败:', error);
                    return null;
                }
            }

            // 清理数据
            clear() {
                try {
                    localStorage.removeItem(this.storageKey);
                    this.showStorageInfo('本地存储数据已清理');
                    return true;
                } catch (error) {
                    console.error('清理本地存储失败:', error);
                    this.showStorageInfo('清理失败: ' + error.message, 'danger');
                    return false;
                }
            }

            // 检查是否有存储数据
            hasData() {
                const data = this.load();
                return data !== null;
            }

            // 显示存储信息
            showStorageInfo(message, type = 'info') {
                const storageInfo = document.getElementById('storageInfo');
                const storageStatus = document.getElementById('storageStatus');
                
                storageStatus.textContent = message;
                storageInfo.className = `storage-info alert alert-${type}`;
                storageInfo.style.display = 'block';
                
                // 3秒后自动隐藏
                setTimeout(() => {
                    storageInfo.style.display = 'none';
                }, 3000);
            }
        }

        const storageManager = new LocalStorageManager();

        // 页面加载时检查本地存储
        document.addEventListener('DOMContentLoaded', () => {
            if (storageManager.hasData()) {
                const storageInfo = document.getElementById('storageInfo');
                storageInfo.style.display = 'block';
                document.getElementById('storageStatus').textContent = '检测到本地存储数据，可以加载使用';
            }
        });

        // 上传区域事件
        document.getElementById('uploadArea').addEventListener('click', () => {
            document.getElementById('fontFile').click();
        });

        document.getElementById('uploadArea').addEventListener('dragover', (e) => {
            e.preventDefault();
            e.currentTarget.classList.add('dragover');
        });

        document.getElementById('uploadArea').addEventListener('dragleave', (e) => {
            e.currentTarget.classList.remove('dragover');
        });

        document.getElementById('uploadArea').addEventListener('drop', (e) => {
            e.preventDefault();
            e.currentTarget.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFileUpload(files[0]);
            }
        });

        document.getElementById('fontFile').addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFileUpload(e.target.files[0]);
            }
        });

        // 文件上传处理
        function handleFileUpload(file) {
            const formData = new FormData();
            formData.append('font_file', file);

            showProgress();
            
            console.log('开始上传文件:', file.name);
            
            fetch('<?= $this->getUrl("*/backend/upload") ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                console.log('上传响应状态:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('上传响应数据:', data);
                hideProgress();
                if (data.code === 200) {
                    showFileInfo(data.data);
                    currentRecordId = data.data.id;
                    console.log('设置currentRecordId:', currentRecordId);
                } else {
                    console.error('上传失败:', data.msg);
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('上传失败') ?>',
                            text: data.msg,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(data.msg);
                    }
                }
            })
            .catch(error => {
                console.error('上传异常:', error);
                hideProgress();
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('上传失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('上传失败') ?>: ' + error.message);
                }
            });
        }

        // 显示进度条
        function showProgress() {
            document.getElementById('progressContainer').style.display = 'block';
            document.getElementById('progressBar').style.width = '0%';
            document.getElementById('progressText').textContent = '<?= __('上传中...') ?>';
        }

        // 隐藏进度条
        function hideProgress() {
            document.getElementById('progressContainer').style.display = 'none';
        }

        // 显示文件信息
        function showFileInfo(fileInfo) {
            document.getElementById('fileName').textContent = fileInfo.filename;
            document.getElementById('fileFormat').textContent = fileInfo.format.toUpperCase();
            document.getElementById('fileSize').textContent = fileInfo.size;
            document.getElementById('fileInfo').style.display = 'block';
        }

        // 提取字符
        document.getElementById('extractBtn').addEventListener('click', () => {
            console.log('点击提取按钮，currentRecordId:', currentRecordId);
            
            if (!currentRecordId) {
                console.error('currentRecordId为空，提示用户上传文件');
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请先上传字体文件') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('请先上传字体文件') ?>');
                }
                return;
            }

            showProgress();
            document.getElementById('progressText').textContent = '<?= __('提取字符中...') ?>';

            console.log('开始提取字符，记录ID:', currentRecordId);

            fetch(`<?= $this->getUrl("*/backend/extract") ?>?record_id=${currentRecordId}`)
            .then(response => {
                console.log('提取响应状态:', response.status);
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('提取响应数据:', data);
                hideProgress();
                
                if (data.code === 200) {
                    if (data.data && data.data.characters && Array.isArray(data.data.characters)) {
                        showCharacterGrid(data.data.characters);
                    } else {
                        console.error('字符数据格式错误:', data.data);
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('格式错误') ?>',
                                text: '<?= __('字符数据格式错误') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        } else {
                            console.error('<?= __('字符数据格式错误') ?>');
                        }
                    }
                } else {
                    console.error('提取失败:', data.msg);
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('提取失败') ?>',
                            text: data.msg || '<?= __('提取失败') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(data.msg || '<?= __('提取失败') ?>');
                    }
                }
            })
            .catch(error => {
                console.error('提取异常:', error);
                hideProgress();
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('提取失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('提取失败') ?>: ' + error.message);
                }
            });
        });

        // 显示字符网格
        function showCharacterGrid(characters) {
            console.log('显示字符网格，字符数量:', characters.length);
            
            if (!Array.isArray(characters) || characters.length === 0) {
                console.error('字符数据无效:', characters);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('没有可显示的字符') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('没有可显示的字符') ?>');
                }
                return;
            }

            allCharacters = characters;
            const grid = document.getElementById('characterGrid');
            grid.innerHTML = '';

            // 创建字体预览样式
            const fontUrl = `<?= $this->getUrl("*/backend/download") ?>?record_id=${currentRecordId}&preview=1`;
            const fontFamily = 'CustomFont_' + currentRecordId;
            
            console.log('字体URL:', fontUrl);
            console.log('字体族名:', fontFamily);
            
            // 添加字体样式到页面
            const style = document.createElement('style');
            style.textContent = `
                @font-face {
                    font-family: '${fontFamily}';
                    src: url('${fontUrl}') format('opentype');
                    font-weight: normal;
                    font-style: normal;
                }
                .character-item {
                    font-family: '${fontFamily}', sans-serif !important;
                }
            `;
            document.head.appendChild(style);

            let validCharacters = 0;
            characters.forEach((char, index) => {
                if (char && typeof char === 'object' && char.value !== undefined && char.code !== undefined) {
                    const item = document.createElement('div');
                    item.className = 'character-item';
                    item.textContent = char.value;
                    item.dataset.code = char.code;
                    item.style.fontFamily = `'${fontFamily}', sans-serif`;
                    item.addEventListener('click', () => toggleCharacter(char.code, char.value));
                    grid.appendChild(item);
                    validCharacters++;
                } else {
                    console.warn('跳过无效字符:', char, '索引:', index);
                }
            });

            console.log('有效字符数量:', validCharacters);
            
            if (validCharacters > 0) {
                document.getElementById('characterCard').style.display = 'block';
                updateSelectedCount();
            } else {
                console.error('没有有效的字符可以显示');
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('没有有效的字符可以显示') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('没有有效的字符可以显示') ?>');
                }
            }
        }

        // 切换字符选择
        function toggleCharacter(code, value) {
            const item = document.querySelector(`[data-code="${code}"]`);
            if (selectedCharacters.has(code)) {
                selectedCharacters.delete(code);
                item.classList.remove('selected');
            } else {
                selectedCharacters.add(code);
                item.classList.add('selected');
            }
            updateSelectedCount();
        }

        // 更新选择计数
        function updateSelectedCount() {
            document.getElementById('selectedCount').textContent = selectedCharacters.size;
        }

        // 全选
        document.getElementById('selectAllBtn').addEventListener('click', () => {
            document.querySelectorAll('.character-item').forEach(item => {
                const code = item.dataset.code;
                selectedCharacters.add(code);
                item.classList.add('selected');
            });
            updateSelectedCount();
        });

        // 取消全选
        document.getElementById('deselectAllBtn').addEventListener('click', () => {
            selectedCharacters.clear();
            document.querySelectorAll('.character-item').forEach(item => {
                item.classList.remove('selected');
            });
            updateSelectedCount();
        });

        // 添加到自定义字符
        document.getElementById('addToCustomBtn').addEventListener('click', () => {
            if (selectedCharacters.size === 0) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请先选择字符') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('请先选择字符') ?>');
                }
                return;
            }

            const customCharsTextarea = document.getElementById('customChars');
            const currentCustomChars = customCharsTextarea.value;
            
            // 获取选中的字符值
            const selectedCharValues = Array.from(selectedCharacters).map(code => {
                const char = allCharacters.find(c => c.code == code);
                return char ? char.value : String.fromCharCode(code);
            });

            // 合并到自定义字符区域
            const newCustomChars = currentCustomChars + selectedCharValues.join('');
            customCharsTextarea.value = newCustomChars;
            
            storageManager.showStorageInfo('已添加 ' + selectedCharValues.length + ' 个字符到自定义区域');
        });

        // 清空自定义字符
        document.getElementById('clearCustomBtn').addEventListener('click', () => {
            if (confirm('<?= __('确定要清空自定义字符吗？') ?>')) {
                document.getElementById('customChars').value = '';
                storageManager.showStorageInfo('自定义字符已清空');
            }
        });

        // 加载本地存储数据
        document.getElementById('loadStorageBtn').addEventListener('click', () => {
            const data = storageManager.load();
            if (data) {
                // 加载自定义字符
                if (data.customChars) {
                    document.getElementById('customChars').value = data.customChars;
                }

                // 加载选中的字符（如果字符网格已显示）
                if (data.selectedChars && data.selectedChars.length > 0 && allCharacters.length > 0) {
                    selectedCharacters.clear();
                    data.selectedChars.forEach(code => {
                        selectedCharacters.add(code);
                        const item = document.querySelector(`[data-code="${code}"]`);
                        if (item) {
                            item.classList.add('selected');
                        }
                    });
                    updateSelectedCount();
                }

                storageManager.showStorageInfo('数据加载成功');
            } else {
                storageManager.showStorageInfo('没有找到存储数据', 'warning');
            }
        });

        // 保存到本地存储
        document.getElementById('saveStorageBtn').addEventListener('click', () => {
            const customChars = document.getElementById('customChars').value;
            const selectedChars = Array.from(selectedCharacters);
            
            const data = {
                customChars: customChars,
                selectedChars: selectedChars
            };

            if (storageManager.save(data)) {
                storageManager.showStorageInfo('数据保存成功');
            }
        });

        // 清理本地存储
        document.getElementById('clearStorageBtn').addEventListener('click', () => {
            if (confirm('<?= __('确定要清理本地存储数据吗？此操作不可恢复。') ?>')) {
                if (storageManager.clear()) {
                    // 清空界面数据
                    document.getElementById('customChars').value = '';
                    selectedCharacters.clear();
                    document.querySelectorAll('.character-item').forEach(item => {
                        item.classList.remove('selected');
                    });
                    updateSelectedCount();
                    
                    // 隐藏存储信息
                    document.getElementById('storageInfo').style.display = 'none';
                }
            }
        });

        // 生成字体
        document.getElementById('generateBtn').addEventListener('click', () => {
            if (!currentRecordId) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请先上传字体文件') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('请先上传字体文件') ?>');
                }
                return;
            }

            const customChars = document.getElementById('customChars').value.trim();
            const selectedCharsArray = Array.from(selectedCharacters);
            
            // 检查是否有自定义输入或选择的字符
            if (selectedCharsArray.length === 0 && !customChars) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请选择要包含的字符或输入自定义字符') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('请选择要包含的字符或输入自定义字符') ?>');
                }
                return;
            }

            let allChars = selectedCharsArray;
            
            if (customChars) {
                const customCharCodes = Array.from(customChars).map(char => char.charCodeAt(0));
                allChars = allChars.concat(customCharCodes);
            }

            // 自动保存当前状态
            const data = {
                customChars: customChars,
                selectedChars: selectedCharsArray
            };
            storageManager.save(data);

            showProgress();
            document.getElementById('progressText').textContent = '<?= __('生成字体中...') ?>';

            const formData = new FormData();
            formData.append('record_id', currentRecordId);
            formData.append('selected_chars', JSON.stringify(allChars));

            fetch('<?= $this->getUrl("*/backend/generate") ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                hideProgress();
                if (data.code === 200) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: '<?= __('子集字体生成成功') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        console.log('<?= __('子集字体生成成功') ?>');
                    }
                    // 可以添加下载链接
                    const downloadUrl = `<?= $this->getUrl("*/backend/download") ?>?record_id=${currentRecordId}`;
                    window.open(downloadUrl, '_blank');
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('生成失败') ?>',
                            text: data.msg,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(data.msg);
                    }
                }
            })
            .catch(error => {
                hideProgress();
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('生成失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('生成失败') ?>: ' + error.message);
                }
            });
        });
    </script>
</body>
</html>
