                            <li><i class="bi bi-check-circle text-success"></i> <?= __('支持多种字体格式') ?></li>
                            <li><i class="bi bi-check-circle text-success"></i> <?= __('智能字符提取') ?></li>
                            <li><i class="bi bi-check-circle text-success"></i> <?= __('可视化字符选择') ?></li>
                            <li><i class="bi bi-check-circle text-success"></i> <?= __('高效字体压缩') ?></li>
