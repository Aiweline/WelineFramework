<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= $title ?> - <?= $subtitle ?></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .status-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        .table-responsive {
            min-height: 400px;
        }
    </style>
</head>
<body>
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h3 mb-0">
                        <i class="bi bi-list-ul"></i>
                        <?= $title ?>
                        <small class="text-muted"><?= $subtitle ?></small>
                    </h1>
                    <a href="<?= $this->getUrl('*/index') ?>" class="btn btn-primary">
                        <i class="bi bi-plus"></i> <?= __('新建处理') ?>
                    </a>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-table"></i> <?= __('处理记录列表') ?>
                        </h5>
                    </div>
                    <div class="card-body">
                        <?php if (empty($records)): ?>
                            <div class="text-center py-5">
                                <i class="bi bi-inbox display-1 text-muted"></i>
                                <p class="mt-3 text-muted"><?= __('暂无处理记录') ?></p>
                                <a href="<?= $this->getUrl('*/index') ?>" class="btn btn-primary">
                                    <?= __('开始处理字体') ?>
                                </a>
                            </div>
                        <?php else: ?>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th><?= __('ID') ?></th>
                                            <th><?= __('原始文件名') ?></th>
                                            <th><?= __('字体格式') ?></th>
                                            <th><?= __('文件大小') ?></th>
                                            <th><?= __('状态') ?></th>
                                            <th><?= __('创建时间') ?></th>
                                            <th><?= __('操作') ?></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <?php foreach ($records as $record): ?>
                                            <tr>
                                                <td><?= $record['id'] ?></td>
                                                <td>
                                                    <div class="fw-bold"><?= htmlspecialchars($record['original_filename']) ?></div>
                                                    <?php if ($record['processed_filename']): ?>
                                                        <small class="text-muted">
                                                            <?= __('处理后') ?>: <?= htmlspecialchars($record['processed_filename']) ?>
                                                        </small>
                                                    <?php endif; ?>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary"><?= strtoupper($record['font_format']) ?></span>
                                                </td>
                                                <td><?= $record['file_size_formatted'] ?? $record['file_size'] ?></td>
                                                <td>
                                                    <?php
                                                    $statusClass = '';
                                                    $statusText = '';
                                                    switch ($record['status']) {
                                                        case 'uploaded':
                                                            $statusClass = 'bg-warning';
                                                            $statusText = __('已上传');
                                                            break;
                                                        case 'processing':
                                                            $statusClass = 'bg-info';
                                                            $statusText = __('处理中');
                                                            break;
                                                        case 'completed':
                                                            $statusClass = 'bg-success';
                                                            $statusText = __('已完成');
                                                            break;
                                                        case 'failed':
                                                            $statusClass = 'bg-danger';
                                                            $statusText = __('失败');
                                                            break;
                                                        default:
                                                            $statusClass = 'bg-secondary';
                                                            $statusText = $record['status'];
                                                    }
                                                    ?>
                                                    <span class="badge status-badge <?= $statusClass ?>"><?= $statusText ?></span>
                                                    <?php if ($record['status'] === 'failed' && $record['error_message']): ?>
                                                        <br><small class="text-danger"><?= htmlspecialchars($record['error_message']) ?></small>
                                                    <?php endif; ?>
                                                </td>
                                                <td>
                                                    <?= date('Y-m-d H:i:s', $record['created_at']) ?>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <?php if ($record['status'] === 'uploaded'): ?>
                                                            <button type="button" class="btn btn-outline-primary" 
                                                                    onclick="extractCharacters(<?= $record['id'] ?>)">
                                                                <i class="bi bi-search"></i> <?= __('提取字符') ?>
                                                            </button>
                                                        <?php endif; ?>
                                                        
                                                        <?php if ($record['status'] === 'completed' && $record['processed_filename']): ?>
                                                            <a href="<?= $this->getUrl('*/download', ['record_id' => $record['id']]) ?>" 
                                                               class="btn btn-outline-success">
                                                                <i class="bi bi-download"></i> <?= __('下载') ?>
                                                            </a>
                                                        <?php endif; ?>
                                                        
                                                        <button type="button" class="btn btn-outline-danger" 
                                                                onclick="deleteRecord(<?= $record['id'] ?>)">
                                                            <i class="bi bi-trash"></i> <?= __('删除') ?>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <?php endforeach; ?>
                                    </tbody>
                                </table>
                            </div>

                            <!-- 分页 -->
                            <?php if ($total > $limit): ?>
                                <nav aria-label="Page navigation" class="mt-4">
                                    <ul class="pagination justify-content-center">
                                        <?php
                                        $totalPages = ceil($total / $limit);
                                        $currentPage = $page;
                                        ?>
                                        
                                        <!-- 上一页 -->
                                        <?php if ($currentPage > 1): ?>
                                            <li class="page-item">
                                                <a class="page-link" href="<?= $this->getUrl('*/list', ['page' => $currentPage - 1]) ?>">
                                                    <?= __('上一页') ?>
                                                </a>
                                            </li>
                                        <?php endif; ?>
                                        
                                        <!-- 页码 -->
                                        <?php
                                        $startPage = max(1, $currentPage - 2);
                                        $endPage = min($totalPages, $currentPage + 2);
                                        
                                        for ($i = $startPage; $i <= $endPage; $i++):
                                        ?>
                                            <li class="page-item <?= $i === $currentPage ? 'active' : '' ?>">
                                                <a class="page-link" href="<?= $this->getUrl('*/list', ['page' => $i]) ?>">
                                                    <?= $i ?>
                                                </a>
                                            </li>
                                        <?php endfor; ?>
                                        
                                        <!-- 下一页 -->
                                        <?php if ($currentPage < $totalPages): ?>
                                            <li class="page-item">
                                                <a class="page-link" href="<?= $this->getUrl('*/list', ['page' => $currentPage + 1]) ?>">
                                                    <?= __('下一页') ?>
                                                </a>
                                            </li>
                                        <?php endif; ?>
                                    </ul>
                                </nav>
                            <?php endif; ?>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 提取字符
        function extractCharacters(recordId) {
            if (!confirm('<?= __('确定要提取字符吗？') ?>')) {
                return;
            }

            fetch(`<?= $this->getUrl("*/backend/extract") ?>?record_id=${recordId}`)
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    alert('<?= __('字符提取成功') ?>');
                    location.reload();
                } else {
                    alert(data.msg);
                }
            })
            .catch(error => {
                alert('<?= __('提取失败') ?>: ' + error.message);
            });
        }

        // 删除记录
        function deleteRecord(recordId) {
            if (!confirm('<?= __('确定要删除这条记录吗？') ?>')) {
                return;
            }

            fetch(`<?= $this->getUrl("*/backend/delete") ?>?record_id=${recordId}`)
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    alert('<?= __('记录删除成功') ?>');
                    location.reload();
                } else {
                    alert(data.msg);
                }
            })
            .catch(error => {
                alert('<?= __('删除失败') ?>: ' + error.message);
            });
        }
    </script>
</body>
</html>
