<script>
function deleteRecord(id) {
    if (confirm('<?= __('确定要删除这条记录吗？') ?>')) {
        fetch('<?= $this->getUrl("fontsubletter/backend/record/delete") ?>?id=' + id, {
            method: 'POST'
        })
        .then(response => response.json())
        .then(data => {
            if (data.code === 200) {
                alert(data.msg);
                location.reload();
            } else {
                alert('<?= __('删除失败') ?>: ' + data.msg);
            }
        })
        .catch(error => {
            alert('<?= __('删除失败') ?>: ' + error.message);
        });
    }
}
</script>
