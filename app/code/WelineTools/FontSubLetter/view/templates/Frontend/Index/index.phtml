    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentRecordId = null;
        let selectedCharacters = new Set();

        // 上传区域事件
        document.getElementById('uploadArea').addEventListener('click', () => {
            // 强制清空文件输入框，确保能触发change事件
            const fileInput = document.getElementById('fontFile');
            fileInput.value = '';
            fileInput.click();
        });

        document.getElementById('uploadArea').addEventListener('dragover', (e) => {
            e.preventDefault();
            e.currentTarget.classList.add('dragover');
        });

        document.getElementById('uploadArea').addEventListener('dragleave', (e) => {
            e.currentTarget.classList.remove('dragover');
        });

        document.getElementById('uploadArea').addEventListener('drop', (e) => {
            e.preventDefault();
            e.currentTarget.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFileUpload(files[0]);
            }
        });

        // 文件选择事件处理
        document.getElementById('fontFile').addEventListener('change', (e) => {
            console.log('文件选择事件触发，文件数量:', e.target.files.length); // 调试信息
            if (e.target.files.length > 0) {
                handleFileUpload(e.target.files[0]);
            } else {
                console.log('没有选择文件'); // 调试信息
            }
        });

        // 添加文件输入框的点击事件监听，确保每次点击都能触发文件选择
        document.getElementById('fontFile').addEventListener('click', (e) => {
            console.log('文件输入框被点击'); // 调试信息
            // 每次点击时清空值，确保能触发change事件
            e.target.value = '';
        });

        // 文件上传处理
        function handleFileUpload(file) {
            console.log('开始上传文件:', file.name); // 调试信息
            
            // 检查文件是否有效
            if (!file || file.size === 0) {
                alert('<?= __('请选择有效的文件') ?>');
                return;
            }
            
            // 清除之前的状态
            currentRecordId = null;
            selectedCharacters.clear();
            
            const formData = new FormData();
            formData.append('font_file', file);

            showProgress();
            
            // 添加时间戳防止缓存
            const url = '<?= $this->getUrl("*/frontend/upload") ?>' + '?t=' + Date.now();
            
            fetch(url, {
                method: 'POST',
                body: formData,
                cache: 'no-cache' // 防止缓存
            })
            .then(response => {
                console.log('服务器响应状态:', response.status); // 调试信息
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('服务器返回数据:', data); // 调试信息
                hideProgress();
                if (data.code === 200) {
                    showFileInfo(data.data);
                    currentRecordId = data.data.id;
                    // 重置文件输入框，允许重新选择相同文件
                    document.getElementById('fontFile').value = '';
                } else {
                    showErrorAndReset('<?= __('上传失败') ?>: ' + data.msg);
                }
            })
            .catch(error => {
                console.error('上传错误:', error); // 调试信息
                showErrorAndReset('<?= __('上传失败') ?>: ' + error.message);
            });
        }

        // 显示进度条
        function showProgress() {
            document.getElementById('progressContainer').style.display = 'block';
            document.getElementById('progressBar').style.width = '0%';
            document.getElementById('progressText').textContent = '<?= __('上传中...') ?>';
        }

        // 隐藏进度条
        function hideProgress() {
            document.getElementById('progressContainer').style.display = 'none';
        }

        // 显示错误信息并重置状态
        function showErrorAndReset(message) {
            hideProgress();
            alert(message + '\n\n请重新选择文件进行上传。');
            
            // 重置上传状态，让用户可以继续尝试
            resetUpload();
            
            // 高亮上传区域，提示用户可以重新选择
            const uploadArea = document.getElementById('uploadArea');
            uploadArea.style.borderColor = '#dc3545';
            uploadArea.style.backgroundColor = '#f8d7da';
            
            // 3秒后恢复正常样式
            setTimeout(() => {
                uploadArea.style.borderColor = '';
                uploadArea.style.backgroundColor = '';
            }, 3000);
        }

        // 显示文件信息
        function showFileInfo(fileInfo) {
            document.getElementById('fileName').textContent = fileInfo.filename;
            document.getElementById('fileFormat').textContent = fileInfo.format.toUpperCase();
            document.getElementById('fileSize').textContent = fileInfo.size;
            document.getElementById('fileInfo').style.display = 'block';
        }

        // 提取字符
        document.getElementById('extractBtn').addEventListener('click', () => {
            if (!currentRecordId) return;

            showProgress();
            document.getElementById('progressText').textContent = '<?= __('提取字符中...') ?>';

            fetch(`<?= $this->getUrl("*/frontend/extract") ?>?record_id=${currentRecordId}`)
            .then(response => response.json())
            .then(data => {
                hideProgress();
                if (data.code === 200) {
                    showCharacterGrid(data.data.characters);
                } else {
                    showErrorAndReset('<?= __('提取失败') ?>: ' + data.msg);
                }
            })
            .catch(error => {
                showErrorAndReset('<?= __('提取失败') ?>: ' + error.message);
            });
        });

        // 显示字符网格
        function showCharacterGrid(characters) {
            const grid = document.getElementById('characterGrid');
            grid.innerHTML = '';

            // 创建字体预览样式
            const fontUrl = `<?= $this->getUrl("*/frontend/download") ?>?record_id=${currentRecordId}&preview=1`;
            const fontFamily = 'CustomFont_' + currentRecordId;
            
            // 添加字体样式到页面
            const style = document.createElement('style');
            style.textContent = `
                @font-face {
                    font-family: '${fontFamily}';
                    src: url('${fontUrl}') format('opentype');
                    font-weight: normal;
                    font-style: normal;
                }
                .character-item {
                    font-family: '${fontFamily}', sans-serif !important;
                }
            `;
            document.head.appendChild(style);

            characters.forEach(char => {
                const item = document.createElement('div');
                item.className = 'character-item';
                item.textContent = char.value;
                item.dataset.code = char.code;
                item.style.fontFamily = `'${fontFamily}', sans-serif`;
                item.addEventListener('click', () => toggleCharacter(char.code, char.value));
                grid.appendChild(item);
            });

            document.getElementById('characterCard').style.display = 'block';
            updateSelectedCount();
            loadRememberedChars(); // 加载记住的字符
        }

        // 切换字符选择
        function toggleCharacter(code, value) {
            const item = document.querySelector(`[data-code="${code}"]`);
            const customInput = document.getElementById('customChars');
            let currentCustom = customInput.value;

            if (selectedCharacters.has(code)) {
                selectedCharacters.delete(code);
                item.classList.remove('selected');
                // 从自定义中移除
                currentCustom = currentCustom.replace(value, '');
            } else {
                selectedCharacters.add(code);
                item.classList.add('selected');
                // 添加到自定义
                if (!currentCustom.includes(value)) {
                    currentCustom += value;
                }
            }

            customInput.value = currentCustom;
            updateSelectedCount();
        }

        // 更新选择计数
        function updateSelectedCount() {
            const customChars = document.getElementById('customChars').value.trim();
            const customCount = customChars.length;
            const total = selectedCharacters.size + customCount;
            document.getElementById('selectedCount').textContent = total;
        }

        // 重置上传状态
        function resetUpload() {
            console.log('重置上传状态'); // 调试信息
            
            // 清除当前记录ID
            currentRecordId = null;
            
            // 清除选择的字符
            selectedCharacters.clear();
            
            // 隐藏文件信息
            document.getElementById('fileInfo').style.display = 'none';
            
            // 隐藏字符选择区域
            document.getElementById('characterCard').style.display = 'none';
            
            // 清除字符网格
            document.getElementById('characterGrid').innerHTML = '';
            
            // 清除自定义字符输入
            document.getElementById('customChars').value = '';
            
            // 重置选择计数
            updateSelectedCount();
            
            // 重置文件输入框 - 强制清空值以触发change事件
            const fileInput = document.getElementById('fontFile');
            fileInput.value = '';
            
            // 移除已添加的字体样式
            const existingStyles = document.querySelectorAll('style');
            existingStyles.forEach(style => {
                if (style.textContent.includes('CustomFont_')) {
                    style.remove();
                }
            });
            
            console.log('上传状态重置完成'); // 调试信息
        }

        // 全选
        document.getElementById('selectAllBtn').addEventListener('click', () => {
            const customInput = document.getElementById('customChars');
            let currentCustom = customInput.value;

            document.querySelectorAll('.character-item').forEach(item => {
                const code = item.dataset.code;
                const value = item.textContent;
                selectedCharacters.add(code);
                item.classList.add('selected');
                if (!currentCustom.includes(value)) {
                    currentCustom += value;
                }
            });

            customInput.value = currentCustom;
            updateSelectedCount();
        });

        // 取消全选
        document.getElementById('deselectAllBtn').addEventListener('click', () => {
            selectedCharacters.clear();
            document.querySelectorAll('.character-item').forEach(item => {
                item.classList.remove('selected');
            });
            document.getElementById('customChars').value = '';
            updateSelectedCount();
        });

        // 生成字体
        document.getElementById('generateBtn').addEventListener('click', () => {
            if (!currentRecordId) {
                alert('<?= __('请先上传字体文件') ?>');
                return;
            }

            const customChars = document.getElementById('customChars').value.trim();
            const selectedCharsArray = Array.from(selectedCharacters);
            
            // 检查是否有自定义输入或选择的字符
            if (selectedCharsArray.length === 0 && !customChars) {
                alert('<?= __('请选择要包含的字符或输入自定义字符') ?>');
                return;
            }

            let allChars = selectedCharsArray;
            
            if (customChars) {
                const customCharCodes = Array.from(customChars).map(char => char.charCodeAt(0));
                allChars = allChars.concat(customCharCodes);
            }

            showProgress();
            document.getElementById('progressText').textContent = '<?= __('生成字体中...') ?>';

            const formData = new FormData();
            formData.append('record_id', currentRecordId);
            formData.append('selected_chars', JSON.stringify(allChars));

            fetch('<?= $this->getUrl("*/frontend/generate") ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                hideProgress();
                if (data.code === 200) {
                    alert('<?= __('子集字体生成成功') ?>');
                    // 可以添加下载链接
                    const downloadUrl = `<?= $this->getUrl("*/frontend/download") ?>?record_id=${currentRecordId}`;
                    window.open(downloadUrl, '_blank');
                } else {
                    showErrorAndReset('<?= __('生成失败') ?>: ' + data.msg);
                }
            })
            .catch(error => {
                showErrorAndReset('<?= __('生成失败') ?>: ' + error.message);
            });
        });

        // 自定义字符输入事件
        document.getElementById('customChars').addEventListener('input', updateSelectedCount);

        // 新增：清理按钮
        const clearBtn = document.createElement('button');
        clearBtn.type = 'button';
        clearBtn.className = 'btn btn-outline-danger me-2';
        clearBtn.id = 'clearBtn';
        clearBtn.innerHTML = '<i class="bi bi-trash"></i> 清理记住的字符';
        document.querySelector('.mb-4').appendChild(clearBtn);

        clearBtn.addEventListener('click', () => {
            if (confirm('确定要清理记住的字符信息吗？')) {
                fetch('<?= $this->getUrl("*/frontend/clear-selected") ?>', { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 200) {
                            alert('已清理');
                            location.reload();
                        } else {
                            alert('清理失败: ' + data.msg);
                        }
                    });
            }
        });

        // 新增：加载记住的字符
        function loadRememberedChars() {
            fetch('<?= $this->getUrl("*/frontend/get-selected") ?>')
                .then(response => response.json())
                .then(data => {
                    if (data.code === 200 && data.data) {
                        const remembered = data.data;
                        let customCharsValue = remembered.customChars || '';
                        
                        remembered.selectedChars.forEach(code => {
                            selectedCharacters.add(code);
                            const item = document.querySelector(`[data-code="${code}"]`);
                            if (item) {
                                item.classList.add('selected');
                                const value = item.textContent;
                                if (!customCharsValue.includes(value)) {
                                    customCharsValue += value;
                                }
                            } else {
                                // If no item found, still add the character
                                const value = String.fromCharCode(code);
                                if (!customCharsValue.includes(value)) {
                                    customCharsValue += value;
                                }
                            }
                        });
                        
                        document.getElementById('customChars').value = customCharsValue;
                        
                        updateSelectedCount();
                    }
                });
        }

        document.getElementById('generateBtnCustom').addEventListener('click', () => {
            // Same logic as generateBtn
            if (!currentRecordId) {
                alert('<?= __('请先上传字体文件') ?>');
                return;
            }

            const customChars = document.getElementById('customChars').value.trim();
            const selectedCharsArray = Array.from(selectedCharacters);
            
            if (selectedCharsArray.length === 0 && !customChars) {
                alert('<?= __('请选择要包含的字符或输入自定义字符') ?>');
                return;
            }

            let allChars = selectedCharsArray;
            
            if (customChars) {
                const customCharCodes = Array.from(customChars).map(char => char.charCodeAt(0));
                allChars = allChars.concat(customCharCodes);
            }

            showProgress();
            document.getElementById('progressText').textContent = '<?= __('生成字体中...') ?>';

            const formData = new FormData();
            formData.append('record_id', currentRecordId);
            formData.append('selected_chars', JSON.stringify(allChars));

            fetch('<?= $this->getUrl("*/frontend/generate") ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                hideProgress();
                if (data.code === 200) {
                    alert('<?= __('子集字体生成成功') ?>');
                    const downloadUrl = `<?= $this->getUrl("*/frontend/download") ?>?record_id=${currentRecordId}`;
                    window.open(downloadUrl, '_blank');
                } else {
                    showErrorAndReset('<?= __('生成失败') ?>: ' + data.msg);
                }
            })
            .catch(error => {
                showErrorAndReset('<?= __('生成失败') ?>: ' + error.message);
            });
        });
    </script>
</body>
</html>
