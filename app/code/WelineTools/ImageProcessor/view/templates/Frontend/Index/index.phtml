<!DOCTYPE html>
<html lang="<?= $this->getLocale() ?? 'zh-CN' ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= $this->e($title ?? __('图片处理工具集')) ?></title>
    <meta name="description" content="<?= __('免费在线图片处理：按颜色去除背景、生成透明 PNG。处理在浏览器本地完成，图片不上传服务器。') ?>">
    <style>
        * { box-sizing: border-box; }
        body { font-family: "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; background: #1e293b; color: #e2e8f0; min-height: 100vh; }
        .imgproc-header { background: #0f172a; padding: 20px; text-align: center; border-bottom: 2px solid #3b82f6; }
        .imgproc-header h1 { margin: 0; font-size: 1.5rem; color: #f8fafc; }
        .imgproc-header p { margin: 8px 0 0; font-size: 14px; color: #94a3b8; }
        .imgproc-main { max-width: 960px; margin: 0 auto; padding: 24px; }
        .imgproc-tabs { display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 1px solid #334155; padding-bottom: 12px; }
        .imgproc-tab { background: #334155; color: #94a3b8; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-size: 14px; }
        .imgproc-tab:hover { background: #475569; color: #fff; }
        .imgproc-tab.active { background: #3b82f6; color: #fff; }
        .imgproc-pane { display: none; }
        .imgproc-pane.active { display: block; }
        .imgproc-dropzone { border: 2px dashed #475569; background: #334155; border-radius: 12px; padding: 40px; text-align: center; cursor: pointer; transition: 0.2s; color: #94a3b8; }
        .imgproc-dropzone:hover { border-color: #3b82f6; background: #475569; color: #e2e8f0; }
        .imgproc-dropzone .icon { font-size: 48px; margin-bottom: 12px; opacity: 0.8; }
        .imgproc-preview-row { display: flex; gap: 24px; flex-wrap: wrap; justify-content: center; margin-top: 20px; }
        .imgproc-preview-box { width: 220px; height: 220px; border: 1px solid #475569; border-radius: 8px; overflow: hidden; background: #334155; display: flex; align-items: center; justify-content: center; }
        .imgproc-preview-box.transparent-bg { background: repeating-conic-gradient(#475569 0% 25%, #1e293b 0% 50%) 50% / 16px 16px; }
        .imgproc-preview-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .imgproc-preview-box .placeholder { color: #64748b; font-size: 14px; }
        .imgproc-label { display: block; margin-bottom: 8px; font-size: 13px; color: #94a3b8; }
        .imgproc-progress { height: 6px; background: #334155; border-radius: 3px; overflow: hidden; margin: 16px 0; display: none; }
        .imgproc-progress.show { display: block; }
        .imgproc-progress-bar { height: 100%; width: 100%; background: linear-gradient(90deg, #3b82f6, #8b5cf6); animation: imgproc-pulse 1s ease-in-out infinite; }
        @keyframes imgproc-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
        .imgproc-btn { background: #3b82f6; color: #fff; border: none; padding: 10px 24px; border-radius: 8px; cursor: pointer; font-size: 14px; margin-top: 12px; }
        .imgproc-btn:hover { background: #2563eb; }
        .imgproc-btn.hidden { display: none; }
        .imgproc-desc { color: #94a3b8; font-size: 14px; margin-bottom: 20px; line-height: 1.6; }
        .imgproc-options { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin: 16px 0; }
        .imgproc-options label { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #94a3b8; }
        .imgproc-options input[type="color"] { width: 36px; height: 28px; padding: 2px; cursor: pointer; border: 1px solid #475569; border-radius: 6px; }
        .imgproc-options input[type="range"] { width: 120px; }
        .imgproc-preview-box.cursor-brush { cursor: crosshair; }
        .imgproc-canvas-wrap { position: relative; }
        .imgproc-canvas-wrap canvas { display: block; max-width: 100%; max-height: 280px; }
        .imgproc-btn-outline { background: transparent; border: 1px solid #475569; color: #94a3b8; }
        .imgproc-btn-outline:hover { background: #334155; color: #e2e8f0; }
        .imgproc-samples-hint { font-size: 13px; color: #64748b; }
        .imgproc-samples-strip { display: flex; flex-wrap: wrap; gap: 4px; margin: 12px 0; min-height: 24px; }
        .imgproc-samples-strip .swatch { width: 20px; height: 20px; border-radius: 4px; border: 1px solid #475569; }
    </style>
</head>
<body>
<header class="imgproc-header">
    <h1><?= __('图片处理工具集') ?></h1>
    <p><?= __('免费在线图片处理，按颜色去除背景（纯色/近似纯色）') ?></p>
</header>

<main class="imgproc-main">
    <div class="imgproc-tabs">
        <button type="button" class="imgproc-tab active" data-tab="remove-bg"><?= __('去除背景') ?></button>
        <button type="button" class="imgproc-tab" data-tab="more"><?= __('更多工具') ?></button>
    </div>

    <div id="pane-remove-bg" class="imgproc-pane active">
        <p class="imgproc-desc"><?= __('上传图片后，在图上涂抹背景区域取色（按住鼠标拖拽），取到的颜色会作为要去除的背景；调整容差与羽化后点击「去除背景」生成透明图。') ?></p>
        <div id="remove-bg-drop" class="imgproc-dropzone">
            <div class="icon">📤</div>
            <span id="remove-bg-hint"><?= __('点击或拖拽图片到此处') ?></span>
            <input type="file" id="remove-bg-input" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none">
        </div>
        <small class="imgproc-label" style="display:block;margin-top:8px"><?= __('支持 JPG、PNG、WebP、GIF') ?></small>
        <div id="remove-bg-options" class="imgproc-options" style="display:none">
            <span class="imgproc-label" style="margin-right:8px"><?= __('涂抹取色') ?></span>
            <span id="remove-bg-samples-hint" class="imgproc-samples-hint">0</span>
            <button type="button" class="imgproc-btn imgproc-btn-outline" id="remove-bg-clear"><?= __('清空取色') ?></button>
            <label>
                <span><?= __('容差') ?></span>
                <input type="range" id="remove-bg-tolerance" min="0" max="100" value="45">
                <span id="remove-bg-tolerance-val">45</span>
            </label>
            <label>
                <span><?= __('边缘羽化') ?></span>
                <input type="range" id="remove-bg-feather" min="0" max="80" value="25">
                <span id="remove-bg-feather-val">25</span>
            </label>
            <button type="button" class="imgproc-btn" id="remove-bg-run"><?= __('去除背景') ?></button>
        </div>
        <div id="remove-bg-samples-strip" class="imgproc-samples-strip" style="display:none"></div>
        <div id="remove-bg-progress" class="imgproc-progress"><div class="imgproc-progress-bar"></div></div>
        <button type="button" class="imgproc-btn hidden" id="remove-bg-download"><?= __('下载透明图') ?></button>
        <div class="imgproc-preview-row">
            <div>
                <span class="imgproc-label"><?= __('原图') ?> <small id="pick-hint" style="display:none">(<?= __('按住拖拽涂抹背景取色') ?>)</small></span>
                <div id="remove-bg-preview-origin" class="imgproc-preview-box imgproc-canvas-wrap">
                    <span class="placeholder"><?= __('待上传') ?></span>
                </div>
            </div>
            <div>
                <span class="imgproc-label"><?= __('去背景后') ?></span>
                <div id="remove-bg-preview-result" class="imgproc-preview-box transparent-bg">
                    <span class="placeholder"><?= __('待处理') ?></span>
                </div>
            </div>
        </div>
    </div>

    <div id="pane-more" class="imgproc-pane">
        <p class="imgproc-desc"><?= __('更多图片工具即将上线') ?></p>
    </div>
</main>

<script>
(function() {
    'use strict';
    const L = (k, d) => (typeof window.__ === 'function' ? window.__(k) : d);
    const MAX_SAMPLES = 200;
    const BRUSH_STEP = 4;

    document.querySelectorAll('.imgproc-tab').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.imgproc-tab').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.imgproc-pane').forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            const pane = document.getElementById('pane-' + btn.dataset.tab);
            if (pane) pane.classList.add('active');
        });
    });

    const dropEl = document.getElementById('remove-bg-drop');
    const inputEl = document.getElementById('remove-bg-input');
    const hintEl = document.getElementById('remove-bg-hint');
    const progressEl = document.getElementById('remove-bg-progress');
    const optionsEl = document.getElementById('remove-bg-options');
    const samplesHintEl = document.getElementById('remove-bg-samples-hint');
    const samplesStripEl = document.getElementById('remove-bg-samples-strip');
    const clearBtn = document.getElementById('remove-bg-clear');
    const toleranceEl = document.getElementById('remove-bg-tolerance');
    const toleranceValEl = document.getElementById('remove-bg-tolerance-val');
    const featherEl = document.getElementById('remove-bg-feather');
    const featherValEl = document.getElementById('remove-bg-feather-val');
    const runBtn = document.getElementById('remove-bg-run');
    const downloadBtn = document.getElementById('remove-bg-download');
    const previewOrigin = document.getElementById('remove-bg-preview-origin');
    const previewResult = document.getElementById('remove-bg-preview-result');
    const pickHint = document.getElementById('pick-hint');
    let resultBlob = null;
    let sourceCanvas = null;
    let samples = [];

    toleranceEl.addEventListener('input', function() { toleranceValEl.textContent = this.value; });
    featherEl.addEventListener('input', function() { featherValEl.textContent = this.value; });

    function updateSamplesUI() {
        samplesHintEl.textContent = samples.length + (typeof window.__ === 'function' ? window.__(' 个色') : ' 个色');
        samplesStripEl.style.display = samples.length ? 'flex' : 'none';
        samplesStripEl.innerHTML = '';
        samples.forEach(function(rgb) {
            const hex = '#' + rgb.map(function(x) { return x.toString(16).padStart(2, '0'); }).join('');
            const swatch = document.createElement('div');
            swatch.className = 'swatch';
            swatch.style.background = hex;
            samplesStripEl.appendChild(swatch);
        });
    }

    clearBtn.addEventListener('click', function() {
        samples = [];
        updateSamplesUI();
    });

    dropEl.addEventListener('click', () => inputEl.click());
    dropEl.addEventListener('dragover', e => { e.preventDefault(); dropEl.style.opacity = '0.8'; });
    dropEl.addEventListener('dragleave', () => { dropEl.style.opacity = '1'; });
    dropEl.addEventListener('drop', function(e) {
        e.preventDefault();
        dropEl.style.opacity = '1';
        const f = e.dataTransfer.files[0];
        if (f && f.type.startsWith('image/')) loadFile(f);
    });
    inputEl.addEventListener('change', function() {
        const f = inputEl.files[0];
        if (f) loadFile(f);
    });

    function loadFile(file) {
        hintEl.textContent = file.name;
        previewResult.innerHTML = '<span class="placeholder">' + L('待处理', '待处理') + '</span>';
        previewOrigin.innerHTML = '';
        samples = [];
        updateSamplesUI();
        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.onload = function() {
            let w = img.naturalWidth;
            let h = img.naturalHeight;
            const maxSide = 1200;
            if (w > maxSide || h > maxSide) {
                if (w >= h) {
                    h = Math.round(h * maxSide / w);
                    w = maxSide;
                } else {
                    w = Math.round(w * maxSide / h);
                    h = maxSide;
                }
            }
            sourceCanvas = document.createElement('canvas');
            sourceCanvas.width = w;
            sourceCanvas.height = h;
            const ctx = sourceCanvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            previewOrigin.innerHTML = '';
            previewOrigin.appendChild(sourceCanvas);
            previewOrigin.classList.add('cursor-brush');
            pickHint.style.display = 'inline';
            resultBlob = null;
            downloadBtn.classList.add('hidden');
            optionsEl.style.display = 'flex';

            let lastX = -999;
            let lastY = -999;
            function sampleAt(cx, cy) {
                const rect = sourceCanvas.getBoundingClientRect();
                const scaleX = sourceCanvas.width / rect.width;
                const scaleY = sourceCanvas.height / rect.height;
                const ix = Math.floor((cx - rect.left) * scaleX);
                const iy = Math.floor((cy - rect.top) * scaleY);
                if (ix < 0 || ix >= sourceCanvas.width || iy < 0 || iy >= sourceCanvas.height) return;
                const data = ctx.getImageData(ix, iy, 1, 1).data;
                const r = data[0], g = data[1], b = data[2];
                const key = r + ',' + g + ',' + b;
                if (samples.length >= MAX_SAMPLES) return;
                for (var i = 0; i < samples.length; i++) {
                    var s = samples[i];
                    if (s[0] === r && s[1] === g && s[2] === b) return;
                }
                samples.push([r, g, b]);
                updateSamplesUI();
            }
            function onMove(e) {
                const rect = sourceCanvas.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                if (e.buttons !== 1) return;
                const dx = x - lastX;
                const dy = y - lastY;
                const steps = Math.max(1, Math.floor(Math.sqrt(dx*dx + dy*dy) / BRUSH_STEP));
                for (let t = 0; t <= steps; t++) {
                    const cx = rect.left + lastX + dx * t / steps;
                    const cy = rect.top + lastY + dy * t / steps;
                    sampleAt(cx, cy);
                }
                lastX = x;
                lastY = y;
            }
            sourceCanvas.addEventListener('mousedown', function(e) {
                if (e.button !== 0) return;
                lastX = e.clientX - sourceCanvas.getBoundingClientRect().left;
                lastY = e.clientY - sourceCanvas.getBoundingClientRect().top;
                sampleAt(e.clientX, e.clientY);
            });
            sourceCanvas.addEventListener('mousemove', onMove);
            sourceCanvas.addEventListener('mouseleave', function() { lastX = -999; lastY = -999; });
        };
        previewOrigin.classList.remove('cursor-brush');
        pickHint.style.display = 'none';
        optionsEl.style.display = 'flex';
    }

    function colorDistance(r1, g1, b1, r2, g2, b2) {
        return Math.sqrt((r1 - r2) ** 2 + (g1 - g2) ** 2 + (b1 - b2) ** 2);
    }

    function minDistanceToSamples(r, g, b) {
        if (samples.length === 0) return 999;
        var min = 999;
        for (var i = 0; i < samples.length; i++) {
            var s = samples[i];
            var d = colorDistance(r, g, b, s[0], s[1], s[2]);
            if (d < min) min = d;
        }
        return min;
    }

    runBtn.addEventListener('click', function() {
        if (!sourceCanvas || samples.length === 0) return;
        const tolerance = Math.min(255, Math.round((Number(toleranceEl.value) / 100) * 255));
        const feather = Math.round((Number(featherEl.value) / 80) * 150);
        progressEl.classList.add('show');
        previewResult.innerHTML = '<span class="placeholder">' + L('处理中...', '处理中...') + '</span>';

        const w = sourceCanvas.width;
        const h = sourceCanvas.height;
        const work = document.createElement('canvas');
        work.width = w;
        work.height = h;
        const wctx = work.getContext('2d');
        wctx.drawImage(sourceCanvas, 0, 0);
        const imageData = wctx.getImageData(0, 0, w, h);
        const data = imageData.data;

        for (let i = 0; i < data.length; i += 4) {
            const r = data[i];
            const g = data[i + 1];
            const b = data[i + 2];
            const a = data[i + 3];
            const dist = minDistanceToSamples(r, g, b);
            if (dist <= tolerance) {
                data[i + 3] = 0;
            } else if (feather > 0 && dist < tolerance + feather) {
                data[i + 3] = Math.round(a * (dist - tolerance) / feather);
            }
        }
        wctx.putImageData(imageData, 0, 0);

        work.toBlob(function(blob) {
            progressEl.classList.remove('show');
            if (!blob) {
                previewResult.innerHTML = '<span class="placeholder" style="color:#ef4444">' + L('处理失败', '处理失败') + '</span>';
                return;
            }
            resultBlob = blob;
            const url = URL.createObjectURL(blob);
            previewResult.innerHTML = '';
            const resultImg = document.createElement('img');
            resultImg.src = url;
            resultImg.style.maxWidth = '100%';
            resultImg.style.maxHeight = '100%';
            resultImg.style.objectFit = 'contain';
            previewResult.appendChild(resultImg);
            downloadBtn.classList.remove('hidden');
        }, 'image/png');
    });

    downloadBtn.addEventListener('click', function() {
        if (!resultBlob) return;
        const a = document.createElement('a');
        a.href = URL.createObjectURL(resultBlob);
        a.download = 'no-bg-' + Date.now() + '.png';
        a.click();
        URL.revokeObjectURL(a.href);
    });
})();
</script>
</body>
</html>
