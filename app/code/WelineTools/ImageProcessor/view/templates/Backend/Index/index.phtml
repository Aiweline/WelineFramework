</style>

<script>
(function() {
    'use strict';
    var MAX_SAMPLES = 200;
    var BRUSH_STEP = 4;

    var dropEl = document.getElementById('remove-bg-drop');
    var inputEl = document.getElementById('remove-bg-input');
    var hintEl = document.getElementById('remove-bg-hint');
    var progressEl = document.getElementById('remove-bg-progress');
    var optionsEl = document.getElementById('remove-bg-options');
    var actionsEl = document.getElementById('remove-bg-actions');
    var samplesHintEl = document.getElementById('remove-bg-samples-hint');
    var samplesStripEl = document.getElementById('remove-bg-samples-strip');
    var clearBtn = document.getElementById('remove-bg-clear');
    var toleranceEl = document.getElementById('remove-bg-tolerance');
    var toleranceValEl = document.getElementById('remove-bg-tolerance-val');
    var featherEl = document.getElementById('remove-bg-feather');
    var featherValEl = document.getElementById('remove-bg-feather-val');
    var runBtn = document.getElementById('remove-bg-run');
    var previewOrigin = document.getElementById('remove-bg-preview-origin');
    var previewResult = document.getElementById('remove-bg-preview-result');
    var downloadBtn = document.getElementById('remove-bg-download');
    var pickHint = document.getElementById('pick-hint');
    var resultBlob = null;
    var sourceCanvas = null;
    var samples = [];

    function showToast(msg, type) {
        if (window.BackendToast && typeof window.BackendToast.show === 'function') {
            BackendToast.show(msg, type || 'info');
        } else {
            console.log(msg);
        }
    }

    function updateSamplesUI() {
        samplesHintEl.textContent = samples.length + (typeof window.__ === 'function' ? window.__(' 个色') : ' 个色');
        samplesStripEl.style.display = samples.length ? 'flex' : 'none';
        samplesStripEl.innerHTML = '';
        for (var i = 0; i < samples.length; i++) {
            var rgb = samples[i];
            var hex = '#' + rgb.map(function(x) { return x.toString(16).padStart(2, '0'); }).join('');
            var swatch = document.createElement('div');
            swatch.className = 'swatch';
            swatch.style.background = hex;
            samplesStripEl.appendChild(swatch);
        }
    }

    clearBtn.addEventListener('click', function() {
        samples = [];
        updateSamplesUI();
    });

    toleranceEl.addEventListener('input', function() { toleranceValEl.textContent = this.value; });
    featherEl.addEventListener('input', function() { featherValEl.textContent = this.value; });

    dropEl.addEventListener('click', function() { inputEl.click(); });
    dropEl.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropEl.style.opacity = '0.8';
    });
    dropEl.addEventListener('dragleave', function() { dropEl.style.opacity = '1'; });
    dropEl.addEventListener('drop', function(e) {
        e.preventDefault();
        dropEl.style.opacity = '1';
        var f = e.dataTransfer.files[0];
        if (f && f.type.startsWith('image/')) loadFile(f);
    });
    inputEl.addEventListener('change', function() {
        var f = inputEl.files[0];
        if (f) loadFile(f);
    });

    function loadFile(file) {
        hintEl.textContent = file.name;
        previewResult.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-muted">' + (typeof window.__ === 'function' ? window.__('待处理') : '待处理') + '</div>';
        previewOrigin.innerHTML = '';
        previewOrigin.classList.remove('d-flex', 'align-items-center', 'justify-content-center', 'cursor-brush');
        pickHint.classList.add('d-none');
        samples = [];
        updateSamplesUI();
        var img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.onload = function() {
            var w = img.naturalWidth;
            var h = img.naturalHeight;
            var maxSide = 1200;
            if (w > maxSide || h > maxSide) {
                if (w >= h) {
                    h = Math.round(h * maxSide / w);
                    w = maxSide;
                } else {
                    w = Math.round(w * maxSide / h);
                    h = maxSide;
                }
            }
            sourceCanvas = document.createElement('canvas');
            sourceCanvas.width = w;
            sourceCanvas.height = h;
            var ctx = sourceCanvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            previewOrigin.innerHTML = '';
            previewOrigin.appendChild(sourceCanvas);
            previewOrigin.classList.add('cursor-brush');
            pickHint.classList.remove('d-none');
            resultBlob = null;
            actionsEl.classList.add('d-none');
            optionsEl.classList.remove('d-none');

            var lastX = -999, lastY = -999;
            function sampleAt(cx, cy) {
                var rect = sourceCanvas.getBoundingClientRect();
                var scaleX = sourceCanvas.width / rect.width;
                var scaleY = sourceCanvas.height / rect.height;
                var ix = Math.floor((cx - rect.left) * scaleX);
                var iy = Math.floor((cy - rect.top) * scaleY);
                if (ix < 0 || ix >= sourceCanvas.width || iy < 0 || iy >= sourceCanvas.height) return;
                var data = ctx.getImageData(ix, iy, 1, 1).data;
                var r = data[0], g = data[1], b = data[2];
                if (samples.length >= MAX_SAMPLES) return;
                for (var i = 0; i < samples.length; i++) {
                    if (samples[i][0] === r && samples[i][1] === g && samples[i][2] === b) return;
                }
                samples.push([r, g, b]);
                updateSamplesUI();
            }
            sourceCanvas.addEventListener('mousedown', function(e) {
                if (e.button !== 0) return;
                lastX = e.clientX - sourceCanvas.getBoundingClientRect().left;
                lastY = e.clientY - sourceCanvas.getBoundingClientRect().top;
                sampleAt(e.clientX, e.clientY);
            });
            sourceCanvas.addEventListener('mousemove', function(e) {
                var rect = sourceCanvas.getBoundingClientRect();
                var x = e.clientX - rect.left;
                var y = e.clientY - rect.top;
                if (e.buttons !== 1) return;
                var dx = x - lastX, dy = y - lastY;
                var steps = Math.max(1, Math.floor(Math.sqrt(dx*dx + dy*dy) / BRUSH_STEP));
                for (var t = 0; t <= steps; t++) {
                    sampleAt(lastX + rect.left + dx * t / steps, lastY + rect.top + dy * t / steps);
                }
                lastX = x;
                lastY = y;
            });
            sourceCanvas.addEventListener('mouseleave', function() { lastX = -999; lastY = -999; });
        };
        optionsEl.classList.remove('d-none');
    }

    function colorDistance(r1, g1, b1, r2, g2, b2) {
        return Math.sqrt((r1 - r2) * (r1 - r2) + (g1 - g2) * (g1 - g2) + (b1 - b2) * (b1 - b2));
    }

    function minDistanceToSamples(r, g, b) {
        if (samples.length === 0) return 999;
        var min = 999;
        for (var i = 0; i < samples.length; i++) {
            var s = samples[i];
            var d = colorDistance(r, g, b, s[0], s[1], s[2]);
            if (d < min) min = d;
        }
        return min;
    }

    runBtn.addEventListener('click', function() {
        if (!sourceCanvas || samples.length === 0) return;
        var tolerance = Math.min(255, Math.round((Number(toleranceEl.value) / 100) * 255));
        var feather = Math.round((Number(featherEl.value) / 80) * 150);
        progressEl.style.display = 'block';
        previewResult.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-muted">' + (typeof window.__ === 'function' ? window.__('处理中...') : '处理中...') + '</div>';

        var w = sourceCanvas.width;
        var h = sourceCanvas.height;
        var work = document.createElement('canvas');
        work.width = w;
        work.height = h;
        var wctx = work.getContext('2d');
        wctx.drawImage(sourceCanvas, 0, 0);
        var imageData = wctx.getImageData(0, 0, w, h);
        var data = imageData.data;

        for (var i = 0; i < data.length; i += 4) {
            var dist = minDistanceToSamples(data[i], data[i+1], data[i+2]);
            if (dist <= tolerance) {
                data[i + 3] = 0;
            } else if (feather > 0 && dist < tolerance + feather) {
                data[i + 3] = Math.round(data[i + 3] * (dist - tolerance) / feather);
            }
        }
        wctx.putImageData(imageData, 0, 0);

        work.toBlob(function(blob) {
            progressEl.style.display = 'none';
            if (!blob) {
                previewResult.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-danger small p-2">' + (typeof window.__ === 'function' ? window.__('处理失败') : '处理失败') + '</div>';
                return;
            }
            resultBlob = blob;
            var url = URL.createObjectURL(blob);
            previewResult.innerHTML = '';
            var resultImg = document.createElement('img');
            resultImg.src = url;
            resultImg.style.maxWidth = '100%';
            resultImg.style.maxHeight = '100%';
            resultImg.style.objectFit = 'contain';
            previewResult.appendChild(resultImg);
            previewResult.classList.remove('d-flex', 'align-items-center', 'justify-content-center');
            actionsEl.classList.remove('d-none');
            showToast(typeof window.__ === 'function' ? window.__('去背景完成') : '去背景完成', 'success');
        }, 'image/png');
    });

    downloadBtn.addEventListener('click', function() {
        if (!resultBlob) return;
        var a = document.createElement('a');
        a.href = URL.createObjectURL(resultBlob);
        a.download = 'no-bg-' + Date.now() + '.png';
        a.click();
        URL.revokeObjectURL(a.href);
        showToast(typeof window.__ === 'function' ? window.__('已开始下载') : '已开始下载', 'success');
    });
})();
</script>
