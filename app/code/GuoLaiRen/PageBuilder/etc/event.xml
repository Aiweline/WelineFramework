<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!--
        网站保存后事件：
        - 新建站点 / 更新站点时，将站点归属到当前后台用户。
        - 一个站点同一时间只能分配给一个后台用户，后续分配会自动替换之前的分配关系。
    -->
    <event name="GuoLaiRen_PageBuilder::website_save_after">
        <observer name="GuoLaiRen_PageBuilder::website_user_auto_assign"
                  instance="GuoLaiRen\PageBuilder\Observer\WebsiteUserAutoAssign"
                  sort="10"
                  shared="1"
                  disabled="0"/>
    </event>

    <!--
        虚拟主题请求拦截：
        - 在路由处理前检测 virtual_theme_id 参数
        - 注入虚拟主题上下文到 Request，让 Theme 模块能够识别
        - 优先级设为 5，早于 ACL 检查（sort=1）和其他业务逻辑
    -->
    <event name="Weline_Framework_Router::route_before">
        <observer name="GuoLaiRen_PageBuilder::virtual_theme_request_interceptor"
                  instance="GuoLaiRen\PageBuilder\Observer\VirtualThemeRequestInterceptor"
                  sort="5"
                  shared="1"
                  disabled="0"/>
    </event>
</config>

