<?php
/**
 * Rummy Overdrive - Header
 *
 * @fields_start
 *
 * group:color_scheme => 配色方案
 * color_scheme.scheme => 主题配色方案:select:default|default,blue,green,purple,red
 *
 * group:header_logo => Header Logo设置
 * header.logo.display => 显示Logo:select:yes|yes,no
 * header.logo.text => Logo旁文本:text:Rummy Overdrive
 * header.logo.subline => Logo副标题:text:Neon Rummy Route
 * header.logo.url => Logo地址:textarea:|默认使用主题Logo
 * header.logo.width => Logo宽度:responsive:52/52|px
 * header.logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 *
 * group:header_navigation => Header导航设置
 * header.navigation.display => 显示导航:select:yes|yes,no
 * header.navigation.bg_color => 导航背景色:color:rgba(7,10,20,0.82)
 * header.navigation.text_color => 导航文字颜色:color:#f7f8fc
 * header.navigation.link_color => 链接颜色:color:#d4d8e5
 * header.navigation.link_hover_color => 链接悬停颜色:color:#d2ff3f
 * header.navigation.items => 导航项:textarea:Home=>/\r\nTables=>#tables\r\nWhy Overdrive=>#advantages\r\nPlayers=>#reviews\r\nFAQ=>#faq|每行一项，格式：标题=>链接
 * header.navigation.label_home_page => 首页菜单名:text:
 * header.navigation.label_about_page => 关于我们菜单名:text:
 * header.navigation.label_blog_list => 博客菜单名:text:
 * header.navigation.label_contact_page => 联系我们菜单名:text:
 * header.navigation.label_terms_of_service => 条款菜单名:text:
 * header.navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:header_download_button => Header下载按钮
 * header.download_button.display => 显示下载按钮:select:yes|yes,no
 * header.download_button.text => 按钮文字:text:Download Pulse
 * header.download_button.url => 按钮链接:text:#download
 * header.download_button.bg_color => 按钮背景色:color:#ff4d7a
 * header.download_button.text_color => 按钮文字颜色:color:#05070e
 * header.download_button.hover_bg_color => 按钮悬停背景色:color:#ff8c42
 * header.download_button.size => 按钮字号:responsive:13/13|px
 * header.download_button.padding => 按钮内边距:responsive:12/12|px
 * header.download_button.border_radius => 按钮圆角:number:999|px
 * header.download_button.extra_classes => 按钮附加类名:text:
 *
 * group:banner => Banner兼容设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用主题Banner
 * banner.image_desktop => PC端Banner图片:textarea:|默认使用主题Banner
 * banner.alt => Banner图片描述:text:Rummy Overdrive hero preview
 * banner.bg_color => Banner背景基础色:color:#090f1d
 * banner.slider_classes => Banner附加类名:text:rov-hero-stage
 * banner.padding_v => Banner上下内边距:responsive:0/0|px
 * banner.download_btn_image => Banner下载按钮图片:textarea:|默认使用主题下载按钮图
 * banner.download_btn_alt => Banner下载按钮描述:text:Download Rummy Overdrive
 *
 * group:pixel => 像素追踪
 * pixel.enabled => 启用像素:select:no|yes,no
 * pixel.name => 像素名称:text:
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

$templateCode = $page ? $page->getData('style') : 'rummy-overdrive';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'rummy-overdrive';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__rov_shell_managed', true);
$this->assign('__pagebuilder_shell_managed', true);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?= $this->fetchTemplate('GuoLaiRen_PageBuilder::style/rummy-overdrive/components/header/nav.phtml') ?>
