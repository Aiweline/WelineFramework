<?php
/**
 * Rummy Overdrive Blog Category Component
 *
 * @fields_start
 * blog.title|Category title|text|Browse the Overdrive Desk
 * blog.subtitle|Category subtitle|text|Explore tactics, beginner notes, room updates, and responsible-play explainers.
 * blog.posts_per_page|Posts per page|number|9
 * blog.show_sidebar|Show sidebar|select:yes=Yes,no=No|yes
 * blog.show_category|Show category|select:yes=Yes,no=No|yes
 * blog.show_date|Show date|select:yes=Yes,no=No|yes
 * blog.show_author|Show author|select:yes=Yes,no=No|yes
 * blog.card_style|Card style|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$componentId = 'rov-blog-category-' . uniqid();
$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? __('Category Posts'));
$subtitle = $getConfig('blog.subtitle', __('Browse articles by category'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';

$primaryColor = $getConfig('color_scheme.primary', '#ff4d7a');
$secondaryColor = $getConfig('color_scheme.secondary', '#2be7ff');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/poker-header-bg.svg');

$spotlightPost = $blogPosts[0] ?? null;
$timelinePosts = array_slice($blogPosts, 1);
$postCount = count($blogPosts);
?>

<section id="<?= $componentId ?>" class="rov-blog-category">
    <div class="category-shell">
        <div class="category-grid<?= $showSidebar ? ' has-rail' : '' ?>">
            <aside class="overview-panel wow animate__animated animate__fadeInLeft">
                <?php if (!empty($currentCategory['name'])): ?>
                    <span class="category-chip"><?= htmlspecialchars($currentCategory['name']) ?></span>
                <?php endif; ?>

                <h1><?= htmlspecialchars($title) ?></h1>

                <?php if ($subtitle): ?>
                    <p class="overview-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>

                <?php if (!empty($currentCategory['description'])): ?>
                    <div class="overview-note">
                        <span class="note-kicker"><?= __('Category Focus') ?></span>
                        <p><?= htmlspecialchars($currentCategory['description']) ?></p>
                    </div>
                <?php endif; ?>

                <div class="overview-metrics">
                    <article>
                        <strong><?= (int)$postCount ?></strong>
                        <span><?= __('Active stories') ?></span>
                    </article>
                    <article>
                        <strong><?= (int)count($blogCategories) ?></strong>
                        <span><?= __('Tracked lanes') ?></span>
                    </article>
                </div>

                <a href="/blog" class="back-link"><?= __('Back To Blog') ?></a>

                <?php if ($showSidebar && !empty($blogCategories)): ?>
                    <section class="overview-card">
                        <span class="card-kicker"><?= __('Topic Radar') ?></span>
                        <h3><?= __('Browse categories') ?></h3>
                        <div class="category-list">
                            <?php foreach ($blogCategories as $category): ?>
                                <?php $active = !empty($currentCategory['id']) && isset($category['id']) && $category['id'] == $currentCategory['id']; ?>
                                <a href="<?= htmlspecialchars($category['url']) ?>" class="category-entry<?= $active ? ' is-active' : '' ?>">
                                    <span><?= htmlspecialchars($category['name']) ?></span>
                                    <?php if (isset($category['post_count'])): ?>
                                        <small><?= (int)$category['post_count'] ?></small>
                                    <?php endif; ?>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    </section>
                <?php endif; ?>

                <?php if ($showSidebar && !empty($recentPosts)): ?>
                    <section class="overview-card">
                        <span class="card-kicker"><?= __('Fresh Signals') ?></span>
                        <h3><?= __('Recent posts') ?></h3>
                        <div class="recent-stack">
                            <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                    <?php endif; ?>
                                    <span>
                                        <strong><?= htmlspecialchars($post['title']) ?></strong>
                                        <?php if (!empty($post['published_at'])): ?>
                                            <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                        <?php endif; ?>
                                    </span>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    </section>
                <?php endif; ?>
            </aside>

            <div class="category-feed">
                <?php if (empty($blogPosts)): ?>
                    <div class="category-empty wow animate__animated animate__fadeInUp">
                        <div class="empty-icon">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.34" xmlns="http://www.w3.org/2000/svg">
                                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                            </svg>
                        </div>
                        <h2><?= __('This lane has no live articles yet.') ?></h2>
                        <p><?= __('As soon as new posts land in this category, they will appear here in the category timeline.') ?></p>
                    </div>
                <?php else: ?>
                    <?php if ($spotlightPost): ?>
                        <article class="headline-dock wow animate__animated animate__fadeInUp">
                            <div class="headline-copy">
                                <span class="headline-kicker"><?= __('Category Lead') ?></span>
                                <h2>
                                    <a href="<?= htmlspecialchars($spotlightPost['url']) ?>"><?= htmlspecialchars($spotlightPost['title']) ?></a>
                                </h2>

                                <div class="meta-row">
                                    <?php if ($showCategory && !empty($spotlightPost['category_name'])): ?>
                                        <span class="story-chip"><?= htmlspecialchars($spotlightPost['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($spotlightPost['published_at'])): ?>
                                        <span class="story-date"><?= date('M d, Y', strtotime($spotlightPost['published_at'])) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showAuthor && !empty($spotlightPost['author'])): ?>
                                        <span class="story-author"><?= htmlspecialchars($spotlightPost['author']) ?></span>
                                    <?php endif; ?>
                                </div>

                                <?php if (!empty($spotlightPost['summary'])): ?>
                                    <p>
                                        <?= htmlspecialchars(mb_substr($spotlightPost['summary'], 0, 240)) ?><?= mb_strlen($spotlightPost['summary']) > 240 ? '...' : '' ?>
                                    </p>
                                <?php endif; ?>

                                <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="story-link">
                                    <?= __('Read Article') ?>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                    </svg>
                                </a>
                            </div>

                            <?php if (!empty($spotlightPost['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="headline-media">
                                    <img src="<?= htmlspecialchars($spotlightPost['cover_image']) ?>" alt="<?= htmlspecialchars($spotlightPost['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($timelinePosts)): ?>
                        <div class="timeline-lane">
                            <?php foreach ($timelinePosts as $index => $post): ?>
                                <?php $offsetClass = $index % 2 === 1 ? ' is-offset' : ''; ?>
                                <article class="timeline-card<?= $offsetClass ?> wow animate__animated animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.06 * (($index % 5) + 1), 2)) ?>s">
                                    <span class="timeline-point" aria-hidden="true"></span>
                                    <div class="timeline-body">
                                        <?php if (!empty($post['cover_image'])): ?>
                                            <a href="<?= htmlspecialchars($post['url']) ?>" class="timeline-media">
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            </a>
                                        <?php endif; ?>

                                        <div class="timeline-copy">
                                            <div class="meta-row">
                                                <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                    <span class="story-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                                <?php endif; ?>
                                                <?php if ($showDate && !empty($post['published_at'])): ?>
                                                    <span class="story-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                                <?php endif; ?>
                                            </div>

                                            <h3>
                                                <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a>
                                            </h3>

                                            <?php if (!empty($post['summary'])): ?>
                                                <p>
                                                    <?= htmlspecialchars(mb_substr($post['summary'], 0, 170)) ?><?= mb_strlen($post['summary']) > 170 ? '...' : '' ?>
                                                </p>
                                            <?php endif; ?>

                                            <div class="timeline-foot">
                                                <?php if ($showAuthor && !empty($post['author'])): ?>
                                                    <span class="story-author"><?= htmlspecialchars($post['author']) ?></span>
                                                <?php endif; ?>
                                                <a href="<?= htmlspecialchars($post['url']) ?>" class="story-link"><?= __('Open Story') ?></a>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>
    </div>
</section>

