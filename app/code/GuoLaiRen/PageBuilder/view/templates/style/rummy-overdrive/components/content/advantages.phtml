<?php
/**
 * @component_start
 * code: advantages
 * name: 优势展示
 * name_en: Advantages
 * description: 展示 Rummy Overdrive 的核心优势
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示描述:select:yes|yes,no
 * display.show_button => 显示按钮:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#d9ff45
 * style.title_color => 标题颜色:color:#05070e
 * style.title_font_size => 标题字体大小(PC端):number:64|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:34|px
 * style.card_bg_color => 卡片背景色:color:rgba(7,10,20,0.9)
 * style.card_border_color => 卡片边框色:color:rgba(5,7,14,0.18)
 * style.card_title_color => 卡片标题颜色:color:#ffffff
 * style.card_title_font_size => 卡片标题字号:number:24|px
 * style.card_desc_color => 卡片描述颜色:color:#b7bfd1
 * style.card_desc_font_size => 卡片描述字号:number:15|px
 * style.icon_size => 图标尺寸:number:58|px
 * style.icon_border_radius => 图标圆角:number:18|px
 * style.section_padding => 区域内边距(PC端):number:84|px
 * style.section_padding_mobile => 区域内边距(移动端):number:52|px
 * style.card_gap => 卡片间距:number:24|px
 *
 * group:button => 按钮配置
 * button.text => 按钮文本:text:View Tables
 * button.url => 按钮链接:text:#tables
 * button.bg_gradient_start => 按钮渐变起始色:color:#111728
 * button.bg_gradient_end => 按钮渐变结束色:color:#2be7ff
 * button.text_color => 按钮文字颜色:color:#f7f8fc
 * button.border_radius => 按钮圆角:number:999|px
 * button.padding_x => 按钮水平内边距:number:26|px
 * button.padding_y => 按钮垂直内边距:number:12|px
 *
 * group:icons => 图标配置
 * icons.icon_1 => 优势1图标:textarea:
 * icons.icon_2 => 优势2图标:textarea:
 * icons.icon_3 => 优势3图标:textarea:
 *
 * group:texts => 文本内容
 * texts.kicker => 区域徽标:text:Overdrive gains
 * texts.title => 区域标题:text:Why Rummy Overdrive Feels Faster
 * texts.summary => 区域辅助文案:textarea:The goal is not just brighter color. It is a faster reading path for rummy players, stronger contrast between sections, and a homepage that feels more alive on every hover and swipe.
 * texts.metric_1_value => 指标1主文案:text:Mobile-first
 * texts.metric_1_label => 指标1说明:text:Large touch zones
 * texts.metric_2_value => 指标2主文案:text:Rummy-led
 * texts.metric_2_label => 指标2说明:text:More relevant defaults
 * texts.metric_3_value => 指标3主文案:text:High contrast
 * texts.metric_3_label => 指标3说明:text:Sharper module separation
 * texts.advantage_1_icon => 优势1兼容图标:text:01
 * texts.advantage_1_title => 优势1标题:text:Scan The Table In One Pass
 * texts.advantage_1_desc => 优势1描述:textarea:Cash tables, practice rooms, and rummy entry routes are organized in a clearer visual stack, so the player does not waste time hunting the next move.
 * texts.advantage_2_icon => 优势2兼容图标:text:02
 * texts.advantage_2_title => 优势2标题:text:Built Around Rummy Decisions
 * texts.advantage_2_desc => 优势2描述:textarea:Joker pressure, set building, and run-focused table notes are surfaced earlier, making the whole landing page feel more game-aware.
 * texts.advantage_3_icon => 优势3兼容图标:text:03
 * texts.advantage_3_title => 优势3标题:text:Motion Without Noise
 * texts.advantage_3_desc => 优势3描述:textarea:Animated streaks, glowing rails, and hover passes add energy, while the core buttons and descriptions still stay readable on mobile.
 *
 * @fields_end
 */

$componentId = 'rov-advantages-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getCardConfig = static function (int $index, array $keys, $default = '') use ($getConfigAny) {
    $scope = 'advantage_' . $index;
    $scopedKeys = [];
    foreach ($keys as $key) {
        $scopedKeys[] = $scope . '.' . $key;
    }

    return $getConfigAny(array_merge($scopedKeys, $keys), $default);
};

$display = $getConfigAny(['display.show_section', 'advantages.display'], 'yes') !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfigAny(['display.show_title'], 'yes') !== 'no';
$showDescription = $getConfigAny(['display.show_description'], 'yes') !== 'no';
$showButton = $getConfigAny(['display.show_button'], 'no') !== 'no';

$bgColor = (string) $getConfigAny(['style.bg_color', 'advantages.bg_color'], '#d9ff45');
$titleColor = (string) $getConfigAny(['style.title_color'], '#05070e');
$titleFontSize = (int) $getConfigAny(['style.title_font_size'], '64');
$titleFontSizeMobile = (int) $getConfigAny(['style.title_font_size_mobile'], '34');
$cardBgColor = (string) $getConfigAny(['style.card_bg_color'], 'rgba(7,10,20,0.9)');
$cardBorderColor = (string) $getConfigAny(['style.card_border_color'], 'rgba(5,7,14,0.18)');
$cardTitleColor = (string) $getConfigAny(['style.card_title_color'], '#ffffff');
$cardTitleFontSize = (int) $getConfigAny(['style.card_title_font_size'], '24');
$cardDescColor = (string) $getConfigAny(['style.card_desc_color'], '#b7bfd1');
$cardDescFontSize = (int) $getConfigAny(['style.card_desc_font_size'], '15');
$iconSize = (int) $getConfigAny(['style.icon_size'], '58');
$iconBorderRadius = (int) $getConfigAny(['style.icon_border_radius'], '18');
$sectionPadding = (int) $getConfigAny(['style.section_padding'], '84');
$sectionPaddingMobile = (int) $getConfigAny(['style.section_padding_mobile'], '52');
$cardGap = (int) $getConfigAny(['style.card_gap'], '24');

$buttonText = trim((string) $getConfigAny(['button.text'], 'View Tables'));
$buttonUrl = trim((string) $getConfigAny(['button.url'], '#tables'));
$buttonGradientStart = (string) $getConfigAny(['button.bg_gradient_start'], '#111728');
$buttonGradientEnd = (string) $getConfigAny(['button.bg_gradient_end'], '#2be7ff');
$buttonTextColor = (string) $getConfigAny(['button.text_color'], '#f7f8fc');
$buttonBorderRadius = (int) $getConfigAny(['button.border_radius'], '999');
$buttonPaddingX = (int) $getConfigAny(['button.padding_x'], '26');
$buttonPaddingY = (int) $getConfigAny(['button.padding_y'], '12');

$kicker = trim((string) $getConfigAny(['texts.kicker'], 'Overdrive gains'));
$title = (string) $getConfigAny(['texts.title', 'advantages.title'], 'Why Rummy Overdrive Feels Faster');
$summary = trim((string) $getConfigAny(
    ['texts.summary', 'texts.advantages_summary'],
    'The goal is not just brighter color. It is a faster reading path for rummy players, stronger contrast between sections, and a homepage that feels more alive on every hover and swipe.'
));

$metrics = [];
for ($i = 1; $i <= 3; $i++) {
    $metricValue = trim((string) $getConfigAny(['texts.metric_' . $i . '_value'], ''));
    $metricLabel = trim((string) $getConfigAny(['texts.metric_' . $i . '_label'], ''));
    if ($metricValue !== '' || $metricLabel !== '') {
        $metrics[] = [
            'value' => $metricValue,
            'label' => $metricLabel,
        ];
    }
}

$isImageValue = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return false;
    }

    if (stripos($value, 'data:image/') === 0) {
        return true;
    }

    return (bool) preg_match('/\.(svg|png|jpe?g|webp|gif|avif)(\?.*)?$/i', $value);
};

$items = [];
$defaultItems = [
    1 => [
        'icon' => '01',
        'title' => 'Scan The Table In One Pass',
        'desc' => 'Cash tables, practice rooms, and rummy entry routes are organized in a clearer visual stack, so the player does not waste time hunting the next move.',
    ],
    2 => [
        'icon' => '02',
        'title' => 'Built Around Rummy Decisions',
        'desc' => 'Joker pressure, set building, and run-focused table notes are surfaced earlier, making the whole landing page feel more game-aware.',
    ],
    3 => [
        'icon' => '03',
        'title' => 'Motion Without Noise',
        'desc' => 'Animated streaks, glowing rails, and hover passes add energy, while the core buttons and descriptions still stay readable on mobile.',
    ],
];

for ($i = 1; $i <= 3; $i++) {
    $defaults = $defaultItems[$i];
    $iconValue = trim((string) $getCardConfig($i, ['icons.icon_' . $i, 'texts.advantage_' . $i . '_icon'], $defaults['icon']));
    $items[] = [
        'icon' => $iconValue !== '' ? $iconValue : $defaults['icon'],
        'title' => (string) $getCardConfig($i, ['texts.advantage_' . $i . '_title'], $defaults['title']),
        'desc' => (string) $getCardConfig($i, ['texts.advantage_' . $i . '_desc'], $defaults['desc']),
    ];
}
?>

<section id="<?= $componentId ?>" class="rov-advantages" aria-labelledby="<?= $componentId ?>-title">
    <div class="adv-shell">
        <div class="adv-grid">
            <header class="adv-lead" id="advantages">
                <?php if ($kicker !== ''): ?>
                    <span class="adv-kicker wow animate__fadeInDown"><?= htmlspecialchars($kicker) ?></span>
                <?php endif; ?>

                <?php if ($showTitle): ?>
                    <h2 id="<?= $componentId ?>-title" class="wow animate__fadeInUp" data-wow-delay="0.08s"><?= htmlspecialchars($title) ?></h2>
                <?php endif; ?>

                <?php if ($showDescription && $summary !== ''): ?>
                    <p class="wow animate__fadeInUp" data-wow-delay="0.16s"><?= nl2br(htmlspecialchars($summary)) ?></p>
                <?php endif; ?>

                <?php if (!empty($metrics)): ?>
                    <div class="adv-metrics">
                        <?php foreach ($metrics as $index => $metric): ?>
                            <article class="metric-card wow animate__fadeInUp" data-wow-delay="<?= number_format((240 + ($index * 70)) / 1000, 2) ?>s">
                                <?php if ($metric['value'] !== ''): ?>
                                    <strong><?= htmlspecialchars($metric['value']) ?></strong>
                                <?php endif; ?>
                                <?php if ($metric['label'] !== ''): ?>
                                    <span><?= htmlspecialchars($metric['label']) ?></span>
                                <?php endif; ?>
                            </article>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>

                <?php if ($showButton && $buttonText !== '' && $buttonUrl !== ''): ?>
                    <a class="adv-button wow animate__fadeInUp" data-wow-delay="0.22s" href="<?= htmlspecialchars($buttonUrl) ?>">
                        <span><?= htmlspecialchars($buttonText) ?></span>
                    </a>
                <?php endif; ?>
            </header>

            <div class="adv-stack">
                <?php foreach ($items as $index => $item): ?>
                    <article class="adv-card adv-card-<?= (int) $index ?> wow animate__fadeInUp" data-wow-delay="<?= number_format((220 + ($index * 110)) / 1000, 2) ?>s">
                        <span class="adv-index<?= $isImageValue($item['icon']) ? ' is-image' : '' ?>">
                            <?php if ($isImageValue($item['icon'])): ?>
                                <img src="<?= htmlspecialchars($item['icon']) ?>" alt="" loading="lazy" decoding="async">
                            <?php else: ?>
                                <?= htmlspecialchars($item['icon']) ?>
                            <?php endif; ?>
                        </span>
                        <div class="adv-copy">
                            <h3><?= htmlspecialchars($item['title']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= nl2br(htmlspecialchars($item['desc'])) ?></p>
                            <?php endif; ?>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

