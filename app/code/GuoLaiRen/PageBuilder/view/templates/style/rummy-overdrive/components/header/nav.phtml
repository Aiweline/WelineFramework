<script>
(function() {
    var nav = document.getElementById('<?= $componentId ?>');
    if (!nav) {
        return;
    }

    var toggle = nav.querySelector('.nav-toggle');
    var panel = document.getElementById('<?= $componentId ?>-mobile');
    var overlay = document.getElementById('<?= $componentId ?>-overlay');
    var closeButton = panel ? panel.querySelector('.mobile-close') : null;
    if (!toggle || !panel || !overlay) {
        return;
    }

    var syncScrolledState = function () {
        nav.classList.toggle('is-scrolled', window.scrollY > 10);
    };

    var closePanel = function() {
        nav.setAttribute('data-mobile-open', 'false');
        toggle.setAttribute('aria-expanded', 'false');
        panel.classList.remove('is-active');
        overlay.classList.remove('is-active');
        panel.setAttribute('aria-hidden', 'true');
        overlay.setAttribute('aria-hidden', 'true');
        window.setTimeout(function() {
            if (nav.getAttribute('data-mobile-open') === 'false') {
                panel.style.display = '';
                overlay.style.display = '';
            }
        }, 280);
    };

    var openPanel = function() {
        nav.setAttribute('data-mobile-open', 'true');
        toggle.setAttribute('aria-expanded', 'true');
        panel.setAttribute('aria-hidden', 'false');
        overlay.setAttribute('aria-hidden', 'false');
        window.requestAnimationFrame(function() {
            panel.classList.add('is-active');
            overlay.classList.add('is-active');
        });
    };

    toggle.addEventListener('click', function() {
        var isOpen = nav.getAttribute('data-mobile-open') === 'true';
        if (isOpen) {
            closePanel();
            return;
        }
        openPanel();
    });

    panel.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', closePanel);
    });

    if (closeButton) {
        closeButton.addEventListener('click', closePanel);
    }

    overlay.addEventListener('click', closePanel);

    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && nav.getAttribute('data-mobile-open') === 'true') {
            closePanel();
        }
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 1023 && nav.getAttribute('data-mobile-open') === 'true') {
            closePanel();
        }
    });

    window.addEventListener('scroll', syncScrolledState, { passive: true });
    syncScrolledState();
})();
</script>
