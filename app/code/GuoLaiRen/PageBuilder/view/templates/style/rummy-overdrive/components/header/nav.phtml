/**
 * Rummy Overdrive - Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航栏
 * name_en: Navigation Bar
 * description: 霓虹赛道风导航，支持移动端菜单与底部流光动画
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 *
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo旁文本:text:Rummy Overdrive
 * logo.subline => Logo副标题:text:Neon Rummy Route
 * logo.url => Logo地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:responsive:52/52|px
 * logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 *
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:rgba(7,10,20,0.82)
 * navigation.bg_color_scrolled => 滚动后背景色:color:rgba(7,10,20,0.96)
 * navigation.text_color => 导航文字颜色:color:#f7f8fc
 * navigation.link_color => 链接颜色:color:#d4d8e5
 * navigation.link_hover_color => 链接悬停颜色:color:#d2ff3f
 * navigation.link_font_size => 链接字号:number:14|px
 * navigation.link_font_weight => 链接字重:number:600
 * navigation.link_gap => 链接间距:number:16|px
 * navigation.padding_x => 水平内边距:number:16|px
 * navigation.padding_y => 垂直内边距:number:13|px
 * navigation.min_height => 最小高度:number:78|px
 * navigation.box_shadow => 阴影:text:0 18px 42px rgba(0,0,0,0.24)
 * navigation.backdrop_blur => 背景模糊:number:18|px
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.items => 导航项配置:textarea:Home=>/\r\nTables=>#tables\r\nWhy Overdrive=>#advantages\r\nPlayers=>#reviews\r\nFAQ=>#faq|配置格式：名字=>url，一行一个
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * navigation.use_subpages => 兼容旧版-使用子页面生成导航:select:no|yes,no
 *
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文字:text:Download Pulse
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff4d7a
 * download_button.bg_hover_color => 按钮悬停背景色:color:#ff8c42
 * download_button.text_color => 按钮文字颜色:color:#05070e
 * download_button.font_size => 按钮字号:number:13|px
 * download_button.font_weight => 按钮字重:number:800
 * download_button.border_radius => 按钮圆角:number:999|px
 * download_button.padding_x => 按钮水平内边距:number:18|px
 * download_button.padding_y => 按钮垂直内边距:number:12|px
 *
 * @fields_end
 */

$componentId = 'rov-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$standaloneShell = !($this->getData('__rov_shell_managed') || $this->getData('__pagebuilder_shell_managed'));

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$sanitizeTitle = function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string) $value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string) ($parts[0] ?? '')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function ($parsed) {
    $mobile = (float) $parsed['mobile'];
    $desktop = (float) $parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$pageTitleRaw = $page ? ($page->getData('meta_title') ?: $page->getData('title') ?: '') : '';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'Rummy Overdrive';
}

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle((string) $getConfigAny(['logo.text', 'header.logo.text'], $pageTitle));
if ($logoText === '') {
    $logoText = 'Rummy Overdrive';
}
$logoSubline = trim((string) $getConfigAny(['logo.subline', 'header.logo.subline'], 'Neon Rummy Route'));
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/overdrive-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '52/52') . 'px'));
$logoHeightConfig = trim((string) $getConfigAny(['logo.height', 'header.logo.height'], ''));
$logoHeight = $logoHeightConfig !== '' ? $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px')) : $logoWidth;

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], 'rgba(7,10,20,0.82)');
$navBgColorScrolled = (string) $getConfigAny(['navigation.bg_color_scrolled'], 'rgba(7,10,20,0.96)');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#f7f8fc');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#d4d8e5');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#d2ff3f');
$navLinkFontSize = (int) $getConfigAny(['navigation.link_font_size'], '14');
$navLinkFontWeight = (int) $getConfigAny(['navigation.link_font_weight'], '600');
$navLinkGap = (int) $getConfigAny(['navigation.link_gap'], '16');
$navPaddingX = (int) $getConfigAny(['navigation.padding_x'], '16');
$navPaddingY = (int) $getConfigAny(['navigation.padding_y'], '13');
$navMinHeight = (int) $getConfigAny(['navigation.min_height'], '78');
$navBoxShadow = (string) $getConfigAny(['navigation.box_shadow'], '0 18px 42px rgba(0,0,0,0.24)');
$navBackdropBlur = (int) $getConfigAny(['navigation.backdrop_blur'], '18');
$useCustomLinksRaw = (string) $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], '');
$legacyUseSubpagesRaw = (string) $getConfigAny(['navigation.use_subpages'], '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($legacyUseSubpagesRaw, 'no') !== 'yes';
$navItemsConfig = (string) $getConfigAny(
    ['navigation.items', 'header.navigation.items'],
    "Home=>/\nTables=>#tables\nWhy Overdrive=>#advantages\nPlayers=>#reviews\nFAQ=>#faq"
);

$downloadBtnDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Download Pulse'));
$ctaUrl = (string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download');
$downloadBtnBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff4d7a');
$downloadBtnBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], '#ff8c42');
$downloadBtnTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#05070e');
$downloadBtnFontSize = (int) $getConfigAny(['download_button.font_size'], '13');
$downloadBtnFontWeight = (int) $getConfigAny(['download_button.font_weight'], '800');
$downloadBtnRadius = (int) $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '999');
$downloadBtnPaddingX = (int) $getConfigAny(['download_button.padding_x'], '18');
$downloadBtnPaddingY = (int) $getConfigAny(['download_button.padding_y'], '12');

if (!$navDisplay) {
    return;
}

$navItems = [];

if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(12)
        : $page->getNavigationPages([], 12);
    foreach ($navigationPages as $navPage) {
        $type = trim((string) ($navPage['type'] ?? ''));
        $configuredLabel = $type !== '' ? trim((string) $getConfigAny([
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], '')) : '';
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim($line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}
?>
