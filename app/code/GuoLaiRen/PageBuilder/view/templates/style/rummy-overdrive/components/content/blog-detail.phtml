                            <section class="rail-card">
                                <span class="block-title"><?= __('Category Radar') ?></span>
                                <div class="category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-entry"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
