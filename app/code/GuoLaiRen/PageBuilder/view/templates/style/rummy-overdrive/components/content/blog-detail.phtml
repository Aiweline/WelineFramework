            </header>

            <div class="reading-grid<?= $showSidebar ? ' has-rail' : '' ?>">
                <aside class="story-notes wow animate__animated animate__fadeInLeft">
                    <section class="notes-card">
                        <span class="block-title"><?= __('Story Signals') ?></span>
                        <div class="metrics-stack">
