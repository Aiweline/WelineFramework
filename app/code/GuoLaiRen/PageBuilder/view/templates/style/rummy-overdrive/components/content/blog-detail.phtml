                            <span class="block-title"><?= __('Share') ?></span>
                            <div class="share-row">
                                <a href="https://www.facebook.com/sharer/sharer.php?u=<?= $shareUrl ?>" target="_blank" rel="noopener" class="share-btn" title="Share on Facebook">FB</a>
                                <a href="https://twitter.com/intent/tweet?url=<?= $shareUrl ?>&text=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="Share on X">X</a>
                                <a href="https://www.linkedin.com/shareArticle?mini=true&url=<?= $shareUrl ?>&title=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="Share on LinkedIn">IN</a>
                                <button type="button" class="share-btn" title="Copy link" onclick="<?= $jsCopyFunction ?>()">CP</button>
                            </div>
                        </section>
                    <?php endif; ?>

                    <a href="/blog" class="notes-back"><?= __('Back To Blog') ?></a>
                </aside>

                <article class="reading-paper wow animate__animated animate__fadeInUp">
