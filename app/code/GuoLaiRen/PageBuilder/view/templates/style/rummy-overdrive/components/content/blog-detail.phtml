                <a href="/blog"><?= __('Blog') ?></a>
                <span>/</span>
                <strong><?= htmlspecialchars(mb_substr($currentPost['title'], 0, 44)) ?><?= mb_strlen($currentPost['title']) > 44 ? '...' : '' ?></strong>
            </nav>

            <header class="story-stage<?= $hasCover ? '' : ' no-cover' ?> wow animate__animated animate__fadeInUp">
