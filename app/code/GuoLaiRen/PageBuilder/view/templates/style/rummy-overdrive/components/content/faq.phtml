<?php
/**
 * @component_start
 * code: faq
 * name: 常见问题
 * name_en: FAQ
 * description: FAQ折叠面板
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_intro => 显示简介:select:yes|yes,no
 * display.first_open => 首个问题默认展开:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景主色:color:#cffff6
 * style.accent_color => 强调色:color:#2be7ff
 * style.title_color => 标题颜色:color:#07111f
 * style.title_font_size => 标题字体大小(PC端):number:58|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:32|px
 * style.text_color => 正文颜色:color:#214055
 * style.panel_bg_color => 卡片兼容背景色:color:rgba(255,255,255,0.78)
 * style.card_border_color => 卡片兼容边框色:color:rgba(7,17,31,0.1)
 * style.card_radius => 卡片兼容圆角:number:24|px
 * style.item_bg_color => 问答项背景色:color:rgba(255,255,255,0.78)
 * style.item_border_color => 问答项边框颜色:color:rgba(7,17,31,0.1)
 * style.item_border_radius => 问答项圆角:number:24|px
 * style.item_gap => 问答项间距:number:14|px
 * style.question_color => 问题文字颜色:color:#07111f
 * style.question_font_size => 问题字号(PC端):number:16|px
 * style.question_font_size_mobile => 问题字号(移动端):number:14|px
 * style.question_padding => 问题区域内边距:number:16|px
 * style.question_hover_bg => 问题悬停背景色:color:rgba(255,255,255,0.22)
 * style.icon_color => 图标颜色:color:#214055
 * style.icon_size => 图标尺寸:number:18|px
 * style.answer_color => 答案颜色:color:#214055
 * style.answer_font_size => 答案字号:number:15|px
 * style.answer_padding => 答案区域内边距:number:16|px
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:52|px
 *
 * group:texts => 文本内容
 * texts.badge => 徽标文字:text:Overdrive FAQ
 * texts.title => 区域标题:text:Frequently Asked Questions
 * texts.intro => 简介:textarea:From responsive behavior to default fallback content, the section below keeps the common rummy landing questions compact and easy to open in place.
 * texts.tag_1 => 标签1:text:Rummy-ready
 * texts.tag_2 => 标签2:text:Mobile-safe
 * texts.tag_3 => 标签3:text:Config fallback
 * texts.faq_1_question => 问题1:text:Does this theme still follow the original tpmst data rules?
 * texts.faq_1_answer => 答案1:textarea:Yes. The theme keeps the same PHP data entry points, especially for homepage configuration, blog data, style settings, and component-level field fallback.
 * texts.faq_2_question => 问题2:text:Can the hero banner and download button be replaced from config?
 * texts.faq_2_answer => 答案2:textarea:Yes. The hero continues to read the banner and download_btn keys, so the visual assets can be swapped without changing the HTML structure.
 * texts.faq_3_question => 问题3:text:Is the layout responsive on smaller phones?
 * texts.faq_3_answer => 答案3:textarea:Yes. The hero cards stack, the review lane becomes swipeable, the table cards turn into horizontal snap cards, and the FAQ collapses into a single readable column.
 * texts.faq_4_question => 问题4:text:Can I hide specific content blocks without editing the file?
 * texts.faq_4_answer => 答案4:textarea:Yes. Display switches such as show_title, show_intro, show_rating, show_avg, and first_open are kept so editors can reduce or expand each module without code changes.
 * texts.faq_5_question => 问题5:text:Are the default texts rummy-related or just placeholder copy?
 * texts.faq_5_answer => 答案5:textarea:The defaults are written around rummy rooms, cash tables, joker-led flow, and quick room entry so the theme looks relevant even before custom content is added.
 * texts.faq_6_question => 问题6:text:Will empty FAQ slots break the section?
 * texts.faq_6_answer => 答案6:textarea:No. Empty items are skipped, and if nothing is configured the module falls back to a complete default FAQ set.
 *
 * @fields_end
 */

$componentId = 'rov-faq-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getFaqConfig = static function (int $index, array $keys, $default = '') use ($getConfigAny) {
    $scope = 'faq_' . $index;
    $scopedKeys = [];
    foreach ($keys as $key) {
        $scopedKeys[] = $scope . '.' . $key;
    }

    return $getConfigAny(array_merge($scopedKeys, $keys), $default);
};

$display = $getConfigAny(['display.show_section', 'faq.display'], 'yes') !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfigAny(['display.show_title'], 'yes') !== 'no';
$showIntro = $getConfigAny(['display.show_intro'], 'yes') !== 'no';
$firstOpen = $getConfigAny(['display.first_open'], 'no') === 'yes';

$bgColor = (string) $getConfigAny(['style.bg_color', 'faq.bg_color'], '#cffff6');
$accentColor = (string) $getConfigAny(['style.accent_color'], '#2be7ff');
$titleColor = (string) $getConfigAny(['style.title_color'], '#07111f');
$titleFontSize = (int) $getConfigAny(['style.title_font_size'], '58');
$titleFontSizeMobile = (int) $getConfigAny(['style.title_font_size_mobile'], '32');
$textColor = (string) $getConfigAny(['style.text_color'], '#214055');
$itemBgColor = (string) $getConfigAny(['style.item_bg_color', 'style.panel_bg_color'], 'rgba(255,255,255,0.78)');
$itemBorderColor = (string) $getConfigAny(['style.item_border_color', 'style.card_border_color'], 'rgba(7,17,31,0.1)');
$itemBorderRadius = (int) $getConfigAny(['style.item_border_radius', 'style.card_radius'], '24');
$itemGap = (int) $getConfigAny(['style.item_gap'], '14');
$questionColor = (string) $getConfigAny(['style.question_color'], '#07111f');
$questionFontSize = (int) $getConfigAny(['style.question_font_size'], '16');
$questionFontSizeMobile = (int) $getConfigAny(['style.question_font_size_mobile'], '14');
$questionPadding = (int) $getConfigAny(['style.question_padding'], '16');
$questionHoverBg = (string) $getConfigAny(['style.question_hover_bg'], 'rgba(255,255,255,0.22)');
$iconColor = (string) $getConfigAny(['style.icon_color'], '#214055');
$iconSize = (int) $getConfigAny(['style.icon_size'], '18');
$answerColor = (string) $getConfigAny(['style.answer_color'], $textColor);
$answerFontSize = (int) $getConfigAny(['style.answer_font_size'], '15');
$answerPadding = (int) $getConfigAny(['style.answer_padding'], '16');
$sectionPadding = (int) $getConfigAny(['style.section_padding'], '80');
$sectionPaddingMobile = (int) $getConfigAny(['style.section_padding_mobile'], '52');

$badgeText = trim((string) $getConfigAny(['texts.badge'], 'Overdrive FAQ'));
$title = (string) $getConfigAny(['texts.title', 'faq.title', 'texts.faq_title'], 'Frequently Asked Questions');
$intro = trim((string) $getConfigAny(
    ['texts.intro', 'texts.faq_intro'],
    'From responsive behavior to default fallback content, the section below keeps the common rummy landing questions compact and easy to open in place.'
));
$tags = array_values(array_filter([
    trim((string) $getConfigAny(['texts.tag_1'], 'Rummy-ready')),
    trim((string) $getConfigAny(['texts.tag_2'], 'Mobile-safe')),
    trim((string) $getConfigAny(['texts.tag_3'], 'Config fallback')),
], static function ($item) {
    return $item !== '';
}));

$defaults = [
    1 => [
        'question' => 'Does this theme still follow the original tpmst data rules?',
        'answer' => 'Yes. The theme keeps the same PHP data entry points, especially for homepage configuration, blog data, style settings, and component-level field fallback.',
    ],
    2 => [
        'question' => 'Can the hero banner and download button be replaced from config?',
        'answer' => 'Yes. The hero continues to read the banner and download_btn keys, so the visual assets can be swapped without changing the HTML structure.',
    ],
    3 => [
        'question' => 'Is the layout responsive on smaller phones?',
        'answer' => 'Yes. The hero cards stack, the review lane becomes swipeable, the table cards turn into horizontal snap cards, and the FAQ collapses into a single readable column.',
    ],
    4 => [
        'question' => 'Can I hide specific content blocks without editing the file?',
        'answer' => 'Yes. Display switches such as show_title, show_intro, show_rating, show_avg, and first_open are kept so editors can reduce or expand each module without code changes.',
    ],
    5 => [
        'question' => 'Are the default texts rummy-related or just placeholder copy?',
        'answer' => 'The defaults are written around rummy rooms, cash tables, joker-led flow, and quick room entry so the theme looks relevant even before custom content is added.',
    ],
    6 => [
        'question' => 'Will empty FAQ slots break the section?',
        'answer' => 'No. Empty items are skipped, and if nothing is configured the module falls back to a complete default FAQ set.',
    ],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i];
    $question = trim((string) $getFaqConfig($i, ['texts.faq_' . $i . '_question', 'texts.faq_question_' . $i], $default['question']));
    $answer = trim((string) $getFaqConfig($i, ['texts.faq_' . $i . '_answer', 'texts.faq_answer_' . $i], $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqs[] = [
            'index' => count($faqs),
            'question' => $question,
            'answer' => $answer,
        ];
    }
}

if (empty($faqs)) {
    foreach ($defaults as $default) {
        $faqs[] = [
            'index' => count($faqs),
            'question' => $default['question'],
            'answer' => $default['answer'],
        ];
    }
}

$leftColumn = [];
$rightColumn = [];
foreach ($faqs as $index => $faq) {
    if ($index % 2 === 0) {
        $leftColumn[] = $faq;
    } else {
        $rightColumn[] = $faq;
    }
}

$renderFaqCard = static function (array $faq, string $columnKey) use ($componentId, $firstOpen) {
    $isOpen = $firstOpen && $faq['index'] === 0;
    ?>
    <article class="faq-card wow animate__fadeInUp<?= $isOpen ? ' is-open' : '' ?>" data-faq-item="<?= (int) $faq['index'] ?>" data-wow-delay="<?= number_format((220 + ($faq['index'] * 90)) / 1000, 2) ?>s">
        <button
            type="button"
            class="faq-trigger"
            id="<?= $componentId ?>-trigger-<?= htmlspecialchars($columnKey) ?>-<?= (int) $faq['index'] ?>"
            data-faq-trigger="<?= (int) $faq['index'] ?>"
            aria-expanded="<?= $isOpen ? 'true' : 'false' ?>"
            aria-controls="<?= $componentId ?>-panel-<?= htmlspecialchars($columnKey) ?>-<?= (int) $faq['index'] ?>"
        >
            <span class="faq-index"><?= sprintf('%02d', $faq['index'] + 1) ?></span>
            <span class="faq-question"><?= htmlspecialchars($faq['question']) ?></span>
            <span class="faq-toggle" aria-hidden="true"><?= $isOpen ? '−' : '+' ?></span>
        </button>

        <div
            class="faq-panel<?= $isOpen ? ' is-open' : '' ?>"
            id="<?= $componentId ?>-panel-<?= htmlspecialchars($columnKey) ?>-<?= (int) $faq['index'] ?>"
            data-faq-panel="<?= (int) $faq['index'] ?>"
            aria-hidden="<?= $isOpen ? 'false' : 'true' ?>"
        >
            <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
        </div>
    </article>
    <?php
};
?>

<section id="<?= $componentId ?>" class="rov-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell">
        <header class="faq-head" id="faq">
            <?php if ($badgeText !== ''): ?>
                <span class="faq-badge wow animate__fadeInDown"><?= htmlspecialchars($badgeText) ?></span>
            <?php endif; ?>

            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title" class="wow animate__fadeInUp" data-wow-delay="0.08s"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>

            <?php if ($showIntro && $intro !== ''): ?>
                <p class="faq-intro wow animate__fadeInUp" data-wow-delay="0.16s"><?= nl2br(htmlspecialchars($intro)) ?></p>
            <?php endif; ?>

            <?php if (!empty($tags)): ?>
                <div class="faq-tags">
                    <?php foreach ($tags as $index => $tag): ?>
                        <span class="wow animate__fadeInUp" data-wow-delay="<?= number_format((240 + ($index * 70)) / 1000, 2) ?>s"><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="faq-columns">
            <div class="faq-column">
                <?php foreach ($leftColumn as $faq): ?>
                    <?php $renderFaqCard($faq, 'left'); ?>
                <?php endforeach; ?>
            </div>

            <div class="faq-column">
                <?php foreach ($rightColumn as $faq): ?>
                    <?php $renderFaqCard($faq, 'right'); ?>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

