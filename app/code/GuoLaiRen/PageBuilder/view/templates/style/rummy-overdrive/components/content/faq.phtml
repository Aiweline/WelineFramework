</style>

<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    root.querySelectorAll('[data-faq-trigger]').forEach(function (trigger) {
        trigger.addEventListener('click', function () {
            var parent = trigger.closest('[data-faq-item]');
            var panel = parent ? parent.querySelector('[data-faq-panel]') : null;
            var toggle = parent ? parent.querySelector('.faq-toggle') : null;
            if (!parent || !panel) {
                return;
            }

            var expanded = trigger.getAttribute('aria-expanded') === 'true';
            trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            parent.classList.toggle('is-open', !expanded);
            panel.classList.toggle('is-open', !expanded);
            panel.setAttribute('aria-hidden', expanded ? 'true' : 'false');

            if (toggle) {
                toggle.textContent = expanded ? '+' : '−';
            }
        });
    });
})();
</script>
