<?php
/**
 * Rummy Overdrive - Games Component
 *
 * @component_start
 * code: games
 * name: 游戏介绍
 * name_en: Games Showcase
 * description: Rummy 房间展示卡片，遵循 tpmst 的图片与文案配置结构
 * category: content
 * region: content
 * thumbnail: asset/img/game-rummy-rush.svg
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示卡片描述:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#fff3c1
 * style.title_color => 标题颜色:color:#111728
 * style.title_font_size => 标题字体大小(PC端):number:38|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:26|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.82)
 * style.card_border_radius => 卡片圆角:number:26|px
 * style.card_border_color => 卡片边框色:color:rgba(17,23,40,0.08)
 * style.card_title_color => 卡片标题颜色:color:#111728
 * style.card_title_font_size => 卡片标题字号:number:22|px
 * style.card_desc_color => 卡片描述颜色:color:#4d566b
 * style.card_desc_font_size => 卡片描述字号:number:15|px
 * style.section_padding => 区域内边距(PC端):number:82|px
 * style.section_padding_mobile => 区域内边距(移动端):number:50|px
 * style.card_gap => 卡片间距:number:24|px
 * style.card_content_padding => 卡片内容内边距:number:22|px
 * style.hover_transform => 悬停上移距离:number:8|px
 *
 * group:images => 图片配置
 * images.image_1_desktop => 游戏1桌面端图片:textarea:|默认使用本地图片
 * images.image_1_mobile => 游戏1移动端图片:textarea:|默认使用本地图片
 * images.image_2 => 游戏2图片:textarea:|默认使用本地图片
 * images.image_3 => 游戏3图片:textarea:|默认使用本地图片
 *
 * group:texts => 游戏文本
 * texts.title => 区域标题:text:Choose Your Overdrive Table
 * texts.summary => 区域辅助文案:text:Three room routes for quicker table entry, joker reads, and longer rummy sessions.
 * texts.game_1_title => 游戏1标题:text:Rush Meld Table
 * texts.game_1_desc => 游戏1描述:textarea:A faster rummy lane for players who want to build runs quickly and jump into active cash flow without extra friction.
 * texts.game_2_title => 游戏2标题:text:Joker Circuit
 * texts.game_2_desc => 游戏2描述:textarea:A room style that leans into joker-led decisions, clearer hand reading, and more visible table rhythm across each round.
 * texts.game_3_title => 游戏3标题:text:Night Cash Arena
 * texts.game_3_desc => 游戏3描述:textarea:A darker premium room mood with sharper contrast, cleaner stakes visibility, and a steadier pace for longer sessions.
 *
 * @fields_end
 */

$componentId = 'rov-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getCardValue = function ($index, array $keys, $default = '') use ($getConfigAny) {
    $prefixedKeys = [];
    foreach ($keys as $key) {
        $prefixedKeys[] = 'game_' . $index . '.' . $key;
        $prefixedKeys[] = $key;
    }
    return $getConfigAny($prefixedKeys, $default);
};

$joinLabels = static function (array $items) {
    $items = array_values(array_filter(array_map('trim', $items), static function ($item) {
        return $item !== '';
    }));
    $count = count($items);
    if ($count === 0) {
        return '';
    }
    if ($count === 1) {
        return $items[0];
    }
    if ($count === 2) {
        return $items[0] . ' and ' . $items[1];
    }
    $last = array_pop($items);
    return implode(', ', $items) . ', and ' . $last;
};

$display = $getConfigAny(['display.show_section', 'games.display'], 'yes') !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfigAny(['display.show_title'], 'yes') !== 'no';
$showDescription = $getConfigAny(['display.show_description'], 'yes') !== 'no';

$bgColor = $getConfigAny(['style.bg_color', 'games.bg_color'], '#fff3c1');
$titleColor = $getConfigAny(['style.title_color'], '#111728');
$titleFontSize = (int) $getConfigAny(['style.title_font_size'], '38');
$titleFontSizeMobile = (int) $getConfigAny(['style.title_font_size_mobile'], '26');
$cardBgColor = $getConfigAny(['style.card_bg_color'], 'rgba(255,255,255,0.82)');
$cardBorderRadius = (int) $getConfigAny(['style.card_border_radius'], '26');
$cardBorderColor = $getConfigAny(['style.card_border_color'], 'rgba(17,23,40,0.08)');
$cardTitleColor = $getConfigAny(['style.card_title_color'], '#111728');
$cardTitleFontSize = (int) $getConfigAny(['style.card_title_font_size'], '22');
$cardDescColor = $getConfigAny(['style.card_desc_color'], '#4d566b');
$cardDescFontSize = (int) $getConfigAny(['style.card_desc_font_size'], '15');
$sectionPadding = (int) $getConfigAny(['style.section_padding'], '82');
$sectionPaddingMobile = (int) $getConfigAny(['style.section_padding_mobile'], '50');
$cardGap = (int) $getConfigAny(['style.card_gap'], '24');
$cardContentPadding = (int) $getConfigAny(['style.card_content_padding'], '22');
$hoverTransform = (int) $getConfigAny(['style.hover_transform'], '8');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/game-rummy-rush.svg');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/game-rummy-rush.svg');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/game-rummy-fusion.svg');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/game-rummy-nightshift.svg');

$image1Desktop = $getCardValue(1, ['images.image_1_desktop', 'games.image_1_desktop'], '') ?: $defaultImage1Desktop;
$image1Mobile = $getCardValue(1, ['images.image_1_mobile', 'games.image_1_mobile'], '') ?: $defaultImage1Mobile;
$image2 = $getCardValue(2, ['images.image_2', 'games.image_2'], '') ?: $defaultImage2;
$image3 = $getCardValue(3, ['images.image_3', 'games.image_3'], '') ?: $defaultImage3;

$title = $getConfigAny(['texts.title', 'games.title', 'texts.games_title'], 'Choose Your Overdrive Table');
$cards = [
    [
        'title' => $getCardValue(1, ['texts.game_1_title'], 'Rush Meld Table'),
        'description' => $getCardValue(
            1,
            ['texts.game_1_desc'],
            'A faster rummy lane for players who want to build runs quickly and jump into active cash flow without extra friction.'
        ),
        'desktop_image' => $image1Desktop,
        'mobile_image' => $image1Mobile,
        'chip' => 'Fast route',
        'note' => 'Quick room entry',
    ],
    [
        'title' => $getCardValue(2, ['texts.game_2_title'], 'Joker Circuit'),
        'description' => $getCardValue(
            2,
            ['texts.game_2_desc'],
            'A room style that leans into joker-led decisions, clearer hand reading, and more visible table rhythm across each round.'
        ),
        'desktop_image' => $image2,
        'mobile_image' => $image2,
        'chip' => 'Smart read',
        'note' => 'Joker-heavy flow',
    ],
    [
        'title' => $getCardValue(3, ['texts.game_3_title'], 'Night Cash Arena'),
        'description' => $getCardValue(
            3,
            ['texts.game_3_desc'],
            'A darker premium room mood with sharper contrast, cleaner stakes visibility, and a steadier pace for longer sessions.'
        ),
        'desktop_image' => $image3,
        'mobile_image' => $image3,
        'chip' => 'Premium pace',
        'note' => 'Long-session comfort',
    ],
];
$gameTitles = array_values(array_filter(array_map(static function ($card) {
    return trim((string)($card['title'] ?? ''));
}, $cards), static function ($item) {
    return $item !== '';
}));
$summaryDefault = 'Three room routes for quicker table entry across ' . $joinLabels(array_slice($gameTitles, 0, 3)) . '.';
$summary = trim((string)$getConfigAny(['texts.summary', 'texts.games_summary'], $summaryDefault));
?>

<section id="<?= $componentId ?>" class="rov-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <span class="games-kicker wow animate__fadeInDown">Room selector</span>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title" class="wow animate__fadeInUp" data-wow-delay="0.08s"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($summary !== ''): ?>
                <p class="wow animate__fadeInUp" data-wow-delay="0.16s"><?= htmlspecialchars($summary) ?></p>
            <?php endif; ?>
        </header>

        <div class="games-track" aria-label="Available rummy tables">
            <?php foreach ($cards as $index => $card): ?>
                <article class="game-card game-card-<?= (int) $index ?> wow animate__zoomIn" data-wow-delay="<?= number_format((240 + ($index * 110)) / 1000, 2) ?>s">
                    <div class="game-card-glow" aria-hidden="true"></div>
                    <div class="game-media">
                        <picture>
                            <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($card['mobile_image']) ?>">
                            <img src="<?= htmlspecialchars($card['desktop_image']) ?>" alt="<?= htmlspecialchars($card['title']) ?>" loading="lazy">
                        </picture>
                    </div>

                    <div class="game-body">
                        <div class="game-topline">
                            <span class="game-chip"><?= htmlspecialchars($card['chip']) ?></span>
                            <span class="game-note"><?= htmlspecialchars($card['note']) ?></span>
                        </div>

                        <h3><?= htmlspecialchars($card['title']) ?></h3>

                        <?php if ($showDescription): ?>
                            <p><?= htmlspecialchars($card['description']) ?></p>
                        <?php endif; ?>

                        <div class="game-pulse" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

