{
    "$schema": "2.1.0",
    "template": "rummy-overdrive",
    "name": "Rummy Overdrive",
    "description": "High-contrast neon rummy landing theme with responsive Tailwind-ready modules and a more aggressive visual rhythm.",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航、Logo等",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "advantages", "games", "testimonials", "faq"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含版权、链接等",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "Overdrive 导航",
            "name_en": "Overdrive Navigation",
            "description": "深色霓虹导航，含底部流光与移动端折叠菜单",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "download_button"],
            "file": "header/nav.phtml"
        },
        "header-simple": {
            "name": "简洁头部",
            "name_en": "Simple Header",
            "description": "简洁头部封装，复用主题导航组件",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "style"],
            "file": "header/simple.phtml"
        },
        "header-dark": {
            "name": "深色头部",
            "name_en": "Dark Header",
            "description": "深色头部封装，复用主题导航组件",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 3,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "button", "style"],
            "file": "header/dark.phtml"
        },
        "hero-slider": {
            "name": "Hero 首屏",
            "name_en": "Hero Section",
            "description": "高反差赛道式首屏，保留 tpmst 的 banner/download_btn/layout 配置入口",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner", "download_btn", "layout", "hero"],
            "file": "content/hero-slider.phtml"
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages",
            "description": "高亮宣言板 + 节奏信息塔的优势布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts"],
            "file": "content/advantages.phtml"
        },
        "games": {
            "name": "Rummy 桌面展示",
            "name_en": "Rummy Tables",
            "description": "高反差三列桌面卡片，支持默认文案与列表配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts", "games"],
            "file": "content/games.phtml"
        },
        "slider": {
            "name": "轮播横幅",
            "name_en": "Slider",
            "description": "兼容原有 Banner/Slider 数据配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 35,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["slider"],
            "file": "content/slider.phtml"
        },
        "banner": {
            "name": "静态横幅",
            "name_en": "Banner",
            "description": "兼容原有 Banner 图片与下载按钮配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 36,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner"],
            "file": "content/banner.phtml"
        },
        "testimonials": {
            "name": "玩家评价",
            "name_en": "Testimonials",
            "description": "横向滑动评价车道，保留评分、头像与平均分回退逻辑",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/testimonials.phtml"
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ",
            "description": "赛道式问答列表，支持首项展开与响应式切换",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/faq.phtml"
        },
        "about-content": {
            "name": "关于页内容",
            "name_en": "About Content",
            "description": "品牌介绍页内容组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 60,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/about-content.phtml"
        },
        "contact-content": {
            "name": "联系页内容",
            "name_en": "Contact Content",
            "description": "联系页和支持入口组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 61,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/contact-content.phtml"
        },
        "legal-content": {
            "name": "法律页内容",
            "name_en": "Legal Content",
            "description": "政策与条款页面组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 62,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/legal-content.phtml"
        },
        "blog-list": {
            "name": "博客列表",
            "name_en": "Blog List",
            "description": "博客列表页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 63,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-list.phtml"
        },
        "blog-category": {
            "name": "博客分类",
            "name_en": "Blog Category",
            "description": "博客分类列表页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 64,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-category.phtml"
        },
        "blog-detail": {
            "name": "博客详情",
            "name_en": "Blog Detail",
            "description": "博客详情页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 65,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-detail.phtml"
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer Links",
            "description": "Overdrive 发光地平线页脚，支持多列链接与社交信息",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "config_groups": ["display", "style", "disclaimer", "copyright", "footer", "content", "layout", "typography"],
            "file": "footer/links.phtml"
        },
        "footer-simple": {
            "name": "简洁底部",
            "name_en": "Simple Footer",
            "description": "简洁底部封装，复用主题页脚组件",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "config_groups": ["content", "style"],
            "file": "footer/simple.phtml"
        }
    }
}
