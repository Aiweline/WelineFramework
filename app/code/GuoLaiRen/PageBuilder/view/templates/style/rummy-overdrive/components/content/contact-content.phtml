<?php
/**
 * Rummy Overdrive - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: 联系方式和表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Contact Rummy Overdrive
 * hero.subtitle => 页面副标题:textarea:Need help with account access, room entry, or rummy support questions? Use the contact details below to reach the right team.
 * hero.bg_color => 背景色:color:#0c1020
 * hero.bg_gradient_end => 渐变结束色:color:#171228
 * hero.title_color => 标题颜色:color:#ffffff
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@rummyoverdrive.com
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook:text:
 * social.twitter => Twitter:text:
 * social.linkedin => LinkedIn:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Ticket
 * form.name_label => 姓名标签:text:Full Name
 * form.email_label => 邮箱标签:text:Email Address
 * form.subject_label => 主题标签:text:Subject
 * form.message_label => 留言标签:text:Message
 * form.submit_text => 提交按钮:text:Submit Request
 * form.success_message => 成功提示:text:Include your UID, room name, and device details so the support team can reply faster.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Location Map
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$componentId = 'rov-contact-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$showMap = $getConfigAny(['display.show_map'], 'yes') !== 'no';
$showForm = $getConfigAny(['display.show_form'], 'yes') !== 'no';
$showSocial = $getConfigAny(['display.show_social'], 'yes') !== 'no';
$showInfo = $getConfigAny(['display.show_info'], 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfigAny(['hero.title'], $pageTitle));
if ($title === '') {
    $title = 'Contact Rummy Overdrive';
}
$description = trim((string)$getConfigAny(['hero.subtitle'], 'Need help with account access, room entry, or rummy support questions? Use the contact details below to reach the right team.'));

$addressLabel = (string)$getConfigAny(['contact_info.address_label'], 'Address');
$phoneLabel = (string)$getConfigAny(['contact_info.phone_label'], 'Phone');
$emailLabel = (string)$getConfigAny(['contact_info.email_label'], 'Email');
$hoursLabel = (string)$getConfigAny(['contact_info.work_hours_label'], 'Support Hours');
$email = trim((string)$getConfigAny(['contact_info.email'], 'support@rummyoverdrive.com'));
$phone = trim((string)$getConfigAny(['contact_info.phone'], '+91 1800-XXX-XXXX'));
$address = trim((string)$getConfigAny(['contact_info.address'], 'Mumbai, India'));
$hours = trim((string)$getConfigAny(['contact_info.work_hours'], '24/7 Customer Support'));

$formTitle = trim((string)$getConfigAny(['form.title'], 'Send A Support Ticket'));
$formNameLabel = (string)$getConfigAny(['form.name_label'], 'Full Name');
$formEmailLabel = (string)$getConfigAny(['form.email_label'], 'Email Address');
$formSubjectLabel = (string)$getConfigAny(['form.subject_label'], 'Subject');
$formMessageLabel = (string)$getConfigAny(['form.message_label'], 'Message');
$formSubmitText = trim((string)$getConfigAny(['form.submit_text'], 'Submit Request'));
$formSuccessMessage = trim((string)$getConfigAny(['form.success_message'], 'Include your UID, room name, and device details so the support team can reply faster.'));
$mapTitle = trim((string)$getConfigAny(['map.title'], 'Location Map'));
$mapEmbedUrl = trim((string)$getConfigAny(['map.embed_url'], ''));
$mapHeight = max(240, (int)$getConfigAny(['map.height'], 360));

$contactCards = [];
if ($email !== '') {
    $contactCards[] = [
        'label' => $emailLabel,
        'value' => $email,
        'icon' => 'EM',
        'href' => 'mailto:' . $email,
    ];
}
if ($phone !== '') {
    $contactCards[] = [
        'label' => $phoneLabel,
        'value' => $phone,
        'icon' => 'PH',
        'href' => 'tel:' . preg_replace('/[^0-9+]/', '', $phone),
    ];
}
if ($address !== '') {
    $contactCards[] = [
        'label' => $addressLabel,
        'value' => $address,
        'icon' => 'AD',
        'href' => '',
    ];
}
if ($hours !== '') {
    $contactCards[] = [
        'label' => $hoursLabel,
        'value' => $hours,
        'icon' => '24',
        'href' => '',
    ];
}

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string)$getConfigAny([$key], ''));
    if ($url === '') {
        continue;
    }
    $socials[] = [
        'name' => $label,
        'url' => $url,
    ];
}

$heroBg = (string)$getConfigAny(['hero.bg_color'], $colors['hero_bg'] ?? '#0c1020');
$heroBgEnd = (string)$getConfigAny(['hero.bg_gradient_end'], $colors['hero_bg_gradient_end'] ?? '#171228');
$heroTitleColor = (string)$getConfigAny(['hero.title_color'], $colors['text_primary'] ?? '#ffffff');
$textMuted = (string)($colors['text_muted'] ?? '#9fb0cb');
$cardBg = (string)($colors['card_bg'] ?? 'rgba(16, 22, 40, 0.88)');
$cardBorder = (string)($colors['border_light'] ?? 'rgba(255,255,255,0.08)');
$accentPrimary = (string)($colors['accent_primary'] ?? '#ff4d7a');
$accentSecondary = (string)($colors['accent_secondary'] ?? '#2be7ff');
$accentThird = (string)($colors['accent_tertiary'] ?? '#d2ff3f');
$buttonBg = (string)($colors['button_primary_bg'] ?? 'linear-gradient(135deg, #ff4d7a 0%, #d2ff3f 100%)');
$buttonText = (string)($colors['button_primary_text'] ?? '#0a0f1d');
?>

<section
    id="<?= $componentId ?>"
    class="rov-contact"
    style="--rov-contact-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-card-bg: <?= htmlspecialchars($cardBg, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-card-border: <?= htmlspecialchars($cardBorder, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-accent-primary: <?= htmlspecialchars($accentPrimary, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-accent-secondary: <?= htmlspecialchars($accentSecondary, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-accent-third: <?= htmlspecialchars($accentThird, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-button-bg: <?= htmlspecialchars($buttonBg, ENT_QUOTES, 'UTF-8') ?>; --rov-contact-button-text: <?= htmlspecialchars($buttonText, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="contact-shell">
        <header class="dispatch-hero wow animate__animated animate__fadeInUp">
            <div class="hero-copy">
                <h1><?= htmlspecialchars($title) ?></h1>
                <?php if ($description !== ''): ?>
                    <p><?= htmlspecialchars($description) ?></p>
                <?php endif; ?>
            </div>

            <?php if ($hours !== ''): ?>
                <div class="hero-pulse">
                    <span class="pulse-label"><?= htmlspecialchars($hoursLabel) ?></span>
                    <strong><?= htmlspecialchars($hours) ?></strong>
                </div>
            <?php endif; ?>
        </header>

        <div class="dispatch-grid<?= !$showForm ? ' no-form' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="support-stage wow animate__animated animate__fadeInLeft">
                    <?php if (!empty($contactCards)): ?>
                        <div class="route-grid">
                            <?php foreach ($contactCards as $index => $card): ?>
                                <?php if (!empty($card['href'])): ?>
                                    <a
                                        class="route-card wow animate__animated animate__fadeInUp"
                                        href="<?= htmlspecialchars($card['href']) ?>"
                                        data-wow-delay="<?= htmlspecialchars(number_format(0.06 + ($index * 0.05), 2)) ?>s"
                                    >
                                        <span class="route-mark"><?= htmlspecialchars($card['icon']) ?></span>
                                        <span class="route-label"><?= htmlspecialchars($card['label']) ?></span>
                                        <strong><?= htmlspecialchars($card['value']) ?></strong>
                                    </a>
                                <?php else: ?>
                                    <div
                                        class="route-card wow animate__animated animate__fadeInUp"
                                        data-wow-delay="<?= htmlspecialchars(number_format(0.06 + ($index * 0.05), 2)) ?>s"
                                    >
                                        <span class="route-mark"><?= htmlspecialchars($card['icon']) ?></span>
                                        <span class="route-label"><?= htmlspecialchars($card['label']) ?></span>
                                        <strong><?= htmlspecialchars($card['value']) ?></strong>
                                    </div>
                                <?php endif; ?>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <?php if ($pageContent !== ''): ?>
                        <div class="desk-note">
                            <span class="note-title"><?= __('Contact Note') ?></span>
                            <div class="contact-richtext"><?= $pageContent ?></div>
                        </div>
                    <?php endif; ?>

                    <?php if ($showSocial && !empty($socials)): ?>
                        <div class="social-runner">
                            <span class="note-title"><?= __('Social Links') ?></span>
                            <div class="social-links">
                                <?php foreach ($socials as $social): ?>
                                    <a href="<?= htmlspecialchars($social['url']) ?>" class="social-link" target="_blank" rel="noopener" title="<?= htmlspecialchars($social['name']) ?>">
                                        <span><?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?></span>
                                        <small><?= htmlspecialchars($social['name']) ?></small>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <section class="message-bay wow animate__animated animate__fadeInRight">
                    <div class="bay-head">
                        <h2><?= htmlspecialchars($formTitle) ?></h2>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </div>

                    <form class="contact-form">
                        <div class="field">
                            <label><?= htmlspecialchars($formNameLabel) ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formNameLabel) ?>">
                        </div>
                        <div class="field">
                            <label><?= htmlspecialchars($formEmailLabel) ?></label>
                            <input type="email" placeholder="<?= htmlspecialchars($formEmailLabel) ?>">
                        </div>
                        <div class="field is-full">
                            <label><?= htmlspecialchars($formSubjectLabel) ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formSubjectLabel) ?>">
                        </div>
                        <div class="field is-full">
                            <label><?= htmlspecialchars($formMessageLabel) ?></label>
                            <textarea placeholder="<?= htmlspecialchars($formMessageLabel) ?>"></textarea>
                        </div>
                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </section>
            <?php endif; ?>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="map-stage wow animate__animated animate__fadeInUp">
                <div class="map-copy">
                    <h2><?= htmlspecialchars($mapTitle) ?></h2>
                </div>
                <div class="map-frame">
                    <iframe
                        src="<?= htmlspecialchars($mapEmbedUrl) ?>"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        style="height: <?= (int)$mapHeight ?>px;"
                        title="<?= htmlspecialchars((string)__('Contact map')) ?>"></iframe>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>

<style>
