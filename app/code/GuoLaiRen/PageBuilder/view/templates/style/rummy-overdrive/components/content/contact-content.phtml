    background: rgba(255, 255, 255, 0.04);
    color: #ffffff;
    text-decoration: none;
    display: grid;
    gap: 0.22rem;
    text-align: center;
}

#<?= $componentId ?> .social-link span {
    color: var(--rov-contact-accent-primary);
    font-weight: 800;
}

#<?= $componentId ?> .social-link small {
    color: #9fb0cb;
}

#<?= $componentId ?> .bay-head h2,
#<?= $componentId ?> .map-copy h2 {
    color: #ffffff;
    font-size: clamp(1.45rem, 3vw, 2rem);
}

#<?= $componentId ?> .contact-form {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
}

#<?= $componentId ?> .field {
    display: grid;
    gap: 0.45rem;
}

#<?= $componentId ?> .field.is-full {
    grid-column: 1 / -1;
}

