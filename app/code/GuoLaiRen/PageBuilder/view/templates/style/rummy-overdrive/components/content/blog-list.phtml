<?php
/**
 * Rummy Overdrive Blog List Component
 *
 * @fields_start
 * blog.title|Blog list title|text|Overdrive Rummy Guides & Updates
 * blog.subtitle|Blog list subtitle|text|Fresh reads on table rhythm, room modes, mobile flow, and platform updates.
 * blog.posts_per_page|Posts per page|number|9
 * blog.show_sidebar|Show sidebar|select:yes=Yes,no=No|yes
 * blog.show_category|Show category|select:yes=Yes,no=No|yes
 * blog.show_date|Show date|select:yes=Yes,no=No|yes
 * blog.show_author|Show author|select:yes=Yes,no=No|yes
 * blog.card_style|Card style|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$componentId = 'rov-blog-list-' . uniqid();
$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', __('Overdrive Rummy Guides & Updates'));
$subtitle = $getConfig('blog.subtitle', __('Fresh reads on table rhythm, room modes, mobile flow, and platform updates.'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#ff4d7a');
$secondaryColor = $getConfig('color_scheme.secondary', '#2be7ff');
$accentColor = '#d2ff3f';
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/rummy-overdrive/asset/img/poker-header-bg.svg');

$featuredPost = $blogPosts[0] ?? null;
$briefPosts = array_slice($blogPosts, 1, 2);
$lanePosts = array_slice($blogPosts, 3);
$cardStyleClass = 'style-' . preg_replace('/[^a-z0-9-]+/i', '', (string)$cardStyle);
$storyCount = count($blogPosts);
$categoryCount = count($blogCategories);
?>

<section id="<?= $componentId ?>" class="rov-blog-list">
    <div class="blog-shell">
        <header class="dispatch-head wow animate__animated animate__fadeInUp">
            <div class="head-copy">
                <span class="headline-chip">Overdrive Journal</span>
                <h1><?= htmlspecialchars($title) ?></h1>
                <?php if ($subtitle): ?>
                    <p><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="head-stats">
                <article class="stat-chip">
                    <strong><?= (int)$storyCount ?></strong>
                    <span><?= __('Published reads') ?></span>
                </article>
                <article class="stat-chip">
                    <strong><?= (int)$categoryCount ?></strong>
                    <span><?= __('Tracked topics') ?></span>
                </article>
            </div>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="blog-empty wow animate__animated animate__fadeInUp">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.34" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <h2><?= __('No stories are live yet.') ?></h2>
                <p><?= __('New rummy notes, update logs, and table explainers will appear here once posts are published.') ?></p>
            </div>
        <?php else: ?>
            <div class="blog-board<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="board-main">
                    <?php if ($featuredPost): ?>
                        <div class="lead-grid">
                            <article class="lead-story wow animate__animated animate__fadeInUp">
                                <?php if (!empty($featuredPost['cover_image'])): ?>
                                    <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="lead-media">
                                        <img src="<?= htmlspecialchars($featuredPost['cover_image']) ?>" alt="<?= htmlspecialchars($featuredPost['title']) ?>" loading="lazy">
                                    </a>
                                <?php endif; ?>

                                <div class="lead-copy">
                                    <div class="meta-row">
                                        <?php if ($showCategory && !empty($featuredPost['category_name'])): ?>
                                            <span class="story-chip"><?= htmlspecialchars($featuredPost['category_name']) ?></span>
                                        <?php endif; ?>
                                        <?php if ($showDate && !empty($featuredPost['published_at'])): ?>
                                            <span class="story-date"><?= date('M d, Y', strtotime($featuredPost['published_at'])) ?></span>
                                        <?php endif; ?>
                                    </div>

                                    <span class="story-kicker"><?= __('Lead Story') ?></span>
                                    <h2>
                                        <a href="<?= htmlspecialchars($featuredPost['url']) ?>"><?= htmlspecialchars($featuredPost['title']) ?></a>
                                    </h2>

                                    <?php if (!empty($featuredPost['summary'])): ?>
                                        <p class="lead-summary">
                                            <?= htmlspecialchars(mb_substr($featuredPost['summary'], 0, 240)) ?><?= mb_strlen($featuredPost['summary']) > 240 ? '...' : '' ?>
                                        </p>
                                    <?php endif; ?>

                                    <div class="story-foot">
                                        <?php if ($showAuthor && !empty($featuredPost['author'])): ?>
                                            <span class="story-author"><?= htmlspecialchars($featuredPost['author']) ?></span>
                                        <?php endif; ?>
                                        <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="story-link">
                                            <?= __('Read Story') ?>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                            </svg>
                                        </a>
                                    </div>
                                </div>
                            </article>

                            <?php if (!empty($briefPosts)): ?>
                                <div class="brief-stack">
                                    <?php foreach ($briefPosts as $index => $post): ?>
                                        <article class="brief-card wow animate__animated animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.08 + ($index * 0.08), 2)) ?>s">
                                            <div class="meta-row">
                                                <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                    <span class="story-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                                <?php endif; ?>
                                                <?php if ($showDate && !empty($post['published_at'])): ?>
                                                    <span class="story-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                                <?php endif; ?>
                                            </div>

                                            <h3>
                                                <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a>
                                            </h3>

                                            <?php if (!empty($post['summary'])): ?>
                                                <p>
                                                    <?= htmlspecialchars(mb_substr($post['summary'], 0, 120)) ?><?= mb_strlen($post['summary']) > 120 ? '...' : '' ?>
                                                </p>
                                            <?php endif; ?>

                                            <div class="story-foot compact">
                                                <?php if ($showAuthor && !empty($post['author'])): ?>
                                                    <span class="story-author"><?= htmlspecialchars($post['author']) ?></span>
                                                <?php endif; ?>
                                                <a href="<?= htmlspecialchars($post['url']) ?>" class="story-link"><?= __('Open') ?></a>
                                            </div>
                                        </article>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    <?php endif; ?>

                    <?php if (!empty($lanePosts)): ?>
                        <div class="lane-grid <?= htmlspecialchars($cardStyleClass) ?>">
                            <?php foreach ($lanePosts as $index => $post): ?>
                                <?php
                                $isWide = $cardStyle === 'featured' && $index === 0;
                                $hasCover = !empty($post['cover_image']);
                                $cardClasses = 'lane-card';
                                if ($isWide) {
                                    $cardClasses .= ' is-wide';
                                }
                                if ($hasCover) {
                                    $cardClasses .= ' has-cover';
                                }
                                ?>
                                <article class="<?= htmlspecialchars($cardClasses) ?> wow animate__animated animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.04 * (($index % 4) + 1), 2)) ?>s">
                                    <?php if ($hasCover): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="lane-media">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                        </a>
                                    <?php endif; ?>

                                    <div class="lane-copy">
                                        <div class="meta-row">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span class="story-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span class="story-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>

                                        <h3>
                                            <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a>
                                        </h3>

                                        <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                            <p class="lane-summary">
                                                <?= htmlspecialchars(mb_substr($post['summary'], 0, $isWide ? 180 : 130)) ?><?= mb_strlen($post['summary']) > ($isWide ? 180 : 130) ? '...' : '' ?>
                                            </p>
                                        <?php endif; ?>

                                        <div class="story-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span class="story-author"><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars($post['url']) ?>" class="story-link">
                                                <?= __('Read More') ?>
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="signal-rail wow animate__animated animate__fadeInRight">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker"><?= __('Category Radar') ?></span>
                                <h4><?= __('Browse by topic') ?></h4>
                                <div class="category-cloud">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-pill"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker"><?= __('Fresh Signals') ?></span>
                                <h4><?= __('Recent posts') ?></h4>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

