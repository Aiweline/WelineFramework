$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$templateCode = $page ? $page->getData('style') : 'rummy-overdrive';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'rummy-overdrive';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$layoutConfigRaw = $this->getData('layout_config');
if (is_string($layoutConfigRaw)) {
    $layoutConfig = json_decode($layoutConfigRaw, true) ?: [];
} else {
    $layoutConfig = is_array($layoutConfigRaw) ? $layoutConfigRaw : [];
}
$contentComponents = $layoutConfig['content'] ?? [];
if (!is_array($contentComponents)) {
    $contentComponents = [];
}

$pageType = $page ? (string) ($page->getData('type') ?: '') : '';
if (empty($contentComponents)) {
    switch ($pageType) {
        case 'about_page':
            $contentComponents = [['code' => 'about-content', 'enabled' => true, 'config' => []]];
            break;
        case 'contact_page':
            $contentComponents = [['code' => 'contact-content', 'enabled' => true, 'config' => []]];
            break;
        case 'privacy_policy':
        case 'terms_of_service':
        case 'refund_policy':
        case 'shipping_policy':
        case 'cookie_policy':
            $contentComponents = [['code' => 'legal-content', 'enabled' => true, 'config' => []]];
            break;
        case 'blog_list':
            $contentComponents = [['code' => 'blog-list', 'enabled' => true, 'config' => []]];
            break;
        case 'blog_category':
            $contentComponents = [['code' => 'blog-category', 'enabled' => true, 'config' => []]];
            break;
        case 'blog_post':
            $contentComponents = [['code' => 'blog-detail', 'enabled' => true, 'config' => []]];
            break;
        default:
            $contentComponents = [
                ['code' => 'hero-slider', 'enabled' => true, 'config' => []],
                ['code' => 'advantages', 'enabled' => true, 'config' => []],
                ['code' => 'games', 'enabled' => true, 'config' => []],
                ['code' => 'testimonials', 'enabled' => true, 'config' => []],
                ['code' => 'faq', 'enabled' => true, 'config' => []],
            ];
            break;
    }
}

$componentFiles = [
    'hero-slider' => 'content/hero-slider.phtml',
    'slider' => 'content/slider.phtml',
    'banner' => 'content/banner.phtml',
    'advantages' => 'content/advantages.phtml',
    'games' => 'content/games.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'faq' => 'content/faq.phtml',
    'about-content' => 'content/about-content.phtml',
    'contact-content' => 'content/contact-content.phtml',
    'legal-content' => 'content/legal-content.phtml',
    'blog-list' => 'content/blog-list.phtml',
    'blog-category' => 'content/blog-category.phtml',
    'blog-detail' => 'content/blog-detail.phtml',
];

$renderComponent = function (array $component, int $index) use ($componentFiles, $page, $styleSettings, $colors) {
    $code = $component['code'] ?? $component['component'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];

    if (!$enabled || $code === '') {
        return '';
    }

    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        return '<!-- Unknown content component: ' . htmlspecialchars($code, ENT_QUOTES, 'UTF-8') . ' -->';
    }

    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
    $this->assign('component_instance_id', 'rov-content-' . $code . '-' . $index);
    $this->assign('colors', $colors);

    try {
        return $this->fetchTemplate('GuoLaiRen_PageBuilder::style/rummy-overdrive/components/' . $file);
    } catch (\Throwable $e) {
        return '<!-- Error rendering content component ' . htmlspecialchars($code, ENT_QUOTES, 'UTF-8') . ': ' . htmlspecialchars($e->getMessage(), ENT_QUOTES, 'UTF-8') . ' -->';
    }
};

$bodyBg = (string) ($colors['body_bg'] ?? '#080b14');
$textColor = (string) ($colors['text_primary'] ?? '#f7f8fc');
$linkColor = (string) ($colors['accent_secondary'] ?? '#d2ff3f');
$customContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';
?>
<style>
.rov-content-region {
    min-height: 50vh;
    background: <?= htmlspecialchars($bodyBg) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
}

.rov-content-region a {
    color: <?= htmlspecialchars($linkColor) ?>;
}

.rov-content-fallback {
    width: min(920px, calc(100% - 1.2rem));
    margin: 0 auto;
    padding: clamp(4rem, 7vw, 6rem) 0;
}

.rov-content-fallback > :first-child {
    margin-top: 0;
}

.rov-content-fallback > :last-child {
    margin-bottom: 0;
}

.rov-content-empty {
    width: min(720px, calc(100% - 1.2rem));
    margin: 0 auto;
    padding: 4rem 0;
    text-align: center;
    color: rgba(247, 248, 252, 0.72);
}
</style>

<main class="rov-content-region">
    <?php if (!empty($contentComponents)): ?>
        <?php foreach ($contentComponents as $index => $component): ?>
            <?= $renderComponent((array) $component, (int) $index) ?>
        <?php endforeach; ?>
    <?php elseif ($customContent !== ''): ?>
        <section class="rov-content-fallback">
            <?= $customContent ?>
        </section>
    <?php else: ?>
        <section class="rov-content-empty">
            <p>No content is configured for this page yet.</p>
        </section>
    <?php endif; ?>
</main>
