$fontSize = $genResponsiveCSS($parseResponsive($getConfigAny(['typography.font_size'], '12/14') . 'px'));
$lineHeight = (float) $getConfigAny(['typography.line_height'], '1.75');

$logoText = (string) $getConfigAny(['footer.logo_text', 'footer.logo.text', 'logo.text'], 'Rummy Overdrive');
