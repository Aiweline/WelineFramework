$borderWidth = (int) $getConfigAny(['style.border_width'], '1');
$sectionPadding = (int) $getConfigAny(['style.section_padding'], '40');
$sectionPaddingMobile = (int) $getConfigAny(['style.section_padding_mobile'], '28');
$separatorDisplay = $normalizeToggle($getConfigAny(['style.separator_display'], 'no'), 'no') !== 'no';
$separatorChar = trim((string) $getConfigAny(['style.separator_char'], '/'));
if ($separatorChar === '') {
    $separatorChar = '/';
}
$separatorColor = (string) $getConfigAny(['style.separator_color'], '#8e99b3');

$disclaimerBgColor = (string) $getConfigAny(['disclaimer.bg_color'], 'transparent');
