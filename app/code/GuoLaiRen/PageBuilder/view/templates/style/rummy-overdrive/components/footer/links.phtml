$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);
$tagline = (string) $getConfigAny(['footer.tagline'], 'High-contrast rummy lanes, faster scan paths, and mobile-ready table entry.');
