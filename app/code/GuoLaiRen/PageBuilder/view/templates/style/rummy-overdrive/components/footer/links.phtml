);

$links = [];
$useCustomLinksRaw = (string) $getConfigAny(['content.use_custom_links'], '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfigAny(['content.use_subpages'], 'no'), 'no') !== 'yes';
if (!$useCustomLinks && $page) {
    $footerPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(30)
        : $page->getNavigationPages([], 30);
    foreach ($footerPages as $subpage) {
        $type = (string) ($subpage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny(['content.footer_label_' . $type], ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($subpage['title'] ?? ''),
            'href' => $subpage['url'] ?? '#',
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny(
        ['content.footer_links', 'footer.links'],
        "Home=>/\nTables=>#tables\nWhy Overdrive=>#advantages\nPlayers=>#reviews\nFAQ=>#faq\nSupport=>/contact"
    );

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = (strpos($linksConfig, "\n") !== false && strpos($linksConfig, ',') === false)
        ? preg_split('/\r?\n/', $linksConfig)
        : explode(',', $linksConfig);

    foreach ($items as $item) {
        $item = trim($item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } elseif (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } else {
            $parts = [$item, '#'];
        }
        if (count($parts) >= 1 && $parts[0] !== '') {
            $links[] = ['text' => $parts[0], 'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#'];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

$socials = [
