$avatarBorderRadius = (int) $getConfigAny(['style.avatar_border_radius'], '16');
$textColor = (string) $getConfigAny(['style.text_color'], '#f7f8fc');
$sectionPadding = (int) $getConfigAny(['style.section_padding'], '84');
$sectionPaddingMobile = (int) $getConfigAny(['style.section_padding_mobile'], '52');
$cardGap = (int) $getConfigAny(['style.card_gap'], '16');

$kicker = trim((string) $getConfigAny(['texts.kicker'], 'Player reactions'));
$title = (string) $getConfigAny(['texts.title', 'testimonials.title', 'texts.testimonials_title'], 'What Rummy Players Notice First');
$intro = trim((string) $getConfigAny(
    ['texts.intro'],
    'Rummy players usually notice whether the review lane helps them trust the table mood, room clarity, and mobile swipe flow before they commit to a room.'
));
$averageLabel = trim((string) $getConfigAny(['texts.average_label'], 'Average rating'));
$prevLabel = trim((string) $getConfigAny(['texts.prev_label'], 'Prev'));
$nextLabel = trim((string) $getConfigAny(['texts.next_label'], 'Next'));

$parseRating = static function ($raw) {
    $raw = trim((string) $raw);
    if ($raw === '') {
        return 0;
    }
    if (is_numeric($raw)) {
        return (int) $raw;
    }
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    1 => [
        'name' => 'Aarav Sinha',
        'tag' => 'Rush Meld Table',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'The table cards read fast. I can judge room mood, pace, and entry intent before I even hit the button.',
    ],
    2 => [
        'name' => 'Meera Joshi',
        'tag' => 'Joker Circuit',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'The moving light effects feel premium, but the buttons and content still stay simple enough for mobile.',
    ],
    3 => [
        'name' => 'Rohan Verma',
        'tag' => 'Night Cash Arena',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'This does not look like a recycled casino page. The structure feels designed around rummy instead of generic game traffic.',
    ],
    4 => [
        'name' => 'Ananya Pillai',
        'tag' => 'Mobile Player',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'I liked how fast the cards collapsed into swipe mode on my phone. Nothing felt cramped.',
    ],
    5 => [
        'name' => 'Kabir Rao',
        'tag' => 'Daily Cash Visitor',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'The contrast between the bright sections and dark review lane keeps the homepage from feeling flat.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i];
    $name = trim((string) $getTestimonialConfig($i, ['texts.testimonial_' . $i . '_name'], $defaults['name']));
    $tag = trim((string) $getTestimonialConfig($i, ['texts.testimonial_' . $i . '_tag'], $defaults['tag']));
    $ratingText = (string) $getTestimonialConfig($i, ['texts.testimonial_' . $i . '_rating'], $defaults['rating']);
    $content = trim((string) $getTestimonialConfig($i, ['texts.testimonial_' . $i . '_content'], $defaults['text']));
    $avatar = trim((string) $getTestimonialConfig($i, ['avatars.avatar_' . $i], ''));

    if ($name !== '' && $content !== '') {
        $ratingValue = max(0, min(5, $parseRating($ratingText)));
        $ratingDisplay = is_numeric($ratingText) ? str_repeat('★', (int) $ratingText) : trim($ratingText);
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => $ratingValue,
            'rating_text' => $ratingDisplay !== '' ? $ratingDisplay : str_repeat('★', max(1, $ratingValue)),
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($testimonials)) {
    foreach ($defaultTestimonials as $defaults) {
        $testimonials[] = [
            'name' => $defaults['name'],
            'tag' => $defaults['tag'],
            'rating' => $parseRating($defaults['rating']),
            'rating_text' => $defaults['rating'],
            'text' => $defaults['text'],
            'avatar' => '',
        ];
    }
}

$avgRating = count($testimonials) ? array_sum(array_column($testimonials, 'rating')) / count($testimonials) : 0;
$avgRatingLabel = number_format($avgRating, 1);
$avgRatingStars = str_repeat('★', max(1, (int) round($avgRating)));

$buildInitials = static function ($name) {
    $parts = preg_split('/\s+/', trim((string) $name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};
