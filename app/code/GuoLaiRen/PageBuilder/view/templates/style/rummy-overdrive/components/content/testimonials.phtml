<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var track = root.querySelector('[data-review-track]');
    if (!track) {
        return;
    }

    root.querySelectorAll('.review-nav').forEach(function (button) {
        button.addEventListener('click', function () {
            var card = track.querySelector('[data-review-card]');
            var step = card ? card.offsetWidth + <?= $cardGap ?> : track.clientWidth * 0.8;
            var direction = button.getAttribute('data-direction') === 'prev' ? -1 : 1;
            track.scrollBy({ left: step * direction, behavior: 'smooth' });
        });
    });
})();
</script>
