$componentId = 'rov-testimonials-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getTestimonialConfig = static function (int $index, array $keys, $default = '') use ($getConfigAny) {
    $scope = 'testimonial_' . $index;
    $scopedKeys = [];
    foreach ($keys as $key) {
        $scopedKeys[] = $scope . '.' . $key;
    }

    return $getConfigAny(array_merge($scopedKeys, $keys), $default);
};

$display = $getConfigAny(['display.show_section', 'testimonials.display'], 'yes') !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfigAny(['display.show_title'], 'yes') !== 'no';
$showRating = $getConfigAny(['display.show_rating'], 'yes') !== 'no';
$showAvatar = $getConfigAny(['display.show_avatar'], 'yes') !== 'no';
$showAvg = $getConfigAny(['display.show_avg'], 'yes') !== 'no';

$bgColor = (string) $getConfigAny(['style.bg_color', 'testimonials.bg_color'], '#101628');
$accentColor = (string) $getConfigAny(['style.accent_color'], '#2be7ff');
$titleColor = (string) $getConfigAny(['style.title_color'], '#ffffff');
$titleFontSize = (int) $getConfigAny(['style.title_font_size'], '58');
$titleFontSizeMobile = (int) $getConfigAny(['style.title_font_size_mobile'], '32');
$cardBgColor = (string) $getConfigAny(['style.card_bg_color'], 'rgba(255,255,255,0.06)');
$cardBorderColor = (string) $getConfigAny(['style.card_border_color'], 'rgba(255,255,255,0.1)');
$cardBorderRadius = (int) $getConfigAny(['style.card_border_radius'], '26');
$cardBorderLeftColor = (string) $getConfigAny(['style.card_border_left_color'], '#2be7ff');
$cardBorderLeftWidth = (int) $getConfigAny(['style.card_border_left_width'], '2');
$cardPadding = (int) $getConfigAny(['style.card_padding'], '18');
$nameColor = (string) $getConfigAny(['style.name_color'], '#ffffff');
