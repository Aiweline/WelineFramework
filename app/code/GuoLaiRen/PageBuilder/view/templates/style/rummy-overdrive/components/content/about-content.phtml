 * values.value_2_icon => 价值2图标:text:🛰️
 * values.value_2_title => 价值2标题:text:Clear Signals
 * values.value_2_desc => 价值2描述:textarea:Keep room notes, support paths, and review blocks readable across desktop and mobile.
 * values.value_3_icon => 价值3图标:text:📱
 * values.value_3_title => 价值3标题:text:Responsive Motion
 * values.value_3_desc => 价值3描述:textarea:Use animation as emphasis while keeping tap targets and sections stable on smaller screens.
 * values.bg_color => 背景色:color:#171228
 *
 * group:team => 团队区块
 * team.title => 标题:text:Operations Roles
 * team.subtitle => 副标题:text:Configurable profile cards for support, publishing, and product ownership.
 * team.member_1_icon => 成员1头像:text:🎯
 * team.member_1_name => 成员1姓名:text:Support Lead
 * team.member_1_role => 成员1职位:text:Player issue routing
 * team.member_2_icon => 成员2头像:text:🛡️
 * team.member_2_name => 成员2姓名:text:Safety Ops
 * team.member_2_role => 成员2职位:text:Policy and trust review
 * team.member_3_icon => 成员3头像:text:🃏
 * team.member_3_name => 成员3姓名:text:Room Product
 * team.member_3_role => 成员3职位:text:Rummy room flow design
 * team.member_4_icon => 成员4头像:text:📣
 * team.member_4_name => 成员4姓名:text:Content Ops
 * team.member_4_role => 成员4职位:text:Guide and update publishing
 *
 * group:cta => 底部CTA
 * cta.title => CTA标题:text:Need a custom about page flow?
 * cta.description => CTA描述:textarea:Use the editable title, story, values, team, and CTA fields to adapt this page for each new rummy site.
 * cta.button_text => 按钮文字:text:Contact Support
 * cta.button_url => 按钮链接:text:/contact
 * cta.button_bg => 按钮背景:color:linear-gradient(135deg, #ff4d7a 0%, #d2ff3f 100%)
 * cta.button_text_color => 按钮文字颜色:color:#0a0f1d
 *
 * @fields_end
 */

$componentId = 'rov-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if ($getConfig('display.show_section', 'yes') === 'no') {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'yes') !== 'no';
$showCta = $getConfig('display.show_cta', 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$heroTitle = trim((string)$getConfig('hero.title', $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'About Rummy Overdrive';
}
$heroSubtitle = trim((string)$getConfig('hero.subtitle', 'Rummy Overdrive reshapes the landing flow around faster table reading, stronger contrast, and cleaner mobile support for rummy-first traffic.'));
$heroPadding = max(48, (int)$getConfig('hero.padding', 88));

$storyTitle = trim((string)$getConfig('story.title', 'Why This Theme Exists'));
$storySubtitle = trim((string)$getConfig('story.subtitle', 'Built for faster table reading and cleaner mobile landing flow.'));
$storyContent = trim((string)$getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Rummy Overdrive keeps the original PHP rules and data structure intact while changing how players move through hero, tables, reviews, and support pages.';
}
$storyParagraphs = preg_split('/[\r\n]+/', $storyContent);
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs)) {
    $storyParagraphs = [$storyContent];
}

$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultNumber = ['24/7', '13-card', '3x', '1-tap'][$i - 1];
    $defaultLabel = ['Support coverage', 'Rummy-ready rules', 'Homepage contrast bands', 'Mobile room access'][$i - 1];
    $number = trim((string)$getConfig("stats.stat_{$i}_number", $defaultNumber));
    $label = trim((string)$getConfig("stats.stat_{$i}_label", $defaultLabel));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'number' => $number,
        'label' => $label,
    ];
}

$valuesTitle = trim((string)$getConfig('values.title', 'What The Theme Prioritizes'));
$valuesSubtitle = trim((string)$getConfig('values.subtitle', 'Three configurable pillars keep the layout focused and editable when new sites are created.'));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $defaultIcon = ['⚡', '🛰️', '📱'][$i - 1];
    $defaultTitle = ['Fast Entry', 'Clear Signals', 'Responsive Motion'][$i - 1];
    $defaultDesc = [
        'Guide players to the right rummy room with less scanning and clearer contrast.',
        'Keep room notes, support paths, and review blocks readable across desktop and mobile.',
        'Use animation as emphasis while keeping tap targets and sections stable on smaller screens.',
    ][$i - 1];

    $itemTitle = trim((string)$getConfig("values.value_{$i}_title", $defaultTitle));
    $itemDesc = trim((string)$getConfig("values.value_{$i}_desc", $defaultDesc));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string)$getConfig("values.value_{$i}_icon", $defaultIcon)),
        'title' => $itemTitle,
        'description' => $itemDesc,
    ];
}

$teamTitle = trim((string)$getConfig('team.title', 'Operations Roles'));
$teamSubtitle = trim((string)$getConfig('team.subtitle', 'Configurable profile cards for support, publishing, and product ownership.'));
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultName = ['Support Lead', 'Safety Ops', 'Room Product', 'Content Ops'][$i - 1];
    $defaultRole = ['Player issue routing', 'Policy and trust review', 'Rummy room flow design', 'Guide and update publishing'][$i - 1];
    $name = trim((string)$getConfig("team.member_{$i}_name", $defaultName));
    $role = trim((string)$getConfig("team.member_{$i}_role", $defaultRole));
    if ($name === '' && $role === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => trim((string)$getConfig("team.member_{$i}_icon", ['🎯', '🛡️', '🃏', '📣'][$i - 1])),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string)$getConfig('cta.title', 'Need a custom about page flow?'));
$ctaDescription = trim((string)$getConfig('cta.description', 'Use the editable title, story, values, team, and CTA fields to adapt this page for each new rummy site.'));
$ctaButtonText = trim((string)$getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string)$getConfig('cta.button_url', '/contact'));

$heroBg = (string)$getConfig('hero.bg_color', $colors['hero_bg'] ?? '#0c1020');
$heroBgEnd = (string)$getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#171228');
$heroTitleColor = (string)$getConfig('hero.title_color', $colors['text_primary'] ?? '#ffffff');
$heroTextColor = (string)$getConfig('hero.text_color', $colors['text_secondary'] ?? '#c7d2e5');
$storyBg = (string)$getConfig('story.bg_color', $colors['section_bg_2'] ?? '#111728');
$storyTitleColor = (string)$getConfig('story.title_color', $colors['accent_secondary'] ?? '#d2ff3f');
$valuesBg = (string)$getConfig('values.bg_color', $colors['section_bg_3'] ?? '#171228');
$statsCardBg = (string)$getConfig('stats.card_bg', $colors['card_bg'] ?? 'rgba(255,255,255,0.05)');
$statsNumberColor = (string)$getConfig('stats.number_color', $colors['accent_secondary'] ?? '#d2ff3f');
$statsLabelColor = (string)$getConfig('stats.label_color', $colors['text_muted'] ?? '#8b8b8b');
$ctaButtonBg = (string)$getConfig('cta.button_bg', $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #ff4d7a 0%, #d2ff3f 100%)');
$ctaButtonTextColor = (string)$getConfig('cta.button_text_color', $colors['button_primary_text'] ?? '#0a0f1d');
?>

<section
    id="<?= $componentId ?>"
    class="rov-about"
    style="--rov-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rov-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rov-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --rov-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --rov-about-stats-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --rov-about-stat-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-stat-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --rov-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --rov-about-hero-padding: <?= (int)$heroPadding ?>px;"
>
    <div class="about-shell">
        <header class="about-hero wow animate__animated animate__fadeInUp">
            <div class="hero-copy">
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <?php if ($heroSubtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($heroSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="story-panel wow animate__animated animate__fadeInUp" data-wow-delay="0.08s">
                <?php if ($storyTitle !== ''): ?>
                    <span class="panel-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                <?php endif; ?>
                <?php if ($storySubtitle !== ''): ?>
                    <h2><?= htmlspecialchars($storySubtitle) ?></h2>
                <?php endif; ?>
                <?php foreach ($storyParagraphs as $paragraph): ?>
                    <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                <?php endforeach; ?>
            </div>
        </header>

        <?php if ($showStats && !empty($stats)): ?>
            <section class="stats-belt wow animate__animated animate__fadeInUp" data-wow-delay="0.12s">
                <?php foreach ($stats as $index => $stat): ?>
                    <article class="stat-card<?= $index === 0 ? ' is-featured' : '' ?>">
                        <strong><?= htmlspecialchars($stat['number']) ?></strong>
                        <?php if ($stat['label'] !== ''): ?>
                            <span><?= htmlspecialchars($stat['label']) ?></span>
                        <?php endif; ?>
                    </article>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage wow animate__animated animate__fadeInUp" data-wow-delay="0.16s">
                <div class="section-head">
                    <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-card<?= $index === 0 ? ' is-featured' : '' ?>">
                            <div class="value-icon"><?= htmlspecialchars($value['icon']) ?></div>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <?php if ($value['description'] !== ''): ?>
                                <p><?= htmlspecialchars($value['description']) ?></p>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showTeam && !empty($teamMembers)): ?>
            <section class="team-stage wow animate__animated animate__fadeInUp" data-wow-delay="0.2s">
                <div class="section-head">
                    <h2><?= htmlspecialchars($teamTitle) ?></h2>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="team-grid">
                    <?php foreach ($teamMembers as $member): ?>
                        <article class="team-card">
                            <div class="team-icon"><?= htmlspecialchars($member['icon']) ?></div>
                            <h3><?= htmlspecialchars($member['name']) ?></h3>
                            <?php if ($member['role'] !== ''): ?>
                                <p><?= htmlspecialchars($member['role']) ?></p>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
            <section class="cta-band wow animate__animated animate__fadeInUp" data-wow-delay="0.24s">
                <div class="cta-copy">
                    <?php if ($ctaTitle !== ''): ?>
                        <h2><?= htmlspecialchars($ctaTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription) ?></p>
                    <?php endif; ?>
                </div>
                <?php if ($ctaButtonText !== ''): ?>
                    <a href="<?= htmlspecialchars($ctaButtonUrl !== '' ? $ctaButtonUrl : '/contact') ?>" class="cta-link"><?= htmlspecialchars($ctaButtonText) ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>

