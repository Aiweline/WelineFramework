    position: relative;
    padding: 84px 0;
    min-height: 100vh;
    background:
        radial-gradient(720px 360px at 10% 8%, rgba(255, 77, 122, 0.16), transparent 72%),
        radial-gradient(680px 360px at 88% 16%, rgba(43, 231, 255, 0.12), transparent 70%),
        linear-gradient(180deg, #0b1020 0%, #171228 48%, #090d18 100%);
}

