<?php
/**
 * Rummy Overdrive - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录、更新时间显示，继承主题配色
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:60|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.bg_color => 背景色:color:#0c1020
 * header.bg_gradient_end => 渐变结束色:color:#171228
 * header.title_color => 标题颜色:color:#ffffff
 * header.text_color => 文字颜色:color:#c7d2e5
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.items => 章节列表:textarea:|当页面正文为空时使用，一行一节，格式：标题=>内容
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.05)
 * toc.border_color => 目录边框色:color:rgba(255,255,255,0.1)
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:|当页面正文为空时显示
 * content.empty_text => 空内容提示:text:Content will be displayed here.
 * content.bg_color => 内容区背景色:color:#111728
 * content.text_color => 内容文字颜色:color:#c7d2e5
 * content.heading_color => 标题颜色:color:#ffffff
 * content.link_color => 链接颜色:color:#d2ff3f
 *
 * group:header_meta => 头部辅助信息
 * header.updated_label => 更新时间标签:text:Last Updated
 *
 * @fields_end
 */

$componentId = 'rov-legal-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$showToc = $getConfigAny(['display.show_toc'], 'yes') !== 'no';
$showLastUpdated = $getConfigAny(['display.show_last_updated'], 'yes') !== 'no';
$showIcon = $getConfigAny(['display.show_icon'], 'yes') !== 'no';

$contentWidth = (string)$getConfigAny(['layout.content_width'], 'narrow');
$headerPadding = max(48, (int)$getConfigAny(['layout.header_padding'], 80));
$contentPadding = max(28, (int)$getConfigAny(['layout.content_padding'], 60));

$pageType = $page ? (string)($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string)($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string)($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$headerTitle = trim((string)$getConfigAny(['header.title'], $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$headerIcon = trim((string)$getConfigAny(['header.icon'], $typeIcons[$pageType] ?? '📄'));
$updatedLabel = (string)$getConfigAny(['header.updated_label'], 'Last Updated');
$tocTitle = trim((string)$getConfigAny(['toc.title'], 'On This Page'));
$tocItemsConfig = (string)$getConfigAny(['toc.items'], '');
$contentBody = trim((string)$getConfigAny(['content.body'], ''));
$contentEmptyText = (string)$getConfigAny(['content.empty_text'], 'Content will be displayed here.');

$heroBg = (string)$getConfigAny(['header.bg_color'], $colors['hero_bg'] ?? '#0c1020');
$heroBgEnd = (string)$getConfigAny(['header.bg_gradient_end'], $colors['hero_bg_gradient_end'] ?? '#171228');
$heroTitleColor = (string)$getConfigAny(['header.title_color'], $colors['text_primary'] ?? '#ffffff');
$heroTextColor = (string)$getConfigAny(['header.text_color'], $colors['text_secondary'] ?? '#c7d2e5');
$tocBg = (string)$getConfigAny(['toc.bg_color'], $colors['card_bg'] ?? 'rgba(255,255,255,0.05)');
$tocBorder = (string)$getConfigAny(['toc.border_color'], $colors['border_light'] ?? 'rgba(255,255,255,0.1)');
$contentBg = (string)$getConfigAny(['content.bg_color'], $colors['section_bg_2'] ?? '#111728');
$contentText = (string)$getConfigAny(['content.text_color'], $colors['text_secondary'] ?? '#c7d2e5');
$contentHeading = (string)$getConfigAny(['content.heading_color'], $colors['text_primary'] ?? '#ffffff');
$contentLink = (string)$getConfigAny(['content.link_color'], $colors['accent_secondary'] ?? '#d2ff3f');

$maxWidth = match ($contentWidth) {
    'wide' => '1180px',
    'medium' => '980px',
    default => '820px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($pageContent === '') {
    $sections = [];
    foreach (preg_split('/\r?\n/', $tocItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        if (strpos($line, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $line, 2));
        } elseif (strpos($line, '|') !== false) {
            $parts = array_map('trim', explode('|', $line, 2));
        } else {
            $parts = [$line, ''];
        }
        if (($parts[0] ?? '') === '') {
            continue;
        }
        $sections[] = ['title' => $parts[0], 'content' => $parts[1] ?? ''];
    }
    if ($contentBody !== '' || !empty($sections)) {
        $pageContent = '';
        if ($contentBody !== '') {
            $pageContent .= '<p>' . nl2br(htmlspecialchars($contentBody)) . '</p>';
        }
        foreach ($sections as $section) {
            $pageContent .= '<h2>' . htmlspecialchars((string)$section['title']) . '</h2>';
            if ((string)$section['content'] !== '') {
                $pageContent .= '<p>' . nl2br(htmlspecialchars((string)$section['content'])) . '</p>';
            }
        }
    }
}
if ($showToc && $pageContent !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int)$matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (++$headingIndex);

        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContent);
}

$hasToc = $showToc && !empty($tocItems);
?>

<section
    id="<?= $componentId ?>"
    class="rov-legal"
    style="--rov-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --rov-legal-header-padding: <?= (int)$headerPadding ?>px; --rov-legal-content-padding: <?= (int)$contentPadding ?>px; --rov-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="legal-shell">
        <header class="legal-hero wow animate__animated animate__fadeInUp">
            <?php if ($showIcon && $headerIcon !== ''): ?>
                <span class="hero-icon"><?= htmlspecialchars($headerIcon) ?></span>
            <?php endif; ?>
            <h1><?= htmlspecialchars($headerTitle) ?></h1>
            <?php if ($showLastUpdated && $lastUpdated !== ''): ?>
                <p class="last-updated"><?= htmlspecialchars($updatedLabel) ?>: <?= htmlspecialchars(date('F j, Y', strtotime($lastUpdated))) ?></p>
            <?php endif; ?>
        </header>

        <div class="legal-layout<?= $hasToc ? ' has-toc' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-toc wow animate__animated animate__fadeInLeft" aria-label="<?= htmlspecialchars((string)__('Table of contents')) ?>">
                    <div class="toc-card">
                        <span class="toc-title"><?= htmlspecialchars($tocTitle) ?></span>
                        <nav class="toc-links">
                            <?php foreach ($tocItems as $item): ?>
                                <a href="#<?= htmlspecialchars($item['id']) ?>" class="toc-link level-<?= (int)$item['level'] ?>">
                                    <?= htmlspecialchars($item['text']) ?>
                                </a>
                            <?php endforeach; ?>
                        </nav>
                    </div>
                </aside>
            <?php endif; ?>

            <article class="legal-article wow animate__animated animate__fadeInUp">
                <div class="legal-content">
                    <?php if ($pageContent !== ''): ?>
                        <?= $pageContent ?>
                    <?php else: ?>
                        <p><?= htmlspecialchars($contentEmptyText) ?></p>
                    <?php endif; ?>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
