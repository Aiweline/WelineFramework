}

#<?= $componentId ?> .legal-content a {
    color: var(--rov-legal-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
}

#<?= $componentId ?> .legal-content ul,
#<?= $componentId ?> .legal-content ol {
    padding-left: 1.3rem;
}

#<?= $componentId ?> .legal-content blockquote {
    margin: 1.2rem 0;
    padding-left: 1rem;
    border-left: 3px solid rgba(210, 255, 63, 0.35);
}

#<?= $componentId ?> .legal-content table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: 16px;
}

#<?= $componentId ?> .legal-content table th,
#<?= $componentId ?> .legal-content table td {
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
}

@media (max-width: 960px) {
    #<?= $componentId ?> .legal-layout.has-toc {
        grid-template-columns: 1fr;
    }

    #<?= $componentId ?> .legal-toc {
        position: static;
    }
}

@media (max-width: 760px) {
    #<?= $componentId ?> {
        padding: 64px 0;
    }

    #<?= $componentId ?> .legal-shell {
        width: min(100% - 1.25rem, 1220px);
    }

    #<?= $componentId ?> .legal-article {
        padding: 1.2rem;
