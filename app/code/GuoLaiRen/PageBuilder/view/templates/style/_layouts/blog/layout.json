{
    "layout": "blog",
    "name": "博客布局",
    "description": "博客专用布局类型，提供文章列表、文章详情、分类、标签等功能",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "required": true,
            "accepts": ["header"],
            "default_component": null
        },
        "sidebar": {
            "name": "侧边栏",
            "required": false,
            "accepts": ["widget", "sidebar"],
            "position": "left|right",
            "default_position": "right",
            "widgets": [
                "categories",
                "recent_posts",
                "tags_cloud",
                "search",
                "archives",
                "custom"
            ]
        },
        "content": {
            "name": "内容区域",
            "required": true,
            "accepts": ["content", "section"],
            "content_types": {
                "blog_list": {
                    "name": "文章列表",
                    "description": "显示博客文章列表",
                    "template": "list.phtml"
                },
                "blog_post": {
                    "name": "文章详情",
                    "description": "显示单篇博客文章",
                    "template": "detail.phtml"
                },
                "blog_category": {
                    "name": "分类文章",
                    "description": "显示特定分类的文章",
                    "template": "category.phtml"
                },
                "blog_tag": {
                    "name": "标签文章",
                    "description": "显示特定标签的文章",
                    "template": "tag.phtml"
                }
            }
        },
        "footer": {
            "name": "底部区域",
            "required": true,
            "accepts": ["footer"],
            "default_component": null
        }
    },
    "settings": {
        "sidebar": {
            "show": {
                "label": "显示侧边栏",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "position": {
                "label": "侧边栏位置",
                "type": "select",
                "options": ["left", "right"],
                "default": "right"
            },
            "width": {
                "label": "侧边栏宽度",
                "type": "select",
                "options": ["3", "4"],
                "default": "4",
                "description": "Bootstrap栅格列数"
            }
        },
        "list": {
            "style": {
                "label": "列表样式",
                "type": "select",
                "options": ["grid", "list"],
                "default": "grid"
            },
            "columns": {
                "label": "网格列数",
                "type": "select",
                "options": ["2", "3", "4"],
                "default": "3"
            },
            "posts_per_page": {
                "label": "每页文章数",
                "type": "number",
                "default": 9
            },
            "show_excerpt": {
                "label": "显示摘要",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "show_date": {
                "label": "显示日期",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "show_author": {
                "label": "显示作者",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "show_category": {
                "label": "显示分类",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            }
        },
        "article": {
            "show_cover": {
                "label": "显示封面图",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "show_share": {
                "label": "显示分享按钮",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "show_related": {
                "label": "显示相关文章",
                "type": "select",
                "options": ["yes", "no"],
                "default": "yes"
            },
            "related_count": {
                "label": "相关文章数量",
                "type": "number",
                "default": 3
            }
        }
    },
    "data_sources": {
        "blog_posts": "GuoLaiRen\\Blog\\Model\\Post",
        "blog_categories": "GuoLaiRen\\Blog\\Model\\Category"
    }
}
