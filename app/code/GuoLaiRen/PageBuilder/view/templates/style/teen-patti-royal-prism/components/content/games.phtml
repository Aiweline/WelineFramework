    [
        'title' => $title2,
        'desc' => $desc2,
        'desktop' => $image2,
        'mobile' => $image2,
        'tag' => 'Skill lane',
        'stamp' => 'Route 02',
        'tone' => 'mint',
    ],
    [
        'title' => $title3,
        'desc' => $desc3,
        'desktop' => $image3,
        'mobile' => $image3,
        'tag' => 'Break lane',
        'stamp' => 'Route 03',
