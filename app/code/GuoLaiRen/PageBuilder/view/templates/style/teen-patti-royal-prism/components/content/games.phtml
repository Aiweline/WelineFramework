$componentId = 'prism-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#ffe0c2'));
$titleColor = $getConfig('style.title_color', '#3d2217');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.82)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '18');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(126,91,67,0.14)');
$cardTitleColor = $getConfig('style.card_title_color', '#3d2217');
$cardTitleFontSize = (int)$getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', '#6b4e41');
