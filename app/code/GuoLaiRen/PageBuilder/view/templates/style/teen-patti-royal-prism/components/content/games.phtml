    ['title' => 'Rummy Turbo', 'desc' => 'Sequence-focused matches with cleaner score rhythm and fast rematch entry.'],
    ['title' => 'Slot Sprint', 'desc' => 'Short spin sessions designed for fast breaks between card tables.'],
];

$title = $getConfig('texts.title', $getConfig('games.title', $getConfig('texts.games_title', $defaultSectionTitle)));
