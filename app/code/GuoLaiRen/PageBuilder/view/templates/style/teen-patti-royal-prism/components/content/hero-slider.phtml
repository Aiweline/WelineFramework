<?php
/**
 * Teen Patti Royal Prism - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: 首屏轮播Banner
 * name_en: Hero Slider
 * description: 首屏轮播Banner，与导航重叠效果，支持响应式图片和下载按钮
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.webp
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用本地prism-hero-stage.svg
 * banner.image_desktop => 桌面端Banner图片:textarea:|默认使用本地prism-hero-stage.svg
 * banner.alt => Banner图片描述:text:Teen Patti Royal Prism launch board
 * banner.bg_color => Banner背景色:color:#fff4d8
 *
 * group:hero => Hero文案
 * hero.title => Hero标题:text:
 * hero.subtitle => Hero副标题:textarea:
 * hero.stage_text => Hero舞台文案:text:
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载徽章图片:textarea:|默认使用本地prism-floating-badge.svg
 * download_btn.alt => 下载按钮文案:text:Download App
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 附加类名:textarea:rs-slider slider-style2
 * layout.margin_top => 顶部偏移:number:0|px
 * layout.img_margin_top => 媒体偏移:number:0|px
 *
 * @fields_end
 */

$page = $this->getData('page') ?? null;
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    $value = $config[$key] ?? $default;
    if ($value === '' && $default !== '') {
        return $default;
    }
    return $value;
};

$bannerDisplayRaw = $getConfig('banner.display', 'yes');
$bannerDisplay = ($bannerDisplayRaw === 'yes' || $bannerDisplayRaw === true || $bannerDisplayRaw === 'true' || $bannerDisplayRaw === 0 || $bannerDisplayRaw === '0');
if (!$bannerDisplay) {
    return;
}

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sanitizeTitle = static function ($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$defaultStage = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/prism-hero-stage.svg');
$defaultDownloadBadge = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/prism-floating-badge.svg');

$bannerImageMobile = trim((string)$getConfig('banner.image_mobile', '')) ?: $defaultStage;
$bannerImageDesktop = trim((string)$getConfig('banner.image_desktop', '')) ?: $defaultStage;
$bannerAlt = (string)$getConfig('banner.alt', 'Teen Patti Royal Prism launch board');
$bannerBgColor = (string)$getConfig('banner.bg_color', $colors['hero_bg'] ?? '#fff4d8');

$downloadBtnDisplayRaw = $getConfig('download_btn.display', 'yes');
$downloadBtnDisplay = ($downloadBtnDisplayRaw === 'yes' || $downloadBtnDisplayRaw === true || $downloadBtnDisplayRaw === 'true' || $downloadBtnDisplayRaw === 0 || $downloadBtnDisplayRaw === '0');
$downloadBtnImage = trim((string)$getConfig('download_btn.image', '')) ?: $defaultDownloadBadge;
$downloadBtnAlt = (string)$getConfig('download_btn.alt', 'Download App');
$downloadBtnUrl = (string)$getConfig('download_btn.url', '#download');

$sliderClasses = trim((string)$getConfig('layout.slider_classes', 'rs-slider slider-style2'));
$marginTop = (int)$getConfig('layout.margin_top', '0');
$imgMarginTop = (int)$getConfig('layout.img_margin_top', '0');

$appName = $sanitizeTitle((string)$getConfig('app_info.app_name', ''));
if ($appName === '') {
    $appName = 'Teen Patti Royal Prism';
}
$pageTitleFallback = $page ? $sanitizeTitle((string)($page->getData('title') ?: $page->getData('meta_title') ?: $appName)) : $appName;
$pageTitle = $sanitizeTitle((string)$getConfig('hero.title', $pageTitleFallback));
if ($pageTitle === '') {
    $pageTitle = $appName;
}
$subtitle = trim((string)$getConfig('hero.subtitle', $page ? (string)($page->getData('meta_description') ?: '') : ''));
if ($subtitle === '') {
    $subtitle = trim((string)$bannerAlt);
    if ($subtitle === $pageTitle) {
        $subtitle = '';
    }
}

$heroMarqueeText = trim((string)$getConfig('hero.stage_text', ''));
if ($heroMarqueeText === '') {
    $heroMarqueeText = trim((string)$bannerAlt);
}
if ($heroMarqueeText === '') {
    $heroMarqueeText = $pageTitle;
}

$stagePanels = [];
foreach ([$appName, $pageTitle, $heroMarqueeText] as $panelValue) {
    $panelValue = trim((string)$panelValue);
    if ($panelValue === '' || in_array($panelValue, $stagePanels, true)) {
        continue;
    }
    $stagePanels[] = $panelValue;
}

$componentId = 'prism-hero-' . uniqid();
?>
<section id="main-content" class="prism-hero-section <?= htmlspecialchars($sliderClasses) ?>" style="--hero-offset: <?= $marginTop ?>px; --media-offset: <?= $imgMarginTop ?>px;">
    <div id="<?= $componentId ?>" class="prism-hero-wrap">
        <div class="prism-hero-orbit orbit-a" data-prism-parallax data-prism-speed="0.05" aria-hidden="true"></div>
        <div class="prism-hero-orbit orbit-b" data-prism-parallax data-prism-speed="0.09" aria-hidden="true"></div>
        <div class="prism-hero-grid prism-section-shell">
            <header class="prism-hero-copy" data-prism-reveal data-prism-effect="animate__fadeInUp">
                <span class="prism-hero-kicker"><?= htmlspecialchars($appName) ?></span>
                <h1><?= htmlspecialchars($pageTitle) ?></h1>
                <p class="prism-hero-subtitle"><?= htmlspecialchars($subtitle) ?></p>

                <div class="prism-hero-actions" id="download">
                    <?php if ($downloadBtnDisplay): ?>
                        <a class="prism-hero-primary" href="<?= htmlspecialchars($downloadBtnUrl) ?>">
                            <span><?= htmlspecialchars($downloadBtnAlt) ?></span>
                        </a>
                        <a class="prism-hero-badge" href="<?= htmlspecialchars($downloadBtnUrl) ?>" aria-label="<?= htmlspecialchars($downloadBtnAlt) ?>">
                            <img src="<?= htmlspecialchars($downloadBtnImage) ?>" alt="<?= htmlspecialchars($downloadBtnAlt) ?>" loading="lazy" decoding="async">
                        </a>
                    <?php endif; ?>
                </div>
            </header>

            <div class="prism-hero-stage" data-prism-reveal data-prism-effect="animate__fadeInRight">
                <?php if ($heroMarqueeText !== ''): ?>
                    <article class="prism-stage-marquee prism-glass" data-prism-parallax data-prism-speed="0.08">
                        <span class="marquee-chip"><?= htmlspecialchars($appName) ?></span>
                        <strong><?= htmlspecialchars($heroMarqueeText) ?></strong>
                    </article>
                <?php endif; ?>

                <figure class="prism-stage-billboard prism-glass" data-prism-parallax data-prism-speed="0.1">
                    <picture>
                        <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerImageMobile) ?>">
                        <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerImageDesktop) ?>">
                        <img src="<?= htmlspecialchars($bannerImageDesktop ?: $bannerImageMobile) ?>" alt="<?= htmlspecialchars($bannerAlt) ?>" fetchpriority="high" decoding="async">
                    </picture>
                </figure>

                <?php if (!empty($stagePanels)): ?>
                    <div class="prism-stage-panels">
                        <?php foreach ($stagePanels as $index => $panel): ?>
                            <article class="prism-panel prism-glass prism-panel-<?= (int)($index + 1) ?>" data-prism-parallax data-prism-speed="<?= htmlspecialchars(number_format(0.06 + ($index * 0.02), 2, '.', '')) ?>">
                                <strong><?= htmlspecialchars($panel) ?></strong>
                            </article>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</section>
<style>
