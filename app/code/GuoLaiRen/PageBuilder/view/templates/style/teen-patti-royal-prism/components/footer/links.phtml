if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$bgColor = $getConfig('style.background_color', $colors['footer_bg'] ?? '#fff1dc');
$textColor = $getConfig('style.text_color', $colors['footer_text'] ?? '#7e6253');
$linkColor = $getConfig('style.link_color', $colors['footer_link'] ?? '#4c2d20');
$linkHoverColor = $getConfig('style.link_hover_color', $colors['footer_link_hover'] ?? '#1fcab6');
$borderTop = $normalizeToggle($getConfig('style.border_top', 'yes')) !== 'no';
$borderColor = $getConfig('style.border_color', $colors['border_light'] ?? 'rgba(126,91,67,0.14)');
$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';

$maxWidth = (int)$getConfig('layout.max_width', '1200');
$paddingHorizontal = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_horizontal', '20/40') . 'px'));
$paddingVertical = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_vertical', '34/54') . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float)$getConfig('typography.line_height', '1.65');

$footerHomeText = $getConfig('content.footer_label_home_page', $getConfig('texts.footer_home', 'Home'));
$footerFaqText = $getConfig('texts.footer_faq', 'FAQ');
$footerBlogText = $getConfig('content.footer_label_blog_list', $getConfig('texts.footer_blog', 'Blog'));
$footerAboutText = $getConfig('content.footer_label_about_page', $getConfig('texts.footer_about', 'About'));
$footerPrivacyText = $getConfig('content.footer_label_privacy_policy', $getConfig('texts.footer_privacy', 'Privacy Policy'));
$footerTermsText = $getConfig('content.footer_label_terms_of_service', $getConfig('texts.footer_terms', 'Terms & Conditions'));
$copyrightText = $getConfig('content.copyright_text', '© 2026 Teen Patti Royal Prism. All rights reserved.');
$disclaimerText = $getConfig('content.disclaimer_text', '18+ Only. Play responsibly and review local regulations before participating in any gaming activity.');

$footerLinksText = trim((string)$getConfig('content.footer_links', 'Home|/,Blog|/blog,FAQ|/faqs,About|/about,Privacy|/privacy-policy,Terms|/terms-conditions'));
$links = [];
$useCustomLinks = $normalizeToggle($getConfig('content.use_custom_links', 'yes')) === 'yes';
if (!$useCustomLinks && $page) {
    $footerPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(30)
        : $page->getNavigationPages([], 30);
    foreach ($footerPages as $footerPage) {
        $title = trim((string)($footerPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }
        $type = (string)($footerPage['type'] ?? '');
        $configuredLabel = trim((string)$getConfig('content.footer_label_' . $type, ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $title,
            'href' => (string)($footerPage['url'] ?? '#'),
        ];
    }
}
if (empty($links) && $footerLinksText !== '') {
    $items = strpos($footerLinksText, "\n") !== false ? preg_split('/\r?\n/', $footerLinksText) : explode(',', $footerLinksText);
    foreach ($items as $item) {
        $item = trim((string)$item);
        if ($item === '') {
            continue;
        }
        $delimiter = strpos($item, '|') !== false ? '|' : (strpos($item, '=>') !== false ? '=>' : null);
        if (!$delimiter) {
            continue;
        }
        $parts = array_map('trim', explode($delimiter, $item, 2));
        if (count($parts) === 2 && $parts[0] !== '' && $parts[1] !== '') {
            $links[] = ['text' => $parts[0], 'href' => $parts[1]];
        }
    }
}
if (empty($links)) {
    $links = [
        ['text' => $footerHomeText, 'href' => '/'],
        ['text' => $footerFaqText, 'href' => '/faqs'],
        ['text' => $footerBlogText, 'href' => '/blog'],
        ['text' => $footerAboutText, 'href' => '/about'],
        ['text' => $footerPrivacyText, 'href' => '/privacy-policy'],
        ['text' => $footerTermsText, 'href' => '/terms-conditions'],
    ];
}

$logoText = trim((string)$getConfig('logo.text', $getConfig('footer.logo.text', $getConfig('app_info.app_name', ''))));
if ($logoText === '') {
    $logoText = 'Teen Patti Royal Prism';
}
$logoUrl = $getConfig('logo.url', $getConfig('footer.logo.url', '')) ?: ($page && $page->getData('logo') ? $page->getData('logo') : $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/prism-logo-icon.svg'));
$downloadDisplay = $getConfig('download_button.display', $getConfig('download_btn.display', 'yes')) !== 'no';
$downloadText = trim((string)$getConfig('download_button.text', ''));
if ($downloadText === '') {
    $downloadText = trim((string)$getConfig('download_btn.alt', ''));
}
if ($downloadText === '' || strtolower($downloadText) === 'download app') {
    $downloadText = 'Download';
}
$downloadUrl = trim((string)$getConfig('download_button.url', ''));
if ($downloadUrl === '') {
    $downloadUrl = trim((string)$getConfig('download_btn.url', '#download'));
}
if ($downloadUrl === '') {
    $downloadUrl = '#download';
}
$downloadImage = trim((string)$getConfig('download_btn.image', ''));
if ($downloadImage === '') {
    $downloadImage = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/prism-floating-download-tab.svg');
}
