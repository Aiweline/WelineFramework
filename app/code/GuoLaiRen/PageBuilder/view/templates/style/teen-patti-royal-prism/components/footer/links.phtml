    <a id="<?= $floatingId ?>"
       class="prism-floating-download"
       href="<?= htmlspecialchars($downloadUrl) ?>"
       aria-label="<?= htmlspecialchars($downloadText) ?>"
       title="<?= htmlspecialchars($downloadText) ?>"
       data-prism-reveal
       data-prism-effect="animate__fadeInUp">
