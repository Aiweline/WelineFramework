            <?php if ($downloadImage !== ''): ?>
                <img src="<?= htmlspecialchars($downloadImage) ?>" alt="" loading="lazy" decoding="async">
            <?php endif; ?>
        </span>
        <span class="floating-copy">
            <strong><?= htmlspecialchars($downloadText) ?></strong>
        </span>
        <span class="floating-arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M7 17L17 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M9 7H17V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </a>
    <script>
    (function () {
        var trigger = document.getElementById('<?= $floatingId ?>');
        if (!trigger) {
            return;
        }

        trigger.addEventListener('click', function (event) {
            var href = trigger.getAttribute('href') || '';
            if (!href || href.charAt(0) !== '#') {
                return;
            }

            var target = document.querySelector(href)
                || document.getElementById('download')
                || document.querySelector('[data-download-anchor]')
                || document.querySelector('.banner-pocket')
                || document.querySelector('.download-dock')
                || document.querySelector('.hero-actions')
                || document.getElementById('hero')
                || document.getElementById('games');

            if (!target) {
                return;
            }

            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    })();
    </script>
