<?php
/**
 * 通用法律内容组件
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录、更新时间显示，继承主题配色
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:60|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:|留空使用页面标题
 * header.icon => 自定义图标:text:|如:PP TC RF
 * header.bg_color => 背景色:color:#fff4d8
 * header.bg_gradient_end => 渐变结束色:color:#ffe4a8
 * header.title_color => 标题颜色:color:#402217
 * header.text_color => 文字颜色:color:#6b4e41
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.78)
 * toc.border_color => 目录边框色:color:rgba(126,91,67,0.14)
 *
 * group:content => 内容设置
 * content.bg_color => 内容区背景色:color:#fffdf8
 * content.text_color => 内容文字颜色:color:#6b4e41
 * content.heading_color => 标题颜色:color:#402217
 * content.link_color => 链接颜色:color:#ff7a45
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$config = array_merge(
    is_array($styleSettings) ? $styleSettings : [],
    is_array($componentConfig) ? $componentConfig : []
);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string)$getConfig('layout.content_width', 'narrow');
$headerPadding = max(44, (int)$getConfig('layout.header_padding', '80'));
$contentPadding = max(26, (int)$getConfig('layout.content_padding', '60'));

$headerTitle = trim((string)$getConfig('header.title', ''));
$headerIcon = trim((string)$getConfig('header.icon', ''));
$headerBgColorConfig = $getConfig('header.bg_color', '');
$headerGradientEndConfig = $getConfig('header.bg_gradient_end', '');
$headerTitleColorConfig = $getConfig('header.title_color', '');
$headerTextColorConfig = $getConfig('header.text_color', '');

$tocTitle = $getConfig('toc.title', $getConfig('legal.toc_title', 'On This Page'));
$tocBgColorConfig = $getConfig('toc.bg_color', '');
$tocBorderColorConfig = $getConfig('toc.border_color', '');

$contentBgColorConfig = $getConfig('content.bg_color', '');
$contentTextColorConfig = $getConfig('content.text_color', '');
$contentHeadingColorConfig = $getConfig('content.heading_color', '');
$contentLinkColorConfig = $getConfig('content.link_color', '');

$page = $this->getData('page');
$pageTitle = $headerTitle ?: ($page ? (string)($page->getData('title') ?? '') : '');
$pageTitle = trim($pageTitle) !== '' ? trim($pageTitle) : 'Legal Document';
$pageContentRaw = $page ? (string)($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string)($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';
$pageType = $page ? (string)($page->getData('type') ?? '') : '';

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $headerBgColorConfig ?: ($colors['hero_bg'] ?? '#fff6ea');
$heroGradientEnd = $headerGradientEndConfig ?: ($colors['hero_bg_gradient_end'] ?? '#ffe2bb');
$contentBg = $contentBgColorConfig ?: ($colors['section_bg_1'] ?? '#fffdf8');
$textPrimary = $colors['text_primary'] ?? '#332016';
$textSecondary = $contentTextColorConfig ?: ($colors['text_secondary'] ?? '#6b4e41');
$textMuted = $headerTextColorConfig ?: ($colors['text_muted'] ?? '#9a7d6d');
$headingColor = $contentHeadingColorConfig ?: ($headerTitleColorConfig ?: ($colors['heading_color'] ?? '#3d2217'));
$linkColor = $contentLinkColorConfig ?: ($colors['accent_primary'] ?? '#ff7a45');
$cardBg = $tocBgColorConfig ?: ($colors['card_bg'] ?? 'rgba(255,255,255,0.82)');
$borderLight = $tocBorderColorConfig ?: ($colors['border_light'] ?? 'rgba(126,91,67,0.14)');
$primaryColor = $getConfig('color_scheme.primary', '#ff7a45');
$secondaryColor = $getConfig('color_scheme.secondary', '#00cdb6');

$typeLabels = [
    'privacy_policy' => __('Privacy Policy'),
    'terms_of_service' => __('Terms & Conditions'),
    'refund_policy' => __('Refund Policy'),
    'shipping_policy' => __('Shipping Policy'),
    'cookie_policy' => __('Cookie Policy'),
];
$typeIcons = [
    'privacy_policy' => 'PP',
    'terms_of_service' => 'TC',
    'refund_policy' => 'RF',
    'shipping_policy' => 'SP',
    'cookie_policy' => 'CK',
];
$pageLabel = $typeLabels[$pageType] ?? __('Legal Page');
$currentIcon = $headerIcon !== '' ? $headerIcon : ($typeIcons[$pageType] ?? 'LG');

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $text = trim(strip_tags((string)$matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $tocItems[] = [
            'id' => $id,
            'title' => $text,
            'level' => (int)$matches[1],
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}

$hasToc = $showToc && !empty($tocItems);
$formattedUpdated = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('M j, Y', $timestamp);
    }
}

$contentHtml = trim(strip_tags($pageContent)) !== '' ? $pageContent : '<p>' . htmlspecialchars((string)__('Content will appear here once published.')) . '</p>';
$maxWidth = match ($contentWidth) {
    'wide' => '1280px',
    'medium' => '1120px',
    default => $hasToc ? '1120px' : '920px',
};

$instanceId = $component_instance_id ?? 'legal-content-' . uniqid();
?>

<section id="<?= $instanceId ?>" class="prism-legal-page">
    <div class="legal-hero">
        <span class="hero-ribbon ribbon-left" data-prism-parallax data-prism-speed="0.05" aria-hidden="true"></span>
        <span class="hero-ribbon ribbon-right" data-prism-parallax data-prism-speed="0.08" aria-hidden="true"></span>
        <div class="section-inner" style="max-width: <?= $maxWidth ?>;">
            <div class="hero-shell">
                <header class="hero-copy" data-prism-reveal data-prism-effect="animate__fadeInUp">
                    <p class="section-tag"><?= htmlspecialchars((string)$pageLabel) ?></p>
                    <h1><?= htmlspecialchars($pageTitle) ?></h1>
                    <?php if ($formattedUpdated !== ''): ?>
                        <p class="hero-updated">
                            <span><?= __('Updated') ?></span>
                            <time datetime="<?= htmlspecialchars(date('c', strtotime($lastUpdated))) ?>"><?= htmlspecialchars($formattedUpdated) ?></time>
                        </p>
                    <?php endif; ?>
                </header>

                <?php if ($showIcon): ?>
                    <aside class="hero-mark" data-prism-reveal data-prism-effect="animate__fadeInLeft" aria-hidden="true">
                        <strong><?= htmlspecialchars($currentIcon) ?></strong>
                        <small><?= __('Legal') ?></small>
                    </aside>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <div class="legal-stage">
        <div class="section-inner" style="max-width: <?= $maxWidth ?>;">
            <div class="reader-layout<?= $hasToc ? ' has-toc' : '' ?>">
                <?php if ($hasToc): ?>
                    <aside class="toc-panel" data-prism-reveal data-prism-effect="animate__fadeInUp">
                        <div class="toc-card">
                            <h2><?= htmlspecialchars((string)$tocTitle) ?></h2>
                            <nav aria-label="Table of contents">
                                <?php foreach ($tocItems as $item): ?>
                                    <a href="#<?= htmlspecialchars($item['id']) ?>" class="level-<?= (int)$item['level'] ?>">
                                        <?= htmlspecialchars($item['title']) ?>
                                    </a>
                                <?php endforeach; ?>
                            </nav>
                        </div>
                    </aside>
                <?php endif; ?>

                <article class="reader-paper" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="90ms">
                    <?= $contentHtml ?>
                </article>
            </div>
        </div>
    </div>
</section>

<?php if ($hasToc): ?>
<script>
(function () {
    var root = document.getElementById('<?= $instanceId ?>');
    if (!root || !('IntersectionObserver' in window)) {
        return;
    }

    var links = Array.prototype.slice.call(root.querySelectorAll('.toc-card a[href^="#"]'));
    var headings = links.map(function (link) {
        var target = root.querySelector(link.getAttribute('href'));
        return target ? { link: link, target: target } : null;
    }).filter(Boolean);

    if (!headings.length) {
        return;
    }

    var activeLink = function (id) {
        links.forEach(function (link) {
            link.classList.toggle('is-active', link.getAttribute('href') === '#' + id);
        });
    };

    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                activeLink(entry.target.id);
            }
        });
    }, {
        rootMargin: '-20% 0px -65% 0px',
        threshold: 0
    });

    headings.forEach(function (item, index) {
        observer.observe(item.target);
        if (index === 0) {
            activeLink(item.target.id);
        }
    });
})();
</script>
<?php endif; ?>

