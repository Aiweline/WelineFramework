$componentId = 'prism-advantages-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';
$showButton = $getConfig('display.show_button', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('advantages.bg_color', '#ddfff5'));
$titleColor = $getConfig('style.title_color', '#3d2217');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardTitleColor = $getConfig('style.card_title_color', '#3d2217');
$cardTitleFontSize = (int)$getConfig('style.card_title_font_size', '18');
$cardDescColor = $getConfig('style.card_desc_color', '#6b4e41');
$cardDescFontSize = (int)$getConfig('style.card_desc_font_size', '14');
$iconSize = (int)$getConfig('style.icon_size', '85');
$iconBorderRadius = (int)$getConfig('style.icon_border_radius', '50');
$sectionPadding = (int)$getConfig('style.section_padding', '60');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '40');
$cardGap = (int)$getConfig('style.card_gap', '30');

$btnText = $getConfig('button.text', 'Join Table');
$btnUrl = $getConfig('button.url', '#download');
$btnGradientStart = $getConfig('button.bg_gradient_start', '#ffd661');
$btnGradientEnd = $getConfig('button.bg_gradient_end', '#ff764d');
$btnTextColor = $getConfig('button.text_color', '#2b140d');
$btnBorderRadius = (int)$getConfig('button.border_radius', '999');
$btnPaddingX = (int)$getConfig('button.padding_x', '32');
$btnPaddingY = (int)$getConfig('button.padding_y', '10');

$defaultIcon1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/our-advantages/icon01.webp');
$defaultIcon2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/our-advantages/icon02.webp');
$defaultIcon3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-royal-prism/asset/img/our-advantages/icon03.webp');

$icon1 = $getConfig('icons.icon_1', $getConfig('advantages.icon_1', '')) ?: $defaultIcon1;
$icon2 = $getConfig('icons.icon_2', $getConfig('advantages.icon_2', '')) ?: $defaultIcon2;
$icon3 = $getConfig('icons.icon_3', $getConfig('advantages.icon_3', '')) ?: $defaultIcon3;

$defaultSectionTitle = 'Why This Bright Layout Stands Out';
$defaultCards = [
    [
        'title' => 'Fast Teen Patti Entry',
        'desc' => 'Open active Teen Patti rooms quickly with fewer taps and clearer mode grouping.',
    ],
    [
        'title' => 'Stable Round Sync',
        'desc' => 'Card state and wallet values update in a clean rhythm across repeat rounds.',
    ],
    [
        'title' => 'Pace-Friendly UI',
        'desc' => 'Readable hierarchy and stronger focus zones help players scan decisions faster.',
    ],
];

$title = $getConfig('texts.title', $getConfig('advantages.title', $getConfig('texts.advantages_title', $defaultSectionTitle)));
$title1 = $getConfig('texts.advantage_1_title', $defaultCards[0]['title']);
