                    <?php if ($showTitle): ?>
                        <h2 id="<?= $componentId ?>-title" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="70ms"><?= htmlspecialchars($title) ?></h2>
                    <?php endif; ?>
                </div>
                <?php if ($showButton): ?>
                    <a href="<?= htmlspecialchars($btnUrl) ?>" class="adv-cta" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="130ms"><?= htmlspecialchars($btnText) ?></a>
                <?php endif; ?>
            </header>
        <?php endif; ?>

        <ol class="adv-promenade" aria-label="Core advantages">
            <?php foreach ($cards as $index => $card): ?>
                <?php $baseDelay = 120 + ($index * 120); ?>
                <li class="adv-lane adv-lane-<?= (int)($index + 1) ?>">
                    <article class="adv-card">
                        <span class="adv-card-aura" aria-hidden="true"></span>
                        <span class="adv-line" aria-hidden="true"></span>
                        <div class="adv-number" data-prism-reveal data-prism-effect="animate__zoomIn" data-wow-delay="<?= htmlspecialchars((string)$baseDelay) ?>ms"><?= htmlspecialchars($card['index']) ?></div>
                        <div class="adv-media" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="<?= htmlspecialchars((string)($baseDelay + 60)) ?>ms">
                            <div class="adv-icon-wrap">
                                <img src="<?= htmlspecialchars($card['icon']) ?>" alt="<?= htmlspecialchars($card['title']) ?>" loading="lazy" decoding="async">
                            </div>
                        </div>
                        <div class="adv-copy" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="<?= htmlspecialchars((string)($baseDelay + 120)) ?>ms">
                            <span class="adv-tag"><?= htmlspecialchars($card['tag']) ?></span>
