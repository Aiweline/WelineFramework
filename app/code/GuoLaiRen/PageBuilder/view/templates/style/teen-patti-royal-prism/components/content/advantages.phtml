 * group:texts => 文本内容
 * texts.title => 区域标题:text:Why This Bright Layout Stands Out
 * texts.advantage_1_title => 优势1标题:text:Fast Teen Patti Entry
 * texts.advantage_1_desc => 优势1描述:textarea:Open active Teen Patti rooms quickly with fewer taps and clearer mode grouping.
 * texts.advantage_2_title => 优势2标题:text:Stable Round Sync
 * texts.advantage_2_desc => 优势2描述:textarea:Card state and wallet values update in a clean rhythm across repeat rounds.
 * texts.advantage_3_title => 优势3标题:text:Pace-Friendly UI
 * texts.advantage_3_desc => 优势3描述:textarea:Readable hierarchy and stronger focus zones help players scan decisions faster.
 *
