    ['icon' => $icon2, 'title' => $title2, 'desc' => $desc2, 'tag' => 'Clean sync', 'index' => '02'],
    ['icon' => $icon3, 'title' => $title3, 'desc' => $desc3, 'tag' => 'Mobile focus', 'index' => '03'],
];
?>
<section id="<?= $componentId ?>" class="prism-advantages" aria-labelledby="<?= $componentId ?>-title">
    <div class="adv-orb adv-orb-sun" data-prism-parallax data-prism-speed="0.05" aria-hidden="true"></div>
    <div class="adv-orb adv-orb-mint" data-prism-parallax data-prism-speed="0.08" aria-hidden="true"></div>
    <div class="adv-zigzag" data-prism-parallax data-prism-speed="0.04" aria-hidden="true">
