<?php
/**
 * Teen Patti Royal Prism - Blog Category Component
 *
 * @fields_start
 * blog.title|分类页标题（留空使用分类名）|text|
 * blog.subtitle|副标题|text|Browse articles by category
 * blog.posts_per_page|每页文章数|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=重点|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? 'Category Posts');
$subtitle = $getConfig('blog.subtitle', 'Browse articles by category');
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = (string)$getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#ff7a45');
$secondaryColor = $getConfig('color_scheme.secondary', '#00cdb6');
$bgColor = $getConfig('color_scheme.background', '#fffaf0');
$textColor = $getConfig('color_scheme.text', '#332016');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $posts[0] ?? null;
$listPosts = array_slice($posts, 1);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};

$componentId = $component_instance_id ?? 'blog-category-' . uniqid();
?>

<section id="<?= $componentId ?>" class="prism-blog-category style-<?= htmlspecialchars($cardStyle) ?>">
    <div class="section-inner">
        <header class="category-head">
            <div class="head-copy" data-prism-reveal data-prism-effect="animate__fadeInUp">
                <?php if (!empty($currentCategory['name'])): ?>
                    <p class="section-tag"><?= htmlspecialchars((string)$currentCategory['name']) ?></p>
                <?php else: ?>
                    <p class="section-tag"><?= __('Category') ?></p>
                <?php endif; ?>

                <div class="head-row">
                    <h1><?= htmlspecialchars((string)$title) ?></h1>
                    <?php if (!empty($posts)): ?>
                        <span class="post-count"><?= count($posts) ?> <?= __('Posts') ?></span>
                    <?php endif; ?>
                </div>

                <?php if ($subtitle): ?>
                    <p class="head-summary"><?= htmlspecialchars((string)$subtitle) ?></p>
                <?php endif; ?>

                <?php if (!empty($currentCategory['description'])): ?>
                    <p class="head-description"><?= htmlspecialchars((string)$currentCategory['description']) ?></p>
                <?php endif; ?>
            </div>

            <?php if (!empty($blogCategories)): ?>
                <nav class="category-switchboard" aria-label="Category switchboard" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="90ms">
                    <?php foreach ($blogCategories as $category): ?>
                        <?php
                        $name = (string)($category['name'] ?? '');
                        $url = (string)($category['url'] ?? '#');
                        $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$currentCategory['id'] === (string)$category['id'];
                        if ($name === '') continue;
                        ?>
                        <a href="<?= htmlspecialchars($url) ?>" class="<?= $isActive ? 'is-active' : '' ?>">
                            <span><?= htmlspecialchars($name) ?></span>
                            <?php if (isset($category['post_count'])): ?>
                                <em><?= (int)$category['post_count'] ?></em>
                            <?php endif; ?>
                        </a>
                    <?php endforeach; ?>
                </nav>
            <?php endif; ?>
        </header>

        <?php if (empty($posts)): ?>
            <article class="empty-state" data-prism-reveal data-prism-effect="animate__fadeInUp">
                <h2><?= __('No posts in this category yet') ?></h2>
                <p><?= __('Try another category or return to the blog index.') ?></p>
                <a href="/blog"><?= __('Back to Blog') ?></a>
            </article>
        <?php else: ?>
            <div class="category-layout<?= $showSidebar ? ' with-sidebar' : '' ?>">
                <main class="category-main">
                    <?php if ($featuredPost): ?>
                        <?php
                        $featuredUrl = (string)($featuredPost['url'] ?? '#');
                        $featuredTitle = (string)($featuredPost['title'] ?? __('Untitled Post'));
                        $featuredSummary = (string)($featuredPost['summary'] ?? '');
                        $featuredImage = (string)($featuredPost['cover_image'] ?? '');
                        $featuredCategory = (string)($featuredPost['category_name'] ?? '');
                        $featuredDate = $formatDate($featuredPost['published_at'] ?? '');
                        $featuredAuthor = (string)($featuredPost['author'] ?? '');
                        ?>
                        <article class="focus-card<?= $featuredImage === '' ? ' no-image' : '' ?>" data-prism-reveal data-prism-effect="animate__fadeInUp">
                            <div class="focus-copy">
                                <div class="focus-meta">
                                    <?php if ($showCategory && $featuredCategory !== ''): ?>
                                        <span class="story-chip"><?= htmlspecialchars($featuredCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $featuredDate !== ''): ?>
                                        <span class="story-date"><?= htmlspecialchars($featuredDate) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h2><a href="<?= htmlspecialchars($featuredUrl) ?>"><?= htmlspecialchars($featuredTitle) ?></a></h2>

                                <?php if ($featuredSummary !== ''): ?>
                                    <p><?= htmlspecialchars(mb_substr($featuredSummary, 0, 220)) ?><?= mb_strlen($featuredSummary) > 220 ? '...' : '' ?></p>
                                <?php endif; ?>

                                <div class="focus-foot">
                                    <?php if ($showAuthor && $featuredAuthor !== ''): ?>
                                        <span class="story-author"><?= htmlspecialchars($featuredAuthor) ?></span>
                                    <?php endif; ?>
                                    <a class="story-link" href="<?= htmlspecialchars($featuredUrl) ?>"><?= __('Read Story') ?></a>
                                </div>
                            </div>

                            <?php if ($featuredImage !== ''): ?>
                                <a class="focus-media" href="<?= htmlspecialchars($featuredUrl) ?>">
                                    <img src="<?= htmlspecialchars($featuredImage) ?>" alt="<?= htmlspecialchars($featuredTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($listPosts)): ?>
                        <div class="ledger-list">
                            <?php foreach ($listPosts as $index => $post): ?>
                                <?php
                                $postUrl = (string)($post['url'] ?? '#');
                                $postTitle = (string)($post['title'] ?? __('Untitled Post'));
                                $postSummary = (string)($post['summary'] ?? '');
                                $postImage = (string)($post['cover_image'] ?? '');
                                $postCategory = (string)($post['category_name'] ?? '');
                                $postDate = $formatDate($post['published_at'] ?? '');
                                $postAuthor = (string)($post['author'] ?? '');
                                $toneClass = 'tone-' . (($index % 3) + 1);
                                ?>
                                <article class="ledger-entry <?= htmlspecialchars($toneClass) ?><?= $postImage === '' ? ' no-image' : '' ?>" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="<?= min($index * 70, 280) ?>ms">
                                    <div class="entry-stamp">
                                        <?php if ($showCategory && $postCategory !== ''): ?>
                                            <span class="stamp-chip"><?= htmlspecialchars($postCategory) ?></span>
                                        <?php endif; ?>
                                        <?php if ($showDate && $postDate !== ''): ?>
                                            <strong><?= htmlspecialchars($postDate) ?></strong>
                                        <?php endif; ?>
                                        <?php if ($showAuthor && $postAuthor !== ''): ?>
                                            <small><?= htmlspecialchars($postAuthor) ?></small>
                                        <?php endif; ?>
                                    </div>

                                    <div class="entry-body">
                                        <h3><a href="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($postTitle) ?></a></h3>
                                        <?php if ($postSummary !== ''): ?>
                                            <p><?= htmlspecialchars(mb_substr($postSummary, 0, 180)) ?><?= mb_strlen($postSummary) > 180 ? '...' : '' ?></p>
                                        <?php endif; ?>
                                        <a class="story-link" href="<?= htmlspecialchars($postUrl) ?>"><?= __('Read More') ?></a>
                                    </div>

                                    <?php if ($postImage !== ''): ?>
                                        <a class="entry-media" href="<?= htmlspecialchars($postUrl) ?>">
                                            <img src="<?= htmlspecialchars($postImage) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </main>

                <?php if ($showSidebar): ?>
                    <aside class="category-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card" data-prism-reveal data-prism-effect="animate__fadeInUp">
                                <h2><?= __('Category Guide') ?></h2>
                                <div class="rail-category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php
                                        $name = (string)($category['name'] ?? '');
                                        $url = (string)($category['url'] ?? '#');
                                        $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$currentCategory['id'] === (string)$category['id'];
                                        if ($name === '') continue;
                                        ?>
                                        <a href="<?= htmlspecialchars($url) ?>" class="<?= $isActive ? 'is-active' : '' ?>">
                                            <span><?= htmlspecialchars($name) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <em><?= (int)$category['post_count'] ?></em>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recent)): ?>
                            <section class="rail-card" data-prism-reveal data-prism-effect="animate__fadeInUp" data-wow-delay="100ms">
                                <h2><?= __('Recent Posts') ?></h2>
                                <div class="recent-stack">
                                    <?php foreach ($recent as $post): ?>
                                        <?php
                                        $recentUrl = (string)($post['url'] ?? '#');
                                        $recentTitle = (string)($post['title'] ?? __('Untitled Post'));
                                        $recentDate = $formatDate($post['published_at'] ?? '');
                                        ?>
                                        <a href="<?= htmlspecialchars($recentUrl) ?>">
                                            <strong><?= htmlspecialchars($recentTitle) ?></strong>
                                            <?php if ($recentDate !== ''): ?>
                                                <span><?= htmlspecialchars($recentDate) ?></span>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

