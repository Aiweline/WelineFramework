// Helper functions
if (!function_exists('getConfig')) {
    function getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

if (!function_exists('parseResp')) {
    function parseResp($value) {
        if (empty($value)) return ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => ''];
        $value = trim($value);
        $unit = '';
        if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
            $unit = $matches[1];
            $value = preg_replace('/[a-z%]+$/i', '', $value);
        }
        $parts = explode('/', trim($value));
        $result = ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
        switch (count($parts)) {
            case 1: $result['mobile'] = $result['tablet'] = $result['desktop'] = trim($parts[0]); break;
            case 2: $result['mobile'] = trim($parts[0]); $result['desktop'] = trim($parts[1]); break;
            case 3: $result['mobile'] = trim($parts[0]); $result['tablet'] = trim($parts[1]); $result['desktop'] = trim($parts[2]); break;
        }
        return $result;
    }
}

if (!function_exists('genRespCSS')) {
    function genRespCSS($parsed) {
        $mobile = floatval($parsed['mobile']);
        $desktop = floatval($parsed['desktop']);
        $unit = $parsed['unit'];
        if ($mobile === $desktop) return $mobile . $unit;
        $diff = $desktop - $mobile;
        return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
    }
}

if (!function_exists('genButtonHeight')) {
    /**
     * 生成按钮高度的 clamp 表达式
     * @param int $mobile 移动端高度
     * @param int $pc PC端高度
     * @return string
     */
    function genButtonHeight($mobile, $pc) {
        $diff = $pc - $mobile;
        return "clamp({$mobile}px, calc({$mobile}px + {$diff} * ((100vw - 375px) / (1280 - 375))), {$pc}px)";
    }
}

if (!function_exists('genButtonWidth')) {
    /**
     * 生成按钮宽度的 clamp 表达式
     * @param int $mobile 移动端宽度
     * @param int $pc PC端宽度
     * @return string
     */
    function genButtonWidth($mobile, $pc) {
        $diff = $pc - $mobile;
        return "clamp({$mobile}px, calc({$mobile}px + {$diff} * ((100vw - 375px) / (1280 - 375))), {$pc}px)";
    }
}

if (!function_exists('genThreeBreakpoint')) {
    /**
     * 生成三端（Mobile/iPad/PC）的 clamp 表达式
     * 确保在 iPad 断点（768px）精确匹配 tablet 值
     * @param float $mobile 移动端值（375px）
     * @param float $tablet iPad 端值（768px）
     * @param float $pc PC端值（1280px）
     * @param string $unit 单位，默认 'px'
     * @return string
     */
    function genThreeBreakpoint($mobile, $tablet, $pc, $unit = 'px') {
        // 如果三端值相同，直接返回
        if ($mobile === $tablet && $tablet === $pc) {
            return $mobile . $unit;
        }
        
        // 分段插值：
        // 第一段：375px -> 768px (mobile -> tablet)
        // 第二段：768px -> 1280px (tablet -> pc)
        $diff1 = $tablet - $mobile;
        $diff2 = $pc - $tablet;
        
        // 使用分段计算：当 vw < 768px 时使用第一段，当 vw >= 768px 时使用第二段
        // 通过 min/max 实现条件判断
        return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + ({$tablet} - {$mobile}) * ((min(100vw, 768px) - 375px) / (768 - 375)) + ({$pc} - {$tablet}) * ((max(0px, 100vw - 768px)) / (1280 - 768))), {$pc}{$unit})";
    }
}

