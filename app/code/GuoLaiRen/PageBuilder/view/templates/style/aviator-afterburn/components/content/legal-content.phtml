<?php
/**
 * Aviator Afterburn - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录和更新时间显示
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:52|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.updated_label => 更新时间前缀:text:Last Updated
 * header.bg_color => 背景色:color:#08111f
 * header.bg_gradient_end => 渐变结束色:color:#132746
 * header.title_color => 标题颜色:color:#f5fbff
 * header.text_color => 文字颜色:color:#b9cfe4
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Legal Index
 * toc.items => 章节:textarea:标题|段落内容，一行一节（当页面内容为空时由配置渲染）
 * toc.bg_color => 目录背景色:color:rgba(10,21,37,0.84)
 * toc.border_color => 目录边框色:color:rgba(41,208,255,0.16)
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:（当页面内容为空时显示）
 * content.empty_text => 空内容提示:text:Content will be displayed here.
 * content.bg_color => 内容区背景色:color:#0d182c
 * content.text_color => 内容文字颜色:color:#c7daed
 * content.heading_color => 标题颜色:color:#f5fbff
 * content.link_color => 链接颜色:color:#ffb24f
 *
 * @fields_end
 */

$componentId = 'aab-legal-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string) $getConfig('layout.content_width', 'narrow');
$headerPadding = max(48, (int) $getConfig('layout.header_padding', 80));
$contentPadding = max(28, (int) $getConfig('layout.content_padding', 52));

$pageType = $page ? (string) ($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string) ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$headerTitle = trim((string) $getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}

$typeIcons = [
    'privacy_policy' => 'PP',
    'terms_of_service' => 'TS',
    'refund_policy' => 'RF',
    'shipping_policy' => 'DL',
    'cookie_policy' => 'CK',
];
$headerIcon = trim((string) $getConfig('header.icon', $typeIcons[$pageType] ?? 'LG'));
$updatedLabelPrefix = trim((string) $getConfig('header.updated_label', 'Last Updated'));
$tocTitle = trim((string) $getConfig('toc.title', 'Legal Index'));
$fallbackTocRaw = trim((string) $getConfig('toc.items', ''));
$fallbackBody = trim((string) $getConfig('content.body', ''));
$emptyText = trim((string) $getConfig('content.empty_text', 'Content will be displayed here.'));

$heroBg = (string) $getConfig('header.bg_color', $colors['hero_bg'] ?? '#08111f');
$heroBgEnd = (string) $getConfig('header.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#132746');
$heroTitleColor = (string) $getConfig('header.title_color', $colors['text_primary'] ?? '#f5fbff');
$heroTextColor = (string) $getConfig('header.text_color', $colors['text_secondary'] ?? '#b9cfe4');
$tocBg = (string) $getConfig('toc.bg_color', $colors['card_bg'] ?? 'rgba(10,21,37,0.84)');
$tocBorder = (string) $getConfig('toc.border_color', $colors['border_light'] ?? 'rgba(41,208,255,0.16)');
$contentBg = (string) $getConfig('content.bg_color', $colors['section_bg_2'] ?? '#0d182c');
$contentText = (string) $getConfig('content.text_color', $colors['text_secondary'] ?? '#c7daed');
$contentHeading = (string) $getConfig('content.heading_color', $colors['text_primary'] ?? '#f5fbff');
$contentLink = (string) $getConfig('content.link_color', $colors['accent_secondary'] ?? '#ffb24f');

$maxWidth = match ($contentWidth) {
    'wide' => '1180px',
    'medium' => '980px',
    default => '820px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($pageContent === '' && ($fallbackBody !== '' || $fallbackTocRaw !== '')) {
    $rebuiltContent = [];
    if ($fallbackBody !== '') {
        $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($fallbackBody)) . '</p>';
    }
    foreach (preg_split('/[\r\n]+/', $fallbackTocRaw) as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $sectionTitle = trim((string) ($parts[0] ?? ''));
        $sectionBody = trim((string) ($parts[1] ?? ''));
        if ($sectionTitle === '') {
            continue;
        }
        $rebuiltContent[] = '<h2>' . htmlspecialchars($sectionTitle) . '</h2>';
        if ($sectionBody !== '') {
            $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($sectionBody)) . '</p>';
        }
    }
    $pageContent = implode('', $rebuiltContent);
}
if ($showToc && $pageContent !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int) $matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (++$headingIndex);

        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContent);
}

$hasToc = $showToc && !empty($tocItems);
?>

<section
    id="<?= $componentId ?>"
    class="aab-legal"
    style="--aab-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --aab-legal-header-padding: <?= (int) $headerPadding ?>px; --aab-legal-content-padding: <?= (int) $contentPadding ?>px; --aab-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="legal-shell">
        <header class="legal-hero">
            <?php if ($showIcon && $headerIcon !== ''): ?>
                <span class="hero-icon"><?= htmlspecialchars($headerIcon) ?></span>
            <?php endif; ?>
            <div class="hero-copy">
                <h1><?= htmlspecialchars($headerTitle) ?></h1>
                <?php if ($showLastUpdated && $lastUpdated !== ''): ?>
                    <p class="last-updated"><?= htmlspecialchars($updatedLabelPrefix !== '' ? $updatedLabelPrefix : 'Last Updated') ?>: <?= htmlspecialchars(date('F j, Y', strtotime($lastUpdated))) ?></p>
                <?php endif; ?>
            </div>
        </header>

        <?php if ($hasToc): ?>
            <section class="legal-index" aria-label="<?= htmlspecialchars((string) __('Table of contents')) ?>">
                <div class="index-head">
                    <span class="hero-kicker hero-kicker-dark"><?= htmlspecialchars($tocTitle) ?></span>
                </div>
                <nav class="index-scroll">
                    <?php foreach ($tocItems as $item): ?>
                        <a href="#<?= htmlspecialchars($item['id']) ?>" class="index-pill level-<?= (int) $item['level'] ?>">
                            <?= htmlspecialchars($item['text']) ?>
                        </a>
                    <?php endforeach; ?>
                </nav>
            </section>
        <?php endif; ?>

        <article class="legal-article">
            <div class="legal-content">
                <?php if ($pageContent !== ''): ?>
                    <?= $pageContent ?>
                <?php else: ?>
                    <p><?= htmlspecialchars($emptyText !== '' ? $emptyText : 'Content will be displayed here.') ?></p>
                <?php endif; ?>
            </div>
        </article>
    </div>
</section>

<style>
#<?= $componentId ?> {
    position: relative;
    padding: 84px 0;
    min-height: 100vh;
    background:
        radial-gradient(760px 360px at 8% 4%, rgba(255,107,44,0.12), transparent 72%),
        radial-gradient(720px 340px at 92% 16%, rgba(41,208,255,0.14), transparent 70%),
        linear-gradient(180deg, var(--aab-legal-hero-bg) 0%, var(--aab-legal-hero-end) 34%, #09111f 100%);
}

#<?= $componentId ?> .legal-shell {
    width: min(1220px, calc(100% - 1.2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

#<?= $componentId ?> .legal-hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    padding-top: var(--aab-legal-header-padding);
}

#<?= $componentId ?> .hero-icon {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 22px;
    background: linear-gradient(160deg, rgba(8,17,31,0.96) 0%, rgba(14,29,51,0.84) 100%);
    border: 1px solid rgba(41,208,255,0.18);
    box-shadow: 0 20px 36px rgba(4,10,18,0.22);
    color: #d9f4ff;
    font-size: 1.1rem;
    font-weight: 800;
}

#<?= $componentId ?> .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    min-height: 34px;
    padding: 0.4rem 0.84rem;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
    background: rgba(8,17,31,0.8);
    border: 1px solid rgba(41,208,255,0.18);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 18px 30px rgba(4,10,18,0.2);
    color: #d9f4ff;
}

#<?= $componentId ?> .hero-kicker::before {
    content: '';
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff6b2c 0%, #ffbf3f 46%, #29d0ff 100%);
    box-shadow: 0 0 12px rgba(41,208,255,0.28);
}

#<?= $componentId ?> .hero-kicker-dark {
    background: rgba(8,17,31,0.9);
}

#<?= $componentId ?> .hero-copy h1 {
    margin-top: 1rem;
    color: var(--aab-legal-hero-title);
    font-size: clamp(2.1rem, 4vw, 3.8rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-shadow: 0 0 22px rgba(41,208,255,0.14), 0 12px 28px rgba(0,0,0,0.22);
}

#<?= $componentId ?> .last-updated {
    margin-top: 0.85rem;
    color: var(--aab-legal-hero-text);
    font-size: 0.95rem;
}

#<?= $componentId ?> .legal-index,
#<?= $componentId ?> .legal-article {
    border-radius: 28px;
    border: 1px solid var(--aab-legal-toc-border);
    box-shadow: 0 24px 52px rgba(4,10,18,0.24);
}

#<?= $componentId ?> .legal-index {
    margin-top: 1.2rem;
    padding: 1rem;
    background:
        radial-gradient(220px 160px at 100% 0%, rgba(255,107,44,0.12), transparent 74%),
        linear-gradient(165deg, var(--aab-legal-toc-bg) 0%, rgba(12,25,43,0.94) 100%);
}

#<?= $componentId ?> .index-scroll {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding: 0.2rem 0 0.15rem;
    margin-top: 0.85rem;
    scrollbar-width: thin;
}

#<?= $componentId ?> .index-pill {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    color: #d9f4ff;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(41,208,255,0.14);
    white-space: nowrap;
}

#<?= $componentId ?> .index-pill.level-3 {
    opacity: 0.86;
}

#<?= $componentId ?> .legal-article {
    width: min(100%, var(--aab-legal-max-width));
    margin: 1rem auto 0;
    padding: var(--aab-legal-content-padding);
    background:
        radial-gradient(320px 120px at 100% 0%, rgba(41,208,255,0.08), transparent 74%),
        linear-gradient(160deg, var(--aab-legal-content-bg) 0%, rgba(12,25,43,0.96) 100%);
}

#<?= $componentId ?> .legal-content {
    color: var(--aab-legal-content-text);
    line-height: 1.88;
    font-size: 1rem;
}

#<?= $componentId ?> .legal-content h2,
#<?= $componentId ?> .legal-content h3 {
    color: var(--aab-legal-heading);
    scroll-margin-top: 120px;
    text-shadow: 0 0 18px rgba(41,208,255,0.1);
}

#<?= $componentId ?> .legal-content h2 {
    margin-top: 2rem;
    margin-bottom: 0.9rem;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    letter-spacing: -0.03em;
}

#<?= $componentId ?> .legal-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.72rem;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
}

#<?= $componentId ?> .legal-content p,
#<?= $componentId ?> .legal-content ul,
#<?= $componentId ?> .legal-content ol {
    margin: 0 0 1rem;
}

#<?= $componentId ?> .legal-content a {
    color: var(--aab-legal-link);
}

#<?= $componentId ?> .legal-content ul,
#<?= $componentId ?> .legal-content ol {
    padding-left: 1.4rem;
}

@media (max-width: 720px) {
    #<?= $componentId ?> {
        padding: 68px 0;
    }

    #<?= $componentId ?> .legal-shell {
        width: min(100%, calc(100% - 1rem));
    }

    #<?= $componentId ?> .legal-hero {
        grid-template-columns: 1fr;
        padding-top: 56px;
    }

    #<?= $componentId ?> .legal-article {
        padding: 1rem;
    }
}
</style>
