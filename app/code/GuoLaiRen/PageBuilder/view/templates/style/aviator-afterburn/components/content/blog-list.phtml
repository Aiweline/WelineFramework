        radial-gradient(1200px 600px at 15% 10%, rgba(255, 107, 44, 0.18), transparent 60%),
        radial-gradient(800px 500px at 85% 20%, rgba(41, 208, 255, 0.16), transparent 55%),
        <?= htmlspecialchars($bgColor) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
    overflow: hidden;
}

