<?php
/**
 * @component_start
 * code: faq
 * name: 常见问题
 * name_en: FAQ
 * description: Aviator 时间轴式 FAQ
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_intro => 显示简介:select:yes|yes,no
 * display.first_open => 首个问题默认展开:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景主色:color:#0c1728
 * style.accent_color => 强调色:color:#ff6b2c
 * style.title_color => 标题颜色:color:#f5fbff
 * style.text_color => 正文颜色:color:#c1d1e0
 * style.panel_bg_color => 卡片背景色:color:rgba(255,255,255,0.95)
 * style.card_border_color => 卡片边框色:color:rgba(41,208,255,0.18)
 * style.card_radius => 卡片圆角:number:24|px
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:52|px
 *
 * group:texts => 文本内容
 * texts.badge => 徽标文字:text:Flight Answers
 * texts.title => 区域标题:text:Frequently Asked Questions
 * texts.intro => 简介:textarea:Players usually want the same core answers first: how quickly rooms open, what the layout changes, and whether mobile actions stay clear during play.
 * texts.tag_1 => 标签1:text:Room Access
 * texts.tag_2 => 标签2:text:Crash Timing
 * texts.tag_3 => 标签3:text:Mobile Flow
 * texts.faq_1_question => 问题1:text:What changes from one Aviator room to another?
 * texts.faq_1_answer => 答案1:textarea:The crash game stays familiar, but room pace, visual density, and entry flow can change. That helps players choose a table that matches how quickly they want to react.
 * texts.faq_2_question => 问题2:text:Can the default room titles and descriptions be edited later?
 * texts.faq_2_answer => 答案2:textarea:Yes. Section title, intro, tags, room list, and each question-answer pair all follow editable component configuration values.
 * texts.faq_3_question => 问题3:text:Is the homepage still responsive on smaller screens?
 * texts.faq_3_answer => 答案3:textarea:Yes. Cards, review slides, and FAQ entries reflow into touch-friendly layouts, and the next item remains partly visible where that helps navigation.
 * texts.faq_4_question => 问题4:text:Why does this theme use stronger contrast between modules?
 * texts.faq_4_answer => 答案4:textarea:Aviator pages benefit from clearer separation. Distinct module backgrounds help players read the page faster instead of seeing one long block of similar surfaces.
 * texts.faq_5_question => 问题5:text:
 * texts.faq_5_answer => 答案5:textarea:
 * texts.faq_6_question => 问题6:text:
 * texts.faq_6_answer => 答案6:textarea:
 *
 * @fields_end
 */

$componentId = 'aab-faq-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showIntro = $getConfig('display.show_intro', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

$bgColor = (string) $getConfig('style.bg_color', '#0c1728');
$accentColor = (string) $getConfig('style.accent_color', '#ff6b2c');
$titleColor = (string) $getConfig('style.title_color', '#f5fbff');
$textColor = (string) $getConfig('style.text_color', '#c1d1e0');
$panelBgColor = (string) $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.95)');
$cardBorderColor = (string) $getConfig('style.card_border_color', 'rgba(41,208,255,0.18)');
$cardRadius = max(18, (int) $getConfig('style.card_radius', '24'));
$sectionPadding = max(48, (int) $getConfig('style.section_padding', '80'));
$sectionPaddingMobile = max(36, (int) $getConfig('style.section_padding_mobile', '52'));

$badgeText = (string) $getConfig('texts.badge', 'Flight Answers');
$title = (string) $getConfig('texts.title', 'Frequently Asked Questions');
$intro = (string) $getConfig('texts.intro', 'Players usually want the same core answers first: how quickly rooms open, what the layout changes, and whether mobile actions stay clear during play.');
$tags = [];
for ($i = 1; $i <= 3; $i++) {
    $tag = trim((string) $getConfig("texts.tag_{$i}", ''));
    if ($tag !== '') {
        $tags[] = $tag;
    }
}

$defaultFaqs = [
    1 => [
        'question' => 'What changes from one Aviator room to another?',
        'answer' => 'The crash game stays familiar, but room pace, visual density, and entry flow can change. That helps players choose a table that matches how quickly they want to react.',
    ],
    2 => [
        'question' => 'Can the default room titles and descriptions be edited later?',
        'answer' => 'Yes. Section title, intro, tags, room list, and each question-answer pair all follow editable component configuration values.',
    ],
    3 => [
        'question' => 'Is the homepage still responsive on smaller screens?',
        'answer' => 'Yes. Cards, review slides, and FAQ entries reflow into touch-friendly layouts, and the next item remains partly visible where that helps navigation.',
    ],
    4 => [
        'question' => 'Why does this theme use stronger contrast between modules?',
        'answer' => 'Aviator pages benefit from clearer separation. Distinct module backgrounds help players read the page faster instead of seeing one long block of similar surfaces.',
    ],
    5 => [
        'question' => '',
        'answer' => '',
    ],
    6 => [
        'question' => '',
        'answer' => '',
    ],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $defaults = $defaultFaqs[$i];
    $question = trim((string) $getConfig("texts.faq_{$i}_question", $defaults['question']));
    $answer = trim((string) $getConfig("texts.faq_{$i}_answer", $defaults['answer']));
    if ($question === '' || $answer === '') {
        continue;
    }
    $faqs[] = [
        'index' => count($faqs),
        'question' => $question,
        'answer' => $answer,
    ];
}
?>
<section id="<?= $componentId ?>" class="aab-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell" id="faq">
        <header class="faq-head">
            <div class="faq-copy">
                <span class="faq-badge"><?= htmlspecialchars($badgeText) ?></span>
                <?php if ($showTitle): ?>
                    <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php endif; ?>
                <?php if ($showIntro && $intro !== ''): ?>
                    <p class="faq-intro"><?= htmlspecialchars($intro) ?></p>
                <?php endif; ?>
            </div>

            <?php if (!empty($tags)): ?>
                <div class="faq-tags" aria-label="FAQ topics">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="faq-grid">
            <?php foreach ($faqs as $index => $faq): ?>
                <details class="faq-item"<?= ($firstOpen && $index === 0) ? ' open' : '' ?>>
                    <summary>
                        <span class="faq-index"><?= sprintf('%02d', $index + 1) ?></span>
                        <span class="faq-question"><?= htmlspecialchars($faq['question']) ?></span>
                        <span class="faq-icon" aria-hidden="true"></span>
                    </summary>
                    <div class="faq-answer">
                        <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
                    </div>
                </details>
            <?php endforeach; ?>
        </div>
    </div>
</section>

