<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var track = root.querySelector('[data-runway-track]');
    if (!track) {
        return;
    }

    var scrollByCard = function(direction) {
        var card = track.querySelector('.flight-card');
        var gap = 24;
        if (card) {
            var styles = window.getComputedStyle(track);
            gap = parseFloat(styles.columnGap || styles.gap || gap) || gap;
            track.scrollBy({
                left: (card.getBoundingClientRect().width + gap) * direction,
                behavior: 'smooth'
            });
        }
    };

    root.querySelectorAll('.carousel-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            scrollByCard(button.getAttribute('data-direction') === 'prev' ? -1 : 1);
        });
    });
})();
</script>
