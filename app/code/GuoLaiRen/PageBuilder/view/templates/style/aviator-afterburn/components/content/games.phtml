 * texts.game_1_title => 卡片1标题:text:Quick Lift
 * texts.game_1_desc => 卡片1描述:textarea:Short-form Aviator room for players who want instant entry and faster crash cycles.
 * texts.game_1_tag => 卡片1标签:text:Fast Lift
 * texts.game_1_url => 卡片1链接:text:#quick
 * images.image_1_desktop => 卡片1桌面图:textarea:|留空则不显示图片
 * images.image_1_mobile => 卡片1移动图:textarea:|留空则不显示图片
 *
 * group:game_2 => 卡片2
 * texts.game_2_badge => 卡片2徽章:text:Quick Board
 * texts.game_2_title => 卡片2标题:text:Prime Cabin
 * texts.game_2_desc => 卡片2描述:textarea:Balanced multiplier rhythm with clearer cue spacing for repeat sessions.
 * texts.game_2_tag => 卡片2标签:text:Live Multiplier
 * texts.game_2_url => 卡片2链接:text:#prime
 * images.image_2 => 卡片2图片:textarea:|留空则不显示图片
 *
 * group:game_3 => 卡片3
 * texts.game_3_badge => 卡片3徽章:text:Pilot Favorite
 * texts.game_3_title => 卡片3标题:text:Turbo Hangar
 * texts.game_3_desc => 卡片3描述:textarea:Higher-tempo room built for players who prefer quick decision windows.
 * texts.game_3_tag => 卡片3标签:text:Low Friction
 * texts.game_3_url => 卡片3链接:text:#turbo
 * images.image_3 => 卡片3图片:textarea:|留空则不显示图片
 *
 * group:game_4 => 卡片4
 * texts.game_4_badge => 卡片4徽章:text:Late Night
 * texts.game_4_title => 卡片4标题:text:Crew Table
 * texts.game_4_desc => 卡片4描述:textarea:A calmer shared room for players comparing timing before cashing out.
 * texts.game_4_tag => 卡片4标签:text:Shared Room
 * texts.game_4_url => 卡片4链接:text:#crew
 *
 * group:game_5 => 卡片5
 * texts.game_5_badge => 卡片5徽章:text:New User
 * texts.game_5_title => 卡片5标题:text:Skyline Deck
 * texts.game_5_desc => 卡片5描述:textarea:A brighter Aviator lobby with premium visual focus and direct access.
 * texts.game_5_tag => 卡片5标签:text:Premium Lane
 * texts.game_5_url => 卡片5链接:text:#skyline
 *
 * group:game_6 => 卡片6
 * texts.game_6_badge => 卡片6徽章:text:High Tempo
 * texts.game_6_title => 卡片6标题:text:Touch & Go
 * texts.game_6_desc => 卡片6描述:textarea:Low-pressure entry point for newer players learning when to exit.
 * texts.game_6_tag => 卡片6标签:text:Crash Room
 * texts.game_6_url => 卡片6链接:text:#touch
 *
 * @fields_end
 */

$componentId = 'aab-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfigAny(['display.show_description', 'display.show_subtitle'], 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';

$bgColor = (string) $getConfig('style.bg_color', '#0b1528');
$accentColor = (string) $getConfig('style.accent_color', '#ff6b2c');
$titleColor = (string) $getConfig('style.title_color', '#f5fbff');
$titleFontSize = (int) $getConfig('style.title_font_size', '74');
$titleFontSizeMobile = (int) $getConfig('style.title_font_size_mobile', '40');
$subtitleColor = (string) $getConfig('style.subtitle_color', '#b4c6dc');
$panelBgColor = (string) $getConfig('style.panel_bg_color', 'rgba(10,20,38,0.82)');
$cardBgColor = (string) $getConfig('style.card_bg_color', 'rgba(18,32,58,0.88)');
$cardBorderColor = (string) $getConfig('style.card_border_color', 'rgba(41,208,255,0.18)');
$cardRadius = max(18, (int) $getConfigAny(['style.card_border_radius', 'style.card_radius'], '26'));
$cardTitleColor = (string) $getConfig('style.card_title_color', '#f5fbff');
$cardTitleFontSize = (int) $getConfig('style.card_title_font_size', '28');
$cardDescColor = (string) $getConfig('style.card_desc_color', '#b4c6dc');
$cardDescFontSize = (int) $getConfig('style.card_desc_font_size', '15');
$sectionPadding = max(48, (int) $getConfig('style.section_padding', '88'));
$sectionPaddingMobile = max(36, (int) $getConfig('style.section_padding_mobile', '56'));
$cardGap = max(14, (int) $getConfig('style.card_gap', '24'));
$cardContentPadding = max(16, (int) $getConfig('style.card_content_padding', '22'));
$hoverTransform = max(0, (int) $getConfig('style.hover_transform', '2'));

$title = (string) $getConfig('texts.title', 'Choose Your Afterburn Flight');
$subtitle = (string) $getConfigAny(['texts.summary', 'texts.subtitle'], 'Each Aviator room keeps the same crash logic, but the pace, access style, and round rhythm can feel completely different.');

$normalizeLines = static function (string $value): array {
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$legacyGames = [];
foreach ($normalizeLines((string) $getConfig('games.items', '')) as $line) {
    $parts = array_map('trim', explode('|', $line));
    $titlePart = $parts[0] ?? '';
    if ($titlePart === '') {
        continue;
    }
    $legacyGames[] = [
        'title' => $titlePart,
        'desc' => $parts[1] ?? '',
        'url' => $parts[2] ?? '#',
    ];
}

$defaultGames = [
    ['badge' => 'Hot Flight', 'title' => 'Quick Lift', 'desc' => 'Short-form Aviator room for players who want instant entry and faster crash cycles.', 'tag' => 'Fast Lift', 'url' => '#quick'],
    ['badge' => 'Quick Board', 'title' => 'Prime Cabin', 'desc' => 'Balanced multiplier rhythm with clearer cue spacing for repeat sessions.', 'tag' => 'Live Multiplier', 'url' => '#prime'],
    ['badge' => 'Pilot Favorite', 'title' => 'Turbo Hangar', 'desc' => 'Higher-tempo room built for players who prefer quick decision windows.', 'tag' => 'Low Friction', 'url' => '#turbo'],
    ['badge' => 'Late Night', 'title' => 'Crew Table', 'desc' => 'A calmer shared room for players comparing timing before cashing out.', 'tag' => 'Shared Room', 'url' => '#crew'],
    ['badge' => 'New User', 'title' => 'Skyline Deck', 'desc' => 'A brighter Aviator lobby with premium visual focus and direct access.', 'tag' => 'Premium Lane', 'url' => '#skyline'],
    ['badge' => 'High Tempo', 'title' => 'Touch & Go', 'desc' => 'Low-pressure entry point for newer players learning when to exit.', 'tag' => 'Crash Room', 'url' => '#touch'],
];
$games = [];
for ($i = 1; $i <= 6; $i++) {
    $index = $i - 1;
    $default = $defaultGames[$index];
    $legacy = $legacyGames[$index] ?? [];
    $groupPrefix = "game_{$i}.";
    $imageDesktop = '';
    $imageMobile = '';
    if ($i === 1) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_desktop', 'images.image_1_desktop', 'games.image_1_desktop'], ''));
        $imageMobile = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_mobile', 'images.image_1_mobile', 'games.image_1_mobile'], ''));
    } elseif ($i === 2) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_2', 'images.image_2', 'games.image_2'], ''));
        $imageMobile = $imageDesktop;
    } elseif ($i === 3) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_3', 'images.image_3', 'games.image_3'], ''));
        $imageMobile = $imageDesktop;
    }
    $room = [
        'name' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_title", "texts.game_{$i}_title"], $legacy['title'] ?? $default['title'])),
        'description' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_desc", "texts.game_{$i}_desc"], $legacy['desc'] ?? $default['desc'])),
        'url' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_url", "texts.game_{$i}_url"], $legacy['url'] ?? $default['url'])),
        'badge' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_badge", "texts.game_{$i}_badge"], $default['badge'])),
        'tag' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_tag", "texts.game_{$i}_tag"], $default['tag'])),
        'code' => sprintf('FLT-%02d', $i),
        'desktop_image' => $imageDesktop,
        'mobile_image' => $imageMobile !== '' ? $imageMobile : $imageDesktop,
    ];
    if ($room['name'] === '') {
        continue;
    }
    if ($room['url'] === '') {
        $room['url'] = '#';
    }
    $games[] = $room;
}

$tags = [];
foreach ($games as $room) {
    if (!empty($room['tag']) && !in_array($room['tag'], $tags, true)) {
        $tags[] = $room['tag'];
    }
    if (count($tags) >= 4) {
        break;
    }
}

$totalFlights = count($games);
$meterLabel = '';
if (!empty($games)) {
    $meterLabel = trim((string) ($games[0]['tag'] ?? ''));
    if ($meterLabel === '') {
        $meterLabel = trim((string) ($games[0]['badge'] ?? ''));
    }
}
?>
<section id="<?= $componentId ?>" class="aab-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <div class="head-copy">
                <?php if (!empty($games[0]['badge'])): ?>
                    <span class="head-kicker"><?= htmlspecialchars($games[0]['badge']) ?></span>
                <?php endif; ?>
                <?php if ($showTitle): ?>
                    <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php endif; ?>
                <?php if ($showSubtitle && $subtitle !== ''): ?>
                    <p><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="head-side">
                <?php if ($showTags && !empty($tags)): ?>
                    <div class="head-tags" aria-label="Flight highlights">
                        <?php foreach ($tags as $tag): ?>
                            <span><?= htmlspecialchars($tag) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>

                <div class="head-controls">
                    <div class="head-meter" aria-hidden="true">
                        <?php if ($meterLabel !== ''): ?>
                            <span class="meter-label"><?= htmlspecialchars($meterLabel) ?></span>
                        <?php endif; ?>
                        <strong><?= (int) $totalFlights ?></strong>
                    </div>
                    <div class="carousel-controls" aria-label="Flight carousel controls">
                        <button type="button" class="carousel-btn" data-direction="prev" aria-label="Previous flights">
                            <span>&larr;</span>
                        </button>
                        <button type="button" class="carousel-btn" data-direction="next" aria-label="Next flights">
                            <span>&rarr;</span>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <div class="runway-wrap">
            <div class="runway-glow runway-glow-left" aria-hidden="true"></div>
            <div class="runway-glow runway-glow-right" aria-hidden="true"></div>
            <div class="runway-line runway-line-one" aria-hidden="true"></div>
            <div class="runway-line runway-line-two" aria-hidden="true"></div>

            <div class="runway-track" data-runway-track role="region" aria-label="Aviator room list" tabindex="0">
                <?php foreach ($games as $index => $game): ?>
                    <?php $summaryTone = $index % 3; ?>
                    <article class="flight-card tone-<?= (int) $summaryTone ?>">
                        <span class="flight-contrail" aria-hidden="true"></span>
                        <div class="flight-top">
                            <span class="flight-code"><?= htmlspecialchars($game['code']) ?></span>
                            <span class="flight-badge"><?= htmlspecialchars($game['badge']) ?></span>
                        </div>

                        <div class="flight-copy">
                            <span class="flight-tag"><?= htmlspecialchars($game['tag']) ?></span>
                            <?php if ($game['desktop_image'] !== ''): ?>
                                <figure class="flight-art">
                                    <picture>
                                        <?php if ($game['mobile_image'] !== ''): ?>
                                            <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile_image']) ?>">
                                        <?php endif; ?>
                                        <img src="<?= htmlspecialchars($game['desktop_image']) ?>" alt="<?= htmlspecialchars($game['name']) ?>" loading="lazy" decoding="async">
                                    </picture>
                                </figure>
                            <?php endif; ?>
                            <h3><?= htmlspecialchars($game['name']) ?></h3>
                            <?php if ($showSubtitle && $game['description'] !== ''): ?>
                                <p><?= htmlspecialchars($game['description']) ?></p>
                            <?php endif; ?>
                        </div>

                        <a class="flight-link" href="<?= htmlspecialchars($game['url']) ?>">
                            <span><?= htmlspecialchars($game['tag'] !== '' ? $game['tag'] : $game['badge']) ?></span>
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 12h13.25l-4.8-4.8L14 5.65 21.15 12 14 19.15l-1.55-1.55 4.8-4.8H4z" fill="currentColor"></path>
                            </svg>
                        </a>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

