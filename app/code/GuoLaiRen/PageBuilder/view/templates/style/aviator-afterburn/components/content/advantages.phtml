 * style.card_border_color => 卡片边框色:color:rgba(41,208,255,0.16)
 * style.card_title_color => 卡片标题颜色:color:#08111f
 * style.card_desc_color => 卡片描述颜色:color:#4d6078
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 * style.card_gap => 卡片间距:number:24|px
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Why Aviator Afterburn Changes The Pace
 * texts.advantage_1_icon => 优势1图标:text:01
 * texts.advantage_1_title => 优势1标题:text:Faster Read
 * texts.advantage_1_desc => 优势1描述:textarea:Multiplier cues, install actions, and mode links stay visible without drowning the screen in repeated blocks.
 * texts.advantage_2_icon => 优势2图标:text:02
 * texts.advantage_2_title => 优势2标题:text:Flight Deck Structure
 * texts.advantage_2_desc => 优势2描述:textarea:Each module is framed differently so players can scan the homepage like a route board instead of a generic landing stack.
 * texts.advantage_3_icon => 优势3图标:text:03
 * texts.advantage_3_title => 优势3标题:text:Responsive Lift
 * texts.advantage_3_desc => 优势3描述:textarea:The same hierarchy holds on mobile, with cards reflowing into larger touch targets instead of shrinking into noise.
 *
 * @fields_end
 */

$componentId = 'aab-advantages-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};
$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#f4f8ff');
$titleColor = $getConfig('style.title_color', '#08111f');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.9)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(41,208,255,0.16)');
$cardTitleColor = $getConfig('style.card_title_color', '#08111f');
$cardDescColor = $getConfig('style.card_desc_color', '#4d6078');
$sectionPadding = (int) $getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '48');
$cardGap = (int) $getConfig('style.card_gap', '24');

$title = $getConfig('texts.title', 'Why Aviator Afterburn Changes The Pace');
$advKicker = trim((string) $getConfigAny(['logo.subline', 'header.logo.subline', 'logo.text', 'header.logo.text'], ''));
$items = [
    [
        'icon' => $getConfig('texts.advantage_1_icon', '01'),
        'title' => $getConfig('texts.advantage_1_title', 'Faster Read'),
        'desc' => $getConfig('texts.advantage_1_desc', 'Multiplier cues, install actions, and mode links stay visible without drowning the screen in repeated blocks.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_2_icon', '02'),
        'title' => $getConfig('texts.advantage_2_title', 'Flight Deck Structure'),
        'desc' => $getConfig('texts.advantage_2_desc', 'Each module is framed differently so players can scan the homepage like a route board instead of a generic landing stack.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_3_icon', '03'),
        'title' => $getConfig('texts.advantage_3_title', 'Responsive Lift'),
        'desc' => $getConfig('texts.advantage_3_desc', 'The same hierarchy holds on mobile, with cards reflowing into larger touch targets instead of shrinking into noise.'),
    ],
];
?>

<section id="<?= $componentId ?>" class="aab-advantages" aria-labelledby="<?= $componentId ?>-title">
    <div class="adv-shell">
        <div class="adv-grid" style="--adv-gap: <?= (int) $cardGap ?>px;">
            <?php if ($showTitle): ?>
                <header class="adv-head" id="advantages">
                    <?php if ($advKicker !== ''): ?>
                        <span class="adv-kicker"><?= htmlspecialchars($advKicker) ?></span>
                    <?php endif; ?>
                    <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                </header>
            <?php endif; ?>

            <ol class="adv-lanes">
                <?php foreach ($items as $index => $item): ?>
                    <li class="adv-lane adv-lane-<?= (int) $index ?>">
                        <article class="adv-card">
                            <span class="adv-step"><?= htmlspecialchars($item['icon']) ?></span>
                            <div class="adv-card-copy">
                                <h3><?= htmlspecialchars($item['title']) ?></h3>
                                <p><?= htmlspecialchars($item['desc']) ?></p>
                            </div>
                        </article>
                    </li>
                <?php endforeach; ?>
            </ol>
        </div>
    </div>
</section>

