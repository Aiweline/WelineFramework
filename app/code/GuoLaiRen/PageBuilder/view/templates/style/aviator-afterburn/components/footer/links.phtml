    <div class="footer-base">
        <?php if ($showCopyright): ?>
            <p class="footer-copy"><?= htmlspecialchars($copyright) ?></p>
        <?php endif; ?>
        <?php if ($showDisclaimer && $disclaimerText !== ''): ?>
            <p class="footer-note"><?= nl2br(htmlspecialchars($disclaimerText)) ?></p>
        <?php endif; ?>
    </div>
</footer>
<?php if ($floatingDisplay && $floatingImage !== ''): ?>
    <a id="<?= $floatingId ?>" class="aab-floating-download" href="<?= htmlspecialchars($floatingUrl ?: '#download') ?>" aria-label="<?= htmlspecialchars($floatingText) ?>" title="<?= htmlspecialchars($floatingText) ?>">
        <span class="floating-glow" aria-hidden="true"></span>
        <img src="<?= htmlspecialchars($floatingImage) ?>" alt="<?= htmlspecialchars($floatingText) ?>" width="184" height="248" loading="lazy" decoding="async">
    </a>
    <script>
    (function () {
        var trigger = document.getElementById('<?= $floatingId ?>');
        if (!trigger) {
            return;
        }
        trigger.addEventListener('click', function (event) {
            var href = trigger.getAttribute('href') || '';
            if (href && href !== '#download') {
                return;
            }
            var target = document.getElementById('download')
                || document.querySelector('[data-download-anchor]')
                || document.querySelector('.banner-pocket')
                || document.querySelector('.download-dock')
                || document.querySelector('.hero-actions')
                || document.getElementById('tables');
            if (!target) {
                return;
            }
            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    })();
    </script>
<?php endif; ?>

