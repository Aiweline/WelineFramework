/**
 * Aviator Afterburn - Footer Component
 *
 * @component_start
 * code: footer-links
 * name: 页脚链接
 * name_en: Footer Links
 * description: 引擎尾焰风页脚，支持品牌信息与链接导航
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.background_color => 背景基础色:color:#050b13
 * style.text_color => 正文颜色:color:#edf4ff
 * style.link_color => 链接颜色:color:#edf4ff
 * style.link_hover_color => 链接悬停颜色:color:#ffffff
 * style.link_font_size => 链接字号:number:14|px
 * style.link_font_weight => 链接字重:number:700
 * style.link_gap => 链接间距:number:18|px
 *
 * group:footer => 页脚品牌
 * footer.logo.text => 品牌名称:text:Aviator Afterburn
 * footer.logo.url => 品牌图标:textarea:|留空使用默认图标
 * footer.logo.subline => 品牌副标题:text:Faster lift. Cleaner flight paths.
 *
 * group:content => 内容配置
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nFlight Modes=>#tables\r\nWhy Us=>#advantages\r\nPlayer Notes=>#reviews\r\nFAQ=>#faq\r\nSupport=>/contact|配置格式：名字=>url，一行一个。URL为空时自动补#
 * content.copyright_text => 版权信息:text:© 2026 Aviator Afterburn. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. Play responsibly and review local rules before participating in any gaming-related activity.
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * @fields_end
 */

$componentId = 'aab-footer-' . uniqid();
$floatingId = $componentId . '-floating';
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';

$backgroundColor = (string) $getConfig('style.background_color', '#050b13');
$textColor = (string) $getConfig('style.text_color', '#edf4ff');
$linkColor = (string) $getConfig('style.link_color', '#edf4ff');
$linkHoverColor = (string) $getConfig('style.link_hover_color', '#ffffff');
$linkFontSize = (int) $getConfig('style.link_font_size', '14');
$linkFontWeight = (int) $getConfig('style.link_font_weight', '700');
$linkGap = (int) $getConfig('style.link_gap', '18');

$logoText = (string) $getConfigAny(['footer.logo.text', 'footer.logo_text', 'logo.text'], 'Aviator Afterburn');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/afterburn-logo-icon.svg');
$floatingIconDefault = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/floating-download-afterburn.svg');
$logoUrl = $getConfigAny(['footer.logo.url', 'footer.logo_url', 'logo.url'], '') ?: $logoIconUrl;
$tagline = (string) $getConfigAny(['footer.logo.subline', 'footer.tagline', 'logo.subline'], 'Faster lift. Cleaner flight paths.');
$copyright = (string) $getConfigAny(['content.copyright_text', 'footer.copyright'], '© 2026 Aviator Afterburn. All rights reserved.');
$disclaimerText = (string) $getConfigAny(['content.disclaimer_text', 'footer.disclaimer_text'], '18+ Only. Play responsibly and review local rules before participating in any gaming-related activity.');
$floatingDisplay = true;
$floatingImage = trim((string) $getConfigAny(['download.image'], '')) ?: $floatingIconDefault;
$floatingText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Download'));
$floatingUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url', 'download.primary_url', 'download_btn.url', 'hero.cta_url'], '#download'));

$links = [];
$useCustomLinksRaw = (string) $getConfig('content.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('content.use_subpages', 'no'), 'no') !== 'yes';
if (!$useCustomLinks && $page) {
    $subpages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(30)
        : $page->getNavigationPages([], 30);
    foreach ($subpages as $subpage) {
        $type = trim((string) ($subpage['type'] ?? ''));
        $label = $type !== '' ? trim((string) $getConfigAny([
            'content.footer_label_' . $type,
            'content_footer_labels.content.footer_label_' . $type,
        ], '')) : '';
        $links[] = [
            'text' => $label !== '' ? $label : ($subpage['title'] ?? ''),
            'href' => $subpage['url'] ?? '#',
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny(
        ['content.footer_links', 'footer.links'],
        "Home=>/\nFlight Modes=>#tables\nWhy Us=>#advantages\nPlayer Notes=>#reviews\nFAQ=>#faq\nSupport=>/contact"
    );

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }

    foreach ($items as $item) {
        $item = trim((string) $item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            $parts = [$item, '#'];
        }
        if (!empty($parts[0])) {
            $links[] = ['text' => $parts[0], 'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#'];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

$linkColumns = [[], []];
foreach ($links as $index => $link) {
    $linkColumns[$index % 2][] = $link;
}
?>

