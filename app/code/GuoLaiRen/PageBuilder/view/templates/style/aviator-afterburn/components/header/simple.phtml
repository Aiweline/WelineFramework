<?php
/**
 * Aviator Afterburn - Simple Header Component
 *
 * @component_start
 * code: header-simple
 * name: 简洁头部
 * name_en: Simple Header
 * description: 仅展示品牌标识的简洁头部
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => 品牌标识设置
 * logo.display => 显示品牌标识:select:yes|yes,no
 * logo.url => 品牌标识地址:textarea:|默认使用主题图标
 * logo.width => 品牌标识宽度:number:120|px
 * logo.position => 品牌标识位置:select:center|left,center,right
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#08111f
 * style.padding => 内边距:number:20|px
 * @fields_end
 */
$componentId = 'aab-header-simple-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$getConfig = static function ($key, $default = '') use ($config) { return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default; };
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/afterburn-logo-icon.svg');
$logoUrl = $getConfig('logo.url', '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = max(48, (int) $getConfig('logo.width', '120'));
$logoPosition = (string) $getConfig('logo.position', 'center');
$bgColor = (string) $getConfig('style.bg_color', '#08111f');
$padding = max(0, (int) $getConfig('style.padding', '20'));
$justify = ['left' => 'flex-start', 'center' => 'center', 'right' => 'flex-end'][$logoPosition] ?? 'center';
?>
<style>
#<?= $componentId ?>{background:<?= htmlspecialchars($bgColor) ?>;padding:<?= $padding ?>px 0;width:100%;}
#<?= $componentId ?> .simple-shell{max-width:1240px;margin:0 auto;padding:0 20px;display:flex;justify-content:<?= $justify ?>;align-items:center;}
#<?= $componentId ?> img{width:<?= $logoWidth ?>px;height:auto;display:block;}
</style>
<header id="<?= $componentId ?>"><div class="simple-shell"><?php if ($logoDisplay && $logoUrl): ?><a href="/"><img src="<?= htmlspecialchars($logoUrl) ?>" alt="Logo"></a><?php endif; ?></div></header>
