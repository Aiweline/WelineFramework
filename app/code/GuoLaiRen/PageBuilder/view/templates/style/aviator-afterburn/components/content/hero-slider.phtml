 * hero.title => 主标题:text:|留空使用页面标题
 * hero.subtitle => 副标题:textarea:|留空使用页面描述
 * hero.cta_text => 主按钮文字:text:Download Flight App
 * hero.cta_url => 主按钮链接:text:#download
 * hero.secondary_cta_text => 次按钮文字:text:Browse Flight Modes
 * hero.secondary_cta_url => 次按钮链接:text:#tables
 * hero.image => 桌面端Hero图片:textarea:|默认使用本地图
 * hero.image_mobile => 移动端Hero图片:textarea:|默认使用本地图
 * hero.alt => Hero图片描述:text:Aviator Afterburn hero
 * hero.bg_color => Hero背景基础色:color:#0f1b31
 * hero.bg_image => 背景图片:textarea:|留空使用默认图
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:
 * download_btn.alt => 下载按钮描述:text:Download Flight App
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域附加类名:textarea:
 * layout.margin_top => 区域顶部偏移:number:0|px
 * layout.img_margin_top => 图片顶部偏移:number:0|px
 *
 * @fields_end
 */

$componentId = 'aab-hero-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$getExplicitConfig = static function (array $source, string $key, $default = '') {
    return array_key_exists($key, $source) && $source[$key] !== '' ? $source[$key] : $default;
};

$heroDisplayRaw = $getExplicitConfig(is_array($componentConfig) ? $componentConfig : [], 'hero.display', '');
if ($heroDisplayRaw === '') {
    $heroDisplayRaw = $getExplicitConfig(is_array($styleSettings) ? $styleSettings : [], 'hero.display', '');
}
if ($heroDisplayRaw === '') {
    $heroDisplayRaw = $getExplicitConfig(is_array($componentConfig) ? $componentConfig : [], 'banner.display', '');
}
$display = $normalizeToggle($heroDisplayRaw, 'yes') === 'yes';
if (!$display) {
    return;
}

$page = $this->getData('page');
$pageTitle = $page ? $sanitizeTitle((string) ($page->getData('meta_title') ?: $page->getData('title') ?: '')) : '';
$title = $sanitizeTitle((string) $getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'Launch Faster With Aviator Afterburn';
}
$subtitle = trim((string) $getConfig('hero.subtitle', $page ? (string) ($page->getData('meta_description') ?: '') : ''));
if ($subtitle === '') {
    $subtitle = 'Aviator multipliers, live round cues, and download actions framed like a flight deck instead of a recycled casino shell.';
}
$ctaDisplay = $normalizeToggle($getConfig('download_btn.display', 'yes')) === 'yes';
$ctaText = $getConfigAny(['hero.cta_text', 'download_btn.alt'], 'Download Flight App');
$ctaUrl = $getConfigAny(['hero.cta_url', 'download_btn.url'], '#download');
$ctaSecondaryText = $getConfig('hero.secondary_cta_text', 'Browse Flight Modes');
$ctaSecondaryUrl = $getConfig('hero.secondary_cta_url', '#tables');
$heroImage = trim((string) $getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$heroImage = $heroImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/hero-afterburn-console.svg');
$heroImageMobile = trim((string) $getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$heroImageMobile = $heroImageMobile !== '' ? $heroImageMobile : $heroImage;
$bgImage = trim((string) $getConfig('hero.bg_image', ''));
$bgImage = $bgImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/poker-header-bg.svg');
$heroAlt = trim((string) $getConfigAny(['hero.alt', 'banner.alt'], $title));
$heroBgColor = (string) $getConfig('hero.bg_color', $getConfig('banner.bg_color', '#0f1b31'));
$sliderClasses = trim((string) $getConfig('layout.slider_classes', ''));
$marginTop = (int) $getConfig('layout.margin_top', '0');
$imgMarginTop = (int) $getConfig('layout.img_margin_top', '0');
$heroKicker = trim((string) $getConfigAny(['logo.text', 'header.logo.text'], 'Aviator Afterburn'));
if ($heroKicker === '') {
    $heroKicker = 'Aviator Afterburn';
}
