<?php
/**
 * Aviator Afterburn - Dark Header Component
 *
 * @component_start
 * code: header-dark
 * name: 深色头部
 * name_en: Dark Header
 * description: 深色品牌头部，支持导航和下载按钮
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => 品牌标识设置
 * logo.display => 显示品牌标识:select:yes|yes,no
 * logo.url => 品牌标识地址:textarea:|默认使用主题图标
 * logo.width => 品牌标识宽度:text:160px
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.use_custom_links => 使用自定义导航:select:yes|yes,no
 * navigation.items => 导航项配置:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQ=>/faq|配置格式：名字=>url，一行一个
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:Download Flight App
 * download_button.url => 按钮链接:text:#download
 * group:style => 样式设置
 * style.background => 背景颜色:color:#08111f
 * style.nav_color => 导航文字颜色:color:#f4f8ff
 * style.accent_color => 强调颜色:color:#29d0ff
 * style.height => 头部高度:text:70px
 * @fields_end
 */
$componentId = 'aab-header-dark-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$getConfig = static function ($key, $default = '') use ($config) { return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default; };
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
$logoUrl = $getConfig('logo.url', '') ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/aviator-afterburn/asset/img/afterburn-logo-icon.svg');
$logoWidth = (string) $getConfig('logo.width', '160px');
$navDisplay = $getConfig('navigation.display', 'yes') !== 'no';
$useCustomLinks = $getConfig('navigation.use_custom_links', 'yes') === 'yes';
$navItems = [];
if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    foreach ($page->getHeaderNavigationPages(8) as $navPage) {
        $navItems[] = ['text' => $navPage['title'] ?? '', 'href' => $navPage['url'] ?? '#'];
    }
}
if (empty($navItems)) {
    $navItemsRaw = (string) $getConfig('navigation.items', "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQ=>/faq");
    if (strpos($navItemsRaw, '\\n') !== false && strpos($navItemsRaw, "\n") === false) {
        $navItemsRaw = str_replace('\\n', "\n", $navItemsRaw);
    }
    foreach (preg_split('/\r?\n/', $navItemsRaw) as $line) {
        $line = trim((string) $line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}
$buttonDisplay = $getConfig('download_button.display', 'yes') !== 'no';
$buttonText = (string) $getConfig('download_button.text', 'Download Flight App');
$buttonUrl = (string) $getConfig('download_button.url', '#download');
$bgColor = (string) $getConfig('style.background', '#08111f');
$navColor = (string) $getConfig('style.nav_color', '#f4f8ff');
$accentColor = (string) $getConfig('style.accent_color', '#29d0ff');
$headerHeight = (string) $getConfig('style.height', '70px');
?>
<style>
#<?= $componentId ?>{background:<?= htmlspecialchars($bgColor) ?>;min-height:<?= htmlspecialchars($headerHeight) ?>;position:sticky;top:0;z-index:80;}
#<?= $componentId ?> .dark-shell{max-width:1240px;margin:0 auto;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;}
#<?= $componentId ?> .dark-nav{display:flex;gap:16px;flex-wrap:wrap;}
#<?= $componentId ?> a{color:<?= htmlspecialchars($navColor) ?>;text-decoration:none;}
#<?= $componentId ?> .dark-btn{padding:10px 16px;border-radius:999px;background:<?= htmlspecialchars($accentColor) ?>;color:#08111f;display:inline-flex;align-items:center;font-weight:700;}
</style>
<header id="<?= $componentId ?>"><div class="dark-shell"><?php if ($logoDisplay): ?><a href="/"><img src="<?= htmlspecialchars($logoUrl) ?>" alt="Logo" style="width:<?= htmlspecialchars($logoWidth) ?>"></a><?php endif; ?><?php if ($navDisplay && !empty($navItems)): ?><nav class="dark-nav"><?php foreach ($navItems as $item): ?><a href="<?= htmlspecialchars($item['href']) ?>"><?= htmlspecialchars($item['text']) ?></a><?php endforeach; ?></nav><?php endif; ?><?php if ($buttonDisplay): ?><a class="dark-btn" href="<?= htmlspecialchars($buttonUrl) ?>"><?= htmlspecialchars($buttonText) ?></a><?php endif; ?></div></header>
