<?php
/**
 * Aviator Afterburn - Simple Footer Component
 *
 * @component_start
 * code: footer-simple
 * name: 简洁底部
 * name_en: Simple Footer
 * description: 仅展示版权信息的简洁底部
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 * group:content => 内容配置
 * content.copyright_text => 版权信息:text:© 2026 Aviator Afterburn All rights reserved
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#060c15
 * style.text_color => 文字颜色:color:#98abc4
 * style.padding => 内边距:number:20|px
 * style.text_align => 对齐方式:select:center|left,center,right
 * @fields_end
 */
$componentId = 'aab-footer-simple-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$getConfig = static function ($key, $default = '') use ($config) { return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default; };
$copyrightText = (string) $getConfig('content.copyright_text', '© 2026 Aviator Afterburn All rights reserved');
$bgColor = (string) $getConfig('style.bg_color', '#060c15');
$textColor = (string) $getConfig('style.text_color', '#98abc4');
$padding = max(0, (int) $getConfig('style.padding', '20'));
$textAlign = (string) $getConfig('style.text_align', 'center');
?>
<style>
#<?= $componentId ?>{background:<?= htmlspecialchars($bgColor) ?>;padding:<?= $padding ?>px 0;width:100%;}
#<?= $componentId ?> .simple-shell{max-width:1200px;margin:0 auto;padding:0 20px;text-align:<?= htmlspecialchars($textAlign) ?>;color:<?= htmlspecialchars($textColor) ?>;font-size:12px;}
</style>
<footer id="<?= $componentId ?>"><div class="simple-shell"><p><?= htmlspecialchars($copyrightText) ?></p></div></footer>
