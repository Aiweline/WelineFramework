<?php
/**
 * Aviator Afterburn - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: Aviator 联系方式和表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Contact Aviator Afterburn
 * hero.subtitle => 页面副标题:textarea:Need help with access, room selection, or account support? Use the contact routes below to reach the right desk.
 * hero.bg_color => 背景色:color:#08111f
 * hero.bg_gradient_end => 渐变结束色:color:#132746
 * hero.title_color => 标题颜色:color:#f5fbff
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@aviatorafterburn.com
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间:text:24/7 Player Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:
 * social.twitter => Twitter链接:text:
 * social.linkedin => LinkedIn链接:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Request
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share your UID, device, and issue details so the support team can route the request faster.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Map
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$componentId = 'aab-contact-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$title = trim((string) $getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'Contact Aviator Afterburn';
}
$description = trim((string) $getConfig('hero.subtitle', 'Need help with access, room selection, or account support? Use the contact routes below to reach the right desk.'));

$addressLabel = trim((string) $getConfig('contact_info.address_label', 'Address'));
$phoneLabel = trim((string) $getConfig('contact_info.phone_label', 'Phone'));
$emailLabel = trim((string) $getConfig('contact_info.email_label', 'Email'));
$hoursLabel = trim((string) $getConfig('contact_info.work_hours_label', 'Support Hours'));
$email = trim((string) $getConfig('contact_info.email', 'support@aviatorafterburn.com'));
$phone = trim((string) $getConfig('contact_info.phone', '+91 1800-XXX-XXXX'));
$address = trim((string) $getConfig('contact_info.address', 'Mumbai, India'));
$hours = trim((string) $getConfig('contact_info.work_hours', '24/7 Player Support'));

$formTitle = trim((string) $getConfig('form.title', 'Send A Support Request'));
$formNameLabel = trim((string) $getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string) $getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string) $getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string) $getConfig('form.message_label', 'Message'));
$formSubmitText = trim((string) $getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string) $getConfig('form.success_message', 'Share your UID, device, and issue details so the support team can route the request faster.'));
$mapTitle = trim((string) $getConfig('map.title', 'Map'));
$mapEmbedUrl = trim((string) $getConfig('map.embed_url', ''));
$mapHeight = max(240, (int) $getConfig('map.height', 360));

$contactCards = [];
if ($email !== '') {
    $contactCards[] = ['label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email, 'icon' => 'EM', 'href' => 'mailto:' . $email];
}
if ($phone !== '') {
    $contactCards[] = ['label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone, 'icon' => 'PH', 'href' => 'tel:' . preg_replace('/[^0-9+]/', '', $phone)];
}
if ($address !== '') {
    $contactCards[] = ['label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address, 'icon' => 'AD', 'href' => ''];
}
if ($hours !== '') {
    $contactCards[] = ['label' => $hoursLabel !== '' ? $hoursLabel : 'Support Hours', 'value' => $hours, 'icon' => '24', 'href' => ''];
}

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string) $getConfig($key, ''));
    if ($url !== '') {
        $socials[] = ['name' => $label, 'url' => $url];
    }
}
$hasBoard = ($showInfo && !empty($contactCards)) || ($showSocial && !empty($socials));

$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#08111f');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#132746');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#f5fbff');
?>

<section
    id="<?= $componentId ?>"
    class="aab-contact"
    style="--aab-contact-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --aab-contact-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --aab-contact-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="contact-shell">
        <header class="contact-hero">
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <?php if ($showInfo && !empty($contactCards)): ?>
            <section class="route-grid" aria-label="Contact information">
                <?php foreach ($contactCards as $index => $card): ?>
                    <?php if ($card['href'] !== ''): ?>
                        <a class="route-card route-card-<?= (int) ($index + 1) ?>" href="<?= htmlspecialchars($card['href']) ?>">
                            <span class="route-icon"><?= htmlspecialchars($card['icon']) ?></span>
                            <span class="route-label"><?= htmlspecialchars($card['label']) ?></span>
                            <strong><?= htmlspecialchars($card['value']) ?></strong>
                        </a>
                    <?php else: ?>
                        <article class="route-card route-card-<?= (int) ($index + 1) ?>">
                            <span class="route-icon"><?= htmlspecialchars($card['icon']) ?></span>
                            <span class="route-label"><?= htmlspecialchars($card['label']) ?></span>
                            <strong><?= htmlspecialchars($card['value']) ?></strong>
                        </article>
                    <?php endif; ?>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <div class="contact-stage<?= (!$showForm || !$hasBoard) ? ' is-simple' : '' ?>">
            <?php if ($hasBoard): ?>
                <aside class="support-board">
                    <?php if ($showInfo && !empty($contactCards)): ?>
                        <section class="board-card">
                            <div class="board-list">
                                <?php foreach ($contactCards as $card): ?>
                                    <div class="board-item">
                                        <span><?= htmlspecialchars($card['label']) ?></span>
                                        <strong><?= htmlspecialchars($card['value']) ?></strong>
                                    </div>
                                <?php endforeach; ?>
                            </div>
                        </section>
                    <?php endif; ?>

                    <?php if ($showSocial && !empty($socials)): ?>
                        <section class="board-card">
                            <div class="social-grid">
                                <?php foreach ($socials as $social): ?>
                                    <a href="<?= htmlspecialchars($social['url']) ?>" class="social-link" target="_blank" rel="noopener">
                                        <span><?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?></span>
                                        <small><?= htmlspecialchars($social['name']) ?></small>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <section class="message-bay" aria-labelledby="<?= $componentId ?>-form-title">
                    <header class="message-head">
                        <?php if ($formTitle !== ''): ?>
                            <h2 id="<?= $componentId ?>-form-title"><?= htmlspecialchars($formTitle) ?></h2>
                        <?php endif; ?>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </header>

                    <form class="contact-form">
                        <div class="field-row">
                            <label class="field">
                                <span><?= htmlspecialchars($formNameLabel) ?></span>
                                <input type="text" placeholder="<?= htmlspecialchars((string) __('Enter your name')) ?>">
                            </label>
                            <label class="field">
                                <span><?= htmlspecialchars($formEmailLabel) ?></span>
                                <input type="email" placeholder="<?= htmlspecialchars((string) __('Enter your email')) ?>">
                            </label>
                        </div>

                        <label class="field">
                            <span><?= htmlspecialchars($formSubjectLabel) ?></span>
                            <input type="text" placeholder="<?= htmlspecialchars((string) __('What is this about?')) ?>">
                        </label>

                        <label class="field">
                            <span><?= htmlspecialchars($formMessageLabel) ?></span>
                            <textarea placeholder="<?= htmlspecialchars((string) __('Tell us how we can help...')) ?>"></textarea>
                        </label>

                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </section>
            <?php endif; ?>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="map-stage" aria-label="<?= htmlspecialchars($mapTitle !== '' ? $mapTitle : 'Map') ?>">
                <div class="map-head">
                    <?php if ($mapTitle !== ''): ?>
                        <span class="board-kicker"><?= htmlspecialchars($mapTitle) ?></span>
                    <?php endif; ?>
                </div>
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int) $mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

