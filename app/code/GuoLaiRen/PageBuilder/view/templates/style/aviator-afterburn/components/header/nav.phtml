    }
}
</style>

<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    const toggle = root.querySelector('.nav-toggle');
    const panel = root.querySelector('.mobile-panel');
    const backdrop = root.querySelector('.mobile-backdrop');
    const links = root.querySelectorAll('[data-nav-link]');
    let closeTimer = null;

    const setCurrentLink = () => {
        const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
        links.forEach((link) => {
            const href = link.getAttribute('data-nav-href') || link.getAttribute('href') || '';
            const linkPath = href.startsWith('#') ? href : (href.replace(window.location.origin, '').replace(/\/$/, '') || '/');
            const isCurrent = href.startsWith('#') ? window.location.hash === href : linkPath === currentPath;
            link.classList.toggle('is-current', isCurrent);
        });
    };

    const syncPanelPosition = () => {
        if (!panel) {
            return;
        }
        const rect = root.getBoundingClientRect();
        panel.style.top = `${Math.max(72, Math.round(rect.bottom + 10))}px`;
    };

    const finishHide = () => {
        if (panel) {
            panel.classList.add('is-hidden');
        }
        if (backdrop) {
            backdrop.classList.add('is-hidden');
        }
    };

    const closeMenu = (immediate = false) => {
        if (!toggle || !panel) {
            return;
        }
        root.classList.remove('is-open');
        root.setAttribute('data-mobile-open', 'false');
        toggle.setAttribute('aria-expanded', 'false');

        if (closeTimer) {
            window.clearTimeout(closeTimer);
        }

        if (immediate) {
            finishHide();
            return;
        }

        closeTimer = window.setTimeout(() => {
            finishHide();
        }, 280);
    };

    const openMenu = () => {
        if (!toggle || !panel) {
            return;
        }
        if (closeTimer) {
            window.clearTimeout(closeTimer);
        }
        syncPanelPosition();
        panel.classList.remove('is-hidden');
        if (backdrop) {
            backdrop.classList.remove('is-hidden');
        }
        requestAnimationFrame(() => {
            root.classList.add('is-open');
            root.setAttribute('data-mobile-open', 'true');
            toggle.setAttribute('aria-expanded', 'true');
        });
    };

    if (toggle && panel) {
        toggle.addEventListener('click', () => {
            if (root.classList.contains('is-open')) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        if (backdrop) {
            backdrop.addEventListener('click', () => closeMenu());
        }

        panel.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => closeMenu());
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && root.classList.contains('is-open')) {
                closeMenu();
            }
        });

        document.addEventListener('click', (event) => {
            if (!root.classList.contains('is-open')) {
                return;
            }
            const target = event.target;
            if (target instanceof Node && !root.contains(target)) {
                closeMenu();
            }
        });

        window.addEventListener('resize', () => {
            syncPanelPosition();
            if (window.innerWidth > 1024) {
                closeMenu(true);
            }
        });

        window.addEventListener('scroll', () => {
            if (root.classList.contains('is-open')) {
                syncPanelPosition();
            }
        }, { passive: true });
    }

    const syncScrolled = () => {
        root.classList.toggle('is-scrolled', window.scrollY > 12);
    };

    setCurrentLink();
    syncScrolled();
    window.addEventListener('hashchange', setCurrentLink);
    window.addEventListener('scroll', syncScrolled, { passive: true });
})();
</script>
