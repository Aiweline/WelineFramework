$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '56/56') . 'px'));
$logoHeight = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.height', 'header.logo.height'], '56/56') . 'px'));

$navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nFlight Modes=>#tables\nWhy Us=>#advantages\nPlayer Notes=>#reviews\nFAQ=>#faq");
$useCustomLinksRaw = $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], '');
$legacyUseSubpagesRaw = $getConfig('navigation.use_subpages', '');
if ($useCustomLinksRaw !== '') {
    $useCustomLinks = $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes';
} elseif ($legacyUseSubpagesRaw !== '') {
    $useCustomLinks = $normalizeToggle($legacyUseSubpagesRaw, 'no') !== 'yes';
} else {
    $useCustomLinks = true;
}
$ctaDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Download Flight App'));
$ctaUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download'));
$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], 'rgba(8,17,31,0.94)');
$navBgColorScrolled = (string) $getConfig('navigation.bg_color_scrolled', 'rgba(8,17,31,0.98)');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#edf4ff');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#edf4ff');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#29d0ff');
$navLinkFontSize = (int) $getConfig('navigation.link_font_size', '14');
$navLinkFontWeight = (int) $getConfig('navigation.link_font_weight', '700');
$navLinkGap = (int) $getConfig('navigation.link_gap', '18');
$navPaddingX = (int) $getConfig('navigation.padding_x', '16');
$navPaddingY = (int) $getConfig('navigation.padding_y', '13');
$navMinHeight = (int) $getConfig('navigation.min_height', '78');
$navBoxShadow = (string) $getConfig('navigation.box_shadow', '0 22px 44px rgba(8,17,31,0.16)');
$navBackdropBlur = (int) $getConfig('navigation.backdrop_blur', '18');
$ctaBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff6b2c');
$ctaBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.bg_hover_color'], '#29d0ff');
$ctaTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#08111f');
$ctaFontSize = (int) $getConfig('download_button.font_size', '14');
$ctaFontWeight = (int) $getConfig('download_button.font_weight', '800');
$ctaRadius = (int) $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '999');
$ctaPaddingX = (int) $getConfig('download_button.padding_x', '18');
$ctaPaddingY = (int) $getConfig('download_button.padding_y', '10');
$navItems = [];

$pageTitleRaw = $page ? ($page->getData('title') ?: '') : '';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'Aviator Afterburn';
}

if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $type = trim((string) ($navPage['type'] ?? ''));
        $label = $type !== '' ? trim((string) $getConfig('navigation.label_' . $type, '')) : '';
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim($line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

$leftCount = count($navItems) > 1 ? (int) ceil(count($navItems) / 2) : count($navItems);
$leftNavItems = array_slice($navItems, 0, $leftCount);
$rightNavItems = array_slice($navItems, $leftCount);
if (empty($rightNavItems) && count($leftNavItems) > 1) {
    $rightNavItems[] = array_pop($leftNavItems);
}
?>
