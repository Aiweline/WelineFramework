 * story.bg_color => 背景色:color:#08111f
 * story.title_color => 标题颜色:color:#f5fbff
 *
 * group:values => 价值观区块
 * values.title => 标题:text:What This Theme Keeps Clear
 * values.subtitle => 副标题:text:Three editable pillars help new Aviator sites stay readable, relevant, and responsive.
 * values.value_1_icon => 价值1图标:text:AT
 * values.value_1_title => 价值1标题:text:Action Priority
 * values.value_1_desc => 价值1描述:textarea:Download links, room choices, and support routes stay easy to spot before the page gets visually dense.
 * values.value_2_icon => 价值2图标:text:MR
 * values.value_2_title => 价值2标题:text:Mobile Readability
 * values.value_2_desc => 价值2描述:textarea:Layouts collapse with intention, so cards remain touch-friendly and the next action stays visible.
 * values.value_3_icon => 价值3图标:text:RC
 * values.value_3_title => 价值3标题:text:Room Contrast
 * values.value_3_desc => 价值3描述:textarea:Different module backgrounds create stronger separation, helping players scan the page faster.
 * values.bg_color => 背景色:color:#0d182c
 *
 * group:team => 团队区块
 * team.title => 标题:text:Teams Behind The Flow
 * team.subtitle => 副标题:text:Small, editable role cards for the desks players rely on most.
 * team.member_1_icon => 成员1头像:text:SD
 * team.member_1_name => 成员1姓名:text:Support Desk
 * team.member_1_role => 成员1职位:text:Login and room-access help
 * team.member_2_icon => 成员2头像:text:TR
 * team.member_2_name => 成员2姓名:text:Trust Review
 * team.member_2_role => 成员2职位:text:Policy and fair-play checks
 * team.member_3_icon => 成员3头像:text:PD
 * team.member_3_name => 成员3姓名:text:Product Desk
 * team.member_3_role => 成员3职位:text:Flight-layout updates
 * team.member_4_icon => 成员4头像:text:CO
 * team.member_4_name => 成员4姓名:text:Content Ops
 * team.member_4_role => 成员4职位:text:Guide and landing updates
 *
 * group:cta => 底部CTA
 * cta.title => CTA标题:text:Need a custom landing route?
 * cta.description => CTA描述:textarea:Use the editable hero, story, values, team, and CTA fields to adapt this page for each new Aviator build.
 * cta.button_text => 按钮文字:text:Contact Support
 * cta.button_url => 按钮链接:text:/contact
 * cta.button_bg => 按钮背景:color:linear-gradient(120deg, #ff6b2c 0%, #29d0ff 100%)
 * cta.button_text_color => 按钮文字颜色:color:#08111f
 *
 * @fields_end
 */

$componentId = 'aab-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'yes') !== 'no';
$showCta = $getConfig('display.show_cta', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$heroTitle = trim((string) $getConfig('hero.title', $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'About Aviator Afterburn';
}
$heroSubtitle = trim((string) $getConfig('hero.subtitle', 'Aviator Afterburn is built for clearer room reading, sharper contrast between sections, and a smoother mobile path from landing to flight selection.'));
$heroPadding = max(56, (int) $getConfig('hero.padding', 88));

$stats = [];
$defaultStats = [
    ['24/7', 'Support routing'],
    ['1-Tap', 'Flight entry path'],
    ['3-Layer', 'Signal-first layout'],
    ['Mobile', 'Responsive flight flow'],
];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $defaultStats[$i - 1][0]));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $defaultStats[$i - 1][1]));
    if ($number === '' || $label === '') {
        continue;
    }
    $stats[] = ['number' => $number, 'label' => $label];
}

$storyTitle = trim((string) $getConfig('story.title', 'Why This Theme Exists'));
$storySubtitle = trim((string) $getConfig('story.subtitle', 'Built for Aviator pages that need more lift than a simple recolor.'));
$storyContent = trim((string) $getConfig('story.content', $pageContent !== '' ? $pageContent : 'Aviator Afterburn keeps the existing PHP-driven configuration approach while changing how information is staged. Room choices, trust signals, and download actions are spaced like a flight system instead of a generic casino stack.'));
$storyParagraphs = array_values(array_filter(array_map('trim', preg_split('/\r\n|\r|\n/', $storyContent) ?: []), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs) && $storyContent !== '') {
    $storyParagraphs[] = $storyContent;
}

$valuesTitle = trim((string) $getConfig('values.title', 'What This Theme Keeps Clear'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'Three editable pillars help new Aviator sites stay readable, relevant, and responsive.'));
$defaultValues = [
    ['AT', 'Action Priority', 'Download links, room choices, and support routes stay easy to spot before the page gets visually dense.'],
    ['MR', 'Mobile Readability', 'Layouts collapse with intention, so cards remain touch-friendly and the next action stays visible.'],
    ['RC', 'Room Contrast', 'Different module backgrounds create stronger separation, helping players scan the page faster.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $titleValue = trim((string) $getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $descValue = trim((string) $getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($titleValue === '' || $descValue === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string) $getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
        'title' => $titleValue,
        'desc' => $descValue,
    ];
}

$teamTitle = trim((string) $getConfig('team.title', 'Teams Behind The Flow'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', 'Small, editable role cards for the desks players rely on most.'));
$defaultMembers = [
    ['SD', 'Support Desk', 'Login and room-access help'],
    ['TR', 'Trust Review', 'Policy and fair-play checks'],
    ['PD', 'Product Desk', 'Flight-layout updates'],
    ['CO', 'Content Ops', 'Guide and landing updates'],
];
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $name = trim((string) $getConfig("team.member_{$i}_name", $defaultMembers[$i - 1][1]));
    $role = trim((string) $getConfig("team.member_{$i}_role", $defaultMembers[$i - 1][2]));
    if ($name === '' || $role === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => trim((string) $getConfig("team.member_{$i}_icon", $defaultMembers[$i - 1][0])),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string) $getConfig('cta.title', 'Need a custom landing route?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Use the editable hero, story, values, team, and CTA fields to adapt this page for each new Aviator build.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact'));

$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#08111f');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#132746');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#f5fbff');
$heroTextColor = (string) $getConfig('hero.text_color', $colors['text_secondary'] ?? '#b9cfe4');
$storyBg = (string) $getConfig('story.bg_color', $colors['section_bg_1'] ?? '#08111f');
$storyTitleColor = (string) $getConfig('story.title_color', '#f5fbff');
$valuesBg = (string) $getConfig('values.bg_color', $colors['section_bg_2'] ?? '#0d182c');
$statsCardBg = (string) $getConfig('stats.card_bg', $colors['card_bg'] ?? 'rgba(10,21,37,0.78)');
$statsNumberColor = (string) $getConfig('stats.number_color', $colors['accent_primary'] ?? '#ff6b2c');
$statsLabelColor = (string) $getConfig('stats.label_color', $colors['text_muted'] ?? '#6d8098');
$ctaButtonBg = (string) $getConfig('cta.button_bg', $colors['button_primary_bg'] ?? 'linear-gradient(120deg, #ff6b2c 0%, #29d0ff 100%)');
$ctaButtonTextColor = (string) $getConfig('cta.button_text_color', $colors['button_primary_text'] ?? '#fff');
?>

<section
    id="<?= $componentId ?>"
    class="aab-about"
    style="--aab-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --aab-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --aab-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --aab-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --aab-about-stats-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --aab-about-stat-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-stat-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --aab-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --aab-about-hero-padding: <?= (int) $heroPadding ?>px;"
>
    <div class="about-shell">
        <header class="about-hero">
            <div class="hero-copy">
                <span class="hero-kicker">Aviator Brief</span>
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <?php if ($heroSubtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($heroSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <?php if ($showStats && !empty($stats)): ?>
                <div class="hero-stats" aria-label="Theme statistics">
                    <?php foreach ($stats as $index => $stat): ?>
                        <article class="stat-ticket stat-ticket-<?= (int) ($index + 1) ?>">
                            <strong><?= htmlspecialchars($stat['number']) ?></strong>
                            <span><?= htmlspecialchars($stat['label']) ?></span>
                        </article>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="story-stage">
            <article class="story-frame">
                <div class="story-head">
                    <span class="section-kicker">Story Route</span>
                    <?php if ($storyTitle !== ''): ?>
                        <h2><?= htmlspecialchars($storyTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($storySubtitle !== ''): ?>
                        <p class="story-subtitle"><?= htmlspecialchars($storySubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="story-body">
                    <span class="story-line" aria-hidden="true"></span>
                    <div class="story-copy">
                        <?php foreach ($storyParagraphs as $paragraph): ?>
                            <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                        <?php endforeach; ?>
                    </div>
                </div>
            </article>

            <?php if ($showValues && !empty($values)): ?>
                <aside class="values-radar" aria-labelledby="<?= $componentId ?>-values-title">
                    <div class="values-head">
                        <span class="section-kicker">Signal Pillars</span>
                        <?php if ($valuesTitle !== ''): ?>
                            <h2 id="<?= $componentId ?>-values-title"><?= htmlspecialchars($valuesTitle) ?></h2>
                        <?php endif; ?>
                        <?php if ($valuesSubtitle !== ''): ?>
                            <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                        <?php endif; ?>
                    </div>

                    <div class="values-stack">
                        <?php foreach ($values as $index => $value): ?>
                            <article class="value-node value-node-<?= (int) ($index + 1) ?>">
                                <span class="value-icon"><?= htmlspecialchars($value['icon']) ?></span>
                                <div class="value-copy">
                                    <h3><?= htmlspecialchars($value['title']) ?></h3>
                                    <p><?= htmlspecialchars($value['desc']) ?></p>
                                </div>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </aside>
            <?php endif; ?>
        </div>

        <?php if ($showTeam && !empty($teamMembers)): ?>
            <section class="team-hangar" aria-labelledby="<?= $componentId ?>-team-title">
                <header class="team-head">
                    <span class="section-kicker">Ops Desks</span>
                    <?php if ($teamTitle !== ''): ?>
                        <h2 id="<?= $componentId ?>-team-title"><?= htmlspecialchars($teamTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle) ?></p>
                    <?php endif; ?>
                </header>

                <div class="team-grid">
                    <?php foreach ($teamMembers as $index => $member): ?>
                        <article class="team-card">
                            <span class="team-icon"><?= htmlspecialchars($member['icon']) ?></span>
                            <strong><?= htmlspecialchars($member['name']) ?></strong>
                            <span><?= htmlspecialchars($member['role']) ?></span>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && $ctaTitle !== ''): ?>
            <section class="about-cta" aria-labelledby="<?= $componentId ?>-cta-title">
                <div class="cta-copy">
                    <span class="section-kicker">Next Route</span>
                    <h2 id="<?= $componentId ?>-cta-title"><?= htmlspecialchars($ctaTitle) ?></h2>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription) ?></p>
                    <?php endif; ?>
                </div>

                <?php if ($ctaButtonText !== ''): ?>
                    <a href="<?= htmlspecialchars($ctaButtonUrl !== '' ? $ctaButtonUrl : '/contact') ?>" class="cta-link"><?= htmlspecialchars($ctaButtonText) ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>

