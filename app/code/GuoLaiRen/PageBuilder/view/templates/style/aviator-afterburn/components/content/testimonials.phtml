$buildInitials = static function (string $name): string {
    $parts = preg_split('/\s+/', trim($name)) ?: [];
    $letters = [];
    foreach ($parts as $part) {
        if ($part === '') {
            continue;
        }
        $letters[] = mb_strtoupper(mb_substr($part, 0, 1));
        if (count($letters) === 2) {
            break;
        }
    }
    return $letters ? implode('', $letters) : 'AP';
};

$parseRatingScore = static function (string $rating): float {
    $filled = mb_substr_count($rating, '⭐');
    if ($filled <= 0) {
        return 5.0;
    }
    $empty = mb_substr_count($rating, '☆');
    return max(0, min(5, $filled - ($empty > 0 ? 0.2 : 0)));
};

