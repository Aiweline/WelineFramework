<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var track = root.querySelector('[data-voices-track]');
    if (!track) {
        return;
    }

    var step = function(direction) {
        var card = track.querySelector('.voice-card');
        if (!card) {
            return;
        }
        var styles = window.getComputedStyle(track);
        var gap = parseFloat(styles.columnGap || styles.gap || 16) || 16;
        track.scrollBy({
            left: (card.getBoundingClientRect().width + gap) * direction,
            behavior: 'smooth'
        });
    };

    root.querySelectorAll('.voices-arrow').forEach(function(button) {
        button.addEventListener('click', function() {
            step(button.getAttribute('data-direction') === 'prev' ? -1 : 1);
        });
    });
})();
</script>
