$sanitizeTitle = function($value) {
    $value = trim((string)$value);
    if ($value === '') return $value;
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$metaTitleRaw = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Aviator Afterburn';
$metaTitle = $sanitizeTitle($metaTitleRaw);
if ($metaTitle === '') {
    $metaTitle = 'Aviator Afterburn';
}
$metaDescription = $page ? $page->getData('meta_description') : '';
$metaKeywords = $page ? $page->getData('meta_keywords') : '';
