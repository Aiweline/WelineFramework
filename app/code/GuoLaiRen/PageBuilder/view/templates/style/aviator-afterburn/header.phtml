 * header.download_button.text => 下载按钮文本:text:Download Flight App
 * header.download_button.bg_color => 按钮背景颜色:color:#ff6b2c
 * header.download_button.hover_bg_color => 按钮悬停背景色:color:#ff7f45
 * header.download_button.text_color => 按钮文字颜色:color:#08111f
 * header.download_button.size => 按钮字体大小:responsive:14/14|px[保持当前主题视觉]
 * header.download_button.padding => 按钮内边距:responsive:10/10|px[保持当前主题视觉]
 * header.download_button.border_radius => 按钮圆角:number:999|px
 * header.download_button.extra_classes => 按钮额外样式类:textarea:
 * header.download_button.url => 下载链接:text:#download
 *
 * group:banner => 横幅兼容字段（已独立为首屏轮播组件）
 * banner.display => 显示横幅区域:select:no|yes,no
 * banner.image_mobile => 移动端横幅图片:textarea:
 * banner.image_desktop => 桌面端横幅图片:textarea:
 * banner.alt => 横幅图片替代文本:text:Aviator Afterburn hero banner
 * banner.download_btn_image => 横幅下载按钮图片:textarea:
 * banner.download_btn_alt => 横幅下载按钮替代文本:text:Download Flight App
 * banner.bg_color => 横幅背景颜色:color:#08111f
 * banner.padding_v => 横幅上下内边距:responsive:0/0|px[保持当前主题视觉]
 * banner.slider_classes => 横幅轮播区域样式类:textarea:
 *
 * group:color_scheme => 全局色系设置
 * color_scheme.scheme => 选择色系:select:default|default,blue,purple,green,red
 *
 * group:pixel => 像素统计
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

$templateCode = $page ? $page->getData('style') : 'aviator-afterburn';
if (empty($templateCode)) {
    $templateCode = 'aviator-afterburn';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__pagebuilder_shell_managed', true);
$this->assign('__aab_shell_managed', true);
