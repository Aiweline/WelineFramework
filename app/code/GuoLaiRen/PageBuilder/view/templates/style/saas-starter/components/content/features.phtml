<?php
/**
 * SaaS Starter - Features Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Features
 * content.title => 标题:text:Everything you need to scale
 * content.description => 描述:textarea:Powerful tools designed to help your team work smarter, ship faster, and grow without limits.
 * group:features => 特性列表
 * features.items => 特性列表:textarea:Workflow Automation|Build custom workflows with drag-and-drop simplicity. Automate repetitive tasks and focus on what matters.|⚡\r\nReal-time Analytics|Track key metrics with live dashboards. Make data-driven decisions with actionable insights.|📊\r\nTeam Collaboration|Share, comment, and iterate together. Keep everyone aligned with built-in communication tools.|👥\r\nEnterprise Security|SOC 2 compliant with end-to-end encryption. Your data stays protected at every layer.|🔒\r\nAPI Integrations|Connect with 50+ popular tools. REST API and webhooks for custom workflows.|🔗\r\nGlobal CDN|Lightning-fast load times worldwide. Edge caching ensures your users get the best experience.|🌍|格式：标题|描述|图标，一行一个
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['features_bg'] ?? '#0d1321';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$textMuted = $colors['text_muted'] ?? '#64748b';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#34d399';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(16, 185, 129, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(16, 185, 129, 0.3)';

$badge = $config['content.badge'] ?? 'Features';
$title = $config['content.title'] ?? 'Everything you need to scale';
$description = $config['content.description'] ?? 'Powerful tools designed to help your team work smarter, ship faster, and grow without limits.';

$featuresRaw = $config['features.items'] ?? "Workflow Automation|Build custom workflows with drag-and-drop simplicity. Automate repetitive tasks and focus on what matters.|⚡\nReal-time Analytics|Track key metrics with live dashboards. Make data-driven decisions with actionable insights.|📊\nTeam Collaboration|Share, comment, and iterate together. Keep everyone aligned with built-in communication tools.|👥\nEnterprise Security|SOC 2 compliant with end-to-end encryption. Your data stays protected at every layer.|🔒\nAPI Integrations|Connect with 50+ popular tools. REST API and webhooks for custom workflows.|🔗\nGlobal CDN|Lightning-fast load times worldwide. Edge caching ensures your users get the best experience.|🌍";

$features = [];
foreach (preg_split('/[\r\n]+/', $featuresRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $featureTitle = trim($parts[0] ?? '');
    $featureDesc = trim($parts[1] ?? '');
    $featureIcon = trim($parts[2] ?? '⭐');
    if (!empty($featureTitle)) {
        $features[] = ['title' => $featureTitle, 'description' => $featureDesc, 'icon' => $featureIcon];
    }
}

$instanceId = 'ss-features-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 100px 0; }
        #<?= $instanceId ?> .ss-features-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .ss-features-header { text-align: center; margin-bottom: 64px; }
        #<?= $instanceId ?> .ss-features-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>; border-radius: 50px; font-size: 0.875rem; font-weight: 500; color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; }
        #<?= $instanceId ?> .ss-features-title { font-size: 2.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .ss-features-subtitle { font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; line-height: 1.7; }
        #<?= $instanceId ?> .ss-features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        #<?= $instanceId ?> .ss-features-card { background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>; border-radius: 16px; padding: 32px 28px; transition: all 0.3s ease; }
        #<?= $instanceId ?> .ss-features-card:hover { background: rgba(255,255,255,0.05); border-color: rgba(16,185,129,0.4); transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
        #<?= $instanceId ?> .ss-features-card-icon { width: 56px; height: 56px; background: <?= $buttonPrimaryBg ?>; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 20px; box-shadow: 0 8px 24px rgba(16,185,129,0.25); transition: transform 0.3s ease; }
        #<?= $instanceId ?> .ss-features-card:hover .ss-features-card-icon { transform: scale(1.1) rotate(3deg); }
        #<?= $instanceId ?> .ss-features-card-title { font-size: 1.125rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 10px; }
        #<?= $instanceId ?> .ss-features-card-desc { font-size: 0.9rem; color: <?= $textMuted ?>; line-height: 1.7; }
        @media (max-width: 992px) { #<?= $instanceId ?> .ss-features-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { #<?= $instanceId ?> .ss-features-title { font-size: 1.75rem; } #<?= $instanceId ?> .ss-features-grid { grid-template-columns: 1fr; } }
    </style>
    
    <div class="ss-features-container">
        <div class="ss-features-header">
            <div class="ss-features-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="ss-features-title"><?= htmlspecialchars($title) ?></h2>
            <p class="ss-features-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        <div class="ss-features-grid">
            <?php foreach ($features as $feature): ?>
            <div class="ss-features-card">
                <div class="ss-features-card-icon"><?= $feature['icon'] ?></div>
                <h3 class="ss-features-card-title"><?= htmlspecialchars($feature['title']) ?></h3>
                <p class="ss-features-card-desc"><?= htmlspecialchars($feature['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
