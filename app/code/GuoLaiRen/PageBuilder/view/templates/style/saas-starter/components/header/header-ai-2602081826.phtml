$_jsPlaceholder = <<<'JSEOF'
// 滚动检测
let lastScrollTop = 0;
const scrollThreshold = 50;

const handleScroll = () => {
    const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
    
    // 滚动背景效果
    const scrolled = currentScroll > scrollThreshold;
    component.classList.toggle('ai-header-scrolled', scrolled);
    
    // 固定导航
    if ( $stickyHeader ? 'true' : 'false' ) {
        component.classList.toggle('ai-header-sticky', scrolled);
    }
    
    // 滚动方向检测（可选：隐藏/显示导航）
    if (currentScroll > lastScrollTop && currentScroll > 100) {
        component.style.transform = 'translateY(-100%)';
    } else {
        component.style.transform = 'translateY(0)';
    }
    
    lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
};

// 移动端菜单切换
const hamburger = component.querySelector('.ai-header-hamburger');
const navMenu = component.querySelector('.ai-header-nav-menu');

if (hamburger && navMenu) {
    hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        navMenu.classList.toggle('active');
        document.body.style.overflow = navMenu.classList.contains('active') ? 'hidden' : '';
    });
    
    // 点击菜单项关闭菜单
    const navLinks = navMenu.querySelectorAll('.ai-header-nav-link');
    navLinks.forEach(link => {
        link.addEventListener('click', () => {
            hamburger.classList.remove('active');
            navMenu.classList.remove('active');
            document.body.style.overflow = '';
        });
    });
}

// 初始化
handleScroll();
window.addEventListener('scroll', handleScroll, { passive: true });

// 窗口大小变化时重置移动端菜单
window.addEventListener('resize', () => {
    if (window.innerWidth > 768 && navMenu) {
        navMenu.classList.remove('active');
        if (hamburger) hamburger.classList.remove('active');
        document.body.style.overflow = '';
    }
});
JSEOF;
