<?php
/**
 * SaaS Starter - Navigation Header Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:SaaSFlow
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:36|px
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:no|no,yes
 * navigation.links => 导航链接:textarea:Features=>#features\r\nPricing=>#pricing\r\nTestimonials=>#testimonials\r\nFAQ=>#faq|格式：名称=>链接，一行一个（仅当开启自定义链接时生效）
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Start Free Trial
 * navigation.cta_url => CTA按钮链接:text:#pricing
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$logoDisplay = $config['logo.display'] ?? 'yes';
$logoText = $config['logo.text'] ?? 'SaaSFlow';
$logoUrl = $config['logo.url'] ?? '';
$logoWidth = $config['logo.width'] ?? '36';
$useCustomLinks = ($config['navigation.use_custom_links'] ?? 'no') === 'yes';
$navLinksRaw = $config['navigation.links'] ?? "Features=>#features\nPricing=>#pricing\nTestimonials=>#testimonials\nFAQ=>#faq";
$showCta = $config['navigation.show_cta'] ?? 'yes';
$ctaText = $config['navigation.cta_text'] ?? 'Start Free Trial';
$ctaUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($config['navigation.cta_url'] ?? '#pricing');
$ctaResolvedHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaResolvedHref, 'url');

$accentPrimary = $colors['accent_primary'] ?? '#10b981';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$navLinkHoverColor = $colors['nav_link_hover'] ?? '#34d399';
$navBg = $colors['nav_bg'] ?? 'rgba(11, 15, 25, 0.95)';

$navLinks = [];
$page = $this->getData('page');

if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $headerPages = $page->getHeaderNavigationPages(10);
    foreach ($headerPages as $navPage) {
        $type = $navPage['type'] ?? '';
        $labelKey = 'navigation.label_' . $type;
        $configuredLabel = trim((string)($config[$labelKey] ?? ''));
        $title = $navPage['title'] ?? '';
        $url = $navPage['url'] ?? '/';
        if (isset($navPage['type']) && $navPage['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
            $title = __('Home');
            $url = '/';
        }
        $navLinks[] = ['name' => $configuredLabel !== '' ? $configuredLabel : $title, 'url' => $url];
    }
}
if ($useCustomLinks || empty($navLinks)) {
    $navLinks = [];
    foreach (preg_split('/[\r\n]+/', $navLinksRaw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl(trim($parts[1] ?? '#'));
        if (!empty($name)) $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
if (empty($navLinks)) {
    $navLinks = [['name' => 'Features', 'url' => '/#features'], ['name' => 'Pricing', 'url' => '/#pricing'], ['name' => 'Testimonials', 'url' => '/#testimonials'], ['name' => 'FAQ', 'url' => '/#faq']];
}

$instanceId = 'ss-nav-' . uniqid();
?>

<div class="ss-nav-outer" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { width: 100vw; margin-left: calc(-50vw + 50%); box-sizing: border-box; position: relative; background: <?= htmlspecialchars($navBg) ?>; backdrop-filter: blur(10px); padding: 15px 0; }
        #<?= $instanceId ?> .ss-nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; }
        #<?= $instanceId ?> .ss-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: <?= $textPrimary ?>; }
        #<?= $instanceId ?> .ss-nav-inner .ss-logo-icon { width: <?= intval($logoWidth) ?>px; height: <?= intval($logoWidth) ?>px; background: <?= $buttonPrimaryBg ?>; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
        #<?= $instanceId ?> .ss-nav-inner .ss-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
        #<?= $instanceId ?> .ss-nav-inner .ss-logo-text { font-size: 1.25rem; font-weight: 700; }
        #<?= $instanceId ?> .ss-nav-inner .ss-nav { display: flex; align-items: center; gap: 32px; }
        #<?= $instanceId ?> .ss-nav-inner .ss-nav-links { display: flex; gap: 28px; list-style: none; margin: 0; padding: 0; }
        #<?= $instanceId ?> .ss-nav-inner .ss-nav-link { color: <?= $textPrimary ?>; opacity: 0.8; text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: all 0.3s ease; }
        #<?= $instanceId ?> .ss-nav-inner .ss-nav-link:hover { color: <?= $navLinkHoverColor ?>; opacity: 1; }
        #<?= $instanceId ?> .ss-nav-inner .ss-header-cta { display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; background: <?= $buttonPrimaryBg ?>; color: #fff; border-radius: 10px; font-size: 0.9rem; font-weight: 600; transition: all 0.3s ease; text-decoration: none; }
        #<?= $instanceId ?> .ss-nav-inner .ss-header-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(16,185,129,0.4); }
        @media (max-width: 768px) { #<?= $instanceId ?> .ss-nav-inner .ss-nav-links { display: none; } }
    </style>
    <nav class="ss-nav-inner">
        <?php if ($logoDisplay === 'yes'): ?>
        <a href="/" class="ss-logo">
            <span class="ss-logo-icon">
                <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>" style="width:100%;height:100%;object-fit:contain;">
                <?php else: ?>
                    <svg viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <?php endif; ?>
            </span>
            <span class="ss-logo-text"><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        <nav class="ss-nav">
            <ul class="ss-nav-links">
                <?php foreach ($navLinks as $link): ?>
                <li><a href="<?= htmlspecialchars($link['url']) ?>" class="ss-nav-link"><?= htmlspecialchars($link['name']) ?></a></li>
                <?php endforeach; ?>
            </ul>
            <?php if ($showCta === 'yes'): ?>
            <a role="button" tabindex="0" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($ctaRef)) ?>" data-glr-ref="<?= htmlspecialchars($ctaRef) ?>" class="ss-header-cta">
                <span><?= htmlspecialchars($ctaText) ?></span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <?php endif; ?>
        </nav>
    </nav>
</div>
