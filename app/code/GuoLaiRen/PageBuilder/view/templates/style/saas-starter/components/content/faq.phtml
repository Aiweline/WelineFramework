<?php
/**
 * SaaS Starter - FAQ Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:FAQ
 * content.title => 标题:text:Frequently asked questions
 * content.description => 描述:textarea:Everything you need to know about the platform. Can't find the answer? Contact our support team.
 * group:faq => FAQ列表
 * faq.items => FAQ列表:textarea:How does the free trial work?|You get full access to all Pro features for 14 days. No credit card required. At the end of the trial, choose a plan or continue with the free tier.\r\nCan I change plans later?|Absolutely. You can upgrade, downgrade, or cancel at any time. Changes take effect at the start of your next billing cycle.\r\nIs my data secure?|Yes. We use end-to-end encryption, are SOC 2 Type II certified, and comply with GDPR. Your data is stored in enterprise-grade data centers.\r\nDo you offer custom integrations?|We have 50+ pre-built integrations and a REST API for custom setups. Enterprise plans include dedicated integration support.\r\nWhat kind of support do you provide?|Starter plans include email support. Pro includes priority support with 4-hour response time. Enterprise gets 24/7 dedicated support.\r\nCan I export my data?|Yes, you can export all your data at any time in CSV, JSON, or via our API. We believe your data belongs to you.|格式：问题|回答，一行一个
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['faq_bg'] ?? '#0b0f19';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$textMuted = $colors['text_muted'] ?? '#64748b';
$accentPrimary = $colors['accent_primary'] ?? '#10b981';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#34d399';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(16, 185, 129, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(16, 185, 129, 0.3)';

$badge = $config['content.badge'] ?? 'FAQ';
$title = $config['content.title'] ?? 'Frequently asked questions';
$description = $config['content.description'] ?? "Everything you need to know about the platform. Can't find the answer? Contact our support team.";

$faqRaw = $config['faq.items'] ?? "How does the free trial work?|You get full access to all Pro features for 14 days. No credit card required.\nCan I change plans later?|Absolutely. You can upgrade, downgrade, or cancel at any time.\nIs my data secure?|Yes. We use end-to-end encryption, are SOC 2 Type II certified, and comply with GDPR.\nDo you offer custom integrations?|We have 50+ pre-built integrations and a REST API for custom setups.\nWhat kind of support do you provide?|Starter plans include email support. Pro includes priority support. Enterprise gets 24/7 dedicated support.\nCan I export my data?|Yes, you can export all your data at any time in CSV, JSON, or via our API.";

$faqs = [];
foreach (preg_split('/[\r\n]+/', $faqRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $question = trim($parts[0] ?? '');
    if (!empty($question)) {
        $faqs[] = ['question' => $question, 'answer' => trim($parts[1] ?? '')];
    }
}

$instanceId = 'ss-faq-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 100px 0; }
        #<?= $instanceId ?> .ss-faq-container { max-width: 800px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .ss-faq-header { text-align: center; margin-bottom: 60px; }
        #<?= $instanceId ?> .ss-faq-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>; border-radius: 50px; font-size: 0.875rem; font-weight: 500; color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; }
        #<?= $instanceId ?> .ss-faq-title { font-size: 2.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .ss-faq-subtitle { font-size: 1.125rem; color: <?= $textSecondary ?>; line-height: 1.7; }
        #<?= $instanceId ?> .ss-faq-list { display: flex; flex-direction: column; gap: 14px; }
        #<?= $instanceId ?> .ss-faq-item { background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>; border-radius: 14px; overflow: hidden; transition: all 0.3s ease; }
        #<?= $instanceId ?> .ss-faq-item:hover { border-color: rgba(16,185,129,0.3); }
        #<?= $instanceId ?> .ss-faq-item.active { border-color: <?= $accentPrimary ?>; }
        #<?= $instanceId ?> .ss-faq-question { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 24px; cursor: pointer; transition: background 0.3s ease; }
        #<?= $instanceId ?> .ss-faq-question:hover { background: rgba(255,255,255,0.02); }
        #<?= $instanceId ?> .ss-faq-question-text { font-size: 1rem; font-weight: 600; color: <?= $textPrimary ?>; flex: 1; }
        #<?= $instanceId ?> .ss-faq-question-icon { width: 32px; height: 32px; background: rgba(16,185,129,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s ease; }
        #<?= $instanceId ?> .ss-faq-question-icon svg { width: 16px; height: 16px; fill: <?= $accentPrimaryLight ?>; transition: transform 0.3s ease; }
        #<?= $instanceId ?> .ss-faq-item.active .ss-faq-question-icon { background: <?= $accentPrimary ?>; }
        #<?= $instanceId ?> .ss-faq-item.active .ss-faq-question-icon svg { fill: #fff; transform: rotate(180deg); }
        #<?= $instanceId ?> .ss-faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        #<?= $instanceId ?> .ss-faq-item.active .ss-faq-answer { max-height: 500px; }
        #<?= $instanceId ?> .ss-faq-answer-content { padding: 0 24px 24px; font-size: 0.95rem; color: <?= $textMuted ?>; line-height: 1.7; }
        @media (max-width: 576px) { #<?= $instanceId ?> .ss-faq-title { font-size: 1.75rem; } }
    </style>
    
    <div class="ss-faq-container">
        <div class="ss-faq-header">
            <div class="ss-faq-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="ss-faq-title"><?= htmlspecialchars($title) ?></h2>
            <p class="ss-faq-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="ss-faq-list">
            <?php foreach ($faqs as $index => $faq): ?>
            <div class="ss-faq-item<?= $index === 0 ? ' active' : '' ?>">
                <div class="ss-faq-question" onclick="this.parentElement.classList.toggle('active')">
                    <span class="ss-faq-question-text"><?= htmlspecialchars($faq['question']) ?></span>
                    <span class="ss-faq-question-icon">
                        <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                    </span>
                </div>
                <div class="ss-faq-answer">
                    <div class="ss-faq-answer-content"><?= htmlspecialchars($faq['answer']) ?></div>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
