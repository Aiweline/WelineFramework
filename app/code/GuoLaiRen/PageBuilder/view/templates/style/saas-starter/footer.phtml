$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$templateCode = $page ? $page->getData('style') : 'saas-starter';
if (empty($templateCode)) { $templateCode = 'saas-starter'; }
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) { $colors = []; }
if (!function_exists('ss_footer_color')) {
    function ss_footer_color($c, $k, $d = '') { return $c[$k] ?? $d; }
}
if (!function_exists('ss_footer_getConfig')) {
    function ss_footer_getConfig($s, $k, $d = '') { return $s[$k] ?? $d; }
}

$brandName = ss_footer_getConfig($styleSettings, 'brand.name', 'SaaSFlow');
$brandDesc = ss_footer_getConfig($styleSettings, 'brand.description', 'The modern platform for teams who ship fast.');
$col1Title = ss_footer_getConfig($styleSettings, 'links.column1_title', 'Product');
$col1Raw = ss_footer_getConfig($styleSettings, 'links.column1_items', "Features=>#features\nPricing=>#pricing\nIntegrations=>/integrations\nChangelog=>/changelog");
$col2Title = ss_footer_getConfig($styleSettings, 'links.column2_title', 'Company');
$col2Raw = ss_footer_getConfig($styleSettings, 'links.column2_items', "About=>/about\nBlog=>/blog\nCareers=>/careers\nContact=>/contact");
$col3Title = ss_footer_getConfig($styleSettings, 'links.column3_title', 'Legal');
$col3Raw = ss_footer_getConfig($styleSettings, 'links.column3_items', "Privacy=>/privacy\nTerms=>/terms\nCookies=>/cookies");

$parseLinks = function($raw) {
    $links = [];
    foreach (preg_split('/[\r\n]+/', $raw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl(trim($parts[1] ?? '#'));
        if (!empty($name)) $links[] = ['name' => $name, 'url' => $url];
    }
    return $links;
};

$col1Links = $parseLinks($col1Raw);
$col2Links = $parseLinks($col2Raw);
$col3Links = $parseLinks($col3Raw);

$copyrightText = ss_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved.');
$bgColor = ss_footer_getConfig($styleSettings, 'style.background_color', ss_footer_color($colors, 'footer_bg', '#080c14'));
$textColor = ss_footer_getConfig($styleSettings, 'style.text_color', ss_footer_color($colors, 'footer_text', '#64748b'));
$linkColor = ss_footer_getConfig($styleSettings, 'style.link_color', ss_footer_color($colors, 'footer_link', '#94a3b8'));
$linkHoverColor = ss_footer_getConfig($styleSettings, 'style.link_hover_color', ss_footer_color($colors, 'footer_link_hover', '#34d399'));
$textPrimary = ss_footer_color($colors, 'text_primary', '#f1f5f9');
$buttonPrimaryBg = ss_footer_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)');
$footerBorder = ss_footer_color($colors, 'footer_border', 'rgba(255, 255, 255, 0.06)');
$currentYear = date('Y');
?>

