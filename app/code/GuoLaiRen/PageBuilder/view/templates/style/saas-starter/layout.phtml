        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: <?= $bodyBg ?>;
            color: <?= ss_color($colors, 'text_primary', '#f1f5f9') ?>;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        img { max-width: 100%; height: auto; display: block; }
        a { text-decoration: none; color: inherit; transition: color 0.3s ease; }
        button { font-family: inherit; cursor: pointer; border: none; background: none; }
        ul, ol { list-style: none; }

        .ss-container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        @media (max-width: 768px) { .ss-container { padding: 0 16px; } }

        .ss-section { padding: 100px 0; }
        @media (max-width: 768px) { .ss-section { padding: 60px 0; } }

        .ss-btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            padding: 14px 28px; font-size: 1rem; font-weight: 600;
            border-radius: 12px; transition: all 0.3s ease; cursor: pointer;
        }
        .ss-btn-primary {
            background: <?= ss_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)') ?>;
            color: <?= ss_color($colors, 'button_primary_text', '#ffffff') ?>;
            box-shadow: 0 4px 20px <?= ss_color($colors, 'button_primary_shadow', 'rgba(16, 185, 129, 0.4)') ?>;
        }
        .ss-btn-primary:hover {
            box-shadow: 0 6px 30px <?= ss_color($colors, 'button_primary_shadow_hover', 'rgba(16, 185, 129, 0.6)') ?>;
            transform: translateY(-2px);
        }
        .ss-btn-secondary {
            background: transparent;
            color: <?= ss_color($colors, 'button_secondary_text', '#34d399') ?>;
            border: 2px solid <?= ss_color($colors, 'button_secondary_border', '#10b981') ?>;
        }
        .ss-btn-secondary:hover {
            background: rgba(16, 185, 129, 0.1);
            border-color: <?= ss_color($colors, 'accent_primary_light', '#34d399') ?>;
        }

        .ss-card {
            background: <?= ss_color($colors, 'card_bg', 'rgba(255, 255, 255, 0.03)') ?>;
            border: 1px solid <?= ss_color($colors, 'card_border', 'rgba(255, 255, 255, 0.08)') ?>;
            border-radius: 16px; padding: 24px; transition: all 0.3s ease;
        }
        .ss-card:hover {
            background: <?= ss_color($colors, 'card_bg_hover', 'rgba(255, 255, 255, 0.06)') ?>;
            border-color: <?= ss_color($colors, 'card_border_hover', 'rgba(16, 185, 129, 0.4)') ?>;
            transform: translateY(-4px);
            box-shadow: <?= ss_color($colors, 'card_shadow_hover', '0 8px 32px rgba(16, 185, 129, 0.15)') ?>;
        }

        .ss-grid { display: grid; gap: 24px; }
        .ss-grid-2 { grid-template-columns: repeat(2, 1fr); }
        .ss-grid-3 { grid-template-columns: repeat(3, 1fr); }
        .ss-grid-4 { grid-template-columns: repeat(4, 1fr); }
        @media (max-width: 992px) { .ss-grid-3, .ss-grid-4 { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { .ss-grid-2, .ss-grid-3, .ss-grid-4 { grid-template-columns: 1fr; } }

        .ss-region { position: relative; }
        .ss-region-header {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            background: <?= $navBgColor ?>; backdrop-filter: blur(10px);
        }
        .ss-region-content { padding-top: 80px; }
        .ss-region-footer {
            background: <?= ss_color($colors, 'footer_bg', '#080c14') ?>;
            border-top: 1px solid <?= ss_color($colors, 'footer_border', 'rgba(255, 255, 255, 0.06)') ?>;
        }

        .ss-component-wrapper, .tpmst-component-wrapper { position: relative; }

        @keyframes ssFadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .ss-animate { animation: ssFadeInUp 0.6s ease forwards; }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: <?= ss_color($colors, 'section_bg_4', '#0b0f19') ?>; }
        ::-webkit-scrollbar-thumb { background: <?= ss_color($colors, 'accent_primary', '#10b981') ?>; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: <?= ss_color($colors, 'accent_primary_light', '#34d399') ?>; }
    </style>
</head>
<body>
    <header class="ss-region ss-region-header" data-region="header" data-multiple="false">
        <?php foreach ($headerComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
            <div class="ss-component-wrapper tpmst-component-wrapper"
                 data-component="<?= htmlspecialchars($component['code']) ?>"
                 data-region="header">
                <?= $renderComponent($component) ?>
            </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </header>
    
    <main class="ss-region ss-region-content" data-region="content" data-multiple="true">
        <?php foreach ($contentComponents as $index => $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
            <div class="ss-component-wrapper tpmst-component-wrapper"
                 data-component="<?= htmlspecialchars($component['code']) ?>"
                 data-region="content"
                 data-index="<?= $index ?>">
                <?= $renderComponent($component) ?>
            </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </main>
    
    <footer class="ss-region ss-region-footer" data-region="footer" data-multiple="false">
        <?php foreach ($footerComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
            <div class="ss-component-wrapper tpmst-component-wrapper"
                 data-component="<?= htmlspecialchars($component['code']) ?>"
                 data-region="footer">
                <?= $renderComponent($component) ?>
            </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </footer>
    
    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });
        
        const header = document.querySelector('.ss-region-header');
        window.addEventListener('scroll', () => {
            header.style.boxShadow = window.pageYOffset > 50 ? '0 4px 20px rgba(0,0,0,0.3)' : 'none';
        });
    </script>
</body>
</html>
