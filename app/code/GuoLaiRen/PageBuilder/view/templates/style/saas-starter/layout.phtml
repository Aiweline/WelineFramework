<?php
/**
 * SaaS Starter 模板 - Main Layout
 * 
 * 定义 header/content/footer 三个区域容器
 * 支持组件动态加载和可视化拖拽
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$pageId = $page && $page->getId() ? $page->getId() : 0;
$templateCode = 'saas-starter';

// 获取页面布局配置
$layoutConfig = $this->getData('layout_config') ?: [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];

// 默认组件
if (empty($headerComponents)) {
    $headerComponents = [
        ['code' => 'header-nav', 'enabled' => true, 'config' => []]
    ];
}

if (empty($contentComponents)) {
    $contentComponents = [
        ['code' => 'hero', 'enabled' => true, 'config' => []],
        ['code' => 'features', 'enabled' => true, 'config' => []],
        ['code' => 'pricing', 'enabled' => true, 'config' => []],
        ['code' => 'testimonials', 'enabled' => true, 'config' => []],
        ['code' => 'cta-banner', 'enabled' => true, 'config' => []],
        ['code' => 'faq', 'enabled' => true, 'config' => []],
    ];
}

if (empty($footerComponents)) {
    $footerComponents = [
        ['code' => 'footer-links', 'enabled' => true, 'config' => []]
    ];
}

// 组件代码到文件的映射
$componentFiles = [
    'header-nav' => 'header/nav.phtml',
    'hero' => 'content/hero.phtml',
    'features' => 'content/features.phtml',
    'pricing' => 'content/pricing.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'cta-banner' => 'content/cta-banner.phtml',
    'faq' => 'content/faq.phtml',
    'footer-links' => 'footer/links.phtml',
];

/**
 * 渲染单个组件
 */
$renderComponent = function($component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];
    
    if (!$enabled || empty($code)) {
        return '';
    }
    
    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        return "<!-- Component not found: {$code} -->";
    }
    
    ob_start();
    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', $componentConfig);
    echo $this->fetchTemplate("GuoLaiRen_PageBuilder::templates/style/saas-starter/components/{$file}");
    return ob_get_clean();
};

// 加载颜色配置
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('ss_color')) {
    function ss_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('ss_getConfig')) {
    function ss_getConfig($settings, $key, $default = '') {
        $value = $settings[$key] ?? $default;
        if ($value === '' && $default !== '') {
            return $default;
        }
        return $value;
    }
}

$pageTitle = $page ? $page->getData('title') : 'SaaSFlow';
$pageDescription = $page ? $page->getData('meta_description') : 'The modern SaaS platform for teams';
$bodyBg = ss_color($colors, 'body_bg', '#0b0f19');
$navBgColor = ss_color($colors, 'nav_bg', 'rgba(11, 15, 25, 0.95)');
?>
