<?php
/**
 * SaaS Starter - Footer Links Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:SaaSFlow
 * brand.description => 品牌描述:textarea:The modern platform for teams who ship fast.
 * group:links => 链接设置
 * links.use_custom_links => 使用自定义链接组:select:no|no,yes
 * links.column1_title => 栏目1标题:text:Product
 * links.column1_items => 栏目1链接:textarea:Features=>#features\r\nPricing=>#pricing\r\nIntegrations=>/integrations\r\nChangelog=>/changelog|格式：名称=>链接（仅当开启自定义链接时生效）
 * links.column2_title => 栏目2标题:text:Company
 * links.column2_items => 栏目2链接:textarea:About=>/about\r\nBlog=>/blog\r\nCareers=>/careers\r\nContact=>/contact|格式：名称=>链接
 * links.column3_title => 栏目3标题:text:Legal
 * links.column3_items => 栏目3链接:textarea:Privacy=>/privacy\r\nTerms=>/terms\r\nCookies=>/cookies|格式：名称=>链接
 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved.
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$footerBg = $colors['footer_bg'] ?? '#080c14';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$textMuted = $colors['text_muted'] ?? '#64748b';
$linkColor = $colors['footer_link'] ?? '#94a3b8';
$linkHoverColor = $colors['footer_link_hover'] ?? '#34d399';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)';
$footerBorder = $colors['footer_border'] ?? 'rgba(255, 255, 255, 0.06)';

$brandName = $config['brand.name'] ?? 'SaaSFlow';
$brandDesc = $config['brand.description'] ?? 'The modern platform for teams who ship fast.';
$copyrightText = $config['copyright.text'] ?? 'All rights reserved.';

$parseLinks = function($raw) {
    $links = [];
    foreach (preg_split('/[\r\n]+/', $raw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) $links[] = ['name' => $name, 'url' => $url];
    }
    return $links;
};

// 按页面类型分组的底栏列（3列）：与 header 一致使用 getHeaderNavigationPages
$footerColTypes = [
    1 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME, \GuoLaiRen\PageBuilder\Model\Page::TYPE_ABOUT, \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG_LIST],
    2 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_CONTACT],
    3 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_TERMS_OF_SERVICE, \GuoLaiRen\PageBuilder\Model\Page::TYPE_PRIVACY_POLICY],
];
$footerColDefaultTitles = [1 => 'Product', 2 => 'Company', 3 => 'Legal'];

$useCustomLinks = ($config['links.use_custom_links'] ?? 'no') === 'yes';
$page = $this->getData('page');
$col1Links = [];
$col2Links = [];
$col3Links = [];
$col1Title = $config['links.column1_title'] ?? 'Product';
$col2Title = $config['links.column2_title'] ?? 'Company';
$col3Title = $config['links.column3_title'] ?? 'Legal';

if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $navPages = $page->getHeaderNavigationPages(20);
    $byCol = [1 => [], 2 => [], 3 => []];
    foreach ($navPages as $item) {
        $type = $item['type'] ?? '';
        foreach ($footerColTypes as $colIndex => $types) {
            if (in_array($type, $types, true)) {
                $labelKey = 'links.footer_label_' . $type;
                $label = isset($config[$labelKey]) && (string)$config[$labelKey] !== '' ? (string)$config[$labelKey] : ($item['title'] ?? '');
                $url = $item['url'] ?? '/';
                if (isset($item['type']) && $item['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
                    $label = __('Home');
                    $url = '/';
                }
                $byCol[$colIndex][] = ['name' => $label, 'url' => $url];
                break;
            }
        }
    }
    if (!empty($navPages)) {
        $col1Links = $byCol[1];
        $col2Links = $byCol[2];
        $col3Links = $byCol[3];
        $col1Title = isset($config['links.column1_title']) && (string)$config['links.column1_title'] !== '' ? (string)$config['links.column1_title'] : $footerColDefaultTitles[1];
        $col2Title = isset($config['links.column2_title']) && (string)$config['links.column2_title'] !== '' ? (string)$config['links.column2_title'] : $footerColDefaultTitles[2];
        $col3Title = isset($config['links.column3_title']) && (string)$config['links.column3_title'] !== '' ? (string)$config['links.column3_title'] : $footerColDefaultTitles[3];
    }
}
if ($useCustomLinks || (empty($col1Links) && empty($col2Links) && empty($col3Links))) {
    $col1Title = $config['links.column1_title'] ?? 'Product';
    $col1Links = $parseLinks($config['links.column1_items'] ?? "Features=>#features\nPricing=>#pricing\nIntegrations=>/integrations\nChangelog=>/changelog");
    $col2Title = $config['links.column2_title'] ?? 'Company';
    $col2Links = $parseLinks($config['links.column2_items'] ?? "About=>/about\nBlog=>/blog\nCareers=>/careers\nContact=>/contact");
    $col3Title = $config['links.column3_title'] ?? 'Legal';
    $col3Links = $parseLinks($config['links.column3_items'] ?? "Privacy=>/privacy\nTerms=>/terms\nCookies=>/cookies");
}
$currentYear = date('Y');
$instanceId = 'ss-footer-' . uniqid();
?>

<footer id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $footerBg ?>; padding: 80px 0 0; }
        #<?= $instanceId ?> .ss-footer-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .ss-footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 60px; border-bottom: 1px solid <?= $footerBorder ?>; }
        #<?= $instanceId ?> .ss-footer-logo { display: flex; align-items: center; gap: 10px; font-size: 1.25rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 14px; }
        #<?= $instanceId ?> .ss-footer-logo-icon { width: 36px; height: 36px; background: <?= $buttonPrimaryBg ?>; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
        #<?= $instanceId ?> .ss-footer-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
        #<?= $instanceId ?> .ss-footer-brand-desc { font-size: 0.9rem; color: <?= $textMuted ?>; line-height: 1.7; max-width: 260px; }
        #<?= $instanceId ?> .ss-footer-column h4 { font-size: 0.85rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 18px; text-transform: uppercase; letter-spacing: 0.06em; }
        #<?= $instanceId ?> .ss-footer-links { display: flex; flex-direction: column; gap: 10px; }
        #<?= $instanceId ?> .ss-footer-link { font-size: 0.9rem; color: <?= $linkColor ?>; text-decoration: none; transition: color 0.3s ease; }
        #<?= $instanceId ?> .ss-footer-link:hover { color: <?= $linkHoverColor ?>; }
        #<?= $instanceId ?> .ss-footer-bottom { padding: 24px 0; text-align: center; }
        #<?= $instanceId ?> .ss-footer-copyright { font-size: 0.85rem; color: <?= $textMuted ?>; }
        @media (max-width: 992px) { #<?= $instanceId ?> .ss-footer-grid { grid-template-columns: 1fr 1fr; } #<?= $instanceId ?> .ss-footer-brand { grid-column: 1 / -1; } }
        @media (max-width: 576px) { #<?= $instanceId ?> .ss-footer-grid { grid-template-columns: 1fr; gap: 32px; } }
    </style>
    
    <div class="ss-footer-container">
        <div class="ss-footer-grid">
            <div class="ss-footer-brand">
                <div class="ss-footer-logo">
                    <span class="ss-footer-logo-icon"><svg viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></span>
                    <span><?= htmlspecialchars($brandName) ?></span>
                </div>
                <p class="ss-footer-brand-desc"><?= htmlspecialchars($brandDesc) ?></p>
            </div>
            <div class="ss-footer-column">
                <h4><?= htmlspecialchars($col1Title) ?></h4>
                <div class="ss-footer-links">
                    <?php foreach ($col1Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="ss-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <div class="ss-footer-column">
                <h4><?= htmlspecialchars($col2Title) ?></h4>
                <div class="ss-footer-links">
                    <?php foreach ($col2Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="ss-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <div class="ss-footer-column">
                <h4><?= htmlspecialchars($col3Title) ?></h4>
                <div class="ss-footer-links">
                    <?php foreach ($col3Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="ss-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
        </div>
        <div class="ss-footer-bottom">
            <div class="ss-footer-copyright">&copy; <?= $currentYear ?> <?= htmlspecialchars($brandName) ?>. <?= htmlspecialchars($copyrightText) ?></div>
        </div>
    </div>
</footer>
