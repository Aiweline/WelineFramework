 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved.
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$footerBg = $colors['footer_bg'] ?? '#080c14';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$textMuted = $colors['text_muted'] ?? '#64748b';
$linkColor = $colors['footer_link'] ?? '#94a3b8';
$linkHoverColor = $colors['footer_link_hover'] ?? '#34d399';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)';
$footerBorder = $colors['footer_border'] ?? 'rgba(255, 255, 255, 0.06)';

$brandName = $config['brand.name'] ?? 'SaaSFlow';
$brandDesc = $config['brand.description'] ?? 'The modern platform for teams who ship fast.';
$col1Title = $config['links.column1_title'] ?? 'Product';
$col1Raw = $config['links.column1_items'] ?? "Features=>#features\nPricing=>#pricing\nIntegrations=>/integrations\nChangelog=>/changelog";
$col2Title = $config['links.column2_title'] ?? 'Company';
$col2Raw = $config['links.column2_items'] ?? "About=>/about\nBlog=>/blog\nCareers=>/careers\nContact=>/contact";
$col3Title = $config['links.column3_title'] ?? 'Legal';
$col3Raw = $config['links.column3_items'] ?? "Privacy=>/privacy\nTerms=>/terms\nCookies=>/cookies";
$copyrightText = $config['copyright.text'] ?? 'All rights reserved.';

$parseLinks = function($raw) {
    $links = [];
    foreach (preg_split('/[\r\n]+/', $raw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) $links[] = ['name' => $name, 'url' => $url];
    }
    return $links;
};

$col1Links = $parseLinks($col1Raw);
$col2Links = $parseLinks($col2Raw);
$col3Links = $parseLinks($col3Raw);
$currentYear = date('Y');
$instanceId = 'ss-footer-' . uniqid();
?>

