                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="ss-pricing-title"><?= htmlspecialchars($title) ?></h2>
            <p class="ss-pricing-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="ss-pricing-grid">
            <?php foreach ($plans as $plan): ?>
            <div class="ss-pricing-card<?= $plan['popular'] ? ' popular' : '' ?>">
                <?php if ($plan['popular']): ?>
                <span class="ss-pricing-popular-tag">Most Popular</span>
                <?php endif; ?>
                <h3 class="ss-pricing-card-name"><?= htmlspecialchars($plan['name']) ?></h3>
                <p class="ss-pricing-card-desc"><?= htmlspecialchars($plan['desc']) ?></p>
                <div class="ss-pricing-card-price">
                    <span class="price"><?= htmlspecialchars($plan['price']) ?></span>
                    <span class="period"><?= htmlspecialchars($plan['period']) ?></span>
                </div>
                <ul class="ss-pricing-card-features">
                    <?php foreach ($plan['features'] as $feature): ?>
                    <li><?= htmlspecialchars($feature) ?></li>
                    <?php endforeach; ?>
