        #<?= $instanceId ?> .ss-pricing-popular-tag { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); padding: 4px 16px; background: <?= $buttonPrimaryBg ?>; color: #fff; font-size: 0.8rem; font-weight: 600; border-radius: 50px; white-space: nowrap; }
        #<?= $instanceId ?> .ss-pricing-card-name { font-size: 1.25rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 8px; }
        #<?= $instanceId ?> .ss-pricing-card-desc { font-size: 0.9rem; color: <?= $textMuted ?>; margin-bottom: 24px; }
        #<?= $instanceId ?> .ss-pricing-card-price { margin-bottom: 32px; }
        #<?= $instanceId ?> .ss-pricing-card-price .price { font-size: 3rem; font-weight: 800; color: <?= $textPrimary ?>; }
        #<?= $instanceId ?> .ss-pricing-card-price .period { font-size: 1rem; color: <?= $textMuted ?>; }
