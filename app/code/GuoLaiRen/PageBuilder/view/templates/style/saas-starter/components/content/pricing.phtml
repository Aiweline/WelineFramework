        #<?= $instanceId ?> .ss-pricing-card-btn.primary:hover { box-shadow: 0 8px 30px rgba(16,185,129,0.5); transform: translateY(-2px); }
        #<?= $instanceId ?> .ss-pricing-card-btn.secondary { background: transparent; color: <?= $accentPrimaryLight ?>; border: 2px solid rgba(16,185,129,0.4); }
        #<?= $instanceId ?> .ss-pricing-card-btn.secondary:hover { background: rgba(16,185,129,0.1); }
        @media (max-width: 992px) { #<?= $instanceId ?> .ss-pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; } }
