$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['pricing_bg'] ?? '#111827';
$textPrimary = $colors['text_primary'] ?? '#f1f5f9';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$textMuted = $colors['text_muted'] ?? '#64748b';
$accentPrimary = $colors['accent_primary'] ?? '#10b981';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#34d399';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #10b981 0%, #06b6d4 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(16, 185, 129, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(16, 185, 129, 0.3)';
$popularBg = $colors['pricing_card_popular_bg'] ?? 'rgba(16, 185, 129, 0.08)';
$popularBorder = $colors['pricing_card_popular_border'] ?? 'rgba(16, 185, 129, 0.5)';

$badge = $config['content.badge'] ?? 'Pricing';
$title = $config['content.title'] ?? 'Simple, transparent pricing';
$description = $config['content.description'] ?? 'No hidden fees. No surprises. Pick a plan that fits your team size and scale as you grow.';

// 构建定价方案
$plans = [];
for ($i = 1; $i <= 3; $i++) {
    $name = $config["plans.plan{$i}_name"] ?? '';
    if (empty($name)) {
        $defaults = [
            1 => ['Starter', '$19', '/month', 'Perfect for small teams', "Up to 5 team members\n10GB storage\nBasic analytics\nEmail support\nAPI access", 'Get Started', '#', 'no'],
            2 => ['Pro', '$49', '/month', 'For growing teams', "Up to 20 team members\n100GB storage\nAdvanced analytics\nPriority support\nCustom integrations\nTeam permissions", 'Start Free Trial', '#', 'yes'],
            3 => ['Enterprise', 'Custom', '', 'For large organizations', "Unlimited team members\nUnlimited storage\nCustom analytics\n24/7 dedicated support\nCustom SLA\nOn-premise option", 'Contact Sales', '/contact', 'no'],
        ];
        $d = $defaults[$i];
        $name = $d[0];
        $price = $d[1]; $period = $d[2]; $desc = $d[3]; $featuresRaw = $d[4]; $btnText = $d[5]; $btnUrl = $d[6]; $popular = $d[7];
    } else {
        $price = $config["plans.plan{$i}_price"] ?? '';
        $period = $config["plans.plan{$i}_period"] ?? '';
        $desc = $config["plans.plan{$i}_desc"] ?? '';
        $featuresRaw = $config["plans.plan{$i}_features"] ?? '';
        $btnText = $config["plans.plan{$i}_btn_text"] ?? 'Get Started';
        $btnUrl = $config["plans.plan{$i}_btn_url"] ?? '#';
        $popular = $config["plans.plan{$i}_popular"] ?? 'no';
    }
    $featureList = array_filter(array_map('trim', preg_split('/[\r\n]+/', $featuresRaw)));
    $plans[] = [
        'name' => $name, 'price' => $price, 'period' => $period, 'desc' => $desc,
        'features' => $featureList, 'btn_text' => $btnText, 'btn_url' => $btnUrl, 'popular' => $popular === 'yes',
    ];
}

$instanceId = 'ss-pricing-' . uniqid();
?>

