                            <span><i class="mdi mdi-account"></i> <?= htmlspecialchars($currentPost->getData('author')) ?></span>
                            <?php endif; ?>
                            
                            <?php if ($articleShowDate && $currentPost->getData('published_at')): ?>
                            <span><i class="mdi mdi-calendar"></i> <?= date('Y-m-d', strtotime($currentPost->getData('published_at'))) ?></span>
                            <?php endif; ?>
                            
                            <span><i class="mdi mdi-eye"></i> <?= (int)$currentPost->getData('view_count') ?> <?= __('阅读') ?></span>
                        </div>
                    </header>
                    
                    <?php if ($articleShowCover && $currentPost->getData('cover_image')): ?>
                    <img src="<?= htmlspecialchars($currentPost->getData('cover_image')) ?>" 
                         alt="<?= htmlspecialchars($currentPost->getData('title')) ?>"
                         class="blog-article-cover">
                    <?php endif; ?>
                    
                    <div class="blog-article-content">
                        <?= $currentPost->getData('content') ?>
                    </div>
                    
                    <?php if ($articleShowTags && $currentPost->getTagsArray()): ?>
                    <div class="blog-article-tags">
                        <strong><?= __('标签：') ?></strong>
                        <?php foreach ($currentPost->getTagsArray() as $tag): ?>
                        <a href="#" class="blog-tag"><?= htmlspecialchars($tag) ?></a>
                        <?php endforeach; ?>
                    </div>
                    <?php endif; ?>
                    
                    <?php if ($articleShowShare): ?>
                    <div class="blog-share">
