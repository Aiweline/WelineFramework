                                <a href="<?= $this->getUrl('blog/frontend/post/view', ['slug' => $post->getData('slug')]) ?>">
                                    <?= htmlspecialchars($post->getData('title')) ?>
                                </a>
                                <small class="text-muted d-block">
                                    <?= date('Y-m-d', strtotime($post->getData('published_at'))) ?>
