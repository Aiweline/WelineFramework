                                    <?php if ($showDate && $post->getData('published_at')): ?>
                                    <span><i class="mdi mdi-calendar"></i> <?= date('Y-m-d', strtotime($post->getData('published_at'))) ?></span>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    </div>
                    <?php endforeach; ?>
                </div>
                
                <?php if ($pagination): ?>
                <nav class="blog-pagination">
                    <?= $pagination ?>
                </nav>
                <?php endif; ?>
                
                <?php endif; ?>
                <?php endif; ?>
            </div>
            
            <?php if ($showSidebar): ?>
            <!-- Sidebar -->
            <div class="col-lg-4 <?= $sidebarPosition === 'left' ? 'order-lg-1' : '' ?>">
