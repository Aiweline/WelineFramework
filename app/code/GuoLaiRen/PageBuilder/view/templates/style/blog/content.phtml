<?php
/**
 * Blog模板 - Content
 * 
 * 可用变量：
 * - $page: Page模型实例
 * - $style: 样式配置数组
 * - $blog_posts: 博客文章列表
 * - $blog_categories: 博客分类列表
 * - $current_category: 当前分类
 * - $current_post: 当前文章（详情页）
 * - $pagination: 分页信息
 * - $related_posts: 相关文章
 * 
 * @fields_start
 * group:posts => 文章列表配置
 * posts.style => 列表样式:select:grid|grid,list
 * posts.columns => 网格列数:select:3|2,3,4
 * posts.show_excerpt => 显示摘要:select:yes|yes,no
 * posts.show_date => 显示日期:select:yes|yes,no
 * posts.show_author => 显示作者:select:yes|yes,no
 * posts.show_category => 显示分类:select:yes|yes,no
 * posts.excerpt_length => 摘要长度:text:150
 * 
 * group:article => 文章详情配置
 * article.show_cover => 显示封面图:select:yes|yes,no
 * article.show_author => 显示作者:select:yes|yes,no
 * article.show_date => 显示日期:select:yes|yes,no
 * article.show_tags => 显示标签:select:yes|yes,no
 * article.show_share => 显示分享:select:yes|yes,no
 * article.show_related => 显示相关文章:select:yes|yes,no
 * 
 * group:sidebar => 侧边栏配置
 * sidebar.show => 显示侧边栏:select:yes|yes,no
 * sidebar.position => 侧边栏位置:select:right|left,right
 * sidebar.show_categories => 显示分类:select:yes|yes,no
 * sidebar.show_recent => 显示最近文章:select:yes|yes,no
 * sidebar.show_tags => 显示标签云:select:yes|yes,no
 * sidebar.recent_count => 最近文章数量:text:5
 * 
 * group:style => 样式配置
 * style.primary_color => 主色调:color:#0d6efd
 * style.card_bg => 卡片背景色:color:#ffffff
 * style.card_shadow => 卡片阴影:select:yes|yes,no
 * style.content_bg => 内容区背景:color:#f8f9fa
 * @fields_end
 */

// 获取配置
$postsStyle = $style['posts.style'] ?? 'grid';
$postsColumns = $style['posts.columns'] ?? '3';
$showExcerpt = ($style['posts.show_excerpt'] ?? 'yes') === 'yes';
$showDate = ($style['posts.show_date'] ?? 'yes') === 'yes';
$showAuthor = ($style['posts.show_author'] ?? 'yes') === 'yes';
$showCategoryBadge = ($style['posts.show_category'] ?? 'yes') === 'yes';
$excerptLength = (int)($style['posts.excerpt_length'] ?? 150);

$articleShowCover = ($style['article.show_cover'] ?? 'yes') === 'yes';
$articleShowAuthor = ($style['article.show_author'] ?? 'yes') === 'yes';
$articleShowDate = ($style['article.show_date'] ?? 'yes') === 'yes';
$articleShowTags = ($style['article.show_tags'] ?? 'yes') === 'yes';
$articleShowShare = ($style['article.show_share'] ?? 'yes') === 'yes';
$articleShowRelated = ($style['article.show_related'] ?? 'yes') === 'yes';

$showSidebar = ($style['sidebar.show'] ?? 'yes') === 'yes';
$sidebarPosition = $style['sidebar.position'] ?? 'right';
$sidebarShowCategories = ($style['sidebar.show_categories'] ?? 'yes') === 'yes';
$sidebarShowRecent = ($style['sidebar.show_recent'] ?? 'yes') === 'yes';
$sidebarShowTags = ($style['sidebar.show_tags'] ?? 'yes') === 'yes';
$recentCount = (int)($style['sidebar.recent_count'] ?? 5);

$primaryColor = $style['style.primary_color'] ?? '#0d6efd';
$cardBg = $style['style.card_bg'] ?? '#ffffff';
$cardShadow = ($style['style.card_shadow'] ?? 'yes') === 'yes';
$contentBg = $style['style.content_bg'] ?? '#f8f9fa';

// 获取数据
$blogPosts = $blog_posts ?? [];
$blogCategories = $blog_categories ?? [];
$currentCategory = $current_category ?? null;
$currentPost = $current_post ?? null;
$relatedPosts = $related_posts ?? [];
$pagination = $pagination ?? null;
$recentPosts = $recent_posts ?? [];

// 确定页面类型
$pageType = $page->getData('type');
$isDetailPage = $pageType === 'blog_post' && $currentPost;
$isListPage = in_array($pageType, ['blog_list', 'blog_category']) || (!$isDetailPage && !empty($blogPosts));

// 列数对应的Bootstrap类
$colClass = [
    '2' => 'col-md-6',
    '3' => 'col-md-6 col-lg-4',
    '4' => 'col-md-6 col-lg-3',
];
$columnClass = $colClass[$postsColumns] ?? 'col-md-6 col-lg-4';
?>

