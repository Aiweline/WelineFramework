                    <?php if ($currentCategory->getData('description')): ?>
                    <p class="text-muted"><?= htmlspecialchars($currentCategory->getData('description')) ?></p>
                    <?php endif; ?>
                </div>
                <?php endif; ?>
                
                <div class="row">
                    <?php foreach ($blogPosts as $post): ?>
                    <div class="<?= $columnClass ?> mb-4">
                        <div class="blog-card">
