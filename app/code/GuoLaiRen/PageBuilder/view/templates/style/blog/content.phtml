                                <img src="<?= htmlspecialchars($post->getData('cover_image')) ?>" 
                                     alt="<?= htmlspecialchars($post->getData('title')) ?>"
                                     class="blog-card-img">
                            </a>
                            <?php endif; ?>
                            
                            <div class="blog-card-body">
                                <?php if ($showCategoryBadge && $post->getCategoryName()): ?>
                                <span class="blog-category-badge"><?= htmlspecialchars($post->getCategoryName()) ?></span>
                                <?php endif; ?>
                                
                                <h3 class="blog-card-title">
                                    <a href="<?= $this->getUrl('blog/frontend/post/view', ['slug' => $post->getData('slug')]) ?>">
                                        <?= htmlspecialchars($post->getData('title')) ?>
                                    </a>
                                </h3>
                                
                                <?php if ($showExcerpt && $post->getData('summary')): ?>
                                <p class="blog-card-excerpt">
                                    <?= htmlspecialchars(mb_substr($post->getData('summary'), 0, $excerptLength)) ?>
