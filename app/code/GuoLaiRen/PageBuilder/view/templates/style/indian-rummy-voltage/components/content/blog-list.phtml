<?php
/**
 * Indian Rummy Voltage - Blog List Component
 *
 * @fields_start
 * group:blog => 博客设置
 * blog.title => 博客标题:text:Latest Indian Rummy Voltage Updates
 * blog.subtitle => 副标题:text:Tips, patch notes, and strategy breakdowns from the Indian Rummy Voltage desk
 * blog.kicker => 提示文案:text:Voltage Playbook Feed
 * blog.posts_per_page => 每页文章数:number:9
 * blog.show_sidebar => 显示侧边栏:select:yes|yes,no
 * blog.show_category => 显示分类:select:yes|yes,no
 * blog.show_date => 显示日期:select:yes|yes,no
 * blog.show_author => 显示作者:select:yes|yes,no
 * blog.card_style => 卡片样式:select:default|default,minimal,featured
 * blog.empty_title => 空状态标题:text:No posts yet
 * blog.empty_desc => 空状态描述:text:Fresh Indian Rummy Voltage updates will appear here soon.
 * blog.read_article_text => 首篇文章按钮文案:text:Read Story
 * blog.read_more_text => 列表按钮文案:text:Read More
 * blog.categories_title => 分类标题:text:Categories
 * blog.recent_posts_title => 最近文章标题:text:Recent Posts
 * blog.untitled_post_text => 缺省文章标题:text:Untitled Post
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$config = array_merge(is_array($style) ? $style : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$title = trim((string)$getConfig('blog.title', 'Latest Indian Rummy Voltage Updates'));
$subtitle = trim((string)$getConfig('blog.subtitle', 'Tips, patch notes, and strategy breakdowns from the Indian Rummy Voltage desk'));
$kicker = trim((string)$getConfig('blog.kicker', 'Voltage Playbook Feed'));
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $normalizeToggle($getConfig('blog.show_sidebar', 'yes')) === 'yes';
$showCategory = $normalizeToggle($getConfig('blog.show_category', 'yes')) === 'yes';
$showDate = $normalizeToggle($getConfig('blog.show_date', 'yes')) === 'yes';
$showAuthor = $normalizeToggle($getConfig('blog.show_author', 'yes')) === 'yes';
$cardStyle = trim((string)$getConfig('blog.card_style', 'default'));
if (!in_array($cardStyle, ['default', 'minimal', 'featured'], true)) {
    $cardStyle = 'default';
}
$emptyTitle = trim((string)$getConfig('blog.empty_title', 'No posts yet'));
$emptyDesc = trim((string)$getConfig('blog.empty_desc', 'Fresh Indian Rummy Voltage updates will appear here soon.'));
$readArticleText = trim((string)$getConfig('blog.read_article_text', 'Read Story'));
$readMoreText = trim((string)$getConfig('blog.read_more_text', 'Read More'));
$categoriesTitle = trim((string)$getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string)$getConfig('blog.recent_posts_title', 'Recent Posts'));
$untitledPostText = trim((string)$getConfig('blog.untitled_post_text', 'Untitled Post'));

$primaryColor = $getConfig('color_scheme.primary', '#ffd067');
$secondaryColor = $getConfig('color_scheme.secondary', '#00d8ae');
$bgColor = $getConfig('color_scheme.background', '#0d2133');
$textColor = $getConfig('color_scheme.text', '#f4f7ff');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $posts[0] ?? null;
$listPosts = array_slice($posts, 1);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};

$excerptText = static function ($text, $limit = 160) {
    $text = trim((string)$text);
    if ($text === '') {
        return '';
    }
    return mb_strlen($text) > $limit ? mb_substr($text, 0, $limit) . '...' : $text;
};
?>

<section class="rv-section rv-blog-list" id="blog">
    <div class="rv-inner">
        <header class="rv-blog-head">
            <?php if ($kicker !== ''): ?>
                <p class="rv-kicker"><?= htmlspecialchars($kicker) ?></p>
            <?php endif; ?>
            <h2><?= htmlspecialchars($title !== '' ? $title : 'Latest Indian Rummy Voltage Updates') ?></h2>
            <?php if ($subtitle): ?>
                <p class="rv-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </header>

        <?php if (!empty($blogCategories)): ?>
            <nav class="rv-blog-switch" aria-label="blog categories">
                <?php foreach (array_slice($blogCategories, 0, 8) as $category): ?>
                    <?php
                    $categoryName = $category['name'] ?? '';
                    $categoryUrl = $category['url'] ?? '#';
                    if ($categoryName === '') {
                        continue;
                    }
                    ?>
                    <a href="<?= htmlspecialchars((string)$categoryUrl) ?>"><?= htmlspecialchars((string)$categoryName) ?></a>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>

        <div class="rv-layout<?= $showSidebar ? ' with-sidebar' : ' full' ?> style-<?= htmlspecialchars((string)$cardStyle) ?>">
            <main class="rv-main" aria-label="Blog posts">
                <?php if (empty($posts)): ?>
                    <article class="rv-empty">
                        <h3><?= htmlspecialchars($emptyTitle !== '' ? $emptyTitle : 'No posts yet') ?></h3>
                        <p><?= htmlspecialchars($emptyDesc !== '' ? $emptyDesc : 'Fresh Indian Rummy Voltage updates will appear here soon.') ?></p>
                    </article>
                <?php else: ?>
                    <?php if ($featuredPost): ?>
                        <?php
                        $featuredUrl = $featuredPost['url'] ?? '#';
                        $featuredTitle = $featuredPost['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                        $featuredSummary = $featuredPost['summary'] ?? '';
                        $featuredCategory = $featuredPost['category_name'] ?? '';
                        $featuredDate = $formatDate($featuredPost['published_at'] ?? '');
                        $featuredAuthor = $featuredPost['author'] ?? '';
                        $featuredImage = $featuredPost['cover_image'] ?? '';
                        ?>
                        <article class="rv-featured-card">
                            <?php if ($featuredImage): ?>
                                <a href="<?= htmlspecialchars((string)$featuredUrl) ?>" class="rv-featured-media">
                                    <img src="<?= htmlspecialchars((string)$featuredImage) ?>" alt="<?= htmlspecialchars((string)$featuredTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>

                            <div class="rv-featured-body">
                                <span class="rv-order rv-order-main">01</span>
                                <div class="rv-meta">
                                    <?php if ($showCategory && $featuredCategory): ?>
                                        <span class="rv-chip"><?= htmlspecialchars((string)$featuredCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $featuredDate): ?>
                                        <time><?= htmlspecialchars((string)$featuredDate) ?></time>
                                    <?php endif; ?>
                                </div>

                                <h3><a href="<?= htmlspecialchars((string)$featuredUrl) ?>"><?= htmlspecialchars((string)$featuredTitle) ?></a></h3>

                                <?php if ($cardStyle !== 'minimal'): ?>
                                    <?php $summary = $excerptText($featuredSummary, 220); ?>
                                    <?php if ($summary !== ''): ?>
                                        <p class="rv-summary"><?= htmlspecialchars((string)$summary) ?></p>
                                    <?php endif; ?>
                                <?php endif; ?>

                                <div class="rv-footer-row">
                                    <?php if ($showAuthor && $featuredAuthor): ?>
                                        <span class="rv-author"><?= htmlspecialchars((string)$featuredAuthor) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars((string)$featuredUrl) ?>" class="rv-read-link"><?= htmlspecialchars($readArticleText !== '' ? $readArticleText : 'Read Story') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($listPosts)): ?>
                        <div class="rv-grid-cards">
                            <?php foreach ($listPosts as $index => $post): ?>
                                <?php
                                $postUrl = $post['url'] ?? '#';
                                $postTitle = $post['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                                $postSummary = $post['summary'] ?? '';
                                $postCategory = $post['category_name'] ?? '';
                                $postDate = $formatDate($post['published_at'] ?? '');
                                $postAuthor = $post['author'] ?? '';
                                $postImage = $post['cover_image'] ?? '';
                                $lane = 'lane-' . (($index % 3) + 1);
                                $orderNumber = str_pad((string)($index + 2), 2, '0', STR_PAD_LEFT);
                                ?>
                                <article class="rv-card <?= htmlspecialchars((string)$lane) ?><?= $cardStyle === 'featured' && $index < 2 ? ' boost' : '' ?>">
                                    <?php if ($cardStyle !== 'minimal' && $postImage): ?>
                                        <a href="<?= htmlspecialchars((string)$postUrl) ?>" class="rv-card-media">
                                            <img src="<?= htmlspecialchars((string)$postImage) ?>" alt="<?= htmlspecialchars((string)$postTitle) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>

                                    <div class="rv-card-body">
                                        <span class="rv-order"><?= htmlspecialchars((string)$orderNumber) ?></span>
                                        <div class="rv-meta">
                                            <?php if ($showCategory && $postCategory): ?>
                                                <span class="rv-chip"><?= htmlspecialchars((string)$postCategory) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && $postDate): ?>
                                                <time><?= htmlspecialchars((string)$postDate) ?></time>
                                            <?php endif; ?>
                                        </div>

                                        <h3><a href="<?= htmlspecialchars((string)$postUrl) ?>"><?= htmlspecialchars((string)$postTitle) ?></a></h3>

                                        <?php if ($cardStyle !== 'minimal'): ?>
                                            <?php $summary = $excerptText($postSummary, 145); ?>
                                            <?php if ($summary !== ''): ?>
                                                <p class="rv-summary"><?= htmlspecialchars((string)$summary) ?></p>
                                            <?php endif; ?>
                                        <?php endif; ?>

                                        <div class="rv-footer-row">
                                            <?php if ($showAuthor && $postAuthor): ?>
                                                <span class="rv-author"><?= htmlspecialchars((string)$postAuthor) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars((string)$postUrl) ?>" class="rv-read-link"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </main>

            <?php if ($showSidebar): ?>
                <aside class="rv-sidebar">
                    <?php if (!empty($blogCategories)): ?>
                        <section class="rv-side-card">
                            <h4><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h4>
                            <ul>
                                <?php foreach ($blogCategories as $category): ?>
                                    <?php
                                    $name = $category['name'] ?? '';
                                    $url = $category['url'] ?? '#';
                                    if ($name === '') {
                                        continue;
                                    }
                                    ?>
                                    <li><a href="<?= htmlspecialchars((string)$url) ?>"><?= htmlspecialchars((string)$name) ?></a></li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($recent)): ?>
                        <section class="rv-side-card">
                            <h4><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h4>
                            <ul class="rv-recent-list">
                                <?php foreach ($recent as $post): ?>
                                    <?php
                                    $postUrl = $post['url'] ?? '#';
                                    $postTitle = $post['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                                    $postDate = $formatDate($post['published_at'] ?? '');
                                    ?>
                                    <li>
                                        <a href="<?= htmlspecialchars((string)$postUrl) ?>">
                                            <span><?= htmlspecialchars((string)$postTitle) ?></span>
                                            <?php if ($postDate): ?>
                                                <em><?= htmlspecialchars((string)$postDate) ?></em>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>
        </div>
    </div>
</section>

