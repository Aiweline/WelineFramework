$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$hasText = static function ($value) {
    return trim(strip_tags((string)$value)) !== '';
};

$showMap = $normalizeToggle($getConfigAny(['display.display.show_map', 'display.show_map'], 'yes')) !== 'no';
$showForm = $normalizeToggle($getConfigAny(['display.display.show_form', 'display.show_form'], 'yes')) !== 'no';
$showSocial = $normalizeToggle($getConfigAny(['display.display.show_social', 'display.show_social'], 'yes')) !== 'no';
$showInfo = $normalizeToggle($getConfigAny(['display.display.show_info', 'display.show_info'], 'yes')) !== 'no';

$heroKicker = trim((string) $getConfigAny(['hero.hero.kicker', 'hero.kicker'], 'Support Center'));
$heroTitle = $getConfigAny(['hero.hero.title', 'hero.title'], '');
$heroSubtitle = $getConfigAny(['hero.hero.subtitle', 'hero.subtitle'], '');
$heroBgColorConfig = $getConfigAny(['hero.hero.bg_color', 'hero.bg_color'], '');
$heroGradientEndConfig = $getConfigAny(['hero.hero.bg_gradient_end', 'hero.bg_gradient_end'], '');
$heroTitleColorConfig = $getConfigAny(['hero.hero.title_color', 'hero.title_color'], '');

$addressLabel = trim((string) $getConfigAny(['contact_info.contact_info.address_label', 'contact_info.address_label'], 'Address'));
$contactAddress = $getConfigAny(['contact_info.contact_info.address', 'contact_info.address'], 'Mumbai Operations Hub, Andheri East, Maharashtra, India');
$phoneLabel = trim((string) $getConfigAny(['contact_info.contact_info.phone_label', 'contact_info.phone_label'], 'Phone'));
$contactPhone = $getConfigAny(['contact_info.contact_info.phone', 'contact_info.phone'], '+91 98765 43210');
$emailLabel = trim((string) $getConfigAny(['contact_info.contact_info.email_label', 'contact_info.email_label'], 'Email'));
$contactEmail = $getConfigAny(['contact_info.contact_info.email', 'contact_info.email'], 'support@indianrummyvoltage.com');
$workHoursLabel = trim((string) $getConfigAny(['contact_info.contact_info.work_hours_label', 'contact_info.work_hours_label'], 'Availability'));
$contactWorkHours = $getConfigAny(['contact_info.contact_info.work_hours', 'contact_info.work_hours'], '24/7 Player Support');

$socialWechat = $getConfigAny(['social.social.wechat', 'social.wechat'], '');
$socialWeibo = $getConfigAny(['social.social.weibo', 'social.weibo'], '');
$socialFacebook = $getConfigAny(['social.social.facebook', 'social.facebook'], '');
$socialTwitter = $getConfigAny(['social.social.twitter', 'social.twitter'], '');
$socialLinkedIn = $getConfigAny(['social.social.linkedin', 'social.linkedin'], '');

$formTitle = $getConfigAny(['form.form.title', 'form.title'], 'Send A Support Message');
$formNameLabel = trim((string) $getConfigAny(['form.form.name_label', 'form.name_label'], 'Name'));
$formEmailLabel = trim((string) $getConfigAny(['form.form.email_label', 'form.email_label'], 'Email'));
$formSubjectLabel = trim((string) $getConfigAny(['form.form.subject_label', 'form.subject_label'], 'Subject'));
$formMessageLabel = trim((string) $getConfigAny(['form.form.message_label', 'form.message_label'], 'Message'));
$formSubmitText = $getConfigAny(['form.form.submit_text', 'form.submit_text'], 'Send Message');
$formSuccessMessage = $getConfigAny(['form.form.success_message', 'form.success_message'], 'Thanks. Our team will reply soon.');

$mapTitle = trim((string) $getConfigAny(['map.map.title', 'map.title'], 'Map'));
$mapEmbedUrl = trim((string) $getConfigAny(['map.map.embed_url', 'map.embed_url'], ''));
$mapHeight = max(240, (int) $getConfigAny(['map.map.height', 'map.height'], '400'));
$showMap = $showMap && $mapEmbedUrl !== '';

$page = $this->getData('page');
$pageTitle = $heroTitle ?: ($page ? ($page->getData('title') ?? 'Contact Indian Rummy Voltage') : 'Contact Indian Rummy Voltage');

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $heroBgColorConfig ?: ($colors['hero_bg'] ?? '#0a2a3c');
$heroGradientEnd = $heroGradientEndConfig ?: ($colors['hero_bg_gradient_end'] ?? '#17233f');
