$sectionBg2 = $colors['section_bg_2'] ?? '#111b38';
$borderLight = $colors['border_light'] ?? 'rgba(157, 186, 231, 0.24)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.9)';
$accentPrimary = $heroTitleColorConfig ?: ($colors['heading_color_alt'] ?? $colors['accent_primary_vibrant'] ?? '#ffd067');
$accentSecondary = $colors['accent_secondary'] ?? '#00d8ae';
$accentAlt = $colors['accent_primary'] ?? '#ff5a5d';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(115deg, #ffd067 0%, #ff9050 45%, #ff5a5d 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#2f1207';

$socialLinks = [
    ['name' => 'Facebook', 'url' => trim((string)$socialFacebook), 'short' => 'FB'],
    ['name' => 'Twitter', 'url' => trim((string)$socialTwitter), 'short' => 'X'],
    ['name' => 'LinkedIn', 'url' => trim((string)$socialLinkedIn), 'short' => 'IN'],
    ['name' => 'WeChat', 'url' => trim((string)$socialWechat), 'short' => 'WC'],
    ['name' => 'Weibo', 'url' => trim((string)$socialWeibo), 'short' => 'WB'],
];
$socialLinks = array_values(array_filter($socialLinks, static function ($item) {
    return $item['url'] !== '';
}));

$phoneHref = preg_replace('/[^0-9+]/', '', (string)$contactPhone);
$hasAddress = $hasText($contactAddress);
$hasPhone = $hasText($contactPhone) && $phoneHref !== '';
$hasEmail = $hasText($contactEmail);
$hasWorkHours = $hasText($contactWorkHours);
$showSocial = $showSocial && !empty($socialLinks);
$showInfoPanel = $showInfo && ($hasAddress || $hasPhone || $hasEmail || $hasWorkHours || $showSocial);
$showQuickActions = !$showInfoPanel && ($hasPhone || $hasEmail || $hasWorkHours);
$showInfo = $showInfoPanel;

$instanceId = $component_instance_id ?? 'contact-content-' . uniqid();
?>

