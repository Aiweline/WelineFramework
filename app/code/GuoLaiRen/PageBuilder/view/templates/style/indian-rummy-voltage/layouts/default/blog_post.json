                    "blog.show_author": "yes",
                    "blog.show_date": "yes",
                    "blog.show_sidebar": "yes",
                    "blog.show_tags": "yes",
                    "blog.show_share": "yes",
                    "blog.show_related": "yes",
                    "blog.related_count": "3"
                }
            }
        ],
        "footer": []
    },
    "notes": "header 和 footer 为空数组表示从首页继承"
