$componentId = 'rv-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#f1e0bf'));
$titleColorRaw = $getConfig('style.title_color', '#fff2cf');
$titleColor = $titleColorRaw;
if (preg_match('/^#([0-9a-fA-F]{6})$/', $titleColorRaw, $matches)) {
    $hex = $matches[1];
    $r = hexdec(substr($hex, 0, 2));
    $g = hexdec(substr($hex, 2, 2));
    $b = hexdec(substr($hex, 4, 2));
    $luma = 0.299 * $r + 0.587 * $g + 0.114 * $b;
    if ($luma < 130) {
        $titleColor = '#fff2cf';
    }
} elseif (preg_match('/^rgba?\(\s*(\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})/i', $titleColorRaw, $matches)) {
    $r = min(255, (int)$matches[1]);
    $g = min(255, (int)$matches[2]);
    $b = min(255, (int)$matches[3]);
    $luma = 0.299 * $r + 0.587 * $g + 0.114 * $b;
    if ($luma < 130) {
        $titleColor = '#fff2cf';
    }
}
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.86)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '16');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(20,58,67,0.18)');
$cardTitleColor = $getConfig('style.card_title_color', '#143641');
$cardTitleFontSize = (int)$getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', '#2f434c');
$cardDescFontSize = (int)$getConfig('style.card_desc_font_size', '14');
$sectionPadding = (int)$getConfig('style.section_padding', '68');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '42');
$cardGap = (int)$getConfig('style.card_gap', '24');
$cardContentPadding = (int)$getConfig('style.card_content_padding', '22');
$hoverTransform = (int)$getConfig('style.hover_transform', '4');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/game/game-i1.webp');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/game/game-i1-m.webp');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/game/game-i2.webp');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/game/game-i3.webp');

$image1Desktop = $getConfig('images.image_1_desktop', $getConfig('games.image_1_desktop', '')) ?: $defaultImage1Desktop;
$image1Mobile = $getConfig('images.image_1_mobile', $getConfig('games.image_1_mobile', '')) ?: $defaultImage1Mobile;
$image2 = $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2;
$image3 = $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3;

$title = $getConfig('texts.title', $getConfig('games.title', 'Choose Your Voltage Table'));
$brandName = $getConfig('logo.text', $getConfig('header.logo.text', $getConfig('texts.app_name', $getConfig('app_info.app_name', 'Indian Rummy Voltage'))));
if (strtolower(trim($title)) === 'multiples game') {
    $title = 'Choose Your Voltage Table';
}
$title1 = $getConfig('texts.game_1_title', 'Indian Rummy Classic');
$desc1 = $getConfig('texts.game_1_desc', 'Core Rummy table flow with rapid room entry and stable rounds.');
$title2 = $getConfig('texts.game_2_title', 'Rummy Turbo');
$desc2 = $getConfig('texts.game_2_desc', 'Sequence-focused matches with cleaner score rhythm and fast rematch entry.');
$title3 = $getConfig('texts.game_3_title', 'Slot Sprint');
$desc3 = $getConfig('texts.game_3_desc', 'Short spin sessions designed for fast breaks between card tables.');

$games = [
    [
        'title' => $title1,
        'desc' => $desc1,
        'desktop' => $image1Desktop,
        'mobile' => $image1Mobile,
        'label' => '01',
    ],
    [
        'title' => $title2,
        'desc' => $desc2,
        'desktop' => $image2,
        'mobile' => $image2,
        'label' => '02',
    ],
    [
        'title' => $title3,
        'desc' => $desc3,
        'desktop' => $image3,
        'mobile' => $image3,
        'label' => '03',
    ],
];
