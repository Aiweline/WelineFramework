<?php
/**
 * Indian Rummy Voltage - Testimonials Component
 *
 * @component_start
 * code: testimonials
 * name: 用户评价
 * name_en: Testimonials
 * description: 用户评价展示，主卡+侧列结构
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示设置
 * display.show_section => 显示区块:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_rating => 显示评分:select:yes|yes,no
 * display.show_avatar => 显示头像:select:yes|yes,no
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#f7efdf
 * style.title_color => 标题颜色:color:#ffe8be
 * style.title_font_size => 标题字号桌面端:number:36|px
 * style.title_font_size_mobile => 标题字号移动端:number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.9)
 * style.card_border_radius => 卡片圆角:number:14|px
 * style.card_border_left_color => 卡片强调色:color:#c9472d
 * style.card_border_left_width => 卡片强调线宽:number:3|px
 * style.card_padding => 卡片内边距:number:22|px
 * style.name_color => 名称颜色:color:#132e38
 * style.name_font_size => 名称字号:number:16|px
 * style.rating_color => 评分颜色:color:#c9472d
 * style.content_color => 内容颜色:color:#30464f
 * style.content_font_size => 内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:58|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区块上下间距桌面端:number:68|px
 * style.section_padding_mobile => 区块上下间距移动端:number:42|px
 * style.card_gap => 卡片间距:number:20|px
 *
 * group:avatars => 头像设置
 * avatars.avatar_1 => 评价1头像:textarea:|默认使用本地头像
 * avatars.avatar_2 => 评价2头像:textarea:|默认使用本地头像
 * avatars.avatar_3 => 评价3头像:textarea:|默认使用本地头像
 *
 * group:texts => 文本设置
 * texts.title => 区块标题:text:What Players Notice First
 * texts.testimonial_1_name => 评价1姓名:text:Rajesh Kumar (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:4.9/5
 * texts.testimonial_1_content => 评价1内容:textarea:Indian Rummy Voltage loads tables very quickly and results settle without delays.
 * texts.testimonial_2_name => 评价2姓名:text:Priya Sharma (Delhi)
 * texts.testimonial_2_rating => 评价2评分:text:4.8/5
 * texts.testimonial_2_content => 评价2内容:textarea:I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.
 * texts.testimonial_3_name => 评价3姓名:text:Amit Patel (Ahmedabad)
 * texts.testimonial_3_rating => 评价3评分:text:4.8/5
 * texts.testimonial_3_content => 评价3内容:textarea:The app flow is clean and withdrawals are easy to track from the wallet panel.
 *
 * @fields_end
 */

$componentId = 'rv-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#f7efdf'));
$titleColorRaw = $getConfig('style.title_color', '#ffe8be');
$titleColor = $titleColorRaw;
if (preg_match('/^#([0-9a-fA-F]{6})$/', $titleColorRaw, $matches)) {
    $hex = $matches[1];
    $r = hexdec(substr($hex, 0, 2));
    $g = hexdec(substr($hex, 2, 2));
    $b = hexdec(substr($hex, 4, 2));
    $luma = 0.299 * $r + 0.587 * $g + 0.114 * $b;
    if ($luma < 130) {
        $titleColor = '#ffe8be';
    }
} elseif (preg_match('/^rgba?\(\s*(\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})/i', $titleColorRaw, $matches)) {
    $r = min(255, (int)$matches[1]);
    $g = min(255, (int)$matches[2]);
    $b = min(255, (int)$matches[3]);
    $luma = 0.299 * $r + 0.587 * $g + 0.114 * $b;
    if ($luma < 130) {
        $titleColor = '#ffe8be';
    }
}
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.9)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '14');
$cardAccentColor = $getConfig('style.card_border_left_color', '#c9472d');
$cardAccentWidth = (int)$getConfig('style.card_border_left_width', '3');
$cardPadding = (int)$getConfig('style.card_padding', '22');
$nameColor = $getConfig('style.name_color', '#132e38');
$nameFontSize = (int)$getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', '#c9472d');
$contentColor = $getConfig('style.content_color', '#30464f');
$contentFontSize = (int)$getConfig('style.content_font_size', '14');
$avatarSize = (int)$getConfig('style.avatar_size', '58');
$avatarRadius = (int)$getConfig('style.avatar_border_radius', '50');
$sectionPadding = (int)$getConfig('style.section_padding', '68');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '42');
$cardGap = (int)$getConfig('style.card_gap', '20');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/user/Amit-Patel-3.avif');

$avatar1 = $getConfig('avatars.avatar_1', $getConfig('testimonials.avatar_1', '')) ?: $defaultAvatar1;
$avatar2 = $getConfig('avatars.avatar_2', $getConfig('testimonials.avatar_2', '')) ?: $defaultAvatar2;
$avatar3 = $getConfig('avatars.avatar_3', $getConfig('testimonials.avatar_3', '')) ?: $defaultAvatar3;

$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Notice First'));
if (strtolower(trim($title)) === 'testimonials') {
    $title = 'What Players Notice First';
}
$name1 = $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)');
$rating1 = $getConfig('texts.testimonial_1_rating', '4.9/5');
$content1 = $getConfig('texts.testimonial_1_content', 'Indian Rummy Voltage loads tables very quickly and results settle without delays.');
$name2 = $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)');
$rating2 = $getConfig('texts.testimonial_2_rating', '4.8/5');
$content2 = $getConfig('texts.testimonial_2_content', 'I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.');
$name3 = $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)');
$rating3 = $getConfig('texts.testimonial_3_rating', '4.8/5');
$content3 = $getConfig('texts.testimonial_3_content', 'The app flow is clean and withdrawals are easy to track from the wallet panel.');

$cards = [
    ['avatar' => $avatar1, 'name' => $name1, 'rating' => $rating1, 'content' => $content1],
    ['avatar' => $avatar2, 'name' => $name2, 'rating' => $rating2, 'content' => $content2],
    ['avatar' => $avatar3, 'name' => $name3, 'rating' => $rating3, 'content' => $content3],
];

$renderCard = function ($card, $index) use ($showAvatar, $showRating) {
    ?>
    <article class="rvtest-card rvtest-card-<?= (int)($index + 1) ?>">
        <span class="rvtest-stamp" aria-hidden="true">Slip <?= sprintf('%02d', $index + 1) ?></span>
        <div class="rvtest-head">
            <?php if ($showAvatar): ?>
                <img src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
            <?php endif; ?>
            <div>
                <h3><?= htmlspecialchars($card['name']) ?></h3>
                <?php if ($showRating): ?>
                    <p class="rvtest-rating"><?= htmlspecialchars($card['rating']) ?></p>
                <?php endif; ?>
            </div>
        </div>
        <p class="rvtest-body"><?= htmlspecialchars($card['content']) ?></p>
    </article>
    <?php
};
?>

<section id="<?= $componentId ?>" class="rvtest" aria-labelledby="<?= $componentId ?>-title">
    <div class="rvtest-inner">
        <?php if ($showTitle): ?>
            <div class="rvtest-title-wrap">
                <span class="rvtest-title-mark" aria-hidden="true">
                    <span class="signal-bar signal-low"></span>
                    <span class="signal-bar signal-mid"></span>
                    <span class="signal-bar signal-high"></span>
                    <span class="signal-dot"></span>
                </span>
                <h2 id="<?= $componentId ?>-title" class="rvtest-title"><?= htmlspecialchars($title) ?></h2>
            </div>
        <?php endif; ?>

        <div class="rvtest-board">
            <?php foreach ($cards as $index => $card): ?>
                <?php $renderCard($card, $index); ?>
            <?php endforeach; ?>
        </div>

        <div class="rvtest-mobile-stack" role="list">
            <?php foreach ($cards as $index => $card): ?>
                <div class="rvtest-mobile-item" role="listitem">
                    <?php $renderCard($card, $index); ?>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>

