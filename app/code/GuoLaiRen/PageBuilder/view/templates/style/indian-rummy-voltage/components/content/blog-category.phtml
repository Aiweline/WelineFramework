<?php
/**
 * Indian Rummy Voltage - Blog Category Component
 *
 * @fields_start
 * group:blog => 博客设置
 * blog.title => 博客标题:text:Category Posts
 * blog.subtitle => 副标题:text:Browse articles by category
 * blog.posts_per_page => 每页文章数:number:9
 * blog.show_sidebar => 显示侧边栏:select:yes|yes,no
 * blog.show_category => 显示分类:select:yes|yes,no
 * blog.show_date => 显示日期:select:yes|yes,no
 * blog.show_author => 显示作者:select:yes|yes,no
 * blog.card_style => 卡片样式:select:default|default,minimal,featured
 * blog.article_singular => 文章数量单数标签:text:Post
 * blog.article_plural => 文章数量复数标签:text:Posts
 * blog.empty_title => 空状态标题:text:No posts in this category yet
 * blog.empty_desc => 空状态描述:text:Try another category or return to the main blog index.
 * blog.back_to_blog_text => 返回博客文案:text:Back to Blog
 * blog.read_more_text => 列表按钮文案:text:Read More
 * blog.categories_title => 分类标题:text:Categories
 * blog.recent_posts_title => 最近文章标题:text:Recent Posts
 * blog.untitled_post_text => 缺省文章标题:text:Untitled Post
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$config = array_merge(is_array($style) ? $style : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$title = trim((string)$getConfig('blog.title', $currentCategory['name'] ?? 'Category Posts'));
$subtitle = trim((string)$getConfig('blog.subtitle', 'Browse articles by category'));
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $normalizeToggle($getConfig('blog.show_sidebar', 'yes')) === 'yes';
$showCategory = $normalizeToggle($getConfig('blog.show_category', 'yes')) === 'yes';
$showDate = $normalizeToggle($getConfig('blog.show_date', 'yes')) === 'yes';
$showAuthor = $normalizeToggle($getConfig('blog.show_author', 'yes')) === 'yes';
$cardStyle = trim((string)$getConfig('blog.card_style', 'default'));
if (!in_array($cardStyle, ['default', 'minimal', 'featured'], true)) {
    $cardStyle = 'default';
}
$articleSingular = trim((string)$getConfig('blog.article_singular', 'Post'));
$articlePlural = trim((string)$getConfig('blog.article_plural', 'Posts'));
$emptyTitle = trim((string)$getConfig('blog.empty_title', 'No posts in this category yet'));
$emptyDesc = trim((string)$getConfig('blog.empty_desc', 'Try another category or return to the main blog index.'));
$backToBlogText = trim((string)$getConfig('blog.back_to_blog_text', 'Back to Blog'));
$readMoreText = trim((string)$getConfig('blog.read_more_text', 'Read More'));
$categoriesTitle = trim((string)$getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string)$getConfig('blog.recent_posts_title', 'Recent Posts'));
$untitledPostText = trim((string)$getConfig('blog.untitled_post_text', 'Untitled Post'));

$primaryColor = $getConfig('color_scheme.primary', '#ffd067');
$secondaryColor = $getConfig('color_scheme.secondary', '#00d8ae');
$bgColor = $getConfig('color_scheme.background', '#0d2133');
$textColor = $getConfig('color_scheme.text', '#f4f7ff');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};
?>

<section class="rv-section rv-blog-category" id="blog-category">
    <div class="section-inner">
        <header class="blog-head">
            <?php if (!empty($currentCategory['name'])): ?>
                <p class="category-pill"><?= htmlspecialchars($currentCategory['name']) ?></p>
            <?php endif; ?>

            <div class="blog-head-row">
                <h2><?= htmlspecialchars($title !== '' ? $title : 'Category Posts') ?></h2>
                <?php if (!empty($posts)): ?>
                    <span class="post-count"><?= count($posts) ?> <?= htmlspecialchars(count($posts) === 1 ? ($articleSingular !== '' ? $articleSingular : 'Post') : ($articlePlural !== '' ? $articlePlural : 'Posts')) ?></span>
                <?php endif; ?>
            </div>

            <?php if ($subtitle): ?>
                <p class="head-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if (!empty($currentCategory['description'])): ?>
                <p class="head-desc"><?= htmlspecialchars($currentCategory['description']) ?></p>
            <?php endif; ?>

            <?php if (!empty($blogCategories)): ?>
                <nav class="category-rail" aria-label="Blog categories">
                    <?php foreach ($blogCategories as $category): ?>
                        <?php
                        $categoryName = $category['name'] ?? '';
                        $categoryUrl = $category['url'] ?? '#';
                        $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$category['id'] === (string)$currentCategory['id'];
                        if ($categoryName === '') {
                            continue;
                        }
                        ?>
                        <a href="<?= htmlspecialchars($categoryUrl) ?>" class="<?= $isActive ? 'active' : '' ?>">
                            <span><?= htmlspecialchars($categoryName) ?></span>
                            <?php if (isset($category['post_count'])): ?>
                                <em><?= (int)$category['post_count'] ?></em>
                            <?php endif; ?>
                        </a>
                    <?php endforeach; ?>
                </nav>
            <?php endif; ?>
        </header>

        <div class="blog-layout<?= $showSidebar ? ' with-sidebar' : ' full-width' ?>">
            <main class="posts-grid" aria-label="Category posts">
                <?php if (empty($posts)): ?>
                    <article class="empty-state">
                        <h3><?= htmlspecialchars($emptyTitle !== '' ? $emptyTitle : 'No posts in this category yet') ?></h3>
                        <p><?= htmlspecialchars($emptyDesc !== '' ? $emptyDesc : 'Try another category or return to the main blog index.') ?></p>
                        <a class="empty-link" href="/blog"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
                    </article>
                <?php else: ?>
                    <?php foreach ($posts as $index => $post): ?>
                        <?php
                        $postUrl = !empty($post['url']) ? $post['url'] : '#';
                        $postTitle = !empty($post['title']) ? $post['title'] : ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                        $postSummary = !empty($post['summary']) ? $post['summary'] : '';
                        $postImage = !empty($post['cover_image']) ? $post['cover_image'] : '';
                        $postCategory = !empty($post['category_name']) ? $post['category_name'] : '';
                        $postDate = $formatDate($post['published_at'] ?? '');
                        $postAuthor = !empty($post['author']) ? $post['author'] : '';
                        $laneClass = 'lane-' . (($index % 3) + 1);
                        $orderNumber = str_pad((string)($index + 1), 2, '0', STR_PAD_LEFT);
                        ?>
                        <article class="post-card style-<?= htmlspecialchars($cardStyle) ?> <?= htmlspecialchars($laneClass) ?><?= $index === 0 && $cardStyle === 'featured' ? ' is-featured' : '' ?>">
                            <?php if ($postImage): ?>
                                <a class="post-image" href="<?= htmlspecialchars($postUrl) ?>">
                                    <img src="<?= htmlspecialchars($postImage) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>

                            <div class="post-body">
                                <span class="post-order"><?= htmlspecialchars($orderNumber) ?></span>
                                <div class="post-meta">
                                    <?php if ($showCategory && $postCategory): ?>
                                        <span class="post-chip"><?= htmlspecialchars($postCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $postDate): ?>
                                        <span class="post-date"><?= htmlspecialchars($postDate) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h3><a href="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($postTitle) ?></a></h3>

                                <?php if ($postSummary): ?>
                                    <p class="post-summary">
                                        <?= htmlspecialchars(mb_substr($postSummary, 0, 170)) ?><?= mb_strlen($postSummary) > 170 ? '...' : '' ?>
                                    </p>
                                <?php endif; ?>

                                <div class="post-footer">
                                    <?php if ($showAuthor && $postAuthor): ?>
                                        <span class="post-author"><?= htmlspecialchars($postAuthor) ?></span>
                                    <?php endif; ?>
                                    <a class="read-more" href="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Read More') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                <?php endif; ?>
            </main>

            <?php if ($showSidebar): ?>
                <aside class="sidebar">
                    <?php if (!empty($blogCategories)): ?>
                        <section class="sidebar-card">
                            <h4><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h4>
                            <ul>
                                <?php foreach ($blogCategories as $category): ?>
                                    <?php
                                    $categoryName = $category['name'] ?? '';
                                    $categoryUrl = $category['url'] ?? '#';
                                    $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$category['id'] === (string)$currentCategory['id'];
                                    if ($categoryName === '') {
                                        continue;
                                    }
                                    ?>
                                    <li class="<?= $isActive ? 'active' : '' ?>">
                                        <a href="<?= htmlspecialchars($categoryUrl) ?>">
                                            <span><?= htmlspecialchars($categoryName) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <small><?= (int)$category['post_count'] ?></small>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($recent)): ?>
                        <section class="sidebar-card">
                            <h4><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h4>
                            <ul class="recent-list">
                                <?php foreach ($recent as $post): ?>
                                    <?php
                                    $postUrl = $post['url'] ?? '#';
                                    $postTitle = $post['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                                    $postDate = $formatDate($post['published_at'] ?? '');
                                    ?>
                                    <li>
                                        <a href="<?= htmlspecialchars($postUrl) ?>">
                                            <span class="recent-title"><?= htmlspecialchars($postTitle) ?></span>
                                            <?php if ($postDate): ?>
                                                <span class="recent-date"><?= htmlspecialchars($postDate) ?></span>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>
        </div>
    </div>
</section>

