@keyframes rvhero-floor-pulse {
    0%, 100% {
        transform: translate3d(0, 0, 0) scale(1);
        opacity: .5;
    }
    50% {
        transform: translate3d(0, -1.2%, 0) scale(1.04);
        opacity: .78;
    }
}

@keyframes rvhero-floor-breathe {
    0%, 100% {
        transform: scale(1);
        opacity: .58;
    }
    50% {
        transform: scale(1.06);
        opacity: .82;
    }
}

@keyframes rvhero-up-haze {
    0% {
        transform: translate3d(0, 0, 0) scale(1);
        opacity: .36;
    }
    50% {
        transform: translate3d(0, -2.8%, 0) scale(1.04);
        opacity: .54;
    }
    100% {
        transform: translate3d(0, -4.8%, 0) scale(1.06);
        opacity: .28;
    }
}

@keyframes rvhero-spot-sway {
    0%, 100% {
        transform: translateX(-50%) rotate(calc(var(--rv-spot-angle, 30deg) - var(--rv-spot-sway, 2deg)));
    }
    50% {
        transform: translateX(-50%) rotate(calc(var(--rv-spot-angle, 30deg) + var(--rv-spot-sway, 2deg)));
    }
}

@keyframes rvhero-spot-breathe {
    0%, 100% {
        opacity: .64;
        filter: blur(2px) saturate(1);
    }
    50% {
        opacity: .92;
        filter: blur(1px) saturate(1.14);
    }
}

@keyframes rvhero-svg-breathe {
    0%, 100% {
        opacity: .62;
    }
    50% {
        opacity: .9;
    }
}

@keyframes rvhero-lamp-core {
    0%, 100% {
        transform: translateX(-50%) scale(.94);
        opacity: .74;
    }
    50% {
        transform: translateX(-50%) scale(1.08);
        opacity: .98;
    }
}

