/**
 * Indian Rummy Voltage - Hero Slider Component
 *
 * @fields_start
 *
 * group:hero => 首屏设置
 * hero.display => 显示首屏:select:yes|yes,no
 * hero.title => 首屏标题:text:Indian Rummy Voltage
 * hero.subtitle => 首屏副标题:textarea:Play Indian Rummy with voltage-fast rooms, smooth card flow, and secure table action.
 * hero.image_mobile => 移动端首屏图片:textarea:|默认使用本地banner-2.jpg
 * hero.image => 桌面端首屏图片:textarea:|默认使用本地banner-03.webp
 * hero.alt => 首屏图片替代文本:text:Indian Rummy Voltage hero banner
 * hero.bg_color => 首屏背景色:color:#102930
 * hero.cta_text => 首屏按钮文本:text:DOWNLOAD APP
 * hero.cta_url => 首屏按钮链接:text:#download
 *
 * group:download_btn => 下载按钮
 * download_btn.image => 下载按钮图片:textarea:|默认使用本地download-btn-m.webp
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区块样式类:textarea:rs-slider slider-style2|额外类名
 * layout.margin_top => 桌面端顶部重叠:number:-75|px
 * layout.img_margin_top => 桌面端图片偏移:number:-10|px
 *
 * @fields_end
 */

$page = $this->getData('page') ?? $page ?? null;
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeSwitch = static function ($value, $default = 'yes') {
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$bannerDisplay = $normalizeSwitch($getConfigAny(['hero.display', 'banner.display'], 'yes'), 'yes');
if ($bannerDisplay !== 'yes') {
    return;
}

$bannerAlt = (string)$getConfigAny(['hero.alt', 'banner.alt'], 'Indian Rummy Voltage hero banner');
$bannerBgColor = (string)$getConfigAny(['hero.bg_color', 'banner.bg_color'], '#102930');
$downloadDisplay = $normalizeSwitch($getConfigAny(['download_btn.display', 'hero.display'], 'yes'), 'yes') === 'yes';
$downloadBtnAlt = (string)$getConfigAny(['hero.cta_text', 'download_btn.alt'], 'DOWNLOAD APP');
$downloadBtnUrl = (string)$getConfigAny(['hero.cta_url', 'download_btn.url'], '#download');
$sliderClasses = (string)$getConfig('layout.slider_classes', 'rs-slider slider-style2');
$marginTop = (int)$getConfig('layout.margin_top', -75);
$imgMarginTop = (int)$getConfig('layout.img_margin_top', -10);

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/download-btn-m.webp');

$bannerImageMobile = trim((string)$getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$bannerImageDesktop = trim((string)$getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$downloadBtnImage = trim((string)$getConfig('download_btn.image', ''));

$finalBannerMobile = $bannerImageMobile !== '' ? $bannerImageMobile : (string)$defaultBannerMobile;
$finalBannerDesktop = $bannerImageDesktop !== '' ? $bannerImageDesktop : (string)$defaultBannerDesktop;
$finalDownloadBtn = $downloadBtnImage !== '' ? $downloadBtnImage : (string)$defaultDownloadBtn;

$isPreviewPlaceholder = static function ($value) {
    $text = trim((string)$value);
    if ($text === '') {
        return false;
    }
    $signals = [
        '预览模式',
        '模板默认配置',
        'preview mode',
        'default template',
        'template default'
    ];
    foreach ($signals as $signal) {
        if (stripos($text, $signal) !== false) {
            return true;
        }
    }
    return false;
};

$pageTitle = $page ? trim((string)($page->getData('title') ?: '')) : '';
$heroName = trim((string)$getConfig('hero.title', $pageTitle));
if ($heroName === '' || $isPreviewPlaceholder($heroName)) {
    $heroName = 'Indian Rummy Voltage';
}
$heroMeta = $page ? trim((string)($page->getData('meta_description') ?: '')) : '';
$heroSubtitleDefault = ($heroMeta !== '' && !$isPreviewPlaceholder($heroMeta))
    ? $heroMeta
    : 'Play Indian Rummy with voltage-fast rooms, smooth card flow, and secure table action.';
$heroSubtitle = trim((string)$getConfig('hero.subtitle', $heroSubtitleDefault));

