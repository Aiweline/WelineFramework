$componentId = 'gr-footer-links-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$decodeFieldText = static function ($value) {
    return html_entity_decode((string) $value, ENT_QUOTES, 'UTF-8');
};

$parseLinkLines = static function ($value) {
    $links = [];
    $value = trim((string) $value);
    if ($value === '') {
        return $links;
    }

    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }

    if (strpos($value, '=>') !== false) {
        foreach (preg_split('/\r?\n/', $value) as $line) {
            $line = trim((string) $line);
            if ($line === '' || strpos($line, '=>') === false) {
                continue;
            }
            $parts = explode('=>', $line, 2);
            $text = trim((string) ($parts[0] ?? ''));
            $url = trim((string) ($parts[1] ?? ''));
            if ($text === '') {
                continue;
            }
            $links[] = ['text' => $text, 'url' => $url !== '' ? $url : '#'];
        }
        return $links;
    }

    foreach (explode(',', $value) as $line) {
        $parts = explode('|', trim((string) $line), 2);
        $text = trim((string) ($parts[0] ?? ''));
        $url = trim((string) ($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }
        $links[] = ['text' => $text, 'url' => $url !== '' ? $url : '#'];
    }

    return $links;
};

