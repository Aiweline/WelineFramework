<?php
/**
 * Indian Rummy Voltage - Blog Detail Component
 *
 * @fields_start
 * group:blog => 博客设置
 * blog.show_sidebar => 显示侧边栏:select:yes|yes,no
 * blog.show_cover => 显示封面图:select:yes|yes,no
 * blog.show_author => 显示作者:select:yes|yes,no
 * blog.show_date => 显示日期:select:yes|yes,no
 * blog.show_tags => 显示标签:select:yes|yes,no
 * blog.show_share => 显示分享按钮:select:yes|yes,no
 * blog.show_related => 显示相关文章:select:yes|yes,no
 * blog.related_count => 相关文章数量:number:3
 * blog.not_found_title => 未找到标题:text:Article Not Found
 * blog.not_found_desc => 未找到描述:text:The article you are looking for is unavailable.
 * blog.back_to_blog_text => 返回博客文案:text:Back to Blog
 * blog.breadcrumb_home_text => 面包屑首页文案:text:Home
 * blog.breadcrumb_blog_text => 面包屑博客文案:text:Blog
 * blog.views_suffix => 阅读量后缀:text:views
 * blog.share_facebook_text => 脸书按钮文案:text:Facebook
 * blog.share_twitter_text => 社交按钮文案（原推特）:text:X
 * blog.share_linkedin_text => 领英按钮文案:text:LinkedIn
 * blog.share_copy_text => 复制链接按钮文案:text:Copy Link
 * blog.share_copied_text => 复制成功文案:text:Copied
 * blog.summary_label => 摘要标签:text:Round Snapshot
 * blog.categories_title => 分类标题:text:Categories
 * blog.recent_posts_title => 最近文章标题:text:Recent Posts
 * blog.related_title => 相关文章标题:text:Related Articles
 * blog.related_count_suffix => 相关文章数量后缀:text:Items
 * blog.untitled_post_text => 缺省文章标题:text:Untitled Post
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$currentPost = $this->getData('current_post') ?: [];
$relatedPosts = $this->getData('related_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$config = array_merge(is_array($style) ? $style : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$showSidebar = $normalizeToggle($getConfig('blog.show_sidebar', 'yes')) === 'yes';
$showCover = $normalizeToggle($getConfig('blog.show_cover', 'yes')) === 'yes';
$showAuthor = $normalizeToggle($getConfig('blog.show_author', 'yes')) === 'yes';
$showDate = $normalizeToggle($getConfig('blog.show_date', 'yes')) === 'yes';
$showTags = $normalizeToggle($getConfig('blog.show_tags', 'yes')) === 'yes';
$showShare = $normalizeToggle($getConfig('blog.show_share', 'yes')) === 'yes';
$showRelated = $normalizeToggle($getConfig('blog.show_related', 'yes')) === 'yes';
$relatedCount = max(1, (int)$getConfig('blog.related_count', 3));
$notFoundTitle = trim((string)$getConfig('blog.not_found_title', 'Article Not Found'));
$notFoundDesc = trim((string)$getConfig('blog.not_found_desc', 'The article you are looking for is unavailable.'));
$backToBlogText = trim((string)$getConfig('blog.back_to_blog_text', 'Back to Blog'));
$breadcrumbHomeText = trim((string)$getConfig('blog.breadcrumb_home_text', 'Home'));
$breadcrumbBlogText = trim((string)$getConfig('blog.breadcrumb_blog_text', 'Blog'));
$viewsSuffix = trim((string)$getConfig('blog.views_suffix', 'views'));
$shareFacebookText = trim((string)$getConfig('blog.share_facebook_text', 'Facebook'));
$shareTwitterText = trim((string)$getConfig('blog.share_twitter_text', 'X'));
$shareLinkedinText = trim((string)$getConfig('blog.share_linkedin_text', 'LinkedIn'));
$shareCopyText = trim((string)$getConfig('blog.share_copy_text', 'Copy Link'));
$shareCopiedText = trim((string)$getConfig('blog.share_copied_text', 'Copied'));
$summaryLabel = trim((string)$getConfig('blog.summary_label', 'Round Snapshot'));
$categoriesTitle = trim((string)$getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string)$getConfig('blog.recent_posts_title', 'Recent Posts'));
$relatedTitle = trim((string)$getConfig('blog.related_title', 'Related Articles'));
$relatedCountSuffix = trim((string)$getConfig('blog.related_count_suffix', 'Items'));
$untitledPostText = trim((string)$getConfig('blog.untitled_post_text', 'Untitled Post'));

$primaryColor = $getConfig('color_scheme.primary', '#ffd067');
$secondaryColor = $getConfig('color_scheme.secondary', '#00d8ae');
$bgColor = $getConfig('color_scheme.background', '#0d2133');
$textColor = $getConfig('color_scheme.text', '#f4f7ff');

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('F d, Y', $timestamp) : (string)$value;
};

$related = array_slice($relatedPosts, 0, $relatedCount);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : $related;
?>

<section class="rv-section rv-blog-detail">
    <div class="section-inner">
        <?php if (empty($currentPost)): ?>
            <article class="empty-state">
                <h2><?= htmlspecialchars($notFoundTitle !== '' ? $notFoundTitle : 'Article Not Found') ?></h2>
                <p><?= htmlspecialchars($notFoundDesc !== '' ? $notFoundDesc : 'The article you are looking for is unavailable.') ?></p>
                <a href="/blog" class="back-link"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
            </article>
        <?php else: ?>
            <?php
            $postTitle = $currentPost['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
            $postUrl = $currentPost['url'] ?? (\w_env_request_uri() ?: '/blog');
            $postDate = $formatDate($currentPost['published_at'] ?? '');
            $postAuthor = $currentPost['author'] ?? '';
            $postCover = $currentPost['cover_image'] ?? '';
            $postSummary = $currentPost['summary'] ?? '';
            $postContent = $currentPost['content'] ?? '';
            $postCategory = $currentPost['category_name'] ?? '';
            $postViews = !empty($currentPost['view_count']) ? (int)$currentPost['view_count'] : 0;

            $tags = [];
            if (!empty($currentPost['tags'])) {
                $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', (string)$currentPost['tags']);
                $tags = array_values(array_filter(array_map('trim', $tags), function ($tag) {
                    return $tag !== '';
                }));
            }
            ?>

            <nav class="breadcrumb" aria-label="breadcrumb">
                <a href="/"><?= htmlspecialchars($breadcrumbHomeText !== '' ? $breadcrumbHomeText : 'Home') ?></a>
                <span>/</span>
                <a href="/blog"><?= htmlspecialchars($breadcrumbBlogText !== '' ? $breadcrumbBlogText : 'Blog') ?></a>
                <span>/</span>
                <span><?= htmlspecialchars(mb_substr($postTitle, 0, 40)) ?><?= mb_strlen($postTitle) > 40 ? '...' : '' ?></span>
            </nav>

            <div class="detail-layout<?= $showSidebar ? ' with-sidebar' : ' full-width' ?>">
                <article class="article-card">
                    <header class="article-hero">
                        <?php if ($postCategory !== ''): ?>
                            <span class="article-pill"><?= htmlspecialchars($postCategory) ?></span>
                        <?php endif; ?>

                        <h1><?= htmlspecialchars($postTitle) ?></h1>

                        <div class="article-meta">
                            <?php if ($showDate && $postDate): ?>
                                <span><?= htmlspecialchars($postDate) ?></span>
                            <?php endif; ?>
                            <?php if ($showAuthor && $postAuthor): ?>
                                <span><?= htmlspecialchars($postAuthor) ?></span>
                            <?php endif; ?>
                            <?php if ($postViews > 0): ?>
                                <span><?= $postViews ?> <?= htmlspecialchars($viewsSuffix !== '' ? $viewsSuffix : 'views') ?></span>
                            <?php endif; ?>
                        </div>

                        <?php if ($showShare): ?>
                            <div class="article-share article-share-top">
                                <button type="button" data-share="facebook" data-url="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($shareFacebookText !== '' ? $shareFacebookText : 'Facebook') ?></button>
                                <button type="button" data-share="twitter" data-url="<?= htmlspecialchars($postUrl) ?>" data-title="<?= htmlspecialchars($postTitle) ?>"><?= htmlspecialchars($shareTwitterText !== '' ? $shareTwitterText : 'X') ?></button>
                                <button type="button" data-share="linkedin" data-url="<?= htmlspecialchars($postUrl) ?>" data-title="<?= htmlspecialchars($postTitle) ?>"><?= htmlspecialchars($shareLinkedinText !== '' ? $shareLinkedinText : 'LinkedIn') ?></button>
                                <button type="button" data-share="copy" data-url="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($shareCopyText !== '' ? $shareCopyText : 'Copy Link') ?></button>
                            </div>
                        <?php endif; ?>
                    </header>

                    <?php if ($showCover && $postCover): ?>
                        <div class="article-cover">
                            <img src="<?= htmlspecialchars($postCover) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                        </div>
                    <?php endif; ?>

                    <?php if ($postSummary): ?>
                        <aside class="article-summary">
                            <strong><?= htmlspecialchars($summaryLabel !== '' ? $summaryLabel : 'Round Snapshot') ?></strong>
                            <p><?= htmlspecialchars($postSummary) ?></p>
                        </aside>
                    <?php endif; ?>

                    <div class="article-content"><?= $postContent ?></div>

                    <?php if ($showTags && !empty($tags)): ?>
                        <div class="article-tags">
                            <?php foreach ($tags as $tag): ?>
                                <a href="/blog/tag/<?= urlencode($tag) ?>">#<?= htmlspecialchars($tag) ?></a>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <div class="article-nav">
                        <a href="/blog" class="back-link"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
                    </div>
                </article>

                <?php if ($showSidebar): ?>
                    <aside class="sidebar">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="sidebar-card">
                                <h4><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h4>
                                <ul>
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php
                                        $name = $category['name'] ?? '';
                                        $url = $category['url'] ?? '#';
                                        if ($name === '') {
                                            continue;
                                        }
                                        ?>
                                        <li><a href="<?= htmlspecialchars($url) ?>"><?= htmlspecialchars($name) ?></a></li>
                                    <?php endforeach; ?>
                                </ul>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recent)): ?>
                            <section class="sidebar-card">
                                <h4><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h4>
                                <ul class="recent-list">
                                    <?php foreach ($recent as $post): ?>
                                        <?php
                                        $url = $post['url'] ?? '#';
                                        $name = $post['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                                        $date = $formatDate($post['published_at'] ?? '');
                                        ?>
                                        <li>
                                            <a href="<?= htmlspecialchars($url) ?>">
                                                <span class="recent-title"><?= htmlspecialchars($name) ?></span>
                                                <?php if ($date): ?>
                                                    <span class="recent-date"><?= htmlspecialchars($date) ?></span>
                                                <?php endif; ?>
                                            </a>
                                        </li>
                                    <?php endforeach; ?>
                                </ul>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>

            <?php if ($showRelated && !empty($related)): ?>
                <section class="related-wrap">
                    <div class="related-head">
                        <h3><?= htmlspecialchars($relatedTitle !== '' ? $relatedTitle : 'Related Articles') ?></h3>
                        <span><?= count($related) ?> <?= htmlspecialchars($relatedCountSuffix !== '' ? $relatedCountSuffix : 'Items') ?></span>
                    </div>
                    <div class="related-grid">
                        <?php foreach ($related as $relatedIndex => $post): ?>
                            <?php
                            $url = $post['url'] ?? '#';
                            $name = $post['title'] ?? ($untitledPostText !== '' ? $untitledPostText : 'Untitled Post');
                            $date = $formatDate($post['published_at'] ?? '');
                            $image = $post['cover_image'] ?? '';
                            $orderNumber = str_pad((string)($relatedIndex + 1), 2, '0', STR_PAD_LEFT);
                            ?>
                            <article class="related-card">
                                <?php if ($image): ?>
                                    <a class="related-image" href="<?= htmlspecialchars($url) ?>">
                                        <img src="<?= htmlspecialchars($image) ?>" alt="<?= htmlspecialchars($name) ?>" loading="lazy" decoding="async">
                                    </a>
                                <?php endif; ?>
                                <div class="related-body">
                                    <span class="related-order"><?= htmlspecialchars($orderNumber) ?></span>
                                    <h4><a href="<?= htmlspecialchars($url) ?>"><?= htmlspecialchars($name) ?></a></h4>
                                    <?php if ($date): ?>
                                        <p><?= htmlspecialchars($date) ?></p>
                                    <?php endif; ?>
                                </div>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </section>
            <?php endif; ?>
        <?php endif; ?>
    </div>
</section>

