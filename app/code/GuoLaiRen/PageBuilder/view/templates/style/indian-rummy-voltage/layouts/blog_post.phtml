<?php
/**
 * 博客文章详情布局模板
 * 
 * 页面类型: blog_post
 * 描述: 单篇博客文章详情页面布局，继承首页的 header/footer
 * 
 * 可用变量:
 * - $page: Page 模型对象
 * - $layout_config: 布局配置数组
 * - $style_setting: 样式配置数组
 * - $mode: 渲染模式 (visual/preview/live)
 * - $current_post: 当前文章对象
 * - $related_posts: 相关文章列表
 * - $blog_categories: 博客分类列表
 * - $recent_posts: 最新文章列表
 */

// 获取布局配置
$layoutConfig = $layout_config ?? [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];

// 渲染模式
$isVisualMode = ($mode ?? 'live') === 'visual';

// 博客数据
$currentPost = $current_post ?? [];
$relatedPosts = $related_posts ?? [];
$blogCategories = $blog_categories ?? [];
$recentPosts = $recent_posts ?? [];
?>
<!DOCTYPE html>
<html lang="<?= $lang ?? 'en' ?>">
<head>
    <?php $this->renderHead($page, $style_setting); ?>
    
    <!-- 文章结构化数据 -->
    <?php if (!empty($currentPost)): ?>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": "<?= htmlspecialchars($currentPost['title'] ?? '') ?>",
        "description": "<?= htmlspecialchars($currentPost['summary'] ?? '') ?>",
        "datePublished": "<?= $currentPost['created_at'] ?? '' ?>",
        "dateModified": "<?= $currentPost['updated_at'] ?? $currentPost['created_at'] ?? '' ?>",
        "author": {
            "@type": "Person",
            "name": "<?= htmlspecialchars($currentPost['author_name'] ?? 'Admin') ?>"
        }
    }
    </script>
    <?php endif; ?>
</head>
<body class="page-blog page-blog-post">
    <!-- Header Region (从首页继承) -->
    <header class="site-header" data-region="header"<?= $isVisualMode ? ' data-slot-name="Header"' : '' ?>>
        <?php $this->renderRegionComponents('header', $headerComponents, $page); ?>
    </header>
    
    <!-- Main Content Region -->
    <main class="site-content blog-content" data-region="content"<?= $isVisualMode ? ' data-slot-name="Content"' : '' ?>>
        <div class="blog-container blog-post-container">
            <?php if (empty($contentComponents)): ?>
                <!-- 无自定义内容组件时显示默认博客详情 -->
                <div class="blog-detail-default">
                    <?php $this->fetch('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/components/content/blog-detail.phtml', [
                        'current_post' => $currentPost,
                        'related_posts' => $relatedPosts,
                        'blog_categories' => $blogCategories,
                        'recent_posts' => $recentPosts,
                        'page' => $page,
                    ]); ?>
                </div>
            <?php else: ?>
                <?php $this->renderRegionComponents('content', $contentComponents, $page); ?>
            <?php endif; ?>
        </div>
    </main>
    
    <!-- Footer Region (从首页继承) -->
    <footer class="site-footer" data-region="footer"<?= $isVisualMode ? ' data-slot-name="Footer"' : '' ?>>
        <?php $this->renderRegionComponents('footer', $footerComponents, $page); ?>
    </footer>
    
    <?php $this->renderFooterScripts($page, $style_setting); ?>
</body>
</html>
