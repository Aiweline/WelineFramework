];

$left = [];
$right = [];
foreach ($faqItems as $index => $item) {
    $entry = [
        'index' => $index,
        'question' => (string)($item['question'] ?? ''),
        'answer' => (string)($item['answer'] ?? ''),
    ];
    if ($index % 2 === 0) {
        $left[] = $entry;
    } else {
        $right[] = $entry;
    }
}

$renderFaq = function (array $item, string $scope) use ($componentId, $firstOpen) {
    $idx = (int)$item['index'];
    $open = $firstOpen && $idx === 0;
    $key = $scope . '-' . $idx;
    ?>
    <article class="rvfaq-item<?= $open ? ' is-open' : '' ?>" data-rvfaq-item="<?= htmlspecialchars($key) ?>">
        <button
            class="rvfaq-question"
            type="button"
            id="<?= $componentId ?>-trigger-<?= htmlspecialchars($key) ?>"
            aria-controls="<?= $componentId ?>-panel-<?= htmlspecialchars($key) ?>"
            aria-expanded="<?= $open ? 'true' : 'false' ?>"
            data-rvfaq-trigger="<?= htmlspecialchars($key) ?>"
        >
            <span class="rvfaq-no"><?= sprintf('%02d', $idx + 1) ?></span>
            <span class="rvfaq-text"><?= htmlspecialchars($item['question']) ?></span>
            <span class="rvfaq-icon" aria-hidden="true"></span>
        </button>

        <div class="rvfaq-answer-wrap<?= $open ? ' is-open' : '' ?>" data-rvfaq-wrap="<?= htmlspecialchars($key) ?>">
            <div
                class="rvfaq-answer"
                id="<?= $componentId ?>-panel-<?= htmlspecialchars($key) ?>"
                role="region"
                aria-labelledby="<?= $componentId ?>-trigger-<?= htmlspecialchars($key) ?>"
                aria-hidden="<?= $open ? 'false' : 'true' ?>"
            >
                <p><?= nl2br(htmlspecialchars($item['answer'])) ?></p>
            </div>
        </div>
    </article>
    <?php
};
