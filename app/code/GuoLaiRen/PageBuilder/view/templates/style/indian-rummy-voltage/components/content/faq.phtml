<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) return;

    var triggers = root.querySelectorAll('[data-rvfaq-trigger]');

    triggers.forEach(function(trigger) {
        trigger.addEventListener('click', function() {
            var key = trigger.getAttribute('data-rvfaq-trigger');
            if (!key) return;

            var item = root.querySelector('[data-rvfaq-item="' + key + '"]');
            var wrap = root.querySelector('[data-rvfaq-wrap="' + key + '"]');
            var panel = root.querySelector('#<?= $componentId ?>-panel-' + key);
            if (!item || !wrap || !panel) return;

            var open = !item.classList.contains('is-open');
            item.classList.toggle('is-open', open);
            wrap.classList.toggle('is-open', open);
            trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
            panel.setAttribute('aria-hidden', open ? 'false' : 'true');
        });
    });
})();
</script>
