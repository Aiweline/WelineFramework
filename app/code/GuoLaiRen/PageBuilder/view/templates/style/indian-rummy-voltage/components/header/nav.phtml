 * navigation.link_color => 链接颜色:color:#ebdcc4
 * navigation.link_hover_color => 链接悬停颜色:color:#f4be52
 * navigation.link_font_size => 链接字号:number:14|px
 * navigation.link_font_weight => 链接字重:number:600
 * navigation.link_gap => 链接间距:number:30|px
 * navigation.padding_x => 水平内边距:number:24|px
 * navigation.padding_y => 垂直内边距:number:12|px
 * navigation.min_height => 最小高度:number:74|px
 * navigation.box_shadow => 阴影:text:0 10px 26px rgba(7, 16, 19, 0.28)
 * navigation.backdrop_blur => 背景模糊:number:8|px
 * navigation.items => 导航项配置:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQs=>/faqs|配置格式：名字=>url，一行一个
 * navigation.use_custom_links => 使用自定义导航:select:yes|yes,no
 * navigation.mobile_title => 移动端菜单标题:text:Quick Route
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:DOWNLOAD APP
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#c9472d
 * download_button.bg_hover_color => 按钮悬停背景色:color:#de6648
 * download_button.text_color => 按钮文字颜色:color:#fff5e6
 * download_button.font_size => 按钮字号:number:12|px
 * download_button.font_weight => 按钮字重:number:700
 * download_button.border_radius => 按钮圆角:number:999|px
 * download_button.padding_x => 按钮水平内边距:number:18|px
 * download_button.padding_y => 按钮垂直内边距:number:10|px
 *
 * @fields_end
 */

$componentId = 'rv-header-nav-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$resolveHeaderValue = static function ($componentKey, $rootKey, $default = '') use ($componentConfig, $styleSettings) {
    $componentValue = array_key_exists($componentKey, $componentConfig) ? $componentConfig[$componentKey] : null;
    $rootValue = array_key_exists($rootKey, $styleSettings) ? $styleSettings[$rootKey] : null;

    if ($rootValue !== null && $rootValue !== '' && ($componentValue === null || $componentValue === '' || $componentValue === $default)) {
        return $rootValue;
    }
    if ($componentValue !== null && $componentValue !== '') {
        return $componentValue;
    }
    if ($rootValue !== null && $rootValue !== '') {
        return $rootValue;
    }

    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$parseResponsive = function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim($parts[0] ?? ''),
        'desktop' => trim($parts[1] ?? ($parts[0] ?? '')),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = function ($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/indian-rummy-voltage/asset/img/logo-icon-128.avif');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '70/70') . 'px'));
$logoHeightConfig = $getConfigAny(['logo.height', 'header.logo.height'], '');
$logoHeight = empty($logoHeightConfig) ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));
$brandName = trim((string) $resolveHeaderValue('logo.text', 'header.logo.text', 'Indian Rummy Voltage'));
if ($brandName === '') {
    $brandName = trim((string) $getConfigAny(['texts.app_name', 'app_info.app_name'], ''));
}
if ($brandName === '') {
    $brandName = 'Indian Rummy Voltage';
}
$brandSubline = trim((string) $resolveHeaderValue('logo.subline', 'header.logo.subline', ''));

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], '#0f2c34');
$navBgColorScrolled = $getConfig('navigation.bg_color_scrolled', 'rgba(15, 44, 52, 0.96)');
$navTextColor = $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#f9ecd7');
$linkColor = $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#ebdcc4');
$linkHoverColor = $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#f4be52');
$linkFontSize = $getConfig('navigation.link_font_size', '14');
$linkFontWeight = $getConfig('navigation.link_font_weight', '600');
$linkGap = $getConfig('navigation.link_gap', '30');
$navPaddingX = $getConfig('navigation.padding_x', '24');
$navPaddingY = $getConfig('navigation.padding_y', '12');
$navMinHeight = $getConfig('navigation.min_height', '74');
$navBoxShadow = $getConfig('navigation.box_shadow', '0 10px 26px rgba(7, 16, 19, 0.28)');
$navBackdropBlur = $getConfig('navigation.backdrop_blur', '8');
$mobileMenuTitle = trim((string) $getConfig('navigation.mobile_title', 'Quick Route'));
$useCustomLinksRaw = $getConfig('navigation.use_custom_links', '');
if ($useCustomLinksRaw !== '') {
    $useCustomLinks = $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes';
} else {
    $useCustomLinks = $normalizeToggle($getConfig('navigation.use_subpages', 'no'), 'no') !== 'yes';
}

$navItems = [];
if (!$useCustomLinks && $page) {
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $navigationPages = $page->getHeaderNavigationPages(12);
    } else {
        $navigationPages = $page->getNavigationPages([], 12);
    }
    foreach ($navigationPages as $navPage) {
        $pageType = trim((string) ($navPage['type'] ?? ''));
        $label = trim((string) $getConfigAny([
            'navigation.label_' . $pageType,
            'header.navigation.label_' . $pageType,
        ], ''));
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}
if (empty($navItems)) {
    $navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $text = trim((string)($parts[0] ?? ''));
        $href = trim((string)($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }
        if ($href === '') {
            $href = '#';
        }
        $navItems[] = ['text' => $text, 'href' => $href];
    }
}
if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

$normalizePath = function ($path) {
    $path = trim((string)$path);
    if ($path === '') {
        return '/';
    }
    $path = '/' . ltrim($path, '/');
    if (strlen($path) > 1) {
        $path = rtrim($path, '/');
    }
    return $path;
};

$requestPath = '/';
$rawRequestUri = (string) \w_env('request.uri', '');
if ($rawRequestUri !== '') {
    $parsedRequestPath = parse_url($rawRequestUri, PHP_URL_PATH);
    if (is_string($parsedRequestPath) && $parsedRequestPath !== '') {
        $requestPath = $parsedRequestPath;
    }
}
$currentPath = $normalizePath($requestPath);

$hasActiveNav = false;
foreach ($navItems as $navIndex => $navItem) {
    $href = isset($navItem['href']) ? (string)$navItem['href'] : '';
    $path = parse_url($href, PHP_URL_PATH);
    $targetPath = is_string($path) && $path !== '' ? $normalizePath($path) : '';
    $isAnchor = strpos($href, '#') === 0;
    $isActive = !$isAnchor && $targetPath !== '' && $targetPath === $currentPath;
    $navItems[$navIndex]['is_active'] = $isActive;
    if ($isActive) {
        $hasActiveNav = true;
    }
}
if (!$hasActiveNav && !empty($navItems)) {
    $navItems[0]['is_active'] = true;
}

$leftCount = count($navItems) > 1 ? (int)ceil(count($navItems) / 2) : count($navItems);
$leftNavItems = array_slice($navItems, 0, $leftCount);
$rightNavItems = array_slice($navItems, $leftCount);
if (empty($rightNavItems) && count($leftNavItems) > 1) {
    $rightNavItems[] = array_pop($leftNavItems);
}

$downloadBtnDisplay = $getConfig('download_button.display', 'yes') !== 'no';
$downloadBtnText = $getConfig('download_button.text', 'DOWNLOAD APP');
$downloadBtnUrl = $getConfig('download_button.url', '#download');
$downloadBtnBgColor = $getConfig('download_button.bg_color', '#c9472d');
$downloadBtnBgHoverColor = $getConfig('download_button.bg_hover_color', '#de6648');
$downloadBtnTextColor = $getConfig('download_button.text_color', '#fff5e6');
$downloadBtnFontSize = $getConfig('download_button.font_size', '12');
$downloadBtnFontWeight = $getConfig('download_button.font_weight', '700');
$downloadBtnRadius = $getConfig('download_button.border_radius', '999');
$downloadBtnPaddingX = $getConfig('download_button.padding_x', '18');
$downloadBtnPaddingY = $getConfig('download_button.padding_y', '10');

$standaloneShell = !$this->getData('__rv_shell_managed');
$pageTitle = $page ? (string)($page->getData('meta_title') ?: $page->getData('title') ?: $brandName) : $brandName;
?>
