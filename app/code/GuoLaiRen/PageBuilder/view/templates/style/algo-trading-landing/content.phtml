<script>
document.addEventListener('DOMContentLoaded', function() {
    var selector = '.algo-cta-middle .algo-cta-button, .algo-cta-why .algo-cta-button, .algo-final-cta .algo-cta-button';
    var ctas = document.querySelectorAll(selector);
    if (!ctas || ctas.length === 0) return;
    ctas.forEach(function(btn) {
        var handle = btn.getAttribute('data-handle') || 'handle_cta';
        btn.addEventListener('click', function() {
            // 使用通用跟踪函数
            window.trackEvent(handle);
        }, { once: false });
    });
});
</script>

