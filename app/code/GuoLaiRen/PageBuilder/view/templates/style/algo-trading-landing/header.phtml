function getAlgoConfig($settings, $key, $default = '') {
    $value = $settings[$key] ?? $default;
    // 如果值为空字符串，使用默认值
    return ($value === '' && $default !== '') ? $default : $value;
}

function parseAlgoResponsive($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => ''];
    $value = trim($value);
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
    switch (count($parts)) {
        case 1: $result['mobile'] = $result['desktop'] = trim($parts[0]); break;
        case 2: $result['mobile'] = trim($parts[0]); $result['desktop'] = trim($parts[1]); break;
    }
    return $result;
}

function genAlgoCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
}

