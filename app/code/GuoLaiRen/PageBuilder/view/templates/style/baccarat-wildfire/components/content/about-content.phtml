$componentId = 'bwf-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'yes') !== 'no';
$showCta = $getConfig('display.show_cta', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$heroTitle = trim((string) $getConfig('hero.title', $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'About Baccarat Wildfire';
}
$heroSubtitle = trim((string) $getConfig('hero.subtitle', 'A baccarat hub built for quick table selection, readable room signals, and steady mobile play.'));
$heroPadding = max(52, (int) $getConfig('hero.padding', 88));

$storyTitle = trim((string) $getConfig('story.title', 'Built For Quick Baccarat Sessions'));
$storySubtitle = trim((string) $getConfig('story.subtitle', 'A clear landing flow helps players compare rooms, reach support, and move into play with less friction.'));
$storyContent = trim((string) $getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Baccarat Wildfire is designed for sites that want a brighter baccarat presentation without losing focus on live tables, room comparison, and trust-led support information.';
}
$storyParagraphs = preg_split('/[\r\n]+/', $storyContent);
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs)) {
    $storyParagraphs = [$storyContent];
}

$stats = [];
$defaultStats = [
    ['24/7', 'Support desk'],
    ['1-Tap', 'Lobby-to-table entry'],
    ['3-Step', 'Deposit to seat flow'],
    ['Mobile', 'Responsive table browsing'],
];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $defaultStats[$i - 1][0]));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $defaultStats[$i - 1][1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'number' => $number,
        'label' => $label,
    ];
}

$valuesTitle = trim((string) $getConfig('values.title', 'What Players Expect Here'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'These blocks explain how the platform approaches room clarity, support access, and responsible play.'));
$defaultValues = [
    ['☀️', 'Clear Table Signals', 'Room cards highlight pace, entry point, and baccarat mode so players can compare options quickly.'],
    ['🔥', 'Smooth Mobile Flow', 'Spacing and touch areas stay comfortable on smaller screens, from the first CTA to the table list.'],
    ['🛡️', 'Support And Fair Play', 'Policy links, help routes, and responsible-play references stay easy to find when players need them.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $title = trim((string) $getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $desc = trim((string) $getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($title === '' && $desc === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string) $getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
        'title' => $title,
        'description' => $desc,
    ];
}

$teamTitle = trim((string) $getConfig('team.title', 'Teams Behind The Tables'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', 'Dedicated desks support account access, payment questions, fair play reviews, and content updates.'));
$defaultMembers = [
    ['🛎️', 'Support Desk', 'Gameplay and login help'],
    ['💳', 'Payments Desk', 'Deposit and withdrawal review'],
    ['🛡️', 'Fair Play Desk', 'Rule guidance and account checks'],
    ['✍️', 'Content Desk', 'Guides and update notices'],
];
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $name = trim((string) $getConfig("team.member_{$i}_name", $defaultMembers[$i - 1][1]));
    $role = trim((string) $getConfig("team.member_{$i}_role", $defaultMembers[$i - 1][2]));
    if ($name === '' && $role === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => trim((string) $getConfig("team.member_{$i}_icon", $defaultMembers[$i - 1][0])),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string) $getConfig('cta.title', 'Need help before joining a table?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Reach the support team for account access, payment questions, table guidance, or responsible-play help.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact'));

$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#fff7ed');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe8d1');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#3f2418');
$heroTextColor = (string) $getConfig('hero.text_color', $colors['text_secondary'] ?? '#6f4b37');
$storyBg = (string) $getConfig('story.bg_color', $colors['section_bg_2'] ?? '#fff4e6');
$storyTitleColor = (string) $getConfig('story.title_color', $colors['accent_secondary'] ?? '#b5482a');
$valuesBg = (string) $getConfig('values.bg_color', $colors['section_bg_3'] ?? '#fff1e1');
$statsCardBg = (string) $getConfig('stats.card_bg', $colors['card_bg'] ?? 'rgba(255,250,244,0.9)');
$statsNumberColor = (string) $getConfig('stats.number_color', $colors['accent_primary'] ?? '#f3b53f');
$statsLabelColor = (string) $getConfig('stats.label_color', $colors['text_muted'] ?? '#8f725f');
$ctaButtonBg = (string) $getConfig('cta.button_bg', $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f3b53f 0%, #d95438 100%)');
$ctaButtonTextColor = (string) $getConfig('cta.button_text_color', $colors['button_primary_text'] ?? '#fff7ed');
?>

<section
    id="<?= $componentId ?>"
    class="bwf-about"
    style="--bwf-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-stats-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-stat-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-stat-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-about-hero-padding: <?= (int) $heroPadding ?>px;"
>
    <div class="about-shell">
        <header class="about-hero<?= ($showStats && !empty($stats)) ? ' has-snapshot' : '' ?>">
            <div class="hero-copy">
                <span class="hero-flare" aria-hidden="true"></span>
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <?php if ($heroSubtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($heroSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="hero-lane">
                <div class="story-panel">
                    <?php if ($storyTitle !== ''): ?>
                        <span class="story-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                    <?php endif; ?>
                    <?php if ($storySubtitle !== ''): ?>
                        <h2><?= htmlspecialchars($storySubtitle) ?></h2>
                    <?php endif; ?>
                    <div class="story-copy">
                        <?php foreach ($storyParagraphs as $paragraph): ?>
                            <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                        <?php endforeach; ?>
                    </div>
                </div>

                <?php if ($showStats && !empty($stats)): ?>
                    <aside class="snapshot-stack" aria-label="Brand statistics">
                        <?php $leadStat = $stats[0] ?? null; ?>
                        <?php $trailStats = array_slice($stats, 1); ?>

                        <?php if ($leadStat): ?>
                            <article class="lead-stat">
                                <span class="stat-overline"><?= __('Wildfire Snapshot') ?></span>
                                <strong><?= htmlspecialchars($leadStat['number']) ?></strong>
                                <span class="stat-caption"><?= htmlspecialchars($leadStat['label']) ?></span>
                            </article>
                        <?php endif; ?>

                        <?php if (!empty($trailStats)): ?>
                            <div class="stat-grid">
                                <?php foreach ($trailStats as $stat): ?>
                                    <article class="stat-card">
                                        <strong><?= htmlspecialchars($stat['number']) ?></strong>
                                        <span><?= htmlspecialchars($stat['label']) ?></span>
                                    </article>
                                <?php endforeach; ?>
                            </div>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        </header>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage">
                <div class="values-header">
                    <?php if ($valuesTitle !== ''): ?>
                        <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <?php $cardClass = $index === 0 ? ' is-featured' : (($index % 3 === 2) ? ' is-tall' : ''); ?>
                        <article class="value-card<?= $cardClass ?>">
                            <div class="value-mark"><?= htmlspecialchars($value['icon']) ?></div>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <p><?= htmlspecialchars($value['description']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showTeam && !empty($teamMembers)): ?>
            <section class="team-stage">
                <div class="team-header">
                    <?php if ($teamTitle !== ''): ?>
                        <h2><?= htmlspecialchars($teamTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="team-grid">
                    <?php foreach ($teamMembers as $member): ?>
                        <article class="team-card">
                            <span class="team-icon"><?= htmlspecialchars($member['icon']) ?></span>
                            <h3><?= htmlspecialchars($member['name']) ?></h3>
                            <p><?= htmlspecialchars($member['role']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
            <section class="cta-band">
                <div class="cta-copy">
                    <?php if ($ctaTitle !== ''): ?>
                        <h2><?= htmlspecialchars($ctaTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription) ?></p>
                    <?php endif; ?>
                </div>
                <?php if ($ctaButtonText !== ''): ?>
                    <a href="<?= htmlspecialchars($ctaButtonUrl) ?>" class="cta-link"><?= htmlspecialchars($ctaButtonText) ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>

