$cardTitleColor = $getConfig('style.card_title_color', '#171117');
$cardDescColor = $getConfig('style.card_desc_color', '#5d4650');
$sectionPadding = (int)$getConfig('style.section_padding', '88');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '52');
$cardGap = (int)$getConfig('style.card_gap', '24');

$title = $getConfig('texts.title', 'Why Baccarat Wildfire Changes The Pace');
$items = [
    [
        'icon' => $getConfig('texts.advantage_1_icon', '♠'),
        'title' => $getConfig('texts.advantage_1_title', 'Sharper Table Picking'),
        'desc' => $getConfig('texts.advantage_1_desc', 'Room choices are framed with stronger contrast so players can compare pace, limits, and table mood faster.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_2_icon', '✦'),
        'title' => $getConfig('texts.advantage_2_title', 'High Contrast Reading'),
        'desc' => $getConfig('texts.advantage_2_desc', 'Important baccarat actions stay clearer on bright screens and smaller devices without losing atmosphere.'),
