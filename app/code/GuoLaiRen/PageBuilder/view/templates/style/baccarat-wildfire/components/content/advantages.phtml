        'title' => $getConfig('texts.advantage_3_title', 'Cleaner Mobile Movement'),
        'desc' => $getConfig('texts.advantage_3_desc', 'Touch targets, spacing, and visual rhythm are tuned for players jumping from landing page to live room.'),
    ],
];
