<script>
(function() {
    const section = document.getElementById('<?= $componentId ?>');
    if (!section) {
        return;
    }

    const triggers = Array.from(section.querySelectorAll('[data-faq-trigger]'));
    const wraps = Array.from(section.querySelectorAll('[data-faq-panel-wrap]'));
    const panels = Array.from(section.querySelectorAll('[data-faq-panel]'));

    const closeAll = () => {
        triggers.forEach((trigger) => {
            trigger.classList.remove('is-active');
            trigger.setAttribute('aria-expanded', 'false');
        });
        wraps.forEach((wrap) => {
            wrap.classList.remove('is-open');
            wrap.setAttribute('aria-hidden', 'true');
        });
        panels.forEach((panel) => {
            panel.setAttribute('tabindex', '-1');
        });
        section.querySelectorAll('.faq-card').forEach((card) => card.classList.remove('is-open'));
    };

    triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
            const index = trigger.getAttribute('data-faq-trigger');
            const card = trigger.closest('.faq-card');
            const wrap = section.querySelector('[data-faq-panel-wrap="' + index + '"]');
            const panel = section.querySelector('[data-faq-panel="' + index + '"]');
            const shouldOpen = !trigger.classList.contains('is-active');

            closeAll();

            if (!shouldOpen || !wrap || !panel || !card) {
                return;
            }

            trigger.classList.add('is-active');
            trigger.setAttribute('aria-expanded', 'true');
            wrap.classList.add('is-open');
            wrap.setAttribute('aria-hidden', 'false');
            panel.setAttribute('tabindex', '0');
            card.classList.add('is-open');
        });
    });
})();
</script>
