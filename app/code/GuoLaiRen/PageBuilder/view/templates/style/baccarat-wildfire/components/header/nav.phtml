/**
 * Baccarat Wildfire - Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航栏
 * name_en: Navigation Bar
 * description: 炽焰风格导航，支持移动端菜单与热浪扫描效果
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => 品牌名称:text:Baccarat Wildfire
 * logo.subline => 品牌副标题:text:
 * logo.url => Logo图片:textarea:|留空使用默认图标
 * logo.width => Logo宽度:responsive:52/52|px
 * logo.height => Logo高度:responsive:52/52|px
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景基础色:color:rgba(255,248,242,0.8)
 * navigation.bg_color_scrolled => 滚动后导航背景色:color:rgba(255,248,242,0.92)
 * navigation.text_color => 导航文字颜色:color:#171117
 * navigation.link_color => 导航链接颜色:color:#5c4149
 * navigation.link_hover_color => 导航链接悬停颜色:color:#bc2832
 * navigation.link_font_size => 导航链接字号:number:13|px
 * navigation.link_font_weight => 导航链接字重:number:800
 * navigation.link_gap => 导航链接间距:number:8|px
 * navigation.padding_x => 导航左右内边距:number:16|px
 * navigation.padding_y => 导航上下内边距:number:14|px
 * navigation.min_height => 导航最小高度:number:72|px
 * navigation.box_shadow => 导航阴影:text:0 18px 48px rgba(76,22,34,0.08)
 * navigation.backdrop_blur => 导航背景模糊:number:18|px
 * navigation.use_custom_links => 使用自定义导航:select:yes|yes,no
 * navigation.items => 导航项:textarea:Home=>/\r\nTables=>#tables\r\nWhy Us=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|配置格式：名字=>url，一行一个。URL为空时自动补#
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * navigation.use_subpages => 兼容旧版-使用子页面生成导航:select:no|yes,no
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文字:text:Enter Table
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff5f3a
 * download_button.bg_hover_color => 按钮悬停背景色:color:#08e7d8
 * download_button.text_color => 按钮文字颜色:color:#140b11
 * download_button.font_size => 按钮字号:number:14|px
 * download_button.font_weight => 按钮字重:number:900
 * download_button.border_radius => 按钮圆角:number:999|px
 * download_button.padding_x => 按钮左右内边距:number:16|px
 * download_button.padding_y => 按钮上下内边距:number:10|px
 * @fields_end
 */

$componentId = 'bwf-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$standaloneShell = !($this->getData('__pagebuilder_shell_managed') || $this->getData('__bwf_shell_managed'));

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$sanitizeTitle = function($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string) $value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string) ($parts[0] ?? '')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function ($parsed) {
    $mobile = (float) $parsed['mobile'];
    $desktop = (float) $parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name'], 'Baccarat Wildfire'));
if ($logoText === '') {
    $logoText = 'Baccarat Wildfire';
}
$logoSubline = trim((string) $getConfigAny(['logo.subline', 'header.logo.subline'], ''));
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/baccarat-wildfire/asset/img/wildfire-logo-icon.svg');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '52/52') . 'px'));
$logoHeight = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.height', 'header.logo.height'], '52/52') . 'px'));

$navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nTables=>#tables\nWhy Us=>#advantages\nReviews=>#reviews\nFAQ=>#faq");
$useCustomLinksRaw = $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], '');
$legacyUseSubpagesRaw = $getConfig('navigation.use_subpages', '');
if ($useCustomLinksRaw !== '') {
    $useCustomLinks = $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes';
} elseif ($legacyUseSubpagesRaw !== '') {
    $useCustomLinks = $normalizeToggle($legacyUseSubpagesRaw, 'no') !== 'yes';
} else {
    $useCustomLinks = true;
}
$ctaDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Enter Table'));
$ctaUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download'));
$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], 'rgba(255,248,242,0.8)');
$navBgColorScrolled = (string) $getConfig('navigation.bg_color_scrolled', 'rgba(255,248,242,0.92)');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#171117');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#5c4149');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#bc2832');
$navLinkFontSize = (int) $getConfig('navigation.link_font_size', '13');
$navLinkFontWeight = (int) $getConfig('navigation.link_font_weight', '800');
$navLinkGap = (int) $getConfig('navigation.link_gap', '8');
$navPaddingX = (int) $getConfig('navigation.padding_x', '16');
$navPaddingY = (int) $getConfig('navigation.padding_y', '14');
$navMinHeight = (int) $getConfig('navigation.min_height', '72');
$navBoxShadow = (string) $getConfig('navigation.box_shadow', '0 18px 48px rgba(76,22,34,0.08)');
$navBackdropBlur = (int) $getConfig('navigation.backdrop_blur', '18');
$ctaBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff5f3a');
$ctaBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.bg_hover_color'], '#08e7d8');
$ctaTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#140b11');
$ctaFontSize = (int) $getConfig('download_button.font_size', '14');
$ctaFontWeight = (int) $getConfig('download_button.font_weight', '900');
$ctaRadius = (int) $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '999');
$ctaPaddingX = (int) $getConfig('download_button.padding_x', '16');
$ctaPaddingY = (int) $getConfig('download_button.padding_y', '10');
$navItems = [];

$pageTitleRaw = $page ? ($page->getData('title') ?: '') : '';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'Baccarat Wildfire';
}

if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $type = trim((string) ($navPage['type'] ?? ''));
        $label = $type !== '' ? trim((string) $getConfig('navigation.label_' . $type, '')) : '';
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim($line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}
?>
