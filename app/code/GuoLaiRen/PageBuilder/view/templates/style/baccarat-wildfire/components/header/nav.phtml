        transition: none;
    }
}
</style>

<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    const toggle = root.querySelector('.nav-toggle');
    const panel = root.querySelector('.mobile-panel');
    const desktopMq = window.matchMedia('(min-width: 961px)');
    const navLinks = Array.from(root.querySelectorAll('[data-nav-link]'));
    let closeTimer = null;

    const closePanel = () => {
        if (!toggle || !panel) {
            return;
        }
        clearTimeout(closeTimer);
        toggle.setAttribute('aria-expanded', 'false');
        root.classList.remove('is-open');
        root.dataset.mobileOpen = 'false';
        closeTimer = window.setTimeout(() => {
            if (root.dataset.mobileOpen !== 'true') {
                panel.classList.add('is-hidden');
            }
        }, 260);
    };

    const openPanel = () => {
        if (!toggle || !panel) {
            return;
        }
        clearTimeout(closeTimer);
        panel.classList.remove('is-hidden');
        toggle.setAttribute('aria-expanded', 'true');
        root.dataset.mobileOpen = 'true';
        requestAnimationFrame(() => {
            root.classList.add('is-open');
        });
    };

    const normalizePath = (value) => {
        const cleaned = (value || '').replace(/\/+$/, '');
        return cleaned === '' ? '/' : cleaned;
    };

    const setActiveHref = (href) => {
        navLinks.forEach((link) => {
            const linkHref = link.getAttribute('data-nav-href') || link.getAttribute('href') || '';
            link.classList.toggle('is-current', linkHref === href);
        });
    };

    const currentPath = normalizePath(window.location.pathname);
    const sectionLinks = navLinks
        .map((link) => {
            const href = link.getAttribute('data-nav-href') || link.getAttribute('href') || '';
            if (!href || href.charAt(0) !== '#') {
                return null;
            }
            const target = document.querySelector(href);
            return target ? { href, target } : null;
        })
        .filter(Boolean);

    const updateActiveLink = () => {
        if (currentPath !== '/') {
            const matched = navLinks.find((link) => {
                const href = link.getAttribute('data-nav-href') || link.getAttribute('href') || '';
                if (!href || href.charAt(0) === '#') {
                    return false;
                }
                return normalizePath(href) === currentPath;
            });
            if (matched) {
                setActiveHref(matched.getAttribute('data-nav-href') || matched.getAttribute('href') || '');
            }
            return;
        }

        let activeHref = '/';
        const offset = 140;
        sectionLinks.forEach(({ href, target }) => {
            const rect = target.getBoundingClientRect();
            if (rect.top <= offset) {
                activeHref = href;
            }
        });
        setActiveHref(activeHref);
    };

    if (toggle && panel) {
        toggle.addEventListener('click', () => {
            const expanded = toggle.getAttribute('aria-expanded') === 'true';
            if (expanded) {
                closePanel();
            } else {
                openPanel();
            }
        });

        panel.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', closePanel);
        });

        document.addEventListener('click', (event) => {
            if (root.dataset.mobileOpen === 'true' && !root.contains(event.target)) {
                closePanel();
            }
        });

        const syncDesktop = (event) => {
            if (event.matches) {
                closePanel();
            }
        };

        if (desktopMq.addEventListener) {
            desktopMq.addEventListener('change', syncDesktop);
        } else if (desktopMq.addListener) {
            desktopMq.addListener(syncDesktop);
        }
    }

    navLinks.forEach((link) => {
        link.addEventListener('click', () => {
            const href = link.getAttribute('data-nav-href') || link.getAttribute('href') || '';
            setActiveHref(href);
        });
    });

    const syncScrolled = () => {
        root.classList.toggle('is-scrolled', window.scrollY > 12);
    };

    updateActiveLink();
    syncScrolled();
    window.addEventListener('scroll', updateActiveLink, { passive: true });
    window.addEventListener('scroll', syncScrolled, { passive: true });
    window.addEventListener('hashchange', updateActiveLink);
})();
</script>
