                    <button type="button" class="voice-arrow" data-voice-next aria-label="Next reviews"><span>›</span></button>
                </div>
            </div>
        </div>

        <div class="voices-rail" data-voices-rail>
            <?php foreach ($testimonials as $index => $item): ?>
                <article class="voice-card voice-card-<?= (int)(($index % 4) + 1) ?>">
                    <div class="voice-card-inner">
                        <div class="voice-top-row">
                            <?php if ($showAvatar): ?>
                                <div class="voice-avatar">
                                    <?php if (!empty($item['avatar'])): ?>
                                        <img src="<?= htmlspecialchars($item['avatar']) ?>" alt="<?= htmlspecialchars($item['name']) ?>">
                                    <?php else: ?>
                                        <?= htmlspecialchars($buildInitials($item['name'])) ?>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>

                            <div class="voice-meta">
                                <strong><?= htmlspecialchars($item['name']) ?></strong>
                                <?php if ($item['tag'] !== ''): ?>
                                    <span><?= htmlspecialchars($item['tag']) ?></span>
                                <?php endif; ?>
                            </div>
                        </div>

                        <?php if ($showRating): ?>
                            <div class="voice-rating"><?= htmlspecialchars($item['rating_text']) ?></div>
                        <?php endif; ?>

                        <p><?= htmlspecialchars($item['text']) ?></p>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

