            <?php if ($showTitle): ?>
                <header class="voices-header" id="reviews">
                    <div class="voices-title-wrap">
                        <span class="voices-title-mark" aria-hidden="true">
                            <span class="signal-bar signal-low"></span>
                            <span class="signal-bar signal-mid"></span>
                            <span class="signal-bar signal-high"></span>
                            <span class="signal-dot"></span>
                        </span>
                        <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                    </div>
                </header>
            <?php endif; ?>

            <div class="voices-tools<?= !$showAvg ? ' no-summary' : '' ?>">
                <?php if ($showAvg): ?>
                    <div class="voices-summary">
                        <?php if ($showRating): ?>
                            <span class="summary-stars"><?= htmlspecialchars(str_repeat('★', max(1, (int)round($avgRating)))) ?></span>
                        <?php endif; ?>
                        <strong><?= htmlspecialchars($avgRatingLabel) ?></strong>
                        <small><?= (int) count($testimonials) ?></small>
                    </div>
                <?php endif; ?>

                <div class="voices-controls">
