    padding: clamp(1.4rem, 3vw, 2.2rem);
    border-radius: 34px 54px 30px 30px;
    background: linear-gradient(160deg, rgba(255,255,255,0.96) 0%, rgba(255,244,235,0.92) 100%);
}

#<?= $componentId ?> .hero-card::after {
    content: '';
    position: absolute;
    right: -44px;
    top: -46px;
    width: 170px;
    height: 170px;
    border-radius: 46% 54% 60% 40% / 46% 36% 64% 54%;
    background: radial-gradient(circle, rgba(255,179,71,0.2) 0%, rgba(255,179,71,0.02) 72%, transparent 80%);
}

#<?= $componentId ?> .hero-icon {
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(255,95,58,0.12) 0%, rgba(8,231,216,0.12) 100%);
    font-size: 1.4rem;
}

#<?= $componentId ?> .hero-card h1 {
    margin-top: 1rem;
    color: var(--bwf-legal-hero-title);
    font-family: 'Outfit', 'Manrope', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4.1rem);
    line-height: 0.94;
    letter-spacing: -0.07em;
}

#<?= $componentId ?> .last-updated {
    margin-top: 0.9rem;
    color: #6b4a3b;
    line-height: 1.8;
}

#<?= $componentId ?> .legal-layout {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: minmax(220px, 0.28fr) minmax(0, 0.72fr);
    gap: 1rem;
    align-items: start;
}

#<?= $componentId ?> .legal-layout:not(.has-toc) {
    grid-template-columns: 1fr;
}

#<?= $componentId ?> .legal-toc {
    position: sticky;
    top: 6.3rem;
}

#<?= $componentId ?> .toc-card {
    padding: 1rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, var(--bwf-legal-toc-bg) 100%);
}

