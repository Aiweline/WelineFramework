    display: inline-flex;
    align-items: center;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8b6756;
}

#<?= $componentId ?> .toc-links {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.46rem;
}

#<?= $componentId ?> .toc-link {
    display: block;
    padding: 0.62rem 0.78rem;
    border-radius: 16px;
    text-decoration: none;
    color: #3b2426;
    background: rgba(35,21,27,0.04);
    border: 1px solid rgba(35,21,27,0.06);
}

#<?= $componentId ?> .toc-link.level-3 {
    margin-left: 0.8rem;
    font-size: 0.92rem;
    opacity: 0.82;
}

#<?= $componentId ?> .legal-content {
    padding: var(--bwf-legal-content-padding);
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, var(--bwf-legal-content-bg) 100%);
    color: var(--bwf-legal-content-text);
    line-height: 1.84;
}

#<?= $componentId ?> .legal-content h1,
#<?= $componentId ?> .legal-content h2,
#<?= $componentId ?> .legal-content h3,
#<?= $componentId ?> .legal-content h4 {
    color: var(--bwf-legal-heading);
    font-family: 'Outfit', 'Manrope', sans-serif;
    letter-spacing: -0.04em;
}

#<?= $componentId ?> .legal-content h2,
#<?= $componentId ?> .legal-content h3 {
    scroll-margin-top: 6.5rem;
}

#<?= $componentId ?> .legal-content a {
    color: var(--bwf-legal-link);
}

#<?= $componentId ?> .legal-content table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
}

#<?= $componentId ?> .legal-content table th,
#<?= $componentId ?> .legal-content table td {
    padding: 0.72rem 0.76rem;
    border: 1px solid rgba(63,36,24,0.08);
}

@media (max-width: 980px) {
    #<?= $componentId ?> .legal-layout {
        grid-template-columns: 1fr;
    }

    #<?= $componentId ?> .legal-toc {
        position: static;
    }
}

@media (max-width: 640px) {
    #<?= $componentId ?> {
        padding: 3.4rem 0 4rem;
    }

    #<?= $componentId ?> .legal-shell {
        width: min(100% - 0.9rem, 100%);
    }

    #<?= $componentId ?> .hero-card,
    #<?= $componentId ?> .toc-card,
    #<?= $componentId ?> .legal-content {
        border-radius: 24px;
    }

    #<?= $componentId ?> .legal-content {
        padding: 1rem;
    }
}
</style>
