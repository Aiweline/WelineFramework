<?php
/**
 * Baccarat Wildfire - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录和更新时间显示
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:52|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.updated_label => 更新时间前缀:text:Last Updated
 * header.bg_color => 背景色:color:#fff7ed
 * header.bg_gradient_end => 渐变结束色:color:#ffe8d1
 * header.title_color => 标题颜色:color:#3f2418
 * header.text_color => 文字颜色:color:#6f4b37
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.items => 章节:textarea:标题|段落内容，一行一节（当页面内容为空时由配置渲染）
 * toc.bg_color => 目录背景色:color:rgba(255,250,244,0.92)
 * toc.border_color => 目录边框色:color:rgba(122,161,192,0.22)
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:（当页面内容为空时显示）
 * content.empty_text => 空内容提示:text:Content will be displayed here.
 * content.bg_color => 内容区背景色:color:#fff8f0
 * content.text_color => 内容文字颜色:color:#6f4b37
 * content.heading_color => 标题颜色:color:#3f2418
 * content.link_color => 链接颜色:color:#d95438
 *
 * @fields_end
 */

$componentId = 'bwf-legal-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string) $getConfig('layout.content_width', 'narrow');
$headerPadding = max(48, (int) $getConfig('layout.header_padding', 80));
$contentPadding = max(28, (int) $getConfig('layout.content_padding', 52));

$pageType = $page ? (string) ($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string) ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$headerTitle = trim((string) $getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$headerIcon = trim((string) $getConfig('header.icon', $typeIcons[$pageType] ?? '📄'));
$updatedLabelPrefix = trim((string) $getConfig('header.updated_label', 'Last Updated'));
$tocTitle = trim((string) $getConfig('toc.title', 'On This Page'));
$fallbackTocRaw = trim((string) $getConfig('toc.items', ''));
$fallbackBody = trim((string) $getConfig('content.body', ''));
$emptyText = trim((string) $getConfig('content.empty_text', 'Content will be displayed here.'));

$heroBg = (string) $getConfig('header.bg_color', $colors['hero_bg'] ?? '#fff7ed');
$heroBgEnd = (string) $getConfig('header.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe8d1');
$heroTitleColor = (string) $getConfig('header.title_color', $colors['text_primary'] ?? '#3f2418');
$heroTextColor = (string) $getConfig('header.text_color', $colors['text_secondary'] ?? '#6f4b37');
$tocBg = (string) $getConfig('toc.bg_color', $colors['card_bg'] ?? 'rgba(255,250,244,0.92)');
$tocBorder = (string) $getConfig('toc.border_color', $colors['border_light'] ?? 'rgba(122,161,192,0.22)');
$contentBg = (string) $getConfig('content.bg_color', $colors['section_bg_2'] ?? '#fff8f0');
$contentText = (string) $getConfig('content.text_color', $colors['text_secondary'] ?? '#6f4b37');
$contentHeading = (string) $getConfig('content.heading_color', $colors['text_primary'] ?? '#3f2418');
$contentLink = (string) $getConfig('content.link_color', $colors['accent_secondary'] ?? '#d95438');

$maxWidth = match ($contentWidth) {
    'wide' => '1180px',
    'medium' => '980px',
    default => '820px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($pageContent === '' && ($fallbackBody !== '' || $fallbackTocRaw !== '')) {
    $rebuiltContent = [];
    if ($fallbackBody !== '') {
        $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($fallbackBody)) . '</p>';
    }
    foreach (preg_split('/[\r\n]+/', $fallbackTocRaw) as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $sectionTitle = trim((string) ($parts[0] ?? ''));
        $sectionBody = trim((string) ($parts[1] ?? ''));
        if ($sectionTitle === '') {
            continue;
        }
        $rebuiltContent[] = '<h2>' . htmlspecialchars($sectionTitle) . '</h2>';
        if ($sectionBody !== '') {
            $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($sectionBody)) . '</p>';
        }
    }
    $pageContent = implode('', $rebuiltContent);
}
if ($showToc && $pageContent !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int) $matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (++$headingIndex);

        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContent);
}

$hasToc = $showToc && !empty($tocItems);
?>

<section
    id="<?= $componentId ?>"
    class="bwf-legal"
    style="--bwf-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --bwf-legal-header-padding: <?= (int) $headerPadding ?>px; --bwf-legal-content-padding: <?= (int) $contentPadding ?>px; --bwf-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="legal-shell">
        <header class="legal-hero">
            <div class="hero-card">
                <?php if ($showIcon && $headerIcon !== ''): ?>
                    <span class="hero-icon"><?= htmlspecialchars($headerIcon) ?></span>
                <?php endif; ?>
                <h1><?= htmlspecialchars($headerTitle) ?></h1>
                <?php if ($showLastUpdated && $lastUpdated !== ''): ?>
                    <p class="last-updated"><?= htmlspecialchars($updatedLabelPrefix !== '' ? $updatedLabelPrefix : 'Last Updated') ?>: <?= htmlspecialchars(date('F j, Y', strtotime($lastUpdated))) ?></p>
                <?php endif; ?>
            </div>
        </header>

        <div class="legal-layout<?= $hasToc ? ' has-toc' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-toc" aria-label="<?= htmlspecialchars((string) __('Table of contents')) ?>">
                    <div class="toc-card">
                        <span class="toc-title"><?= htmlspecialchars($tocTitle) ?></span>
                        <nav class="toc-links">
                            <?php foreach ($tocItems as $item): ?>
                                <a href="#<?= htmlspecialchars($item['id']) ?>" class="toc-link level-<?= (int) $item['level'] ?>">
                                    <?= htmlspecialchars($item['text']) ?>
                                </a>
                            <?php endforeach; ?>
                        </nav>
                    </div>
                </aside>
            <?php endif; ?>

            <article class="legal-article<?= !$hasToc ? ' no-toc' : '' ?>">
                <div class="legal-content">
                    <?php if ($pageContent !== ''): ?>
                        <?= $pageContent ?>
                    <?php else: ?>
                        <p><?= htmlspecialchars($emptyText !== '' ? $emptyText : 'Content will be displayed here.') ?></p>
                    <?php endif; ?>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 8vw, 5.6rem) 0;
    background:
        radial-gradient(720px 340px at 10% 0%, rgba(255,95,58,0.12), transparent 70%),
        radial-gradient(620px 280px at 90% 16%, rgba(8,231,216,0.12), transparent 66%),
        linear-gradient(180deg, #fff9f1 0%, #fff4e9 100%);
}

#<?= $componentId ?>::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(63,36,24,0.03) 1px, transparent 1px);
    background-size: 52px 100%;
    opacity: 0.36;
    pointer-events: none;
}

#<?= $componentId ?> .legal-shell {
    width: min(var(--bwf-legal-max-width), calc(100% - 1.2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

#<?= $componentId ?> .hero-card,
#<?= $componentId ?> .toc-card,
#<?= $componentId ?> .legal-content {
    position: relative;
    border: 1px solid rgba(63,36,24,0.08);
    box-shadow: 0 24px 48px rgba(98, 50, 32, 0.08);
}

