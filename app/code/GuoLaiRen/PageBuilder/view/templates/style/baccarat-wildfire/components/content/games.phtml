$componentId = 'bwf-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeLines = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$parseLegacyGames = static function ($value) use ($normalizeLines) {
    $items = [];
    foreach ($normalizeLines($value) as $line) {
        $parts = array_map('trim', explode('|', $line));
        $title = $parts[0] ?? '';
        if ($title === '') {
            continue;
        }
        $items[] = [
            'title' => $title,
            'desc' => $parts[1] ?? '',
            'url' => $parts[2] ?? '#',
        ];
    }
    return $items;
};

$parseLegacyTokenList = static function ($value) {
    $tokens = preg_split('/\|/', str_replace(["\r", "\n"], '|', (string) $value)) ?: [];
    return array_values(array_filter(array_map('trim', $tokens), static function ($item) {
        return $item !== '';
    }));
};

$getLegacyIndexed = static function (array $items, $index, $default = '') {
    return isset($items[$index]) && $items[$index] !== '' ? $items[$index] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfigAny(['display.show_description', 'display.show_subtitle'], 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';
$tableLinkText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'hero.cta_text'], 'Enter Table'));
if ($tableLinkText === '') {
    $tableLinkText = 'Enter Table';
}

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#ecfffb'));
$accentColor = $getConfig('style.accent_color', '#08e7d8');
$titleColor = $getConfig('style.title_color', '#171117');
$titleFontSize = (int) $getConfig('style.title_font_size', '56');
$titleFontSizeMobile = (int) $getConfig('style.title_font_size_mobile', '36');
$subtitleColor = $getConfig('style.subtitle_color', '#4f454d');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(18,12,18,0.96)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.9)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,95,58,0.16)');
$cardRadius = (int)$getConfigAny(['style.card_border_radius', 'style.card_radius'], '30');
$cardTitleColor = $getConfig('style.card_title_color', '#171117');
$cardTitleFontSize = (int) $getConfig('style.card_title_font_size', '24');
$cardDescColor = $getConfig('style.card_desc_color', '#4f454d');
$cardDescFontSize = (int) $getConfig('style.card_desc_font_size', '15');
$sectionPadding = (int)$getConfig('style.section_padding', '88');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '52');
$cardGap = (int)$getConfig('style.card_gap', '24');
$cardContentPadding = (int) $getConfig('style.card_content_padding', '22');
$hoverTransform = (int) $getConfig('style.hover_transform', '2');

$title = $getConfig('texts.title', 'Choose Your Wildfire Table');
$subtitle = $getConfigAny(['texts.summary', 'texts.subtitle'], 'Pick the baccarat room that fits your pace, from live dealer tables to tighter mobile-first sessions.');
$legacyGames = $parseLegacyGames($getConfig('games.items', ''));
$legacyBadges = $parseLegacyTokenList($getConfig('texts.badges', ''));
$legacyTags = $parseLegacyTokenList($getConfig('texts.tags', ''));
$defaultGames = [
    ['badge' => 'Live Dealer', 'title' => 'Live Baccarat', 'desc' => 'Dealer-led room with readable table notes and a faster jump into real-time play.', 'tag' => 'Live Baccarat', 'url' => '#live-baccarat'],
    ['badge' => 'Fast Entry', 'title' => 'Classic Baccarat', 'desc' => 'Balanced pace with clear score flow for everyday banker or player sessions.', 'tag' => 'No Commission', 'url' => '#classic-baccarat'],
    ['badge' => 'Popular Pick', 'title' => 'No Commission', 'desc' => 'A streamlined baccarat lane for players who want simpler room rules.', 'tag' => 'High Roller', 'url' => '#no-commission'],
    ['badge' => 'High Stakes', 'title' => 'High Roller Lounge', 'desc' => 'Premium stakes and a quieter room atmosphere for confident table choices.', 'tag' => 'Mobile Flow', 'url' => '#high-roller'],
    ['badge' => 'Mobile Ready', 'title' => 'Speed Baccarat', 'desc' => 'Shorter decision windows for players who like rapid rounds.', 'tag' => 'Fast Pace', 'url' => '#speed-baccarat'],
    ['badge' => 'VIP Room', 'title' => 'Mini Baccarat', 'desc' => 'Compact room details and lighter limits for quick mobile sessions.', 'tag' => 'Quick Entry', 'url' => '#mini-baccarat'],
];
$games = [];
for ($i = 1; $i <= 6; $i++) {
    $index = $i - 1;
    $default = $defaultGames[$index];
    $legacy = $legacyGames[$index] ?? [];
    $groupPrefix = "game_{$i}.";
    $imageDesktop = '';
    $imageMobile = '';
    if ($i === 1) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_desktop', 'images.image_1_desktop', 'games.image_1_desktop'], ''));
        $imageMobile = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_mobile', 'images.image_1_mobile', 'games.image_1_mobile'], ''));
    } elseif ($i === 2) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_2', 'images.image_2', 'games.image_2'], ''));
        $imageMobile = $imageDesktop;
    } elseif ($i === 3) {
        $imageDesktop = trim((string) $getConfigAny([$groupPrefix . 'images.image_3', 'images.image_3', 'games.image_3'], ''));
        $imageMobile = $imageDesktop;
    }
    $game = [
        'badge' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_badge", "texts.game_{$i}_badge"], $getLegacyIndexed($legacyBadges, $index, $default['badge']))),
        'name' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_title", "texts.game_{$i}_title"], $legacy['title'] ?? $default['title'])),
        'description' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_desc", "texts.game_{$i}_desc"], $legacy['desc'] ?? $default['desc'])),
        'tag' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_tag", "texts.game_{$i}_tag"], $getLegacyIndexed($legacyTags, $index, $default['tag']))),
        'link' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_url", "texts.game_{$i}_url"], $legacy['url'] ?? $default['url'])),
        'desktop_image' => $imageDesktop,
        'mobile_image' => $imageMobile !== '' ? $imageMobile : $imageDesktop,
    ];
    if ($game['name'] === '') {
        continue;
    }
    if ($game['link'] === '') {
        $game['link'] = '#';
    }
    $games[] = $game;
}

if (empty($games)) {
    return;
}

$tags = [];
foreach ($games as $game) {
    if (!empty($game['tag']) && !in_array($game['tag'], $tags, true)) {
        $tags[] = $game['tag'];
    }
    if (count($tags) >= 4) {
        break;
    }
}
?>

<section id="<?= $componentId ?>" class="bwf-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <div class="games-copy">
                <?php if ($showTitle): ?>
                    <div class="games-title-wrap">
                        <span class="games-title-mark" aria-hidden="true">
                            <span class="mark-line mark-line-long"></span>
                            <span class="mark-core"></span>
                            <span class="mark-line mark-line-short"></span>
                        </span>
                        <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                    </div>
                <?php endif; ?>
                <?php if ($showSubtitle): ?>
                    <p class="games-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
                <?php if ($showTags && !empty($tags)): ?>
                    <div class="games-tags">
                        <?php foreach ($tags as $tag): ?>
                            <span><?= htmlspecialchars($tag) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>

            <div class="games-controls">
                <button type="button" class="games-arrow" data-games-prev aria-label="Previous tables"><span>‹</span></button>
                <button type="button" class="games-arrow" data-games-next aria-label="Next tables"><span>›</span></button>
            </div>
        </header>

        <div class="table-rail-wrap">
            <span class="rail-streak streak-one" aria-hidden="true"></span>
            <span class="rail-streak streak-two" aria-hidden="true"></span>
            <span class="rail-streak streak-three" aria-hidden="true"></span>

            <div class="table-rail" data-table-rail>
                <?php foreach ($games as $index => $game): ?>
                    <?php
                    $badge = $game['badge'];
                    $tokens = array_values(array_unique(array_filter([
                        $badge,
                        $game['tag'] ?? '',
                        $tags[$index % max(1, count($tags))] ?? '',
                    ], static function($value) {
                        return trim((string)$value) !== '';
                    })));
                    ?>
                    <article class="table-card table-card-<?= (int)(($index % 4) + 1) ?>">
                        <div class="table-card-inner">
                            <span class="table-badge"><?= htmlspecialchars($badge) ?></span>
                            <?php if ($game['desktop_image'] !== ''): ?>
                                <figure class="table-art">
                                    <picture>
                                        <?php if ($game['mobile_image'] !== ''): ?>
                                            <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile_image']) ?>">
                                        <?php endif; ?>
                                        <img src="<?= htmlspecialchars($game['desktop_image']) ?>" alt="<?= htmlspecialchars($game['name']) ?>" loading="lazy" decoding="async">
                                    </picture>
                                </figure>
                            <?php endif; ?>
                            <h3><?= htmlspecialchars($game['name']) ?></h3>
                            <?php if ($showSubtitle && $game['description'] !== ''): ?>
                                <p><?= htmlspecialchars($game['description']) ?></p>
                            <?php endif; ?>

                            <?php if ($showTags && !empty($tokens)): ?>
                                <div class="table-token-row">
                                    <?php foreach ($tokens as $token): ?>
                                        <span><?= htmlspecialchars($token) ?></span>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>

                            <div class="table-foot">
                                <span class="table-pulse" aria-hidden="true"></span>
                                <a href="<?= htmlspecialchars($game['link']) ?>" class="table-link">
                                    <span><?= htmlspecialchars($tableLinkText) ?></span>
                                </a>
                            </div>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

