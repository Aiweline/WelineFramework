    position: relative;
    overflow: hidden;
    padding: 84px 0;
    background:
        radial-gradient(860px 360px at 8% 0%, rgba(242,107,79,0.16), transparent 68%),
        radial-gradient(720px 320px at 92% 14%, rgba(8,231,216,0.12), transparent 64%),
        radial-gradient(640px 260px at 50% 100%, rgba(243,181,63,0.16), transparent 62%),
        linear-gradient(180deg, #fff9f1 0%, <?= htmlspecialchars($bgColor) ?> 100%);
    color: <?= htmlspecialchars($textColor) ?>;
}

