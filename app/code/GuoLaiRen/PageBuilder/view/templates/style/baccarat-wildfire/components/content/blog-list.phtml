    color: inherit;
    text-decoration: none;
}

.bwf-blog-list .featured-copy h3 {
    font-family: 'Outfit', 'Manrope', sans-serif;
    font-size: clamp(1.9rem, 3.2vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
}

.bwf-blog-list .featured-summary,
.bwf-blog-list .story-summary {
    margin-top: 0.92rem;
    color: rgba(63,36,24,0.74);
    line-height: 1.82;
}

.bwf-blog-list .story-link {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: #b24d34;
    font-weight: 800;
    text-decoration: none;
}

