@media (max-width: 640px) {
    .bwf-blog-list {
        padding: 56px 0;
    }

    .bwf-blog-list .blog-shell {
        width: min(100% - 0.9rem, 100%);
    }

    .bwf-blog-list .featured-story,
    .bwf-blog-list .story-card,
    .bwf-blog-list .rail-card,
    .bwf-blog-list .blog-empty {
