}

.bwf-blog-list .recent-stack {
    display: grid;
    gap: 0.72rem;
}

.bwf-blog-list .recent-link {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 0.7rem;
    text-decoration: none;
    color: #3b2426;
}

.bwf-blog-list .recent-link img {
    border-radius: 16px;
    aspect-ratio: 1 / 1;
}

.bwf-blog-list .recent-link span {
