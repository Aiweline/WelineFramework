    display: block;
}

.bwf-blog-list .news-deck {
    margin-top: 1.2rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 300px);
    gap: 1rem;
}

.bwf-blog-list .news-deck:not(.has-rail) {
    grid-template-columns: 1fr;
}

.bwf-blog-list .story-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
