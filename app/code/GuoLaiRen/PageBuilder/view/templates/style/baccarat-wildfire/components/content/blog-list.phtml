<?php
/**
 * Baccarat Wildfire Blog List Component
 *
 * @fields_start
 * blog.title|博客列表标题|text|Latest Blog Posts
 * blog.subtitle|副标题|text|Stay updated with our latest news and articles
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=特色|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', __('Latest Blog Posts'));
$subtitle = $getConfig('blog.subtitle', __('Stay updated with our latest news and articles'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#f26b4f');
$secondaryColor = $getConfig('color_scheme.secondary', '#f3b53f');
$bgColor = $getConfig('color_scheme.background', '#fff7ed');
$textColor = $getConfig('color_scheme.text', '#3f2418');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/baccarat-wildfire/asset/img/poker-header-bg.svg');

$featuredPost = $blogPosts[0] ?? null;
$gridPosts = array_slice($blogPosts, 1);
$cardStyleClass = 'style-' . preg_replace('/[^a-z0-9-]+/i', '', (string)$cardStyle);
?>

<section class="bwf-blog-list" id="blog">
    <div class="blog-shell">
        <header class="blog-masthead">
            <span class="masthead-kicker">Wildfire Journal</span>
            <h2><?= htmlspecialchars($title) ?></h2>
            <?php if ($subtitle): ?>
                <p><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="blog-empty">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <p><?= __('There are no blog posts yet. Please check back later!') ?></p>
            </div>
        <?php else: ?>
            <?php if ($featuredPost): ?>
                <article class="featured-story">
                    <?php if (!empty($featuredPost['cover_image'])): ?>
                        <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="featured-media">
                            <img src="<?= htmlspecialchars($featuredPost['cover_image']) ?>" alt="<?= htmlspecialchars($featuredPost['title']) ?>" loading="lazy">
                        </a>
                    <?php endif; ?>

                    <div class="featured-copy">
                        <div class="featured-meta">
                            <?php if ($showCategory && !empty($featuredPost['category_name'])): ?>
                                <span class="story-chip"><?= htmlspecialchars($featuredPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($featuredPost['published_at'])): ?>
                                <span class="story-date"><?= date('M d, Y', strtotime($featuredPost['published_at'])) ?></span>
                            <?php endif; ?>
                        </div>

                        <h3>
                            <a href="<?= htmlspecialchars($featuredPost['url']) ?>">
                                <?= htmlspecialchars($featuredPost['title']) ?>
                            </a>
                        </h3>

                        <?php if (!empty($featuredPost['summary'])): ?>
                            <p class="featured-summary"><?= htmlspecialchars(mb_substr($featuredPost['summary'], 0, 220)) ?><?= mb_strlen($featuredPost['summary']) > 220 ? '...' : '' ?></p>
                        <?php endif; ?>

                        <div class="featured-footer">
                            <?php if ($showAuthor && !empty($featuredPost['author'])): ?>
                                <span class="story-author"><?= htmlspecialchars($featuredPost['author']) ?></span>
                            <?php endif; ?>
                            <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="story-link">
                                <?= __('Read Story') ?>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
            <?php endif; ?>

            <div class="news-deck<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="story-grid <?= htmlspecialchars($cardStyleClass) ?>">
                    <?php foreach ($gridPosts as $index => $post): ?>
                        <?php $cardExtraClass = ($cardStyle === 'featured' && $index === 0) ? ' is-wide' : ''; ?>
                        <article class="story-card<?= $cardExtraClass ?>">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="story-cover">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>

                            <div class="story-body">
                                <div class="story-topline">
                                    <?php if ($showCategory && !empty($post['category_name'])): ?>
                                        <span class="story-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($post['published_at'])): ?>
                                        <span class="story-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h3 class="story-title">
                                    <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a>
                                </h3>

                                <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                    <p class="story-summary">
                                        <?= htmlspecialchars(mb_substr($post['summary'], 0, 140)) ?><?= mb_strlen($post['summary']) > 140 ? '...' : '' ?>
                                    </p>
                                <?php endif; ?>

                                <div class="story-foot">
                                    <?php if ($showAuthor && !empty($post['author'])): ?>
                                        <span class="story-author"><?= htmlspecialchars($post['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($post['url']) ?>" class="story-link">
                                        <?= __('Read More') ?>
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="signal-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card">
                                <h4><?= __('Categories') ?></h4>
                                <div class="category-cloud">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-pill"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card">
                                <h4><?= __('Recent Posts') ?></h4>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

<style>
