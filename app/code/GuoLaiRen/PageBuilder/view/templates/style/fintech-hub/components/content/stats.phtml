<?php
/**
 * FinTech Hub - Stats Section Component
 * 
 * 平台数据展示区域，大型指标卡片布局
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Platform Metrics
 * content.title => 标题:text:Numbers that speak for themselves
 * content.description => 描述:textarea:Our platform processes billions in transactions while maintaining the highest standards of security and reliability.
 * 
 * group:stats => 统计数据
 * stats.items => 统计列表:textarea:$2B+|Total Processed|Total transaction volume processed through our platform\r\n1M+|Active Users|Verified users across personal and business accounts\r\n150+|Countries|Global coverage with local payment support\r\n99.99%|Uptime|Industry-leading reliability and availability|格式：数值|标签|描述，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['stats_bg'] ?? '#0e1425';
$textPrimary = $colors['text_primary'] ?? '#f8fafc';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$textMuted = $colors['text_muted'] ?? '#64748b';
$accentPrimary = $colors['accent_primary'] ?? '#2563eb';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#3b82f6';
$accentSecondary = $colors['accent_secondary'] ?? '#f59e0b';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(37, 99, 235, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(37, 99, 235, 0.3)';

// 内容配置
$badge = $config['content.badge'] ?? 'Platform Metrics';
$title = $config['content.title'] ?? 'Numbers that speak for themselves';
$description = $config['content.description'] ?? 'Our platform processes billions in transactions while maintaining the highest standards of security and reliability.';

// 统计数据
$statsRaw = $config['stats.items'] ?? "\$2B+|Total Processed|Total transaction volume processed through our platform\n1M+|Active Users|Verified users across personal and business accounts\n150+|Countries|Global coverage with local payment support\n99.99%|Uptime|Industry-leading reliability and availability";

$stats = [];
$lines = preg_split('/[\r\n]+/', $statsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line);
    $value = trim($parts[0] ?? '');
    $label = trim($parts[1] ?? '');
    $desc = trim($parts[2] ?? '');
    
    if (!empty($value)) {
        $stats[] = [
            'value' => $value,
            'label' => $label,
            'description' => $desc,
        ];
    }
}

$instanceId = 'fh-stats-' . uniqid();
?>

<section class="fh-stats" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
            position: relative;
        }
        
        #<?= $instanceId ?>::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(ellipse at 50% 50%, rgba(37, 99, 235, 0.06) 0%, transparent 70%);
            pointer-events: none;
        }
        
        #<?= $instanceId ?> .fh-stats-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }
        
        #<?= $instanceId ?> .fh-stats-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .fh-stats-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: <?= $badgeBg ?>;
            border: 1px solid <?= $badgeBorder ?>;
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 500;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .fh-stats-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .fh-stats-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .fh-stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .fh-stats-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            padding: 40px 24px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?> .fh-stats-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, <?= $accentPrimary ?>, <?= $accentSecondary ?>);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        #<?= $instanceId ?> .fh-stats-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(37, 99, 235, 0.3);
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }
        
        #<?= $instanceId ?> .fh-stats-card:hover::before {
            opacity: 1;
        }
        
        #<?= $instanceId ?> .fh-stats-card-value {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, <?= $accentPrimaryLight ?>, <?= $accentSecondary ?>);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
            line-height: 1.2;
        }
        
        #<?= $instanceId ?> .fh-stats-card-label {
            font-size: 1.1rem;
            font-weight: 600;
            color: <?= $textPrimary ?>;
            margin-bottom: 8px;
        }
        
        #<?= $instanceId ?> .fh-stats-card-desc {
            font-size: 0.85rem;
            color: <?= $textMuted ?>;
            line-height: 1.5;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .fh-stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .fh-stats-title {
                font-size: 1.75rem;
            }
            
            #<?= $instanceId ?> .fh-stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }
            
            #<?= $instanceId ?> .fh-stats-card {
                padding: 24px 16px;
            }
            
            #<?= $instanceId ?> .fh-stats-card-value {
                font-size: 2rem;
            }
        }
    </style>
    
    <div class="fh-stats-container">
        <div class="fh-stats-header">
            <div class="fh-stats-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/>
                </svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="fh-stats-title"><?= htmlspecialchars($title) ?></h2>
            <p class="fh-stats-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="fh-stats-grid">
            <?php foreach ($stats as $stat): ?>
            <div class="fh-stats-card">
                <div class="fh-stats-card-value"><?= htmlspecialchars($stat['value']) ?></div>
                <div class="fh-stats-card-label"><?= htmlspecialchars($stat['label']) ?></div>
                <?php if (!empty($stat['description'])): ?>
                <div class="fh-stats-card-desc"><?= htmlspecialchars($stat['description']) ?></div>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
