<?php
/**
 * FinTech Hub - Services Section Component
 * 
 * 服务方案展示区域，3列卡片布局
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Our Solutions
 * content.title => 标题:text:Tailored financial services for everyone
 * content.description => 描述:textarea:Whether you are an individual, a growing business, or an enterprise — we have the right plan to power your financial journey.
 * 
 * group:services => 服务列表
 * services.items => 服务列表:textarea:Personal|personal|Everyday banking, payments, and savings tools designed for individuals.|Instant P2P transfers\nSmart savings accounts\nBudget tracking tools\nVirtual & physical cards\nMulti-currency wallet|Get Started\r\nBusiness|business|Invoice management, payroll, and multi-user access for growing teams.|Business accounts\nInvoice & billing\nPayroll management\nMulti-user access\nExpense reporting|Start Free Trial\r\nEnterprise|enterprise|Custom solutions with dedicated support, APIs, and white-label options.|Custom API integration\nDedicated account manager\nWhite-label solutions\n24/7 priority support\nAdvanced analytics|Contact Sales|格式：名称|类型|描述|特性列表(\n分隔)|CTA文字，条目间用\r\n分隔
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['services_bg'] ?? '#0a0f1e';
$textPrimary = $colors['text_primary'] ?? '#f8fafc';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$textMuted = $colors['text_muted'] ?? '#64748b';
$accentPrimary = $colors['accent_primary'] ?? '#2563eb';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#3b82f6';
$accentSecondary = $colors['accent_secondary'] ?? '#f59e0b';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #2563eb 0%, #3b82f6 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(37, 99, 235, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(37, 99, 235, 0.3)';

// 内容配置
$badge = $config['content.badge'] ?? 'Our Solutions';
$title = $config['content.title'] ?? 'Tailored financial services for everyone';
$description = $config['content.description'] ?? 'Whether you are an individual, a growing business, or an enterprise — we have the right plan to power your financial journey.';

// 服务列表
$servicesRaw = $config['services.items'] ?? "Personal|personal|Everyday banking, payments, and savings tools designed for individuals.|Instant P2P transfers\nSmart savings accounts\nBudget tracking tools\nVirtual & physical cards\nMulti-currency wallet|Get Started\r\nBusiness|business|Invoice management, payroll, and multi-user access for growing teams.|Business accounts\nInvoice & billing\nPayroll management\nMulti-user access\nExpense reporting|Start Free Trial\r\nEnterprise|enterprise|Custom solutions with dedicated support, APIs, and white-label options.|Custom API integration\nDedicated account manager\nWhite-label solutions\n24/7 priority support\nAdvanced analytics|Contact Sales";

$services = [];
$serviceBlocks = preg_split('/\r\n/', $servicesRaw);
foreach ($serviceBlocks as $block) {
    $block = trim($block);
    if (empty($block)) continue;
    
    $parts = explode('|', $block, 5);
    $serviceName = trim($parts[0] ?? '');
    $serviceType = trim($parts[1] ?? '');
    $serviceDesc = trim($parts[2] ?? '');
    $serviceFeatures = trim($parts[3] ?? '');
    $serviceCta = trim($parts[4] ?? 'Learn More');
    
    if (!empty($serviceName)) {
        $featureList = array_filter(array_map('trim', explode("\n", $serviceFeatures)));
        $services[] = [
            'name' => $serviceName,
            'type' => $serviceType,
            'description' => $serviceDesc,
            'features' => $featureList,
            'cta' => $serviceCta,
        ];
    }
}

// 服务图标映射
$serviceIcons = [
    'personal' => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>',
    'business' => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/></svg>',
    'enterprise' => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>',
];

$instanceId = 'fh-services-' . uniqid();
?>

