                    <path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/>
                </svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="fh-services-title"><?= htmlspecialchars($title) ?></h2>
            <p class="fh-services-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="fh-services-grid">
            <?php foreach ($services as $index => $service): ?>
            <div class="fh-services-card<?= $index === 1 ? ' featured' : '' ?>">
                <div class="fh-services-card-icon">
                    <?= $serviceIcons[$service['type']] ?? $serviceIcons['personal'] ?>
                </div>
                <h3 class="fh-services-card-name"><?= htmlspecialchars($service['name']) ?></h3>
                <p class="fh-services-card-desc"><?= htmlspecialchars($service['description']) ?></p>
                
                <?php if (!empty($service['features'])): ?>
                <ul class="fh-services-card-features">
                    <?php foreach ($service['features'] as $feature): ?>
                    <li>
                        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                        <?= htmlspecialchars($feature) ?>
                    </li>
                    <?php endforeach; ?>
                </ul>
                <?php endif; ?>
                
                <a href="#" class="fh-services-card-cta"><?= htmlspecialchars($service['cta']) ?></a>
            </div>
            <?php endforeach; ?>
