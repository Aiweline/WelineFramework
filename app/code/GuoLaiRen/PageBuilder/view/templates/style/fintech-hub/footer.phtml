    function fh_footer_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('fh_footer_getConfig')) {
    function fh_footer_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// 品牌配置
$brandName = fh_footer_getConfig($styleSettings, 'brand.name', 'VaultPay');
