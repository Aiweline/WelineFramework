$column4Title = fh_footer_getConfig($styleSettings, 'links.column4_title', 'Support');
$column4Raw = fh_footer_getConfig($styleSettings, 'links.column4_items', "Help Center=>/help\nContact Us=>/contact\nAPI Docs=>/docs\nStatus=>/status");

// 解析链接
$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl(trim($parts[1] ?? '#'));
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$column1Links = $parseLinks($column1Raw);
$column2Links = $parseLinks($column2Raw);
$column3Links = $parseLinks($column3Raw);
$column4Links = $parseLinks($column4Raw);

// 联系信息
$contactEmail = fh_footer_getConfig($styleSettings, 'contact.email', 'support@vaultpay.com');

// 版权配置
