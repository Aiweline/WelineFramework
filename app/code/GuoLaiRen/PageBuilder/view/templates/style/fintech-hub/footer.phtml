// 链接配置
$column1Title = fh_footer_getConfig($styleSettings, 'links.column1_title', 'Products');
$column1Raw = fh_footer_getConfig($styleSettings, 'links.column1_items', "Personal Banking=>/personal\nBusiness Solutions=>/business\nInvestments=>/invest\nGlobal Transfers=>/transfers");
$column2Title = fh_footer_getConfig($styleSettings, 'links.column2_title', 'Company');
$column2Raw = fh_footer_getConfig($styleSettings, 'links.column2_items', "About Us=>/about\nCareers=>/careers\nPress=>/press\nPartners=>/partners");
$column3Title = fh_footer_getConfig($styleSettings, 'links.column3_title', 'Legal');
