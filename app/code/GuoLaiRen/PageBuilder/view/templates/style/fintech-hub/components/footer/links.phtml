 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$footerBg = $colors['footer_bg'] ?? '#060912';
$footerText = $colors['footer_text'] ?? '#64748b';
$footerLink = $colors['footer_link'] ?? '#94a3b8';
$footerLinkHover = $colors['footer_link_hover'] ?? '#3b82f6';
$footerBorder = $colors['footer_border'] ?? 'rgba(255, 255, 255, 0.06)';
$textPrimary = $colors['text_primary'] ?? '#f8fafc';
$accentPrimary = $colors['accent_primary'] ?? '#2563eb';
