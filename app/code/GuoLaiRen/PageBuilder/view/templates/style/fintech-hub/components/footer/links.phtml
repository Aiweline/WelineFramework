// 品牌配置
$brandName = $config['brand.name'] ?? 'VaultPay';
$brandDesc = $config['brand.description'] ?? 'Secure digital finance platform for payments, investments, and global transfers. Licensed and regulated.';
$showLogo = ($config['brand.show_logo'] ?? 'yes') !== 'no';

// 链接解析函数
$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

// 链接配置
$col1Title = $config['links.column1_title'] ?? 'Products';
$col1Links = $parseLinks($config['links.column1_items'] ?? "Personal Banking=>/personal\nBusiness Solutions=>/business\nInvestments=>/invest\nGlobal Transfers=>/transfers");
$col2Title = $config['links.column2_title'] ?? 'Company';
$col2Links = $parseLinks($config['links.column2_items'] ?? "About Us=>/about\nCareers=>/careers\nPress=>/press\nPartners=>/partners");
$col3Title = $config['links.column3_title'] ?? 'Legal';
$col3Links = $parseLinks($config['links.column3_items'] ?? "Privacy Policy=>/privacy\nTerms of Service=>/terms\nCompliance=>/compliance\nSecurity=>/security");
$col4Title = $config['links.column4_title'] ?? 'Support';
$col4Links = $parseLinks($config['links.column4_items'] ?? "Help Center=>/help\nContact Us=>/contact\nAPI Docs=>/docs\nStatus=>/status");

// 版权配置
