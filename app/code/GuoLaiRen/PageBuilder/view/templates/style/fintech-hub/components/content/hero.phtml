<?php
/**
 * FinTech Hub - Hero Section Component
 * 
 * 首屏英雄区域，包含标题、描述、CTA按钮和平台统计数据
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 顶部徽章文字:text:Trusted by 1M+ Users
 * content.title => 主标题:textarea:The future of digital finance starts here
 * content.description => 描述文字:textarea:Secure payments, smart investments, and global transfers — all in one platform. Experience banking reimagined for the digital age.
 * 
 * group:cta => 按钮设置
 * cta.primary_text => 主按钮文字:text:Open Free Account
 * cta.primary_url => 主按钮链接:text:#services
 * cta.secondary_text => 次按钮文字:text:Explore Products
 * cta.secondary_url => 次按钮链接:text:#features
 * 
 * group:stats => 统计数据
 * stats.items => 统计列表:textarea:$2B+|Total Processed\r\n1M+|Active Users\r\n99.99%|Uptime\r\n150+|Countries|格式：数值|标签，一行一个
 * 
 * group:visual => 视觉设置
 * visual.show_decoration => 显示装饰效果:select:yes|yes,no
 * visual.show_image => 显示右侧图片:select:yes|yes,no
 * visual.image_url => 图片URL:textarea:|留空使用默认装饰效果
 * visual.image_alt => 图片Alt文字:text:VaultPay digital finance platform
 * 
 * group:style => 样式设置
 * style.padding_top => 顶部内边距:number:120|px
 * style.padding_bottom => 底部内边距:number:80|px
 * style.title_size => 标题字号:number:3.5|rem
 * style.desc_size => 描述字号:number:1.25|rem
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$heroBg = $colors['hero_bg'] ?? 'linear-gradient(135deg, #0d1b3e 0%, #0a1128 50%, #080b16 100%)';
$textPrimary = $colors['text_primary'] ?? '#f8fafc';
$textSecondary = $colors['text_secondary'] ?? '#94a3b8';
$accentPrimary = $colors['accent_primary'] ?? '#2563eb';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#3b82f6';
$accentSecondary = $colors['accent_secondary'] ?? '#f59e0b';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #2563eb 0%, #3b82f6 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(37, 99, 235, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(37, 99, 235, 0.3)';

// 内容配置
$badge = $config['content.badge'] ?? 'Trusted by 1M+ Users';
$title = $config['content.title'] ?? 'The future of digital finance starts here';
$description = $config['content.description'] ?? 'Secure payments, smart investments, and global transfers — all in one platform. Experience banking reimagined for the digital age.';

// CTA配置
$primaryBtnText = $config['cta.primary_text'] ?? 'Open Free Account';
$primaryBtnUrl = $config['cta.primary_url'] ?? '#services';
$secondaryBtnText = $config['cta.secondary_text'] ?? 'Explore Products';
$secondaryBtnUrl = $config['cta.secondary_url'] ?? '#features';

// 统计数据
$statsRaw = $config['stats.items'] ?? "\$2B+|Total Processed\n1M+|Active Users\n99.99%|Uptime\n150+|Countries";
$stats = [];
$lines = preg_split('/[\r\n]+/', $statsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $value = trim($parts[0] ?? '');
    $label = trim($parts[1] ?? '');
    if (!empty($value)) {
        $stats[] = ['value' => $value, 'label' => $label];
    }
}

// 视觉配置
$showDecoration = ($config['visual.show_decoration'] ?? 'yes') !== 'no';
$showImage = ($config['visual.show_image'] ?? 'yes') !== 'no';
$imageUrl = $config['visual.image_url'] ?? '';
$imageAlt = $config['visual.image_alt'] ?? 'VaultPay digital finance platform';

// 样式配置
$paddingTop = $config['style.padding_top'] ?? '120';
$paddingBottom = $config['style.padding_bottom'] ?? '80';
$titleSize = $config['style.title_size'] ?? '3.5';
$descSize = $config['style.desc_size'] ?? '1.25';

$instanceId = 'fh-hero-' . uniqid();
?>

<section class="fh-hero" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
