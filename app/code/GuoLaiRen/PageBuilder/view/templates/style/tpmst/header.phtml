if (!function_exists('tpmst_makeTransparent')) {
    function tpmst_makeTransparent($color, $opacity = 0.7) {
        // 如果是rgba格式，提取RGB值并应用新的透明度
        if (preg_match('/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*[\d.]+)?\)/', $color, $matches)) {
            $r = intval($matches[1]);
            $g = intval($matches[2]);
            $b = intval($matches[3]);
            return "rgba($r, $g, $b, $opacity)";
        }
        // 如果是hex格式，转换为rgba
        if (preg_match('/^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$/', $color)) {
            $hex = str_replace('#', '', $color);
            if (strlen($hex) === 3) {
                $hex = $hex[0] . $hex[0] . $hex[1] . $hex[1] . $hex[2] . $hex[2];
            }
            $r = hexdec(substr($hex, 0, 2));
            $g = hexdec(substr($hex, 2, 2));
            $b = hexdec(substr($hex, 4, 2));
            return "rgba($r, $g, $b, $opacity)";
        }
        // 默认返回半透明黑色
        return "rgba(10, 10, 15, $opacity)";
    }
}
