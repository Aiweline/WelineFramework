<?php
/**
 * Teen Patti Master 模板 - Hero Slider 组件
 * TPMST Template - Hero Slider Component
 * 
 * 首屏Banner轮播组件，从header独立出来
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用本地banner-2.jpg
 * banner.image_desktop => PC端Banner图片:textarea:|默认使用本地banner-03.webp
 * banner.alt => Banner图片描述:text:100000 earn on teenpatti master
 * banner.bg_color => Banner背景颜色:color:#0c0060
 * 
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:|默认使用本地download-btn-m.webp
 * download_btn.alt => 下载按钮描述:text:DOWNLOAD APP
 * download_btn.url => 下载链接:text:#download
 * 
 * group:layout => 布局设置
 * layout.slider_classes => 轮播区域CSS类:textarea:rs-slider slider-style2|可配置轮播区域的CSS类名
 * layout.margin_top => 顶部负边距(移动端):number:-75|px，用于与导航重叠效果
 * layout.img_margin_top => 图片顶部负边距(PC端):number:-90|px
 * 
 * @fields_end
 */

$page = $this->getData('page') ?? $page ?? null;
$config = $component_config ?? [];
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色辅助函数
if (!function_exists('tpmst_hs_color')) {
    function tpmst_hs_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

// 获取配置辅助函数
if (!function_exists('tpmst_hs_getConfig')) {
    function tpmst_hs_getConfig($config, $key, $default = '') {
        $value = $config[$key] ?? $default;
        if ($value === '' && $default !== '') {
            return $default;
        }
        return $value;
    }
}

// Banner显示配置
$bannerDisplayRaw = tpmst_hs_getConfig($config, 'banner.display', 'yes');
if ($bannerDisplayRaw === 'yes' || $bannerDisplayRaw === true || $bannerDisplayRaw === 'true' || $bannerDisplayRaw === 1 || $bannerDisplayRaw === '1' || $bannerDisplayRaw === 0 || $bannerDisplayRaw === '0') {
    // 兼容 0=yes, 1=no 的逻辑
    if ($bannerDisplayRaw === 0 || $bannerDisplayRaw === '0') {
        $bannerDisplay = 'yes';
    } elseif ($bannerDisplayRaw === 1 || $bannerDisplayRaw === '1') {
        $bannerDisplay = 'no';
    } else {
        $bannerDisplay = ($bannerDisplayRaw === 'yes' || $bannerDisplayRaw === true || $bannerDisplayRaw === 'true') ? 'yes' : 'no';
    }
} else {
    $bannerDisplay = 'yes';
}

// 如果不显示，直接返回
if ($bannerDisplay !== 'yes') {
    return;
}

// Banner配置
$bannerAlt = (string)(tpmst_hs_getConfig($config, 'banner.alt', '100000 earn on teenpatti master') ?? '');
$bannerBgColor = tpmst_hs_color($colors, 'hero_bg', tpmst_hs_getConfig($config, 'banner.bg_color', '#0c0060'));

// 下载按钮配置
$downloadBtnDisplayRaw = tpmst_hs_getConfig($config, 'download_btn.display', 'yes');
$downloadBtnDisplay = ($downloadBtnDisplayRaw === 'yes' || $downloadBtnDisplayRaw === true || $downloadBtnDisplayRaw === 'true' || $downloadBtnDisplayRaw === 0 || $downloadBtnDisplayRaw === '0');
$downloadBtnAlt = (string)(tpmst_hs_getConfig($config, 'download_btn.alt', 'DOWNLOAD APP') ?? '');
$downloadBtnUrl = tpmst_hs_getConfig($config, 'download_btn.url', '#download');
$downloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$downloadBtnUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadHref, 'url');

// 布局配置
$sliderClasses = tpmst_hs_getConfig($config, 'layout.slider_classes', 'rs-slider slider-style2');
$marginTop = tpmst_hs_getConfig($config, 'layout.margin_top', '-75');
$imgMarginTop = tpmst_hs_getConfig($config, 'layout.img_margin_top', '-90');

// 默认Banner图片
$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/download-btn-m.webp');

// 读取图片配置
$bannerImageMobile = tpmst_hs_getConfig($config, 'banner.image_mobile', '');
$bannerImageDesktop = tpmst_hs_getConfig($config, 'banner.image_desktop', '');
$downloadBtnImage = tpmst_hs_getConfig($config, 'download_btn.image', '');

// 确定最终使用的图片
$finalBannerMobile = !empty(trim((string)$bannerImageMobile)) ? trim((string)$bannerImageMobile) : (string)($defaultBannerMobile ?? '');
$finalBannerDesktop = !empty(trim((string)$bannerImageDesktop)) ? trim((string)$bannerImageDesktop) : (string)($defaultBannerDesktop ?? '');
$finalDownloadBtn = !empty(trim((string)$downloadBtnImage)) ? trim((string)$downloadBtnImage) : (string)($defaultDownloadBtn ?? '');

// 构建完整的 slider classes
$fullSliderClasses = trim($sliderClasses);
if (!empty($marginTop) && intval($marginTop) !== 0) {
    $fullSliderClasses .= ' md-mt-' . str_replace('-', '', $marginTop);
}

$instanceId = 'tpmst-hero-slider-' . uniqid();
?>

<!-- Hero/Banner Slider组件 -->
<div class="tpmst-hero-slider-component" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            /* 组件基础样式 */
        }
        
        #<?= $instanceId ?> .rs-slider {
            background: <?= htmlspecialchars($bannerBgColor) ?>;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?> .rs-slider.slider-style2 {
            /* 保持与原样式兼容 */
        }
        
        /* 移动端负边距效果 */
        @media (max-width: 991px) {
            #<?= $instanceId ?> .rs-slider.md-mt-<?= str_replace('-', '', $marginTop) ?> {
                margin-top: <?= intval($marginTop) ?>px;
            }
            
            #<?= $instanceId ?> .slide-img.md-mt-0 {
                margin-top: 0;
                min-width: 100vw !important;
                height: auto;
            }
        }
        
        /* PC端图片负边距 */
        @media (min-width: 992px) {
            #<?= $instanceId ?> .slide-img.mt-<?= str_replace('-', '', $imgMarginTop) ?> {
                margin-top: <?= intval($imgMarginTop) ?>px;
            }
        }
        
        #<?= $instanceId ?> .slider-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        #<?= $instanceId ?> .slide-bg-layer {
            width: 100%;
        }
        
        #<?= $instanceId ?> .slide-bg-layer picture {
            display: block;
            width: 100%;
        }
        
        #<?= $instanceId ?> .slide-img {
            width: 100%;
            height: auto;
            display: block;
        }
        
        #<?= $instanceId ?> .download-btn {
            margin-top: 20px;
            text-align: center;
        }
        
        #<?= $instanceId ?> .download-icon {
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        
        #<?= $instanceId ?> .download-icon:hover {
            transform: scale(1.05);
        }
        
        #<?= $instanceId ?> .animation-scale {
            animation: pulse-scale 2s infinite;
        }
        
        @keyframes pulse-scale {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.02); }
        }
    </style>
    <div class="<?= htmlspecialchars($fullSliderClasses) ?>">
        <div class="slider slider-slide-1">
            <div class="slider-item">
                <div class="container">
                    <div class="slider-inner ml--12 mr--12 justify-content-center">
                        <div class="slide-bg-layer text-center">
                            <picture>
                                <?php if ($finalBannerMobile): ?>
                                <source media="(max-width: 768px)" type="image/jpg" class="lazy-loading2"
                                    srcset="<?= htmlspecialchars($finalBannerMobile) ?>" data-srcset="<?= htmlspecialchars($finalBannerMobile) ?>" />
                                <?php endif; ?>
                                <?php if ($finalBannerDesktop): ?>
                                <source media="(min-width: 769px)" type="image/webp"
                                    srcset="<?= htmlspecialchars($finalBannerDesktop) ?>" />
                                <?php endif; ?>
                                <img class="slide-img mt-<?= str_replace('-', '', $imgMarginTop) ?> md-mt-0" 
                                     width="375" 
                                     height="500" 
                                     src="<?= htmlspecialchars($finalBannerMobile ?: $finalBannerDesktop) ?>" 
                                     alt="<?= htmlspecialchars($bannerAlt) ?>" 
                                     fetchpriority="high" 
                                     decoding="async">
                            </picture>
                        </div>
                        <?php if ($downloadBtnDisplay && $finalDownloadBtn): ?>
                        <a role="button" tabindex="0" class="download-btn" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($downloadRef)) ?>" data-glr-ref="<?= htmlspecialchars($downloadRef) ?>">
                            <img class="download-icon animation-scale lazy-loading" 
                                 src="<?= htmlspecialchars($finalDownloadBtn) ?>" 
                                 data-src="<?= htmlspecialchars($finalDownloadBtn) ?>" 
                                 fetchpriority="high" 
                                 decoding="async" 
                                 width="210" 
                                 height="54" 
                                 alt="<?= htmlspecialchars($downloadBtnAlt) ?>">
                        </a>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
