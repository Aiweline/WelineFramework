<?php
/**
 * TPMST 模板主布局 - Main Layout
 * 
 * 定义 header/content/footer 三个区域容器
 * 支持组件动态加载和可视化拖拽
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$pageId = $page && $page->getId() ? $page->getId() : 0;
$templateCode = 'tpmst';

// 获取页面布局配置（包含组件配置）
$layoutConfig = $this->getData('layout_config') ?: [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];

// 如果没有配置，使用默认组件
if (empty($headerComponents)) {
    $headerComponents = [
        ['code' => 'header-nav', 'enabled' => true, 'config' => []]
    ];
}

if (empty($contentComponents)) {
    $contentComponents = [
        ['code' => 'hero-slider', 'enabled' => true, 'config' => ['banner.display' => 'yes', 'layout.slider_classes' => 'rs-slider slider-style2', 'layout.margin_top' => '-75']],
        ['code' => 'advantages', 'enabled' => true, 'config' => []],
        ['code' => 'games', 'enabled' => true, 'config' => []],
        ['code' => 'testimonials', 'enabled' => true, 'config' => []],
        ['code' => 'faq', 'enabled' => true, 'config' => []],
    ];
}

if (empty($footerComponents)) {
    $footerComponents = [
        ['code' => 'footer-links', 'enabled' => true, 'config' => []]
    ];
}

// 组件代码到文件的映射
// 注意：此映射必须与 component.json 保持同步
// 所有组件文件必须实际存在于 components/ 目录下
$componentFiles = [
    // Header 组件
    'header-nav' => 'header/nav.phtml',
    'header-simple' => 'header/simple.phtml',
    'header-dark' => 'header/dark.phtml',
    
    // Content 组件
    'hero-slider' => 'content/hero-slider.phtml',
    'slider' => 'content/slider.phtml',
    'banner' => 'content/banner.phtml',
    'advantages' => 'content/advantages.phtml',
    'games' => 'content/games.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'faq' => 'content/faq.phtml',
    'blog-list' => 'content/blog-list.phtml',
    'blog-detail' => 'content/blog-detail.phtml',
    'blog-category' => 'content/blog-category.phtml',
    'legal-content' => 'content/legal-content.phtml',
    'about-content' => 'content/about-content.phtml',
    'contact-content' => 'content/contact-content.phtml',
    
    // Footer 组件
    'footer-links' => 'footer/links.phtml',
    'footer-simple' => 'footer/simple.phtml',
];

/**
 * 渲染单个组件
 */
$renderComponent = function($component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];
    
    if (!$enabled || empty($code)) {
        return '';
    }
    
    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        // 尝试查找共享组件
        $sharedFile = 'GuoLaiRen_PageBuilder::style/_shared/components/' . $code . '.phtml';
        if (file_exists($this->getTemplateFile($sharedFile))) {
            $this->assign('page', $page);
            $this->assign('style', $styleSettings);
            $this->assign('style_settings', $styleSettings);
            $this->assign('component_config', $componentConfig);
            return $this->fetchTemplate($sharedFile);
        }
        return "<!-- Component not found: {$code} -->";
    }
    
    $templatePath = 'GuoLaiRen_PageBuilder::style/tpmst/components/' . $file;
    
    // 传递数据到组件
    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', $componentConfig);
    
    try {
        return $this->fetchTemplate($templatePath);
    } catch (\Exception $e) {
        return "<!-- Error loading component {$code}: " . htmlspecialchars($e->getMessage()) . " -->";
    }
};

// 加载颜色配置
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);

// SEO 信息
$metaTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Teen Patti Master';
$metaDescription = $page ? ($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? ($page->getData('meta_keywords') ?: '') : '';
$pageIcon = $page ? ($page->getData('icon') ?: '') : '';

// 像素配置
$getConfig = function($key, $default = '') use ($styleSettings) {
    return isset($styleSettings[$key]) && $styleSettings[$key] !== '' ? $styleSettings[$key] : $default;
};
$pixelEnabled = $getConfig('pixel.enabled', 'yes');
$pixelName = $getConfig('pixel.name', '');
if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}
$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;
$pathInfo = $this->getRequest()->getPathInfo();
$isPreviewMode = $pathInfo ? (strpos($pathInfo, '/preview/') !== false) : false;
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($metaTitle) ?></title>
    
    <!-- Favicon -->
    <?php if (!empty($pageIcon)): ?>
    <link rel="icon" type="image/x-icon" href="<?= htmlspecialchars($pageIcon) ?>">
    <?php else: ?>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <?php endif; ?>
    
    <?php if ($metaDescription): ?>
    <meta name="description" content="<?= htmlspecialchars($metaDescription) ?>">
    <?php endif; ?>
    
    <?php if ($metaKeywords): ?>
    <meta name="keywords" content="<?= htmlspecialchars($metaKeywords) ?>">
    <?php endif; ?>
    
    <!-- 统计代码 -->
    <w:template>GuoLaiRen_PageBuilder::base/tracking.phtml</w:template>
    
    <!-- 本地CSS资源 -->
    <?php $localCssUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/css/home.css'); ?>
    <link rel="stylesheet" type="text/css" href="<?= htmlspecialchars($localCssUrl) ?>">
    
    <style>
        /* 全局基础样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
            background: #0c0060;
            color: #ffffff;
            line-height: 1.6;
        }
        
        /* 布局区域容器 */
        .tpmst-layout {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        .tpmst-region {
            width: 100%;
        }
        
        .tpmst-region-header {
            position: relative;
            z-index: 1000;
        }
        
        .tpmst-region-content {
            flex: 1;
        }
        
        .tpmst-region-footer {
            margin-top: auto;
        }
        
        /* 组件容器 */
        .tpmst-component-wrapper {
            position: relative;
        }
        
        /* 可视化编辑模式标识 */
        .tpmst-layout[data-visual-mode="true"] .tpmst-component-wrapper {
            outline: 2px dashed transparent;
            transition: outline 0.2s;
        }
        
        .tpmst-layout[data-visual-mode="true"] .tpmst-component-wrapper:hover {
            outline-color: #3498db;
        }
        
        /* 空区域提示 */
        .tpmst-region-empty {
            padding: 40px;
            text-align: center;
            background: rgba(255,255,255,0.05);
            border: 2px dashed rgba(255,255,255,0.2);
            border-radius: 8px;
            margin: 20px;
            color: rgba(255,255,255,0.5);
        }
    </style>
    
    <!-- 像素统计 -->
    <?php if ($websiteId > 0 && !empty($pixelName) && !$isPreviewMode): ?>
        <?php
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_ID', (string)$websiteId, 3600 * 24 * 365);
        $this->assign('pixel_name', htmlspecialchars($pixelName));
        $this->assign('pixel_enabled', htmlspecialchars($pixelEnabled));
        ?>
        <pixel name="{{pixel_name}}" enabled="{{pixel_enabled}}" />
    <?php endif; ?>
</head>
<body>
    <div class="tpmst-layout" data-template="tpmst" data-page-id="<?= $pageId ?>">
        
        <!-- ========== HEADER 区域 ========== -->
        <header class="tpmst-region tpmst-region-header" data-region="header" data-multiple="false">
            <?php if (!empty($headerComponents)): ?>
                <?php foreach ($headerComponents as $component): ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="tpmst-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="header">
                        <?= $renderComponent($component) ?>
                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="tpmst-region-empty">
                    <p>拖拽一个 Header 组件到此处</p>
                </div>
            <?php endif; ?>
        </header>
        
        <!-- ========== CONTENT 区域 ========== -->
        <main class="tpmst-region tpmst-region-content" data-region="content" data-multiple="true">
            <?php if (!empty($contentComponents)): ?>
                <?php foreach ($contentComponents as $index => $component): ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="tpmst-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="content"
                         data-index="<?= $index ?>">
                        <?= $renderComponent($component) ?>
                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="tpmst-region-empty">
                    <p>拖拽 Content 组件到此处</p>
                </div>
            <?php endif; ?>
        </main>
        
        <!-- ========== FOOTER 区域 ========== -->
        <footer class="tpmst-region tpmst-region-footer" data-region="footer" data-multiple="false">
            <?php if (!empty($footerComponents)): ?>
                <?php foreach ($footerComponents as $component): ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="tpmst-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="footer">
                        <?= $renderComponent($component) ?>
                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="tpmst-region-empty">
                    <p>拖拽一个 Footer 组件到此处</p>
                </div>
            <?php endif; ?>
        </footer>
        
    </div>
    
    <!-- 本地JS资源 -->
    <?php 
    $localZeptoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/js/zepto.min.js');
    $localCommonJsUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/js/common.js');
    ?>
    <script src="<?= htmlspecialchars($localZeptoUrl) ?>" defer></script>
    <script src="<?= htmlspecialchars($localCommonJsUrl) ?>" defer></script>
</body>
</html>
