$componentId = 'tpmst-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('testimonials.display', 'yes') !== 'no';
if (!$display) return;

$title = $getConfig('testimonials.title', 'Testimonials');
$bgColor = $getConfig('testimonials.bg_color', '#1a1a2e');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/user/Amit-Patel-3.avif');

$avatar1 = $getConfig('testimonials.avatar_1', '') ?: $defaultAvatar1;
$avatar2 = $getConfig('testimonials.avatar_2', '') ?: $defaultAvatar2;
$avatar3 = $getConfig('testimonials.avatar_3', '') ?: $defaultAvatar3;

$name1 = $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)');
$rating1 = $getConfig('texts.testimonial_1_rating', '⭐⭐⭐⭐⭐');
$content1 = $getConfig('texts.testimonial_1_content', "Best Teen Patti app I've used! I've been playing for 6 months and won ₹45,000 so far.");

$name2 = $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)');
$rating2 = $getConfig('texts.testimonial_2_rating', '⭐⭐⭐⭐⭐');
$content2 = $getConfig('texts.testimonial_2_content', "Fair game, genuine payments. After winning ₹8,000 in my first month, I'm hooked!");

$name3 = $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)');
$rating3 = $getConfig('texts.testimonial_3_rating', '⭐⭐⭐⭐☆');
$content3 = $getConfig('texts.testimonial_3_content', 'Love the game variety. Won ₹12K last week in a tournament.');
?>
