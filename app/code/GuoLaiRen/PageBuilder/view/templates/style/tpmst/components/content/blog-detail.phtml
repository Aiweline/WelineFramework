                <?php endif; ?>
                
                <!-- 文章内容 -->
                <div class="article-content">
                    <?= $currentPost['content'] ?? '' ?>
                </div>
                
                <!-- 标签 -->
                <?php if ($showTags && !empty($currentPost['tags'])): ?>
                <div class="article-tags">
                    <span class="tags-label"><?= __('Tags:') ?></span>
                    <?php 
                    $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', $currentPost['tags']);
                    foreach ($tags as $tag): 
                        $tag = trim($tag);
                        if (empty($tag)) continue;
