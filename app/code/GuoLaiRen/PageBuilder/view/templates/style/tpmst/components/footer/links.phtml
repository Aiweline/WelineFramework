<?php
/**
 * TPMST 底部链接组件 - Footer Links Component
 * 
 * 独立组件，所有 CSS/JS 内联，防止跨模板样式冲突
 * 
 * @component_start
 * code: footer-links
 * name: 链接底部
 * name_en: Footer with Links
 * description: 包含链接、版权信息的底部组件
 * category: footer
 * region: footer
 * @component_end
 * 
 * @fields_start
 * 
 * group:style => 样式配置
 * style.background_color => 背景颜色:color:#0a0a1a
 * style.text_color => 文字颜色:color:#cccccc
 * style.link_color => 链接颜色:color:#ff6b35
 * style.link_hover_color => 链接悬停颜色:color:#ffd700
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:#333333
 * 
 * group:content => 内容配置
 * content.use_subpages => 使用子页面作为链接:select:no|yes,no
 * content.footer_links => 页脚链接:textarea:Home|/,FAQ|/faq,Blog|/blog,About|/about,Privacy|/privacy
 * content.copyright_text => 版权信息:text:© 2025 Teen Patti Master | All rights reserved
 * content.disclaimer_text => 免责声明:textarea:Please be cautious with in-game recharges as they involve real money. Only spend what you can afford.
 * 
 * @fields_end
 */

// 组件唯一标识
$componentId = 'tpmst-footer-links-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并配置
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数
$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 样式配置
$bgColor = $getConfig('style.background_color', '#0a0a1a');
$textColor = $getConfig('style.text_color', '#8b8b8b');
$linkColor = $getConfig('style.link_color', '#bebebe');
$linkHoverColor = $getConfig('style.link_hover_color', '#ffd700');
$borderTop = $getConfig('style.border_top', 'yes') !== 'no';
$borderColor = $getConfig('style.border_color', '#333333');

// 内容配置
$useSubpages = $getConfig('content.use_subpages', 'no') === 'yes';
$copyrightText = $getConfig('content.copyright_text', '© 2025 Teen Patti Master | All rights reserved');
$disclaimerText = $getConfig('content.disclaimer_text', '');

// 链接配置
$footerLinks = [];
if ($useSubpages && $page) {
    $subpages = $page->getData('subpages') ?: [];
    foreach ($subpages as $subpage) {
        $footerLinks[] = [
            'text' => $subpage['title'] ?? '',
            'url' => $subpage['url'] ?? '#'
        ];
    }
}

if (empty($footerLinks)) {
    $footerLinksText = $getConfig('content.footer_links', 'Home|/,FAQ|/faq,Blog|/blog,About|/about');
    $links = explode(',', $footerLinksText);
    foreach ($links as $link) {
        $parts = explode('|', trim($link));
        if (count($parts) >= 2) {
            $footerLinks[] = [
                'text' => trim($parts[0]),
                'url' => trim($parts[1])
            ];
        }
    }
}
?>
<!-- TPMST Footer Links Component Start: <?= $componentId ?> -->
<style>
/* ============================================
   TPMST Footer Links Component - Scoped Styles
   Component ID: <?= $componentId ?>
   ============================================ */

#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor) ?>;
    <?= $borderTop ? 'border-top: 1px solid ' . htmlspecialchars($borderColor) . ';' : '' ?>
    padding: 30px 20px;
    margin-top: 0;
}

#<?= $componentId ?> .tpmst-footer-container {
    max-width: 1200px;
    margin: 0 auto;
}

#<?= $componentId ?> .tpmst-footer-content {
    text-align: center;
    color: <?= htmlspecialchars($textColor) ?>;
    font-size: 14px;
    line-height: 1.6;
}

#<?= $componentId ?> .tpmst-footer-links {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    list-style: none;
    padding: 0;
}

#<?= $componentId ?> .tpmst-footer-links a {
    color: <?= htmlspecialchars($linkColor) ?>;
    text-decoration: none;
    transition: color 0.3s;
    font-weight: 500;
}

#<?= $componentId ?> .tpmst-footer-links a:hover {
    color: <?= htmlspecialchars($linkHoverColor) ?>;
    text-decoration: underline;
}

#<?= $componentId ?> .tpmst-footer-links .separator {
    color: <?= htmlspecialchars($textColor) ?>;
    opacity: 0.5;
}

#<?= $componentId ?> .tpmst-footer-disclaimer {
    margin: 15px 0;
    padding: 15px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    font-size: 12px;
    line-height: 1.6;
    color: <?= htmlspecialchars($textColor) ?>;
}

#<?= $componentId ?> .tpmst-footer-copyright {
    margin: 15px 0 0;
    font-size: 12px;
    color: <?= htmlspecialchars($textColor) ?>;
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: 20px 15px;
    }
    
    #<?= $componentId ?> .tpmst-footer-links {
        flex-direction: column;
        gap: 10px;
    }
    
    #<?= $componentId ?> .tpmst-footer-links .separator {
        display: none;
    }
}
</style>

<footer id="<?= $componentId ?>" class="tpmst-footer-links-component">
    <div class="tpmst-footer-container">
        <div class="tpmst-footer-content">
            <!-- 页脚链接 -->
            <?php if (!empty($footerLinks)): ?>
            <div class="tpmst-footer-links">
                <?php foreach ($footerLinks as $index => $link): ?>
                    <?php if ($index > 0): ?><span class="separator">|</span><?php endif; ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
            
            <!-- 免责声明 -->
            <?php if (!empty($disclaimerText)): ?>
            <div class="tpmst-footer-disclaimer">
                <?= nl2br(htmlspecialchars($disclaimerText)) ?>
            </div>
            <?php endif; ?>
            
            <!-- 版权信息 -->
            <p class="tpmst-footer-copyright">
                <?= htmlspecialchars($copyrightText) ?>
            </p>
        </div>
    </div>
</footer>
<!-- TPMST Footer Links Component End: <?= $componentId ?> -->
