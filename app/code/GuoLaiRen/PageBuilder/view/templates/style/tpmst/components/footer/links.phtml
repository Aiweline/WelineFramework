<?php
/**
 * TPMST 底部链接组件 - Footer Links Component
 * 
 * 独立组件，所有 CSS/JS 内联，防止跨模板样式冲突
 * 
 * @component_start
 * code: footer-links
 * name: 链接底部
 * name_en: Footer with Links
 * description: 包含链接、版权信息的底部组件
 * category: footer
 * region: footer
 * @component_end
 * 
 * @fields_start
 * 
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 * 
 * group:style => 样式配置
 * style.background_color => 背景颜色:color:#0a0a1a
 * style.text_color => 文字颜色:color:#8b8b8b
 * style.link_color => 链接颜色:color:#bebebe
 * style.link_hover_color => 链接悬停颜色:color:#ffd700
 * style.link_font_size => 链接字号:number:14|px
 * style.link_font_weight => 链接字重:number:500
 * style.link_gap => 链接间距:number:15|px
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:#333333
 * style.border_width => 边框宽度:number:1|px
 * style.section_padding => 区域内边距(PC端):number:30|px
 * style.section_padding_mobile => 区域内边距(移动端):number:20|px
 * style.separator_display => 显示分隔符:select:yes|yes,no
 * style.separator_char => 分隔符字符:text:|
 * style.separator_color => 分隔符颜色:color:#8b8b8b
 * 
 * group:disclaimer => 免责声明样式
 * disclaimer.bg_color => 免责声明背景:color:rgba(255,255,255,0.05)
 * disclaimer.border_radius => 免责声明圆角:number:8|px
 * disclaimer.padding => 免责声明内边距:number:15|px
 * disclaimer.font_size => 免责声明字号:number:12|px
 * disclaimer.text_color => 免责声明颜色:color:#8b8b8b
 * 
 * group:copyright => 版权信息样式
 * copyright.font_size => 版权字号:number:12|px
 * copyright.text_color => 版权颜色:color:#8b8b8b
 * copyright.margin_top => 版权上边距:number:15|px
 * 
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:no|no,yes
 * content.footer_links => 页脚链接:textarea:Home|/,FAQ|/faq,Blog|/blog,About|/about,Privacy|/privacy|格式：名称|链接（仅当开启自定义链接时生效）
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 * content.copyright_text => 版权信息:text:© 2025 Teen Patti Master | All rights reserved
 * content.disclaimer_text => 免责声明:textarea:Please be cautious with in-game recharges as they involve real money. Only spend what you can afford.
 * 
 * @fields_end
 */

// 组件唯一标识
$componentId = 'tpmst-footer-links-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并配置
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数
$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 显示控制
$showLinks = $getConfig('display.show_links', 'yes') !== 'no';
$showDisclaimer = $getConfig('display.show_disclaimer', 'yes') !== 'no';
$showCopyright = $getConfig('display.show_copyright', 'yes') !== 'no';

// 样式配置
$bgColor = $getConfig('style.background_color', '#0a0a1a');
$textColor = $getConfig('style.text_color', '#8b8b8b');
$linkColor = $getConfig('style.link_color', '#bebebe');
$linkHoverColor = $getConfig('style.link_hover_color', '#ffd700');
$linkFontSize = $getConfig('style.link_font_size', '14');
$linkFontWeight = $getConfig('style.link_font_weight', '500');
$linkGap = $getConfig('style.link_gap', '15');
$borderTop = $getConfig('style.border_top', 'yes') !== 'no';
$borderColor = $getConfig('style.border_color', '#333333');
$borderWidth = $getConfig('style.border_width', '1');
$sectionPadding = $getConfig('style.section_padding', '30');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '20');
$separatorDisplay = $getConfig('style.separator_display', 'yes') !== 'no';
$separatorChar = $getConfig('style.separator_char', '|');
$separatorColor = $getConfig('style.separator_color', '#8b8b8b');

// 免责声明样式
$disclaimerBgColor = $getConfig('disclaimer.bg_color', 'rgba(255,255,255,0.05)');
$disclaimerBorderRadius = $getConfig('disclaimer.border_radius', '8');
$disclaimerPadding = $getConfig('disclaimer.padding', '15');
$disclaimerFontSize = $getConfig('disclaimer.font_size', '12');
$disclaimerTextColor = $getConfig('disclaimer.text_color', '#8b8b8b');

// 版权信息样式
$copyrightFontSize = $getConfig('copyright.font_size', '12');
$copyrightTextColor = $getConfig('copyright.text_color', '#8b8b8b');
$copyrightMarginTop = $getConfig('copyright.margin_top', '15');

// 内容配置
$useSubpages = $getConfig('content.use_subpages', 'no') === 'yes';
$copyrightText = $getConfig('content.copyright_text', '© 2025 Teen Patti Master | All rights reserved');
$disclaimerText = $getConfig('content.disclaimer_text', '');

// 链接配置：默认按页面类型自动生成；开启「使用自定义链接组」时用 content.footer_links
$useCustomLinks = $getConfig('content.use_custom_links', 'no') === 'yes';
$footerLinks = [];
if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $footerPages = $page->getHeaderNavigationPages(30);
    foreach ($footerPages as $fp) {
        $ft = $fp['type'] ?? '';
        $configuredLabel = trim((string)($getConfig('content.footer_label_' . $ft, '') ?? ''));
        $text = $configuredLabel !== '' ? $configuredLabel : ($fp['title'] ?? '');
        $url = $fp['url'] ?? '/';
        if (isset($fp['type']) && $fp['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
            $text = __('Home');
            $url = '/';
        }
        $footerLinks[] = ['text' => $text, 'url' => $url];
    }
}
if ($useCustomLinks || empty($footerLinks)) {
    $footerLinks = [];
    $footerLinksText = $getConfig('content.footer_links', 'Home|/,FAQ|/faq,Blog|/blog,About|/about');
    $links = explode(',', $footerLinksText);
    foreach ($links as $link) {
        $parts = explode('|', trim($link));
        if (count($parts) >= 2) {
            $footerLinks[] = [
                'text' => trim($parts[0]),
                'url' => trim($parts[1]),
            ];
        }
    }
}
?>
<!-- TPMST Footer Links Component Start: <?= $componentId ?> -->
<style>
/* ============================================
   TPMST Footer Links Component - Scoped Styles
   Component ID: <?= $componentId ?>
   ============================================ */

#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor) ?>;
    <?= $borderTop ? 'border-top: ' . htmlspecialchars($borderWidth) . 'px solid ' . htmlspecialchars($borderColor) . ';' : '' ?>
    padding: <?= htmlspecialchars($sectionPadding) ?>px 0;
    margin-top: 0;
    width: 100%;
}

#<?= $componentId ?> .tpmst-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

#<?= $componentId ?> .tpmst-footer-content {
    text-align: center;
    color: <?= htmlspecialchars($textColor) ?>;
    font-size: <?= htmlspecialchars($linkFontSize) ?>px;
    line-height: 1.6;
}

#<?= $componentId ?> .tpmst-footer-links {
    display: flex;
    justify-content: center;
    gap: <?= htmlspecialchars($linkGap) ?>px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    list-style: none;
    padding: 0;
}

#<?= $componentId ?> .tpmst-footer-links a {
    color: <?= htmlspecialchars($linkColor) ?>;
    text-decoration: none;
    transition: color 0.3s;
    font-weight: <?= htmlspecialchars($linkFontWeight) ?>;
    font-size: <?= htmlspecialchars($linkFontSize) ?>px;
}

#<?= $componentId ?> .tpmst-footer-links a:hover {
    color: <?= htmlspecialchars($linkHoverColor) ?>;
    text-decoration: underline;
}

#<?= $componentId ?> .tpmst-footer-links .separator {
    color: <?= htmlspecialchars($separatorColor) ?>;
    opacity: 0.5;
}

#<?= $componentId ?> .tpmst-footer-disclaimer {
    margin: 15px 0;
    padding: <?= htmlspecialchars($disclaimerPadding) ?>px;
    background: <?= htmlspecialchars($disclaimerBgColor) ?>;
    border-radius: <?= htmlspecialchars($disclaimerBorderRadius) ?>px;
    font-size: <?= htmlspecialchars($disclaimerFontSize) ?>px;
    line-height: 1.6;
    color: <?= htmlspecialchars($disclaimerTextColor) ?>;
}

#<?= $componentId ?> .tpmst-footer-copyright {
    margin: <?= htmlspecialchars($copyrightMarginTop) ?>px 0 0;
    font-size: <?= htmlspecialchars($copyrightFontSize) ?>px;
    color: <?= htmlspecialchars($copyrightTextColor) ?>;
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= htmlspecialchars($sectionPaddingMobile) ?>px 0;
    }
    
    #<?= $componentId ?> .tpmst-section-inner {
        padding: 0 15px;
    }
    
    #<?= $componentId ?> .tpmst-footer-links {
        flex-direction: column;
        gap: 10px;
    }
    
    #<?= $componentId ?> .tpmst-footer-links .separator {
        display: none;
    }
}
</style>

<footer id="<?= $componentId ?>" class="tpmst-section tpmst-footer-links-component">
    <div class="tpmst-section-inner">
        <div class="tpmst-footer-content">
            <!-- 页脚链接 -->
            <?php if ($showLinks && !empty($footerLinks)): ?>
            <div class="tpmst-footer-links">
                <?php foreach ($footerLinks as $index => $link): ?>
                    <?php if ($index > 0 && $separatorDisplay): ?><span class="separator"><?= htmlspecialchars($separatorChar) ?></span><?php endif; ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
            
            <!-- 免责声明 -->
            <?php if ($showDisclaimer && !empty($disclaimerText)): ?>
            <div class="tpmst-footer-disclaimer">
                <?= nl2br(htmlspecialchars($disclaimerText)) ?>
            </div>
            <?php endif; ?>
            
            <!-- 版权信息 -->
            <?php if ($showCopyright): ?>
            <p class="tpmst-footer-copyright">
                <?= htmlspecialchars($copyrightText) ?>
            </p>
            <?php endif; ?>
        </div>
    </div>
</footer>
<!-- TPMST Footer Links Component End: <?= $componentId ?> -->
