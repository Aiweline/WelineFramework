<section id="<?= $componentId ?>" class="tpmst-faq-component">
    <div class="tpmst-faq-container">
        <h2 class="tpmst-faq-title"><?= htmlspecialchars($title) ?></h2>
        <?php foreach ($faqs as $index => $faq): ?>
        <div class="tpmst-faq-item" data-faq-index="<?= $index ?>">
            <div class="tpmst-faq-question">
                <span><?= htmlspecialchars($faq['question']) ?></span>
                <span class="tpmst-faq-icon">+</span>
            </div>
            <div class="tpmst-faq-answer">
                <?= nl2br(htmlspecialchars($faq['answer'])) ?>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
</section>

<script>
(function() {
    var componentId = '<?= $componentId ?>';
    var container = document.getElementById(componentId);
    if (!container) return;
    
    container.querySelectorAll('.tpmst-faq-question').forEach(function(question) {
        question.addEventListener('click', function() {
            var item = this.parentElement;
            var wasActive = item.classList.contains('active');
            
            // 关闭其他
            container.querySelectorAll('.tpmst-faq-item').forEach(function(otherItem) {
                otherItem.classList.remove('active');
                otherItem.querySelector('.tpmst-faq-icon').textContent = '+';
            });
            
            // 切换当前
            if (!wasActive) {
                item.classList.add('active');
                item.querySelector('.tpmst-faq-icon').textContent = '−';
            }
        });
    });
})();
</script>
<!-- TPMST FAQ Component End: <?= $componentId ?> -->
