$componentId = 'tpmst-faq-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('faq.display', 'yes') !== 'no';
if (!$display) return;

$title = $getConfig('faq.title', 'FAQs');
$bgColor = $getConfig('faq.bg_color', '#0f0f1e');

$faqs = [
    [
        'question' => $getConfig('texts.faq_1_question', 'What is Teen Patti Master?'),
        'answer' => $getConfig('texts.faq_1_answer', "Teen Patti Master is India's best online card game, which combines strategy and luck for real cash prizes.")
    ],
    [
        'question' => $getConfig('texts.faq_2_question', 'How to Download Teen Patti Master APK?'),
        'answer' => $getConfig('texts.faq_2_answer', "Go to a reliable website and select the download option for the most recent version. It's free, safe, and mobile-friendly.")
    ],
    [
        'question' => $getConfig('texts.faq_3_question', 'Is Teen Patti Master Safe to Play?'),
        'answer' => $getConfig('texts.faq_3_answer', 'Yes, Teen Patti Master is designed to be secure, with features like SSL encryption to protect data.')
    ],
    [
        'question' => $getConfig('texts.faq_4_question', 'How to Win Real Cash?'),
        'answer' => $getConfig('texts.faq_4_answer', 'Win real money by mastering methods like bluffing with strong hands (e.g., Trail or Pure Sequence).')
    ],
    [
        'question' => $getConfig('texts.faq_5_question', 'What are the Game Variants?'),
        'answer' => $getConfig('texts.faq_5_answer', 'Teen Patti Master includes variants such as AK47, Muflis, and Joker for varied teen patti action.')
    ],
];
