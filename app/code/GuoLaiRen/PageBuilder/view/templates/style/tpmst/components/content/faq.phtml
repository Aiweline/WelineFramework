 * style.item_bg_color => 问题卡片背景色:color:rgba(255,255,255,0.05)
 * style.item_border_radius => 问题卡片圆角:number:8|px
 * style.item_border_color => 问题卡片边框色:color:rgba(255,255,255,0.1)
 * style.item_gap => 问题间距:number:15|px
 * style.question_color => 问题文字颜色:color:#ffd700
 * style.question_font_size => 问题字号(PC端):number:16|px
 * style.question_font_size_mobile => 问题字号(移动端):number:14|px
 * style.question_padding => 问题内边距:number:20|px
 * style.question_hover_bg => 问题悬停背景:color:rgba(255,255,255,0.05)
 * style.icon_color => 图标颜色:color:#ffd700
 * style.icon_size => 图标大小:number:20|px
 * style.answer_color => 答案文字颜色:color:#ffffff
 * style.answer_font_size => 答案字号:number:14|px
 * style.answer_padding => 答案内边距:number:20|px
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * 
 * group:texts => FAQ内容
 * texts.title => 区域标题:text:FAQs
 * texts.faq_1_question => 问题1:text:What is Teen Patti Master?
 * texts.faq_1_answer => 答案1:textarea:Teen Patti Master is India's best online card game...
 * texts.faq_2_question => 问题2:text:How to Download Teen Patti Master APK?
 * texts.faq_2_answer => 答案2:textarea:Go to a reliable website and select the download option...
 * texts.faq_3_question => 问题3:text:Is Teen Patti Master Safe to Play?
 * texts.faq_3_answer => 答案3:textarea:Yes, Teen Patti Master is designed to be secure...
 * texts.faq_4_question => 问题4:text:How to Win Real Cash?
 * texts.faq_4_answer => 答案4:textarea:Win real money by mastering methods like bluffing...
 * texts.faq_5_question => 问题5:text:What are the Game Variants?
 * texts.faq_5_answer => 答案5:textarea:Teen Patti Master includes variants such as AK47, Muflis, and Joker...
 * 
 * @fields_end
 */

$componentId = 'tpmst-faq-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 显示控制
$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

// 样式配置
$bgColor = $getConfig('style.bg_color', $getConfig('faq.bg_color', '#0f0f1e'));
$titleColor = $getConfig('style.title_color', '#ffd700');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$itemBgColor = $getConfig('style.item_bg_color', 'rgba(255,255,255,0.05)');
$itemBorderRadius = $getConfig('style.item_border_radius', '8');
$itemBorderColor = $getConfig('style.item_border_color', 'rgba(255,255,255,0.1)');
$itemGap = $getConfig('style.item_gap', '15');
$questionColor = $getConfig('style.question_color', '#ffd700');
$questionFontSize = $getConfig('style.question_font_size', '16');
$questionFontSizeMobile = $getConfig('style.question_font_size_mobile', '14');
$questionPadding = $getConfig('style.question_padding', '20');
$questionHoverBg = $getConfig('style.question_hover_bg', 'rgba(255,255,255,0.05)');
$iconColor = $getConfig('style.icon_color', '#ffd700');
$iconSize = $getConfig('style.icon_size', '20');
$answerColor = $getConfig('style.answer_color', '#ffffff');
$answerFontSize = $getConfig('style.answer_font_size', '14');
$answerPadding = $getConfig('style.answer_padding', '20');
$sectionPadding = $getConfig('style.section_padding', '60');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '40');

// 标题
$title = $getConfig('texts.title', $getConfig('faq.title', 'FAQs'));

$faqs = [
    [
        'question' => $getConfig('texts.faq_1_question', 'What is Teen Patti Master?'),
        'answer' => $getConfig('texts.faq_1_answer', "Teen Patti Master is India's best online card game, which combines strategy and luck for real cash prizes.")
    ],
    [
        'question' => $getConfig('texts.faq_2_question', 'How to Download Teen Patti Master APK?'),
        'answer' => $getConfig('texts.faq_2_answer', "Go to a reliable website and select the download option for the most recent version. It's free, safe, and mobile-friendly.")
    ],
    [
        'question' => $getConfig('texts.faq_3_question', 'Is Teen Patti Master Safe to Play?'),
        'answer' => $getConfig('texts.faq_3_answer', 'Yes, Teen Patti Master is designed to be secure, with features like SSL encryption to protect data.')
    ],
    [
        'question' => $getConfig('texts.faq_4_question', 'How to Win Real Cash?'),
        'answer' => $getConfig('texts.faq_4_answer', 'Win real money by mastering methods like bluffing with strong hands (e.g., Trail or Pure Sequence).')
    ],
    [
        'question' => $getConfig('texts.faq_5_question', 'What are the Game Variants?'),
        'answer' => $getConfig('texts.faq_5_answer', 'Teen Patti Master includes variants such as AK47, Muflis, and Joker for varied teen patti action.')
    ],
];
?>
<!-- TPMST FAQ Component Start: <?= $componentId ?> -->
<style>
#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor) ?>;
    padding: <?= htmlspecialchars($sectionPadding) ?>px 0;
    width: 100%;
}

#<?= $componentId ?> .tpmst-section-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
}

#<?= $componentId ?> .tpmst-faq-title {
    text-align: center;
    font-size: clamp(<?= htmlspecialchars($titleFontSizeMobile) ?>px, 5vw, <?= htmlspecialchars($titleFontSize) ?>px);
    color: <?= htmlspecialchars($titleColor) ?>;
    margin-bottom: 40px;
    font-weight: 700;
}

#<?= $componentId ?> .tpmst-faq-item {
    background: <?= htmlspecialchars($itemBgColor) ?>;
    border-radius: <?= htmlspecialchars($itemBorderRadius) ?>px;
    margin-bottom: <?= htmlspecialchars($itemGap) ?>px;
    overflow: hidden;
    border: 1px solid <?= htmlspecialchars($itemBorderColor) ?>;
}

#<?= $componentId ?> .tpmst-faq-question {
    padding: <?= htmlspecialchars($questionPadding) ?>px;
    cursor: pointer;
    font-weight: 600;
    font-size: <?= htmlspecialchars($questionFontSize) ?>px;
    color: <?= htmlspecialchars($questionColor) ?>;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.3s;
}

#<?= $componentId ?> .tpmst-faq-question:hover {
    background: <?= htmlspecialchars($questionHoverBg) ?>;
}

#<?= $componentId ?> .tpmst-faq-icon {
    font-size: <?= htmlspecialchars($iconSize) ?>px;
    color: <?= htmlspecialchars($iconColor) ?>;
    transition: transform 0.3s;
}

#<?= $componentId ?> .tpmst-faq-item.active .tpmst-faq-icon {
    transform: rotate(45deg);
}

#<?= $componentId ?> .tpmst-faq-answer {
    padding: 0 <?= htmlspecialchars($answerPadding) ?>px <?= htmlspecialchars($answerPadding) ?>px;
    color: <?= htmlspecialchars($answerColor) ?>;
    font-size: <?= htmlspecialchars($answerFontSize) ?>px;
    display: none;
    line-height: 1.8;
    opacity: 0.9;
}

#<?= $componentId ?> .tpmst-faq-item.active .tpmst-faq-answer {
    display: block;
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= htmlspecialchars($sectionPaddingMobile) ?>px 0;
    }
    
    #<?= $componentId ?> .tpmst-section-inner {
        padding: 0 15px;
    }
    
    #<?= $componentId ?> .tpmst-faq-question {
        padding: 15px;
        font-size: <?= htmlspecialchars($questionFontSizeMobile) ?>px;
    }
}
</style>

<section id="<?= $componentId ?>" class="tpmst-section tpmst-faq-component">
    <div class="tpmst-section-inner">
        <?php if ($showTitle): ?>
        <h2 class="tpmst-faq-title"><?= htmlspecialchars($title) ?></h2>
        <?php endif; ?>
        <?php foreach ($faqs as $index => $faq): ?>
        <div class="tpmst-faq-item<?= ($firstOpen && $index === 0) ? ' active' : '' ?>" data-faq-index="<?= $index ?>">
            <div class="tpmst-faq-question">
                <span><?= htmlspecialchars($faq['question']) ?></span>
                <span class="tpmst-faq-icon"><?= ($firstOpen && $index === 0) ? '−' : '+' ?></span>
            </div>
            <div class="tpmst-faq-answer">
                <?= nl2br(htmlspecialchars($faq['answer'])) ?>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
</section>

<script>
(function() {
    var componentId = '<?= $componentId ?>';
    var container = document.getElementById(componentId);
    if (!container) return;
    
    container.querySelectorAll('.tpmst-faq-question').forEach(function(question) {
        question.addEventListener('click', function() {
            var item = this.parentElement;
            var wasActive = item.classList.contains('active');
            
            // 关闭其他
            container.querySelectorAll('.tpmst-faq-item').forEach(function(otherItem) {
                otherItem.classList.remove('active');
                otherItem.querySelector('.tpmst-faq-icon').textContent = '+';
            });
            
            // 切换当前
            if (!wasActive) {
                item.classList.add('active');
                item.querySelector('.tpmst-faq-icon').textContent = '−';
            }
        });
    });
})();
</script>
<!-- TPMST FAQ Component End: <?= $componentId ?> -->
