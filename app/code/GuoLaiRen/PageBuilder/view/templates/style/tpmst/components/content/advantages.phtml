$componentId = 'tpmst-advantages-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('advantages.display', 'yes') !== 'no';
if (!$display) return;

$title = $getConfig('advantages.title', 'Our Advantages');
$bgColor = $getConfig('advantages.bg_color', '#1a1a2e');

$defaultIcon1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon01.webp');
$defaultIcon2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon02.webp');
$defaultIcon3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon03.webp');

$icon1 = $getConfig('advantages.icon_1', '') ?: $defaultIcon1;
$icon2 = $getConfig('advantages.icon_2', '') ?: $defaultIcon2;
$icon3 = $getConfig('advantages.icon_3', '') ?: $defaultIcon3;

$title1 = $getConfig('texts.advantage_1_title', 'Teen Patti Speed');
$desc1 = $getConfig('texts.advantage_1_desc', 'Fast-paced variant where players bet quickly, aiming for the best three-card hand in thrilling, rapid rounds.');
$title2 = $getConfig('texts.advantage_2_title', 'Rummy Master');
$desc2 = $getConfig('texts.advantage_2_desc', 'Skillfully meld cards into sets and sequences in a race to be the first to go out and declare victory.');
$title3 = $getConfig('texts.advantage_3_title', 'Slots Meta');
$desc3 = $getConfig('texts.advantage_3_desc', 'A dazzling array of themed slots where players spin for matching symbols and bonuses in a quest for jackpot wins.');
?>
<!-- TPMST Advantages Component Start: <?= $componentId ?> -->
<style>
