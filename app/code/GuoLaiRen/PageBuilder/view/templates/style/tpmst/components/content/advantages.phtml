<section id="<?= $componentId ?>" class="tpmst-advantages-component">
    <div class="tpmst-adv-container">
        <h2 class="tpmst-adv-title"><?= htmlspecialchars($title) ?></h2>
        <div class="tpmst-adv-grid">
            <div class="tpmst-adv-card">
                <img class="tpmst-adv-icon" src="<?= htmlspecialchars($icon1) ?>" alt="<?= htmlspecialchars($title1) ?>">
                <h3 class="tpmst-adv-card-title"><?= htmlspecialchars($title1) ?></h3>
                <p class="tpmst-adv-card-desc"><?= htmlspecialchars($desc1) ?></p>
