                <a href="#download" class="tpmst-adv-btn">Download</a>
            </div>
            <div class="tpmst-adv-card">
                <img class="tpmst-adv-icon" src="<?= htmlspecialchars($icon3) ?>" alt="<?= htmlspecialchars($title3) ?>">
                <h3 class="tpmst-adv-card-title"><?= htmlspecialchars($title3) ?></h3>
                <p class="tpmst-adv-card-desc"><?= htmlspecialchars($desc3) ?></p>
                <a href="#download" class="tpmst-adv-btn">Download</a>
            </div>
