<?php
/**
 * TPMST 头部导航组件 - Header Navigation Component
 * 
 * Logo居中布局，导航链接在Logo下方
 * 独立组件，所有 CSS/JS 内联，防止跨模板样式冲突
 * 
 * @component_start
 * code: header-nav
 * name: 导航头部（Logo居中）
 * name_en: Navigation Header (Logo Centered)
 * description: Logo居中布局，包含导航菜单、下载按钮和Banner的头部组件
 * category: header
 * region: header
 * thumbnail: asset/img/logo-icon-128.avif
 * @component_end
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo地址:textarea:|默认使用本地logo-icon-128.avif
 * logo.width => Logo宽度:responsive:70/70|px
 * logo.height => Logo高度:responsive:|px[可选，默认使用width值]
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#1a1a2e
 * navigation.text_color => 导航文字颜色:color:#ffffff
 * navigation.link_color => 链接颜色:color:#ffffff
 * navigation.link_hover_color => 链接悬停颜色:color:#ffd700
 * navigation.items => 导航项配置:textarea:Home=>\r\nAbout=>\r\nBlog=>\r\nFAQs=>|配置格式：名字=>url，一行一个
 * navigation.use_subpages => 使用子页面作为导航:select:no|yes,no
 * 
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:DOWNLOAD APP
 * download_button.bg_color => 按钮背景色:color:#ff6b35
 * download_button.text_color => 按钮文字颜色:color:#ffffff
 * download_button.border_radius => 按钮圆角:number:8|px
 * 
 * group:banner => Banner横幅
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端图片:textarea:|默认使用本地banner-2.jpg
 * banner.image_desktop => PC端图片:textarea:|默认使用本地banner-03.webp
 * banner.alt => 图片描述:text:100000 earn on teenpatti master
 * banner.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn-m.webp
 * 
 * @fields_end
 */

// 组件唯一标识，防止样式冲突
$componentId = 'tpmst-header-nav-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并组件配置和样式配置
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数
$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$parseResponsive = function($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    $value = trim($value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim($parts[0] ?? ''),
        'desktop' => trim($parts[1] ?? $parts[0] ?? ''),
        'unit' => $unit
    ];
};

$genResponsiveCSS = function($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

// Logo配置
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/logo-icon-128.avif');
$logoUrl = $getConfig('logo.url', '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfig('logo.width', '70/70') . 'px'));
$logoHeightConfig = $getConfig('logo.height', '');
$logoHeight = empty($logoHeightConfig) ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));

// 导航配置
$navDisplay = $getConfig('navigation.display', 'yes') !== 'no';
$navBgColor = $getConfig('navigation.bg_color', '#0a0a0f');
$navTextColor = $getConfig('navigation.text_color', '#ffffff');
$navLinkColor = $getConfig('navigation.link_color', '#ffffff');
$navLinkHoverColor = $getConfig('navigation.link_hover_color', '#ffd700');
$useSubpages = $getConfig('navigation.use_subpages', 'no') === 'yes';

// 导航项
$navItems = [];
if ($useSubpages && $page) {
    // 使用子页面作为导航
    $subpages = $page->getData('subpages') ?: [];
    foreach ($subpages as $subpage) {
        $navItems[] = [
            'text' => $subpage['title'] ?? '',
            'href' => $subpage['url'] ?? '#'
        ];
    }
}

if (empty($navItems)) {
    // 使用配置的导航项
    $navItemsConfig = $getConfig('navigation.items', "Home=>\nAbout=>\nBlog=>\nFAQs=>");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    $lines = preg_split('/\r?\n/', $navItemsConfig);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        if (strpos($line, '=>') !== false) {
            $parts = explode('=>', $line, 2);
            $text = trim($parts[0]);
            $href = trim($parts[1] ?? '');
            if (!empty($text)) {
                $navItems[] = ['text' => $text, 'href' => !empty($href) ? $href : '#'];
            }
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '#home'],
        ['text' => 'About', 'href' => '#about'],
        ['text' => 'Blog', 'href' => '#blog'],
        ['text' => 'FAQs', 'href' => '#faqs'],
    ];
}

// 下载按钮配置
$downloadBtnDisplay = $getConfig('download_button.display', 'yes') !== 'no';
$downloadBtnText = $getConfig('download_button.text', 'DOWNLOAD APP');
$downloadBtnBgColor = $getConfig('download_button.bg_color', 'linear-gradient(90deg, #ffd700 0%, #ffa500 100%)');
$downloadBtnTextColor = $getConfig('download_button.text_color', '#8b4513');
$downloadBtnRadius = $getConfig('download_button.border_radius', '8');

// Banner配置
$bannerDisplay = $getConfig('banner.display', 'yes') !== 'no';
$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/download-btn-m.webp');

$bannerMobile = $getConfig('banner.image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('banner.image_desktop', '') ?: $defaultBannerDesktop;
$bannerAlt = $getConfig('banner.alt', '100000 earn on teenpatti master');
$bannerDownloadImg = $getConfig('banner.download_btn_image', '') ?: $defaultDownloadBtn;

// SEO
$metaTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Teen Patti Master';
$metaDescription = $page ? ($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? ($page->getData('meta_keywords') ?: '') : '';
$pageIcon = $page ? ($page->getData('icon') ?: '') : '';
?>
<!-- TPMST Header Nav Component Start: <?= $componentId ?> -->
