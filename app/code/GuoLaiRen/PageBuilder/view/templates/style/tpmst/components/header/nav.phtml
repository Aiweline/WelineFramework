<?php
/**
 * TPMST 头部导航组件 - Header Navigation Component
 * 
 * Logo居中布局，导航链接在Logo下方
 * 独立组件，所有 CSS/JS 内联，防止跨模板样式冲突
 * 
 * @component_start
 * code: header-nav
 * name: 导航头部（Logo居中）
 * name_en: Navigation Header (Logo Centered)
 * description: Logo居中布局，包含导航菜单和下载按钮的头部组件
 * category: header
 * region: header
 * thumbnail: asset/img/logo-icon-128.avif
 * @component_end
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo地址:textarea:|默认使用本地logo-icon-128.avif
 * logo.width => Logo宽度:responsive:70/70|px
 * logo.height => Logo高度:responsive:|px[可选，默认使用width值]
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#0a0a0f
 * navigation.bg_color_scrolled => 滚动后背景色:color:rgba(10, 10, 15, 0.98)
 * navigation.text_color => 导航文字颜色:color:#ffffff
 * navigation.link_color => 链接颜色:color:#ffffff
 * navigation.link_hover_color => 链接悬停颜色:color:#ffd700
 * navigation.link_font_size => 链接字号:number:14|px
 * navigation.link_font_weight => 链接字重:number:500
 * navigation.link_gap => 链接间距:number:40|px
 * navigation.padding_x => 水平内边距:number:24|px
 * navigation.padding_y => 垂直内边距:number:12|px
 * navigation.min_height => 最小高度:number:70|px
 * navigation.box_shadow => 阴影:text:0 2px 10px rgba(0,0,0,0.5)
 * navigation.backdrop_blur => 背景模糊:number:10|px
 * navigation.use_custom_links => 使用自定义导航链接:select:no|no,yes
 * navigation.items => 导航项配置:textarea:Home=>\r\nAbout=>\r\nBlog=>\r\nFAQs=>|配置格式：名字=>url，一行一个（仅当开启自定义链接时生效）
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * 
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:DOWNLOAD APP
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff6b35
 * download_button.bg_hover_color => 按钮悬停背景色:color:#e55a2b
 * download_button.text_color => 按钮文字颜色:color:#ffffff
 * download_button.font_size => 按钮字号:number:12|px
 * download_button.font_weight => 按钮字重:number:700
 * download_button.border_radius => 按钮圆角:number:8|px
 * download_button.padding_x => 按钮水平内边距:number:20|px
 * download_button.padding_y => 按钮垂直内边距:number:10|px
 * 
 * @fields_end
 */

// 组件唯一标识，防止样式冲突
$componentId = 'tpmst-header-nav-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并组件配置和样式配置
// 注意：component_config 优先于 style_settings，确保组件特定配置能覆盖样式默认配置
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数
$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$parseResponsive = function($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    $value = trim($value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim($parts[0] ?? ''),
        'desktop' => trim($parts[1] ?? $parts[0] ?? ''),
        'unit' => $unit
    ];
};

$genResponsiveCSS = function($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

// Logo配置
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/logo-icon-128.avif');
$logoUrl = $getConfig('logo.url', '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfig('logo.width', '70/70') . 'px'));
$logoHeightConfig = $getConfig('logo.height', '');
$logoHeight = empty($logoHeightConfig) ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));

// 导航配置（背景优先用配置，否则用主题色 nav_bg）
$themeNavBg = (isset($colors) && is_array($colors) && !empty($colors['nav_bg'])) ? $colors['nav_bg'] : '#0a0a0f';
$themeNavBgScrolled = (isset($colors) && is_array($colors) && !empty($colors['nav_bg_scrolled'])) ? $colors['nav_bg_scrolled'] : 'rgba(10, 10, 15, 0.98)';
$navDisplay = $getConfig('navigation.display', 'yes') !== 'no';
$navBgColor = $getConfig('navigation.bg_color', $themeNavBg);
$navBgColorScrolled = $getConfig('navigation.bg_color_scrolled', $themeNavBgScrolled);
$navTextColor = $getConfig('navigation.text_color', '#ffffff');
$navLinkColor = $getConfig('navigation.link_color', '#ffffff');
$navLinkHoverColor = $getConfig('navigation.link_hover_color', '#ffd700');
$navLinkFontSize = $getConfig('navigation.link_font_size', '14');
$navLinkFontWeight = $getConfig('navigation.link_font_weight', '500');
$navLinkGap = $getConfig('navigation.link_gap', '40');
$navPaddingX = $getConfig('navigation.padding_x', '24');
$navPaddingY = $getConfig('navigation.padding_y', '12');
$navMinHeight = $getConfig('navigation.min_height', '70');
$navBoxShadow = $getConfig('navigation.box_shadow', '0 2px 10px rgba(0,0,0,0.5)');
$navBackdropBlur = $getConfig('navigation.backdrop_blur', '10');

// 导航项：默认按页面类型自动生成；开启「使用自定义导航链接」时用 navigation.items
$navItems = [];
$useCustomLinks = $getConfig('navigation.use_custom_links', 'no') === 'yes';
if (!$useCustomLinks && $page) {
    $headerPages = $page->getHeaderNavigationPages(10);
    foreach ($headerPages as $navPage) {
        $type = $navPage['type'] ?? '';
        $configuredLabel = trim((string)($getConfig('navigation.label_' . $type, '') ?? ''));
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '/',
            'type' => $type,
        ];
    }
}

if ($useCustomLinks || empty($navItems)) {
    $navItems = [];
    $navItemsConfig = $getConfig('navigation.items', "Home=>\nAbout=>\nBlog=>\nFAQs=>");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    $lines = preg_split('/\r?\n/', $navItemsConfig);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        if (strpos($line, '=>') !== false) {
            $parts = explode('=>', $line, 2);
            $text = trim($parts[0]);
            $href = trim($parts[1] ?? '');
            if (!empty($text)) {
                if (empty($href)) {
                    $href = '/' . strtolower(preg_replace('/[^a-zA-Z0-9]+/', '-', trim($text)));
                }
                $navItems[] = ['text' => $text, 'href' => $href];
            }
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

// 下载按钮配置
$downloadBtnDisplay = $getConfig('download_button.display', 'yes') !== 'no';
$downloadBtnText = $getConfig('download_button.text', 'DOWNLOAD APP');
$downloadBtnUrl = $getConfig('download_button.url', '#download');
$downloadBtnBgColor = $getConfig('download_button.bg_color', '#ff6b35');
$downloadBtnBgHoverColor = $getConfig('download_button.bg_hover_color', '#e55a2b');
$downloadBtnTextColor = $getConfig('download_button.text_color', '#ffffff');
$downloadBtnFontSize = $getConfig('download_button.font_size', '12');
$downloadBtnFontWeight = $getConfig('download_button.font_weight', '700');
$downloadBtnRadius = $getConfig('download_button.border_radius', '8');
$downloadBtnPaddingX = $getConfig('download_button.padding_x', '20');
$downloadBtnPaddingY = $getConfig('download_button.padding_y', '10');


// SEO
$metaTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Teen Patti Master';
$metaDescription = $page ? ($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? ($page->getData('meta_keywords') ?: '') : '';
$pageIcon = $page ? ($page->getData('icon') ?: '') : '';
?>
<!-- TPMST Header Nav Component Start: <?= $componentId ?> -->
