<?php
/**
 * TPMST 游戏介绍组件 - Games Component
 * 
 * @component_start
 * code: games
 * name: 游戏介绍
 * name_en: Games Showcase
 * description: 游戏/产品介绍卡片，支持图片和描述
 * category: content
 * region: content
 * thumbnail: asset/img/game/game-i1.webp
 * @component_end
 * 
 * @fields_start
 * 
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示卡片描述:select:yes|yes,no
 * 
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#0f0f1e
 * style.title_color => 标题颜色:color:#ffd700
 * style.title_font_size => 标题字体大小(PC端):number:36|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.05)
 * style.card_border_radius => 卡片圆角:number:12|px
 * style.card_border_color => 卡片边框色:color:rgba(255,255,255,0.1)
 * style.card_title_color => 卡片标题颜色:color:#ffd700
 * style.card_title_font_size => 卡片标题字号:number:20|px
 * style.card_desc_color => 卡片描述颜色:color:#ffffff
 * style.card_desc_font_size => 卡片描述字号:number:14|px
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * style.card_gap => 卡片间距:number:30|px
 * style.card_content_padding => 卡片内容内边距:number:20|px
 * style.hover_transform => 悬停上移距离:number:5|px
 * 
 * group:images => 图片配置
 * images.image_1_desktop => 游戏1桌面端图片:textarea:|默认使用本地图片
 * images.image_1_mobile => 游戏1移动端图片:textarea:|默认使用本地图片
 * images.image_2 => 游戏2图片:textarea:|默认使用本地图片
 * images.image_3 => 游戏3图片:textarea:|默认使用本地图片
 * 
 * group:texts => 游戏文本
 * texts.title => 区域标题:text:Multiples Game
 * texts.game_1_title => 游戏1标题:text:Teen Patti Master
 * texts.game_1_desc => 游戏1描述:textarea:A thrilling card game that combines strategy and luck.
 * texts.game_2_title => 游戏2标题:text:Rummy
 * texts.game_2_desc => 游戏2描述:textarea:Match cards into sets or runs to win.
 * texts.game_3_title => 游戏3标题:text:Slots
 * texts.game_3_desc => 游戏3描述:textarea:Games of chance with spinning reels.
 * 
 * @fields_end
 */

$componentId = 'tpmst-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 显示控制
$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

// 样式配置
$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#0f0f1e'));
$titleColor = $getConfig('style.title_color', '#ffd700');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.05)');
$cardBorderRadius = $getConfig('style.card_border_radius', '12');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,255,255,0.1)');
$cardTitleColor = $getConfig('style.card_title_color', '#ffd700');
$cardTitleFontSize = $getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', '#ffffff');
$cardDescFontSize = $getConfig('style.card_desc_font_size', '14');
$sectionPadding = $getConfig('style.section_padding', '60');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '40');
$cardGap = $getConfig('style.card_gap', '30');
$cardContentPadding = $getConfig('style.card_content_padding', '20');
$hoverTransform = $getConfig('style.hover_transform', '5');

// 图片配置
$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/game/game-i1.webp');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/game/game-i1-m.webp');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/game/game-i2.webp');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/game/game-i3.webp');

$image1Desktop = $getConfig('images.image_1_desktop', $getConfig('games.image_1_desktop', '')) ?: $defaultImage1Desktop;
$image1Mobile = $getConfig('images.image_1_mobile', $getConfig('games.image_1_mobile', '')) ?: $defaultImage1Mobile;
$image2 = $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2;
$image3 = $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3;

// 文本内容
$title = $getConfig('texts.title', $getConfig('games.title', 'Multiples Game'));
$title1 = $getConfig('texts.game_1_title', 'Teen Patti Master');
$desc1 = $getConfig('texts.game_1_desc', 'Teen Patti Master is a thrilling card game that combines strategy and luck. Players aim to create the best three-card hand.');
$title2 = $getConfig('texts.game_2_title', 'Rummy');
$desc2 = $getConfig('texts.game_2_desc', 'Rummy is a card game where players match cards into sets or runs, aiming to be the first to play all their cards.');
$title3 = $getConfig('texts.game_3_title', 'Slots');
$desc3 = $getConfig('texts.game_3_desc', 'Slots are games of chance where players spin reels with symbols, aiming to match combinations for potential wins.');
?>
<!-- TPMST Games Component Start: <?= $componentId ?> -->
<style>
#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor) ?>;
    padding: <?= htmlspecialchars($sectionPadding) ?>px 0;
    width: 100%;
}

#<?= $componentId ?> .tpmst-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

#<?= $componentId ?> .tpmst-games-title {
    text-align: center;
    font-size: clamp(<?= htmlspecialchars($titleFontSizeMobile) ?>px, 5vw, <?= htmlspecialchars($titleFontSize) ?>px);
    color: <?= htmlspecialchars($titleColor) ?>;
    margin-bottom: 40px;
    font-weight: 700;
}

#<?= $componentId ?> .tpmst-games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: <?= htmlspecialchars($cardGap) ?>px;
}

#<?= $componentId ?> .tpmst-game-card {
    background: <?= htmlspecialchars($cardBgColor) ?>;
    border-radius: <?= htmlspecialchars($cardBorderRadius) ?>px;
    overflow: hidden;
    border: 1px solid <?= htmlspecialchars($cardBorderColor) ?>;
    transition: transform 0.3s, box-shadow 0.3s;
}

#<?= $componentId ?> .tpmst-game-card:hover {
    transform: translateY(-<?= htmlspecialchars($hoverTransform) ?>px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

#<?= $componentId ?> .tpmst-game-image {
    width: 100%;
    height: auto;
}

#<?= $componentId ?> .tpmst-game-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
}

#<?= $componentId ?> .tpmst-game-content {
    padding: <?= htmlspecialchars($cardContentPadding) ?>px;
}

#<?= $componentId ?> .tpmst-game-card-title {
    font-size: <?= htmlspecialchars($cardTitleFontSize) ?>px;
    color: <?= htmlspecialchars($cardTitleColor) ?>;
    margin-bottom: 10px;
    font-weight: 600;
}

#<?= $componentId ?> .tpmst-game-card-desc {
    font-size: <?= htmlspecialchars($cardDescFontSize) ?>px;
    color: <?= htmlspecialchars($cardDescColor) ?>;
    line-height: 1.6;
    opacity: 0.9;
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= htmlspecialchars($sectionPaddingMobile) ?>px 0;
    }
    
    #<?= $componentId ?> .tpmst-section-inner {
        padding: 0 15px;
    }
    
    #<?= $componentId ?> .tpmst-games-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<section id="<?= $componentId ?>" class="tpmst-section tpmst-games-component">
    <div class="tpmst-section-inner">
        <?php if ($showTitle): ?>
        <h2 class="tpmst-games-title"><?= htmlspecialchars($title) ?></h2>
        <?php endif; ?>
        <div class="tpmst-games-grid">
            <div class="tpmst-game-card">
                <div class="tpmst-game-image">
                    <picture>
                        <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($image1Mobile) ?>">
                        <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($image1Desktop) ?>">
                        <img src="<?= htmlspecialchars($image1Mobile) ?>" alt="<?= htmlspecialchars($title1) ?>">
                    </picture>
                </div>
                <div class="tpmst-game-content">
                    <h3 class="tpmst-game-card-title"><?= htmlspecialchars($title1) ?></h3>
                    <?php if ($showDescription): ?>
                    <p class="tpmst-game-card-desc"><?= htmlspecialchars($desc1) ?></p>
                    <?php endif; ?>
                </div>
            </div>
            <div class="tpmst-game-card">
                <div class="tpmst-game-image">
                    <img src="<?= htmlspecialchars($image2) ?>" alt="<?= htmlspecialchars($title2) ?>">
                </div>
                <div class="tpmst-game-content">
                    <h3 class="tpmst-game-card-title"><?= htmlspecialchars($title2) ?></h3>
                    <?php if ($showDescription): ?>
                    <p class="tpmst-game-card-desc"><?= htmlspecialchars($desc2) ?></p>
                    <?php endif; ?>
                </div>
            </div>
            <div class="tpmst-game-card">
                <div class="tpmst-game-image">
                    <img src="<?= htmlspecialchars($image3) ?>" alt="<?= htmlspecialchars($title3) ?>">
                </div>
                <div class="tpmst-game-content">
                    <h3 class="tpmst-game-card-title"><?= htmlspecialchars($title3) ?></h3>
                    <?php if ($showDescription): ?>
                    <p class="tpmst-game-card-desc"><?= htmlspecialchars($desc3) ?></p>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- TPMST Games Component End: <?= $componentId ?> -->
