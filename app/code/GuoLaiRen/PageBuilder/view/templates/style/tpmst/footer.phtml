 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'tpmst';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'tpmst';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色辅助函数
if (!function_exists('tpmst_color')) {
    function tpmst_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('tpmst_getConfig')) {
    function tpmst_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

if (!function_exists('tpmst_parseResponsive')) {
    function tpmst_parseResponsive($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => ''];
    $value = trim($value);
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
    if (count($parts) === 2) {
        $result['mobile'] = trim($parts[0]);
        $result['desktop'] = trim($parts[1]);
    } else {
        $result['mobile'] = $result['desktop'] = trim($parts[0] ?? '');
    }
    return $result;
    }
}

if (!function_exists('tpmst_genResponsiveCSS')) {
    function tpmst_genResponsiveCSS($parsed) {
        $mobile = floatval($parsed['mobile']);
        $desktop = floatval($parsed['desktop']);
        $unit = $parsed['unit'];
        if ($mobile === $desktop) return $mobile . $unit;
        $diff = $desktop - $mobile;
        return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
    }
}

// 样式配置（优先使用颜色配置）
$bgColor = tpmst_color($colors, 'footer_bg', tpmst_getConfig($styleSettings, 'style.background_color', '#0a0a1a'));
$textColor = tpmst_color($colors, 'footer_text', tpmst_getConfig($styleSettings, 'style.text_color', '#8b8b8b'));
