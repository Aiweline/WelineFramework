$footerAboutText = tpmst_getConfig($styleSettings, 'texts.footer_about', 'About');
$footerPrivacyText = tpmst_getConfig($styleSettings, 'texts.footer_privacy', 'Privacy Policy');
$footerTermsText = tpmst_getConfig($styleSettings, 'texts.footer_terms', 'Terms & Conditions');
$copyrightText = tpmst_getConfig($styleSettings, 'content.copyright_text', '© 2025 Teen Patti Master | All rights reserved');
$disclaimerText = tpmst_getConfig($styleSettings, 'content.disclaimer_text', 'Please be cautious with in-game recharges as they involve real money. Only spend what you can afford, and ensure all transactions are secure. This game is strictly for users 18+. By downloading or playing, you confirm you meet the age requirement.');

// 页脚链接：直接来自当前站点下的所有已发布页面，菜单名优先用配置项（有配置则显示配置名，否则用页面标题）
$footerLinks = [];
if ($page) {
    $footerPages = $page->getNavigationPages([\GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG], 30);
    foreach ($footerPages as $fp) {
        $ft = $fp['type'] ?? '';
        $labelKey = 'content.footer_label_' . $ft;
        $configuredLabel = trim((string)(tpmst_getConfig($styleSettings, $labelKey, '') ?? ''));
        $footerLinks[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($fp['title'] ?? ''),
            'url' => $fp['url'] ?? '/',
        ];
    }
}
if (empty($footerLinks)) {
    $footerLinksText = tpmst_getConfig($styleSettings, 'content.footer_links', 'Home|/,FAQ|/faq,Blog|/blog,About|/about,Privacy|/privacy');
    $links = explode(',', $footerLinksText);
    foreach ($links as $link) {
        $parts = explode('|', trim($link));
        if (count($parts) >= 2) {
            $footerLinks[] = [
                'text' => trim($parts[0]),
                'url' => trim($parts[1]),
            ];
        }
    }
}

// 排版配置
$fontSizeValue = tpmst_getConfig($styleSettings, 'typography.font_size', '12/14');
$lineHeight = tpmst_getConfig($styleSettings, 'typography.line_height', '1.6');

$fontSize = tpmst_parseResponsive($fontSizeValue . 'px');
