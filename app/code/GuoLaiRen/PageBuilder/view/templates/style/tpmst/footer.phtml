$paddingVerticalValue = tpmst_getConfig($styleSettings, 'layout.padding_vertical', '30/50');

$paddingHorizontal = tpmst_parseResponsive($paddingHorizontalValue . 'px');
$paddingHorizontalResponsive = tpmst_genResponsiveCSS($paddingHorizontal);
$paddingVertical = tpmst_parseResponsive($paddingVerticalValue . 'px');
