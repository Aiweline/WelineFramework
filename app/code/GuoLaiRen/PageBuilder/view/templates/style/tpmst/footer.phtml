$linkHoverColor = tpmst_color($colors, 'footer_link_hover', tpmst_getConfig($styleSettings, 'style.link_hover_color', '#ffd700'));
$copyrightColor = tpmst_color($colors, 'footer_copyright', '#8b8b8b');
$borderTop = tpmst_getConfig($styleSettings, 'style.border_top', 'yes');
