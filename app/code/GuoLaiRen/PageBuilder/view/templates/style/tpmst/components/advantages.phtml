<?php
/**
 * TPMST 组件 - 优势区域 (Advantages)
 * 展示产品/应用的核心优势，三列卡片布局
 * 
 * @component_start
 * name => 优势区域
 * name_en => Advantages Section
 * description => 展示产品/应用的核心优势，三列卡片布局，支持图标和描述
 * category => content
 * type => section
 * thumbnail => asset/img/our-advantages/icon01.webp
 * sort_order => 20
 * compatible_styles => *
 * @component_end
 * 
 * @fields_start
 * 
 * group:advantages => 优势区域设置
 * advantages.title => 优势区域标题:text:Our Advantages
 * advantages.display => 显示优势区域:select:yes|yes,no
 * advantages.bg_color => 背景颜色:color:#1a1a2e
 * advantages.icon_1 => 优势1-图标:textarea:|默认使用本地our-advantages/icon01.webp
 * advantages.title_1 => 优势1-标题:text:Teen Patti Speed
 * advantages.desc_1 => 优势1-描述:textarea:Teen Patti Speed is a fast-paced variant where players bet quickly.
 * advantages.icon_2 => 优势2-图标:textarea:|默认使用本地our-advantages/icon02.webp
 * advantages.title_2 => 优势2-标题:text:Rummy Master
 * advantages.desc_2 => 优势2-描述:textarea:Rummy Master challenges players to skillfully meld cards into sets.
 * advantages.icon_3 => 优势3-图标:textarea:|默认使用本地our-advantages/icon03.webp
 * advantages.title_3 => 优势3-标题:text:Slots Meta
 * advantages.desc_3 => 优势3-描述:textarea:Slots Meta offers a dazzling array of themed slots.
 * advantages.button_text => 按钮文本:text:Download
 * 
 * @fields_end
 * 
 * @var \Weline\Framework\View\Template $this
 */

// 获取配置
$componentConfig = $this->getData('component_config') ?? [];
$styleSettings = $componentConfig ?: ($this->getData('style') ?: $this->getData('style_settings') ?: []);
$colors = $this->getData('colors') ?? [];

// 辅助函数
if (!function_exists('tpmst_adv_getConfig')) {
    function tpmst_adv_getConfig($settings, $key, $default = '') {
        $value = $settings[$key] ?? $default;
        return ($value === '' && $default !== '') ? $default : $value;
    }
}

if (!function_exists('tpmst_adv_color')) {
    function tpmst_adv_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

// 显示控制
$displayRaw = tpmst_adv_getConfig($styleSettings, 'advantages.display', 'yes');
$display = in_array($displayRaw, ['yes', true, 'true', 1, '1'], true);

if (!$display) {
    return;
}

// 配置读取
$title = tpmst_adv_getConfig($styleSettings, 'advantages.title', 'Our Advantages');
$bgColor = tpmst_adv_color($colors, 'advantages_bg', tpmst_adv_getConfig($styleSettings, 'advantages.bg_color', '#1a1a2e'));
$buttonText = tpmst_adv_getConfig($styleSettings, 'advantages.button_text', 'Download');

// 默认图标
$defaultIcon1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon01.webp');
$defaultIcon2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon02.webp');
$defaultIcon3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/tpmst/asset/img/our-advantages/icon03.webp');

// 优势项配置
$advantages = [
    [
        'icon' => tpmst_adv_getConfig($styleSettings, 'advantages.icon_1', '') ?: $defaultIcon1,
        'title' => tpmst_adv_getConfig($styleSettings, 'advantages.title_1', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_teen_patti_speed', 'Teen Patti Speed'),
        'desc' => tpmst_adv_getConfig($styleSettings, 'advantages.desc_1', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_teen_patti_speed_desc', 'Teen Patti Speed is a fast-paced variant where players bet quickly, aiming for the best three-card hand in thrilling, rapid rounds.'),
    ],
    [
        'icon' => tpmst_adv_getConfig($styleSettings, 'advantages.icon_2', '') ?: $defaultIcon2,
        'title' => tpmst_adv_getConfig($styleSettings, 'advantages.title_2', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_rummy_master', 'Rummy Master'),
        'desc' => tpmst_adv_getConfig($styleSettings, 'advantages.desc_2', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_rummy_master_desc', 'Rummy Master challenges players to skillfully meld cards into sets and sequences in a race to be the first to go out and declare victory.'),
    ],
    [
        'icon' => tpmst_adv_getConfig($styleSettings, 'advantages.icon_3', '') ?: $defaultIcon3,
        'title' => tpmst_adv_getConfig($styleSettings, 'advantages.title_3', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_slots_meta', 'Slots Meta'),
        'desc' => tpmst_adv_getConfig($styleSettings, 'advantages.desc_3', '') ?: tpmst_adv_getConfig($styleSettings, 'texts.game_slots_meta_desc', 'Slots Meta offers a dazzling array of themed slots where players spin for matching symbols and bonuses in a quest for jackpot wins.'),
    ],
];

// 颜色变量
$headingColor = tpmst_adv_color($colors, 'heading_color', '#ffd700');
$textColor = tpmst_adv_color($colors, 'text_color', '#ffffff');
$buttonBg = tpmst_adv_color($colors, 'button_primary_bg', '#ff6b35');
$buttonText_color = tpmst_adv_color($colors, 'button_primary_text', '#ffffff');

$componentId = 'tpmst-advantages-' . uniqid();
?>

<!-- TPMST 组件: 优势区域 -->
<section class="tpmst-component tpmst-component-advantages" id="<?= $componentId ?>" style="background: <?= htmlspecialchars($bgColor) ?>;">
    <div class="tpmst-advantages-container">
        <h2 class="tpmst-advantages-title"><?= htmlspecialchars($title) ?></h2>
        
        <div class="tpmst-advantages-grid">
            <?php foreach ($advantages as $index => $item): ?>
            <div class="tpmst-advantage-card">
                <div class="tpmst-advantage-icon">
                    <img src="<?= htmlspecialchars($item['icon']) ?>" 
                         alt="<?= htmlspecialchars($item['title']) ?>" 
                         width="85" height="85"
                         loading="lazy">
                </div>
                <h3 class="tpmst-advantage-title"><?= htmlspecialchars($item['title']) ?></h3>
                <p class="tpmst-advantage-desc"><?= htmlspecialchars($item['desc']) ?></p>
                <?php if ($buttonText): ?>
                <button class="tpmst-advantage-btn"><?= htmlspecialchars($buttonText) ?></button>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>

<style>
#<?= $componentId ?> {
    padding: clamp(40px, 8vw, 90px) 15px;
    width: 100%;
}

#<?= $componentId ?> .tpmst-advantages-container {
    max-width: 1200px;
    margin: 0 auto;
}

#<?= $componentId ?> .tpmst-advantages-title {
    font-size: clamp(24px, 5vw, 36px);
    font-weight: 700;
    color: <?= htmlspecialchars($headingColor) ?>;
    text-align: center;
    margin-bottom: clamp(30px, 5vw, 50px);
}

#<?= $componentId ?> .tpmst-advantages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
}

