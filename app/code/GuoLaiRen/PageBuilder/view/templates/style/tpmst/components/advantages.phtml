    #<?= $componentId ?> .tpmst-advantages-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }
}

@media (max-width: 767px) {
    #<?= $componentId ?> .tpmst-advantages-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
}

#<?= $componentId ?> .tpmst-advantage-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 20px 15px;
}

#<?= $componentId ?> .tpmst-advantage-icon {
    margin-bottom: 15px;
}

#<?= $componentId ?> .tpmst-advantage-icon img {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    object-fit: cover;
}

#<?= $componentId ?> .tpmst-advantage-title {
    font-size: clamp(16px, 3vw, 20px);
    font-weight: 600;
    color: <?= htmlspecialchars($headingColor) ?>;
    margin-bottom: 15px;
}

#<?= $componentId ?> .tpmst-advantage-desc {
    font-size: clamp(13px, 2.5vw, 16px);
    line-height: 1.6;
    color: <?= htmlspecialchars($textColor) ?>;
    margin-bottom: 20px;
}

@media (max-width: 991px) {
    #<?= $componentId ?> .tpmst-advantage-desc {
        display: none;
    }
}

#<?= $componentId ?> .tpmst-advantage-btn {
    background: <?= htmlspecialchars($buttonBg) ?>;
    color: <?= htmlspecialchars($buttonText_color) ?>;
    border: none;
    border-radius: 25px;
    padding: 10px 40px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

#<?= $componentId ?> .tpmst-advantage-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
}

@media (max-width: 767px) {
    #<?= $componentId ?> .tpmst-advantage-btn {
        padding: 8px 22px;
        font-size: 13px;
    }
}
</style>
