            <div class="marketing-footer-content">
                <!-- Disclaimer Text with Links -->
                <?php if ($disclaimerText): ?>
                    <div class="marketing-footer-disclaimer">
                        <?php
                        // 处理 {disclaimer} 和 {Privacy Policy} 占位符
                        $output = htmlspecialchars($disclaimerText);
                        $output = str_replace('{disclaimer}', '<a href="' . htmlspecialchars($disclaimerLink) . '" class="marketing-footer-link">disclaimer</a>', $output);
                        $output = str_replace('{Privacy Policy}', '<a href="' . htmlspecialchars($privacyLink) . '" class="marketing-footer-link">Privacy Policy</a>', $output);
                        echo $output;
