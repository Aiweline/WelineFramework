function parseResp($value) {
    if (empty($value)) return ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => ''];
    $value = trim($value);
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
    switch (count($parts)) {
        case 1: $result['mobile'] = $result['tablet'] = $result['desktop'] = trim($parts[0]); break;
        case 2: $result['mobile'] = trim($parts[0]); $result['desktop'] = trim($parts[1]); break;
        case 3: $result['mobile'] = trim($parts[0]); $result['tablet'] = trim($parts[1]); $result['desktop'] = trim($parts[2]); break;
    }
    return $result;
}

function genRespCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
}

function processContentText($text) {
    // 先将字面的 \n 转换为真正的换行符
    $text = str_replace('\\n', "\n", $text);
    
    $text = htmlspecialchars($text ?? '');
    // 先处理粗体标记
    $text = preg_replace('/\*\*(.+?)\*\*/', '<strong>$1</strong>', $text);
    
    // 按双换行符分段
    $paragraphs = preg_split('/\n\s*\n/', $text);
    $result = '';
    foreach ($paragraphs as $paragraph) {
        $paragraph = trim($paragraph);
        if (!empty($paragraph)) {
            // 单个换行符替换为空格
            $paragraph = preg_replace('/\n/', ' ', $paragraph);
            $result .= '<p>' . $paragraph . '</p>';
        }
    }
    return $result;
}

