<?php
/**
 * Fitness Pro - FAQ Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:FAQ
 * content.title => 标题:text:Frequently Asked Questions
 * content.description => 描述:textarea:Everything you need to know about FitZone. Can't find the answer? Contact our support team.
 * group:faq => FAQ列表
 * faq.items => FAQ列表:textarea:What membership plans do you offer?|We offer Starter, Premium, and Elite memberships. Each includes gym access, with Premium and Elite adding group classes, personal training, and nutrition coaching.\r\nDo you offer a free trial?|Yes! We offer a complimentary 3-day trial pass so you can experience our facilities, classes, and community before committing.\r\nCan I cancel my membership anytime?|Absolutely. We have a no-contract policy. You can cancel or pause your membership at any time with 30 days notice.\r\nWhat types of classes do you offer?|We offer 50+ classes weekly including Strength Training, HIIT, Yoga, CrossFit, Boxing, Pilates, Spin, and more.\r\nAre your trainers certified?|Yes, all our trainers hold nationally recognized certifications (NASM, ACE, NSCA) and undergo continuous education.\r\nDo you provide diet and nutrition plans?|Premium and Elite members get personalized nutrition plans. We also have in-house nutritionists available for all members at discounted rates.|格式：问题|回答，一行一个
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['faq_bg'] ?? '#0f0a07';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d6b87a';
$textMuted = $colors['text_muted'] ?? '#a68b5b';
$accentPrimary = $colors['accent_primary'] ?? '#f97316';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#fb923c';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(249, 115, 22, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(249, 115, 22, 0.3)';

$badge = $config['content.badge'] ?? 'FAQ';
$title = $config['content.title'] ?? 'Frequently Asked Questions';
$description = $config['content.description'] ?? "Everything you need to know about FitZone. Can't find the answer? Contact our support team.";

$faqRaw = $config['faq.items'] ?? "What membership plans do you offer?|We offer Starter, Premium, and Elite memberships. Each includes gym access, with Premium and Elite adding group classes, personal training, and nutrition coaching.\nDo you offer a free trial?|Yes! We offer a complimentary 3-day trial pass so you can experience our facilities, classes, and community before committing.\nCan I cancel my membership anytime?|Absolutely. We have a no-contract policy. You can cancel or pause your membership at any time with 30 days notice.\nWhat types of classes do you offer?|We offer 50+ classes weekly including Strength Training, HIIT, Yoga, CrossFit, Boxing, Pilates, Spin, and more.\nAre your trainers certified?|Yes, all our trainers hold nationally recognized certifications (NASM, ACE, NSCA) and undergo continuous education.\nDo you provide diet and nutrition plans?|Premium and Elite members get personalized nutrition plans. We also have in-house nutritionists available for all members at discounted rates.";

$faqs = [];
foreach (preg_split('/[\r\n]+/', $faqRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $question = trim($parts[0] ?? '');
    if (!empty($question)) {
        $faqs[] = ['question' => $question, 'answer' => trim($parts[1] ?? '')];
    }
}

$instanceId = 'fp-faq-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 100px 0; }
        #<?= $instanceId ?> .fp-faq-container { max-width: 800px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .fp-faq-header { text-align: center; margin-bottom: 60px; }
        #<?= $instanceId ?> .fp-faq-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>; border-radius: 50px; font-size: 0.875rem; font-weight: 500; color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; }
        #<?= $instanceId ?> .fp-faq-title { font-size: 2.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .fp-faq-subtitle { font-size: 1.125rem; color: <?= $textSecondary ?>; line-height: 1.7; }
        #<?= $instanceId ?> .fp-faq-list { display: flex; flex-direction: column; gap: 14px; }
        #<?= $instanceId ?> .fp-faq-item { background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>; border-radius: 14px; overflow: hidden; transition: all 0.3s ease; }
        #<?= $instanceId ?> .fp-faq-item:hover { border-color: rgba(249,115,22,0.3); }
        #<?= $instanceId ?> .fp-faq-item.active { border-color: <?= $accentPrimary ?>; }
        #<?= $instanceId ?> .fp-faq-question { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 24px; cursor: pointer; transition: background 0.3s ease; }
        #<?= $instanceId ?> .fp-faq-question:hover { background: rgba(255,255,255,0.02); }
        #<?= $instanceId ?> .fp-faq-question-text { font-size: 1rem; font-weight: 600; color: <?= $textPrimary ?>; flex: 1; }
        #<?= $instanceId ?> .fp-faq-question-icon { width: 32px; height: 32px; background: rgba(249,115,22,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s ease; }
        #<?= $instanceId ?> .fp-faq-question-icon svg { width: 16px; height: 16px; fill: <?= $accentPrimaryLight ?>; transition: transform 0.3s ease; }
        #<?= $instanceId ?> .fp-faq-item.active .fp-faq-question-icon { background: <?= $accentPrimary ?>; }
        #<?= $instanceId ?> .fp-faq-item.active .fp-faq-question-icon svg { fill: #fff; transform: rotate(180deg); }
        #<?= $instanceId ?> .fp-faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        #<?= $instanceId ?> .fp-faq-item.active .fp-faq-answer { max-height: 500px; }
        #<?= $instanceId ?> .fp-faq-answer-content { padding: 0 24px 24px; font-size: 0.95rem; color: <?= $textMuted ?>; line-height: 1.7; }
        @media (max-width: 576px) { #<?= $instanceId ?> .fp-faq-title { font-size: 1.75rem; } }
    </style>
    
    <div class="fp-faq-container">
        <div class="fp-faq-header">
            <div class="fp-faq-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="fp-faq-title"><?= htmlspecialchars($title) ?></h2>
            <p class="fp-faq-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="fp-faq-list" id="faq">
            <?php foreach ($faqs as $index => $faq): ?>
            <div class="fp-faq-item<?= $index === 0 ? ' active' : '' ?>">
                <div class="fp-faq-question" onclick="this.parentElement.classList.toggle('active')">
                    <span class="fp-faq-question-text"><?= htmlspecialchars($faq['question']) ?></span>
                    <span class="fp-faq-question-icon">
                        <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                    </span>
                </div>
                <div class="fp-faq-answer">
                    <div class="fp-faq-answer-content"><?= htmlspecialchars($faq['answer']) ?></div>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
