<?php
/**
 * Fitness Pro - Programs Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Our Programs
 * content.title => 标题:text:Train Like a Pro
 * content.description => 描述:textarea:Choose from a wide range of programs designed by certified trainers to help you achieve your fitness goals.
 * group:programs => 项目列表
 * programs.items => 项目列表:textarea:Strength Training|Build muscle, increase power, and sculpt your physique with our comprehensive strength program.|💪|8 Weeks\r\nHIIT Cardio|Torch calories and boost endurance with high-intensity interval training sessions.|🔥|6 Weeks\r\nYoga & Flexibility|Improve flexibility, balance, and mental clarity through guided yoga practices.|🧘|4 Weeks\r\nCrossFit|Push your limits with functional movements performed at high intensity.|🏋️|10 Weeks|格式：标题|描述|图标|时长，一行一个
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['programs_bg'] ?? $colors['features_bg'] ?? '#140e08';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d6b87a';
$textMuted = $colors['text_muted'] ?? '#a68b5b';
$accentPrimary = $colors['accent_primary'] ?? '#f97316';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#fb923c';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(249, 115, 22, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(249, 115, 22, 0.3)';

$badge = $config['content.badge'] ?? 'Our Programs';
$title = $config['content.title'] ?? 'Train Like a Pro';
$description = $config['content.description'] ?? 'Choose from a wide range of programs designed by certified trainers to help you achieve your fitness goals.';

$programsRaw = $config['programs.items'] ?? "Strength Training|Build muscle, increase power, and sculpt your physique with our comprehensive strength program.|💪|8 Weeks\nHIIT Cardio|Torch calories and boost endurance with high-intensity interval training sessions.|🔥|6 Weeks\nYoga & Flexibility|Improve flexibility, balance, and mental clarity through guided yoga practices.|🧘|4 Weeks\nCrossFit|Push your limits with functional movements performed at high intensity.|🏋️|10 Weeks";

$programs = [];
foreach (preg_split('/[\r\n]+/', $programsRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $programTitle = trim($parts[0] ?? '');
    if (!empty($programTitle)) {
        $programs[] = [
            'title' => $programTitle,
            'description' => trim($parts[1] ?? ''),
            'icon' => trim($parts[2] ?? '💪'),
            'duration' => trim($parts[3] ?? ''),
        ];
    }
}

$instanceId = 'fp-programs-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 100px 0; }
        #<?= $instanceId ?> .fp-programs-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .fp-programs-header { text-align: center; margin-bottom: 64px; }
        #<?= $instanceId ?> .fp-programs-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>; border-radius: 50px; font-size: 0.875rem; font-weight: 500; color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; }
        #<?= $instanceId ?> .fp-programs-title { font-size: 2.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .fp-programs-subtitle { font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; line-height: 1.7; }
        #<?= $instanceId ?> .fp-programs-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        #<?= $instanceId ?> .fp-programs-card { background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>; border-radius: 16px; padding: 32px 24px; transition: all 0.3s ease; position: relative; overflow: hidden; }
        #<?= $instanceId ?> .fp-programs-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: <?= $buttonPrimaryBg ?>; opacity: 0; transition: opacity 0.3s ease; }
        #<?= $instanceId ?> .fp-programs-card:hover { background: rgba(255,255,255,0.05); border-color: rgba(249,115,22,0.4); transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
        #<?= $instanceId ?> .fp-programs-card:hover::before { opacity: 1; }
        #<?= $instanceId ?> .fp-programs-card-icon { width: 60px; height: 60px; background: <?= $buttonPrimaryBg ?>; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; margin-bottom: 20px; box-shadow: 0 8px 24px rgba(249,115,22,0.25); transition: transform 0.3s ease; }
        #<?= $instanceId ?> .fp-programs-card:hover .fp-programs-card-icon { transform: scale(1.1) rotate(3deg); }
        #<?= $instanceId ?> .fp-programs-card-title { font-size: 1.125rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 10px; }
        #<?= $instanceId ?> .fp-programs-card-desc { font-size: 0.9rem; color: <?= $textMuted ?>; line-height: 1.7; margin-bottom: 16px; }
        #<?= $instanceId ?> .fp-programs-card-duration { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; background: rgba(249,115,22,0.1); border-radius: 20px; font-size: 0.8rem; font-weight: 600; color: <?= $accentPrimaryLight ?>; }
        #<?= $instanceId ?> .fp-programs-card-duration svg { width: 14px; height: 14px; }
        @media (max-width: 992px) { #<?= $instanceId ?> .fp-programs-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { #<?= $instanceId ?> .fp-programs-title { font-size: 1.75rem; } #<?= $instanceId ?> .fp-programs-grid { grid-template-columns: 1fr; } }
    </style>
    
    <div class="fp-programs-container">
        <div class="fp-programs-header">
            <div class="fp-programs-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="fp-programs-title"><?= htmlspecialchars($title) ?></h2>
            <p class="fp-programs-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        <div class="fp-programs-grid" id="programs">
            <?php foreach ($programs as $program): ?>
            <div class="fp-programs-card">
                <div class="fp-programs-card-icon"><?= $program['icon'] ?></div>
                <h3 class="fp-programs-card-title"><?= htmlspecialchars($program['title']) ?></h3>
                <p class="fp-programs-card-desc"><?= htmlspecialchars($program['description']) ?></p>
                <?php if (!empty($program['duration'])): ?>
                <span class="fp-programs-card-duration">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                    <?= htmlspecialchars($program['duration']) ?>
                </span>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
