<?php
/**
 * Fitness Pro - Footer Links Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:FitZone
 * brand.description => 品牌描述:textarea:Transform your body and mind with expert-led fitness programs.
 * group:links => 链接设置
 * links.use_custom_links => 使用自定义链接组:select:no|no,yes
 * links.column1_title => 栏目1标题:text:Classes
 * links.column1_items => 栏目1链接:textarea:Strength Training=>#programs\r\nHIIT Cardio=>#programs\r\nYoga=>#programs\r\nCrossFit=>#programs|格式：名称=>链接（仅当开启自定义链接时生效）
 * links.column2_title => 栏目2标题:text:Company
 * links.column2_items => 栏目2链接:textarea:About Us=>/about\r\nOur Trainers=>/trainers\r\nCareers=>/careers\r\nContact=>/contact|格式：名称=>链接
 * links.column3_title => 栏目3标题:text:Support
 * links.column3_items => 栏目3链接:textarea:Help Center=>/help\r\nMembership=>/membership\r\nPrivacy Policy=>/privacy\r\nTerms of Service=>/terms|格式：名称=>链接
 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved.
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$footerBg = $colors['footer_bg'] ?? '#0a0705';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textMuted = $colors['text_muted'] ?? '#a68b5b';
$linkColor = $colors['footer_link'] ?? '#d6b87a';
$linkHoverColor = $colors['footer_link_hover'] ?? '#fb923c';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)';
$footerBorder = $colors['footer_border'] ?? 'rgba(255, 255, 255, 0.06)';

$brandName = $config['brand.name'] ?? 'FitZone';
$brandDesc = $config['brand.description'] ?? 'Transform your body and mind with expert-led fitness programs.';
$copyrightText = $config['copyright.text'] ?? 'All rights reserved.';

$parseLinks = function($raw) {
    $links = [];
    foreach (preg_split('/[\r\n]+/', $raw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl(trim($parts[1] ?? '#'));
        if (!empty($name)) $links[] = ['name' => $name, 'url' => $url];
    }
    return $links;
};

// 按页面类型分组的底栏列（3列）：与 header 一致使用 getHeaderNavigationPages
$footerColTypes = [
    1 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME, \GuoLaiRen\PageBuilder\Model\Page::TYPE_ABOUT, \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG_LIST],
    2 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_CONTACT],
    3 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_TERMS_OF_SERVICE, \GuoLaiRen\PageBuilder\Model\Page::TYPE_PRIVACY_POLICY],
];
$footerColDefaultTitles = [1 => 'Classes', 2 => 'Company', 3 => 'Support'];

$useCustomLinks = ($config['links.use_custom_links'] ?? 'no') === 'yes';
$page = $this->getData('page');
$col1Links = [];
$col2Links = [];
$col3Links = [];
$col1Title = $config['links.column1_title'] ?? 'Classes';
$col2Title = $config['links.column2_title'] ?? 'Company';
$col3Title = $config['links.column3_title'] ?? 'Support';

if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $navPages = $page->getHeaderNavigationPages(20);
    $byCol = [1 => [], 2 => [], 3 => []];
    foreach ($navPages as $item) {
        $type = $item['type'] ?? '';
        foreach ($footerColTypes as $colIndex => $types) {
            if (in_array($type, $types, true)) {
                $labelKey = 'links.footer_label_' . $type;
                $label = isset($config[$labelKey]) && (string)$config[$labelKey] !== '' ? (string)$config[$labelKey] : ($item['title'] ?? '');
                $url = $item['url'] ?? '/';
                if (isset($item['type']) && $item['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
                    $label = __('Home');
                    $url = '/';
                }
                $byCol[$colIndex][] = ['name' => $label, 'url' => $url];
                break;
            }
        }
    }
    if (!empty($navPages)) {
        $col1Links = $byCol[1];
        $col2Links = $byCol[2];
        $col3Links = $byCol[3];
        $col1Title = isset($config['links.column1_title']) && (string)$config['links.column1_title'] !== '' ? (string)$config['links.column1_title'] : $footerColDefaultTitles[1];
        $col2Title = isset($config['links.column2_title']) && (string)$config['links.column2_title'] !== '' ? (string)$config['links.column2_title'] : $footerColDefaultTitles[2];
        $col3Title = isset($config['links.column3_title']) && (string)$config['links.column3_title'] !== '' ? (string)$config['links.column3_title'] : $footerColDefaultTitles[3];
    }
}
if ($useCustomLinks || (empty($col1Links) && empty($col2Links) && empty($col3Links))) {
    $col1Title = $config['links.column1_title'] ?? 'Classes';
    $col1Links = $parseLinks($config['links.column1_items'] ?? "Strength Training=>#programs\nHIIT Cardio=>#programs\nYoga=>#programs\nCrossFit=>#programs");
    $col2Title = $config['links.column2_title'] ?? 'Company';
    $col2Links = $parseLinks($config['links.column2_items'] ?? "About Us=>/about\nOur Trainers=>/trainers\nCareers=>/careers\nContact=>/contact");
    $col3Title = $config['links.column3_title'] ?? 'Support';
    $col3Links = $parseLinks($config['links.column3_items'] ?? "Help Center=>/help\nMembership=>/membership\nPrivacy Policy=>/privacy\nTerms of Service=>/terms");
}
$currentYear = date('Y');
$instanceId = 'fp-footer-' . uniqid();
?>

<footer id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $footerBg ?>; padding: 80px 0 0; }
        #<?= $instanceId ?> .fp-footer-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .fp-footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 60px; border-bottom: 1px solid <?= $footerBorder ?>; }
        #<?= $instanceId ?> .fp-footer-logo { display: flex; align-items: center; gap: 10px; font-size: 1.25rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 14px; }
        #<?= $instanceId ?> .fp-footer-logo-icon { width: 36px; height: 36px; background: <?= $buttonPrimaryBg ?>; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
        #<?= $instanceId ?> .fp-footer-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
        #<?= $instanceId ?> .fp-footer-brand-desc { font-size: 0.9rem; color: <?= $textMuted ?>; line-height: 1.7; max-width: 260px; }
        #<?= $instanceId ?> .fp-footer-column h4 { font-size: 0.85rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 18px; text-transform: uppercase; letter-spacing: 0.06em; }
        #<?= $instanceId ?> .fp-footer-links { display: flex; flex-direction: column; gap: 10px; }
        #<?= $instanceId ?> .fp-footer-link { font-size: 0.9rem; color: <?= $linkColor ?>; text-decoration: none; transition: color 0.3s ease; }
        #<?= $instanceId ?> .fp-footer-link:hover { color: <?= $linkHoverColor ?>; }
        #<?= $instanceId ?> .fp-footer-bottom { padding: 24px 0; text-align: center; }
        #<?= $instanceId ?> .fp-footer-copyright { font-size: 0.85rem; color: <?= $textMuted ?>; }
        @media (max-width: 992px) { #<?= $instanceId ?> .fp-footer-grid { grid-template-columns: 1fr 1fr; } #<?= $instanceId ?> .fp-footer-brand { grid-column: 1 / -1; } }
        @media (max-width: 576px) { #<?= $instanceId ?> .fp-footer-grid { grid-template-columns: 1fr; gap: 32px; } }
    </style>
    
    <div class="fp-footer-container">
        <div class="fp-footer-grid">
            <div class="fp-footer-brand">
                <div class="fp-footer-logo">
                    <span class="fp-footer-logo-icon"><svg viewBox="0 0 24 24"><path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"/></svg></span>
                    <span><?= htmlspecialchars($brandName) ?></span>
                </div>
                <p class="fp-footer-brand-desc"><?= htmlspecialchars($brandDesc) ?></p>
            </div>
            <div class="fp-footer-column">
                <h4><?= htmlspecialchars($col1Title) ?></h4>
                <div class="fp-footer-links">
                    <?php foreach ($col1Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="fp-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <div class="fp-footer-column">
                <h4><?= htmlspecialchars($col2Title) ?></h4>
                <div class="fp-footer-links">
                    <?php foreach ($col2Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="fp-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <div class="fp-footer-column">
                <h4><?= htmlspecialchars($col3Title) ?></h4>
                <div class="fp-footer-links">
                    <?php foreach ($col3Links as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="fp-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
        </div>
        <div class="fp-footer-bottom">
            <div class="fp-footer-copyright">&copy; <?= $currentYear ?> <?= htmlspecialchars($brandName) ?>. <?= htmlspecialchars($copyrightText) ?></div>
        </div>
    </div>
</footer>
