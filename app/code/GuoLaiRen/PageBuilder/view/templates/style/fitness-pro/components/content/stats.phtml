<?php
/**
 * Fitness Pro - Stats/Achievements Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Our Results
 * content.title => 标题:text:Numbers That Speak
 * content.description => 描述:textarea:Our track record speaks for itself. Join hundreds of members who have transformed their lives.
 * group:stats => 统计数据
 * stats.items => 统计数据:textarea:500+|Happy Members|Dedicated fitness enthusiasts\r\n50+|Daily Classes|Group and personal sessions\r\n15+|Expert Trainers|Certified professionals\r\n10+|Years Experience|Serving our community|格式：数字|标签|描述，一行一个
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['stats_bg'] ?? '#1a1209';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d6b87a';
$textMuted = $colors['text_muted'] ?? '#a68b5b';
$accentPrimary = $colors['accent_primary'] ?? '#f97316';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#fb923c';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(249, 115, 22, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(249, 115, 22, 0.3)';

$badge = $config['content.badge'] ?? 'Our Results';
$title = $config['content.title'] ?? 'Numbers That Speak';
$description = $config['content.description'] ?? 'Our track record speaks for itself. Join hundreds of members who have transformed their lives.';

$statsRaw = $config['stats.items'] ?? "500+|Happy Members|Dedicated fitness enthusiasts\n50+|Daily Classes|Group and personal sessions\n15+|Expert Trainers|Certified professionals\n10+|Years Experience|Serving our community";

$stats = [];
foreach (preg_split('/[\r\n]+/', $statsRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $value = trim($parts[0] ?? '');
    if (!empty($value)) {
        $stats[] = [
            'value' => $value,
            'label' => trim($parts[1] ?? ''),
            'description' => trim($parts[2] ?? ''),
        ];
    }
}

$instanceId = 'fp-stats-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 100px 0; position: relative; overflow: hidden; }
        #<?= $instanceId ?>::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(249,115,22,0.06) 0%, transparent 70%); pointer-events: none; }
        #<?= $instanceId ?> .fp-stats-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }
        #<?= $instanceId ?> .fp-stats-header { text-align: center; margin-bottom: 64px; }
        #<?= $instanceId ?> .fp-stats-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>; border-radius: 50px; font-size: 0.875rem; font-weight: 500; color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; }
        #<?= $instanceId ?> .fp-stats-title { font-size: 2.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .fp-stats-subtitle { font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; line-height: 1.7; }
        #<?= $instanceId ?> .fp-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        #<?= $instanceId ?> .fp-stats-card { background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>; border-radius: 16px; padding: 40px 24px; text-align: center; transition: all 0.3s ease; position: relative; overflow: hidden; }
        #<?= $instanceId ?> .fp-stats-card::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 60px; height: 3px; background: <?= $buttonPrimaryBg ?>; border-radius: 2px; opacity: 0; transition: opacity 0.3s ease; }
        #<?= $instanceId ?> .fp-stats-card:hover { background: rgba(255,255,255,0.05); border-color: rgba(249,115,22,0.3); transform: translateY(-4px); box-shadow: 0 16px 40px rgba(249,115,22,0.1); }
        #<?= $instanceId ?> .fp-stats-card:hover::after { opacity: 1; }
        #<?= $instanceId ?> .fp-stats-value { font-size: 3rem; font-weight: 900; background: <?= $buttonPrimaryBg ?>; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 8px; line-height: 1.2; }
        #<?= $instanceId ?> .fp-stats-label { font-size: 1.05rem; font-weight: 600; color: <?= $textPrimary ?>; margin-bottom: 6px; }
        #<?= $instanceId ?> .fp-stats-desc { font-size: 0.85rem; color: <?= $textMuted ?>; line-height: 1.5; }
        @media (max-width: 992px) { #<?= $instanceId ?> .fp-stats-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { #<?= $instanceId ?> .fp-stats-title { font-size: 1.75rem; } #<?= $instanceId ?> .fp-stats-grid { grid-template-columns: 1fr; } #<?= $instanceId ?> .fp-stats-value { font-size: 2.5rem; } }
    </style>
    
    <div class="fp-stats-container">
        <div class="fp-stats-header">
            <div class="fp-stats-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="fp-stats-title"><?= htmlspecialchars($title) ?></h2>
            <p class="fp-stats-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="fp-stats-grid" id="stats">
            <?php foreach ($stats as $stat): ?>
            <div class="fp-stats-card">
                <div class="fp-stats-value"><?= htmlspecialchars($stat['value']) ?></div>
                <div class="fp-stats-label"><?= htmlspecialchars($stat['label']) ?></div>
                <?php if (!empty($stat['description'])): ?>
                <div class="fp-stats-desc"><?= htmlspecialchars($stat['description']) ?></div>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
