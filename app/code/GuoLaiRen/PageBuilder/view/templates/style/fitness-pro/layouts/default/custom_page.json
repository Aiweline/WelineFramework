{
    "page_type": "custom_page",
    "name": "自定义页面默认布局",
    "description": "Fitness Pro 主题自定义页面布局",
    "version": "1.0.0",
    "layout_config": {
        "header": [
            {
                "code": "header-nav",
                "enabled": true,
                "instance_id": "header-nav-default",
                "config": {
                    "logo.display": "yes",
                    "logo.text": "FitZone",
                    "navigation.show_cta": "yes",
                    "navigation.cta_text": "Join Now"
                }
            }
        ],
        "content": [],
        "footer": [
            {
                "code": "footer-links",
                "enabled": true,
                "instance_id": "footer-links-default",
                "config": {
                    "brand.name": "FitZone"
                }
            }
        ]
    }
}
