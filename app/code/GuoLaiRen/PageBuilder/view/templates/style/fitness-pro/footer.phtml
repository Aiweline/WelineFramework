    function fp_footer_color($c, $k, $d = '') { return $c[$k] ?? $d; }
}
if (!function_exists('fp_footer_getConfig')) {
    function fp_footer_getConfig($s, $k, $d = '') { return $s[$k] ?? $d; }
}

$brandName = fp_footer_getConfig($styleSettings, 'brand.name', 'FitZone');
$brandDesc = fp_footer_getConfig($styleSettings, 'brand.description', 'Transform your body and mind with expert-led fitness programs.');
$col1Title = fp_footer_getConfig($styleSettings, 'links.column1_title', 'Classes');
$col1Raw = fp_footer_getConfig($styleSettings, 'links.column1_items', "Strength=>#programs\nHIIT=>#programs\nYoga=>#programs\nCrossFit=>#programs");
$col2Title = fp_footer_getConfig($styleSettings, 'links.column2_title', 'Company');
$col2Raw = fp_footer_getConfig($styleSettings, 'links.column2_items', "About=>/about\nTrainers=>/trainers\nCareers=>/careers\nContact=>/contact");
$col3Title = fp_footer_getConfig($styleSettings, 'links.column3_title', 'Support');
$col3Raw = fp_footer_getConfig($styleSettings, 'links.column3_items', "Help Center=>/help\nMembership=>/membership\nPrivacy=>/privacy\nTerms=>/terms");

$parseLinks = function($raw) {
    $links = [];
    foreach (preg_split('/[\r\n]+/', $raw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) $links[] = ['name' => $name, 'url' => $url];
    }
    return $links;
};

$col1Links = $parseLinks($col1Raw);
$col2Links = $parseLinks($col2Raw);
$col3Links = $parseLinks($col3Raw);

$copyrightText = fp_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved.');
$bgColor = fp_footer_getConfig($styleSettings, 'style.background_color', fp_footer_color($colors, 'footer_bg', '#0a0705'));
$textColor = fp_footer_getConfig($styleSettings, 'style.text_color', fp_footer_color($colors, 'footer_text', '#a68b5b'));
$linkColor = fp_footer_getConfig($styleSettings, 'style.link_color', fp_footer_color($colors, 'footer_link', '#d6b87a'));
$linkHoverColor = fp_footer_getConfig($styleSettings, 'style.link_hover_color', fp_footer_color($colors, 'footer_link_hover', '#fb923c'));
$textPrimary = fp_footer_color($colors, 'text_primary', '#fef3c7');
$buttonPrimaryBg = fp_footer_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)');
