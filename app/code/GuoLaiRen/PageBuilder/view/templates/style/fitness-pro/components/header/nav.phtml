<?php
/**
 * Fitness Pro - Navigation Header Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:FitZone
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:36|px
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:no|no,yes
 * navigation.links => 导航链接:textarea:Programs=>#programs\r\nResults=>#stats\r\nReviews=>#testimonials\r\nFAQ=>#faq|格式：名称=>链接，一行一个（仅当开启自定义链接时生效）
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Join Now
 * navigation.cta_url => CTA按钮链接:text:#cta
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$logoDisplay = $config['logo.display'] ?? 'yes';
$logoText = $config['logo.text'] ?? 'FitZone';
$logoUrl = $config['logo.url'] ?? '';
$logoWidth = $config['logo.width'] ?? '36';
$useCustomLinks = ($config['navigation.use_custom_links'] ?? 'no') === 'yes';
$navLinksRaw = $config['navigation.links'] ?? "Programs=>#programs\nResults=>#stats\nReviews=>#testimonials\nFAQ=>#faq";
$showCta = $config['navigation.show_cta'] ?? 'yes';
$ctaText = $config['navigation.cta_text'] ?? 'Join Now';
$ctaUrl = $config['navigation.cta_url'] ?? '#cta';

$accentPrimary = $colors['accent_primary'] ?? '#f97316';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$navLinkHoverColor = $colors['nav_link_hover'] ?? '#fb923c';
$navBg = $colors['nav_bg'] ?? 'rgba(15, 10, 7, 0.95)';

$navLinks = [];
$page = $this->getData('page');
if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $headerPages = $page->getHeaderNavigationPages(10);
    foreach ($headerPages as $navPage) {
        $type = $navPage['type'] ?? '';
        $labelKey = 'navigation.label_' . $type;
        $configuredLabel = trim((string)($config[$labelKey] ?? ''));
        $title = $navPage['title'] ?? '';
        $url = $navPage['url'] ?? '/';
        if (isset($navPage['type']) && $navPage['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
            $title = __('Home');
            $url = '/';
        }
        $navLinks[] = ['name' => $configuredLabel !== '' ? $configuredLabel : $title, 'url' => $url];
    }
}
if ($useCustomLinks || empty($navLinks)) {
    $navLinks = [];
    foreach (preg_split('/[\r\n]+/', $navLinksRaw) as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
if (empty($navLinks)) {
    $navLinks = [['name' => 'Programs', 'url' => '#programs'], ['name' => 'Results', 'url' => '#stats'], ['name' => 'Reviews', 'url' => '#testimonials'], ['name' => 'FAQ', 'url' => '#faq']];
}

$instanceId = 'fp-nav-' . uniqid();
?>

<div class="fp-header-outer" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { width: 100vw; margin-left: calc(-50vw + 50%); position: relative; background: <?= htmlspecialchars($navBg) ?>; backdrop-filter: blur(10px); padding: 15px 0; box-sizing: border-box; }
        #<?= $instanceId ?> .fp-header-inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; }
        #<?= $instanceId ?> .fp-header-inner .fp-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: <?= $textPrimary ?>; }
        #<?= $instanceId ?> .fp-header-inner .fp-logo-icon { width: <?= intval($logoWidth) ?>px; height: <?= intval($logoWidth) ?>px; background: <?= $buttonPrimaryBg ?>; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
        #<?= $instanceId ?> .fp-header-inner .fp-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
        #<?= $instanceId ?> .fp-header-inner .fp-logo-text { font-size: 1.25rem; font-weight: 700; }
        #<?= $instanceId ?> .fp-header-inner .fp-nav { display: flex; align-items: center; gap: 32px; }
        #<?= $instanceId ?> .fp-header-inner .fp-nav-links { display: flex; gap: 28px; list-style: none; margin: 0; padding: 0; }
        #<?= $instanceId ?> .fp-header-inner .fp-nav-link { color: <?= $textPrimary ?>; opacity: 0.8; text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: all 0.3s ease; }
        #<?= $instanceId ?> .fp-header-inner .fp-nav-link:hover { color: <?= $navLinkHoverColor ?>; opacity: 1; }
        #<?= $instanceId ?> .fp-header-inner .fp-header-cta { display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; background: <?= $buttonPrimaryBg ?>; color: #fff; border-radius: 10px; font-size: 0.9rem; font-weight: 600; transition: all 0.3s ease; text-decoration: none; }
        #<?= $instanceId ?> .fp-header-inner .fp-header-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(249,115,22,0.4); }
        @media (max-width: 768px) { #<?= $instanceId ?> .fp-nav-links { display: none; } }
    </style>
    <div class="fp-header-inner">
        <?php if ($logoDisplay === 'yes'): ?>
        <a href="/" class="fp-logo">
            <span class="fp-logo-icon">
                <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>" style="width:100%;height:100%;object-fit:contain;">
                <?php else: ?>
                    <svg viewBox="0 0 24 24"><path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"/></svg>
                <?php endif; ?>
            </span>
            <span class="fp-logo-text"><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        <nav class="fp-nav">
            <ul class="fp-nav-links">
                <?php foreach ($navLinks as $link): ?>
                <li><a href="<?= htmlspecialchars($link['url']) ?>" class="fp-nav-link"><?= htmlspecialchars($link['name']) ?></a></li>
                <?php endforeach; ?>
            </ul>
            <?php if ($showCta === 'yes'): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="fp-header-cta">
                <span><?= htmlspecialchars($ctaText) ?></span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <?php endif; ?>
        </nav>
    </div>
</div>
