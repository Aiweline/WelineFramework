<?php
/**
 * Fitness Pro 模板 - Content
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * group:layout => 布局设置
 * layout.max_width => 最大宽度:number:1200|px
 * group:style => 样式设置
 * style.background_color => 背景颜色:color:#140e08
 * style.text_color => 文字颜色:color:#d6b87a
 * style.heading_color => 标题颜色:color:#fef3c7
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$templateCode = $page ? $page->getData('style') : 'fitness-pro';
if (empty($templateCode)) {
    $templateCode = 'fitness-pro';
}
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('fp_content_color')) {
    function fp_content_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}
if (!function_exists('fp_content_getConfig')) {
    function fp_content_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

$maxWidth = fp_content_getConfig($styleSettings, 'layout.max_width', '1200');
$bgColor = fp_content_getConfig($styleSettings, 'style.background_color', fp_content_color($colors, 'section_bg_1', '#140e08'));
$textColor = fp_content_getConfig($styleSettings, 'style.text_color', fp_content_color($colors, 'text_secondary', '#d6b87a'));
$headingColor = fp_content_getConfig($styleSettings, 'style.heading_color', fp_content_color($colors, 'text_primary', '#fef3c7'));

$layoutConfig = $this->getData('layout_config') ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
?>

<style>
    .fp-content { background: <?= htmlspecialchars($bgColor) ?>; color: <?= htmlspecialchars($textColor) ?>; min-height: 50vh; padding-top: 80px; }
    .fp-content-container { max-width: <?= intval($maxWidth) ?>px; margin: 0 auto; padding: 0 20px; }
    .fp-content h1, .fp-content h2, .fp-content h3, .fp-content h4 { color: <?= htmlspecialchars($headingColor) ?>; }
</style>

<main class="fp-content">
    <?php
    $componentFiles = [
        'hero' => 'content/hero.phtml',
        'programs' => 'content/programs.phtml',
        'stats' => 'content/stats.phtml',
        'testimonials' => 'content/testimonials.phtml',
        'cta-banner' => 'content/cta-banner.phtml',
        'faq' => 'content/faq.phtml',
    ];
    
    if (!empty($contentComponents)) {
        foreach ($contentComponents as $index => $component) {
            $componentCode = $component['code'] ?? $component['component'] ?? '';
            $componentConfig = $component['config'] ?? [];
            if (empty($componentCode)) continue;
            $componentFile = $componentFiles[$componentCode] ?? null;
            if ($componentFile) {
                $this->assign('component_config', $componentConfig);
                $this->assign('component_instance_id', 'fp-component-' . $componentCode . '-' . $index);
                $this->assign('colors', $colors);
                ?>
                <div class="fp-component-wrapper" data-component="<?= htmlspecialchars($componentCode) ?>" data-index="<?= $index ?>">
                    <?= $this->fetchTemplate("GuoLaiRen_PageBuilder::templates/style/fitness-pro/components/{$componentFile}") ?>
                </div>
                <?php
            }
        }
    } else {
        if ($page) {
            $pageContent = $page->getData('content') ?? '';
            if ($pageContent) {
                echo '<div class="fp-content-container">' . $pageContent . '</div>';
            }
        }
    }
    ?>
</main>
