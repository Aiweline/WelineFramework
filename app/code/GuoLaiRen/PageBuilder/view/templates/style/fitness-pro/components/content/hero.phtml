        #<?= $instanceId ?> .fp-hero-btn-secondary:hover { background: rgba(249,115,22,0.1); border-color: <?= $accentPrimaryLight ?>; }
        #<?= $instanceId ?> .fp-hero-stats { display: flex; gap: 40px; flex-wrap: wrap; }
        #<?= $instanceId ?> .fp-hero-stat { text-align: left; }
        #<?= $instanceId ?> .fp-hero-stat-value { font-size: 2rem; font-weight: 800; color: <?= $accentPrimaryLight ?>; }
        #<?= $instanceId ?> .fp-hero-stat-label { font-size: 0.9rem; color: <?= $textSecondary ?>; margin-top: 4px; }
        #<?= $instanceId ?> .fp-hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
        #<?= $instanceId ?> .fp-hero-deco { width: 100%; aspect-ratio: 1; background: radial-gradient(circle at 30% 40%, rgba(249,115,22,0.2) 0%, rgba(236,72,153,0.1) 40%, transparent 70%); border-radius: 50%; position: relative; }
        #<?= $instanceId ?> .fp-hero-deco::before { content: ''; position: absolute; inset: 20px; border: 2px dashed rgba(249,115,22,0.2); border-radius: 50%; animation: fpSpin 30s linear infinite; }
