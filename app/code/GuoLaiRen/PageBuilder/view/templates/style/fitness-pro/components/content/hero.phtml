            <?php if (!empty($stats)): ?>
            <div class="fp-hero-stats">
                <?php foreach ($stats as $stat): ?>
                <div class="fp-hero-stat">
                    <div class="fp-hero-stat-value"><?= htmlspecialchars($stat['value']) ?></div>
                    <div class="fp-hero-stat-label"><?= htmlspecialchars($stat['label']) ?></div>
                </div>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
        </div>
        
        <div class="fp-hero-visual">
            <div class="fp-hero-deco">
                <div class="fp-hero-deco-icon">🏋️</div>
            </div>
        </div>
    </div>
