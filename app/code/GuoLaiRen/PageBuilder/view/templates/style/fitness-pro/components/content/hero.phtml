        #<?= $instanceId ?> .fp-hero-btn-primary { display: inline-flex; align-items: center; gap: 10px; padding: 16px 36px; background: <?= $buttonPrimaryBg ?>; color: #fff; font-size: 1.05rem; font-weight: 600; border-radius: 12px; transition: all 0.3s ease; box-shadow: 0 4px 20px rgba(249,115,22,0.4); text-decoration: none; }
        #<?= $instanceId ?> .fp-hero-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(249,115,22,0.5); }
