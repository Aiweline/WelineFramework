            #<?= $instanceId ?> .fp-hero-btn-primary, #<?= $instanceId ?> .fp-hero-btn-secondary { width: 100%; max-width: 320px; justify-content: center; }
            #<?= $instanceId ?> .fp-hero-stats { gap: 24px; }
            #<?= $instanceId ?> .fp-hero-visual { display: none; }
        }
    </style>
    
    <div class="fp-hero-container">
        <div class="fp-hero-content">
            <?php if ($badge): ?>
            <div class="fp-hero-badge">
                <span class="fp-hero-badge-dot"></span>
                <?= htmlspecialchars($badge) ?>
            </div>
            <?php endif; ?>
            
            <h1 class="fp-hero-title"><?= nl2br(htmlspecialchars($title)) ?></h1>
            <p class="fp-hero-desc"><?= htmlspecialchars($description) ?></p>
            
            <div class="fp-hero-cta">
                <a href="<?= htmlspecialchars($primaryBtnUrl) ?>" class="fp-hero-btn-primary">
                    <?= htmlspecialchars($primaryBtnText) ?>
