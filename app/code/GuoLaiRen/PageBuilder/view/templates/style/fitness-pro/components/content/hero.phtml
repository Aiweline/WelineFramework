<?php
/**
 * Fitness Pro - Hero Section Component
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 * 
 * @fields_start
 * group:content => 内容设置
 * content.badge => 顶部徽章文字:text:Transform Your Body
 * content.title => 主标题:textarea:Unleash Your Full Potential
 * content.description => 描述文字:textarea:Join the ultimate fitness experience with world-class trainers, cutting-edge equipment, and a community that pushes you to be your best.
 * group:cta => 按钮设置
 * cta.primary_text => 主按钮文字:text:Start Training
 * cta.primary_url => 主按钮链接:text:#cta
 * cta.secondary_text => 次按钮文字:text:View Programs
 * cta.secondary_url => 次按钮链接:text:#programs
 * group:stats => 数据统计
 * stats.items => 统计数据:textarea:500+|Happy Members\r\n50+|Daily Classes\r\n15+|Expert Trainers|格式：数字|描述，一行一个
 * group:style => 样式设置
 * style.padding_top => 顶部内边距:number:120|px
 * style.padding_bottom => 底部内边距:number:80|px
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$heroBg = $colors['hero_bg'] ?? 'linear-gradient(135deg, #1a0f08 0%, #0f0a07 50%, #120c06 100%)';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d6b87a';
$accentPrimary = $colors['accent_primary'] ?? '#f97316';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#fb923c';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f97316 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(249, 115, 22, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(249, 115, 22, 0.3)';

$badge = $config['content.badge'] ?? 'Transform Your Body';
$title = $config['content.title'] ?? 'Unleash Your Full Potential';
$description = $config['content.description'] ?? 'Join the ultimate fitness experience with world-class trainers, cutting-edge equipment, and a community that pushes you to be your best.';
$primaryBtnText = $config['cta.primary_text'] ?? 'Start Training';
$primaryBtnUrl = $config['cta.primary_url'] ?? '#cta';
$secondaryBtnText = $config['cta.secondary_text'] ?? 'View Programs';
$secondaryBtnUrl = $config['cta.secondary_url'] ?? '#programs';

$statsRaw = $config['stats.items'] ?? "500+|Happy Members\n50+|Daily Classes\n15+|Expert Trainers";
$stats = [];
foreach (preg_split('/[\r\n]+/', $statsRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    if (!empty(trim($parts[0] ?? ''))) {
        $stats[] = ['value' => trim($parts[0]), 'label' => trim($parts[1] ?? '')];
    }
}

$paddingTop = $config['style.padding_top'] ?? '120';
$paddingBottom = $config['style.padding_bottom'] ?? '80';
$instanceId = 'fp-hero-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $heroBg ?>; padding: <?= intval($paddingTop) ?>px 0 <?= intval($paddingBottom) ?>px; position: relative; overflow: hidden; }
