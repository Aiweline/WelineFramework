<?php
/**
 * Twenty Nine Tempest - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: Hero Banner
 * name_en: Hero Slider
 * description: Command-board hero with asymmetric stage
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置（TPMST兼容）
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用主题图
 * banner.image_desktop => PC端Banner图片:textarea:|默认使用主题图
 * banner.alt => Banner图片描述:text:Twenty Nine Tempest hero
 * banner.bg_color => Banner背景颜色:color:#091423
 *
 * group:hero => Hero设置
 * hero.display => 显示Hero:select:yes|yes,no
 * hero.title => 主标题:text:Rule the Next Hand with Twenty Nine Tempest
 * hero.subtitle => 副标题:textarea:Sharp bidding cues, fast lobby entry, and a card-first interface built for competitive 29 players.
 * hero.cta_text => 主按钮文本:text:Play Now
 * hero.cta_url => 主按钮链接:text:#download
 * hero.secondary_cta_text => 次按钮文本:text:Explore Rooms
 * hero.secondary_cta_url => 次按钮链接:text:#tables
 * hero.image => Hero图片地址:textarea:|留空使用默认图片
 * hero.image_mobile => Hero移动端图片地址:textarea:|留空使用默认图片
 * hero.alt => Hero图片描述:text:Twenty Nine Tempest hero
 * hero.bg_color => Hero背景颜色:color:#091423
 * hero.bg_image => 背景图片地址:textarea:|留空使用默认纹理
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:|留空使用箭头图标
 * download_btn.alt => 下载按钮描述:text:Play Now
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域附加类名:textarea:tnt-hero-stage
 * layout.margin_top => 移动端顶部重叠:number:-72|px
 * layout.img_margin_top => 图片偏移:number:0|px
 *
 * @fields_end
 */

$componentId = 'tnt-hero-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$normalizeDisplay = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroDisplay = $normalizeDisplay($getConfig('hero.display', $getConfig('banner.display', 'yes'))) === 'yes';
if (!$heroDisplay) {
    return;
}

$page = $this->getData('page');
$pageTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Twenty Nine Tempest';
$pageTitle = $sanitizeTitle($pageTitle);
if ($pageTitle === '') {
    $pageTitle = 'Twenty Nine Tempest';
}

$title = $sanitizeTitle((string) $getConfig('hero.title', ''));
$bannerTitle = $sanitizeTitle((string) $getConfig('banner.alt', ''));
if ($title === '' && $bannerTitle !== '' && stripos($bannerTitle, 'banner') === false && stripos($bannerTitle, 'hero') === false) {
    $title = $bannerTitle;
}
if ($title === '') {
    $title = $pageTitle !== '' ? $pageTitle : 'Rule the Next Hand with Twenty Nine Tempest';
}

$subtitle = trim((string) $getConfig('hero.subtitle', ''));
if ($subtitle === '') {
    $subtitle = $page ? trim((string) ($page->getData('meta_description') ?: '')) : '';
}
if ($subtitle === '') {
    $subtitle = 'Sharp bidding cues, fast lobby entry, and a card-first interface built for competitive 29 players.';
}

$downloadDisplay = $normalizeDisplay($getConfig('download_btn.display', 'yes')) === 'yes';
$downloadButtonImage = trim((string) $getConfig('download_btn.image', ''));
$ctaText = (string) $getConfig('hero.cta_text', $getConfig('download_btn.alt', 'Play Now'));
$ctaUrl = (string) $getConfig('hero.cta_url', $getConfig('download_btn.url', '#download'));
$ctaHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaHref, 'url');
$ctaSecondaryText = (string) $getConfig('hero.secondary_cta_text', 'Explore Rooms');
$ctaSecondaryUrl = (string) $getConfig('hero.secondary_cta_url', '#tables');
$heroAlt = trim((string) $getConfig('hero.alt', $getConfig('banner.alt', '')));
if ($heroAlt === '') {
    $heroAlt = $title;
}

$heroImageDesktop = trim((string) $getConfig('hero.image', $getConfig('banner.image_desktop', '')));
$heroImageMobile = trim((string) $getConfig('hero.image_mobile', $getConfig('banner.image_mobile', '')));
$defaultHeroImage = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/hero-info-graphic.svg');
$heroImageDesktop = $heroImageDesktop !== '' ? $heroImageDesktop : $defaultHeroImage;
$heroImageMobile = $heroImageMobile !== '' ? $heroImageMobile : $heroImageDesktop;
$bgColor = (string) $getConfig('hero.bg_color', $getConfig('banner.bg_color', $colors['hero_bg'] ?? '#091423'));
$bgImage = trim((string) $getConfig('hero.bg_image', ''));
$bgImage = $bgImage !== '' ? $bgImage : $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/poker-header-bg.svg');
$sliderClasses = trim((string) $getConfig('layout.slider_classes', 'tnt-hero-stage'));
$marginTop = (int) $getConfig('layout.margin_top', '-72');
$imgMarginTop = (int) $getConfig('layout.img_margin_top', '0');

$textLength = static function ($value) {
    return function_exists('mb_strlen') ? mb_strlen($value) : strlen($value);
};

$trimWords = static function ($value, $wordLimit = 3) {
    $value = trim((string) $value);
    if ($value === '') {
        return '';
    }

    $words = preg_split('/\s+/', preg_replace('/[^\p{L}\p{N}]+/u', ' ', $value)) ?: [];
    $words = array_values(array_filter($words, static function ($word) {
        return $word !== '';
    }));

    return trim(implode(' ', array_slice($words, 0, max(1, (int) $wordLimit))));
};

$heroKicker = $trimWords($title, 3);
if ($heroKicker === '') {
    $heroKicker = 'Twenty Nine Tempest';
}

$heroChips = [];
foreach ([$ctaText, $ctaSecondaryText] as $actionText) {
    $actionText = trim((string) $actionText);
    if ($actionText !== '') {
        $heroChips[] = $actionText;
    }
}

$subtitleParts = preg_split('/[,.!?;]+/', $subtitle) ?: [];
foreach ($subtitleParts as $part) {
    $part = trim((string) $part);
    if ($part === '') {
        continue;
    }

    if ($textLength($part) > 24) {
        $part = $trimWords($part, 3);
    }

    if ($part !== '') {
        $heroChips[] = $part;
    }
}

$heroChips[] = $heroKicker;
$heroChips = array_values(array_unique(array_filter($heroChips, static function ($item) {
    return trim((string) $item) !== '';
})));
$heroChips = array_slice($heroChips, 0, 4);
?>

<section id="<?= $componentId ?>" class="tnt-hero <?= htmlspecialchars($sliderClasses) ?>" aria-labelledby="<?= $componentId ?>-title" style="--tnt-hero-base: <?= htmlspecialchars($bgColor) ?>; --tnt-hero-overlap: <?= (int) $marginTop ?>px; --tnt-hero-img-offset: <?= (int) $imgMarginTop ?>px;">
    <div class="hero-texture" style="background-image:url('<?= htmlspecialchars($bgImage) ?>');"></div>

    <div class="hero-shell">
        <div class="hero-grid">
            <figure class="hero-stage wow animate__fadeInUp" data-wow-delay="0.08s">
                <div class="stage-panel">
                    <div class="stage-topbar">
                        <span class="stage-mode">Table View</span>
                        <span class="stage-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                    </div>

                    <div class="stage-frame" data-stage-frame>
                        <span class="stage-glow glow-a" aria-hidden="true"></span>
                        <span class="stage-glow glow-b" aria-hidden="true"></span>

                        <div class="stage-orbit" aria-hidden="true">
                            <span class="orbit-chip orbit-1" aria-hidden="true"></span>
                            <span class="orbit-chip orbit-2" aria-hidden="true"></span>
                            <span class="orbit-chip orbit-3" aria-hidden="true"></span>
                            <span class="orbit-chip orbit-4" aria-hidden="true"></span>
                        </div>

                        <div class="stage-poster">
                            <picture>
                                <source media="(max-width: 767px)" srcset="<?= htmlspecialchars($heroImageMobile) ?>">
                                <source media="(min-width: 768px)" srcset="<?= htmlspecialchars($heroImageDesktop) ?>">
                                <img src="<?= htmlspecialchars($heroImageDesktop) ?>" alt="<?= htmlspecialchars($heroAlt) ?>" fetchpriority="high" decoding="async">
                            </picture>
                        </div>
                    </div>

                </div>
            </figure>

            <aside class="hero-rail">
                <div class="rail-intro wow animate__fadeInRight">
                    <span class="hero-kicker"><?= htmlspecialchars($heroKicker) ?></span>

                    <h1 class="rail-title" id="<?= $componentId ?>-title">
                        <span><?= htmlspecialchars($title) ?></span>
                    </h1>

                    <?php if ($subtitle !== ''): ?>
                        <p class="rail-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                    <?php endif; ?>

                    <div class="hero-tape" aria-label="Hero highlights">
                        <?php foreach ($heroChips as $item): ?>
                            <span class="tape-chip"><?= htmlspecialchars($item) ?></span>
                        <?php endforeach; ?>
                    </div>
                </div>
            </aside>

            <div class="rail-actions wow animate__fadeInUp" data-wow-delay="0.14s">
                <div class="action-layout">
                    <div class="action-stack">
                        <?php if ($downloadDisplay && $ctaText !== ''): ?>
                            <a class="hero-primary" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($ctaRef)) ?>" data-glr-ref="<?= htmlspecialchars($ctaRef) ?>">
                                <?php if ($downloadButtonImage !== ''): ?>
                                    <img class="hero-primary-icon" src="<?= htmlspecialchars($downloadButtonImage) ?>" alt="" aria-hidden="true">
                                <?php else: ?>
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 4V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                        <path d="M8 10L12 14L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M5 18H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    </svg>
                                <?php endif; ?>
                                <span><?= htmlspecialchars($ctaText) ?></span>
                            </a>
                        <?php endif; ?>

                        <?php if ($ctaSecondaryText !== ''): ?>
                            <a class="hero-secondary" href="<?= htmlspecialchars($ctaSecondaryUrl) ?>">
                                <span><?= htmlspecialchars($ctaSecondaryText) ?></span>
                            </a>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

