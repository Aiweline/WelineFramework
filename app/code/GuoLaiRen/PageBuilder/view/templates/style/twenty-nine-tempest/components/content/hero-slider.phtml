</style>

<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var frame = root.querySelector('[data-stage-frame]');
    if (!frame) {
        return;
    }

    var coarsePointer = window.matchMedia && window.matchMedia('(pointer: coarse)').matches;
    if (coarsePointer) {
        return;
    }

    var updateGlow = function (event) {
        var rect = frame.getBoundingClientRect();
        var x = ((event.clientX - rect.left) / rect.width) * 100;
        var y = ((event.clientY - rect.top) / rect.height) * 100;
        frame.style.setProperty('--mx', x.toFixed(2) + '%');
        frame.style.setProperty('--my', y.toFixed(2) + '%');
    };

    frame.addEventListener('pointermove', updateGlow);
    frame.addEventListener('pointerleave', function () {
        frame.style.setProperty('--mx', '50%');
        frame.style.setProperty('--my', '38%');
    });
})();
</script>
