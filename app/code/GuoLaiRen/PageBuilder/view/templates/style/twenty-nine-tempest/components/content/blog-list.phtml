<?php
/**
 * Twenty Nine Tempest Blog List Component
 *
 * @fields_start
 * blog.title|博客列表标题|text|Latest Blog Posts
 * blog.subtitle|副标题|text|Stay updated with our latest news and articles
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=特色|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$componentId = 'tnt-blog-list-' . uniqid();

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', __('Latest Blog Posts'));
$subtitle = $getConfig('blog.subtitle', __('Stay updated with our latest news and articles'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#1eb980');
$secondaryColor = $getConfig('color_scheme.secondary', '#f2a93b');
$bgColor = $getConfig('color_scheme.background', '#0b1525');
$textColor = $getConfig('color_scheme.text', '#f8fafc');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/poker-header-bg.svg');

$featuredPost = $blogPosts[0] ?? null;
$sidePosts = array_slice($blogPosts, 1, 2);
$archivePosts = array_slice($blogPosts, 3);
if (!$featuredPost) {
    $archivePosts = [];
}

$excerpt = static function ($value, $limit) {
    $value = trim((string) $value);
    if ($value === '') {
        return '';
    }

    if (function_exists('mb_strlen') && function_exists('mb_substr')) {
        return mb_strlen($value) > $limit ? mb_substr($value, 0, $limit) . '...' : $value;
    }

    return strlen($value) > $limit ? substr($value, 0, $limit) . '...' : $value;
};
?>

<section id="<?= $componentId ?>" class="tnt-blog-list">
    <div class="blog-shell">
        <header class="blog-head">
            <div>
                <span class="head-kicker">Editorial Dispatch</span>
                <h2><?= htmlspecialchars($title) ?></h2>
            </div>
            <?php if ($subtitle): ?>
                <p class="head-copy"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="blog-empty">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <p><?= __('There are no blog posts yet. Please check back later!') ?></p>
            </div>
        <?php else: ?>
            <div class="blog-layout<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="blog-stage">
                    <?php if ($featuredPost): ?>
                        <section class="lead-deck<?= empty($sidePosts) ? ' no-side' : '' ?>">
                            <article class="lead-story">
                                <div class="lead-copy">
                                    <div class="meta-line">
                                        <?php if ($showCategory && !empty($featuredPost['category_name'])): ?>
                                            <span class="meta-chip"><?= htmlspecialchars($featuredPost['category_name']) ?></span>
                                        <?php endif; ?>
                                        <?php if ($showDate && !empty($featuredPost['published_at'])): ?>
                                            <span class="meta-date"><?= date('M d, Y', strtotime($featuredPost['published_at'])) ?></span>
                                        <?php endif; ?>
                                    </div>

                                    <h3><a href="<?= htmlspecialchars($featuredPost['url']) ?>"><?= htmlspecialchars($featuredPost['title']) ?></a></h3>

                                    <?php if (!empty($featuredPost['summary'])): ?>
                                        <p class="lead-summary"><?= htmlspecialchars($excerpt($featuredPost['summary'], 240)) ?></p>
                                    <?php endif; ?>

                                    <div class="lead-foot">
                                        <?php if ($showAuthor && !empty($featuredPost['author'])): ?>
                                            <span class="meta-author"><?= htmlspecialchars($featuredPost['author']) ?></span>
                                        <?php endif; ?>
                                        <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="read-link">
                                            <?= __('Read Story') ?>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                            </svg>
                                        </a>
                                    </div>
                                </div>

                                <?php if (!empty($featuredPost['cover_image'])): ?>
                                    <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="lead-media">
                                        <img src="<?= htmlspecialchars($featuredPost['cover_image']) ?>" alt="<?= htmlspecialchars($featuredPost['title']) ?>" loading="lazy">
                                    </a>
                                <?php endif; ?>
                            </article>

                            <?php if (!empty($sidePosts)): ?>
                                <div class="signal-stack">
                                    <?php foreach ($sidePosts as $post): ?>
                                        <article class="signal-card">
                                            <div class="meta-line">
                                                <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                    <span class="meta-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                                <?php endif; ?>
                                                <?php if ($showDate && !empty($post['published_at'])): ?>
                                                    <span class="meta-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                                <?php endif; ?>
                                            </div>
                                            <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                            <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                                <p><?= htmlspecialchars($excerpt($post['summary'], 120)) ?></p>
                                            <?php endif; ?>
                                            <div class="signal-foot">
                                                <?php if ($showAuthor && !empty($post['author'])): ?>
                                                    <span><?= htmlspecialchars($post['author']) ?></span>
                                                <?php endif; ?>
                                                <a href="<?= htmlspecialchars($post['url']) ?>" class="read-link"><?= __('Open') ?></a>
                                            </div>
                                        </article>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($archivePosts)): ?>
                        <section class="archive-flow style-<?= htmlspecialchars(preg_replace('/[^a-z0-9-]+/i', '', (string) $cardStyle)) ?>">
                            <?php foreach ($archivePosts as $index => $post): ?>
                                <article class="archive-card<?= $cardStyle === 'featured' && $index === 0 ? ' is-highlight' : '' ?>">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="archive-media">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                        </a>
                                    <?php endif; ?>

                                    <div class="archive-copy">
                                        <div class="meta-line">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span class="meta-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span class="meta-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>
                                        <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                        <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                            <p><?= htmlspecialchars($excerpt($post['summary'], 150)) ?></p>
                                        <?php endif; ?>
                                        <div class="archive-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span class="meta-author"><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars($post['url']) ?>" class="read-link"><?= __('Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </section>
                    <?php endif; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="signal-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Categories</span>
                                <div class="category-cloud">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-pill"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Recent Posts</span>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

