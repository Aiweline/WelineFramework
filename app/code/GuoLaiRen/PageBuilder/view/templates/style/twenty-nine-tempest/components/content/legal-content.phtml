<?php
/**
 * Twenty Nine Tempest - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录与更新时间
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:medium|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:72|px
 * layout.content_padding => 内容内边距:number:32|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.updated_label => 更新时间前缀:text:Last Updated
 * header.bg_color => 背景色:color:#0b1525
 * header.bg_gradient_end => 渐变结束色:color:#0f2538
 * header.title_color => 标题颜色:color:#f8fafc
 * header.text_color => 文字颜色:color:#cbd5e1
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.items => 章节:textarea:
 * toc.bg_color => 目录背景色:color:#102035
 * toc.border_color => 目录边框色:color:#30465e
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:
 * content.empty_text => 空内容提示:text:Content will appear here.
 * content.bg_color => 内容区背景色:color:#0d1a2d
 * content.text_color => 内容文字颜色:color:#e9f5f2
 * content.heading_color => 标题颜色:color:#f2a93b
 * content.link_color => 链接颜色:color:#1eb980
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];
$componentId = 'tnt-legal-' . uniqid();

$getConfig = static function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showToc = $normalizeToggle($getConfig('display.show_toc', 'yes')) !== 'no';
$showLastUpdated = $normalizeToggle($getConfig('display.show_last_updated', 'yes')) !== 'no';
$showIcon = $normalizeToggle($getConfig('display.show_icon', 'yes')) !== 'no';

$contentWidth = (string) $getConfig('layout.content_width', 'medium');
$headerPadding = max(40, (int) $getConfig('layout.header_padding', '72'));
$contentPadding = max(24, (int) $getConfig('layout.content_padding', '32'));
$maxWidth = match ($contentWidth) {
    'wide' => '1220px',
    'narrow' => '860px',
    default => '1040px',
};

$pageType = $page ? (string) ($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string) ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$title = trim((string) $getConfig('header.title', $pageTitle));
if ($title === '') {
    $title = 'Legal Document';
}
$updatedLabel = trim((string) $getConfig('header.updated_label', 'Last Updated'));
$heroBg = (string) $getConfig('header.bg_color', $colors['hero_bg'] ?? '#0b1525');
$heroBgEnd = (string) $getConfig('header.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#0f2538');
$heroTitleColor = (string) $getConfig('header.title_color', $colors['heading_color'] ?? '#f8fafc');
$heroTextColor = (string) $getConfig('header.text_color', $colors['text_secondary'] ?? '#cbd5e1');
$tocTitle = trim((string) $getConfig('toc.title', 'On This Page'));
$tocBg = (string) $getConfig('toc.bg_color', '#102035');
$tocBorder = (string) $getConfig('toc.border_color', '#30465e');
$contentBg = (string) $getConfig('content.bg_color', '#0d1a2d');
$contentText = (string) $getConfig('content.text_color', '#e9f5f2');
$contentHeading = (string) $getConfig('content.heading_color', '#f2a93b');
$contentLink = (string) $getConfig('content.link_color', '#1eb980');
$emptyText = trim((string) $getConfig('content.empty_text', 'Content will appear here.'));

$typeIcons = [
    'privacy_policy' => 'PR',
    'terms_of_service' => 'TS',
    'refund_policy' => 'RF',
    'shipping_policy' => 'SP',
    'cookie_policy' => 'CK',
];
$icon = trim((string) $getConfig('header.icon', $typeIcons[$pageType] ?? 'LG'));

$fallbackBody = trim((string) $getConfig('content.body', ''));
$fallbackTocRaw = trim((string) $getConfig('toc.items', ''));
if (trim($pageContentRaw) === '' && ($fallbackBody !== '' || $fallbackTocRaw !== '')) {
    $rebuilt = [];
    if ($fallbackBody !== '') {
        $rebuilt[] = '<p>' . nl2br(htmlspecialchars($fallbackBody, ENT_QUOTES, 'UTF-8')) . '</p>';
    }
    foreach (preg_split('/[\r\n]+/', $fallbackTocRaw) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $sectionTitle = trim((string) ($parts[0] ?? ''));
        $sectionBody = trim((string) ($parts[1] ?? ''));
        if ($sectionTitle === '') {
            continue;
        }
        $rebuilt[] = '<h2>' . htmlspecialchars($sectionTitle, ENT_QUOTES, 'UTF-8') . '</h2>';
        if ($sectionBody !== '') {
            $rebuilt[] = '<p>' . nl2br(htmlspecialchars($sectionBody, ENT_QUOTES, 'UTF-8')) . '</p>';
        }
    }
    $pageContentRaw = implode('', $rebuilt);
}

$slugify = static function ($text) {
    $text = trim((string) preg_replace('/\s+/u', ' ', strip_tags((string) $text)));
    $slug = strtolower($text);
    $slug = preg_replace('/[^a-z0-9]+/i', '-', $slug);
    return trim((string) $slug, '-') ?: 'section';
};

$tocItems = [];
$usedSlugs = [];
if (trim($pageContentRaw) !== '' && strpos($pageContentRaw, '<') !== false) {
    $processedContent = preg_replace_callback('/<h([2-4])([^>]*)>(.*?)<\/h\1>/is', function ($matches) use (&$tocItems, &$usedSlugs, $slugify) {
        $level = (int) $matches[1];
        $attrs = (string) $matches[2];
        $inner = (string) $matches[3];
        $text = trim((string) preg_replace('/\s+/u', ' ', strip_tags($inner)));
        if ($text === '') {
            return $matches[0];
        }
        if (preg_match('/\sid=("|\')(.*?)\1/i', $attrs, $attrMatch)) {
            $id = $attrMatch[2];
        } else {
            $base = $slugify($text);
            $count = ($usedSlugs[$base] ?? 0) + 1;
            $usedSlugs[$base] = $count;
            $id = $count > 1 ? $base . '-' . $count : $base;
            $attrs .= ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '"';
        }
        $tocItems[] = ['id' => $id, 'text' => $text, 'level' => $level];
        return '<h' . $level . $attrs . '>' . $inner . '</h' . $level . '>';
    }, $pageContentRaw);
} elseif (trim($pageContentRaw) !== '') {
    $processedContent = '<p>' . nl2br(htmlspecialchars(trim($pageContentRaw), ENT_QUOTES, 'UTF-8')) . '</p>';
} else {
    $processedContent = '<p>' . htmlspecialchars($emptyText !== '' ? $emptyText : 'Content will appear here.', ENT_QUOTES, 'UTF-8') . '</p>';
}

$formattedUpdated = '';
$updatedIso = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('F j, Y', $timestamp);
        $updatedIso = date('c', $timestamp);
    }
}
$hasToc = $showToc && !empty($tocItems);
?>
<section id="<?= $componentId ?>" class="tnt-legal-page" aria-labelledby="<?= $componentId ?>-title" style="--legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --legal-content-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --legal-content-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>; --legal-header-padding: <?= (int) $headerPadding ?>px; --legal-content-padding: <?= (int) $contentPadding ?>px;">
    <div class="legal-shell">
        <header class="legal-hero">
            <?php if ($showIcon && $icon !== ''): ?>
                <span class="hero-icon"><?= htmlspecialchars($icon, ENT_QUOTES, 'UTF-8') ?></span>
            <?php endif; ?>
            <div class="hero-copy">
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h1>
                <?php if ($formattedUpdated !== ''): ?>
                    <p>
                        <?php if ($updatedLabel !== ''): ?><?= htmlspecialchars($updatedLabel, ENT_QUOTES, 'UTF-8') ?> <?php endif; ?>
                        <time datetime="<?= htmlspecialchars($updatedIso, ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars($formattedUpdated, ENT_QUOTES, 'UTF-8') ?></time>
                    </p>
                <?php endif; ?>
            </div>
        </header>

        <div class="legal-layout<?= !$hasToc ? ' no-toc' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-toc" aria-label="Table of contents">
                    <div class="toc-card">
                        <span class="toc-title"><?= htmlspecialchars($tocTitle, ENT_QUOTES, 'UTF-8') ?></span>
                        <nav class="toc-links">
                            <?php foreach ($tocItems as $index => $item): ?>
                                <a href="#<?= htmlspecialchars($item['id'], ENT_QUOTES, 'UTF-8') ?>" class="toc-link level-<?= (int) $item['level'] ?>">
                                    <small><?= sprintf('%02d', $index + 1) ?></small>
                                    <span><?= htmlspecialchars($item['text'], ENT_QUOTES, 'UTF-8') ?></span>
                                </a>
                            <?php endforeach; ?>
                        </nav>
                    </div>
                </aside>
            <?php endif; ?>

            <article class="legal-article">
                <div class="article-card">
                    <div class="legal-content"><?= $processedContent ?></div>
                </div>
            </article>
        </div>
    </div>
</section>
<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    padding: clamp(4.5rem, 8vw, 6.4rem) 0;
    min-height: 100vh;
    background:
        radial-gradient(840px 380px at 8% 8%, rgba(24, 240, 255, 0.14), transparent 72%),
        radial-gradient(700px 340px at 92% 18%, rgba(255, 122, 77, 0.14), transparent 68%),
        linear-gradient(180deg, var(--legal-hero-bg) 0%, var(--legal-hero-end) 100%);
}
#<?= $componentId ?>::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(128deg, rgba(255,255,255,0.03) 0 1px, transparent 1px 28px);
    opacity: 0.24;
    pointer-events: none;
}
#<?= $componentId ?> .legal-shell {
    width: min(var(--legal-max-width), calc(100% - 1.2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
}
#<?= $componentId ?> .legal-hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    padding-top: var(--legal-header-padding);
}
#<?= $componentId ?> .hero-icon,
#<?= $componentId ?> .toc-card,
#<?= $componentId ?> .article-card {
    border-radius: 26px;
}
#<?= $componentId ?> .hero-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 72px;
    min-height: 72px;
    padding: 0.8rem;
    color: #08131f;
    background: linear-gradient(135deg, rgba(255,212,93,0.98), rgba(24,240,255,0.92));
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.08em;
}
#<?= $componentId ?> .hero-copy h1 {
    margin: 0;
    color: var(--legal-hero-title);
    font-size: clamp(2.3rem, 4.6vw, 4.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
}
#<?= $componentId ?> .hero-copy p {
    margin: 0.9rem 0 0;
    color: var(--legal-hero-text);
    line-height: 1.8;
}
#<?= $componentId ?> .legal-layout {
    display: grid;
    grid-template-columns: minmax(260px, 0.34fr) minmax(0, 1fr);
    gap: 1rem;
    margin-top: 1rem;
}
#<?= $componentId ?> .legal-layout.no-toc {
    grid-template-columns: 1fr;
}
#<?= $componentId ?> .legal-toc {
    position: sticky;
    top: 6rem;
    align-self: start;
}
#<?= $componentId ?> .toc-card {
    padding: 1rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02)), var(--legal-toc-bg);
    box-shadow: inset 0 0 0 1px var(--legal-toc-border);
}
#<?= $componentId ?> .toc-title {
    display: block;
    color: var(--legal-hero-title);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}
#<?= $componentId ?> .toc-links {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.95rem;
}
#<?= $componentId ?> .toc-link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    text-decoration: none;
    color: var(--legal-hero-text);
    line-height: 1.6;
}
#<?= $componentId ?> .toc-link small {
    color: rgba(255,255,255,0.56);
    font-weight: 800;
    letter-spacing: 0.08em;
}
#<?= $componentId ?> .article-card {
    padding: var(--legal-content-padding);
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)), var(--legal-content-bg);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
}
#<?= $componentId ?> .legal-content {
    color: var(--legal-content-text);
}
#<?= $componentId ?> .legal-content > *:first-child {
    margin-top: 0;
}
#<?= $componentId ?> .legal-content > *:last-child {
    margin-bottom: 0;
}
#<?= $componentId ?> .legal-content p,
#<?= $componentId ?> .legal-content li {
    line-height: 1.9;
}
#<?= $componentId ?> .legal-content h1,
#<?= $componentId ?> .legal-content h2,
#<?= $componentId ?> .legal-content h3,
#<?= $componentId ?> .legal-content h4 {
    color: var(--legal-content-heading);
    line-height: 1.18;
}
#<?= $componentId ?> .legal-content a {
    color: var(--legal-content-link);
}
@media (max-width: 980px) {
    #<?= $componentId ?> .legal-layout {
        grid-template-columns: 1fr;
    }
    #<?= $componentId ?> .legal-toc {
        position: static;
    }
}
@media (max-width: 760px) {
    #<?= $componentId ?> .legal-shell {
        width: min(100%, calc(100% - 0.8rem));
    }
    #<?= $componentId ?> .legal-hero {
        grid-template-columns: 1fr;
    }
    #<?= $componentId ?> .hero-icon,
    #<?= $componentId ?> .toc-card,
    #<?= $componentId ?> .article-card {
        border-radius: 22px;
    }
}
</style>
