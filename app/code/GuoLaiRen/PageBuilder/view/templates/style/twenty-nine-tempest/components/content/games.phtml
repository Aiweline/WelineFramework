 * style.card_gap => 卡片间距:number:24|px
 *
 * group:texts => 文案设置
 * texts.title => 区域标题:text:Choose Your 29 Card Room Style
 * texts.summary => 区域摘要:textarea:Same core game logic, different lobby rhythm. Pick a room format that matches your timing and play pressure.
 * texts.tags => 标签列表:textarea:Quick Entry|Balanced Tempo|Late Night Sessions
 *
 * group:game_1 => 房间1
 * texts.game_1_badge => 房间1徽标:text:Hot Room
 * texts.game_1_title => 房间1标题:text:Speed Bid
 * texts.game_1_desc => 房间1描述:textarea:High-tempo room with fast transitions between bidding rounds.
 * texts.game_1_tag => 房间1标签:text:Quick Entry
 * texts.game_1_url => 房间1链接:text:#speed
 * images.image_1_desktop => 房间1桌面图:textarea:|留空则不显示图片
 * images.image_1_mobile => 房间1移动端图:textarea:|留空则不显示图片
 *
 * group:game_2 => 房间2
 * texts.game_2_badge => 房间2徽标:text:Fast Queue
 * texts.game_2_title => 房间2标题:text:Smart Table
 * texts.game_2_desc => 房间2描述:textarea:Balanced room with cleaner spacing for repeat sessions.
 * texts.game_2_tag => 房间2标签:text:Balanced Tempo
 * texts.game_2_url => 房间2链接:text:#smart
 * images.image_2 => 房间2图片:textarea:|留空则不显示图片
 *
 * group:game_3 => 房间3
 * texts.game_3_badge => 房间3徽标:text:Player Favorite
 * texts.game_3_title => 房间3标题:text:Focus Room
 * texts.game_3_desc => 房间3描述:textarea:Lower-noise layout for players who prefer measured decisions.
 * texts.game_3_tag => 房间3标签:text:Late Night Sessions
 * texts.game_3_url => 房间3链接:text:#focus
 * images.image_3 => 房间3图片:textarea:|留空则不显示图片
 *
 * group:game_4 => 房间4
 * texts.game_4_badge => 房间4徽标:text:Calm Table
 * texts.game_4_title => 房间4标题:text:Night Rally
 * texts.game_4_desc => 房间4描述:textarea:Late-session room tuned for sustained play.
 * texts.game_4_tag => 房间4标签:text:Prime Shift
 * texts.game_4_url => 房间4链接:text:#night
 *
 * group:game_5 => 房间5
 * texts.game_5_badge => 房间5徽标:text:High Stakes
 * texts.game_5_title => 房间5标题:text:Prime 29
 * texts.game_5_desc => 房间5描述:textarea:Flagship room with bold visuals and priority queue.
 * texts.game_5_tag => 房间5标签:text:Table Focus
 * texts.game_5_url => 房间5链接:text:#prime
 *
 * @fields_end
 */

$componentId = 'tnt-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeLines = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$parseLegacyGames = static function ($value) use ($normalizeLines) {
    $rooms = [];
    foreach ($normalizeLines((string) $value) as $line) {
        $parts = array_map('trim', explode('|', $line));
        $title = $parts[0] ?? '';
        if ($title === '') {
            continue;
        }
        $rooms[] = [
            'title' => $title,
            'description' => $parts[1] ?? '',
            'url' => $parts[2] ?? '#',
        ];
    }
    return $rooms;
};

$parseLegacyTokenList = static function ($value) {
    $tokens = preg_split('/\|/', str_replace(["\r", "\n"], '|', (string) $value)) ?: [];
    return array_values(array_filter(array_map('trim', $tokens), static function ($item) {
        return $item !== '';
    }));
};

$getLegacyIndexed = static function (array $items, $index, $default = '') {
    return isset($items[$index]) && $items[$index] !== '' ? $items[$index] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_description', $getConfig('display.show_subtitle', 'yes')) !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';

$bgColor = (string) $getConfig('style.bg_color', $getConfig('games.bg_color', '#0b1528'));
$accentColor = (string) $getConfig('style.accent_color', '#ff6b2c');
$titleColor = (string) $getConfig('style.title_color', '#f5fbff');
$subtitleColor = (string) $getConfig('style.subtitle_color', '#b4c6dc');
$panelBgColor = (string) $getConfig('style.panel_bg_color', 'rgba(10,20,38,0.82)');
$cardBgColor = (string) $getConfig('style.card_bg_color', 'rgba(18,32,58,0.88)');
$cardBorderColor = (string) $getConfig('style.card_border_color', 'rgba(41,208,255,0.18)');
$cardRadius = max(18, (int) $getConfig('style.card_border_radius', '26'));
$cardContentPadding = max(10, (int) $getConfig('style.card_content_padding', '14'));
$cardTitleColor = (string) $getConfig('style.card_title_color', '#ffffff');
$cardDescColor = (string) $getConfig('style.card_desc_color', '#d7e7fb');
$cardTitleFontSize = max(18, (int) $getConfig('style.card_title_font_size', '26'));
$cardDescFontSize = max(13, (int) $getConfig('style.card_desc_font_size', '16'));
$hoverTransform = (int) $getConfig('style.hover_transform', '-3');
$titleFontSize = max(30, (int) $getConfig('style.title_font_size', '68'));
$titleFontSizeMobile = max(24, (int) $getConfig('style.title_font_size_mobile', '34'));
$sectionPadding = max(48, (int) $getConfig('style.section_padding', '88'));
$sectionPaddingMobile = max(36, (int) $getConfig('style.section_padding_mobile', '56'));
$cardGap = max(12, (int) $getConfig('style.card_gap', '24'));

$defaultRooms = [
    ['badge' => 'Hot Room', 'title' => 'Speed Bid', 'description' => 'High-tempo room with fast transitions between bidding rounds.', 'tag' => 'Quick Entry', 'url' => '#speed'],
    ['badge' => 'Fast Queue', 'title' => 'Smart Table', 'description' => 'Balanced room with cleaner spacing for repeat sessions.', 'tag' => 'Balanced Tempo', 'url' => '#smart'],
    ['badge' => 'Player Favorite', 'title' => 'Focus Room', 'description' => 'Lower-noise layout for players who prefer measured decisions.', 'tag' => 'Late Night Sessions', 'url' => '#focus'],
    ['badge' => 'Calm Table', 'title' => 'Night Rally', 'description' => 'Late-session room tuned for sustained play.', 'tag' => 'Prime Shift', 'url' => '#night'],
    ['badge' => 'High Stakes', 'title' => 'Prime 29', 'description' => 'Flagship room with bold visuals and priority queue.', 'tag' => 'Table Focus', 'url' => '#prime'],
];

$title = (string) $getConfigAny(['texts.title', 'games.title', 'texts.games_title'], 'Choose Your 29 Card Room Style');
$summary = (string) $getConfigAny(
    ['texts.summary', 'texts.games_summary', 'texts.subtitle', 'games.subtitle'],
    'Same core game logic, different lobby rhythm. Pick a room format that matches your timing and play pressure.'
);
$tagsConfig = (string) $getConfigAny(['texts.tags', 'games.tags'], 'Quick Entry|Balanced Tempo|Late Night Sessions');
$legacyRooms = $parseLegacyGames($getConfig('games.items', ''));
$legacyBadges = $parseLegacyTokenList($getConfig('texts.badges', ''));
$legacyTags = $parseLegacyTokenList($getConfig('texts.tags', ''));

$tags = array_values(array_filter(array_map('trim', preg_split('/\|/', str_replace(["\r", "\n"], '|', $tagsConfig)) ?: []), static function ($item) {
    return $item !== '';
}));

$games = [];
for ($i = 1; $i <= 5; $i++) {
    $index = $i - 1;
    $default = $defaultRooms[$index];
    $legacyRoom = $legacyRooms[$index] ?? [];
    $groupPrefix = "game_{$i}.";

    $room = [
        'badge' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_badge", "texts.game_{$i}_badge"], $getLegacyIndexed($legacyBadges, $index, $default['badge']))),
        'name' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_title", "texts.game_{$i}_title"], $legacyRoom['title'] ?? $default['title'])),
        'description' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_desc", "texts.game_{$i}_desc"], $legacyRoom['description'] ?? $default['description'])),
        'tag' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_tag", "texts.game_{$i}_tag"], $getLegacyIndexed($legacyTags, $index, $default['tag']))),
        'url' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_url", "texts.game_{$i}_url"], $legacyRoom['url'] ?? $default['url'])),
        'no' => sprintf('%02d', $i),
        'desktop_image' => '',
        'mobile_image' => '',
    ];

    if ($i === 1) {
        $room['desktop_image'] = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_desktop', 'images.image_1_desktop', 'games.image_1_desktop'], ''));
        $room['mobile_image'] = trim((string) $getConfigAny([$groupPrefix . 'images.image_1_mobile', 'images.image_1_mobile', 'games.image_1_mobile'], ''));
    } elseif ($i === 2) {
        $room['desktop_image'] = trim((string) $getConfigAny([$groupPrefix . 'images.image_2', 'images.image_2', 'games.image_2'], ''));
        $room['mobile_image'] = $room['desktop_image'];
    } elseif ($i === 3) {
        $room['desktop_image'] = trim((string) $getConfigAny([$groupPrefix . 'images.image_3', 'images.image_3', 'games.image_3'], ''));
        $room['mobile_image'] = $room['desktop_image'];
    }

    if ($room['name'] === '') {
        continue;
    }
    if ($room['url'] === '') {
        $room['url'] = '#';
    }

    $games[] = $room;
}

if (empty($games)) {
    foreach ($defaultRooms as $index => $default) {
        $games[] = [
            'badge' => $default['badge'],
            'name' => $default['title'],
            'description' => $default['description'],
            'tag' => $default['tag'],
            'url' => $default['url'],
            'no' => sprintf('%02d', $index + 1),
            'desktop_image' => '',
            'mobile_image' => '',
        ];
    }
}

$headerTags = [];
foreach (array_slice($games, 0, 3) as $room) {
    if (!empty($room['tag'])) {
        $headerTags[] = $room['tag'];
    }
}
$roomEffects = ['animate__fadeInLeft', 'animate__fadeInUp', 'animate__fadeInRight'];
?>

<section id="<?= $componentId ?>" class="tnt-games" aria-labelledby="<?= $componentId ?>-title" style="--room-gap: <?= (int) $cardGap ?>px; --room-radius: <?= (int) $cardRadius ?>px; --room-card-padding: <?= (int) $cardContentPadding ?>px; --room-hover-y: <?= (int) $hoverTransform ?>px;">
    <div class="games-shell" id="games">
        <span class="games-anchor" id="tables" aria-hidden="true"></span>

        <header class="games-head wow animate__fadeInDown" data-wow-duration="0.8s">
            <span class="games-kicker">Room Atlas</span>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><span><?= htmlspecialchars($title) ?></span></h2>
            <?php endif; ?>
            <?php if ($showSubtitle && $summary !== ''): ?>
                <p><?= htmlspecialchars($summary) ?></p>
            <?php endif; ?>

            <?php if ($showTags && !empty($headerTags)): ?>
                <div class="games-tags" aria-label="Room tags">
                    <?php foreach ($headerTags as $index => $tag): ?>
                        <span class="wow animate__zoomIn" data-wow-delay="<?= htmlspecialchars(number_format(0.12 + ($index * 0.05), 2)) ?>s" data-wow-duration="0.72s"><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="rooms-grid" role="list" aria-label="29 Card room options">
            <?php foreach ($games as $index => $room): ?>
                <?php $hasMedia = $room['desktop_image'] !== '' || $room['mobile_image'] !== ''; ?>
                <?php $desktopImage = $room['desktop_image'] !== '' ? $room['desktop_image'] : $room['mobile_image']; ?>
                <?php $mobileImage = $room['mobile_image'] !== '' ? $room['mobile_image'] : $room['desktop_image']; ?>
                <article class="room-card<?= $hasMedia ? ' has-media' : '' ?> wow <?= htmlspecialchars($roomEffects[$index % count($roomEffects)]) ?>" role="listitem" data-wow-delay="<?= htmlspecialchars(number_format(0.14 + (($index % 3) * 0.07), 2)) ?>s" data-wow-duration="<?= htmlspecialchars(number_format(0.82 + (($index % 3) * 0.05), 2)) ?>s">
                    <?php if ($hasMedia && $desktopImage !== ''): ?>
                        <div class="room-media">
                            <?php if ($index === 0 && $mobileImage !== '' && $mobileImage !== $desktopImage): ?>
                                <picture>
                                    <source media="(max-width: 767px)" srcset="<?= htmlspecialchars($mobileImage) ?>">
                                    <source media="(min-width: 768px)" srcset="<?= htmlspecialchars($desktopImage) ?>">
                                    <img src="<?= htmlspecialchars($desktopImage) ?>" alt="<?= htmlspecialchars($room['name']) ?>" loading="lazy" decoding="async">
                                </picture>
                            <?php else: ?>
                                <img src="<?= htmlspecialchars($desktopImage) ?>" alt="<?= htmlspecialchars($room['name']) ?>" loading="lazy" decoding="async">
                            <?php endif; ?>
                        </div>
                    <?php endif; ?>

                    <div class="room-card-copy">
                        <div class="room-top">
                            <?php if ($room['badge'] !== ''): ?>
                                <span class="room-badge"><?= htmlspecialchars($room['badge']) ?></span>
                            <?php endif; ?>
                            <span class="room-no"><?= htmlspecialchars($room['no']) ?></span>
                        </div>

                        <h3><?= htmlspecialchars($room['name']) ?></h3>

                        <?php if ($room['description'] !== ''): ?>
                            <p><?= htmlspecialchars($room['description']) ?></p>
                        <?php endif; ?>

                        <div class="room-foot">
                            <?php if ($room['tag'] !== ''): ?>
                                <span class="room-tag"><?= htmlspecialchars($room['tag']) ?></span>
                            <?php endif; ?>

                            <a href="<?= htmlspecialchars($room['url']) ?>" class="room-link" aria-label="Enter <?= htmlspecialchars($room['name']) ?>">
                                <span>Enter</span>
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M4 12h13.2l-4.8-4.8L14 5.6 21.1 12 14 19.2l-1.6-1.6 4.8-4.8H4z" fill="currentColor"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

