<?php
/**
 * Twenty Nine Tempest - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: 联系方式和联系表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Get in Touch
 * hero.subtitle => 页面副标题:textarea:Need help with 29 Card tables, account access, or payout questions? Use the contact routes below to reach the right desk quickly.
 * hero.bg_color => 背景色:color:#0b1830
 * hero.bg_gradient_end => 渐变结束色:color:#09111d
 * hero.title_color => 标题颜色:color:#eef7ff
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@twentyninetempest.com
 * contact_info.work_hours_label => 工作时间标签:text:Hours
 * contact_info.work_hours => 工作时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook:text:
 * social.twitter => Twitter:text:
 * social.linkedin => LinkedIn:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send us a Message
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share the table, account, or payout context so the support team can route your request faster.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Location Window
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$colors = isset($colors) && is_array($colors) ? $colors : [];
$componentId = 'tnt-contact-' . uniqid();

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

if ($normalizeToggle($getConfigAny(['display.display.show_section', 'display.show_section', 'contact.display'], 'yes')) === 'no') {
    return;
}

$showMap = $normalizeToggle($getConfigAny(['display.display.show_map', 'display.show_map'], 'yes')) !== 'no';
$showForm = $normalizeToggle($getConfigAny(['display.display.show_form', 'display.show_form'], 'yes')) !== 'no';
$showSocial = $normalizeToggle($getConfigAny(['display.display.show_social', 'display.show_social'], 'yes')) !== 'no';
$showInfo = $normalizeToggle($getConfigAny(['display.display.show_info', 'display.show_info'], 'yes')) !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageMeta = $page ? trim((string) ($page->getData('meta_description') ?? '')) : '';
$pageContent = $page ? (string) ($page->getData('content') ?? '') : '';

$title = trim((string) $getConfigAny(['hero.hero.title', 'hero.title'], $pageTitle));
if ($title === '') {
    $title = 'Get in Touch';
}
$description = trim((string) $getConfigAny(['hero.hero.subtitle', 'hero.subtitle'], $pageMeta !== '' ? $pageMeta : 'Need help with 29 Card tables, account access, or payout questions? Use the contact routes below to reach the right desk quickly.'));
$heroBg = (string) $getConfigAny(['hero.hero.bg_color', 'hero.bg_color'], $colors['hero_bg'] ?? '#0b1830');
$heroBgEnd = (string) $getConfigAny(['hero.hero.bg_gradient_end', 'hero.bg_gradient_end'], $colors['hero_bg_gradient_end'] ?? '#09111d');
$heroTitleColor = (string) $getConfigAny(['hero.hero.title_color', 'hero.title_color'], $colors['heading_color'] ?? '#eef7ff');

$addressLabel = trim((string) $getConfigAny(['contact_info.contact_info.address_label', 'contact_info.address_label'], 'Address'));
$address = trim((string) $getConfigAny(['contact_info.contact_info.address', 'contact_info.address'], 'Mumbai, India'));
$phoneLabel = trim((string) $getConfigAny(['contact_info.contact_info.phone_label', 'contact_info.phone_label'], 'Phone'));
$phone = trim((string) $getConfigAny(['contact_info.contact_info.phone', 'contact_info.phone'], '+91 1800-XXX-XXXX'));
$emailLabel = trim((string) $getConfigAny(['contact_info.contact_info.email_label', 'contact_info.email_label'], 'Email'));
$email = trim((string) $getConfigAny(['contact_info.contact_info.email', 'contact_info.email'], 'support@twentyninetempest.com'));
$workHoursLabel = trim((string) $getConfigAny(['contact_info.contact_info.work_hours_label', 'contact_info.work_hours_label'], 'Hours'));
$workHours = trim((string) $getConfigAny(['contact_info.contact_info.work_hours', 'contact_info.work_hours'], '24/7 Customer Support'));

$formTitle = trim((string) $getConfigAny(['form.form.title', 'form.title'], 'Send us a Message'));
$formNameLabel = trim((string) $getConfigAny(['form.form.name_label', 'form.name_label'], 'Full Name'));
$formEmailLabel = trim((string) $getConfigAny(['form.form.email_label', 'form.email_label'], 'Email Address'));
$formSubjectLabel = trim((string) $getConfigAny(['form.form.subject_label', 'form.subject_label'], 'Subject'));
$formMessageLabel = trim((string) $getConfigAny(['form.form.message_label', 'form.message_label'], 'Message'));
$formSubmitText = trim((string) $getConfigAny(['form.form.submit_text', 'form.submit_text'], 'Send Message'));
$formSuccessMessage = trim((string) $getConfigAny(['form.form.success_message', 'form.success_message'], 'Share the table, account, or payout context so the support team can route your request faster.'));
$mapTitle = trim((string) $getConfigAny(['map.map.title', 'map.title'], 'Location Window'));
$mapEmbedUrl = trim((string) $getConfigAny(['map.map.embed_url', 'map.embed_url'], ''));
$mapHeight = max(240, (int) $getConfigAny(['map.map.height', 'map.height'], '360'));

$channels = [];
$routeSeed = [
    ['label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address, 'href' => ''],
    ['label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone, 'href' => $phone !== '' ? 'tel:' . preg_replace('/[^0-9+]/', '', $phone) : ''],
    ['label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email, 'href' => $email !== '' ? 'mailto:' . $email : ''],
    ['label' => $workHoursLabel !== '' ? $workHoursLabel : 'Hours', 'value' => $workHours, 'href' => ''],
];
foreach ($routeSeed as $route) {
    if (trim((string) $route['value']) === '') {
        continue;
    }
    $route['icon'] = strtoupper(substr(preg_replace('/[^A-Za-z0-9]/', '', (string) $route['label']) ?: 'CT', 0, 2));
    $channels[] = $route;
}
$channelLead = $channels[0] ?? null;
$channelTrail = array_slice($channels, 1);

$getInitials = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return 'NA';
    }
    $parts = preg_split('/\s+/', $value) ?: [];
    $initials = '';
    foreach ($parts as $part) {
        if ($part === '') {
            continue;
        }
        if (function_exists('mb_substr') && function_exists('mb_strtoupper')) {
            $initials .= mb_strtoupper(mb_substr($part, 0, 1));
        } else {
            $initials .= strtoupper(substr($part, 0, 1));
        }
        if (strlen($initials) >= 2) {
            break;
        }
    }
    return $initials !== '' ? $initials : 'NA';
};

$socialSeed = [
    'WeChat' => trim((string) $getConfigAny(['social.social.wechat', 'social.wechat'], '')),
    'Weibo' => trim((string) $getConfigAny(['social.social.weibo', 'social.weibo'], '')),
    'Facebook' => trim((string) $getConfigAny(['social.social.facebook', 'social.facebook'], '')),
    'Twitter' => trim((string) $getConfigAny(['social.social.twitter', 'social.twitter'], '')),
    'LinkedIn' => trim((string) $getConfigAny(['social.social.linkedin', 'social.linkedin'], '')),
];
$socials = [];
foreach ($socialSeed as $label => $value) {
    if ($value === '') {
        continue;
    }
    $socials[] = [
        'label' => $label,
        'value' => $value,
        'href' => preg_match('/^https?:\/\//i', $value) ? $value : '',
        'mark' => $getInitials($label),
    ];
}

$textSecondary = $colors['text_secondary'] ?? '#c7d9ea';
$textMuted = $colors['text_muted'] ?? '#8ca3bc';
$textDark = $colors['text_primary'] ?? '#0f2034';
$surfaceLight = $colors['card_bg'] ?? 'rgba(255,255,255,0.94)';
$surfaceDark = 'rgba(9, 23, 40, 0.78)';
$borderLight = $colors['border_light'] ?? 'rgba(255,255,255,0.08)';
$accentPrimary = $colors['accent_primary'] ?? '#ffd45d';
$accentSecondary = $colors['accent_secondary'] ?? '#18f0ff';
$buttonBg = $colors['button_primary_bg'] ?? '#ffd45d';
$buttonText = $colors['button_primary_text'] ?? '#08131f';
?>
<section id="<?= $componentId ?>" class="tnt-contact-page" aria-labelledby="<?= $componentId ?>-title" style="--contact-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --contact-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --contact-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --contact-text-secondary: <?= htmlspecialchars($textSecondary, ENT_QUOTES, 'UTF-8') ?>; --contact-text-muted: <?= htmlspecialchars($textMuted, ENT_QUOTES, 'UTF-8') ?>; --contact-text-dark: <?= htmlspecialchars($textDark, ENT_QUOTES, 'UTF-8') ?>; --contact-surface-light: <?= htmlspecialchars($surfaceLight, ENT_QUOTES, 'UTF-8') ?>; --contact-surface-dark: <?= htmlspecialchars($surfaceDark, ENT_QUOTES, 'UTF-8') ?>; --contact-border: <?= htmlspecialchars($borderLight, ENT_QUOTES, 'UTF-8') ?>; --contact-accent-primary: <?= htmlspecialchars($accentPrimary, ENT_QUOTES, 'UTF-8') ?>; --contact-accent-secondary: <?= htmlspecialchars($accentSecondary, ENT_QUOTES, 'UTF-8') ?>; --contact-button-bg: <?= htmlspecialchars($buttonBg, ENT_QUOTES, 'UTF-8') ?>; --contact-button-text: <?= htmlspecialchars($buttonText, ENT_QUOTES, 'UTF-8') ?>;">
    <div class="contact-shell">
        <header class="contact-hero">
            <div class="hero-copy">
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h1>
                <?php if ($description !== ''): ?>
                    <p><?= htmlspecialchars($description, ENT_QUOTES, 'UTF-8') ?></p>
                <?php endif; ?>
            </div>
            <?php if ($showInfo && !empty($channels)): ?>
                <div class="hero-routes" aria-label="Contact routes">
                    <?php foreach ($channels as $index => $channel): ?>
                        <article class="route-pill route-pill-<?= (int) ($index + 1) ?>">
                            <span><?= htmlspecialchars($channel['label'], ENT_QUOTES, 'UTF-8') ?></span>
                            <strong><?= htmlspecialchars($channel['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                        </article>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="contact-layout<?= !$showInfo ? ' no-info' : '' ?><?= !$showForm ? ' no-form' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="contact-board">
                    <?php if (!empty($channels)): ?>
                        <div class="channel-grid">
                            <?php if ($channelLead !== null): ?>
                                <?php if ($channelLead['href'] !== ''): ?>
                                    <a class="channel-lead" href="<?= htmlspecialchars($channelLead['href'], ENT_QUOTES, 'UTF-8') ?>">
                                        <span class="channel-lead-mark"><?= htmlspecialchars($channelLead['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                                        <span class="channel-lead-copy">
                                            <span class="channel-label"><?= htmlspecialchars($channelLead['label'], ENT_QUOTES, 'UTF-8') ?></span>
                                            <strong><?= htmlspecialchars($channelLead['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                                        </span>
                                    </a>
                                <?php else: ?>
                                    <div class="channel-lead">
                                        <span class="channel-lead-mark"><?= htmlspecialchars($channelLead['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                                        <span class="channel-lead-copy">
                                            <span class="channel-label"><?= htmlspecialchars($channelLead['label'], ENT_QUOTES, 'UTF-8') ?></span>
                                            <strong><?= htmlspecialchars($channelLead['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                                        </span>
                                    </div>
                                <?php endif; ?>
                            <?php endif; ?>

                            <?php if (!empty($channelTrail)): ?>
                                <div class="channel-trail">
                                    <?php foreach ($channelTrail as $channel): ?>
                                        <?php if ($channel['href'] !== ''): ?>
                                            <a class="channel-card channel-card-compact" href="<?= htmlspecialchars($channel['href'], ENT_QUOTES, 'UTF-8') ?>">
                                                <span class="channel-icon"><?= htmlspecialchars($channel['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                                                <span class="channel-copy">
                                                    <span class="channel-label"><?= htmlspecialchars($channel['label'], ENT_QUOTES, 'UTF-8') ?></span>
                                                    <strong><?= htmlspecialchars($channel['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                                                </span>
                                            </a>
                                        <?php else: ?>
                                            <div class="channel-card channel-card-compact">
                                                <span class="channel-icon"><?= htmlspecialchars($channel['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                                                <span class="channel-copy">
                                                    <span class="channel-label"><?= htmlspecialchars($channel['label'], ENT_QUOTES, 'UTF-8') ?></span>
                                                    <strong><?= htmlspecialchars($channel['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                                                </span>
                                            </div>
                                        <?php endif; ?>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    <?php endif; ?>

                    <?php if ($showSocial && !empty($socials)): ?>
                        <div class="social-dock">
                            <div class="social-grid">
                                <?php foreach ($socials as $social): ?>
                                    <?php if ($social['href'] !== ''): ?>
                                        <a href="<?= htmlspecialchars($social['href'], ENT_QUOTES, 'UTF-8') ?>" class="social-link" target="_blank" rel="noopener">
                                            <span class="social-mark"><?= htmlspecialchars($social['mark'], ENT_QUOTES, 'UTF-8') ?></span>
                                            <span class="social-copy">
                                                <strong><?= htmlspecialchars($social['label'], ENT_QUOTES, 'UTF-8') ?></strong>
                                                <small><?= htmlspecialchars($social['value'], ENT_QUOTES, 'UTF-8') ?></small>
                                            </span>
                                        </a>
                                    <?php else: ?>
                                        <div class="social-link">
                                            <span class="social-mark"><?= htmlspecialchars($social['mark'], ENT_QUOTES, 'UTF-8') ?></span>
                                            <span class="social-copy">
                                                <strong><?= htmlspecialchars($social['label'], ENT_QUOTES, 'UTF-8') ?></strong>
                                                <small><?= htmlspecialchars($social['value'], ENT_QUOTES, 'UTF-8') ?></small>
                                            </span>
                                        </div>
                                    <?php endif; ?>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php endif; ?>

                    <?php if (trim($pageContent) !== ''): ?>
                        <div class="contact-prose"><?= $pageContent ?></div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <section class="message-console" aria-labelledby="<?= $componentId ?>-form-title">
                    <div class="console-head">
                        <h2 id="<?= $componentId ?>-form-title"><?= htmlspecialchars($formTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage, ENT_QUOTES, 'UTF-8') ?></p>
                        <?php endif; ?>
                    </div>

                    <form class="contact-form">
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formNameLabel, ENT_QUOTES, 'UTF-8') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formNameLabel, ENT_QUOTES, 'UTF-8') ?>">
                        </div>
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formEmailLabel, ENT_QUOTES, 'UTF-8') ?></label>
                            <input type="email" placeholder="<?= htmlspecialchars($formEmailLabel, ENT_QUOTES, 'UTF-8') ?>">
                        </div>
                        <div class="field field-full">
                            <label><?= htmlspecialchars($formSubjectLabel, ENT_QUOTES, 'UTF-8') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formSubjectLabel, ENT_QUOTES, 'UTF-8') ?>">
                        </div>
                        <div class="field field-full">
                            <label><?= htmlspecialchars($formMessageLabel, ENT_QUOTES, 'UTF-8') ?></label>
                            <textarea placeholder="<?= htmlspecialchars($formMessageLabel, ENT_QUOTES, 'UTF-8') ?>"></textarea>
                        </div>
                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText, ENT_QUOTES, 'UTF-8') ?></button>
                    </form>
                </section>
            <?php endif; ?>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="map-stage" aria-labelledby="<?= $componentId ?>-map-title">
                <div class="map-head">
                    <h2 id="<?= $componentId ?>-map-title"><?= htmlspecialchars($mapTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                    <?php if ($address !== ''): ?>
                        <p><?= htmlspecialchars($address, ENT_QUOTES, 'UTF-8') ?></p>
                    <?php endif; ?>
                </div>
                <div class="map-frame">
                    <iframe src="<?= htmlspecialchars($mapEmbedUrl, ENT_QUOTES, 'UTF-8') ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int) $mapHeight ?>px;"></iframe>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>
<style>
