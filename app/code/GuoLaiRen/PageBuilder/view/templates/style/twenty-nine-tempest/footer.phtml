<?php
/**
 * Twenty Nine Tempest - Footer
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.background_color => 背景基础色:color:#0a1527
 * style.text_color => 文字颜色:color:#9ebdda
 * style.link_color => 链接颜色:color:#e8f3ff
 * style.link_hover_color => 链接悬停颜色:color:#7be6ff
 * style.border_top => 显示顶部边框:select:no|yes,no
 * style.border_color => 边框颜色:color:#1d3654
 *
 * group:layout => 布局设置
 * layout.max_width => 最大宽度:number:1240
 * layout.padding_horizontal => 左右内边距:responsive:16/20|px
 * layout.padding_vertical => 上下内边距:responsive:34/48|px
 *
 * group:footer => 页脚品牌设置
 * footer.logo_text => 品牌名称:text:Twenty Nine Tempest
 * footer.logo_url => 品牌Logo地址:textarea:|默认使用本地tempest-logo-icon.svg
 *
 * group:content => 内容配置
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQs=>/faqs|配置格式：名字=>url，一行一个
 * content.copyright_text => 版权信息:text:© 2026 Twenty Nine Tempest. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. Real-money gameplay involves risk. Please play responsibly and stay within your limits.
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * group:typography => 排版设置
 * typography.font_size => 字体大小:responsive:12/14|px
 * typography.line_height => 行高:number:1.65
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$templateCode = $page ? $page->getData('style') : 'twenty-nine-tempest';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'twenty-nine-tempest';
}

$this->assign('template_code', $templateCode);
$this->assign('style', is_array($styleSettings) ? $styleSettings : []);
$this->assign('style_settings', is_array($styleSettings) ? $styleSettings : []);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__tnt_shell_managed', true);
$this->assign('__pagebuilder_shell_managed', true);
?>
<?= $this->fetchTemplate('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/components/footer/links.phtml') ?>
