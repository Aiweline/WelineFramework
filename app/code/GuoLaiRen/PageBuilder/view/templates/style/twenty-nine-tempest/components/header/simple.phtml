<?php
/**
 * Twenty Nine Tempest - Simple Header Component
 *
 * @component_start
 * code: header-simple
 * name: 简洁头部
 * name_en: Simple Header
 * description: Minimal roulette header with editable logo art, brand text, and responsive alignment.
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo图片URL:textarea:|留空使用默认图标
 * logo.text => Logo文字:text:Twenty Nine Tempest
 * logo.width => Logo宽度:number:44|px
 * logo.position => Logo位置:select:center|left,center,right
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#0f1017
 * style.text_color => 文字颜色:color:#f7f1e8
 * style.padding => 内边距:number:18|px
 * @fields_end
 */

$componentId = 'tnt-header-simple-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];
$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};
$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
if (!$logoDisplay) {
    return;
}
$logoText = trim((string) $getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name'], 'Twenty Nine Tempest'));
if ($logoText === '') {
    $logoText = 'Twenty Nine Tempest';
}
$defaultLogo = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/tempest-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $defaultLogo);
$logoWidth = max(28, (int) $getConfig('logo.width', '44'));
$bgColor = (string) $getConfig('style.bg_color', $colors['nav_bg'] ?? '#0f1017');
$textColor = (string) $getConfig('style.text_color', $colors['nav_text'] ?? '#f7f1e8');
$padding = max(10, (int) $getConfig('style.padding', '18'));
$align = (string) $getConfigAny(['logo.position', 'style.align'], 'center');
$justifyMap = ['left' => 'flex-start', 'center' => 'center', 'right' => 'flex-end'];
$justify = $justifyMap[$align] ?? 'center';
?>
<header id="<?= $componentId ?>" class="tnt-header-simple" aria-label="Simple header">
    <div class="simple-shell">
        <a class="simple-brand" href="/" aria-label="<?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?> home">
            <span class="simple-orbit" aria-hidden="true"></span>
            <img src="<?= htmlspecialchars($logoUrl, ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?>" loading="lazy" decoding="async">
            <span><?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?></span>
        </a>
    </div>
</header>
<style>
#<?= $componentId ?> {
    width: 100%;
    background: <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    padding: <?= (int) $padding ?>px 0;
}
#<?= $componentId ?>,
#<?= $componentId ?> * {
    box-sizing: border-box;
}
#<?= $componentId ?> .simple-shell {
    width: min(1280px, calc(100% - 1.4rem));
    margin: 0 auto;
    display: flex;
    justify-content: <?= htmlspecialchars($justify, ENT_QUOTES, 'UTF-8') ?>;
}
#<?= $componentId ?> .simple-brand {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    text-decoration: none;
    color: <?= htmlspecialchars($textColor, ENT_QUOTES, 'UTF-8') ?>;
    font-family: 'Syne', 'Manrope', sans-serif;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
#<?= $componentId ?> .simple-brand img {
    width: <?= (int) $logoWidth ?>px;
    height: <?= (int) $logoWidth ?>px;
    position: relative;
    z-index: 1;
}
#<?= $componentId ?> .simple-brand span:last-child {
    position: relative;
    z-index: 1;
    font-size: clamp(0.82rem, 2vw, 0.96rem);
}
#<?= $componentId ?> .simple-orbit {
    position: absolute;
    left: <?= max(8, (int) round($logoWidth * 0.36)) ?>px;
    top: 50%;
    width: <?= max(44, (int) round($logoWidth * 1.8)) ?>px;
    height: <?= max(44, (int) round($logoWidth * 1.8)) ?>px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.02) 48%, transparent 76%);
}
@media (max-width: 767px) {
    #<?= $componentId ?> .simple-shell {
        width: calc(100% - 1rem);
    }
    #<?= $componentId ?> .simple-brand {
        gap: 0.58rem;
        letter-spacing: 0.06em;
    }
}
</style>
