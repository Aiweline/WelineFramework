}

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';

$bgColor = (string) $getConfig('style.background_color', '#0a1527');
$textColor = (string) $getConfig('style.text_color', '#9ebdda');
$linkColor = (string) $getConfig('style.link_color', '#e8f3ff');
$linkHoverColor = (string) $getConfig('style.link_hover_color', '#7be6ff');
$linkFontSize = (int) $getConfig('style.link_font_size', '15');
$linkFontWeight = (int) $getConfig('style.link_font_weight', '700');
$linkGap = (int) $getConfig('style.link_gap', '10');
$borderTop = $normalizeToggle($getConfig('style.border_top', 'no'), 'no') === 'yes';
$borderColor = (string) $getConfig('style.border_color', '#1d3654');
$borderWidth = (int) $getConfig('style.border_width', '1');
$sectionPadding = (int) $getConfig('style.section_padding', '48');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '34');
$separatorDisplay = $normalizeToggle($getConfig('style.separator_display', 'yes'), 'yes') === 'yes';
$separatorChar = trim((string) $getConfig('style.separator_char', '·'));
if ($separatorChar === '') {
    $separatorChar = '·';
}
$separatorColor = (string) $getConfig('style.separator_color', '#587490');
$maxWidth = (int) $getConfig('layout.max_width', '1240');
$paddingHorizontal = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_horizontal', '16/20') . 'px'));
$paddingVerticalConfig = trim((string) $getConfig('layout.padding_vertical', ''));
$paddingVertical = $paddingVerticalConfig !== ''
    ? $genResponsiveCSS($parseResponsive($paddingVerticalConfig . 'px'))
    : $genResponsiveCSS($parseResponsive($sectionPaddingMobile . '/' . $sectionPadding . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float) $getConfig('typography.line_height', '1.65');
$disclaimerBgColor = (string) $getConfig('disclaimer.bg_color', '#0e1d33');
$disclaimerBorderRadius = (int) $getConfig('disclaimer.border_radius', '20');
$disclaimerPadding = (int) $getConfig('disclaimer.padding', '16');
$disclaimerFontSize = (int) $getConfig('disclaimer.font_size', '14');
$disclaimerTextColor = (string) $getConfig('disclaimer.text_color', '#d5e4f7');
$copyrightFontSize = (int) $getConfig('copyright.font_size', '14');
$copyrightTextColor = (string) $getConfig('copyright.text_color', '#89a6c2');
$copyrightMarginTop = (int) $getConfig('copyright.margin_top', '8');

$logoText = trim((string) $getConfigAny(['footer.logo_text', 'footer.logo.text', 'logo.text', 'app_info.app_name', 'texts.app_name'], 'Twenty Nine Tempest'));
if ($logoText === '' && $page) {
    $logoText = trim((string) ($page->getData('title') ?: ''));
}
if ($logoText === '') {
    $logoText = 'Twenty Nine Tempest';
}
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/tempest-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['footer.logo_url', 'footer.logo.url', 'logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $defaultLogoUrl);
$copyright = (string) $getConfigAny(['content.copyright_text', 'footer.copyright'], '© 2026 Twenty Nine Tempest. All rights reserved.');
$disclaimerText = (string) $getConfigAny(['content.disclaimer_text', 'footer.disclaimer_text'], '18+ Only. Real-money gameplay involves risk. Please play responsibly and stay within your limits.');

$downloadDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$downloadText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Play Now'));
$downloadUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download'));
$downloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $downloadUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadHref, 'url');
$downloadIcon = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/floating-download-badge.svg');

$links = [];
$useCustomLinksRaw = trim((string) $getConfig('content.use_custom_links', ''));
$legacyUseSubpagesRaw = trim((string) $getConfig('content.use_subpages', ''));
if ($useCustomLinksRaw !== '') {
    $useCustomLinks = $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes';
} elseif ($legacyUseSubpagesRaw !== '') {
    $useCustomLinks = $normalizeToggle($legacyUseSubpagesRaw, 'no') !== 'yes';
} else {
    $useCustomLinks = true;
}

if (!$useCustomLinks && $page) {
    $footerPages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $footerPages = $page->getHeaderNavigationPages(30);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $footerPages = $page->getNavigationPages([], 30);
    }

    foreach ($footerPages as $footerPage) {
        $text = trim((string) ($footerPage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = trim((string) ($footerPage['type'] ?? ''));
        $configuredLabel = $type !== '' ? trim((string) $getConfig('content.footer_label_' . $type, '')) : '';
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => (string) ($footerPage['url'] ?? '#'),
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny(['content.footer_links', 'footer.links'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }
    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }
    foreach ($items as $item) {
        $item = trim((string) $item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            $parts = [$item, '#'];
        }
        if (($parts[0] ?? '') === '') {
            continue;
        }
        $links[] = [
            'text' => $parts[0],
            'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#',
        ];
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}
