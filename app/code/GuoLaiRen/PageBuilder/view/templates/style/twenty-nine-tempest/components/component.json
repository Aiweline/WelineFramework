{
  "$schema": "2.1.0",
  "template": "twenty-nine-tempest",
  "name": "Twenty Nine Tempest",
  "description": "High-contrast responsive 29 Card Game theme with modern motion accents and tpmst-compatible editor behavior.",
  "version": "1.0.0",
  "regions": {
    "header": {
      "name": "Header Region",
      "name_en": "Header",
      "description": "Top area including logo and navigation",
      "multiple": false,
      "required": true,
      "accepts": ["header"],
      "default_component": "header-nav",
      "supports_slot_nesting": true
    },
    "content": {
      "name": "Content Region",
      "name_en": "Content",
      "description": "Main page content area",
      "multiple": true,
      "required": false,
      "accepts": ["content", "widget"],
      "default_components": ["hero-slider", "advantages", "games-showcase", "testimonials", "faq"],
      "supports_slot_nesting": true
    },
    "footer": {
      "name": "Footer Region",
      "name_en": "Footer",
      "description": "Bottom area including links and legal notes",
      "multiple": false,
      "required": true,
      "accepts": ["footer"],
      "default_component": "footer-links",
      "supports_slot_nesting": true
    }
  },
  "components": {
    "header-nav": {
      "name": "Header Navigation",
      "name_en": "Header Navigation",
      "description": "Sticky responsive navigation with editor-safe download and page-link settings",
      "region": "header",
      "category": "header",
      "type": "section",
      "sort_order": 1,
      "is_default": true,
      "compatible_styles": ["*"],
      "placeable_in": ["header"],
      "config_groups": ["logo", "navigation", "download_button"],
      "file": "header/nav.phtml"
    },
    "header-simple": {
      "name": "Header Simple",
      "name_en": "Header Simple",
      "description": "Simple header variant",
      "region": "header",
      "category": "header",
      "type": "section",
      "sort_order": 2,
      "compatible_styles": ["*"],
      "placeable_in": ["header"],
      "config_groups": ["logo"],
      "file": "header/simple.phtml"
    },
    "header-dark": {
      "name": "Header Dark",
      "name_en": "Header Dark",
      "description": "Dark header variant",
      "region": "header",
      "category": "header",
      "type": "section",
      "sort_order": 3,
      "compatible_styles": ["*"],
      "placeable_in": ["header"],
      "config_groups": ["logo"],
      "file": "header/dark.phtml"
    },
    "hero-slider": {
      "name": "Hero Section",
      "name_en": "Hero Section",
      "description": "Command-board hero with banner and download fallbacks",
      "region": "content",
      "category": "content",
      "type": "section",
      "sort_order": 10,
      "is_default": true,
      "compatible_styles": ["*"],
      "placeable_in": ["content"],
      "config_groups": ["hero", "banner", "download_btn", "layout"],
      "file": "content/hero-slider.phtml"
    },
    "advantages": {
      "name": "Advantages",
      "name_en": "Advantages",
      "description": "Feature highlights with editable cards and summary copy",
      "region": "content",
      "category": "content",
      "type": "section",
      "sort_order": 20,
      "is_default": true,
      "compatible_styles": ["*"],
      "placeable_in": ["content"],
      "config_groups": ["display", "style", "texts", "button", "icons"],
      "file": "content/advantages.phtml"
    },
    "games-showcase": {
      "name": "Games Showcase",
      "name_en": "Games Showcase",
      "description": "Dynamic room showcase with separated card fields",
      "region": "content",
      "category": "content",
      "type": "section",
