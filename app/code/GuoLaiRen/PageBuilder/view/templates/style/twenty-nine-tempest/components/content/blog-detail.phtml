                    </svg>
                </div>
                <h2><?= __('Article Not Found') ?></h2>
                <p><?= __('The article you are looking for does not exist or has been removed.') ?></p>
                <a href="/blog" class="back-home"><?= __('Back to Blog') ?></a>
            </div>
        </div>
    </section>
<?php else: ?>
    <section id="<?= $componentId ?>" class="tnt-blog-detail">
        <div class="detail-shell">
            <nav class="detail-breadcrumb">
                <a href="/"><?= __('Home') ?></a>
                <span>/</span>
                <a href="/blog"><?= __('Blog') ?></a>
                <span>/</span>
                <strong><?= htmlspecialchars(function_exists('mb_substr') ? mb_substr($currentPost['title'], 0, 42) : substr($currentPost['title'], 0, 42)) ?><?= (function_exists('mb_strlen') ? mb_strlen($currentPost['title']) : strlen($currentPost['title'])) > 42 ? '...' : '' ?></strong>
            </nav>

            <header class="article-hero">
                <div class="hero-copy">
                    <?php if (!empty($currentPost['category_name'])): ?>
                        <span class="hero-chip"><?= htmlspecialchars($currentPost['category_name']) ?></span>
                    <?php endif; ?>

                    <h1><?= htmlspecialchars($currentPost['title']) ?></h1>

                    <div class="hero-meta">
                        <?php if ($showDate && !empty($currentPost['published_at'])): ?>
                            <span><?= date('F d, Y', strtotime($currentPost['published_at'])) ?></span>
                        <?php endif; ?>
                        <?php if ($showAuthor && !empty($currentPost['author'])): ?>
                            <span><?= htmlspecialchars($currentPost['author']) ?></span>
                        <?php endif; ?>
                        <?php if (!empty($currentPost['view_count'])): ?>
                            <span><?= number_format($currentPost['view_count']) ?> <?= __('views') ?></span>
                        <?php endif; ?>
                    </div>

                    <?php if (!empty($currentPost['summary'])): ?>
                        <p class="hero-summary"><?= htmlspecialchars($currentPost['summary']) ?></p>
                    <?php endif; ?>
                </div>

                <?php if ($showCover && !empty($currentPost['cover_image'])): ?>
                    <div class="hero-cover">
                        <img src="<?= htmlspecialchars($currentPost['cover_image']) ?>" alt="<?= htmlspecialchars($currentPost['title']) ?>">
                    </div>
                <?php endif; ?>
            </header>

            <div class="detail-layout<?= $hasRail ? ' has-rail' : '' ?>">
                <?php if ($hasRail): ?>
                    <aside class="reader-rail">
                        <?php if (!empty($jumpLinks)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Jump Within</span>
                                <div class="jump-links">
                                    <?php foreach ($jumpLinks as $index => $item): ?>
                                        <a href="#<?= htmlspecialchars($item['id']) ?>" class="jump-link level-<?= (int) $item['level'] ?>">
                                            <small>0<?= (int) ($index + 1) ?></small>
                                            <span><?= htmlspecialchars($item['label']) ?></span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showTags && !empty($tags)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Tags</span>
                                <div class="tag-list">
                                    <?php foreach ($tags as $tag): ?>
                                        <a href="/blog/tag/<?= urlencode($tag) ?>" class="tag-chip">#<?= htmlspecialchars($tag) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showShare): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Share</span>
                                <div class="share-row">
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=<?= $shareUrl ?>" target="_blank" rel="noopener" class="share-btn" title="Share on Facebook">FB</a>
                                    <a href="https://twitter.com/intent/tweet?url=<?= $shareUrl ?>&text=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="Share on X">X</a>
                                    <a href="https://www.linkedin.com/shareArticle?mini=true&url=<?= $shareUrl ?>&title=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="Share on LinkedIn">IN</a>
                                    <button type="button" class="share-btn" title="Copy Link" onclick="copyToClipboard('<?= $componentId ?>')">CP</button>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showSidebar && !empty($blogCategories)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Categories</span>
                                <div class="category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-entry"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showSidebar && !empty($recentPosts)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Recent Posts</span>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 4) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>

                <article class="reading-stage">
                    <div class="article-card">
                        <div class="article-content">
                            <?= $articleContent ?>
                        </div>

                        <div class="article-navigation">
