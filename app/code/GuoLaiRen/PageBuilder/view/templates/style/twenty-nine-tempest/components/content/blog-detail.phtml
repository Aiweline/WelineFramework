<?php
/**
 * Twenty Nine Tempest Blog Detail Component
 *
 * @fields_start
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_cover|显示封面图|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_tags|显示标签|select:yes=是,no=否|yes
 * blog.show_share|显示分享按钮|select:yes=是,no=否|yes
 * blog.show_related|显示相关文章|select:yes=是,no=否|yes
 * blog.related_count|相关文章数量|number|3
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$currentPost = $this->getData('current_post') ?: [];
$relatedPosts = $this->getData('related_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$componentId = 'tnt-blog-detail-' . uniqid();

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCover = $getConfig('blog.show_cover', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showTags = $getConfig('blog.show_tags', 'yes') === 'yes';
$showShare = $getConfig('blog.show_share', 'yes') === 'yes';
$showRelated = $getConfig('blog.show_related', 'yes') === 'yes';
$relatedCount = (int) $getConfig('blog.related_count', 3);
if ($relatedCount <= 0) {
    $relatedCount = 3;
}

$primaryColor = $getConfig('color_scheme.primary', '#1eb980');
$secondaryColor = $getConfig('color_scheme.secondary', '#f2a93b');
$bgColor = $getConfig('color_scheme.background', '#0b1525');
$textColor = $getConfig('color_scheme.text', '#f8fafc');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/twenty-nine-tempest/asset/img/poker-header-bg.svg');

$tags = [];
if (!empty($currentPost['tags'])) {
    $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', $currentPost['tags']);
    $tags = array_values(array_filter(array_map('trim', $tags), static function ($item) {
        return $item !== '';
    }));
}

$articleContent = (string) ($currentPost['content'] ?? '');
$jumpLinks = [];
if ($articleContent !== '') {
    $headingIndex = 0;
    $articleContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$jumpLinks, &$headingIndex) {
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'article-section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $jumpLinks[] = [
            'id' => $id,
            'label' => $text,
            'level' => (int) $matches[1],
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $articleContent);
}

$hasRail = $showSidebar || ($showShare && !empty($currentPost)) || ($showTags && !empty($tags)) || !empty($jumpLinks);
$shareUrl = urlencode(\w_env_request_uri());
$shareTitle = urlencode((string) ($currentPost['title'] ?? ''));
?>

<?php if (empty($currentPost)): ?>
    <section id="<?= $componentId ?>" class="tnt-blog-detail">
        <div class="detail-shell">
            <div class="detail-empty">
                <div class="empty-icon">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
