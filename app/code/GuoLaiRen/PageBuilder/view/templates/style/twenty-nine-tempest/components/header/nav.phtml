<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    const toggle = root.querySelector('.nav-toggle');
    const panel = root.querySelector('.mobile-panel');
    const desktopMq = window.matchMedia('(min-width: 961px)');

    const closePanel = () => {
        if (!toggle || !panel) {
            return;
        }
        toggle.setAttribute('aria-expanded', 'false');
        panel.setAttribute('aria-hidden', 'true');
        root.dataset.mobileOpen = 'false';
    };

    const openPanel = () => {
        if (!toggle || !panel) {
            return;
        }
        toggle.setAttribute('aria-expanded', 'true');
        panel.setAttribute('aria-hidden', 'false');
        root.dataset.mobileOpen = 'true';
    };

    const syncScroll = () => {
        root.dataset.scrolled = window.scrollY > 10 ? 'true' : 'false';
    };

    syncScroll();
    window.addEventListener('scroll', syncScroll, { passive: true });

    if (toggle && panel) {
        toggle.addEventListener('click', () => {
            const isOpen = toggle.getAttribute('aria-expanded') === 'true';
            if (isOpen) {
                closePanel();
            } else {
                openPanel();
            }
        });

        panel.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', closePanel);
        });

        document.addEventListener('click', (event) => {
            if (root.dataset.mobileOpen === 'true' && !root.contains(event.target)) {
                closePanel();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                closePanel();
            }
        });

        const syncDesktop = (event) => {
            if (event.matches) {
                closePanel();
            }
        };

        if (desktopMq.addEventListener) {
            desktopMq.addEventListener('change', syncDesktop);
        } else if (desktopMq.addListener) {
            desktopMq.addListener(syncDesktop);
        }
    }
})();
</script>

