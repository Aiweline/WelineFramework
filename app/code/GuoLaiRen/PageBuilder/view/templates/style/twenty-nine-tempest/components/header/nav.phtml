$downloadBtnPaddingX = (int) $getConfig('download_button.padding_x', '18');
$downloadBtnPaddingY = (int) $getConfig('download_button.padding_y', '11');

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $navigationPages = $page->getHeaderNavigationPages(10);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $navigationPages = $page->getNavigationPages([], 10);
    }

    foreach ($navigationPages as $navPage) {
        $title = trim((string) ($navPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }
        $type = trim((string) ($navPage['type'] ?? ''));
        $configuredLabel = $type !== '' ? trim((string) $getConfigAny([
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], '')) : '';

        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $title,
            'href' => (string) ($navPage['url'] ?? '#'),
        ];
    }
}

if (empty($navItems)) {
    $navItemsConfig = (string) $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }

    foreach (preg_split('/\r?\n/', $navItemsConfig) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }

        $parts = array_map('trim', explode('=>', $line, 2));
        if (($parts[0] ?? '') === '') {
            continue;
        }

        $navItems[] = [
            'text' => $parts[0],
            'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#',
        ];
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}
