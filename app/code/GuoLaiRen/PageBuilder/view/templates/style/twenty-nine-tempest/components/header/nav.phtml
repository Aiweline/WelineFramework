    <script>
    (function () {
        if (window.__tntWowBootstrapped) {
            return;
        }
        window.__tntWowBootstrapped = true;

        var isEmbeddedFrame = function () {
            try {
                return window.top !== window.self;
            } catch (error) {
                return true;
            }
        };

        var playPreviewAnimation = function (element, fallbackDelay) {
            if (!element || element.dataset.tntPreviewAnimated === '1') {
                return;
            }

            element.dataset.tntPreviewAnimated = '1';
            element.style.visibility = 'visible';

            var effectClasses = Array.prototype.filter.call(element.classList, function (className) {
                return className.indexOf('animate__') === 0 && className !== 'animate__animated';
            });

            if (!effectClasses.length) {
                effectClasses.push('animate__fadeInUp');
            }

            element.classList.remove('animate__animated');
            effectClasses.forEach(function (className) {
                element.classList.remove(className);
            });

            void element.offsetWidth;

            effectClasses.forEach(function (className) {
                element.classList.add(className);
            });

            element.style.animationDelay = element.getAttribute('data-wow-delay') || fallbackDelay;

            var duration = element.getAttribute('data-wow-duration');
            if (duration) {
                element.style.animationDuration = duration;
            }

            requestAnimationFrame(function () {
                element.classList.add('animate__animated');
            });
        };

        var initPreviewAnimations = function (root) {
            var scope = root && root.querySelectorAll ? root : document;
            var wowElements = scope.querySelectorAll('.wow');

            wowElements.forEach(function (element, index) {
                playPreviewAnimation(element, Math.min(index * 70, 420) + 'ms');
            });
        };

        var observePreviewMutations = function () {
            if (window.__tntPreviewObserverStarted || !window.MutationObserver || !document.body) {
                return;
            }

            window.__tntPreviewObserverStarted = true;

            var observer = new MutationObserver(function (mutations) {
                mutations.forEach(function (mutation) {
                    mutation.addedNodes.forEach(function (node) {
                        if (!node || node.nodeType !== 1) {
                            return;
                        }

                        if (node.matches && node.matches('.wow')) {
                            playPreviewAnimation(node, '0ms');
                        }

                        if (node.querySelectorAll) {
                            initPreviewAnimations(node);
                        }
                    });
                });
            });

            observer.observe(document.body, { childList: true, subtree: true });
            window.__tntPreviewObserver = observer;
        };

        var initWow = function () {
            try {
                if (isEmbeddedFrame()) {
                    document.documentElement.classList.remove('tnt-wow-ready');
                    initPreviewAnimations();
                    observePreviewMutations();
                    return;
                }

                if (!window.WOW) {
                    document.documentElement.classList.remove('tnt-wow-ready');
                    initPreviewAnimations();
                    return;
                }

                document.documentElement.classList.add('tnt-wow-ready');
                new window.WOW({
                    boxClass: 'wow',
                    animateClass: 'animate__animated',
                    offset: 24,
                    mobile: true,
                    live: true
                }).init();
            } catch (error) {
                document.documentElement.classList.remove('tnt-wow-ready');
                initPreviewAnimations();
            }
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initWow, { once: true });
        } else {
            initWow();
        }
    })();
    </script>
