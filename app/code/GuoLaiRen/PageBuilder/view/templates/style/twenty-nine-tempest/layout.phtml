        body {
            font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: radial-gradient(1200px 600px at 15% 10%, rgba(30, 185, 128, 0.18), transparent 60%),
                radial-gradient(800px 500px at 85% 20%, rgba(242, 169, 59, 0.12), transparent 55%),
