                    'cb-deep': '<?= htmlspecialchars($colors['section_bg_2'] ?? '#0f2538') ?>',
                }
            }
        }
    }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap');
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        [hidden] { display: none !important; }
        html { scroll-behavior: smooth; }
