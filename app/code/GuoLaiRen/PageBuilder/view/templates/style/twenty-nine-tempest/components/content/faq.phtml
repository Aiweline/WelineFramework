<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var items = Array.prototype.slice.call(root.querySelectorAll('.faq-item'));
    var triggers = Array.prototype.slice.call(root.querySelectorAll('.faq-trigger[data-faq-index]'));
    if (!items.length || !triggers.length) {
        return;
    }

    var syncState = function(item, active) {
        var trigger = item.querySelector('.faq-trigger');
        var answer = item.querySelector('.faq-answer');
        item.classList.toggle('is-open', active);
        if (trigger) {
            trigger.setAttribute('aria-expanded', active ? 'true' : 'false');
        }
        if (answer) {
            answer.classList.toggle('is-open', active);
            answer.setAttribute('aria-hidden', active ? 'false' : 'true');
        }
    };

    var openItem = function(index) {
        items.forEach(function(item, i) {
            syncState(item, i === index);
        });

        if (window.matchMedia && window.matchMedia('(max-width: 767px)').matches && items[index]) {
            setTimeout(function() {
                items[index].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 60);
        }
    };

    var closeAll = function() {
        items.forEach(function(item) {
            syncState(item, false);
        });
    };

    triggers.forEach(function(trigger) {
        var index = parseInt(trigger.getAttribute('data-faq-index'), 10);
        if (Number.isNaN(index)) {
            return;
        }

        trigger.addEventListener('click', function(event) {
            event.preventDefault();
            var expanded = trigger.getAttribute('aria-expanded') === 'true';
            if (expanded) {
                closeAll();
                return;
            }
            openItem(index);
        });
    });

    var initialIndex = <?= (int) $activeIndex ?>;
    if (initialIndex >= 0) {
        openItem(initialIndex);
    } else {
        closeAll();
    }
})();
</script>
