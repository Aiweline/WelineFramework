 * values.value_2_icon => 价值2图标:text:MC
 * values.value_2_title => 价值2标题:text:Mobile Clarity
 * values.value_2_desc => 价值2描述:textarea:Layouts, routes, and controls should remain readable during quick 29 Card browsing on smaller screens.
 * values.value_3_icon => 价值3图标:text:FS
 * values.value_3_title => 价值3标题:text:Fast Support
 * values.value_3_desc => 价值3描述:textarea:Account, payout, and gameplay questions should reach the right desk without extra friction.
 * values.bg_color => 背景色:color:#101d31
 *
 * group:team => 团队区块
 * team.title => 标题:text:Team Grid
 * team.subtitle => 副标题:text:The operators shaping route clarity, support speed, and product flow.
 * team.member_1_icon => 成员1图标:text:R1
 * team.member_1_name => 成员1姓名:text:John Smith
 * team.member_1_role => 成员1职位:text:Chief Executive Officer
 * team.member_2_icon => 成员2图标:text:R2
 * team.member_2_name => 成员2姓名:text:Sarah Johnson
 * team.member_2_role => 成员2职位:text:Chief Technology Officer
 * team.member_3_icon => 成员3图标:text:R3
 * team.member_3_name => 成员3姓名:text:Michael Chen
 * team.member_3_role => 成员3职位:text:Product Director
 * team.member_4_icon => 成员4图标:text:R4
 * team.member_4_name => 成员4姓名:text:Emily Wang
 * team.member_4_role => 成员4职位:text:Design Director
 *
 * group:cta => CTA区块
 * cta.title => 标题:text:Ready for the next hand?
 * cta.description => 描述:textarea:Move from overview to download and support without rebuilding the page structure later.
 * cta.button_text => 按钮文字:text:Contact Us
 * cta.button_url => 按钮链接:text:/contact
 * cta.button_bg => 按钮背景基础色:color:#ffd45d
 * cta.button_text_color => 按钮文字颜色:color:#08131f
 *
 * @fields_end
 */

$page = $this->getData('page');
$componentId = 'tnt-about-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfigAny = static function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = static function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

if ($normalizeToggle($getConfigAny(['display.display.show_section', 'display.show_section', 'about.display'], 'yes')) === 'no') {
    return;
}

$showStats = $normalizeToggle($getConfigAny(['display.display.show_stats', 'display.show_stats'], 'yes')) !== 'no';
$showValues = $normalizeToggle($getConfigAny(['display.display.show_values', 'display.show_values'], 'yes')) !== 'no';
$showTeam = $normalizeToggle($getConfigAny(['display.display.show_team', 'display.show_team'], 'yes')) !== 'no';
$showCta = $normalizeToggle($getConfigAny(['display.display.show_cta', 'display.show_cta'], 'yes')) !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageMeta = $page ? trim((string) ($page->getData('meta_description') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';

$title = trim((string) $getConfigAny(['hero.hero.title', 'hero.title'], $pageTitle));
if ($title === '') {
    $title = 'About Twenty Nine Tempest';
}
$subtitle = trim((string) $getConfigAny(['hero.hero.subtitle', 'hero.subtitle'], $pageMeta !== '' ? $pageMeta : 'Twenty Nine Tempest refines the classic trick-taking experience with clearer room reading, faster support access, and dependable mobile play.'));
$heroBg = (string) $getConfigAny(['hero.hero.bg_color', 'hero.bg_color'], $colors['hero_bg'] ?? '#0b1830');
$heroBgEnd = (string) $getConfigAny(['hero.hero.bg_gradient_end', 'hero.bg_gradient_end'], $colors['hero_bg_gradient_end'] ?? '#09111d');
$heroTitleColor = (string) $getConfigAny(['hero.hero.title_color', 'hero.title_color'], $colors['heading_color'] ?? '#eef7ff');
$heroTextColor = (string) $getConfigAny(['hero.hero.text_color', 'hero.text_color'], $colors['text_secondary'] ?? '#c7d9ea');
$heroPadding = max(48, (int) $getConfigAny(['hero.hero.padding', 'hero.padding'], '72'));

$statsNumberColor = (string) $getConfigAny(['stats.stats.number_color', 'stats.number_color'], $colors['accent_primary'] ?? '#ffd45d');
$statsLabelColor = (string) $getConfigAny(['stats.stats.label_color', 'stats.label_color'], $colors['text_muted'] ?? '#b7cadb');
$statsCardBg = (string) $getConfigAny(['stats.stats.card_bg', 'stats.card_bg'], '#0f2034');
$storyBg = (string) $getConfigAny(['story.story.bg_color', 'story.bg_color'], $colors['section_bg_1'] ?? '#0c1526');
$storyTitleColor = (string) $getConfigAny(['story.story.title_color', 'story.title_color'], $colors['heading_color'] ?? '#eef7ff');
$valuesBg = (string) $getConfigAny(['values.values.bg_color', 'values.bg_color'], $colors['section_bg_2'] ?? '#101d31');
$ctaButtonBg = (string) $getConfigAny(['cta.cta.button_bg', 'cta.button_bg'], $colors['button_primary_bg'] ?? '#ffd45d');
$ctaButtonTextColor = (string) $getConfigAny(['cta.cta.button_text_color', 'cta.button_text_color'], $colors['button_primary_text'] ?? '#08131f');

$defaultStats = [
    ['5+', 'Years refining table flow'],
    ['1M+', '29 Card sessions served'],
    ['24/7', 'Support desk coverage'],
    ['20+', 'Regions reached'],
];
$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfigAny(["stats.stats.stat_{$i}_number", "stats.stat_{$i}_number"], $defaultStats[$i - 1][0]));
    $label = trim((string) $getConfigAny(["stats.stats.stat_{$i}_label", "stats.stat_{$i}_label"], $defaultStats[$i - 1][1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = ['value' => $number, 'label' => $label];
}

$storyTitle = trim((string) $getConfigAny(['story.story.title', 'story.title'], 'Our Story'));
$storySubtitle = trim((string) $getConfigAny(['story.story.subtitle', 'story.subtitle'], 'Built to make every 29 Card route easier to read.'));
$storyContentField = trim((string) $getConfigAny(['story.story.content', 'story.content'], ''));
$storyHtml = '';
if ($storyContentField !== '') {
    $storyHtml = trim(strip_tags($storyContentField)) === $storyContentField
        ? '<p>' . nl2br(htmlspecialchars($storyContentField, ENT_QUOTES, 'UTF-8')) . '</p>'
        : $storyContentField;
} elseif (trim($pageContentRaw) !== '') {
    $storyHtml = trim(strip_tags($pageContentRaw)) === trim($pageContentRaw)
        ? '<p>' . nl2br(htmlspecialchars($pageContentRaw, ENT_QUOTES, 'UTF-8')) . '</p>'
        : $pageContentRaw;
} else {
    $storyHtml = '<p>Twenty Nine Tempest keeps the familiar card rhythm of 29 Card while improving how players discover tables, read feature cues, and reach support across desktop and mobile.</p>';
}

$valuesTitle = trim((string) $getConfigAny(['values.values.title', 'values.title'], 'Our Core Values'));
$valuesSubtitle = trim((string) $getConfigAny(['values.values.subtitle', 'values.subtitle'], 'Three editable pillars keep the page useful when creating new 29 Card sites.'));
$defaultValues = [
    ['FP', 'Fair Play', 'Table signals, rule expectations, and outcome cues should stay transparent from the first tap.'],
    ['MC', 'Mobile Clarity', 'Layouts, routes, and controls should remain readable during quick 29 Card browsing on smaller screens.'],
    ['FS', 'Fast Support', 'Account, payout, and gameplay questions should reach the right desk without extra friction.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $icon = trim((string) $getConfigAny(["values.values.value_{$i}_icon", "values.value_{$i}_icon"], $defaultValues[$i - 1][0]));
    $itemTitle = trim((string) $getConfigAny(["values.values.value_{$i}_title", "values.value_{$i}_title"], $defaultValues[$i - 1][1]));
    $itemDesc = trim((string) $getConfigAny(["values.values.value_{$i}_desc", "values.value_{$i}_desc"], $defaultValues[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = ['icon' => $icon, 'title' => $itemTitle, 'description' => $itemDesc];
}

$teamTitle = trim((string) $getConfigAny(['team.team.title', 'team.title'], 'Team Grid'));
$teamSubtitle = trim((string) $getConfigAny(['team.team.subtitle', 'team.subtitle'], 'The operators shaping route clarity, support speed, and product flow.'));
$defaultTeam = [
    ['R1', 'John Smith', 'Chief Executive Officer'],
    ['R2', 'Sarah Johnson', 'Chief Technology Officer'],
    ['R3', 'Michael Chen', 'Product Director'],
    ['R4', 'Emily Wang', 'Design Director'],
];
$team = [];
for ($i = 1; $i <= 4; $i++) {
    $memberName = trim((string) $getConfigAny(["team.team.member_{$i}_name", "team.member_{$i}_name"], $defaultTeam[$i - 1][1]));
    $memberRole = trim((string) $getConfigAny(["team.team.member_{$i}_role", "team.member_{$i}_role"], $defaultTeam[$i - 1][2]));
    if ($memberName === '' && $memberRole === '') {
        continue;
    }
    $team[] = [
        'icon' => trim((string) $getConfigAny(["team.team.member_{$i}_icon", "team.member_{$i}_icon"], $defaultTeam[$i - 1][0])),
        'name' => $memberName,
        'role' => $memberRole,
    ];
}

$ctaTitle = trim((string) $getConfigAny(['cta.cta.title', 'cta.title'], 'Ready for the next hand?'));
$ctaDescription = trim((string) $getConfigAny(['cta.cta.description', 'cta.description'], 'Move from overview to download and support without rebuilding the page structure later.'));
$ctaButtonText = trim((string) $getConfigAny(['cta.cta.button_text', 'cta.button_text'], 'Contact Us'));
$ctaButtonUrl = trim((string) $getConfigAny(['cta.cta.button_url', 'cta.button_url'], '/contact'));
?>
<section id="<?= $componentId ?>" class="tnt-about-page" aria-labelledby="<?= $componentId ?>-title" style="--about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --about-stats-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --about-stats-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --about-stats-card: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --about-hero-padding: <?= (int) $heroPadding ?>px;">
    <div class="about-shell">
        <header class="about-hero">
            <div class="about-hero-copy">
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p><?= htmlspecialchars($subtitle, ENT_QUOTES, 'UTF-8') ?></p>
                <?php endif; ?>
            </div>

            <?php if ($showStats && !empty($stats)): ?>
                <dl class="about-snapshot" aria-label="Brand statistics">
                    <?php foreach ($stats as $index => $stat): ?>
                        <div class="snapshot-card snapshot-card-<?= (int) ($index + 1) ?>">
                            <?php echo '<dt>' . htmlspecialchars($stat['label'], ENT_QUOTES, 'UTF-8') . '</dt>'; ?>
                            <?php echo '<dd>' . htmlspecialchars($stat['value'], ENT_QUOTES, 'UTF-8') . '</dd>'; ?>
                        </div>
                    <?php endforeach; ?>
                </dl>
            <?php endif; ?>
        </header>

        <div class="about-main<?= !$showStats || count($stats) < 2 ? ' single-column' : '' ?>">
            <section class="story-card" aria-labelledby="<?= $componentId ?>-story-title">
                <?php if ($storyTitle !== ''): ?>
                    <h2 id="<?= $componentId ?>-story-title"><?= htmlspecialchars($storyTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                <?php endif; ?>
                <?php if ($storySubtitle !== ''): ?>
                    <p class="story-subtitle"><?= htmlspecialchars($storySubtitle, ENT_QUOTES, 'UTF-8') ?></p>
                <?php endif; ?>
                <div class="story-prose"><?= $storyHtml ?></div>
            </section>

            <?php if ($showStats && !empty($stats)): ?>
                <aside class="stats-ladder">
                    <?php foreach ($stats as $index => $stat): ?>
                        <article class="ladder-card ladder-card-<?= (int) ($index + 1) ?>">
                            <span class="ladder-order"><?= sprintf('%02d', $index + 1) ?></span>
                            <strong><?= htmlspecialchars($stat['value'], ENT_QUOTES, 'UTF-8') ?></strong>
                            <p><?= htmlspecialchars($stat['label'], ENT_QUOTES, 'UTF-8') ?></p>
                        </article>
                    <?php endforeach; ?>
                </aside>
            <?php endif; ?>
        </div>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage" aria-labelledby="<?= $componentId ?>-values-title">
                <header class="section-head">
                    <h2 id="<?= $componentId ?>-values-title"><?= htmlspecialchars($valuesTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle, ENT_QUOTES, 'UTF-8') ?></p>
                    <?php endif; ?>
                </header>
                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-card value-card-<?= (int) ($index + 1) ?>">
                            <?php if ($value['icon'] !== ''): ?>
                                <span class="value-mark"><?= htmlspecialchars($value['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                            <?php endif; ?>
                            <h3><?= htmlspecialchars($value['title'], ENT_QUOTES, 'UTF-8') ?></h3>
                            <?php if ($value['description'] !== ''): ?>
                                <p><?= htmlspecialchars($value['description'], ENT_QUOTES, 'UTF-8') ?></p>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showTeam && !empty($team)): ?>
            <section class="team-stage" aria-labelledby="<?= $componentId ?>-team-title">
                <header class="section-head">
                    <h2 id="<?= $componentId ?>-team-title"><?= htmlspecialchars($teamTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle, ENT_QUOTES, 'UTF-8') ?></p>
                    <?php endif; ?>
                </header>
                <div class="team-grid">
                    <?php foreach ($team as $index => $member): ?>
                        <article class="team-card team-card-<?= (int) ($index + 1) ?>">
                            <?php if ($member['icon'] !== ''): ?>
                                <span class="team-badge"><?= htmlspecialchars($member['icon'], ENT_QUOTES, 'UTF-8') ?></span>
                            <?php endif; ?>
                            <h3><?= htmlspecialchars($member['name'], ENT_QUOTES, 'UTF-8') ?></h3>
                            <?php if ($member['role'] !== ''): ?>
                                <p><?= htmlspecialchars($member['role'], ENT_QUOTES, 'UTF-8') ?></p>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
            <section class="cta-stage" aria-labelledby="<?= $componentId ?>-cta-title">
                <div class="cta-copy">
                    <?php if ($ctaTitle !== ''): ?>
                        <h2 id="<?= $componentId ?>-cta-title"><?= htmlspecialchars($ctaTitle, ENT_QUOTES, 'UTF-8') ?></h2>
                    <?php endif; ?>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription, ENT_QUOTES, 'UTF-8') ?></p>
                    <?php endif; ?>
                </div>
                <?php if ($ctaButtonText !== ''): ?>
                    <a class="cta-link" href="<?= htmlspecialchars($ctaButtonUrl !== '' ? $ctaButtonUrl : '#', ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars($ctaButtonText, ENT_QUOTES, 'UTF-8') ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>
<style>
