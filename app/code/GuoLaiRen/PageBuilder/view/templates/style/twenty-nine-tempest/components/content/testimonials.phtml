    --my: 50%;
    --spot-alpha: 0;
    --fan-x: -120px;
    --fan-y: 0px;
    --fan-r: 0deg;
    --fan-z: 10;
    position: absolute;
    top: 50%;
    right: clamp(0.2rem, 0.9vw, 0.8rem);
    width: min(460px, calc(100% - 2.4rem));
    padding: <?= (int) $cardPadding ?>px;
    text-align: left;
    overflow: hidden;
    isolation: isolate;
    cursor: pointer;
    transform-origin: right center;
    transform: translate(var(--fan-x), calc(-50% + var(--fan-y))) rotate(var(--fan-r));
    z-index: var(--fan-z);
    transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
