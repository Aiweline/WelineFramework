    transform: translate(calc(var(--fan-x) - 6px), calc(-50% + var(--fan-y))) rotate(var(--fan-r));
    z-index: 240;
    border-color: rgba(255, 110, 66, 0.34);
    box-shadow: 0 26px 48px rgba(12, 27, 52, 0.15);
    outline: none;
