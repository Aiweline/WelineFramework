    background:
        radial-gradient(220px 140px at var(--mx) var(--my), rgba(255,255,255, calc(var(--spot-alpha) * 0.28)), transparent 72%),
        linear-gradient(132deg, rgba(255, 110, 66, calc(var(--spot-alpha) * 0.18)) 0%, rgba(0, 241, 255, calc(var(--spot-alpha) * 0.16)) 100%);
    opacity: 1;
