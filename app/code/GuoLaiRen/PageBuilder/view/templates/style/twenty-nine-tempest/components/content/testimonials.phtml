$buildInitials = static function (string $name): string {
    $parts = preg_split('/\s+/', trim($name)) ?: [];
    $letters = [];
    foreach ($parts as $part) {
        if ($part === '') {
            continue;
        }
        if (function_exists('mb_substr') && function_exists('mb_strtoupper')) {
            $letters[] = mb_strtoupper(mb_substr($part, 0, 1));
        } else {
            $letters[] = strtoupper(substr($part, 0, 1));
        }
        if (count($letters) === 2) {
            break;
        }
    }
    return $letters ? implode('', $letters) : '29';
};

$parseRatingScore = static function (string $rating): float {
    $filled = function_exists('mb_substr_count') ? mb_substr_count($rating, '⭐') : substr_count($rating, '⭐');
    if ($filled <= 0) {
        return 5.0;
    }
    $empty = function_exists('mb_substr_count') ? mb_substr_count($rating, '☆') : substr_count($rating, '☆');
    return max(0.0, min(5.0, $filled - ($empty > 0 ? 0.2 : 0.0)));
};

$defaults = [
    1 => ['name' => 'Aarav Sinha', 'tag' => 'Speed Bid Room', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'The room switch feels immediate. I can compare the pace, jump in, and keep watching the multiplier without extra clutter.'],
    2 => ['name' => 'Meera Joshi', 'tag' => 'Smart Table', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'The page reads like a product instead of a cloned game shell. Buttons, room cards, and support routes are easier to spot.'],
    3 => ['name' => 'Rohan Verma', 'tag' => 'Mobile Player', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'On mobile it still feels deliberate. I can scan room options quickly and keep the next action visible.'],
    4 => ['name' => 'Ananya Pillai', 'tag' => 'Late Session', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'Contrast is stronger than many light themes, so headings and key actions stay visible during long sessions.'],
    5 => ['name' => 'Kabir Rao', 'tag' => 'New User', 'rating' => '⭐⭐⭐⭐☆', 'content' => 'Motion effects feel intentional. Hover reveals are clear without becoming noisy.'],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $default = $defaults[$i];
    $name = trim((string) $getConfig("texts.testimonial_{$i}_name", $default['name']));
    $text = trim((string) $getConfig("texts.testimonial_{$i}_content", $default['content']));
    if ($name === '' || $text === '') {
        continue;
    }

    $ratingText = trim((string) $getConfig("texts.testimonial_{$i}_rating", $default['rating']));
    $testimonials[] = [
        'name' => $name,
        'tag' => trim((string) $getConfig("texts.testimonial_{$i}_tag", $default['tag'])),
        'rating_text' => $ratingText,
        'rating_score' => $parseRatingScore($ratingText),
        'text' => $text,
        'avatar' => trim((string) $getConfigAny(["avatars.avatar_{$i}", "testimonials.avatar_{$i}"], '')),
        'initials' => $buildInitials($name),
    ];
}

if (empty($testimonials)) {
    return;
}

$totalScore = array_sum(array_map(static function ($item) {
    return $item['rating_score'];
}, $testimonials));
$avgScore = $totalScore / max(1, count($testimonials));
$avgLabel = number_format($avgScore, 1);
$spotlight = $testimonials[0];
$testimonialCount = count($testimonials);
$fanMid = $testimonialCount > 1 ? ($testimonialCount - 1) / 2 : 0;

$jsPayload = array_map(static function ($item) {
    return [
        'name' => $item['name'],
        'tag' => $item['tag'],
        'rating_text' => $item['rating_text'],
        'text' => $item['text'],
        'avatar' => $item['avatar'],
        'initials' => $item['initials'],
    ];
}, $testimonials);
