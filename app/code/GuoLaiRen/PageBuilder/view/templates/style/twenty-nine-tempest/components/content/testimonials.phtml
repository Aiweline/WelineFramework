        width: 100%;
        --fan-x: 0px;
        --fan-y: 0px;
        --fan-r: 0deg;
        transform: none;
        z-index: auto;
    }

    #<?= $componentId ?> .voice-card:hover,
    #<?= $componentId ?> .voice-card:focus-visible,
    #<?= $componentId ?> .voice-card.is-active {
        transform: translateY(-2px);
