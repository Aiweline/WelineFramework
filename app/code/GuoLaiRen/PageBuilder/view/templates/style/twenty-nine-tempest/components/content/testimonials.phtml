    #<?= $componentId ?> .voice-spotlight,
    #<?= $componentId ?> .voice-card {
        border-radius: 20px;
    }
}
</style>

<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var data = <?= json_encode($jsPayload, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) ?>;
    if (!Array.isArray(data) || !data.length) {
        return;
    }

    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-voice-index]'));
    var spotlightName = root.querySelector('[data-spotlight-name]');
    var spotlightTag = root.querySelector('[data-spotlight-tag]');
    var spotlightRating = root.querySelector('[data-spotlight-rating]');
    var spotlightText = root.querySelector('[data-spotlight-text]');
    var spotlightAvatar = root.querySelector('[data-spotlight-avatar]');
    var allowAvatar = <?= $showAvatar ? 'true' : 'false' ?>;

    var renderAvatar = function(item) {
        if (!allowAvatar || !spotlightAvatar) {
            return;
        }

        spotlightAvatar.innerHTML = '';
        if (item.avatar) {
            var img = document.createElement('img');
            img.src = item.avatar;
            img.alt = item.name || 'Player avatar';
            spotlightAvatar.appendChild(img);
            return;
        }

        spotlightAvatar.textContent = item.initials || '29';
    };

    var setActive = function(index) {
        var item = data[index];
        if (!item) {
            return;
        }

        cards.forEach(function(card, i) {
            card.classList.toggle('is-active', i === index);
        });

        if (spotlightName) {
            spotlightName.textContent = item.name || '';
        }
        if (spotlightTag) {
            spotlightTag.textContent = item.tag || '';
            spotlightTag.style.display = item.tag ? 'block' : 'none';
        }
        if (spotlightRating) {
            spotlightRating.textContent = item.rating_text || '';
        }
        if (spotlightText) {
            spotlightText.textContent = item.text || '';
        }

        renderAvatar(item);
    };

    cards.forEach(function(card) {
        var index = parseInt(card.getAttribute('data-voice-index'), 10);
        if (Number.isNaN(index)) {
            return;
        }

        card.addEventListener('mousemove', function(event) {
            var rect = card.getBoundingClientRect();
            var x = ((event.clientX - rect.left) / rect.width) * 100;
            var y = ((event.clientY - rect.top) / rect.height) * 100;
            card.style.setProperty('--mx', x.toFixed(2) + '%');
            card.style.setProperty('--my', y.toFixed(2) + '%');
            card.style.setProperty('--spot-alpha', '1');
        });

        card.addEventListener('mouseleave', function() {
            card.style.setProperty('--spot-alpha', '0');
        });

        card.addEventListener('mouseenter', function() {
            setActive(index);
        });

        card.addEventListener('focus', function() {
            setActive(index);
            card.style.setProperty('--spot-alpha', '1');
        });

        card.addEventListener('blur', function() {
            card.style.setProperty('--spot-alpha', '0');
        });

        card.addEventListener('click', function() {
            setActive(index);
        });
    });
})();
</script>
