    #<?= $componentId ?> {
        padding: <?= (int) $sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .voices-shell {
        width: min(100%, calc(100% - 0.95rem));
    }

    #<?= $componentId ?> .voices-head h2 span {
        padding: 0.2rem 0 0.36rem 1.28rem;
    }

    #<?= $componentId ?> .voices-head h2 span::before {
        width: 12px;
        height: 12px;
    }

    #<?= $componentId ?> .voices-fan {
        display: flex;
        overflow-x: auto;
        gap: 0.62rem;
        scroll-snap-type: x mandatory;
        padding-bottom: 0.18rem;
        scrollbar-width: none;
    }

    #<?= $componentId ?> .voices-fan::-webkit-scrollbar {
        display: none;
    }

    #<?= $componentId ?> .voice-card {
        min-width: min(18rem, calc(100vw - 1.1rem));
        scroll-snap-align: start;
    }

    #<?= $componentId ?> .voices-head,
