$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 获取配置值
function getContentConfig($settings, $key, $default = '') {
    return $settings[$key] ?? $default;
}

// 布局配置
$maxWidth = getContentConfig($styleSettings, 'layout.max_width', 1200);
$padding = getContentConfig($styleSettings, 'layout.padding', 40);
