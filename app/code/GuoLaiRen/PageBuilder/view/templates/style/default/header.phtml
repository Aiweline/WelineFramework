    <?php endif; ?>
}

.header-logo {
    display: flex;
    align-items: center;
}

.header-logo img {
    /* Logo 高度根据 Header 高度自适应，保留 30px 上下间距 */
    max-height: calc(<?= $heightResponsive ?> - 30px);
    width: auto;
    /* 响应式Logo最大宽度：移动端 150px 到 PC端 300px */
    max-width: clamp(150px, calc(150px + 150 * ((100vw - 375px) / 905)), 300px);
    object-fit: contain;
}

.header-logo-text {
    /* 响应式字体大小：移动端 18px 到 PC端 24px */
    font-size: clamp(18px, calc(18px + 6 * ((100vw - 375px) / 905)), 24px);
    font-weight: bold;
    color: #333;
    text-decoration: none;
}
</style>

<!-- Header 头部 -->
