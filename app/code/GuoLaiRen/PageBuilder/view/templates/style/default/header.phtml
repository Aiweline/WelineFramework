// 尺寸配置 - 使用新的响应式格式解析
$heightValue = getConfig($styleSettings, 'size.height', '60/80');
$maxWidthValue = getConfig($styleSettings, 'size.max_width', '100/1200');
$paddingHValue = getConfig($styleSettings, 'size.padding_h', '16/40');

$height = parseResponsiveValue($heightValue . 'px');
$maxWidth = parseResponsiveValue($maxWidthValue . 'px');
$paddingH = parseResponsiveValue($paddingHValue . 'px');

/**
 * 生成响应式 CSS 值
 * 支持 clamp() 自动计算中间值
 * 
 * @param array $parsed 解析后的响应式值数组
 * @return string CSS值
 */
function generateResponsiveCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    
    // 如果移动端和PC端值相同，直接返回固定值
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    
    // 断点定义
    $minVw = 375;  // 移动端最小宽度
    $maxVw = 1280; // PC端最大宽度
    $vwDiff = $maxVw - $minVw;
    $diff = $desktop - $mobile;
    
    // 生成 clamp() 函数
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - {$minVw}px) / {$vwDiff})), {$desktop}{$unit})";
}

$heightResponsive = generateResponsiveCSS($height);
$paddingHResponsive = generateResponsiveCSS($paddingH);
$maxWidthResponsive = $maxWidth['desktop'] . $maxWidth['unit']; // 最大宽度使用PC端值

