/**
 * 解析响应式配置值
 * 支持格式：
 * - 单一值: "80" 或 "80px"
 * - 双端值: "60/80" 表示 移动端60 / PC端80
 * - 三端值: "60/70/80" 表示 移动端60 / 平板70 / PC端80
 * 
 * @param string $value 配置值
 * @return array ['mobile' => 60, 'tablet' => 70, 'desktop' => 80, 'unit' => 'px']
 */
if (!function_exists('parseResponsiveValue')) {
function parseResponsiveValue($value) {
    if (empty($value)) {
        return ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => ''];
    }
    
    // 移除空格
    $value = trim($value);
    
    // 提取单位（查找最后一个数字后的字符）
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    
    // 按斜杠分割值
    $parts = explode('/', $value);
    $parts = array_map('trim', $parts);
    
    $result = [
        'mobile' => '',
        'tablet' => '',
        'desktop' => '',
        'unit' => $unit ?: 'px'
    ];
    
    switch (count($parts)) {
        case 1:
            // 单一值：所有端都使用同一值
            $result['mobile'] = $parts[0];
            $result['tablet'] = $parts[0];
            $result['desktop'] = $parts[0];
            break;
            
        case 2:
            // 双端值：移动端/PC端，平板自动计算
            $result['mobile'] = $parts[0];
            $result['tablet'] = ''; // 自动计算
            $result['desktop'] = $parts[1];
            break;
            
        case 3:
            // 三端值：移动端/平板/PC端
            $result['mobile'] = $parts[0];
            $result['tablet'] = $parts[1];
            $result['desktop'] = $parts[2];
            break;
    }
    
    return $result;
}
}

