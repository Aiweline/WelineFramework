<?php
/**
 * 默认样式 - Header
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:layout => 布局
 * layout.logo_position => Logo位置:select:left|left,center,right
 * 
 * group:style => 样式
 * style.header_background_color => 页头背景色:color:transparent
 * style.border_bottom => 底部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:#eeeeee
 * 
 * group:size => 尺寸[MTD]:📱响应式配置说明:支持移动端/平板/PC端三种配置格式\n• 单一值: 80 (所有端相同)\n• 双端值: 60/80 (移动端60, PC端80, 推荐)\n• 三端值: 60/70/80 (移动端60, 平板70, PC端80)\n\n断点定义:\nM (Mobile) 移动端: 375px\nT (Tablet) 平板: 768px\nD (Desktop) PC端: 1280px\n\n标记说明: [M]移动端 [MD]移动+PC [MTD]完整三端
 * size.height => 头部高度:responsive:60/80|px[MD]
 * size.max_width => 内容最大宽度:responsive:100/1200|%/px[移动端使用百分比，PC端使用像素]
 * size.padding_h => 左右内边距:responsive:16/40|px[MD]
 * 
 * @fields_end
 */

$page = $this->getData('page');
// 兼容两种变量名：style（前端页面）和 style_settings（后端编辑预览）
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$isPreview = $this->getData('is_preview');

// 获取配置值的辅助函数
function getConfig($settings, $key, $default = '') {
    return $settings[$key] ?? $default;
}

/**
 * 解析响应式配置值
 * 支持格式：
 * - 单一值: "80" 或 "80px"
 * - 双端值: "60/80" 表示 移动端60 / PC端80
 * - 三端值: "60/70/80" 表示 移动端60 / 平板70 / PC端80
 * 
 * @param string $value 配置值
 * @return array ['mobile' => 60, 'tablet' => 70, 'desktop' => 80, 'unit' => 'px']
 */
function parseResponsiveValue($value) {
    if (empty($value)) {
        return ['mobile' => '', 'tablet' => '', 'desktop' => '', 'unit' => ''];
    }
    
    // 移除空格
    $value = trim($value);
    
    // 提取单位（查找最后一个数字后的字符）
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    
    // 按斜杠分割值
    $parts = explode('/', $value);
    $parts = array_map('trim', $parts);
    
    $result = [
        'mobile' => '',
        'tablet' => '',
        'desktop' => '',
        'unit' => $unit ?: 'px'
    ];
    
    switch (count($parts)) {
        case 1:
            // 单一值：所有端都使用同一值
            $result['mobile'] = $parts[0];
            $result['tablet'] = $parts[0];
            $result['desktop'] = $parts[0];
            break;
            
        case 2:
            // 双端值：移动端/PC端，平板自动计算
            $result['mobile'] = $parts[0];
            $result['tablet'] = ''; // 自动计算
            $result['desktop'] = $parts[1];
            break;
            
        case 3:
            // 三端值：移动端/平板/PC端
            $result['mobile'] = $parts[0];
            $result['tablet'] = $parts[1];
            $result['desktop'] = $parts[2];
            break;
    }
    
    return $result;
}

// 从页面配置中读取 Logo 信息
$logoUrl = $page ? $page->getData('logo') : '';
// 注意：如果页面没有设置 logo，$logoUrl 为空，模板会显示纯文字标题
$pageTitle = $page ? $page->getData('title') : '';
$logoLink = '/'; // 链接到首页

// 从样式配置中读取 Logo 位置
$logoPosition = getConfig($styleSettings, 'layout.logo_position', 'left');

// 样式配置
$bgColor = getConfig($styleSettings, 'style.header_background_color', 'transparent');
$borderBottom = getConfig($styleSettings, 'style.border_bottom', 'yes');
$borderColor = getConfig($styleSettings, 'style.border_color', '#eeeeee');

// 尺寸配置 - 使用新的响应式格式解析
$heightValue = getConfig($styleSettings, 'size.height', '60/80');
$maxWidthValue = getConfig($styleSettings, 'size.max_width', '100/1200');
$paddingHValue = getConfig($styleSettings, 'size.padding_h', '16/40');

$height = parseResponsiveValue($heightValue . 'px');
$maxWidth = parseResponsiveValue($maxWidthValue . 'px');
$paddingH = parseResponsiveValue($paddingHValue . 'px');

/**
 * 生成响应式 CSS 值
 * 支持 clamp() 自动计算中间值
 * 
 * @param array $parsed 解析后的响应式值数组
 * @return string CSS值
 */
function generateResponsiveCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    
    // 如果移动端和PC端值相同，直接返回固定值
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    
    // 断点定义
    $minVw = 375;  // 移动端最小宽度
    $maxVw = 1280; // PC端最大宽度
    $vwDiff = $maxVw - $minVw;
    $diff = $desktop - $mobile;
    
    // 生成 clamp() 函数
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - {$minVw}px) / {$vwDiff})), {$desktop}{$unit})";
}

$heightResponsive = generateResponsiveCSS($height);
$paddingHResponsive = generateResponsiveCSS($paddingH);
$maxWidthResponsive = $maxWidth['desktop'] . $maxWidth['unit']; // 最大宽度使用PC端值

// 从页面配置中读取跟踪代码 ID
