$intro = $getConfig('texts.intro', 'Everything you need to know about Call Break Legend, bidding strategy, and secure withdrawals.');
$tags = array_filter([
    trim((string)$getConfig('texts.tag_1', 'Rules & Bids')),
    trim((string)$getConfig('texts.tag_2', 'Fair Play')),
    trim((string)$getConfig('texts.tag_3', 'Fast Withdrawals')),
]);

$defaults = [
    ['question' => 'How do I start playing?', 'answer' => 'Download the app, sign up, and join a Call Break table in seconds.'],
    ['question' => 'How does bidding work?', 'answer' => 'Place your bid before the round starts, then aim to win exactly that many tricks.'],
    ['question' => 'Is it safe and fair?', 'answer' => 'Yes. We use secure encryption and fair play protections across all tables.'],
    ['question' => 'How do I withdraw winnings?', 'answer' => 'Withdrawals are processed quickly to your preferred payment method.'],
    ['question' => 'Can beginners play ranked tables?', 'answer' => 'Yes. Start in standard rooms, then move into ranked once your bid consistency improves.'],
    ['question' => 'Which modes are available?', 'answer' => 'You can play Classic, Quick Match, and challenge-based tables depending on your pace.'],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i - 1] ?? ['question' => '', 'answer' => ''];
    $question = trim((string)$getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string)$getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

if (empty($faqs)) {
    $faqs = array_slice($defaults, 0, 4);
}

$facts = [
    ['label' => 'Bidding', 'value' => 'Locked pre-round'],
    ['label' => 'Security', 'value' => 'Encrypted sessions'],
    ['label' => 'Withdrawal', 'value' => 'Fast processing'],
