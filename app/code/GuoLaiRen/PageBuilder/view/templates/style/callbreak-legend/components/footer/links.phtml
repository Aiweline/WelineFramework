<?php
/**
 * Call Break Legend - Footer Component
 *
 * 现代化Footer，多列布局，响应式设计
 *
 * @component_start
 * code: footer-links
 * name: 页脚链接
 * name_en: Footer Links
 * description: 多列链接布局，社交媒体图标
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:footer => Footer设置
 * footer.logo_text => Logo文字:text:Call Break Legend
 * footer.logo_url => Logo图片URL:textarea:|留空使用默认图标
 * footer.tagline => 口号:text:Bid smart. Win bold.
 *
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nGames=>#games\r\nHow to Play=>#howto\r\nTournaments=>#tournaments\r\nFAQ=>#faq\r\nSupport=>/contact|配置格式：名字=>url，一行一个
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 * content.copyright_text => 版权信息:text:© 2026 Call Break Legend. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. This game involves real money. Play responsibly and stay within your limits.
 *
 * @fields_end
 */

$componentId = 'abpro-footer-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$logoText = (string) $getConfigAny([
    'footer.logo_text',
    'footer.logo.text',
    'logo.text',
], 'Call Break Legend');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-legend/asset/img/tpm-logo-icon.svg');
$logoUrl = (string) $getConfigAny([
    'footer.logo_url',
    'footer.logo.url',
    'logo.url',
], '') ?: $logoIconUrl;
$tagline = (string) $getConfigAny([
    'footer.tagline',
    'footer.subtitle',
], 'Bid smart. Win bold.');
$copyright = trim((string) $getConfigAny([
    'content.copyright_text',
    'content_footer_labels.content.copyright_text',
    'content_footer_labels.copyright_text',
    'footer.copyright',
], '© 2026 Call Break Legend. All rights reserved.'));
if ($copyright === '') {
    $copyright = '© 2026 Call Break Legend. All rights reserved.';
}
$disclaimerText = trim((string) $getConfigAny([
    'content.disclaimer_text',
    'content_footer_labels.content.disclaimer_text',
    'content_footer_labels.disclaimer_text',
    'footer.disclaimer_text',
], '18+ Only. This game involves real money. Play responsibly and stay within your limits.'));
if ($disclaimerText === '') {
    $disclaimerText = '18+ Only. This game involves real money. Play responsibly and stay within your limits.';
}

$links = [];
$useCustomLinks = $normalizeToggle($getConfigAny([
    'content.use_custom_links',
    'content.footer_use_custom_links',
], 'yes')) === 'yes';

if (!$useCustomLinks && $page) {
    $subpages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $subpages = $page->getHeaderNavigationPages(30);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $subpages = $page->getNavigationPages([], 30);
    } else {
        $subpages = $page->getData('subpages') ?: [];
    }
    foreach ($subpages as $subpage) {
        $pageType = trim((string)($subpage['type'] ?? ''));
        $label = $pageType !== '' ? trim((string)$getConfigAny([
            'content.footer_label_' . $pageType,
            'content_footer_labels.content.footer_label_' . $pageType,
            'content_footer_labels.footer_label_' . $pageType,
        ], '')) : '';
        $links[] = [
            'text' => $label !== '' ? $label : ($subpage['title'] ?? ''),
            'href' => $subpage['url'] ?? '#'
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny([
        'content.footer_links',
        'content_footer_labels.content.footer_links',
    ], "Home=>/\r\nGames=>#games\r\nHow to Play=>#howto\r\nTournaments=>#tournaments\r\nFAQ=>#faq\r\nSupport=>/contact");

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = (strpos($linksConfig, "\n") !== false && strpos($linksConfig, ',') === false)
        ? preg_split('/\r?\n/', $linksConfig)
        : explode(',', $linksConfig);

    foreach ($items as $item) {
        $item = trim($item);
        if (empty($item)) continue;
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            continue;
        }
        if (count($parts) >= 2) {
            $links[] = ['text' => $parts[0], 'href' => $parts[1] !== '' ? $parts[1] : '#'];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}
