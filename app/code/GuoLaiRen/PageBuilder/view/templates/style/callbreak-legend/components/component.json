{
    "$schema": "2.1.0",
    "template": "callbreak-legend",
    "name": "Call Break Legend",
    "description": "Modern responsive theme for Call Break card game with Tailwind CSS",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航、Logo等",
            "multiple": false,
            "required": true,
            "accepts": [
                "header"
            ],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": [
                "content",
                "widget"
            ],
            "default_components": [
                "hero-slider",
                "advantages",
                "games-showcase",
                "testimonials",
                "faq"
            ],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含版权、链接等",
            "multiple": false,
            "required": true,
            "accepts": [
                "footer"
            ],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "现代响应式导航",
            "name_en": "Modern Responsive Navigation",
            "description": "深海翠金主题，移动端汉堡菜单，桌面端横向导航",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "header"
            ],
            "config_groups": [
                "logo",
                "navigation"
            ],
            "file": "header/nav.phtml"
