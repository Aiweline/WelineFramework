<?php
/**
 * Generic simple header component.
 *
 * @component_start
 * code: header-simple
 * name: 简洁头部
 * name_en: Simple Header
 * description: 只包含品牌标识的简洁头部
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo地址:textarea:|优先使用页面Logo
 * logo.width => Logo宽度:number:120|px
 * logo.position => Logo位置:select:center|left,center,right
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#ffffff
 * style.padding => 内边距:number:20|px
 * style.text_color => 文本颜色:color:#111111
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$componentId = 'generic-header-simple-' . uniqid();
$themeCode = basename(dirname(dirname(__DIR__)));
$themeLabel = ucwords(str_replace('-', ' ', $themeCode));

$getConfig = function ($key, $default = '') use ($styleSettings, $componentConfig) {
    if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
        return $styleSettings[$key];
    }
    return $default;
};

$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoUrl = trim((string)$getConfig('logo.url', ''));
if ($logoUrl === '' && $page && $page->getData('logo')) {
    $logoUrl = (string)$page->getData('logo');
}
$logoWidth = max(40, (int)$getConfig('logo.width', '120'));
$logoPosition = (string)$getConfig('logo.position', 'center');
$bgColor = (string)$getConfig('style.bg_color', '#ffffff');
$padding = max(0, (int)$getConfig('style.padding', '20'));
$textColor = (string)$getConfig('style.text_color', '#111111');
$brandText = trim((string)($page ? ($page->getData('title') ?: '') : ''));
if ($brandText === '') {
    $brandText = $themeLabel;
}
$justifyMap = ['left' => 'flex-start', 'center' => 'center', 'right' => 'flex-end'];
$justify = $justifyMap[$logoPosition] ?? 'center';
?>
<style>
#<?= $componentId ?> { background: <?= htmlspecialchars($bgColor) ?>; padding: <?= $padding ?>px 0; width: 100%; }
#<?= $componentId ?> .header-inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; justify-content: <?= $justify ?>; align-items: center; }
#<?= $componentId ?> .brand-mark { display: inline-flex; align-items: center; gap: 12px; color: <?= htmlspecialchars($textColor) ?>; text-decoration: none; font-weight: 700; }
#<?= $componentId ?> .brand-mark img { width: <?= $logoWidth ?>px; height: auto; display: block; }
#<?= $componentId ?> .brand-fallback { font-size: clamp(1rem, 1.8vw, 1.2rem); letter-spacing: 0.02em; }
</style>
<header id="<?= $componentId ?>" class="theme-header-simple">
    <div class="header-inner">
        <?php if ($showLogo): ?>
            <a class="brand-mark" href="/">
                <?php if ($logoUrl !== ''): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($brandText) ?>">
                <?php else: ?>
                    <span class="brand-fallback"><?= htmlspecialchars($brandText) ?></span>
                <?php endif; ?>
            </a>
        <?php endif; ?>
    </div>
</header>
