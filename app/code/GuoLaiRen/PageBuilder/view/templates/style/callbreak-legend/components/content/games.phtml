<?php
/**
 * Call Break Legend - Games Showcase Component
 *
 * @component_start
 * code: games-showcase
 * name: 游戏展示区
 * name_en: Games Showcase
 * description: 创意游戏展示，支持编辑标题、描述与列表
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_subtitle => 显示副标题:select:yes|yes,no
 * display.show_tags => 显示标签:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#0b1525
 * style.accent_color => 强调色:color:#f2a93b
 * style.title_color => 标题颜色:color:#f2a93b
 * style.subtitle_color => 副标题颜色:color:#cbd5e1
 * style.panel_bg_color => 介绍面板背景:color:rgba(11,21,37,0.7)
 * style.card_bg_color => 卡片背景色:color:rgba(11,21,37,0.75)
 * style.card_border_color => 卡片边框色:color:rgba(30,185,128,0.18)
 * style.card_radius => 卡片圆角:number:18|px
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 * style.card_gap => 卡片间距:number:24|px
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Call Break Arena
 * texts.subtitle => 副标题:textarea:Climb the ladder with precision bids and fearless tricks
 * texts.tags => 标签:textarea:Ranked Battles|Quick Match|Private Rooms
 * texts.cta_text => 按钮文字:text:Enter Table
 *
 * group:game_1 => 游戏1配置
 * texts.game_1_badge => 游戏1徽章:text:Legend Table
 * texts.game_1_title => 游戏1标题:text:Classic Call Break
 * texts.game_1_desc => 游戏1描述:textarea:Standard 4-player trick-taking rules
 * links.game_1_url => 游戏1链接:text:#classic
 *
 * group:game_2 => 游戏2配置
 * texts.game_2_badge => 游戏2徽章:text:Precision Bid
 * texts.game_2_title => 游戏2标题:text:Quick Call Break
 * texts.game_2_desc => 游戏2描述:textarea:Short rounds for fast wins
 * links.game_2_url => 游戏2链接:text:#quick
 *
 * group:game_3 => 游戏3配置
 * texts.game_3_badge => 游戏3徽章:text:Streak Bonus
 * texts.game_3_title => 游戏3标题:text:Pro League
 * texts.game_3_desc => 游戏3描述:textarea:Ranked ladder with skill ratings
 * links.game_3_url => 游戏3链接:text:#pro
 *
 * group:game_4 => 游戏4配置
 * texts.game_4_badge => 游戏4徽章:text:Team Clash
 * texts.game_4_title => 游戏4标题:text:High Stakes
 * texts.game_4_desc => 游戏4描述:textarea:Bigger bids, bigger rewards
 * links.game_4_url => 游戏4链接:text:#stakes
 *
 * group:game_5 => 游戏5配置
 * texts.game_5_badge => 游戏5徽章:text:Pro League
 * texts.game_5_title => 游戏5标题:text:Team Clash
 * texts.game_5_desc => 游戏5描述:textarea:2v2 strategic play mode
 * links.game_5_url => 游戏5链接:text:#team
 *
 * group:game_6 => 游戏6配置
 * texts.game_6_badge => 游戏6徽章:text:Daily Quest
 * texts.game_6_title => 游戏6标题:text:Practice Table
 * texts.game_6_desc => 游戏6描述:textarea:Learn bids and tricks risk-free
 * links.game_6_url => 游戏6链接:text:#practice
 *
 * @fields_end
 */

$componentId = 'tpm-games-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeLines = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$parseLegacyGames = static function ($value) use ($normalizeLines) {
    $games = [];
    foreach ($normalizeLines((string) $value) as $line) {
        $parts = array_map('trim', explode('|', $line));
        $title = $parts[0] ?? '';
        if ($title === '') {
            continue;
        }
        $games[] = [
            'title' => $title,
            'description' => $parts[1] ?? '',
            'url' => $parts[2] ?? '#',
        ];
    }
    return $games;
};

$parseLegacyBadgeList = static function ($value) use ($normalizeLines) {
    return $normalizeLines((string) $value);
};

$getLegacyIndexed = static function (array $items, $index, $field, $default = '') {
    return isset($items[$index][$field]) && $items[$index][$field] !== '' ? $items[$index][$field] : $default;
};

$getLegacyToken = static function (array $items, $index, $default = '') {
    return isset($items[$index]) && $items[$index] !== '' ? $items[$index] : $default;
};

// 显示控制
$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';

// 样式配置
$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#0b1525'));
$accentColor = $getConfig('style.accent_color', '#f2a93b');
$titleColor = $getConfig('style.title_color', '#f2a93b');
$subtitleColor = $getConfig('style.subtitle_color', '#cbd5e1');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(11,21,37,0.7)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(11,21,37,0.75)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(30,185,128,0.18)');
$cardRadius = $getConfig('style.card_radius', '18');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');
$cardGap = $getConfig('style.card_gap', '24');

// 文本内容
$title = $getConfig('texts.title', $getConfig('games.title', 'Call Break Arena'));
$subtitle = $getConfig('texts.subtitle', $getConfig('games.subtitle', 'Climb the ladder with precision bids and fearless tricks'));
$tagsConfig = $getConfig('texts.tags', 'Ranked Battles|Quick Match|Private Rooms');
$ctaText = trim((string)$getConfig('texts.cta_text', 'Enter Table'));
if ($ctaText === '') {
    $ctaText = 'Enter Table';
}

$tags = array_filter(array_map('trim', preg_split('/[\r\n\|]+/', $tagsConfig)));
$legacyGames = $parseLegacyGames($getConfigAny(['games.items'], ''));
$legacyBadges = $parseLegacyBadgeList($getConfigAny(['texts.badges'], ''));
$defaultGames = [
    ['badge' => 'Legend Table', 'title' => 'Classic Call Break', 'description' => 'Standard 4-player trick-taking rules', 'url' => '#classic'],
    ['badge' => 'Precision Bid', 'title' => 'Quick Call Break', 'description' => 'Short rounds for fast wins', 'url' => '#quick'],
    ['badge' => 'Streak Bonus', 'title' => 'Pro League', 'description' => 'Ranked ladder with skill ratings', 'url' => '#pro'],
    ['badge' => 'Team Clash', 'title' => 'High Stakes', 'description' => 'Bigger bids, bigger rewards', 'url' => '#stakes'],
    ['badge' => 'Pro League', 'title' => 'Team Clash', 'description' => '2v2 strategic play mode', 'url' => '#team'],
    ['badge' => 'Daily Quest', 'title' => 'Practice Table', 'description' => 'Learn bids and tricks risk-free', 'url' => '#practice'],
];

$games = [];
$badges = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaultGames[$i - 1];
    $badge = (string)$getConfigAny([
        'game_' . $i . '.texts.game_' . $i . '_badge',
        'texts.game_' . $i . '_badge',
    ], $getLegacyToken($legacyBadges, $i - 1, $default['badge']));

    $games[] = [
        'name' => (string)$getConfigAny([
            'game_' . $i . '.texts.game_' . $i . '_title',
            'texts.game_' . $i . '_title',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'title', $default['title'])),
        'description' => (string)$getConfigAny([
            'game_' . $i . '.texts.game_' . $i . '_desc',
            'texts.game_' . $i . '_desc',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'description', $default['description'])),
        'link' => (string)$getConfigAny([
            'game_' . $i . '.links.game_' . $i . '_url',
            'links.game_' . $i . '_url',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'url', $default['url'])),
    ];
    $badges[] = $badge;
}
?>

