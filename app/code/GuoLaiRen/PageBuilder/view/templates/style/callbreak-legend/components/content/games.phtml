<section id="<?= $componentId ?>" class="tpmst-section tpmst-games-component">
    <div class="games-wrap">
        <div class="section-header intro-panel">
            <?php if ($showTitle): ?>
                <h2 class="section-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showSubtitle): ?>
                <p class="section-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if ($showTags && !empty($tags)): ?>
                <div class="intro-badges">
                    <?php foreach ($tags as $tag): ?>
                        <span class="intro-badge"><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </div>

        <div class="games-grid">
            <?php
            $icons = ['🃏', '🂡', '♠️', '♣️', '♦️', '🎴'];
            foreach ($games as $index => $game):
                $icon = $icons[$index % count($icons)];
                $badge = $badges[$index % max(1, count($badges))] ?? '';
                $featured = $index === 0 ? 'featured' : '';
            ?>
            <div class="game-card <?= $featured ?>">
                <div class="game-icon"><?= $icon ?></div>
                <?php if ($badge): ?>
                    <div class="game-badge"><?= htmlspecialchars($badge) ?></div>
                <?php endif; ?>
                <h3 class="game-name"><?= htmlspecialchars($game['name']) ?></h3>
                <p class="game-description"><?= htmlspecialchars($game['description']) ?></p>
                <a href="<?= htmlspecialchars($game['link']) ?>" class="game-link"><?= htmlspecialchars($ctaText) ?> →</a>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
