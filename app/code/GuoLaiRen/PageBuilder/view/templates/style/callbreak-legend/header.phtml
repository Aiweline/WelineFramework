<?php
/**
 * Call Break Legend - Header
 *
 * @fields_start
 *
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:Call Break Legend
 * logo.url => Logo图片URL:textarea:|留空使用默认图标
 *
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.items => 导航项:textarea:Home=>/\r\nGames=>#games\r\nHow to Play=>#howto\r\nWinners=>#winners\r\nFAQ=>#faq|格式：文本=>链接
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:download_button => 下载按钮
 * header.download_button.text => 下载按钮文本:text:Play Now
 * header.download_button.url => 下载链接:text:#download
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

$templateCode = $page ? $page->getData('style') : 'callbreak-legend';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'callbreak-legend';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__pagebuilder_shell_managed', true);
?>
<?= $this->fetchTemplate('GuoLaiRen_PageBuilder::style/callbreak-legend/components/header/nav.phtml') ?>
