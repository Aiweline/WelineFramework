<?php
/**
 * Call Break Legend - About Content Component
 *
 * @component_start
 * code: about-content
 * name: 关于我们内容
 * name_en: About Content
 * description: 品牌关于页面内容展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_stats => 显示数据统计:select:yes|yes,no
 * display.show_values => 显示价值观:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:About Call Break Legend
 * hero.subtitle => 页面副标题:textarea:Call Break Legend refines the classic trick-taking experience with clearer room reading, faster support access, and dependable mobile play.
 *
 * group:stats => 数据统计
 * stats.stat_1_number => 统计1数字:text:5+
 * stats.stat_1_label => 统计1标签:text:Years refining table flow
 * stats.stat_2_number => 统计2数字:text:1M+
 * stats.stat_2_label => 统计2标签:text:Call Break sessions served
 * stats.stat_3_number => 统计3数字:text:24/7
 * stats.stat_3_label => 统计3标签:text:Support desk coverage
 * stats.stat_4_number => 统计4数字:text:20+
 * stats.stat_4_label => 统计4标签:text:Regions reached
 * stats.lead_label => 主数据辅助标签:text:Momentum Snapshot
 *
 * group:story => 故事区块
 * story.title => 标题:text:Our Story
 * story.content => 内容:textarea:Call Break Legend keeps the familiar card rhythm of Call Break while improving how players discover tables, read feature cues, and reach support across desktop and mobile.
 *
 * group:values => 价值观区块
 * values.kicker => 价值观辅助标签:text:Operating Principles
 * values.title => 标题:text:Our Core Values
 * values.subtitle => 副标题:text:Three editable pillars keep the page useful when creating new Call Break sites.
 * values.value_1_icon => 价值1图标:text:⚖️
 * values.value_1_title => 价值1标题:text:Fair Play
 * values.value_1_desc => 价值1描述:textarea:Table signals, rule expectations, and outcome cues should stay transparent from the first tap.
 * values.value_2_icon => 价值2图标:text:📱
 * values.value_2_title => 价值2标题:text:Mobile Clarity
 * values.value_2_desc => 价值2描述:textarea:Layouts, routes, and controls should remain readable during quick Call Break browsing on smaller screens.
 * values.value_3_icon => 价值3图标:text:💬
 * values.value_3_title => 价值3标题:text:Fast Support
 * values.value_3_desc => 价值3描述:textarea:Account, payout, and gameplay questions should reach the right desk without extra friction.
 *
 * @fields_end
 */

$page = $this->getData('page');
$componentId = 'cbl-about-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if ($getConfig('display.show_section', $getConfig('about.display', 'yes')) === 'no') {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'About Call Break Legend';
}
$subtitle = trim((string)$getConfig('hero.subtitle', 'Call Break Legend refines the classic trick-taking experience with clearer room reading, faster support access, and dependable mobile play.'));

$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultNumbers = ['5+', '1M+', '24/7', '20+'];
    $defaultLabels = [
        'Years refining table flow',
        'Call Break sessions served',
        'Support desk coverage',
        'Regions reached',
    ];
    $number = trim((string)$getConfig("stats.stat_{$i}_number", $defaultNumbers[$i - 1]));
    $label = trim((string)$getConfig("stats.stat_{$i}_label", $defaultLabels[$i - 1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'value' => $number,
        'label' => $label,
    ];
}

if (empty($stats)) {
    $statsRaw = (string)$getConfig('stats.items', "5+|Years refining table flow\n1M+|Call Break sessions served\n24/7|Support desk coverage\n20+|Regions reached");
    if (strpos($statsRaw, '\n') !== false && strpos($statsRaw, "\n") === false) {
        $statsRaw = str_replace('\n', "\n", $statsRaw);
    }
    foreach (preg_split('/[\r\n]+/', $statsRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim($parts[0] ?? '') !== '') {
            $stats[] = [
                'value' => trim($parts[0]),
                'label' => trim($parts[1] ?? ''),
            ];
        }
    }
}

$storyTitle = trim((string)$getConfig('story.title', 'Our Story'));
$storyContent = trim((string)$getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Call Break Legend keeps the familiar card rhythm of Call Break while improving how players discover tables, read feature cues, and reach support across desktop and mobile.';
}
$storyParagraphs = preg_split('/[\r\n]+/', trim((string)$storyContent));
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function($item) {
    return $item !== '';
}));
if (empty($storyParagraphs) && trim((string)$storyContent) !== '') {
    $storyParagraphs = [trim((string)$storyContent)];
}

$valuesTitle = trim((string)$getConfig('values.title', 'Our Core Values'));
$valuesKicker = trim((string)$getConfig('values.kicker', 'Operating Principles'));
$valuesSubtitle = trim((string)$getConfig('values.subtitle', 'Three editable pillars keep the page useful when creating new Call Break sites.'));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $defaults = [
        ['⚖️', 'Fair Play', 'Table signals, rule expectations, and outcome cues should stay transparent from the first tap.'],
        ['📱', 'Mobile Clarity', 'Layouts, routes, and controls should remain readable during quick Call Break browsing on smaller screens.'],
        ['💬', 'Fast Support', 'Account, payout, and gameplay questions should reach the right desk without extra friction.'],
    ];
    $itemTitle = trim((string)$getConfig("values.value_{$i}_title", $defaults[$i - 1][1]));
    $itemDesc = trim((string)$getConfig("values.value_{$i}_desc", $defaults[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'title' => $itemTitle,
        'description' => $itemDesc,
        'icon' => trim((string)$getConfig("values.value_{$i}_icon", $defaults[$i - 1][0])),
    ];
}

if (empty($values)) {
    $valuesRaw = (string)$getConfig('values.items', "Fair Play|Table signals, rule expectations, and outcome cues should stay transparent from the first tap.|⚖️\nMobile Clarity|Layouts, routes, and controls should remain readable during quick Call Break browsing on smaller screens.|📱\nFast Support|Account, payout, and gameplay questions should reach the right desk without extra friction.|💬");
    if (strpos($valuesRaw, '\n') !== false && strpos($valuesRaw, "\n") === false) {
        $valuesRaw = str_replace('\n', "\n", $valuesRaw);
    }
    foreach (preg_split('/[\r\n]+/', $valuesRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line);
        if (trim($parts[0] ?? '') !== '') {
            $values[] = [
                'title' => trim($parts[0]),
                'description' => trim($parts[1] ?? ''),
                'icon' => trim($parts[2] ?? '⭐'),
            ];
        }
    }
}

$leadStat = $stats[0] ?? null;
$trailStats = array_slice($stats, 1);
$statsLeadLabel = trim((string)$getConfig('stats.lead_label', 'Momentum Snapshot'));
?>

<section id="<?= $componentId ?>" class="cbl-about">
    <div class="about-shell">
        <header class="about-hero">
            <div class="hero-copy">
                <h1><?= htmlspecialchars($title) ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="story-panel">
                <span class="story-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                <?php foreach ($storyParagraphs as $paragraph): ?>
                    <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                <?php endforeach; ?>
            </div>
        </header>

        <?php if ($showStats && !empty($stats)): ?>
            <section class="stats-belt" aria-label="Brand statistics">
                <?php if ($leadStat): ?>
                    <article class="lead-stat">
                        <?php if ($statsLeadLabel !== ''): ?>
                            <span class="stat-overline"><?= htmlspecialchars($statsLeadLabel) ?></span>
                        <?php endif; ?>
                        <strong><?= htmlspecialchars($leadStat['value']) ?></strong>
                        <span class="stat-caption"><?= htmlspecialchars($leadStat['label']) ?></span>
                    </article>
                <?php endif; ?>

                <?php if (!empty($trailStats)): ?>
                    <div class="stat-grid">
                        <?php foreach ($trailStats as $stat): ?>
                            <article class="stat-card">
                                <strong><?= htmlspecialchars($stat['value']) ?></strong>
                                <span><?= htmlspecialchars($stat['label']) ?></span>
                            </article>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage">
                <div class="values-header">
                    <?php if ($valuesKicker !== ''): ?>
                        <span class="values-kicker"><?= htmlspecialchars($valuesKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <?php $cardClass = $index === 0 ? ' is-featured' : (($index % 3 === 2) ? ' is-tall' : ''); ?>
                        <article class="value-card<?= $cardClass ?>">
                            <div class="value-mark"><?= htmlspecialchars($value['icon']) ?></div>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <p><?= htmlspecialchars($value['description']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>

