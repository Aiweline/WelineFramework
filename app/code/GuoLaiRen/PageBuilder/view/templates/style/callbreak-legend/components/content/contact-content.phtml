<?php
/**
 * Call Break Legend - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: 联系方式和联系表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Get in Touch
 * hero.subtitle => 页面副标题:textarea:Need help with Call Break tables, account access, or payout questions? Use the contact routes below to reach the right desk quickly.
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@callbreaklegend.com
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:
 * social.twitter => Twitter链接:text:
 * social.linkedin => LinkedIn链接:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send us a Message
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share the table, account, or payout context so the support team can route your request faster.
 * form.queue_label => 表单辅助标签:text:Message Queue
 *
 * group:support => 辅助文案
 * support.summary_kicker => 联系摘要标签:text:Support Center
 * support.social_title => 社交区域标题:text:Follow The Desk
 *
 * group:map => 地图设置
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'cbl-contact-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $getConfig('content.title', $pageTitle)));
if ($title === '') {
    $title = 'Get in Touch';
}
$description = trim((string)$getConfig('hero.subtitle', $getConfig('content.description', 'Need help with Call Break tables, account access, or payout questions? Use the contact routes below to reach the right desk quickly.')));

$addressLabel = trim((string)$getConfig('contact_info.address_label', 'Address'));
$phoneLabel = trim((string)$getConfig('contact_info.phone_label', 'Phone'));
$emailLabel = trim((string)$getConfig('contact_info.email_label', 'Email'));
$workHoursLabel = trim((string)$getConfig('contact_info.work_hours_label', 'Support Hours'));
$email = trim((string)$getConfig('contact_info.email', $getConfig('contact.email', 'support@callbreaklegend.com')));
$phone = trim((string)$getConfig('contact_info.phone', $getConfig('contact.phone', '+91 1800-XXX-XXXX')));
$address = trim((string)$getConfig('contact_info.address', $getConfig('contact.address', 'Mumbai, India')));
$hours = trim((string)$getConfig('contact_info.work_hours', $getConfig('contact.hours', '24/7 Customer Support')));

$formTitle = trim((string)$getConfig('form.title', $getConfig('content.form_title', 'Send us a Message')));
$formNameLabel = trim((string)$getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string)$getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string)$getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string)$getConfig('form.message_label', 'Message'));
$formSubmitText = trim((string)$getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string)$getConfig('form.success_message', $getConfig('content.form_intro', 'Share the table, account, or payout context so the support team can route your request faster.')));
$formQueueLabel = trim((string)$getConfig('form.queue_label', 'Message Queue'));
$supportSummaryKicker = trim((string)$getConfig('support.summary_kicker', 'Support Center'));
$supportSocialTitle = trim((string)$getConfig('support.social_title', 'Follow The Desk'));
$mapEmbedUrl = trim((string)$getConfig('map.embed_url', ''));
$mapHeight = max(240, (int)$getConfig('map.height', 360));

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string)$getConfig($key, ''));
    if ($url === '') {
        continue;
    }
    $socials[] = [
        'name' => $label,
        'url' => $url,
    ];
}

if (empty($socials)) {
    $socialRaw = (string)$getConfig('social.items', "Facebook|#\nTwitter|#\nInstagram|#\nYouTube|#");
    if (strpos($socialRaw, '\n') !== false && strpos($socialRaw, "\n") === false) {
        $socialRaw = str_replace('\n', "\n", $socialRaw);
    }
    foreach (preg_split('/[\r\n]+/', $socialRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim($parts[0] ?? '') !== '') {
            $socials[] = [
                'name' => trim($parts[0]),
                'url' => trim($parts[1] ?? '#'),
            ];
        }
    }
}

$channels = [];
if ($email !== '') {
    $channels[] = ['icon' => '📧', 'label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email];
}
if ($phone !== '') {
    $channels[] = ['icon' => '📞', 'label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone];
}
if ($address !== '') {
    $channels[] = ['icon' => '📍', 'label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address];
}
if ($hours !== '') {
    $channels[] = ['icon' => '🕐', 'label' => $workHoursLabel !== '' ? $workHoursLabel : 'Support Hours', 'value' => $hours];
}
?>

<section id="<?= $componentId ?>" class="cbl-contact">
    <div class="contact-shell">
        <header class="contact-hero">
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <div class="contact-layout<?= !$showInfo ? ' is-form-only' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="support-rail">
                    <article class="support-summary">
                        <?php if ($supportSummaryKicker !== ''): ?>
                            <span class="summary-kicker"><?= htmlspecialchars($supportSummaryKicker) ?></span>
                        <?php endif; ?>
                        <h2><?= htmlspecialchars($hours !== '' ? $hours : $title) ?></h2>
                        <?php if ($description !== ''): ?>
                            <p><?= htmlspecialchars($description) ?></p>
                        <?php endif; ?>
                        <?php if ($pageContent !== ''): ?>
                            <div class="support-copy"><?= $pageContent ?></div>
                        <?php endif; ?>
                    </article>

                    <?php if (!empty($channels)): ?>
                        <div class="channel-grid">
                            <?php foreach ($channels as $channel): ?>
                                <article class="channel-card">
                                    <div class="channel-mark"><?= htmlspecialchars($channel['icon']) ?></div>
                                    <span class="channel-label"><?= htmlspecialchars($channel['label']) ?></span>
                                    <strong><?= htmlspecialchars($channel['value']) ?></strong>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <?php if ($showSocial && !empty($socials)): ?>
                        <div class="social-panel">
                            <?php if ($supportSocialTitle !== ''): ?>
                                <span class="social-title"><?= htmlspecialchars($supportSocialTitle) ?></span>
                            <?php endif; ?>
                            <div class="social-links">
                                <?php foreach ($socials as $social): ?>
                                    <a href="<?= htmlspecialchars($social['url']) ?>" class="social-link" target="_blank" rel="noopener" title="<?= htmlspecialchars($social['name']) ?>">
                                        <?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <div class="message-dock">
                    <div class="dock-head">
                        <?php if ($formQueueLabel !== ''): ?>
                            <span class="dock-kicker"><?= htmlspecialchars($formQueueLabel) ?></span>
                        <?php endif; ?>
                        <h2><?= htmlspecialchars($formTitle) ?></h2>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </div>

                    <form class="contact-form">
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formNameLabel !== '' ? $formNameLabel : 'Full Name') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formNameLabel !== '' ? $formNameLabel : 'Full Name') ?>">
                        </div>
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formEmailLabel !== '' ? $formEmailLabel : 'Email Address') ?></label>
                            <input type="email" placeholder="<?= htmlspecialchars($formEmailLabel !== '' ? $formEmailLabel : 'Email Address') ?>">
                        </div>
                        <div class="field">
                            <label><?= htmlspecialchars($formSubjectLabel !== '' ? $formSubjectLabel : 'Subject') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formSubjectLabel !== '' ? $formSubjectLabel : 'Subject') ?>">
                        </div>
                        <div class="field">
                            <label><?= htmlspecialchars($formMessageLabel !== '' ? $formMessageLabel : 'Message') ?></label>
                            <textarea placeholder="<?= htmlspecialchars($formMessageLabel !== '' ? $formMessageLabel : 'Message') ?>"></textarea>
                        </div>
                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </div>
            <?php endif; ?>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="contact-map">
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int)$mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

