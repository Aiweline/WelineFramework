$componentId = 'cbl-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) return;

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';
$showAvg = $getConfig('display.show_avg', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#0b1525'));
$accentColor = $getConfig('style.accent_color', '#f2a93b');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(11,21,37,0.7)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(30,185,128,0.2)');
$textColor = $getConfig('style.text_color', '#e9f5f2');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');

$kicker = $getConfig('texts.kicker', 'Community Feedback');
$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Say'));
$summary = $getConfig('texts.summary', 'Real comments from players who grind ranked tables and tournament rounds every week.');
$avgLabel = $getConfig('texts.avg_label', 'Average Rating');
$spotlightLabel = $getConfig('texts.spotlight_label', 'Top Voice');

$parseRating = function($raw) {
    $raw = trim((string)$raw);
    if ($raw === '') return 0;
    if (is_numeric($raw)) return (int)$raw;
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    [
        'name' => 'Arjun Mehta',
        'tag' => 'Table Captain',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Best part is timing. Every round moves fast, and reading bids actually feels rewarding.',
    ],
    [
        'name' => 'Neha Iyer',
        'tag' => 'Daily Grinder',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Quick sessions still feel meaningful. I can play one table and leave with a real skill win.',
    ],
    [
        'name' => 'Kabir Singh',
        'tag' => 'League Player',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Ranked ladders are fair and the challenge curve feels right at every level.',
    ],
    [
        'name' => 'Priya Nair',
        'tag' => 'VIP Room',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'Good balance of clean UI and strong competition. No clutter, just game focus.',
    ],
    [
        'name' => 'Amit Patel',
        'tag' => 'Tournament Regular',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Weekend events are smooth and payouts are fast. Easy recommendation.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i - 1] ?? ['name' => '', 'tag' => '', 'rating' => '⭐⭐⭐⭐⭐', 'text' => ''];
    $name = trim((string)$getConfig("texts.testimonial_{$i}_name", $defaults['name']));
    $tag = trim((string)$getConfig("texts.testimonial_{$i}_tag", $defaults['tag']));
    $ratingText = $getConfig("texts.testimonial_{$i}_rating", $defaults['rating']);
    $content = trim((string)$getConfig("texts.testimonial_{$i}_content", $defaults['text']));
    $avatar = trim((string)$getConfig("avatars.avatar_{$i}", ''));

    if ($name !== '' && $content !== '') {
        $ratingValue = max(0, min(5, $parseRating($ratingText)));
        $ratingDisplay = is_numeric($ratingText) ? str_repeat('★', (int)$ratingText) : (string)$ratingText;
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => $ratingValue,
            'rating_text' => trim($ratingDisplay) !== '' ? $ratingDisplay : str_repeat('★', max(1, $ratingValue)),
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($testimonials)) {
    foreach ($defaultTestimonials as $fallback) {
        $testimonials[] = [
            'name' => $fallback['name'],
            'tag' => $fallback['tag'],
            'rating' => $parseRating($fallback['rating']),
            'rating_text' => $fallback['rating'],
            'text' => $fallback['text'],
            'avatar' => '',
        ];
    }
}

$totalRating = array_sum(array_column($testimonials, 'rating'));
$avgRating = count($testimonials) ? $totalRating / count($testimonials) : 0;
$avgRatingLabel = number_format($avgRating, 1);

$spotlight = $testimonials[0] ?? null;
$cards = array_slice($testimonials, 1);
if (empty($cards) && $spotlight) {
    $cards = [$spotlight];
}

$ratingBuckets = [5 => 0, 4 => 0, 3 => 0, 2 => 0, 1 => 0];
foreach ($testimonials as $t) {
    $bucket = max(1, min(5, (int)$t['rating']));
    $ratingBuckets[$bucket]++;
}
$bucketMax = max(1, max($ratingBuckets));

$buildInitials = function($name) {
    $parts = preg_split('/\s+/', trim((string)$name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};
?>

<section id="<?= $componentId ?>" class="cbl-testimonials">
    <div class="voices-wrap">
        <?php if ($showTitle): ?>
            <header class="voices-header">
                <?php if ($kicker !== ''): ?>
                    <span class="voices-kicker"><?= htmlspecialchars($kicker) ?></span>
                <?php endif; ?>
                <h2><?= htmlspecialchars($title) ?></h2>
                <?php if ($summary !== ''): ?>
                    <p><?= htmlspecialchars($summary) ?></p>
                <?php endif; ?>
            </header>
        <?php endif; ?>

        <div class="voices-layout">
            <?php if ($showAvg): ?>
                <div class="voice-scoreboard layout-scoreboard">
                    <div class="score-main">
                        <strong><?= htmlspecialchars($avgRatingLabel) ?></strong>
                        <span><?= htmlspecialchars($avgLabel) ?></span>
                    </div>
                    <div class="score-bars">
                        <?php foreach ($ratingBuckets as $star => $count): ?>
                            <?php $width = ($count / $bucketMax) * 100; ?>
                            <div class="score-row">
                                <span><?= (int)$star ?>★</span>
                                <div class="score-track"><i style="width: <?= number_format($width, 2, '.', '') ?>%;"></i></div>
                                <b><?= (int)$count ?></b>
                            </div>
                        <?php endforeach; ?>
                    </div>
                </div>
            <?php endif; ?>

            <?php if ($spotlight): ?>
                <article class="voice-spotlight">
                    <div class="spotlight-top">
                        <span class="spotlight-label"><?= htmlspecialchars($spotlightLabel) ?></span>
                        <?php if ($showRating): ?>
                            <span class="spotlight-stars"><?= htmlspecialchars($spotlight['rating_text']) ?></span>
                        <?php endif; ?>
                    </div>
                    <blockquote>"<?= htmlspecialchars($spotlight['text']) ?>"</blockquote>
                    <footer class="spotlight-footer">
                        <?php if ($showAvatar): ?>
                            <div class="spotlight-avatar">
                                <?php if (!empty($spotlight['avatar'])): ?>
                                    <img src="<?= htmlspecialchars($spotlight['avatar']) ?>" alt="<?= htmlspecialchars($spotlight['name']) ?>">
                                <?php else: ?>
                                    <?= htmlspecialchars($buildInitials($spotlight['name'])) ?>
                                <?php endif; ?>
                            </div>
                        <?php endif; ?>
                        <div>
                            <strong><?= htmlspecialchars($spotlight['name']) ?></strong>
                            <?php if ($spotlight['tag'] !== ''): ?>
                                <span><?= htmlspecialchars($spotlight['tag']) ?></span>
                            <?php endif; ?>
                        </div>
                    </footer>
                </article>
            <?php endif; ?>

            <div class="voices-right">
                <div class="voice-grid">
                    <?php foreach ($cards as $index => $t): ?>
                        <?php $cardWide = $index % 3 === 0 ? ' is-wide' : ''; ?>
                        <article class="voice-card<?= $cardWide ?>">
                            <div class="voice-card-head">
                                <?php if ($showAvatar): ?>
                                    <div class="voice-avatar">
                                        <?php if (!empty($t['avatar'])): ?>
                                            <img src="<?= htmlspecialchars($t['avatar']) ?>" alt="<?= htmlspecialchars($t['name']) ?>">
                                        <?php else: ?>
                                            <?= htmlspecialchars($buildInitials($t['name'])) ?>
                                        <?php endif; ?>
                                    </div>
                                <?php endif; ?>
                                <div class="voice-meta">
                                    <strong><?= htmlspecialchars($t['name']) ?></strong>
                                    <?php if ($t['tag'] !== ''): ?>
                                        <span><?= htmlspecialchars($t['tag']) ?></span>
                                    <?php endif; ?>
                                </div>
                                <?php if ($showRating): ?>
                                    <span class="voice-stars"><?= htmlspecialchars($t['rating_text']) ?></span>
                                <?php endif; ?>
                            </div>
                            <p>"<?= htmlspecialchars($t['text']) ?>"</p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </div>
        </div>
    </div>
</section>

