    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.8rem;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--cbl-legal-heading);
    border: 1px solid rgba(242, 169, 59, 0.26);
    background: rgba(242, 169, 59, 0.12);
}

