    scroll-margin-top: 120px;
}

#<?= $componentId ?> .legal-content h2 {
    margin: 2rem 0 0.9rem;
    color: var(--cbl-legal-heading);
    font-size: 1.55rem;
    line-height: 1.2;
}

#<?= $componentId ?> .legal-content h3 {
    margin: 1.6rem 0 0.7rem;
    color: var(--cbl-legal-hero-title);
    font-size: 1.2rem;
}

