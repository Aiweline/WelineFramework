    position: relative;
    padding: 84px 0;
    min-height: 100vh;
    background:
        radial-gradient(720px 360px at 10% 8%, rgba(30, 185, 128, 0.12), transparent 72%),
        radial-gradient(680px 360px at 88% 16%, rgba(242, 169, 59, 0.1), transparent 70%),
        linear-gradient(180deg, var(--cbl-legal-hero-bg) 0%, var(--cbl-legal-hero-end) 48%, var(--cbl-legal-hero-bg) 100%);
}

#<?= $componentId ?> .legal-shell {
    width: min(var(--cbl-legal-max-width), calc(100% - 2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

#<?= $componentId ?> .legal-hero {
    padding-top: var(--cbl-legal-header-padding);
    max-width: 760px;
    margin-bottom: 1rem;
}

