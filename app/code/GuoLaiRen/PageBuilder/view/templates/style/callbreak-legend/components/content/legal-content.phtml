    color: var(--cbl-legal-heading);
}

#<?= $componentId ?> .legal-content blockquote {
    margin: 1.2rem 0;
    padding: 1rem 1.1rem;
    border-left: 4px solid rgba(242, 169, 59, 0.65);
    background: rgba(242, 169, 59, 0.08);
    border-radius: 0 14px 14px 0;
}

#<?= $componentId ?> .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0;
}

#<?= $componentId ?> .legal-content th,
#<?= $componentId ?> .legal-content td {
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--cbl-legal-toc-border);
    text-align: left;
}

#<?= $componentId ?> .legal-content th {
    color: var(--cbl-legal-hero-title);
    background: rgba(5, 16, 30, 0.68);
}

@media (max-width: 1024px) {
    #<?= $componentId ?> .legal-layout.has-toc {
        grid-template-columns: 1fr;
    }

    #<?= $componentId ?> .legal-toc {
        position: static;
    }
}

@media (max-width: 768px) {
    #<?= $componentId ?> {
        padding: 68px 0;
    }

    #<?= $componentId ?> .legal-shell {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .toc-card,
    #<?= $componentId ?> .legal-article {
        border-radius: 20px;
    }

    #<?= $componentId ?> .legal-article {
        padding: max(20px, calc(var(--cbl-legal-content-padding) * 0.7));
    }
