    border-radius: 24px;
    border: 1px solid var(--cbl-legal-toc-border);
    box-shadow: 0 22px 52px rgba(2, 6, 12, 0.4);
}

#<?= $componentId ?> .toc-card {
    padding: 1.15rem;
    background: var(--cbl-legal-toc-bg);
}

#<?= $componentId ?> .toc-title {
    display: block;
    color: var(--cbl-legal-hero-title);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

#<?= $componentId ?> .toc-links {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.4rem;
}

#<?= $componentId ?> .toc-link {
    color: var(--cbl-legal-content-text);
    text-decoration: none;
