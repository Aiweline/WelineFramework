// 处理高亮词汇
function highlightText($text, $word, $style) {
    if (empty($word)) return $text;
    $styleAttr = '';
    if ($style === 'italic') $styleAttr = 'font-style: italic;';
    elseif ($style === 'bold') $styleAttr = 'font-weight: bold;';
    return str_replace($word, '<em style="' . $styleAttr . '">' . $word . '</em>', $text);
}

