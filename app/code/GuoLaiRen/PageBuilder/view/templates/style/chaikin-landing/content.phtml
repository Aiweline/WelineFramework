// 弹窗三端响应式解析函数
function parsePopupResponsive($value) {
    if (empty($value)) return ['mobile' => '20px', 'tablet' => '32px', 'desktop' => '48px'];
    $value = trim($value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '20px', 'tablet' => '32px', 'desktop' => '48px'];
    switch (count($parts)) {
        case 1: 
            $val = trim($parts[0]);
            $result['mobile'] = $val . $unit;
            $result['tablet'] = $val . $unit;
            $result['desktop'] = $val . $unit;
            break;
        case 2:
            $result['mobile'] = trim($parts[0]) . $unit;
            $result['tablet'] = trim($parts[1]) . $unit;
            $result['desktop'] = trim($parts[1]) . $unit;
            break;
        case 3:
            $result['mobile'] = trim($parts[0]) . $unit;
            $result['tablet'] = trim($parts[1]) . $unit;
            $result['desktop'] = trim($parts[2]) . $unit;
            break;
    }
    return $result;
}

