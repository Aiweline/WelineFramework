<script>
function closeChaikinPopup() {
    const popup = document.getElementById('chaikin-popup-overlay');
    if (popup) {
        popup.style.display = 'none';
    }
}

// CTA 事件绑定
document.addEventListener('DOMContentLoaded', function() {
    // 获取页面 handle 用于生成事件名
    <?php 
    $pageHandleForEvent = $page ? preg_replace('/[^a-zA-Z0-9_-]+/', '-', (string)$page->getData('handle')) : '';
    $pageDefaultCtaEvent = $page ? trim((string)$page->getData('cta_event_name')) : '';
    ?>
    var pageHandle = '<?= htmlspecialchars($pageHandleForEvent ?? '') ?>';
    var pageDefaultEvent = '<?= htmlspecialchars($pageDefaultCtaEvent ?? '') ?>';
    
    // 为弹窗按钮绑定事件
    var popupBtns = document.querySelectorAll('.chaikin-popup-btn');
    if (popupBtns && popupBtns.length > 0) {
        popupBtns.forEach(function(btn) {
            var isPrimary = btn.classList.contains('chaikin-popup-btn-primary');
            var eventName = '';
            
            if (pageDefaultEvent !== '') {
                eventName = pageDefaultEvent + (isPrimary ? '_primary' : '_secondary');
            } else {
                eventName = 'cta_' + pageHandle + '_popup_' + (isPrimary ? 'primary' : 'secondary');
            }
            
            btn.addEventListener('click', function() {
                // 使用通用跟踪函数
                window.trackCTA(eventName, isPrimary ? 'primary' : 'secondary');
            }, { once: false });
        });
    }
});

// 延迟显示弹窗
(function() {
    const delay = <?= $popupDelay ?> * 1000; // 转换为毫秒
    
    setTimeout(function() {
        const popup = document.getElementById('chaikin-popup-overlay');
        if (popup) {
            popup.style.display = 'flex';
        }
    }, delay);
    
    // 点击背景关闭
    document.getElementById('chaikin-popup-overlay')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeChaikinPopup();
        }
    });
    
    // ESC键关闭
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeChaikinPopup();
        }
    });
})();
</script>
