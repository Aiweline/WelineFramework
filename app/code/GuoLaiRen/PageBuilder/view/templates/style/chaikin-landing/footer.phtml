$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

function getFooterConfig($settings, $key, $default = '') {
    return $settings[$key] ?? $default;
}

function parseFooterResponsive($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => ''];
    $value = trim($value);
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
    switch (count($parts)) {
        case 1: $result['mobile'] = $result['desktop'] = trim($parts[0]); break;
        case 2: $result['mobile'] = trim($parts[0]); $result['desktop'] = trim($parts[1]); break;
    }
    return $result;
}

function genFooterCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
}

// 法律声明配置
$noticeText = getFooterConfig($styleSettings, 'legal.notice_text', 'Legal Notices: Here is our Disclosures and Details page. DISCLOSURES ABOUT OUR BUSINESS contains critical information that will help you use our work appropriately and give you a far better understanding of how our business works - both the benefits it might offer you and the inevitable limitations of our products. Although this is not a part of our "Disclosures and Details" page, you can view our company\'s privacy policy here.');
$noticeColor = getFooterConfig($styleSettings, 'legal.notice_color', '#666666');
$noticeSize = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'legal.notice_size', '11/12') . 'px'));
$noticeLineHeight = getFooterConfig($styleSettings, 'legal.notice_line_height', '1.6');
$noticeMargin = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'legal.notice_margin', '20/30') . 'px'));

$disclosureText = getFooterConfig($styleSettings, 'legal.disclosure_link_text', 'Disclosures and Details');
$disclosureUrl = getFooterConfig($styleSettings, 'legal.disclosure_link_url', '#');
$privacyText = getFooterConfig($styleSettings, 'legal.privacy_link_text', 'here');
$privacyUrl = getFooterConfig($styleSettings, 'legal.privacy_link_url', '#');
$linkColor = getFooterConfig($styleSettings, 'legal.link_color', '#0066cc');
$linkHoverColor = getFooterConfig($styleSettings, 'legal.link_hover_color', '#0052a3');

// 版权配置
$copyrightText = getFooterConfig($styleSettings, 'copyright.text', '© 2025 Chaikin Analytics. All rights reserved.');
$copyrightColor = getFooterConfig($styleSettings, 'copyright.color', '#999999');
$copyrightSize = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'copyright.size', '11/12') . 'px'));
$copyrightMargin = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'copyright.margin', '20/30') . 'px'));

// 页脚链接配置
$linksDisplay = getFooterConfig($styleSettings, 'links.display', 'yes');
$linksColor = getFooterConfig($styleSettings, 'links.color', '#666666');
$linksHoverColor = getFooterConfig($styleSettings, 'links.hover_color', '#333333');
$linksSize = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'links.size', '11/12') . 'px'));
$linksSeparator = getFooterConfig($styleSettings, 'links.separator', '|');
$linksMargin = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'links.margin', '15/20') . 'px'));

$footerLinks = [];
for ($i = 1; $i <= 6; $i++) {
    $text = getFooterConfig($styleSettings, "links.item{$i}_text", '');
    $url = getFooterConfig($styleSettings, "links.item{$i}_url", '#');
    if ($text) {
        $footerLinks[] = ['text' => $text, 'url' => $url];
    }
}

// 如果没有配置任何链接，使用默认链接
if (empty($footerLinks)) {
    $footerLinks = [
        ['text' => 'Full Disclaimer', 'url' => '#'],
        ['text' => 'Privacy', 'url' => '#'],
        ['text' => 'Terms & Conditions', 'url' => '#'],
        ['text' => 'Ad Choices', 'url' => '#'],
        ['text' => 'Do Not Sell My Personal Information', 'url' => '#'],
        ['text' => 'Cookie Preferences', 'url' => '#'],
    ];
}

// 页脚样式
$footerBg = getFooterConfig($styleSettings, 'footer.background', '#ffffff');
$footerPaddingV = genFooterCSS(parseFooterResponsive(getFooterConfig($styleSettings, 'footer.padding_v', '30/40') . 'px'));
$footerBorderTop = getFooterConfig($styleSettings, 'footer.border_top', 'yes');
$footerBorderColor = getFooterConfig($styleSettings, 'footer.border_color', '#e5e5e5');

// 处理法律声明中的链接占位符
$noticeProcessed = str_replace('Disclosures and Details', '<a href="' . htmlspecialchars($disclosureUrl ?? '') . '" style="color: ' . htmlspecialchars($linkColor ?? '') . '; text-decoration: underline;">' . htmlspecialchars($disclosureText ?? '') . '</a>', $noticeText);
$noticeProcessed = str_replace('here', '<a href="' . htmlspecialchars($privacyUrl ?? '') . '" style="color: ' . htmlspecialchars($linkColor ?? '') . '; text-decoration: underline;">' . htmlspecialchars($privacyText ?? '') . '</a>', $noticeProcessed);
?>

