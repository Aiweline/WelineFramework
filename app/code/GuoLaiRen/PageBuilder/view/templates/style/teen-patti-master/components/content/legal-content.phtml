<?php
/**
 * Teen Patti Master - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录与更新时间
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:medium|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:40|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.updated_label => 更新时间前缀:text:Last Updated
 * header.bg_color => 背景色:color:#1a2a4e
 * header.bg_gradient_end => 渐变结束色:color:#243a6b
 * header.title_color => 标题颜色:color:#ffd700
 * header.text_color => 文字颜色:color:#9ca3af
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Table of Contents
 * toc.items => 章节配置:textarea:
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.05)
 * toc.border_color => 目录边框色:color:rgba(251,191,36,0.2)
 *
 * group:content => 内容设置
 * content.body => 引言内容:textarea:
 * content.empty_text => 空内容提示:text:Content will be displayed here.
 * content.bg_color => 内容区背景色:color:rgba(255,255,255,0.05)
 * content.text_color => 内容文字颜色:color:#d1d5db
 * content.heading_color => 标题颜色:color:#ffd700
 * content.link_color => 链接颜色:color:#ffd700
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$page = $this->getData('page');
$componentId = 'tpm-legal-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string)$getConfig('layout.content_width', 'medium');
$headerPadding = max(40, (int)$getConfig('layout.header_padding', 80));
$contentPadding = max(24, (int)$getConfig('layout.content_padding', 40));

$pageType = $page ? (string)($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string)($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string)($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$headerTitle = trim((string)$getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}
$updatedLabelPrefix = trim((string)$getConfig('header.updated_label', 'Last Updated'));

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$headerIcon = trim((string)$getConfig('header.icon', $typeIcons[$pageType] ?? '📄'));
$tocTitle = trim((string)$getConfig('toc.title', 'Table of Contents'));
$tocItemsConfig = trim((string)$getConfig('toc.items', ''));

$heroBg = (string)$getConfig('header.bg_color', '#1a2a4e');
$heroBgEnd = (string)$getConfig('header.bg_gradient_end', '#243a6b');
$heroTitleColor = (string)$getConfig('header.title_color', '#ffd700');
$heroTextColor = (string)$getConfig('header.text_color', '#9ca3af');
$tocBg = (string)$getConfig('toc.bg_color', 'rgba(255,255,255,0.05)');
$tocBorder = (string)$getConfig('toc.border_color', 'rgba(251,191,36,0.2)');
$contentBg = (string)$getConfig('content.bg_color', 'rgba(255,255,255,0.05)');
$contentText = (string)$getConfig('content.text_color', '#d1d5db');
$contentHeading = (string)$getConfig('content.heading_color', '#ffd700');
$contentLink = (string)$getConfig('content.link_color', '#ffd700');
$contentBody = trim((string)$getConfig('content.body', ''));
$contentEmptyText = trim((string)$getConfig('content.empty_text', 'Content will be displayed here.'));

$maxWidth = match ($contentWidth) {
    'wide' => '1080px',
    'narrow' => '760px',
    default => '900px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }
        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (++$headingIndex);
        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => (int)$matches[1],
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}
$pageContent = trim((string)$pageContent);
if ($pageContent === '' && $tocItemsConfig !== '') {
    $rebuiltSections = [];
    foreach (preg_split('/[\r\n]+/', $tocItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $heading = trim((string)($parts[0] ?? ''));
        $body = trim((string)($parts[1] ?? ''));
        if ($heading === '') {
            continue;
        }
        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $heading));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (count($tocItems) + 1);
        $tocItems[] = [
            'id' => $id,
            'text' => $heading,
            'level' => 2,
        ];
        $rebuiltSections[] = '<h2 id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . htmlspecialchars($heading) . '</h2>';
        if ($body !== '') {
            $rebuiltSections[] = '<p>' . nl2br(htmlspecialchars($body)) . '</p>';
        }
    }
    $pageContent = implode('', $rebuiltSections);
}
$introContent = $contentBody;
$hasToc = $showToc && !empty($tocItems);

$formattedUpdated = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('F j, Y', $timestamp);
    }
}
?>

<section id="<?= $componentId ?>">
<style>
#<?= $componentId ?> {
    background: linear-gradient(180deg, <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?> 0%, <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?> 100%);
    padding: 80px 0;
    min-height: 100vh;
}
#<?= $componentId ?> .container {
    max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;
    margin: 0 auto;
    padding: 0 20px;
}
#<?= $componentId ?> .header {
    text-align: center;
    margin-bottom: 36px;
    padding-top: <?= (int)$headerPadding ?>px;
}
#<?= $componentId ?> .header-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin-bottom: 18px;
    border-radius: 16px;
    background: rgba(251, 191, 36, 0.14);
    border: 1px solid rgba(251, 191, 36, 0.2);
    font-size: 1.6rem;
}
#<?= $componentId ?> h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>;
    margin-bottom: 16px;
}
#<?= $componentId ?> .last-updated {
    font-size: 0.9rem;
    color: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>;
}
#<?= $componentId ?> .toc {
    background: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>;
    border: 1px solid <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>;
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 24px;
}
#<?= $componentId ?> .toc-title {
    font-size: 1rem;
    font-weight: 700;
    color: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>;
    margin-bottom: 14px;
}
#<?= $componentId ?> .toc-links {
    display: grid;
    gap: 10px;
}
#<?= $componentId ?> .toc-link {
    color: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>;
    text-decoration: none;
    line-height: 1.6;
}
#<?= $componentId ?> .toc-link.level-3 {
    padding-left: 14px;
    opacity: 0.9;
}
#<?= $componentId ?> .content {
    background: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>;
    border: 1px solid <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>;
    border-radius: 20px;
    padding: <?= (int)$contentPadding ?>px;
    color: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>;
    line-height: 1.8;
}
#<?= $componentId ?> .content h2,
#<?= $componentId ?> .content h3 {
    color: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>;
    scroll-margin-top: 120px;
}
#<?= $componentId ?> .content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 16px;
}
#<?= $componentId ?> .content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 24px;
    margin-bottom: 12px;
}
#<?= $componentId ?> .content p {
    margin-bottom: 16px;
}
#<?= $componentId ?> .content ul,
#<?= $componentId ?> .content ol {
    margin-bottom: 16px;
    padding-left: 24px;
}
#<?= $componentId ?> .content li {
    margin-bottom: 8px;
}
#<?= $componentId ?> .content a {
    color: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>;
    text-decoration: underline;
}
@media (max-width: 768px) {
    #<?= $componentId ?> h1 {
        font-size: 1.85rem;
    }
    #<?= $componentId ?> .content {
        padding: 24px;
    }
}
</style>

<div class="container">
    <div class="header">
        <?php if ($showIcon && $headerIcon !== ''): ?>
        <div class="header-icon"><?= htmlspecialchars($headerIcon) ?></div>
        <?php endif; ?>
        <h1><?= htmlspecialchars($headerTitle) ?></h1>
        <?php if ($formattedUpdated !== ''): ?>
        <div class="last-updated"><?= htmlspecialchars($updatedLabelPrefix !== '' ? $updatedLabelPrefix : 'Last Updated') ?>: <?= htmlspecialchars($formattedUpdated) ?></div>
        <?php endif; ?>
    </div>

    <?php if ($introContent !== ''): ?>
    <div class="content" style="margin-bottom: 24px;">
        <p><?= nl2br(htmlspecialchars($introContent)) ?></p>
    </div>
    <?php endif; ?>

    <?php if ($hasToc): ?>
    <nav class="toc">
        <div class="toc-title"><?= htmlspecialchars($tocTitle) ?></div>
        <div class="toc-links">
            <?php foreach ($tocItems as $item): ?>
            <a class="toc-link level-<?= (int)$item['level'] ?>" href="#<?= htmlspecialchars($item['id']) ?>"><?= htmlspecialchars($item['text']) ?></a>
            <?php endforeach; ?>
        </div>
    </nav>
    <?php endif; ?>

    <div class="content">
        <?php if ($pageContent !== ''): ?>
            <?= $pageContent ?>
        <?php else: ?>
            <p><?= htmlspecialchars($contentEmptyText !== '' ? $contentEmptyText : 'Content will be displayed here.') ?></p>
        <?php endif; ?>
    </div>
</div>
</section>
