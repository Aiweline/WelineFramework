<script>
(function() {
    var container = document.getElementById('<?= $componentId ?>');
    if (!container) return;

    container.querySelectorAll('.faq-toggle').forEach(function(toggle) {
        toggle.addEventListener('click', function() {
            var item = this.closest('.faq-card');
            if (!item) return;

            var wasOpen = item.classList.contains('is-open');
            container.querySelectorAll('.faq-card').forEach(function(card) {
                card.classList.remove('is-open');
            });

            if (!wasOpen) {
                item.classList.add('is-open');
            }
        });
    });
})();
</script>
