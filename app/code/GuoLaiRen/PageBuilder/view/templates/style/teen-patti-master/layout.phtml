<?php
/**
 * Teen Patti Master - Main Layout
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$templateCode = 'teen-patti-master';

$layoutConfig = $this->getData('layout_config') ?: [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];

if (empty($headerComponents)) {
    $headerComponents = [['code' => 'header-nav', 'enabled' => true, 'config' => []]];
}

if (empty($contentComponents)) {
    $contentComponents = [
        ['code' => 'hero-slider', 'enabled' => true, 'config' => []],
        ['code' => 'advantages', 'enabled' => true, 'config' => []],
        ['code' => 'games-showcase', 'enabled' => true, 'config' => []],
        ['code' => 'testimonials', 'enabled' => true, 'config' => []],
        ['code' => 'faq', 'enabled' => true, 'config' => []],
    ];
}

if (empty($footerComponents)) {
    $footerComponents = [['code' => 'footer-links', 'enabled' => true, 'config' => []]];
}

$componentFiles = [
    'header-nav' => 'header/nav.phtml',
    'hero-slider' => 'content/hero-slider.phtml',
    'advantages' => 'content/advantages.phtml',
    'games-showcase' => 'content/games.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'faq' => 'content/faq.phtml',
    'about-content' => 'content/about-content.phtml',
    'contact-content' => 'content/contact-content.phtml',
    'legal-content' => 'content/legal-content.phtml',
    'footer-links' => 'footer/links.phtml',
];

$renderComponent = function($component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];

    if (!$enabled || empty($code)) return '';

    $file = $componentFiles[$code] ?? null;
    if (!$file) return "<!-- Component not found: {$code} -->";

    ob_start();
    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', $componentConfig);
    echo $this->fetchTemplate("GuoLaiRen_PageBuilder::style/teen-patti-master/components/{$file}");
    return ob_get_clean();
};

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$pageTitle = $page ? $page->getData('title') : 'Teen Patti Master';
$pageDescription = $page ? $page->getData('meta_description') : '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($pageTitle) ?></title>
    <?php if ($pageDescription): ?>
    <meta name="description" content="<?= htmlspecialchars($pageDescription) ?>">
    <?php endif; ?>

    <w:template>GuoLaiRen_PageBuilder::base/tracking.phtml</w:template>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    'abpro-purple': '<?= htmlspecialchars($colors['section_bg_2'] ?? '#243a6b') ?>',
                    'abpro-gold': '<?= htmlspecialchars($colors['accent_primary'] ?? '#ffd700') ?>',
                    'abpro-dark': '<?= htmlspecialchars($colors['body_bg'] ?? '#1a2a4e') ?>',
                }
            }
        }
    }
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: <?= htmlspecialchars($colors['body_bg'] ?? '#1a2a4e') ?>;
            color: #ffffff;
            overflow-x: hidden;
        }
    </style>
</head>
<body>
    <header class="abpro-region-header" data-region="header">
        <?php if (!empty($headerComponents)): ?>
            <?php foreach ($headerComponents as $component): ?>
                <?php if ($component['enabled'] ?? true): ?>
                <div class="abpro-component-wrapper" data-component="<?= htmlspecialchars($component['code']) ?>">
                    <?= $renderComponent($component) ?>
                </div>
                <?php endif; ?>
            <?php endforeach; ?>
        <?php endif; ?>
    </header>

    <main class="abpro-region-content" data-region="content">
        <?php if (!empty($contentComponents)): ?>
            <?php foreach ($contentComponents as $index => $component): ?>
                <?php if ($component['enabled'] ?? true): ?>
                <div class="abpro-component-wrapper" data-component="<?= htmlspecialchars($component['code']) ?>" data-index="<?= $index ?>">
                    <?= $renderComponent($component) ?>
                </div>
                <?php endif; ?>
            <?php endforeach; ?>
        <?php endif; ?>
    </main>

    <footer class="abpro-region-footer" data-region="footer">
        <?php if (!empty($footerComponents)): ?>
            <?php foreach ($footerComponents as $component): ?>
                <?php if ($component['enabled'] ?? true): ?>
                <div class="abpro-component-wrapper" data-component="<?= htmlspecialchars($component['code']) ?>">
                    <?= $renderComponent($component) ?>
                </div>
                <?php endif; ?>
            <?php endforeach; ?>
        <?php endif; ?>
    </footer>
</body>
</html>
