{
    "$schema": "2.1.0",
    "template": "teen-patti-master",
    "name": "Teen Patti Master",
    "description": "Modern responsive theme for Andar Bahar card game with Tailwind CSS",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航、Logo等",
            "multiple": false,
            "required": true,
            "accepts": [
                "header"
            ],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": [
                "content",
                "widget"
            ],
            "default_components": [
                "hero-slider",
                "advantages",
                "games-showcase",
                "testimonials",
                "faq"
            ],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含版权、链接等",
            "multiple": false,
            "required": true,
            "accepts": [
                "footer"
            ],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "现代响应式导航",
            "name_en": "Modern Responsive Navigation",
            "description": "深紫金色主题，移动端汉堡菜单，桌面端横向导航",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "header"
            ],
            "config_groups": [
                "logo",
                "navigation"
            ],
            "file": "header/nav.phtml"
        },
        "hero-slider": {
            "name": "Hero轮播区",
            "name_en": "Hero Slider",
            "description": "全屏视差效果，动态渐变背景",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "content"
            ],
            "config_groups": [
                "hero"
            ],
            "file": "content/hero-slider.phtml"
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages",
            "description": "展示产品核心优势",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "content"
            ],
            "config_groups": [
                "section"
            ],
            "file": "content/advantages.phtml"
        },
        "games-showcase": {
            "name": "游戏展示区",
            "name_en": "Games Showcase",
            "description": "3D卡片式游戏展示，响应式网格布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 30,
            "is_default": true,
            "required": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "content"
            ],
            "config_groups": [
                "section",
                "games"
            ],
            "file": "content/games.phtml"
        },
        "testimonials": {
            "name": "用户评价",
            "name_en": "Testimonials",
            "description": "用户评价展示",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 40,
            "is_default": true,
            "required": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "content"
            ],
            "config_groups": [],
            "file": "content/testimonials.phtml"
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ",
            "description": "FAQ折叠面板",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 50,
            "is_default": true,
            "required": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "content"
            ],
            "config_groups": [],
            "file": "content/faq.phtml"
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer Links",
            "description": "多列链接布局，社交媒体图标",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": [
                "*"
            ],
            "placeable_in": [
                "footer"
            ],
            "config_groups": [
                "footer"
            ],
            "file": "footer/links.phtml"
        }
    }
}