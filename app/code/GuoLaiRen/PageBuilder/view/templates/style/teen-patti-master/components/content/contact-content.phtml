                    <div>
                        <div class="info-label"><?= htmlspecialchars((string)$channel['label']) ?></div>
                        <div class="info-value">
                            <?php if ($channel['href'] !== ''): ?>
                            <a href="<?= htmlspecialchars($channel['href']) ?>"><?= htmlspecialchars($channel['value']) ?></a>
