<?php
/**
 * TPMST Banner 组件 - Banner Component
 * 
 * 独立的 Banner 横幅组件，用于 content 区域
 * 
 * @component_start
 * code: banner
 * name: Banner横幅
 * name_en: Banner
 * description: 首屏Banner横幅，支持响应式图片和下载按钮
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.webp
 * @component_end
 * 
 * @fields_start
 * 
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端图片:textarea:|默认使用本地banner-2.jpg
 * banner.image_desktop => PC端图片:textarea:|默认使用本地banner-03.webp
 * banner.alt => 图片描述:text:100000 earn on teenpatti master
 * banner.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn-m.webp
 * banner.bg_color => 背景颜色:color:#0c0060
 * banner.bg_gradient_end => 背景渐变色结束:color:#1d1850
 * banner.image_offset_top => 图片向上偏移:number:90|px（用于与header重叠效果）
 * banner.image_offset_top_mobile => 移动端容器向上偏移:number:75|px
 * 
 * @fields_end
 */

// 组件唯一标识
$componentId = 'tpmst-banner-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并配置
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数
$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// Banner配置
$bannerDisplay = $getConfig('banner.display', 'yes') !== 'no';
$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/download-btn-m.webp');

$bannerMobile = $getConfig('banner.image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('banner.image_desktop', '') ?: $defaultBannerDesktop;
$bannerAlt = $getConfig('banner.alt', '100000 earn on teenpatti master');
$bannerDownloadImg = $getConfig('banner.download_btn_image', '') ?: $defaultDownloadBtn;
$bannerBgColor = $getConfig('banner.bg_color', '#0c0060');
$bannerBgGradientEnd = $getConfig('banner.bg_gradient_end', '#1d1850');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/poker-header-bg.svg');

// Banner 图片负边距补偿值（用于与 header 重叠效果）
$bannerImageOffsetTop = intval($getConfig('banner.image_offset_top', '90')); // 单位：px，桌面端图片的 margin-top 负值
$bannerImageOffsetTopMobile = intval($getConfig('banner.image_offset_top_mobile', '75')); // 单位：px，移动端 banner 容器的 margin-top 负值

if (!$bannerDisplay) return;
?>
<!-- TPMST Banner Component Start: <?= $componentId ?> -->
<style>
#<?= $componentId ?> .tpmst-banner {
    position: relative;
    background: linear-gradient(180deg, <?= htmlspecialchars($bannerBgColor) ?> 0%, <?= htmlspecialchars($bannerBgGradientEnd) ?> 100%);
    padding: clamp(60px, 10vw, 120px) 0;
    overflow: hidden;
}

#<?= $componentId ?> .tpmst-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('<?= $pokerBg ?>') center top/cover no-repeat;
    opacity: 0.18;
    pointer-events: none;
}

#<?= $componentId ?> .tpmst-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(400px 200px at 20% 20%, rgba(255, 215, 0, 0.18), transparent 70%),
        radial-gradient(420px 220px at 80% 30%, rgba(154, 36, 193, 0.25), transparent 70%);
    pointer-events: none;
}

#<?= $componentId ?> .tpmst-banner-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    display: flex;
    justify-content: center;
}

#<?= $componentId ?> .tpmst-banner-slide {
    width: 100%;
    max-width: 980px;
}

#<?= $componentId ?> .tpmst-banner-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 26px;
    border: 1px solid rgba(255, 215, 0, 0.2);
    box-shadow: 0 30px 70px rgba(5, 3, 12, 0.65);
    transform: translateY(calc(-1px * <?= $bannerImageOffsetTop ?>));
}

#<?= $componentId ?> .tpmst-banner-download {
    position: absolute;
    bottom: clamp(18px, 4vw, 36px);
    left: 50%;
    transform: translateX(-50%);
    cursor: pointer;
    margin: 0;
    z-index: 2;
}

#<?= $componentId ?> .tpmst-banner-download img {
    animation: <?= $componentId ?>-zoomBtn 2s infinite;
    filter: drop-shadow(0 12px 25px rgba(10, 6, 30, 0.5));
}

@keyframes <?= $componentId ?>-zoomBtn {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(0.92); }
}

@media (max-width: 991px) {
    #<?= $componentId ?> .tpmst-banner {
        padding: 48px 0 70px;
    }

    #<?= $componentId ?> .tpmst-banner-img {
        transform: translateY(0);
        border-radius: 20px;
    }
}
</style>

<div id="<?= $componentId ?>" class="tpmst-banner-component">
    <div class="tpmst-banner">
        <div class="tpmst-banner-inner">
            <div class="tpmst-banner-slide">
                <picture>
                    <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerMobile) ?>">
                    <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerDesktop) ?>">
                    <img class="tpmst-banner-img" 
                         src="<?= htmlspecialchars($bannerMobile) ?>" 
                         alt="<?= htmlspecialchars($bannerAlt) ?>" 
                         fetchpriority="high" 
                         decoding="async">
                </picture>
            </div>
            <?php if ($bannerDownloadImg): ?>
            <p class="tpmst-banner-download">
                <img src="<?= htmlspecialchars($bannerDownloadImg) ?>" 
                     alt="DOWNLOAD APP" 
                     width="210" 
                     height="54">
            </p>
            <?php endif; ?>
        </div>
    </div>
</div>
<!-- TPMST Banner Component End: <?= $componentId ?> -->
