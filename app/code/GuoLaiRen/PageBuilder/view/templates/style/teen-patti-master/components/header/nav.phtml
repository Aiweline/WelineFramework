<script>
(function() {
    var componentId = '<?= $componentId ?>';
    var nav = document.getElementById(componentId);
    var toggleBtn = document.getElementById('mobile-menu-btn-' + componentId);
    var mobileMenu = document.getElementById('mobile-menu-' + componentId);

    if (toggleBtn && mobileMenu) {
        toggleBtn.addEventListener('click', function () {
            var isOpen = mobileMenu.classList.toggle('open');
            toggleBtn.classList.toggle('is-open', isOpen);
            toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        document.addEventListener('click', function (event) {
            if (!mobileMenu.contains(event.target) && !toggleBtn.contains(event.target)) {
                mobileMenu.classList.remove('open');
                toggleBtn.classList.remove('is-open');
                toggleBtn.setAttribute('aria-expanded', 'false');
            }
        });
    }

    if (nav) {
        var syncScrolledState = function () {
            nav.classList.toggle('is-scrolled', (window.scrollY || window.pageYOffset || 0) > 12);
        };
        syncScrolledState();
        window.addEventListener('scroll', syncScrolledState, { passive: true });
    }
})();
</script>

