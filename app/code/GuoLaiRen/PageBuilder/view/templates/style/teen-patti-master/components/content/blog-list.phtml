    text-decoration: none;
    transition: opacity 0.3s;
}

.recent-posts-list a:hover {
    opacity: 0.85;
}

.recent-posts-list img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
}

.recent-post-info {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.recent-post-title {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.recent-post-date {
    font-size: 0.75rem;
    opacity: 0.6;
}

/* 空状态 */
