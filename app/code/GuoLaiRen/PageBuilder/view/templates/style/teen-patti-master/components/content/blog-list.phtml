    position: relative;
    padding: 80px 0;
    background: radial-gradient(1200px 600px at 15% 10%, rgba(154, 36, 193, 0.18), transparent 60%),
        radial-gradient(800px 500px at 85% 20%, rgba(255, 215, 0, 0.12), transparent 55%),
        <?= htmlspecialchars($bgColor) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
    width: 100%;
    overflow: hidden;
}

