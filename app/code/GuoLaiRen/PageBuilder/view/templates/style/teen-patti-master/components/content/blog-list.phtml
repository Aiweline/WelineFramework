    opacity: 0.75;
}

.blog-category {
    background: linear-gradient(120deg, <?= htmlspecialchars($primaryColor) ?> 0%, <?= htmlspecialchars($secondaryColor) ?> 100%);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    text-transform: uppercase;
