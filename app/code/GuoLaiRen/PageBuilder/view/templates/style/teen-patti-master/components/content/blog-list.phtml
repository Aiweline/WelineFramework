    display: flex;
    align-items: center;
    gap: 5px;
    color: <?= htmlspecialchars($primaryColor) ?>;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    transition: gap 0.3s;
}

.blog-read-more:hover {
    gap: 10px;
}

