 * Teen Patti Master - Hero Slider Component
 *
 * 全屏视差滚动Hero区域，带动画效果
 *
 * @component_start
 * code: hero-slider
 * name: Hero轮播区
 * name_en: Hero Slider
 * description: 全屏视差效果，动态渐变背景
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * hero.display => 显示首屏模块:select:yes|yes,no
 *
 * group:hero => Hero设置
 * hero.title => 主标题:text:Experience the Thrill of Teen Patti Master
 * hero.subtitle => 副标题:textarea:India's favorite 3-card showdown - play anytime, anywhere
 * hero.alt => 主视觉描述:text:Teen Patti Master hero
 * hero.cta_text => CTA按钮文字:text:Download Now
 * hero.cta_url => CTA按钮链接:text:#download
 * hero.secondary_cta_text => 次按钮文字:text:Register Now
 * hero.secondary_cta_url => 次按钮链接:text:#register
 * hero.image => 左侧图片:textarea:|留空使用默认图
 * hero.image_mobile => 移动端主视觉:textarea:|留空跟随桌面图
 * hero.bg_color => 背景基础色:color:#1a0f3d
 * hero.bg_image => 背景图片:textarea:|留空使用渐变背景
 *
 * group:download_btn => 下载资源
 * download_btn.display => 显示下载资源:select:no|yes,no
 * download_btn.image => 下载按钮图片:textarea:
 * download_btn.alt => 下载按钮描述:text:Download Now
 * download_btn.url => 下载按钮链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域CSS类:textarea:hero-slider
 * layout.margin_top => 区域顶部偏移:number:0|px
 * layout.img_margin_top => 图片顶部偏移:number:0|px
 *
 * @fields_end
 */

$componentId = 'abpro-hero-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$display = $normalizeToggle($getConfigAny(['hero.display', 'banner.display'], 'yes')) !== 'no';
if (!$display) {
    return;
}

$sliderClasses = trim((string) $getConfig('layout.slider_classes', 'hero-slider'));
$marginTop = (int) $getConfig('layout.margin_top', 0);
$imgMarginTop = (int) $getConfig('layout.img_margin_top', 0);
$title = trim((string) $getConfigAny(['hero.title', 'banner.title'], 'Experience the Thrill of Teen Patti Master'));
$subtitle = trim((string) $getConfigAny(['hero.subtitle', 'banner.subtitle'], "India's favorite 3-card showdown - play anytime, anywhere"));
$heroAlt = trim((string) $getConfigAny(['hero.alt', 'banner.alt'], 'Teen Patti Master hero'));
$heroBgColor = trim((string) $getConfigAny(['hero.bg_color', 'banner.bg_color'], '#1a0f3d'));
$ctaText = trim((string) $getConfigAny(['hero.cta_text', 'download_btn.text', 'banner.download_btn_alt'], 'Download Now'));
$ctaUrl = trim((string) $getConfigAny(['hero.cta_url', 'download_btn.url'], '#download'));
$ctaSecondaryText = trim((string) $getConfig('hero.secondary_cta_text', 'Register Now'));
$ctaSecondaryUrl = trim((string) $getConfig('hero.secondary_cta_url', '#register'));
$heroImage = trim((string) $getConfigAny(['hero.image', 'banner.image_desktop', 'banner.image_mobile'], ''));
$heroImage = $heroImage !== '' ? $heroImage : $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/hero-info-graphic.svg');
$heroImageMobile = trim((string) $getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$heroImageMobile = $heroImageMobile !== '' ? $heroImageMobile : $heroImage;
$bgImage = trim((string) $getConfigAny(['hero.bg_image', 'banner.image_desktop'], ''));
$downloadBtnDisplay = $normalizeToggle($getConfig('download_btn.display', 'no'), 'no') !== 'no';
$downloadBtnImage = trim((string) $getConfigAny(['download_btn.image', 'banner.download_btn_image'], ''));
$downloadBtnAlt = trim((string) $getConfigAny(['download_btn.alt', 'banner.download_btn_alt', 'hero.cta_text'], 'Download Now'));
$downloadBtnUrl = trim((string) $getConfigAny(['download_btn.url', 'hero.cta_url'], '#download'));
?>

