$badge = trim((string) $getConfig('content.badge', 'About'));
$title = trim((string) $getConfigAny(['hero.title', 'content.title'], $pageTitle));
if ($title === '') {
    $title = 'About Teen Patti Master';
}
$subtitle = trim((string) $getConfigAny(['hero.subtitle', 'content.description'], 'Teen Patti Master brings the familiar three-card pace online with clearer table entry, dependable support, and responsive mobile play.'));
