$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$componentId = 'tpm-about-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($getConfig) {
    foreach ($keys as $key) {
        $value = $getConfig($key, '__TPM_ABOUT_MISSING__');
        if ($value !== '__TPM_ABOUT_MISSING__') {
            return $value;
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parsePairs = static function ($raw) {
    $items = [];
    foreach (preg_split('/[\r\n]+/', (string) $raw) as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $first = trim((string) ($parts[0] ?? ''));
        $second = trim((string) ($parts[1] ?? ''));
        if ($first === '') {
            continue;
        }
        $items[] = ['first' => $first, 'second' => $second];
    }
    return $items;
};

$parseTriples = static function ($raw) {
    $items = [];
    foreach (preg_split('/[\r\n]+/', (string) $raw) as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line);
        $title = trim((string) ($parts[0] ?? ''));
        $description = trim((string) ($parts[1] ?? ''));
        $icon = trim((string) ($parts[2] ?? '⭐'));
        if ($title === '') {
            continue;
        }
        $items[] = ['title' => $title, 'description' => $description, 'icon' => $icon !== '' ? $icon : '⭐'];
    }
    return $items;
};

if ($getConfig('display.show_section', $getConfig('about.display', 'yes')) === 'no') {
    return;
}

$showStats = $normalizeToggle($getConfig('display.show_stats', 'yes')) !== 'no';
$showValues = $normalizeToggle($getConfig('display.show_values', 'yes')) !== 'no';
$showTeam = $normalizeToggle($getConfig('display.show_team', 'no'), 'no') !== 'no';
