}

$teamTitle = trim((string) $getConfig('team.title', 'Support Leadership'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', ''));
$team = [];
for ($i = 1; $i <= 4; $i++) {
    $name = trim((string) $getConfig("team.member_{$i}_name", ''));
    $role = trim((string) $getConfig("team.member_{$i}_role", ''));
    $icon = trim((string) $getConfig("team.member_{$i}_icon", 'T' . $i));
    if ($name === '' && $role === '') {
