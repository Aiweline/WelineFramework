$storyBg = trim((string) $getConfig('story.bg_color', '#1a2a4e'));
$storyTitleColor = trim((string) $getConfig('story.title_color', '#ffd700'));
if ($storyContent !== '') {
    $storyHtml = '<p>' . nl2br(htmlspecialchars($storyContent)) . '</p>';
} elseif ($pageContent !== '') {
    $storyHtml = strpos($pageContent, '<') !== false ? $pageContent : '<p>' . nl2br(htmlspecialchars($pageContent)) . '</p>';
} else {
    $storyHtml = '<p>Teen Patti Master keeps the classic Indian card atmosphere while improving how players reach rooms, downloads, and help across desktop and mobile.</p>';
}

$valuesTitle = trim((string) $getConfig('values.title', 'Our Core Values'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'These editable pillars keep the page flexible for future Teen Patti sites without locking in hardcoded copy.'));
$valuesBg = trim((string) $getConfig('values.bg_color', '#1a2a4e'));
$valuesDefaults = [
    ['icon' => '⚖️', 'title' => 'Fair Play', 'description' => 'Players should feel clear, stable table rules and trusted outcomes from the first hand.'],
    ['icon' => '📱', 'title' => 'Mobile Clarity', 'description' => 'Room discovery, wallet actions, and download routes should stay readable on smaller screens.'],
    ['icon' => '💬', 'title' => 'Fast Support', 'description' => 'Account, bonus, or payout questions should reach the right support route without delay.'],
];
$valuesLegacy = $parseTriples($getConfig('values.items', ''));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $legacy = $valuesLegacy[$i - 1] ?? [];
    $default = $valuesDefaults[$i - 1];
    $valueTitle = trim((string) $getConfig("values.value_{$i}_title", $legacy['title'] ?? $default['title']));
    $valueDesc = trim((string) $getConfig("values.value_{$i}_desc", $legacy['description'] ?? $default['description']));
    $valueIcon = trim((string) $getConfig("values.value_{$i}_icon", $legacy['icon'] ?? $default['icon']));
    if ($valueTitle === '' && $valueDesc === '') {
        continue;
    }
    $values[] = [
        'icon' => $valueIcon !== '' ? $valueIcon : '⭐',
        'title' => $valueTitle,
        'description' => $valueDesc,
