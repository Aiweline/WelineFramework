    ['number' => '24/7', 'label' => 'Support desk coverage'],
    ['number' => '20+', 'label' => 'Regions reached'],
];
$statsLegacy = $parsePairs($getConfig('stats.items', "5+|Years of table experience\n1M+|Teen Patti sessions served\n24/7|Support desk coverage\n20+|Regions reached"));
$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $legacy = $statsLegacy[$i - 1] ?? [];
    $default = $statsDefaults[$i - 1];
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $legacy['first'] ?? $default['number']));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $legacy['second'] ?? $default['label']));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = ['value' => $number, 'label' => $label];
}
$statsNumberColor = trim((string) $getConfig('stats.number_color', '#ffd700'));
$statsLabelColor = trim((string) $getConfig('stats.label_color', '#9ca3af'));
$statsCardBg = trim((string) $getConfig('stats.card_bg', 'rgba(255,255,255,0.05)'));

