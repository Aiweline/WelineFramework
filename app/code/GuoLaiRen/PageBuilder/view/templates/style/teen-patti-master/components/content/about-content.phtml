            <p><?= htmlspecialchars($teamSubtitle) ?></p>
            <?php endif; ?>
        </div>
        <div class="team-grid">
            <?php foreach ($team as $member): ?>
            <article class="team-card">
                <div class="team-mark"><?= htmlspecialchars($member['icon']) ?></div>
                <h3><?= htmlspecialchars($member['name']) ?></h3>
                <p><?= htmlspecialchars($member['role']) ?></p>
            </article>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endif; ?>

    <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
    <div class="cta-wrap">
        <?php if ($ctaTitle !== ''): ?>
        <h2><?= htmlspecialchars($ctaTitle) ?></h2>
        <?php endif; ?>
        <?php if ($ctaDescription !== ''): ?>
        <p><?= htmlspecialchars($ctaDescription) ?></p>
        <?php endif; ?>
        <?php if ($ctaButtonText !== ''): ?>
        <a class="cta-btn" href="<?= htmlspecialchars($ctaButtonUrl !== '' ? $ctaButtonUrl : '#') ?>"><?= htmlspecialchars($ctaButtonText) ?></a>
        <?php endif; ?>
    </div>
    <?php endif; ?>
</div>
</section>
