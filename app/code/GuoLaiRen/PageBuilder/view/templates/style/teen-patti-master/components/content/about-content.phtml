    }
    $team[] = [
        'icon' => $icon !== '' ? $icon : ('T' . $i),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string) $getConfig('cta.title', 'Need a direct route?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Use the support page to reach the right desk for account, wallet, or table issues.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact'));
$ctaButtonBg = trim((string) $getConfig('cta.button_bg', '#ffd700'));
$ctaButtonTextColor = trim((string) $getConfig('cta.button_text_color', '#1a2a4e'));
?>

