<?php
/**
 * Teen Patti Master - Games Showcase Component
 *
 * @component_start
 * code: games-showcase
 * name: 游戏展示区
 * name_en: Games Showcase
 * description: 创意游戏展示，支持编辑标题、描述与列表
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_subtitle => 显示副标题:select:yes|yes,no
 * display.show_tags => 显示标签:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#1a2a4e
 * style.accent_color => 强调色:color:#fbd26b
 * style.title_color => 标题颜色:color:#fbd26b
 * style.subtitle_color => 副标题颜色:color:#cbd5f5
 * style.panel_bg_color => 介绍面板背景:color:rgba(11,15,42,0.7)
 * style.card_bg_color => 卡片背景色:color:rgba(26,18,56,0.75)
 * style.card_border_color => 卡片边框色:color:rgba(251,191,36,0.2)
 * style.card_radius => 卡片圆角:number:18|px
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 * style.card_gap => 卡片间距:number:24|px
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Popular Games
 * texts.subtitle => 副标题:textarea:Pick a table, join the action, and win big
 * texts.tags => 标签:textarea:Live Tables\nQuick Match\nVIP Rooms
 *
 * group:game_1 => 游戏卡片1
 * texts.game_1_title => 游戏1标题:text:Teen Patti
 * texts.game_1_desc => 游戏1描述:textarea:3-card showdown with fast rounds
 * texts.game_1_badge => 游戏1徽标:text:Featured Table
 * links.game_1_url => 游戏1链接:text:#teenpatti
 *
 * group:game_2 => 游戏卡片2
 * texts.game_2_title => 游戏2标题:text:AK47
 * texts.game_2_desc => 游戏2描述:textarea:Popular teen patti variation with face cards
 * texts.game_2_badge => 游戏2徽标:text:Face Card Rush
 * links.game_2_url => 游戏2链接:text:#ak47
 *
 * group:game_3 => 游戏卡片3
 * texts.game_3_title => 游戏3标题:text:Muflis
 * texts.game_3_desc => 游戏3描述:textarea:Reverse ranking twist for bold plays
 * texts.game_3_badge => 游戏3徽标:text:Reverse Rank
 * links.game_3_url => 游戏3链接:text:#muflis
 *
 * group:game_4 => 游戏卡片4
 * texts.game_4_title => 游戏4标题:text:Joker
 * texts.game_4_desc => 游戏4描述:textarea:Wild-card thrills and sudden wins
 * texts.game_4_badge => 游戏4徽标:text:Wild Boost
 * links.game_4_url => 游戏4链接:text:#joker
 *
 * group:game_5 => 游戏卡片5
 * texts.game_5_title => 游戏5标题:text:Andar Bahar
 * texts.game_5_desc => 游戏5描述:textarea:Classic side-bet favorite
 * texts.game_5_badge => 游戏5徽标:text:Side Bet
 * links.game_5_url => 游戏5链接:text:#andarbahar
 *
 * group:game_6 => 游戏卡片6
 * texts.game_6_title => 游戏6标题:text:Rummy
 * texts.game_6_desc => 游戏6描述:textarea:Skill-based meld and discard play
 * texts.game_6_badge => 游戏6徽标:text:Skill Play
 * links.game_6_url => 游戏6链接:text:#rummy
 *
 * @fields_end
 */

$componentId = 'tpm-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfig = function($key, $default = '') use ($styleSettings, $componentConfig) {
    if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
        return $styleSettings[$key];
    }
    return $default;
};

// 显示控制
$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';

// 样式配置
$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#1a2a4e'));
$accentColor = $getConfig('style.accent_color', '#fbd26b');
$titleColor = $getConfig('style.title_color', '#fbd26b');
$subtitleColor = $getConfig('style.subtitle_color', '#cbd5f5');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(11,15,42,0.7)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(26,18,56,0.75)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(251,191,36,0.2)');
$cardRadius = $getConfig('style.card_radius', '18');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');
$cardGap = $getConfig('style.card_gap', '24');

// 文本内容
$title = $getConfig('texts.title', $getConfig('games.title', 'Popular Games'));
$subtitle = $getConfig('texts.subtitle', $getConfig('games.subtitle', 'Pick a table, join the action, and win big'));
$tagsConfig = $getConfig('texts.tags', "Live Tables\nQuick Match\nVIP Rooms");
$badgeConfig = $getConfig('texts.badges', "Featured Table\nFace Card Rush\nReverse Rank\nWild Boost\nSide Bet\nSkill Play");
if (strpos((string) $tagsConfig, '\\n') !== false && strpos((string) $tagsConfig, "\n") === false) {
    $tagsConfig = str_replace('\\n', "\n", (string) $tagsConfig);
}
if (strpos((string) $badgeConfig, '\\n') !== false && strpos((string) $badgeConfig, "\n") === false) {
    $badgeConfig = str_replace('\\n', "\n", (string) $badgeConfig);
}

$tags = array_filter(array_map('trim', preg_split('/[\r\n\|]+/', $tagsConfig)));
$legacyBadges = array_values(array_filter(array_map('trim', preg_split('/[\r\n\|]+/', $badgeConfig))));

// 解析游戏列表
$legacyGamesConfig = $getConfig('games.items', "Teen Patti|3-card showdown with fast rounds|#teenpatti\r\nAK47|Popular teen patti variation with face cards|#ak47\r\nMuflis|Reverse ranking twist for bold plays|#muflis\r\nJoker|Wild-card thrills and sudden wins|#joker\r\nAndar Bahar|Classic side-bet favorite|#andarbahar\r\nRummy|Skill-based meld and discard play|#rummy");
$legacyGames = [];
$lines = preg_split('/\r?\n/', str_replace('\\n', "\n", $legacyGamesConfig));
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) {
        continue;
    }
    $parts = array_map('trim', explode('|', $line));
    if (count($parts) >= 2) {
        $legacyGames[] = [
            'title' => $parts[0],
            'desc' => $parts[1],
            'url' => $parts[2] ?? '#',
        ];
    }
}

$cardDefaults = [
    ['title' => 'Teen Patti', 'desc' => '3-card showdown with fast rounds', 'url' => '#teenpatti', 'badge' => 'Featured Table'],
    ['title' => 'AK47', 'desc' => 'Popular teen patti variation with face cards', 'url' => '#ak47', 'badge' => 'Face Card Rush'],
    ['title' => 'Muflis', 'desc' => 'Reverse ranking twist for bold plays', 'url' => '#muflis', 'badge' => 'Reverse Rank'],
    ['title' => 'Joker', 'desc' => 'Wild-card thrills and sudden wins', 'url' => '#joker', 'badge' => 'Wild Boost'],
    ['title' => 'Andar Bahar', 'desc' => 'Classic side-bet favorite', 'url' => '#andarbahar', 'badge' => 'Side Bet'],
    ['title' => 'Rummy', 'desc' => 'Skill-based meld and discard play', 'url' => '#rummy', 'badge' => 'Skill Play'],
];

$getCardValue = function ($index, $field, $default = '') use ($getConfig, $legacyGames, $cardDefaults) {
    $legacyCard = $legacyGames[$index - 1] ?? [];
    $fallback = $legacyCard[$field] ?? ($cardDefaults[$index - 1][$field] ?? $default);

    $keys = [];
    if ($field === 'url') {
        $keys = [
            'game_' . $index . '.links.game_' . $index . '_url',
            'links.game_' . $index . '_url',
        ];
    } else {
        $keys = [
            'game_' . $index . '.texts.game_' . $index . '_' . $field,
            'texts.game_' . $index . '_' . $field,
        ];
    }

    foreach ($keys as $key) {
        $value = $getConfig($key, '');
        if ($value !== '') {
            return $value;
        }
    }

    return $fallback;
};

$getBadgeValue = function ($index, $default = '') use ($getConfig, $legacyBadges, $cardDefaults) {
    $keys = [
        'game_' . $index . '.texts.game_' . $index . '_badge',
        'texts.game_' . $index . '_badge',
    ];

    foreach ($keys as $key) {
        $value = trim((string) $getConfig($key, ''));
        if ($value !== '') {
            return $value;
        }
    }

    return $legacyBadges[$index - 1] ?? ($cardDefaults[$index - 1]['badge'] ?? $default);
};

$games = [];
for ($index = 1; $index <= 6; $index++) {
    $games[] = [
        'name' => $getCardValue($index, 'title'),
        'description' => $getCardValue($index, 'desc'),
        'link' => $getCardValue($index, 'url', '#'),
        'badge' => $getBadgeValue($index),
    ];
}
?>

