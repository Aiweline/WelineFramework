 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:What Players Say
 * texts.testimonial_1_name => 评价1姓名:text:Arjun Mehta
 * texts.testimonial_1_tag => 评价1标签:text:High-Stakes Table
 * texts.testimonial_1_rating => 评价1评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_1_content => 评价1内容:textarea:Teen Patti Master feels like a real table. Fast rounds, smooth animations, and solid competition.
 * texts.testimonial_2_name => 评价2姓名:text:Neha Iyer
 * texts.testimonial_2_tag => 评价2标签:text:Daily Grinder
 * texts.testimonial_2_rating => 评价2评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_2_content => 评价2内容:textarea:Love the quick match flow. I can jump in for 10 minutes and still feel the thrill.
 * texts.testimonial_3_name => 评价3姓名:text:Kabir Singh
 * texts.testimonial_3_tag => 评价3标签:text:Tournament Regular
 * texts.testimonial_3_rating => 评价3评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_3_content => 评价3内容:textarea:Tournaments run on time, and the leaderboard rewards are actually worth it.
 * texts.testimonial_4_name => 评价4姓名:text:Priya Nair
 * texts.testimonial_4_tag => 评价4标签:text:VIP Room
 * texts.testimonial_4_rating => 评价4评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_4_content => 评价4内容:textarea:Great balance between skill and luck. The VIP tables are my favorite.
 * texts.testimonial_5_name => 评价5姓名:text:Arjun Mehta
 * texts.testimonial_5_tag => 评价5标签:text:High-Stakes Table
 * texts.testimonial_5_rating => 评价5评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_5_content => 评价5内容:textarea:Teen Patti Master feels like a real table. Fast rounds, smooth animations, and solid competition.
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:
 * avatars.avatar_2 => 评价2头像:textarea:
 * avatars.avatar_3 => 评价3头像:textarea:
 * avatars.avatar_4 => 评价4头像:textarea:
 * avatars.avatar_5 => 评价5头像:textarea:
 *
 * @fields_end
 */

$componentId = 'tpm-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 显示控制
$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';
$showAvg = $getConfig('display.show_avg', 'yes') !== 'no';

// 样式配置
$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#0b0f2a'));
$accentColor = $getConfig('style.accent_color', '#fbd26b');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.06)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(251,191,36,0.25)');
$textColor = $getConfig('style.text_color', '#e5e7eb');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');

// 文本内容
$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Say'));

$parseRating = function($raw) {
    $raw = trim((string)$raw);
    if ($raw === '') return 0;
    if (is_numeric($raw)) return (int)$raw;
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    [
        'name' => 'Arjun Mehta',
        'tag' => 'High-Stakes Table',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Teen Patti Master feels like a real table. Fast rounds, smooth animations, and solid competition.',
    ],
    [
        'name' => 'Neha Iyer',
        'tag' => 'Daily Grinder',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Love the quick match flow. I can jump in for 10 minutes and still feel the thrill.',
    ],
    [
        'name' => 'Kabir Singh',
        'tag' => 'Tournament Regular',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Tournaments run on time, and the leaderboard rewards are actually worth it.',
    ],
    [
        'name' => 'Priya Nair',
        'tag' => 'VIP Room',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'Great balance between skill and luck. The VIP tables are my favorite.',
    ],
    [
        'name' => 'Amit Patel (Ahmedabad)',
        'tag' => 'High-Stakes Table',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Love the game variety. Won ₹12K last week in a tournament.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i - 1] ?? ['name' => '', 'tag' => '', 'rating' => '⭐⭐⭐⭐⭐', 'text' => ''];
    $name = $getConfig("texts.testimonial_{$i}_name", $defaults['name']);
    $tag = $getConfig("texts.testimonial_{$i}_tag", $defaults['tag']);
    $ratingText = $getConfig("texts.testimonial_{$i}_rating", $defaults['rating']);
    $content = $getConfig("texts.testimonial_{$i}_content", $defaults['text']);
    $avatar = $getConfig("avatars.avatar_{$i}", '');

    if ($name !== '') {
        $ratingValue = $parseRating($ratingText);
        $ratingDisplay = is_numeric($ratingText) ? str_repeat('★', (int)$ratingText) : $ratingText;
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => max(0, min(5, $ratingValue)),
            'rating_text' => $ratingDisplay,
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

$totalRating = array_sum(array_column($testimonials, 'rating'));
$avgRating = count($testimonials) ? $totalRating / count($testimonials) : 0;
$avgRatingLabel = number_format($avgRating, 1);
?>

<style>
