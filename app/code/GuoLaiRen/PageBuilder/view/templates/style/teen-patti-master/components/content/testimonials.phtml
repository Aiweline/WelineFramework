<section id="<?= $componentId ?>" class="tpmst-section tpmst-testimonials-component">
    <div class="testimonials-container">
        <?php if ($showTitle): ?>
            <div class="header">
                <h2 class="text-3xl md:text-5xl font-bold text-white"><?= htmlspecialchars($title) ?></h2>
                <?php if ($showAvg): ?>
                    <div class="rating-pill">⭐ <?= htmlspecialchars($avgRatingLabel) ?>/5 average rating</div>
                <?php endif; ?>
            </div>
        <?php endif; ?>

        <div class="testimonials-grid">

            <?php foreach ($testimonials as $index => $t): ?>
                <?php
                $isFirst = $index === 0;
                $isLast = $index === count($testimonials) - 1;
                $featured = ($isFirst || $isLast) ? 'featured' : '';
                $compact = (!$isFirst && !$isLast) ? 'compact' : '';
                $parts = preg_split('/\s+/', trim($t['name']));
                $first = $parts[0] ?? '';
                $second = $parts[1] ?? $first;
                $initials = strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
                ?>
                <article class="testimonial-card <?= $featured ?> <?= $compact ?>">
                    <div class="card-head">
                        <?php if ($showAvatar): ?>
                            <div class="avatar">
                                <?php if (!empty($t['avatar'])): ?>
                                    <img src="<?= htmlspecialchars($t['avatar']) ?>" alt="<?= htmlspecialchars($t['name']) ?>">
                                <?php else: ?>
                                    <?= htmlspecialchars($initials) ?>
                                <?php endif; ?>
                            </div>
                        <?php endif; ?>
                        <div>
                            <div class="name"><?= htmlspecialchars($t['name']) ?></div>
                            <div class="tag"><?= htmlspecialchars($t['tag']) ?></div>
                        </div>
                        <?php if ($showRating): ?>
                            <div class="stars"><?= htmlspecialchars($t['rating_text']) ?></div>
                        <?php endif; ?>
                    </div>
                    <p class="quote">"<?= htmlspecialchars($t['text']) ?>"</p>
                </article>
            <?php endforeach; ?>
