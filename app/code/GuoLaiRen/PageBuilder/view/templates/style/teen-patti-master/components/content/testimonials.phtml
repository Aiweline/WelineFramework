    background: radial-gradient(circle at 15% 10%, rgba(251, 191, 36, 0.08), transparent 55%),
                radial-gradient(circle at 85% 20%, rgba(88, 20, 121, 0.18), transparent 60%),
                linear-gradient(180deg, <?= htmlspecialchars($bgColor) ?> 0%, #120a2b 55%, #0a061a 100%);
