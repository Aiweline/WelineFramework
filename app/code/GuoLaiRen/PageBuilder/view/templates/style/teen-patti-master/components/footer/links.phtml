<?php
/**
 * Teen Patti Master - Footer Links
 *
 * @component_start
 * code: footer-links
 * name: 页脚链接
 * name_en: Footer Links
 * description: 多列链接布局，社交媒体图标
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.background_color => 背景基础色:color:#0a061a
 * style.text_color => 文字颜色:color:#9ca3af
 * style.link_color => 链接颜色:color:#d1d5db
 * style.link_hover_color => 链接悬停颜色:color:#fbd26b
 * style.link_font_size => 链接字号:number:15|px
 * style.link_font_weight => 链接字重:number:700
 * style.link_gap => 链接间距:number:18|px
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:#2c3250
 * style.border_width => 边框宽度:number:1|px
 * style.section_padding => 区域内边距(PC端):number:48|px
 * style.section_padding_mobile => 区域内边距(移动端):number:35|px
 * style.separator_display => 显示分隔符:select:no|yes,no
 * style.separator_char => 分隔符字符:text:/
 * style.separator_color => 分隔符颜色:color:#5d6278
 *
 * group:layout => 布局设置
 * layout.max_width => 最大宽度:number:1200
 * layout.padding_horizontal => 左右内边距:responsive:20/28|px
 * layout.padding_vertical => 上下内边距:responsive:35/48|px
 *
 * group:footer => 页脚品牌设置
 * footer.logo_text => 品牌名称:text:Teen Patti Master
 * footer.logo_url => 品牌图标:textarea:|留空使用默认图标
 * footer.tagline => 品牌副文案:text:Play smart. Play bold.
 *
 * group:content => 内容配置
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nGames=>#games\r\nHow to Play=>#howto\r\nFAQ=>#faq\r\nSupport=>/contact|配置格式：名字=>url，一行一个
 * content.copyright_text => 版权信息:text:© 2026 Teen Patti Master. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. Play responsibly and review your local gaming regulations before participating.
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.use_subpages => 兼容旧版-使用子页面生成链接:select:no|yes,no
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * group:typography => 字体排版
 * typography.font_size => 字号:responsive:12/14|px
 * typography.line_height => 行高:number:1.65
 *
 * @fields_end
 */

$componentId = 'tpm-footer-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);
$standaloneShell = !($this->getData('__pagebuilder_shell_managed'));

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string) $value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string) ($parts[0] ?? '')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function ($parsed) {
    $mobile = (float) $parsed['mobile'];
    $desktop = (float) $parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';
$borderTop = $normalizeToggle($getConfig('style.border_top', 'yes')) !== 'no';
$separatorDisplay = $normalizeToggle($getConfig('style.separator_display', 'no'), 'no') === 'yes';

$backgroundColor = (string) $getConfig('style.background_color', '#0a061a');
$textColor = (string) $getConfig('style.text_color', '#9ca3af');
$linkColor = (string) $getConfig('style.link_color', '#d1d5db');
$linkHoverColor = (string) $getConfig('style.link_hover_color', '#fbd26b');
$linkFontSize = (int) $getConfig('style.link_font_size', '15');
$linkFontWeight = (int) $getConfig('style.link_font_weight', '700');
$linkGap = (int) $getConfig('style.link_gap', '18');
$borderColor = (string) $getConfig('style.border_color', '#2c3250');
$borderWidth = (int) $getConfig('style.border_width', '1');
$sectionPadding = (int) $getConfig('style.section_padding', '48');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '35');
$separatorChar = trim((string) $getConfig('style.separator_char', '/'));
if ($separatorChar === '') {
    $separatorChar = '/';
}
$separatorColor = (string) $getConfig('style.separator_color', '#5d6278');
$maxWidth = (int) $getConfig('layout.max_width', '1200');
$paddingHorizontal = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_horizontal', '20/28') . 'px'));
$paddingVertical = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_vertical', $sectionPaddingMobile . '/' . $sectionPadding) . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float) $getConfig('typography.line_height', '1.65');

$logoText = (string) $getConfigAny(['footer.logo_text', 'logo.text'], 'Teen Patti Master');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-master/asset/img/tpm-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['footer.logo_url', 'logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);
$tagline = (string) $getConfigAny(['footer.tagline', 'footer.description'], 'Play smart. Play bold.');
$copyright = (string) $getConfigAny(['content.copyright_text', 'footer.copyright'], '© 2026 Teen Patti Master. All rights reserved.');
$disclaimerText = (string) $getConfigAny(['content.disclaimer_text', 'footer.disclaimer'], '18+ Only. Play responsibly and review your local gaming regulations before participating.');

$links = [];
$useCustomLinksRaw = (string) $getConfig('content.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('content.use_subpages', 'no'), 'no') !== 'yes';

if (!$useCustomLinks && $page) {
    $footerPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(30)
        : (method_exists($page, 'getNavigationPages') ? $page->getNavigationPages([], 30) : []);

    foreach ($footerPages as $footerPage) {
        $text = trim((string) ($footerPage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = (string) ($footerPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny([
            'content_footer_labels.content.footer_label_' . $type,
            'content.footer_label_' . $type,
        ], ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => (string) ($footerPage['url'] ?? '#'),
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny(
        ['content.footer_links', 'footer.links'],
        "Home=>/\nGames=>#games\nHow to Play=>#howto\nFAQ=>#faq\nSupport=>/contact"
    );

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }

    foreach ($items as $item) {
        $item = trim((string) $item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            $parts = [$item, '#'];
        }
        if (($parts[0] ?? '') === '') {
            continue;
        }
        $links[] = [
            'text' => $parts[0],
            'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#',
        ];
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}
?>
