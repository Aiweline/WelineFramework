<?php
/**
 * Court Piece Electric Mahal - Footer Links
 *
 * @component_start
 * code: footer-links
 * name: Electric Mahal Footer
 * name_en: Electric Mahal Footer
 * description: High-contrast footer with responsive link layout and floating download action.
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.background_color => 背景基础色:color:#0d0718
 * style.text_color => 文字颜色:color:#beaed8
 * style.link_color => 链接颜色:color:#f8ecff
 * style.link_hover_color => 链接悬停颜色:color:#6ef3ff
 * style.link_font_size => 链接字号:number:14|px
 * style.link_font_weight => 链接字重:number:700
 * style.link_gap => 链接间距:number:12|px
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:rgba(255,255,255,0.1)
 * style.border_width => 边框宽度:number:1|px
 * style.section_padding => 区域内边距(PC端):number:42|px
 * style.section_padding_mobile => 区域内边距(移动端):number:24|px
 * style.separator_display => 显示分隔符:select:no|yes,no
 * style.separator_char => 分隔符字符:text:/
 * style.separator_color => 分隔符颜色:color:#9b8cb3
 *
 * group:disclaimer => 免责声明样式
 * disclaimer.bg_color => 免责声明背景:color:rgba(255,255,255,0.06)
 * disclaimer.border_radius => 免责声明圆角:number:18|px
 * disclaimer.padding => 免责声明内边距:number:14|px
 * disclaimer.font_size => 免责声明字号:number:12|px
 * disclaimer.text_color => 免责声明颜色:color:#beaed8
 *
 * group:copyright => 版权信息样式
 * copyright.font_size => 版权字号:number:12|px
 * copyright.text_color => 版权颜色:color:#9b8cb3
 * copyright.margin_top => 版权上边距:number:12|px
 *
 * group:layout => 布局配置
 * layout.max_width => 最大宽度:number:1220
 * layout.padding_horizontal => 水平内边距:responsive:20/36|px
 * layout.padding_vertical => 垂直内边距:responsive:24/42|px
 *
 * group:footer => 页脚品牌设置
 * footer.logo_text => 品牌名称:text:Court Piece Electric Mahal
 * footer.logo_url => 品牌Logo地址:textarea:|默认使用本地mahal-emblem.svg
 * footer.links => 页脚链接:textarea:Home|/,Blog|/blog,FAQ|/faqs,About|/about,Privacy|/privacy-policy
 * footer.copyright => 版权文案:text:© 2026 Court Piece Electric Mahal | All rights reserved
 * footer.disclaimer_text => 免责声明:textarea:18+ Only. Review local gaming and promotional rules before publishing.
 *
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.use_subpages => 使用子页面生成链接:select:no|yes,no
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * group:typography => 字体排版
 * typography.font_size => 字号:responsive:12/14|px
 * typography.line_height => 行高:number:1.7
 *
 * @fields_end
 */

$componentId = 'court-piece-electric-mahal-footer-links-' . uniqid();
$floatingId = $componentId . '-floating-download';
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];


$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';

$bgColor = (string) $getConfig('style.background_color', $colors['footer_bg'] ?? '#0d0718');
$textColor = (string) $getConfig('style.text_color', $colors['footer_text'] ?? '#beaed8');
$linkColor = (string) $getConfig('style.link_color', $colors['footer_link'] ?? '#f8ecff');
$linkHoverColor = (string) $getConfig('style.link_hover_color', $colors['footer_link_hover'] ?? '#6ef3ff');
$linkFontSize = (int) $getConfig('style.link_font_size', '14');
$linkFontWeight = (int) $getConfig('style.link_font_weight', '700');
$linkGap = (int) $getConfig('style.link_gap', '12');
$borderTop = $normalizeToggle($getConfig('style.border_top', 'yes')) !== 'no';
$borderColor = (string) $getConfig('style.border_color', 'rgba(255,255,255,0.1)');
$borderWidth = (int) $getConfig('style.border_width', '1');
$sectionPadding = (int) $getConfig('style.section_padding', '42');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '24');
$separatorDisplay = $normalizeToggle($getConfig('style.separator_display', 'no'), 'no') !== 'no';
$separatorChar = trim((string) $getConfig('style.separator_char', '/'));
$separatorColor = (string) $getConfig('style.separator_color', '#9b8cb3');

$disclaimerBg = (string) $getConfig('disclaimer.bg_color', 'rgba(255,255,255,0.06)');
$disclaimerRadius = (int) $getConfig('disclaimer.border_radius', '18');
$disclaimerPadding = (int) $getConfig('disclaimer.padding', '14');
$disclaimerFontSize = (int) $getConfig('disclaimer.font_size', '12');
$disclaimerTextColor = (string) $getConfig('disclaimer.text_color', $colors['footer_text'] ?? '#beaed8');
$copyrightFontSize = (int) $getConfig('copyright.font_size', '12');
$copyrightTextColor = (string) $getConfig('copyright.text_color', $colors['footer_copyright'] ?? '#9b8cb3');
$copyrightMarginTop = (int) $getConfig('copyright.margin_top', '12');

$layoutMaxWidth = (int) $getConfig('layout.max_width', '1220');
$typographyFontSize = trim((string) $getConfig('typography.font_size', '12/14'));
$lineHeight = (float) $getConfig('typography.line_height', '1.7');

$brandName = trim((string) $getConfigAny(['footer.logo_text', 'content.logo_text'], ''));
if ($brandName === '') {
    $brandName = $page && $page->getData('title') ? trim((string) $page->getData('title')) : 'Court Piece Electric Mahal';
}
$brandLogo = trim((string) $getConfig('footer.logo_url', ''));
if ($brandLogo === '') {
    $brandLogo = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/court-piece-electric-mahal/asset/img/mahal-emblem.svg');
}
$copyrightText = (string) $getConfigAny(['footer.copyright', 'content.copyright_text'], '© 2026 Court Piece Electric Mahal | All rights reserved');
$disclaimerText = (string) $getConfigAny(['footer.disclaimer_text', 'content.disclaimer_text'], '18+ Only. Review local gaming and promotional rules before publishing.');

$footerLinksConfig = (string) $getConfigAny(['footer.links', 'content.footer_links'], 'Home|/,Blog|/blog,FAQ|/faqs,About|/about,Privacy|/privacy-policy');
$useCustomLinksRaw = trim((string) $getConfig('content.use_custom_links', ''));
$useSubpagesRaw = trim((string) $getConfig('content.use_subpages', ''));
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($useSubpagesRaw, 'no') !== 'yes';
$footerLinks = [];

if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    foreach ($page->getHeaderNavigationPages(30) as $navPage) {
        $type = (string) ($navPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfig('content.footer_label_' . $type, ''));
        $footerLinks[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : (string) ($navPage['title'] ?? ''),
            'url' => (string) ($navPage['url'] ?? '/'),
        ];
    }
}

if (empty($footerLinks)) {
    foreach (explode(',', $footerLinksConfig) as $entry) {
        $parts = array_map('trim', explode('|', trim((string) $entry), 2));
        if (($parts[0] ?? '') === '' || ($parts[1] ?? '') === '') {
            continue;
        }
        $footerLinks[] = [
            'text' => $parts[0],
            'url' => $parts[1],
        ];
    }
}

if (empty($footerLinks)) {
    $footerLinks = [
        ['text' => 'Home', 'url' => '/'],
        ['text' => 'Blog', 'url' => '/blog'],
        ['text' => 'FAQ', 'url' => '/faqs'],
        ['text' => 'About', 'url' => '/about'],
    ];
}

$downloadText = trim((string) $getConfigAny(['header.download_button.text', 'download_button.text'], 'Download App'));
$downloadUrl = trim((string) $getConfigAny(['header.download_button.url', 'download_button.url'], '#download'));
$downloadDisplay = $normalizeToggle($getConfigAny(['header.download_button.display', 'download_button.display'], 'yes')) !== 'no';
$floatingDownloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $downloadUrl);
$floatingDownloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($floatingDownloadHref, 'url');
$showFloatingDownload = $downloadDisplay && $downloadText !== '' && $downloadUrl !== '';

$metaTitle = htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8');
?>
<footer id="<?= $componentId ?>" class="cpe-footer" aria-labelledby="<?= $componentId ?>-title">
    <div class="mx-auto w-full px-5 md:px-8" style="max-width: <?= $layoutMaxWidth ?>px;">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-center">
            <section class="grid gap-4" data-cpe-reveal>
                <div class="flex items-start gap-4">
                    <img class="cpe-brand-logo" src="<?= htmlspecialchars((string) $brandLogo, ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?>" loading="lazy" decoding="async">
                    <div class="min-w-0">
                        <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?></h2>
                        <?php if ($showCopyright): ?>
                        <p class="cpe-copyright"><?= htmlspecialchars($copyrightText, ENT_QUOTES, 'UTF-8') ?></p>
                        <?php endif; ?>
                    </div>
                </div>
            </section>

            <div class="grid gap-4 lg:justify-items-end" data-cpe-reveal>
                <?php if ($showLinks && !empty($footerLinks)): ?>
                <nav class="flex flex-wrap items-center gap-y-3 lg:justify-end" style="column-gap: <?= max(0, $linkGap) ?>px;" aria-label="Footer navigation">
                    <?php foreach ($footerLinks as $index => $link): ?>
                    <?php if ($index > 0 && $separatorDisplay): ?>
                    <span class="cpe-link-separator hidden md:inline-flex" aria-hidden="true"><?= htmlspecialchars($separatorChar, ENT_QUOTES, 'UTF-8') ?></span>
                    <?php endif; ?>
                    <a class="cpe-link-chip" href="<?= htmlspecialchars((string) $link['url'], ENT_QUOTES, 'UTF-8') ?>">
                        <span><?= htmlspecialchars((string) $link['text'], ENT_QUOTES, 'UTF-8') ?></span>
                    </a>
                    <?php endforeach; ?>
                </nav>
                <?php endif; ?>

                <?php if ($showDisclaimer && $disclaimerText !== ''): ?>
                <div class="cpe-disclaimer w-full max-w-[42rem] lg:text-right">
                    <p><?= htmlspecialchars($disclaimerText, ENT_QUOTES, 'UTF-8') ?></p>
                </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</footer>
<?php if ($showFloatingDownload): ?>
<a id="<?= $floatingId ?>" class="cpe-floating-download download-btn" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($floatingDownloadRef), ENT_QUOTES, 'UTF-8') ?>" data-glr-ref="<?= htmlspecialchars($floatingDownloadRef, ENT_QUOTES, 'UTF-8') ?>" aria-label="<?= htmlspecialchars($downloadText, ENT_QUOTES, 'UTF-8') ?>">
    <span class="cpe-floating-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
            <path d="M12 4V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            <path d="M8 10L12 14L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M5 18H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
    </span>
    <span><?= htmlspecialchars($downloadText, ENT_QUOTES, 'UTF-8') ?></span>
</a>
<?php endif; ?>
<style>
#<?= $componentId ?> {
    position: relative;
    padding: <?= $sectionPaddingMobile ?>px 0;
    background:
        radial-gradient(circle at 8% 16%, rgba(255,111,60,0.16), transparent 18%),
        radial-gradient(circle at 92% 14%, rgba(110,243,255,0.14), transparent 19%),
        linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%),
        <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    color: <?= htmlspecialchars($textColor, ENT_QUOTES, 'UTF-8') ?>;
    <?= $borderTop ? 'border-top:' . $borderWidth . 'px solid ' . htmlspecialchars($borderColor, ENT_QUOTES, 'UTF-8') . ';' : '' ?>
    line-height: <?= $lineHeight ?>;
    font-size: <?= htmlspecialchars($typographyFontSize, ENT_QUOTES, 'UTF-8') ?>;
    overflow: clip;
}

@media (min-width: 768px) {
    #<?= $componentId ?> {
        padding-top: <?= $sectionPadding ?>px;
        padding-bottom: <?= $sectionPadding ?>px;
    }
}

#<?= $componentId ?>::before,
#<?= $componentId ?>::after {
    content: "";
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
}

#<?= $componentId ?>::before {
    left: -5rem;
    top: -3rem;
    width: 16rem;
    height: 16rem;
    background: radial-gradient(circle, rgba(255,111,60,0.18), rgba(255,111,60,0) 72%);
}

#<?= $componentId ?>::after {
    right: -4rem;
    bottom: -4rem;
    width: 15rem;
    height: 15rem;
    background: radial-gradient(circle, rgba(110,243,255,0.14), rgba(110,243,255,0) 72%);
}

#<?= $componentId ?> .cpe-brand-logo {
    width: 4.25rem;
    height: 4.25rem;
    object-fit: contain;
    flex-shrink: 0;
    border-radius: 1.4rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.5rem;
}

#<?= $componentId ?> h2 {
    margin: 0;
    color: #fff0af;
    font: 800 clamp(1.45rem, 2.4vw, 2.15rem) / 0.98 "Palatino Linotype", "Book Antiqua", Georgia, serif;
}

#<?= $componentId ?> .cpe-copyright {
    margin: <?= $copyrightMarginTop ?>px 0 0;
    color: <?= htmlspecialchars($copyrightTextColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: <?= $copyrightFontSize ?>px;
}

#<?= $componentId ?> .cpe-link-separator {
    color: <?= htmlspecialchars($separatorColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: <?= max(12, $linkFontSize - 1) ?>px;
    opacity: 0.75;
}

#<?= $componentId ?> .cpe-link-chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding-left: 0.95rem;
    color: <?= htmlspecialchars($linkColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: <?= $linkFontSize ?>px;
    font-weight: <?= $linkFontWeight ?>;
    transition: transform 0.22s ease, color 0.22s ease;
}

#<?= $componentId ?> .cpe-link-chip::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(255,111,60,0.4);
    transform: translateY(-50%);
}

#<?= $componentId ?> .cpe-link-chip:hover,
#<?= $componentId ?> .cpe-link-chip:focus-visible {
    color: <?= htmlspecialchars($linkHoverColor, ENT_QUOTES, 'UTF-8') ?>;
    transform: translateY(-1px);
    outline: none;
}

#<?= $componentId ?> .cpe-disclaimer {
    padding: <?= $disclaimerPadding ?>px;
    border-radius: <?= $disclaimerRadius ?>px;
    background: <?= htmlspecialchars($disclaimerBg, ENT_QUOTES, 'UTF-8') ?>;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
}

#<?= $componentId ?> .cpe-disclaimer p {
    margin: 0;
    color: <?= htmlspecialchars($disclaimerTextColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: <?= $disclaimerFontSize ?>px;
    line-height: 1.82;
}

#<?= $floatingId ?> {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.4rem;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(120deg, #ffd166 0%, #ff7a3c 56%, #ff477e 100%);
    color: #351500;
    box-shadow: 0 18px 36px rgba(255,111,60,0.28);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.24s ease, box-shadow 0.24s ease;
}

@media (min-width: 768px) {
    #<?= $floatingId ?> {
        left: auto;
        right: clamp(0.9rem, 2vw, 1.5rem);
        bottom: clamp(0.9rem, 2vw, 1.5rem);
    }
}

#<?= $floatingId ?>:hover,
#<?= $floatingId ?>:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 22px 42px rgba(255,209,102,0.34);
    outline: none;
}

#<?= $floatingId ?> .cpe-floating-icon {
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(53, 21, 0, 0.12);
}

#<?= $floatingId ?> .cpe-floating-icon svg {
    width: 0.95rem;
    height: 0.95rem;
}
</style>
