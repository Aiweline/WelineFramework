                        <img class="cpe-avatar" src="<?= htmlspecialchars((string) $featured['avatar']) ?>" alt="<?= htmlspecialchars((string) $featured['name']) ?>">
                        <?php else: ?>
                        <div class="cpe-avatar-fallback"><?= htmlspecialchars((string) $featured['initials']) ?></div>
                        <?php endif; ?>
                        <?php endif; ?>

                        <div>
                            <span class="cpe-label"><?= htmlspecialchars((string) $featured['label']) ?></span>
                            <p class="cpe-name"><?= htmlspecialchars((string) $featured['name']) ?></p>
                            <?php if ($showRating): ?>
                            <div class="cpe-rating"><?= htmlspecialchars((string) $featured['rating']) ?></div>
                            <?php endif; ?>
                        </div>
                    </div>

                    <blockquote class="cpe-quote"><?= htmlspecialchars((string) $featured['content']) ?></blockquote>
                    <p class="cpe-body">Players stay for the rooms that stay readable, responsive, and partner-friendly even when the pressure ramps up.</p>
                </article>

                <?php if (!empty($secondaryCards)): ?>
                <div class="cpe-stack" role="list" aria-label="More player reviews">
                    <?php foreach ($secondaryCards as $card): ?>
                    <article role="listitem">
                        <div class="cpe-note-top">
                            <strong><?= htmlspecialchars((string) $card['name']) ?></strong>
                            <span><?= htmlspecialchars((string) $card['label']) ?></span>
                        </div>
                        <?php if ($showRating): ?>
                        <div class="cpe-rating"><?= htmlspecialchars((string) $card['rating']) ?></div>
                        <?php endif; ?>
                        <p class="cpe-note-text"><?= htmlspecialchars((string) $card['content']) ?></p>
                    </article>
                    <?php endforeach; ?>
                </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</section>
