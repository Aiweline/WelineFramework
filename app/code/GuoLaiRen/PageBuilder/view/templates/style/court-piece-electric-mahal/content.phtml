}

.cpe-content-region a {
    color: <?= htmlspecialchars($linkColor, ENT_QUOTES, 'UTF-8') ?>;
}

.cpe-content-fallback {
    width: min(920px, calc(100% - 1.2rem));
    margin: 0 auto;
    padding: clamp(4rem, 7vw, 6rem) 0;
}

.cpe-content-fallback > :first-child {
    margin-top: 0;
}

.cpe-content-fallback > :last-child {
    margin-bottom: 0;
}

.cpe-content-empty {
    width: min(720px, calc(100% - 1.2rem));
    margin: 0 auto;
    padding: 4rem 0;
    text-align: center;
    color: <?= htmlspecialchars($textMuted, ENT_QUOTES, 'UTF-8') ?>;
}
</style>

<main class="cpe-content-region">
    <?php if (!empty($contentComponents)): ?>
        <?php foreach ($contentComponents as $index => $component): ?>
            <?= $renderComponent((array) $component, (int) $index) ?>
        <?php endforeach; ?>
    <?php elseif ($customContent !== ''): ?>
        <div class="cpe-content-fallback"><?= $customContent ?></div>
    <?php else: ?>
        <div class="cpe-content-empty">Content components can be added here.</div>
    <?php endif; ?>
</main>
