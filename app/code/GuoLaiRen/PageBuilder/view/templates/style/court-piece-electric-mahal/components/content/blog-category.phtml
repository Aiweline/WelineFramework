<?php
/**
 * TPMST 博客分类组件
 * 
 * @fields_start
 * blog.title|分类标题|text|Category Posts
 * blog.subtitle|副标题|text|Browse articles by category
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=特色|default
 * @fields_end
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $blog_posts 博客文章列表（已按分类筛选）
 * @var array $blog_categories 博客分类列表
 * @var array $current_category 当前分类信息
 * @var array $style_settings 样式配置
 */
$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

// 配置项
$getConfig = function($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? __('Category Posts'));
$subtitle = $getConfig('blog.subtitle', __('Browse articles by category'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

// 颜色配置
$primaryColor = $getConfig('color_scheme.primary', '#ffd166');
$secondaryColor = $getConfig('color_scheme.secondary', '#6ef3ff');
$bgColor = $getConfig('color_scheme.background', '#140a22');
$textColor = $getConfig('color_scheme.text', '#fff9f1');
?>

<section class="court-piece-electric-mahal-section court-piece-electric-mahal-blog-category" id="blog-category">
    <div class="court-piece-electric-mahal-section-inner">
        <!-- 标题区域 -->
        <div class="blog-header">
            <?php if (!empty($currentCategory)): ?>
            <div class="category-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <?= htmlspecialchars($currentCategory['name']) ?>
            </div>
            <?php endif; ?>
            <h2 class="blog-title"><?= htmlspecialchars($title) ?></h2>
            <?php if ($subtitle): ?>
            <p class="blog-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            
            <?php if (!empty($currentCategory['description'])): ?>
            <p class="category-description"><?= htmlspecialchars($currentCategory['description']) ?></p>
            <?php endif; ?>
        </div>
        
        <div class="blog-content-wrapper <?= $showSidebar ? 'with-sidebar' : 'full-width' ?>">
            <!-- 文章列表 -->
            <div class="blog-posts-grid">
                <?php if (empty($blogPosts)): ?>
                <div class="blog-empty">
                    <div class="empty-icon">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                        </svg>
                    </div>
                    <p><?= __('该分类下暂时还没有文章，稍后再来看看吧～') ?></p>
                    <a href="/blog" class="btn-back-to-blog"><?= __('返回博客列表') ?></a>
                </div>
                <?php else: ?>
                    <?php foreach ($blogPosts as $index => $post): ?>
                    <article class="blog-card blog-card-<?= $cardStyle ?> <?= $index === 0 && $cardStyle === 'featured' ? 'featured' : '' ?>">
                        <?php if (!empty($post['cover_image'])): ?>
                        <div class="blog-card-image">
                            <a href="<?= htmlspecialchars($post['url']) ?>">
                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" 
                                     alt="<?= htmlspecialchars($post['title']) ?>"
                                     loading="lazy">
                            </a>
                        </div>
                        <?php endif; ?>
                        
                        <div class="blog-card-content">
                            <div class="blog-card-meta">
                                <?php if ($showCategory && !empty($post['category_name'])): ?>
                                <span class="blog-category"><?= htmlspecialchars($post['category_name']) ?></span>
                                <?php endif; ?>
                                
                                <?php if ($showDate && !empty($post['published_at'])): ?>
                                <span class="blog-date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
                                    </svg>
                                    <?= date('M d, Y', strtotime($post['published_at'])) ?>
                                </span>
                                <?php endif; ?>
                            </div>
                            
                            <h3 class="blog-card-title">
                                <a href="<?= htmlspecialchars($post['url']) ?>">
                                    <?= htmlspecialchars($post['title']) ?>
                                </a>
                            </h3>
                            
                            <?php if (!empty($post['summary'])): ?>
                            <p class="blog-card-excerpt">
                                <?= htmlspecialchars(mb_substr($post['summary'], 0, 150)) ?><?= mb_strlen($post['summary']) > 150 ? '...' : '' ?>
                            </p>
                            <?php endif; ?>
                            
                            <div class="blog-card-footer">
                                <?php if ($showAuthor && !empty($post['author'])): ?>
                                <span class="blog-author">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                    </svg>
                                    <?= htmlspecialchars($post['author']) ?>
                                </span>
                                <?php endif; ?>
                                
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="blog-read-more">
                                    <?= __('Read More') ?>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>
                    <?php endforeach; ?>
                <?php endif; ?>
            </div>
            
            <!-- 侧边栏 -->
            <?php if ($showSidebar): ?>
            <aside class="blog-sidebar">
                <!-- 分类 -->
                <?php if (!empty($blogCategories)): ?>
                <div class="sidebar-widget">
                    <h4 class="widget-title"><?= __('Categories') ?></h4>
                    <ul class="category-list">
                        <?php foreach ($blogCategories as $category): ?>
                        <li class="<?= (!empty($currentCategory['id']) && $category['id'] == $currentCategory['id']) ? 'active' : '' ?>">
                            <a href="<?= htmlspecialchars($category['url']) ?>">
                                <?= htmlspecialchars($category['name']) ?>
                                <?php if (isset($category['post_count'])): ?>
                                <span class="category-count">(<?= $category['post_count'] ?>)</span>
                                <?php endif; ?>
                            </a>
                        </li>
                        <?php endforeach; ?>
                    </ul>
                </div>
                <?php endif; ?>
                
                <!-- 最近文章 -->
                <?php if (!empty($recentPosts)): ?>
                <div class="sidebar-widget">
                    <h4 class="widget-title"><?= __('Recent Posts') ?></h4>
                    <ul class="recent-posts-list">
                        <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                        <li>
                            <a href="<?= htmlspecialchars($post['url']) ?>">
                                <?php if (!empty($post['cover_image'])): ?>
                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" 
                                     alt="<?= htmlspecialchars($post['title']) ?>"
                                     loading="lazy">
                                <?php endif; ?>
                                <div class="recent-post-info">
                                    <span class="recent-post-title"><?= htmlspecialchars($post['title']) ?></span>
                                    <?php if (!empty($post['published_at'])): ?>
                                    <span class="recent-post-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>
                            </a>
                        </li>
                        <?php endforeach; ?>
                    </ul>
                </div>
                <?php endif; ?>
            </aside>
            <?php endif; ?>
        </div>
    </div>
</section>

