$page = $this->getData('page') ?? $page ?? null;
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$normalizeDisplay = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$heroDisplay = $normalizeDisplay($getConfig('hero.display', $getConfig('banner.display', 'yes')));
if ($heroDisplay !== 'yes') {
    return;
}

$pageTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Court Piece Electric Mahal';
$pageTitle = $sanitizeTitle($pageTitle);
if ($pageTitle === '') {
    $pageTitle = 'Court Piece Electric Mahal';
}

$heroTitle = $sanitizeTitle((string) $getConfig('hero.title', ''));
if ($heroTitle === '') {
    $heroTitle = $pageTitle;
}

$heroSubtitle = trim((string) $getConfig('hero.subtitle', ''));
if ($heroSubtitle === '') {
    $heroSubtitle = $page ? trim((string) ($page->getData('meta_description') ?: '')) : '';
}
if ($heroSubtitle === '') {
    $heroSubtitle = 'Partner-led trick-taking rooms, dramatic trump calls, and a high-energy mobile experience built for Court Piece fans.';
}

$splitHeadline = static function ($value) {
    $words = preg_split('/\s+/', trim((string) $value)) ?: [];
    $words = array_values(array_filter($words, static function ($item) {
        return $item !== '';
    }));
    if (count($words) <= 2) {
        return [implode(' ', $words), 'Electric Mahal'];
    }
    $pivot = min(2, max(1, (int) ceil(count($words) / 2)));
    $first = implode(' ', array_slice($words, 0, $pivot));
    $second = implode(' ', array_slice($words, $pivot));
    return [$first !== '' ? $first : 'Court Piece', $second !== '' ? $second : 'Electric Mahal'];
};
[$headlineA, $headlineB] = $splitHeadline($heroTitle);

$defaultHeroImage = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/court-piece-electric-mahal/asset/img/mahal-stage.svg');
$heroImage = trim((string) $getConfig('hero.image', $getConfig('banner.image_desktop', '')));
$heroImageMobile = trim((string) $getConfig('hero.image_mobile', $getConfig('banner.image_mobile', '')));
$heroImage = $heroImage !== '' ? $heroImage : $defaultHeroImage;
$heroImageMobile = $heroImageMobile !== '' ? $heroImageMobile : $heroImage;

$heroAlt = trim((string) $getConfig('hero.alt', $getConfig('banner.alt', 'Court Piece Electric Mahal hero')));
if ($heroAlt === '') {
    $heroAlt = 'Court Piece Electric Mahal hero';
}

$heroBgColor = (string) $getConfig('hero.bg_color', $getConfig('banner.bg_color', $colors['hero_bg'] ?? '#2b0f54'));
$heroGradientEnd = (string) ($colors['hero_bg_gradient_end'] ?? '#0b6a72');
$ctaDisplay = $normalizeDisplay($getConfig('download_btn.display', 'yes')) === 'yes';
$ctaText = trim((string) $getConfig('hero.cta_text', $getConfig('download_btn.alt', 'Download App')));
if ($ctaText === '') {
    $ctaText = 'Download App';
}
$ctaUrl = trim((string) $getConfig('hero.cta_url', $getConfig('download_btn.url', '#download')));
if ($ctaUrl === '') {
    $ctaUrl = '#download';
}
$ctaHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaHref, 'url');
$downloadBtnImage = trim((string) $getConfig('download_btn.image', ''));
$sliderClasses = trim((string) $getConfig('layout.slider_classes', 'cpe-hero-stage'));
$marginTop = (int) $getConfig('layout.margin_top', '-72');
$imgMarginTop = (int) $getConfig('layout.img_margin_top', '0');

$featurePills = ['Trump call', 'Partner play', 'Fast rounds'];
$marqueeWords = array_fill(0, 4, $heroTitle);
$instanceId = 'court-piece-electric-mahal-hero-slider-' . uniqid();
