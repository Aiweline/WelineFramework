                            <img class="cpe-download-image" src="<?= htmlspecialchars($downloadBtnImage, ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars($ctaText, ENT_QUOTES, 'UTF-8') ?>">
