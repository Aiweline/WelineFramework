                                    <path d="M12 3a1 1 0 0 1 1 1v8.17l2.59-2.58a1 1 0 1 1 1.41 1.41l-4.3 4.3a1 1 0 0 1-1.4 0L7 11a1 1 0 0 1 1.41-1.41L11 12.17V4a1 1 0 0 1 1-1Zm-6 14a1 1 0 0 1 1 1v1h10v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1Z"></path>
                                </svg>
                            </span>
                            <span><?= htmlspecialchars($ctaText, ENT_QUOTES, 'UTF-8') ?></span>
                        </a>
                        <?php endif; ?>
