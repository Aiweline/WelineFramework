                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="court-piece-electric-mahal-region-empty">
                    <p>拖拽一个 Header 组件到此处</p>
                </div>
            <?php endif; ?>
        </header>
        
        <!-- ========== CONTENT 区域 ========== -->
        <main class="court-piece-electric-mahal-region court-piece-electric-mahal-region-content" data-region="content" data-multiple="true">
            <?php if (!empty($contentComponents)): ?>
                <?php foreach ($contentComponents as $index => $component): ?>
                    <?php if (!is_array($component)) continue; ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="court-piece-electric-mahal-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="content"
                         data-index="<?= $index ?>">
                        <?= $renderComponent($component) ?>
                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="court-piece-electric-mahal-region-empty">
                    <p>拖拽 Content 组件到此处</p>
                </div>
            <?php endif; ?>
        </main>
        
        <!-- ========== FOOTER 区域 ========== -->
        <footer class="court-piece-electric-mahal-region court-piece-electric-mahal-region-footer" data-region="footer" data-multiple="false">
            <?php if (!empty($footerComponents)): ?>
                <?php foreach ($footerComponents as $component): ?>
                    <?php if (!is_array($component)) continue; ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="court-piece-electric-mahal-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="footer">
                        <?= $renderComponent($component) ?>
                    </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="court-piece-electric-mahal-region-empty">
                    <p>拖拽一个 Footer 组件到此处</p>
                </div>
            <?php endif; ?>
        </footer>
        
    </div>
    
    <!-- 本地JS资源 -->
    <?php 
    $localZeptoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/court-piece-electric-mahal/asset/js/zepto.min.js');
