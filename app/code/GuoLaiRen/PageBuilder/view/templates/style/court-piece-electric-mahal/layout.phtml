<?php
/**
 * TPMST 模板主布局 - Main Layout
 * 
 * 定义 header/content/footer 三个区域容器
 * 支持组件动态加载和可视化拖拽
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */

$page = $this->getData('page');
$styleSettingsRaw = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$styleSettings = is_array($styleSettingsRaw) ? $styleSettingsRaw : [];
$pageId = $page && $page->getId() ? $page->getId() : 0;
$templateCode = 'court-piece-electric-mahal';

// 获取页面布局配置（包含组件配置）
$layoutConfigRaw = $this->getData('layout_config');
if (is_string($layoutConfigRaw)) {
    $layoutConfig = json_decode($layoutConfigRaw, true) ?: [];
} else {
    $layoutConfig = is_array($layoutConfigRaw) ? $layoutConfigRaw : [];
}
// 规范化 header/footer：PageLayout::exportConfig() 返回单组件对象 ['component'=>..., 'config'=>...]，模板需要组件数组 [['code'=>..., 'enabled'=>..., 'config'=>...]]
$headerRaw = $layoutConfig['header'] ?? [];
$footerRaw = $layoutConfig['footer'] ?? [];
$headerComponents = is_array($headerRaw) && !isset($headerRaw[0]) && isset($headerRaw['component'])
    ? [['code' => $headerRaw['component'], 'enabled' => true, 'config' => $headerRaw['config'] ?? []]]
    : (is_array($headerRaw) ? $headerRaw : []);
$contentComponents = is_array($layoutConfig['content'] ?? null) ? $layoutConfig['content'] : [];
$footerComponents = is_array($footerRaw) && !isset($footerRaw[0]) && isset($footerRaw['component'])
    ? [['code' => $footerRaw['component'], 'enabled' => true, 'config' => $footerRaw['config'] ?? []]]
    : (is_array($footerRaw) ? $footerRaw : []);

// 如果没有配置，使用默认组件
if (empty($headerComponents)) {
    $headerComponents = [
        ['code' => 'header-nav', 'enabled' => true, 'config' => []]
    ];
}

if (empty($contentComponents)) {
    $contentComponents = [
        ['code' => 'hero-slider', 'enabled' => true, 'config' => ['banner.display' => 'yes', 'layout.slider_classes' => 'rs-slider slider-style2', 'layout.margin_top' => '-75']],
        ['code' => 'advantages', 'enabled' => true, 'config' => []],
        ['code' => 'games', 'enabled' => true, 'config' => []],
        ['code' => 'testimonials', 'enabled' => true, 'config' => []],
        ['code' => 'faq', 'enabled' => true, 'config' => []],
    ];
}

if (empty($footerComponents)) {
    $footerComponents = [
        ['code' => 'footer-links', 'enabled' => true, 'config' => []]
    ];
}

// 组件代码到文件的映射
// 注意：此映射必须与 component.json 保持同步
// 所有组件文件必须实际存在于 components/ 目录下
$componentFiles = [
    // Header 组件
    'header-nav' => 'header/nav.phtml',
    'header-simple' => 'header/simple.phtml',
    'header-dark' => 'header/dark.phtml',
    
    // Content 组件
    'hero-slider' => 'content/hero-slider.phtml',
    'slider' => 'content/slider.phtml',
    'banner' => 'content/banner.phtml',
    'advantages' => 'content/advantages.phtml',
    'games' => 'content/games.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'faq' => 'content/faq.phtml',
    'blog-list' => 'content/blog-list.phtml',
    'blog-detail' => 'content/blog-detail.phtml',
    'blog-category' => 'content/blog-category.phtml',
    'legal-content' => 'content/legal-content.phtml',
    'about-content' => 'content/about-content.phtml',
    'contact-content' => 'content/contact-content.phtml',
    
    // Footer 组件
    'footer-links' => 'footer/links.phtml',
    'footer-simple' => 'footer/simple.phtml',
];

/**
 * 渲染单个组件
 */
$renderComponent = function($component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];
    
    if (!$enabled || empty($code)) {
        return '';
    }
    
    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        // 尝试查找共享组件
        $sharedFile = 'GuoLaiRen_PageBuilder::style/_shared/components/' . $code . '.phtml';
        if (file_exists($this->getTemplateFile($sharedFile))) {
            $this->assign('page', $page);
            $this->assign('style', $styleSettings);
            $this->assign('style_settings', $styleSettings);
            $this->assign('component_config', $componentConfig);
            return $this->fetchTemplate($sharedFile);
        }
        return "<!-- Component not found: {$code} -->";
    }
    
    $templatePath = 'GuoLaiRen_PageBuilder::style/court-piece-electric-mahal/components/' . $file;
    
    // 传递数据到组件
    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', $componentConfig);
    
    try {
        return $this->fetchTemplate($templatePath);
    } catch (\Exception $e) {
        return "<!-- Error loading component {$code}: " . htmlspecialchars($e->getMessage()) . " -->";
    }
};

// 加载颜色配置
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);

// SEO 信息
$metaTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Court Piece Electric Mahal';
$metaDescription = $page ? ($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? ($page->getData('meta_keywords') ?: '') : '';
$pageIcon = $page ? ($page->getData('icon') ?: '') : '';

// 像素配置
$getConfig = function($key, $default = '') use ($styleSettings) {
    return isset($styleSettings[$key]) && $styleSettings[$key] !== '' ? $styleSettings[$key] : $default;
};
$pixelEnabled = $getConfig('pixel.enabled', 'yes');
$pixelName = $getConfig('pixel.name', '');
if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}
$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;
$pathInfo = $this->getRequest()->getPathInfo();
$isPreviewMode = $pathInfo ? (strpos($pathInfo, '/preview/') !== false) : false;
?>
