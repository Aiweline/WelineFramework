<body>
    <div class="court-piece-electric-mahal-layout" data-template="court-piece-electric-mahal" data-page-id="<?= $pageId ?>">
        
        <!-- ========== HEADER 区域 ========== -->
        <header class="court-piece-electric-mahal-region court-piece-electric-mahal-region-header" data-region="header" data-multiple="false">
            <?php if (!empty($headerComponents)): ?>
                <?php foreach ($headerComponents as $component): ?>
                    <?php if (!is_array($component)) continue; ?>
                    <?php if ($component['enabled'] ?? true): ?>
                    <div class="court-piece-electric-mahal-component-wrapper" 
                         data-component="<?= htmlspecialchars($component['code']) ?>"
                         data-region="header">
