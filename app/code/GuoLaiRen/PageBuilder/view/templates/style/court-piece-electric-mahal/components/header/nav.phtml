        animation: none;
    }
}

</style>
<script>
(function () {
    const nav = document.getElementById('<?= $componentId ?>');
    if (!nav) {
        return;
    }

    const toggle = nav.querySelector('.cpe-menu-toggle');
    const panel = nav.querySelector('.cpe-mobile-panel');
    const links = nav.querySelectorAll('.cpe-mobile-link');

    const syncOpenState = (open) => {
        nav.dataset.mobileOpen = open ? 'true' : 'false';
        if (toggle) {
            toggle.classList.toggle('is-open', open);
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
        if (panel) {
            panel.classList.toggle('hidden', !open);
        }
    };

    if (toggle && panel) {
        toggle.addEventListener('click', () => {
            syncOpenState(nav.dataset.mobileOpen !== 'true');
        });
    }

    links.forEach((link) => {
        link.addEventListener('click', () => syncOpenState(false));
    });

    const handleScroll = () => {
        nav.classList.toggle('is-scrolled', window.scrollY > 50);
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
})();
</script>
