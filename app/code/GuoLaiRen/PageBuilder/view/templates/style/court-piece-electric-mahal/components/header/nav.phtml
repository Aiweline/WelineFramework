    position: relative;
    align-items: center;
    gap: 0.7rem;
    min-height: 3.2rem;
    padding: <?= $downloadBtnPaddingY ?>px <?= $downloadBtnPaddingX ?>px;
    border-radius: <?= $downloadBtnRadius ?>px;
    background: linear-gradient(120deg, <?= htmlspecialchars($downloadBtnBgColor, ENT_QUOTES, 'UTF-8') ?> 0%, #ffd166 52%, #fff2b8 100%);
    color: <?= htmlspecialchars($downloadBtnTextColor, ENT_QUOTES, 'UTF-8') ?>;
