<?php
/**
 * Court Piece Electric Mahal - Header Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航头部
 * name_en: Header Navigation
 * description: Center-brand navigation with split desktop links, bold download CTA, and a full-width mobile drawer.
 * category: header
 * region: header
 * thumbnail: asset/img/logo-icon-128.avif
 * @component_end
 *
 * @fields_start
 *
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文本:text:Court Piece Electric Mahal
 * logo.subline => Logo副标题:text:Electric Mahal
 * logo.url => Logo地址:textarea:|默认使用本地mahal-emblem.svg
 * logo.width => Logo宽度:responsive:68/72|px
 * logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 *
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#0a0a0f
 * navigation.bg_color_scrolled => 滚动后背景色:color:rgba(11,7,21,0.96)
 * navigation.text_color => 导航文字颜色:color:#fff7ef
 * navigation.link_color => 链接颜色:color:#f6ecff
 * navigation.link_hover_color => 链接悬停颜色:color:#ffd166
 * navigation.link_font_size => 链接字号:number:14|px
 * navigation.link_font_weight => 链接字重:number:600
 * navigation.link_gap => 链接间距:number:28|px
 * navigation.padding_x => 水平内边距:number:24|px
 * navigation.padding_y => 垂直内边距:number:14|px
 * navigation.min_height => 最小高度:number:78|px
 * navigation.box_shadow => 阴影:text:0 24px 48px rgba(0,0,0,0.24)
 * navigation.backdrop_blur => 背景模糊:number:16|px
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.use_subpages => 使用子页面作为导航:select:no|yes,no
 * navigation.items => 导航项配置:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQs=>/faqs|配置格式：名字=>url，一行一个
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:Download App
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff6b35
 * download_button.bg_hover_color => 按钮悬停背景色:color:#ffd166
 * download_button.text_color => 按钮文字颜色:color:#351500
 * download_button.font_size => 按钮字号:number:13|px
 * download_button.font_weight => 按钮字重:number:800
 * download_button.border_radius => 按钮圆角:number:999|px
 * download_button.padding_x => 按钮水平内边距:number:20|px
 * download_button.padding_y => 按钮垂直内边距:number:11|px
 *
 * @fields_end
 */

$componentId = 'court-piece-electric-mahal-header-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value, $fallback = '68/72') {
    $value = trim((string) ($value !== '' ? $value : $fallback));
    $parts = explode('/', $value);
    return [
        'mobile' => trim((string) ($parts[0] ?? '68')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? '72'))),
    ];
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
if (!$navDisplay) {
    return;
}

$brandName = $sanitizeTitle((string) $getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name', 'texts.app_name'], ''));
if ($brandName === '') {
    $brandName = $sanitizeTitle($page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Court Piece Electric Mahal');
}
if ($brandName === '') {
    $brandName = 'Court Piece Electric Mahal';
}
$brandSubline = trim((string) $getConfigAny(['logo.subline', 'header.logo.subline'], 'Electric Mahal'));

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoWidth = $parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '68/72'));
$logoHeight = $parseResponsive($getConfigAny(['logo.height', 'header.logo.height'], $logoWidth['mobile'] . '/' . $logoWidth['desktop']));
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/court-piece-electric-mahal/asset/img/mahal-emblem.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : (($page && $page->getData('logo')) ? (string) $page->getData('logo') : $defaultLogoUrl);

$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], $colors['nav_bg'] ?? 'rgba(17,8,31,0.78)');
$navBgColorScrolled = (string) $getConfigAny(['navigation.bg_color_scrolled', 'header.navigation.bg_color_scrolled'], $colors['nav_bg_scrolled'] ?? 'rgba(11,7,21,0.96)');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], $colors['nav_text'] ?? '#fff7ef');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], $colors['nav_link'] ?? '#f6ecff');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], $colors['nav_link_hover'] ?? '#ffd166');
$navLinkFontSize = (int) $getConfigAny(['navigation.link_font_size', 'header.navigation.link_font_size'], '14');
$navLinkFontWeight = (int) $getConfigAny(['navigation.link_font_weight', 'header.navigation.link_font_weight'], '600');
$navLinkGap = (int) $getConfigAny(['navigation.link_gap', 'header.navigation.link_gap'], '28');
$navPaddingX = (int) $getConfigAny(['navigation.padding_x', 'header.navigation.padding_x'], '24');
$navPaddingY = (int) $getConfigAny(['navigation.padding_y', 'header.navigation.padding_y'], '14');
$navMinHeight = (int) $getConfigAny(['navigation.min_height', 'header.navigation.min_height'], '78');
$navBoxShadow = (string) $getConfigAny(['navigation.box_shadow', 'header.navigation.box_shadow'], '0 24px 48px rgba(0,0,0,0.24)');
$navBackdropBlur = (int) $getConfigAny(['navigation.backdrop_blur', 'header.navigation.backdrop_blur'], '16');

$navItemsConfig = (string) $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
$useCustomLinksRaw = trim((string) $getConfig('navigation.use_custom_links', $getConfig('header.navigation.use_custom_links', '')));
$legacyUseSubpagesRaw = trim((string) $getConfig('navigation.use_subpages', $getConfig('header.navigation.use_subpages', '')));
if ($useCustomLinksRaw !== '') {
    $useCustomLinks = $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes';
} elseif ($legacyUseSubpagesRaw !== '') {
    $useCustomLinks = $normalizeToggle($legacyUseSubpagesRaw, 'no') !== 'yes';
} else {
    $useCustomLinks = true;
}

$configuredNavItems = [];
if (strpos($navItemsConfig, '\n') !== false && strpos($navItemsConfig, "\n") === false) {
    $navItemsConfig = str_replace('\n', "\n", $navItemsConfig);
}

foreach (preg_split('/\r?\n/', $navItemsConfig) ?: [] as $line) {
    $line = trim((string) $line);
    if ($line === '' || strpos($line, '=>') === false) {
        continue;
    }

    $parts = explode('=>', $line, 2);
    $text = trim((string) ($parts[0] ?? ''));
    $href = trim((string) ($parts[1] ?? ''));
    if ($text === '') {
        continue;
    }

    $configuredNavItems[] = [
        'text' => $text,
        'href' => $href !== '' ? $href : '#',
    ];
}

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);

    foreach ($navigationPages as $navPage) {
        $title = trim((string) ($navPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }

        $type = (string) ($navPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny([
            'navigation_labels.navigation.label_' . $type,
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], ''));

        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $title,
            'href' => (string) ($navPage['url'] ?? '#'),
        ];
    }
}

if ($useCustomLinks || empty($navItems) || (count($navItems) <= 1 && count($configuredNavItems) > 1)) {
    $navItems = $configuredNavItems;
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

$splitIndex = (int) ceil(count($navItems) / 2);
$navLeftItems = array_slice($navItems, 0, $splitIndex);
$navRightItems = array_slice($navItems, $splitIndex);

$downloadDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$downloadText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text'], 'Download App'));
$downloadUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url'], '#download'));
$downloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $downloadUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadHref, 'url');
$downloadBtnBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff6b35');
$downloadBtnBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], '#ffd166');
$downloadBtnTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#351500');
$downloadBtnFontSize = (int) $getConfigAny(['download_button.font_size', 'header.download_button.font_size'], '13');
$downloadBtnFontWeight = (int) $getConfigAny(['download_button.font_weight', 'header.download_button.font_weight'], '800');
$downloadBtnRadius = (int) $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '999');
$downloadBtnPaddingX = (int) $getConfigAny(['download_button.padding_x', 'header.download_button.padding_x'], '20');
$downloadBtnPaddingY = (int) $getConfigAny(['download_button.padding_y', 'header.download_button.padding_y'], '11');

?>
<script src="https://cdn.tailwindcss.com"></script>
<nav id="<?= $componentId ?>" class="cpe-nav" aria-label="Primary navigation" data-mobile-open="false">
    <div class="cpe-ribbon">
        <div class="mx-auto flex w-full max-w-[1260px] items-center gap-3 px-4 py-3 md:px-6 xl:grid xl:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)_auto] xl:gap-5" style="min-height: <?= $navMinHeight ?>px;">
            <div class="hidden xl:block min-w-0">
                <ul class="cpe-links justify-start" role="list">
                    <?php foreach ($navLeftItems as $item): ?>
                    <li>
                        <a href="<?= htmlspecialchars((string) ($item['href'] ?? '#'), ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars((string) ($item['text'] ?? ''), ENT_QUOTES, 'UTF-8') ?></a>
                    </li>
                    <?php endforeach; ?>
                </ul>
            </div>

            <a class="cpe-brand min-w-0 xl:justify-self-center" href="/" aria-label="<?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?> home">
                <?php if ($logoDisplay): ?>
                <span class="cpe-brand-mark">
                    <img src="<?= htmlspecialchars((string) $logoUrl, ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?>" style="width: <?= (float) $logoWidth['mobile'] ?>px; height: <?= (float) $logoHeight['mobile'] ?>px;">
                </span>
                <?php endif; ?>
                <span class="cpe-brand-copy">
                    <strong><?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?></strong>
                    <?php if ($brandSubline !== ''): ?>
                    <small><?= htmlspecialchars($brandSubline, ENT_QUOTES, 'UTF-8') ?></small>
                    <?php endif; ?>
                </span>
            </a>

            <div class="hidden xl:block min-w-0">
                <ul class="cpe-links justify-end" role="list">
                    <?php foreach ($navRightItems as $item): ?>
                    <li>
                        <a href="<?= htmlspecialchars((string) ($item['href'] ?? '#'), ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars((string) ($item['text'] ?? ''), ENT_QUOTES, 'UTF-8') ?></a>
                    </li>
                    <?php endforeach; ?>
                </ul>
            </div>

            <div class="ml-auto flex items-center gap-3 xl:ml-0">
                <?php if ($downloadDisplay && $downloadText !== ''): ?>
                <a class="cpe-ticket hidden sm:inline-flex" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($downloadRef), ENT_QUOTES, 'UTF-8') ?>" data-glr-ref="<?= htmlspecialchars($downloadRef, ENT_QUOTES, 'UTF-8') ?>">
                    <span class="cpe-ticket-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                            <path d="M12 4V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                            <path d="M8 10L12 14L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                            <path d="M5 18H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                    </span>
                    <span><?= htmlspecialchars($downloadText, ENT_QUOTES, 'UTF-8') ?></span>
                </a>
                <?php endif; ?>

                <button class="cpe-menu-toggle inline-flex xl:hidden" type="button" aria-expanded="false" aria-controls="<?= $componentId ?>-mobile" aria-label="Toggle navigation">
                    <span></span>
                </button>
            </div>
        </div>

        <div id="<?= $componentId ?>-mobile" class="cpe-mobile-panel hidden xl:hidden">
            <div class="mx-auto w-full max-w-[1260px] pb-4 md:px-6">
                <div class="cpe-mobile-stage">
                    <div class="cpe-mobile-copy">
                        <span class="cpe-mobile-kicker">Court Piece route map</span>
                        <strong><?= htmlspecialchars($brandName, ENT_QUOTES, 'UTF-8') ?></strong>
                        <p>Bold entry lanes, faster page scanning, and a direct download path tuned for mobile table traffic.</p>
                    </div>

                    <ul class="grid gap-3 sm:grid-cols-2" role="list">
                        <?php foreach ($navItems as $item): ?>
                        <li>
                            <a class="cpe-mobile-link" href="<?= htmlspecialchars((string) ($item['href'] ?? '#'), ENT_QUOTES, 'UTF-8') ?>">
                                <span><?= htmlspecialchars((string) ($item['text'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span>
                                <span aria-hidden="true">↗</span>
                            </a>
                        </li>
                        <?php endforeach; ?>
                    </ul>

                    <?php if ($downloadDisplay && $downloadText !== ''): ?>
                    <a class="cpe-ticket hidden w-full justify-center sm:inline-flex xl:hidden" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($downloadRef), ENT_QUOTES, 'UTF-8') ?>" data-glr-ref="<?= htmlspecialchars($downloadRef, ENT_QUOTES, 'UTF-8') ?>">
                        <span class="cpe-ticket-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                                <path d="M12 4V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                                <path d="M8 10L12 14L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                <path d="M5 18H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                            </svg>
                        </span>
                        <span><?= htmlspecialchars($downloadText, ENT_QUOTES, 'UTF-8') ?></span>
                    </a>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</nav>
