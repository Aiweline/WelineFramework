<?php
/**
 * LudoEmpire - Testimonials Component
 * 
 * 玩家评价展示，包含星级评分和奖金数额
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Player Reviews
 * content.title => 标题:text:What Our Players Say
 * content.description => 描述:textarea:Real reviews from real players who love LudoEmpire.
 * 
 * group:testimonials => 评价列表
 * testimonials.items => 评价列表:textarea:RajGamer99|⭐⭐⭐⭐⭐|Best Ludo app ever! I've won over ₹25,000 playing tournaments. The dice is fair and gameplay is super smooth.|₹25,000+ Won|🎲 Tournament Player\r\nPriyaStar|⭐⭐⭐⭐⭐|Love the voice chat feature! Playing with friends has never been this fun. Highly recommend to everyone!|₹12,500+ Won|👥 Team Battle Fan\r\nAkashKing|⭐⭐⭐⭐⭐|Quick payouts, fair gameplay, and amazing tournaments. This is the only Ludo app you need!|₹50,000+ Won|🏆 Top 100 Player|格式：用户名|星级|评价|奖金|标签，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['testimonials_bg'] ?? '#0d0020';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';
$starColor = $colors['star_color'] ?? '#fbbf24';
$winColor = $colors['win_color'] ?? '#22c55e';

$badge = $config['content.badge'] ?? 'Player Reviews';
$title = $config['content.title'] ?? 'What Our Players Say';
$description = $config['content.description'] ?? 'Real reviews from real players who love LudoEmpire.';

$testimonialsRaw = $config['testimonials.items'] ?? "RajGamer99|⭐⭐⭐⭐⭐|Best Ludo app ever! I've won over ₹25,000 playing tournaments. The dice is fair and gameplay is super smooth.|₹25,000+ Won|🎲 Tournament Player\nPriyaStar|⭐⭐⭐⭐⭐|Love the voice chat feature! Playing with friends has never been this fun. Highly recommend to everyone!|₹12,500+ Won|👥 Team Battle Fan\nAkashKing|⭐⭐⭐⭐⭐|Quick payouts, fair gameplay, and amazing tournaments. This is the only Ludo app you need!|₹50,000+ Won|🏆 Top 100 Player";

$testimonials = [];
$lines = preg_split('/[\r\n]+/', $testimonialsRaw);
$avatarColors = ['#8b5cf6', '#ec4899', '#06b6d4'];
foreach ($lines as $i => $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 5);
    $testimonials[] = [
        'username' => trim($parts[0] ?? ''),
        'stars' => trim($parts[1] ?? '⭐⭐⭐⭐⭐'),
        'review' => trim($parts[2] ?? ''),
        'winnings' => trim($parts[3] ?? ''),
        'tag' => trim($parts[4] ?? ''),
        'color' => $avatarColors[$i % count($avatarColors)],
    ];
}

$instanceId = 'le-testimonials-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .le-test-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .le-test-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .le-test-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .le-test-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-test-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
        }
        
        #<?= $instanceId ?> .le-test-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .le-test-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-test-card:hover {
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(139, 92, 246, 0.15);
        }
        
        #<?= $instanceId ?> .le-test-stars {
            font-size: 1.1rem;
            margin-bottom: 16px;
            letter-spacing: 2px;
        }
        
        #<?= $instanceId ?> .le-test-review {
            font-size: 1rem;
            color: <?= $textSecondary ?>;
            line-height: 1.7;
            margin-bottom: 24px;
            font-style: italic;
        }
        
        #<?= $instanceId ?> .le-test-author {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        
        #<?= $instanceId ?> .le-test-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 800;
            color: #ffffff;
        }
        
        #<?= $instanceId ?> .le-test-info {
            flex: 1;
        }
        
        #<?= $instanceId ?> .le-test-name {
            font-size: 1rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
        }
        
        #<?= $instanceId ?> .le-test-tag {
            font-size: 0.8rem;
            color: <?= $textSecondary ?>;
        }
        
        #<?= $instanceId ?> .le-test-winnings {
            font-size: 0.85rem;
            font-weight: 700;
            color: <?= $winColor ?>;
            padding: 4px 12px;
            background: rgba(34, 197, 94, 0.12);
            border-radius: 20px;
            white-space: nowrap;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .le-test-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-test-grid {
                grid-template-columns: 1fr;
            }
            
            #<?= $instanceId ?> .le-test-title {
                font-size: 1.75rem;
            }
        }
    </style>
    
    <div class="le-test-container">
        <div class="le-test-header">
            <div class="le-test-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="le-test-title"><?= htmlspecialchars($title) ?></h2>
            <p class="le-test-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="le-test-grid">
            <?php foreach ($testimonials as $t): ?>
            <div class="le-test-card">
                <div class="le-test-stars"><?= htmlspecialchars($t['stars']) ?></div>
                <p class="le-test-review">"<?= htmlspecialchars($t['review']) ?>"</p>
                <div class="le-test-author">
                    <div class="le-test-avatar" style="background: <?= htmlspecialchars($t['color']) ?>;">
                        <?= htmlspecialchars(mb_strtoupper(mb_substr($t['username'], 0, 1))) ?>
                    </div>
                    <div class="le-test-info">
                        <div class="le-test-name"><?= htmlspecialchars($t['username']) ?></div>
                        <div class="le-test-tag"><?= htmlspecialchars($t['tag']) ?></div>
                    </div>
                    <?php if ($t['winnings']): ?>
                    <span class="le-test-winnings"><?= htmlspecialchars($t['winnings']) ?></span>
                    <?php endif; ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
