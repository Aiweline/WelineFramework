<?php
/**
 * LudoEmpire - Advantages Component
 * 
 * 6大平台优势展示
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Why Choose Us
 * content.title => 标题:text:The Ultimate Ludo Experience
 * content.description => 描述:textarea:Everything you need for the perfect game, all in one place.
 * 
 * group:advantages => 优势列表
 * advantages.items => 优势列表:textarea:Fair Dice System|🎲|Our certified RNG ensures every roll is truly random and fair. No bias, no tricks.|#8b5cf6\r\nReal Cash Prizes|💰|Win real money in tournaments and head-to-head matches. Withdraw anytime!|#ec4899\r\nVoice Chat|🎤|Talk with your opponents in real-time. Laugh, strategize, and have fun!|#06b6d4\r\nAnti-Cheat System|🛡️|Advanced detection ensures a level playing field for everyone.|#f59e0b\r\nInstant Payouts|💸|Withdraw your winnings instantly to your bank or wallet. No waiting!|#22c55e\r\n24/7 Tournaments|🏅|Round-the-clock tournaments with prize pools for every budget.|#ef4444|格式：标题|图标|描述|颜色，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['advantages_bg'] ?? '#110028';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'Why Choose Us';
$title = $config['content.title'] ?? 'The Ultimate Ludo Experience';
$description = $config['content.description'] ?? 'Everything you need for the perfect game, all in one place.';

$advRaw = $config['advantages.items'] ?? "Fair Dice System|🎲|Our certified RNG ensures every roll is truly random and fair. No bias, no tricks.|#8b5cf6\nReal Cash Prizes|💰|Win real money in tournaments and head-to-head matches. Withdraw anytime!|#ec4899\nVoice Chat|🎤|Talk with your opponents in real-time. Laugh, strategize, and have fun!|#06b6d4\nAnti-Cheat System|🛡️|Advanced detection ensures a level playing field for everyone.|#f59e0b\nInstant Payouts|💸|Withdraw your winnings instantly to your bank or wallet. No waiting!|#22c55e\n24/7 Tournaments|🏅|Round-the-clock tournaments with prize pools for every budget.|#ef4444";

$advantages = [];
$lines = preg_split('/[\r\n]+/', $advRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 4);
    $advantages[] = [
        'title' => trim($parts[0] ?? ''),
        'icon' => trim($parts[1] ?? '✨'),
        'description' => trim($parts[2] ?? ''),
        'color' => trim($parts[3] ?? '#8b5cf6'),
    ];
}

$instanceId = 'le-advantages-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .le-adv-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .le-adv-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .le-adv-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .le-adv-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-adv-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
        }
        
        #<?= $instanceId ?> .le-adv-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .le-adv-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s ease;
            text-align: center;
        }
        
        #<?= $instanceId ?> .le-adv-card:hover {
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(139, 92, 246, 0.15);
        }
        
        #<?= $instanceId ?> .le-adv-icon {
            width: 72px;
            height: 72px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 20px;
        }
        
        #<?= $instanceId ?> .le-adv-card-title {
            font-size: 1.15rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 10px;
        }
        
        #<?= $instanceId ?> .le-adv-card-desc {
            font-size: 0.95rem;
            color: <?= $textSecondary ?>;
            line-height: 1.6;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .le-adv-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-adv-grid {
                grid-template-columns: 1fr;
            }
            
            #<?= $instanceId ?> .le-adv-title {
                font-size: 1.75rem;
            }
        }
    </style>
    
    <div class="le-adv-container">
        <div class="le-adv-header">
            <div class="le-adv-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="le-adv-title"><?= htmlspecialchars($title) ?></h2>
            <p class="le-adv-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="le-adv-grid">
            <?php foreach ($advantages as $adv): ?>
            <div class="le-adv-card">
                <div class="le-adv-icon" style="background: <?= htmlspecialchars($adv['color']) ?>20; border: 1px solid <?= htmlspecialchars($adv['color']) ?>40;">
                    <?= htmlspecialchars($adv['icon']) ?>
                </div>
                <h3 class="le-adv-card-title"><?= htmlspecialchars($adv['title']) ?></h3>
                <p class="le-adv-card-desc"><?= htmlspecialchars($adv['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
