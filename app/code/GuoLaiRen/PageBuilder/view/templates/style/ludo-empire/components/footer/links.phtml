/**
 * LudoEmpire - Footer Links Component
 * 
 * 页脚区域，包含品牌信息、3列链接和版权声明
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:LudoEmpire
 * brand.description => 品牌描述:textarea:The ultimate online Ludo gaming platform. Play with friends, win prizes, and enjoy the classic board game experience.
 * 
 * group:links => 链接设置
 * links.column1_title => 栏目1标题:text:Games
 * links.column1_items => 栏目1链接:textarea:Classic Ludo=>/games/classic\r\nQuick Ludo=>/games/quick\r\nTournaments=>/games/tournaments\r\nTeam Battle=>/games/team|格式：名称=>链接，一行一个
 * links.column2_title => 栏目2标题:text:Company
 * links.column2_items => 栏目2链接:textarea:About Us=>/about\r\nBlog=>/blog\r\nCareers=>/careers\r\nPress Kit=>/press|格式：名称=>链接，一行一个
 * links.column3_title => 栏目3标题:text:Support
 * links.column3_items => 栏目3链接:textarea:Help Center=>/help\r\nContact Us=>/contact\r\nFAQ=>/faq\r\nCommunity=>/community|格式：名称=>链接，一行一个
 * 
 * group:legal => 法律链接
 * legal.items => 法律链接:textarea:Privacy Policy=>/privacy\r\nTerms of Service=>/terms\r\nCookie Policy=>/cookies\r\nRefund Policy=>/refund|格式：名称=>链接，一行一个
 * 
 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved. Play responsibly.
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$footerBg = $colors['footer_bg'] ?? '#06000e';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textMuted = $colors['text_muted'] ?? '#7c6fad';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';
$footerLink = $colors['footer_link'] ?? '#c4b5fd';
$footerLinkHover = $colors['footer_link_hover'] ?? '#ec4899';
$footerBorder = $colors['footer_border'] ?? 'rgba(139, 92, 246, 0.1)';

$brandName = $config['brand.name'] ?? 'LudoEmpire';
$brandDesc = $config['brand.description'] ?? 'The ultimate online Ludo gaming platform. Play with friends, win prizes, and enjoy the classic board game experience.';

$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$col1Title = $config['links.column1_title'] ?? 'Games';
$col1Links = $parseLinks($config['links.column1_items'] ?? "Classic Ludo=>/games/classic\nQuick Ludo=>/games/quick\nTournaments=>/games/tournaments\nTeam Battle=>/games/team");
$col2Title = $config['links.column2_title'] ?? 'Company';
$col2Links = $parseLinks($config['links.column2_items'] ?? "About Us=>/about\nBlog=>/blog\nCareers=>/careers\nPress Kit=>/press");
$col3Title = $config['links.column3_title'] ?? 'Support';
$col3Links = $parseLinks($config['links.column3_items'] ?? "Help Center=>/help\nContact Us=>/contact\nFAQ=>/faq\nCommunity=>/community");
$legalLinks = $parseLinks($config['legal.items'] ?? "Privacy Policy=>/privacy\nTerms of Service=>/terms\nCookie Policy=>/cookies\nRefund Policy=>/refund");

$copyrightText = $config['copyright.text'] ?? 'All rights reserved. Play responsibly.';
$currentYear = date('Y');

$instanceId = 'le-footer-' . uniqid();
?>

