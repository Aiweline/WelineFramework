// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色辅助函数
if (!function_exists('le_color')) {
    function le_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

// 配置辅助函数
if (!function_exists('le_getConfig')) {
    function le_getConfig($settings, $key, $default = '') {
        $value = $settings[$key] ?? $default;
        if ($value === '' && $default !== '') {
            return $default;
        }
        return $value;
    }
}

// 获取页面标题和元数据
