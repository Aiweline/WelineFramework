<?php
/**
 * LudoEmpire - FAQ Section Component
 * 
 * 常见问题手风琴展示
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:FAQ
 * content.title => 标题:text:Got Questions? We've Got Answers!
 * content.description => 描述:textarea:Everything you need to know about playing Ludo on our platform.
 * 
 * group:faq => FAQ列表
 * faq.items => FAQ列表:textarea:How do I play Ludo online?|Simply download the app, create an account, choose a game mode, and start playing! You can play against random opponents or invite friends using a room code.\r\nIs LudoEmpire free to play?|Yes! You can play Classic Ludo for free. We also offer cash games and tournaments where you can win real prizes.\r\nHow can I win real cash?|Join cash games or tournaments. Entry fees start as low as ₹10. Win matches to earn real money that you can withdraw instantly!\r\nIs the dice system fair?|Absolutely! We use a certified Random Number Generator (RNG) that ensures every dice roll is completely random and fair.\r\nHow do I withdraw my winnings?|Go to your wallet, tap Withdraw, choose your payment method (UPI, bank transfer, or wallet), and get your money instantly!\r\nCan I play with friends?|Yes! Create a private room and share the code with friends. You can also use voice chat during the game.|格式：问题|回答，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['faq_bg'] ?? '#0b001a';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$textMuted = $colors['text_muted'] ?? '#7c6fad';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'FAQ';
$title = $config['content.title'] ?? "Got Questions? We've Got Answers!";
$description = $config['content.description'] ?? 'Everything you need to know about playing Ludo on our platform.';

$faqRaw = $config['faq.items'] ?? "How do I play Ludo online?|Simply download the app, create an account, choose a game mode, and start playing! You can play against random opponents or invite friends using a room code.\nIs LudoEmpire free to play?|Yes! You can play Classic Ludo for free. We also offer cash games and tournaments where you can win real prizes.\nHow can I win real cash?|Join cash games or tournaments. Entry fees start as low as ₹10. Win matches to earn real money that you can withdraw instantly!\nIs the dice system fair?|Absolutely! We use a certified Random Number Generator (RNG) that ensures every dice roll is completely random and fair.\nHow do I withdraw my winnings?|Go to your wallet, tap Withdraw, choose your payment method (UPI, bank transfer, or wallet), and get your money instantly!\nCan I play with friends?|Yes! Create a private room and share the code with friends. You can also use voice chat during the game.";

$faqs = [];
$lines = preg_split('/[\r\n]+/', $faqRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $question = trim($parts[0] ?? '');
    $answer = trim($parts[1] ?? '');
    if (!empty($question)) {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

$instanceId = 'le-faq-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .le-faq-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .le-faq-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .le-faq-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .le-faq-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-faq-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .le-faq-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        #<?= $instanceId ?> .le-faq-item {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-faq-item:hover {
            border-color: rgba(139, 92, 246, 0.3);
        }
        
        #<?= $instanceId ?> .le-faq-item.active {
            border-color: <?= $accentSecondary ?>;
        }
        
        #<?= $instanceId ?> .le-faq-question {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 20px 24px;
            cursor: pointer;
            transition: background 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-faq-question:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        
        #<?= $instanceId ?> .le-faq-question-text {
            font-size: 1.05rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            flex: 1;
        }
        
        #<?= $instanceId ?> .le-faq-question-icon {
            width: 34px;
            height: 34px;
            background: rgba(139, 92, 246, 0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-faq-question-icon svg {
            width: 16px;
            height: 16px;
            fill: <?= $accentPrimaryLight ?>;
            transition: transform 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-faq-item.active .le-faq-question-icon {
            background: linear-gradient(135deg, <?= $accentPrimary ?>, <?= $accentSecondary ?>);
        }
        
        #<?= $instanceId ?> .le-faq-item.active .le-faq-question-icon svg {
            fill: #ffffff;
            transform: rotate(180deg);
        }
        
        #<?= $instanceId ?> .le-faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-faq-item.active .le-faq-answer {
            max-height: 500px;
        }
        
        #<?= $instanceId ?> .le-faq-answer-content {
            padding: 0 24px 24px;
            font-size: 0.95rem;
            color: <?= $textMuted ?>;
            line-height: 1.7;
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-faq-title {
                font-size: 1.75rem;
            }
            
            #<?= $instanceId ?> .le-faq-question {
                padding: 16px 20px;
            }
            
            #<?= $instanceId ?> .le-faq-question-text {
                font-size: 0.95rem;
            }
            
            #<?= $instanceId ?> .le-faq-answer-content {
                padding: 0 20px 20px;
            }
        }
    </style>
    
    <div class="le-faq-container">
        <div class="le-faq-header">
            <div class="le-faq-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="le-faq-title"><?= htmlspecialchars($title) ?></h2>
            <p class="le-faq-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="le-faq-list">
            <?php foreach ($faqs as $index => $faq): ?>
            <div class="le-faq-item<?= $index === 0 ? ' active' : '' ?>">
                <div class="le-faq-question" onclick="this.parentElement.classList.toggle('active')">
                    <span class="le-faq-question-text"><?= htmlspecialchars($faq['question']) ?></span>
                    <span class="le-faq-question-icon">
                        <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                    </span>
                </div>
                <div class="le-faq-answer">
                    <div class="le-faq-answer-content"><?= htmlspecialchars($faq['answer']) ?></div>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
