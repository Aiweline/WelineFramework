<?php
/**
 * LudoEmpire 模板 - Header
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:LudoEmpire
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:42|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 背景颜色:color:rgba(9, 0, 18, 0.95)
 * navigation.text_color => 文字颜色:color:#f5f3ff
 * navigation.link_hover_color => 链接悬停颜色:color:#ec4899
 * navigation.links => 导航链接:textarea:Home=>/\r\nGames=>/games\r\nDownload=>/download\r\nFAQ=>/faq|格式：名称=>链接，一行一个
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Play Now
 * navigation.cta_url => CTA按钮链接:text:#games
 * 
 * group:pixel => 像素统计:📊访客像素统计配置:配置访客像素统计功能，用于记录页面访问数据。像素统计会自动使用页面绑定的网站（website_id）进行数据关联。
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}:用于区分不同页面的统计来源，默认使用页面的 handle 作为像素名称。留空将自动使用页面的 handle。
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'ludo-empire';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'ludo-empire';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 辅助函数
if (!function_exists('le_color')) {
    function le_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('le_getConfig')) {
    function le_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// Logo配置
$logoDisplay = le_getConfig($styleSettings, 'logo.display', 'yes');
$logoText = le_getConfig($styleSettings, 'logo.text', 'LudoEmpire');
$logoUrl = le_getConfig($styleSettings, 'logo.url', '');
$logoWidth = le_getConfig($styleSettings, 'logo.width', '42');

// 导航配置
$navDisplay = le_getConfig($styleSettings, 'navigation.display', 'yes');
$navBgColor = le_getConfig($styleSettings, 'navigation.bg_color', 'rgba(9, 0, 18, 0.95)');
$navTextColor = le_getConfig($styleSettings, 'navigation.text_color', '#f5f3ff');
$navLinkHoverColor = le_getConfig($styleSettings, 'navigation.link_hover_color', '#ec4899');
$navLinksRaw = le_getConfig($styleSettings, 'navigation.links', "Home=>/\nGames=>/games\nDownload=>/download\nFAQ=>/faq");
$showCta = le_getConfig($styleSettings, 'navigation.show_cta', 'yes');
$ctaText = le_getConfig($styleSettings, 'navigation.cta_text', 'Play Now');
$ctaUrl = le_getConfig($styleSettings, 'navigation.cta_url', '#games');

// 颜色配置
$accentPrimary = le_color($colors, 'accent_primary', '#8b5cf6');
$buttonPrimaryBg = le_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)');

// 解析导航链接
$navLinks = [];
$lines = preg_split('/[\r\n]+/', $navLinksRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('=>', $line, 2);
    $name = trim($parts[0] ?? '');
    $url = trim($parts[1] ?? '#');
    if (!empty($name)) {
        $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
?>

<?php if ($navDisplay === 'yes'): ?>
<style>
