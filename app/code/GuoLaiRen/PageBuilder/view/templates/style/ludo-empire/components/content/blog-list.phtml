<?php
/**
 * LudoEmpire - Blog List Component
 * 
 * 博客文章列表，支持分类筛选和网格布局
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Blog
 * content.title => 标题:text:Latest from LudoEmpire
 * content.description => 描述:textarea:Tips, strategies, and news from the world of Ludo gaming.
 * 
 * group:categories => 分类设置
 * categories.items => 分类列表:textarea:All|all\r\nStrategies|strategies\r\nTournaments|tournaments\r\nUpdates|updates\r\nTips & Tricks|tips|格式：名称|slug，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0020';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$textMuted = $colors['text_muted'] ?? '#7c6fad';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'Blog';
$title = $config['content.title'] ?? 'Latest from LudoEmpire';
$description = $config['content.description'] ?? 'Tips, strategies, and news from the world of Ludo gaming.';

$catsRaw = $config['categories.items'] ?? "All|all\nStrategies|strategies\nTournaments|tournaments\nUpdates|updates\nTips & Tricks|tips";
$categories = [];
$catLines = preg_split('/[\r\n]+/', $catsRaw);
foreach ($catLines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $categories[] = ['name' => trim($parts[0] ?? ''), 'slug' => trim($parts[1] ?? '')];
}

// Default blog posts for display
$posts = [
    ['title' => '10 Winning Strategies for Ludo Tournaments', 'excerpt' => 'Master these proven strategies to dominate any Ludo tournament and climb the leaderboard.', 'category' => 'Strategies', 'date' => 'Feb 1, 2026', 'read_time' => '5 min read'],
    ['title' => 'February Tournament Schedule Released', 'excerpt' => 'Check out the exciting lineup of tournaments this month with prize pools up to ₹1,00,000!', 'category' => 'Tournaments', 'date' => 'Jan 28, 2026', 'read_time' => '3 min read'],
    ['title' => 'New Team Battle Mode Now Live!', 'excerpt' => 'Team up with friends in our brand new 2v2 Team Battle mode. Coordinate, strategize, and win together!', 'category' => 'Updates', 'date' => 'Jan 25, 2026', 'read_time' => '4 min read'],
    ['title' => 'How to Use Safe Zones Effectively', 'excerpt' => 'Learn the art of positioning your tokens in safe zones to protect them while maintaining offensive pressure.', 'category' => 'Tips & Tricks', 'date' => 'Jan 20, 2026', 'read_time' => '6 min read'],
    ['title' => 'Top Players of January 2026', 'excerpt' => 'Congratulations to our top performers this month! See who made it to the Hall of Fame.', 'category' => 'Tournaments', 'date' => 'Jan 18, 2026', 'read_time' => '3 min read'],
    ['title' => 'Understanding Dice Probability in Ludo', 'excerpt' => 'A deep dive into dice probabilities and how to make better decisions based on statistical odds.', 'category' => 'Strategies', 'date' => 'Jan 15, 2026', 'read_time' => '7 min read'],
];

$instanceId = 'le-blog-list-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .le-bl-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .le-bl-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        #<?= $instanceId ?> .le-bl-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .le-bl-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-bl-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
        }
        
        #<?= $instanceId ?> .le-bl-filters {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 48px;
        }
        
        #<?= $instanceId ?> .le-bl-filter {
            padding: 8px 20px;
            font-size: 0.9rem;
            font-weight: 600;
            border-radius: 50px;
            border: 1px solid <?= $borderLight ?>;
            background: transparent;
            color: <?= $textSecondary ?>;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-bl-filter:hover,
        #<?= $instanceId ?> .le-bl-filter.active {
            background: <?= $buttonPrimaryBg ?>;
            border-color: transparent;
            color: #ffffff;
        }
        
        #<?= $instanceId ?> .le-bl-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .le-bl-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
            text-decoration: none;
            display: block;
        }
        
        #<?= $instanceId ?> .le-bl-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(139, 92, 246, 0.15);
            border-color: rgba(236, 72, 153, 0.3);
        }
        
        #<?= $instanceId ?> .le-bl-card-image {
            height: 180px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(236, 72, 153, 0.1));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }
        
        #<?= $instanceId ?> .le-bl-card-body {
            padding: 24px;
        }
        
        #<?= $instanceId ?> .le-bl-card-cat {
            font-size: 0.8rem;
            font-weight: 700;
            color: <?= $accentSecondary ?>;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        #<?= $instanceId ?> .le-bl-card-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 8px;
            line-height: 1.4;
        }
        
        #<?= $instanceId ?> .le-bl-card-excerpt {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
            line-height: 1.6;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-bl-card-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            color: <?= $textMuted ?>;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .le-bl-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-bl-grid {
                grid-template-columns: 1fr;
            }
            
            #<?= $instanceId ?> .le-bl-title {
                font-size: 1.75rem;
            }
        }
    </style>
    
    <div class="le-bl-container">
        <div class="le-bl-header">
            <div class="le-bl-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="le-bl-title"><?= htmlspecialchars($title) ?></h2>
            <p class="le-bl-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <?php if (!empty($categories)): ?>
        <div class="le-bl-filters">
            <?php foreach ($categories as $i => $cat): ?>
            <button class="le-bl-filter<?= $i === 0 ? ' active' : '' ?>"><?= htmlspecialchars($cat['name']) ?></button>
            <?php endforeach; ?>
        </div>
        <?php endif; ?>
        
        <div class="le-bl-grid">
            <?php $icons = ['📋', '🏆', '🚀', '🎯', '⭐', '🎲']; ?>
            <?php foreach ($posts as $i => $post): ?>
            <a href="#" class="le-bl-card">
                <div class="le-bl-card-image"><?= $icons[$i % count($icons)] ?></div>
                <div class="le-bl-card-body">
                    <div class="le-bl-card-cat"><?= htmlspecialchars($post['category']) ?></div>
                    <h3 class="le-bl-card-title"><?= htmlspecialchars($post['title']) ?></h3>
                    <p class="le-bl-card-excerpt"><?= htmlspecialchars($post['excerpt']) ?></p>
                    <div class="le-bl-card-meta">
                        <span><?= htmlspecialchars($post['date']) ?></span>
                        <span><?= htmlspecialchars($post['read_time']) ?></span>
                    </div>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
