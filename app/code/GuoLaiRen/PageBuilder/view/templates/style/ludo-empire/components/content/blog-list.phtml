<?php
/**
 * LudoEmpire - Blog List Component
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 *
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Blog
 * content.title => 标题:text:Latest from LudoEmpire
 * content.description => 描述:textarea:Tips, strategies, and news from the world of Ludo gaming.
 * group:categories => 分类设置
 * categories.items => 分类列表:textarea:All|all\r\nStrategies|strategies\r\nTournaments|tournaments\r\nUpdates|updates\r\nTips & Tricks|tips|格式：名称|slug，一行一个
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0020';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$textMuted = $colors['text_muted'] ?? '#7c6fad';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'Blog';
$title = $config['content.title'] ?? 'Latest from LudoEmpire';
$description = $config['content.description'] ?? 'Tips, strategies, and news from the world of Ludo gaming.';
$isPreview = (bool)($this->getData('is_preview') ?? false);
$page = $this->getData('page');

$catsRaw = $config['categories.items'] ?? "All|all\nStrategies|strategies\nTournaments|tournaments\nUpdates|updates\nTips & Tricks|tips";
$categories = [];
foreach (preg_split('/[\r\n]+/', $catsRaw) as $line) {
    $line = trim($line);
    if ($line === '') {
        continue;
    }
    $parts = explode('|', $line, 2);
    $categories[] = [
        'name' => trim($parts[0] ?? ''),
        'slug' => trim($parts[1] ?? ''),
    ];
}

$blogPosts = $this->getData('blog_posts');
if ((!is_array($blogPosts) || $blogPosts === []) && $page && method_exists($page, 'getData')) {
    $blogPosts = $page->getData('blog_posts') ?? [];
}

$samplePosts = [
    ['title' => '10 Winning Strategies for Ludo Tournaments', 'excerpt' => 'Master these proven strategies to dominate any Ludo tournament and climb the leaderboard.', 'category' => 'Strategies', 'date' => 'Feb 1, 2026', 'read_time' => '5 min read'],
    ['title' => 'February Tournament Schedule Released', 'excerpt' => 'Check out the exciting lineup of tournaments this month with prize pools up to $100,000!', 'category' => 'Tournaments', 'date' => 'Jan 28, 2026', 'read_time' => '3 min read'],
    ['title' => 'New Team Battle Mode Now Live!', 'excerpt' => 'Team up with friends in our brand new 2v2 Team Battle mode. Coordinate, strategize, and win together!', 'category' => 'Updates', 'date' => 'Jan 25, 2026', 'read_time' => '4 min read'],
    ['title' => 'How to Use Safe Zones Effectively', 'excerpt' => 'Learn the art of positioning your tokens in safe zones to protect them while maintaining offensive pressure.', 'category' => 'Tips & Tricks', 'date' => 'Jan 20, 2026', 'read_time' => '6 min read'],
    ['title' => 'Top Players of January 2026', 'excerpt' => 'Congratulations to our top performers this month! See who made it to the Hall of Fame.', 'category' => 'Tournaments', 'date' => 'Jan 18, 2026', 'read_time' => '3 min read'],
    ['title' => 'Understanding Dice Probability in Ludo', 'excerpt' => 'A deep dive into dice probabilities and how to make better decisions based on statistical odds.', 'category' => 'Strategies', 'date' => 'Jan 15, 2026', 'read_time' => '7 min read'],
];

$resolveBlogCard = static function (array $post, string $defaultCategory = 'Blog'): array {
    $title = trim((string)($post['title'] ?? ''));
    $excerpt = trim((string)($post['excerpt'] ?? $post['summary'] ?? $post['description'] ?? ''));
    $content = trim(strip_tags((string)($post['content'] ?? '')));
    if ($excerpt === '' && $content !== '') {
        $excerpt = function_exists('mb_substr') ? mb_substr($content, 0, 140) : substr($content, 0, 140);
        $contentLength = function_exists('mb_strlen') ? mb_strlen($content) : strlen($content);
        $excerptLength = function_exists('mb_strlen') ? mb_strlen($excerpt) : strlen($excerpt);
        if ($contentLength > $excerptLength) {
            $excerpt .= '...';
        }
    }

    $category = trim((string)($post['category_name'] ?? $post['category'] ?? ''));
    if ($category === '') {
        $tags = array_values(array_filter(array_map('trim', explode(',', (string)($post['tags'] ?? '')))));
        $category = $tags[0] ?? $defaultCategory;
    }

    $dateLabel = trim((string)($post['date'] ?? ''));
    if ($dateLabel === '') {
        $publishedAt = trim((string)($post['published_at'] ?? ''));
        if ($publishedAt !== '') {
            $timestamp = strtotime($publishedAt);
            $dateLabel = $timestamp ? date('M d, Y', $timestamp) : $publishedAt;
        }
    }

    $readTime = trim((string)($post['read_time'] ?? ''));
    if ($readTime === '') {
        $readingSource = trim($content !== '' ? $content : $excerpt);
        if ($readingSource !== '') {
            $wordCount = count(preg_split('/\s+/u', $readingSource, -1, PREG_SPLIT_NO_EMPTY));
            $charCount = function_exists('mb_strlen') ? mb_strlen($readingSource) : strlen($readingSource);
            $minutes = $wordCount > 0 ? (int)ceil($wordCount / 180) : (int)ceil($charCount / 400);
            $readTime = max(1, $minutes) . ' min read';
        }
    }

    $coverImage = trim((string)($post['cover_image'] ?? ''));
    $url = trim((string)($post['url'] ?? '#'));
    $placeholder = function_exists('mb_substr') ? mb_substr($category, 0, 1) : substr($category, 0, 1);

    return [
        'title' => $title,
        'excerpt' => $excerpt,
        'category' => $category,
        'date' => $dateLabel,
        'read_time' => $readTime,
        'cover_image' => $coverImage,
        'url' => $url !== '' ? $url : '#',
        'placeholder' => strtoupper((string)$placeholder),
    ];
};

$posts = [];
if (is_array($blogPosts) && $blogPosts !== []) {
    foreach ($blogPosts as $post) {
        if (is_array($post)) {
            $posts[] = $resolveBlogCard($post, $badge);
        }
    }
} elseif ($isPreview) {
    foreach ($samplePosts as $post) {
        $posts[] = $resolveBlogCard($post, $badge);
    }
}

$instanceId = 'le-blog-list-' . uniqid();
?>

