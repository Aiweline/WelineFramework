<?php
/**
 * LudoEmpire - App Download Component
 * 
 * 应用下载区域，包含手机样机和功能亮点
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Download Now
 * content.title => 标题:text:Play Ludo Anytime, Anywhere
 * content.description => 描述:textarea:Download our app and enjoy seamless gameplay on your mobile device. Available for Android and iOS!
 * 
 * group:features => 功能特点
 * features.items => 功能列表:textarea:📱 Tiny Size|Only 25MB - won't eat your storage!\r\n🎮 Smooth Gameplay|60fps buttery smooth animations\r\n📴 Offline Mode|Play with bots even without internet|格式：图标 标题|描述，一行一个
 * 
 * group:download => 下载按钮
 * download.android_text => Android按钮文字:text:Download for Android
 * download.android_url => Android链接:text:#
 * download.ios_text => iOS按钮文字:text:Download for iOS
 * download.ios_url => iOS链接:text:#
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['download_bg'] ?? 'linear-gradient(135deg, #1a0a2e 0%, #0d0020 100%)';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'Download Now';
$title = $config['content.title'] ?? 'Play Ludo Anytime, Anywhere';
$description = $config['content.description'] ?? 'Download our app and enjoy seamless gameplay on your mobile device. Available for Android and iOS!';

$featuresRaw = $config['features.items'] ?? "📱 Tiny Size|Only 25MB - won't eat your storage!\n🎮 Smooth Gameplay|60fps buttery smooth animations\n📴 Offline Mode|Play with bots even without internet";
$features = [];
$lines = preg_split('/[\r\n]+/', $featuresRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $features[] = [
        'title' => trim($parts[0] ?? ''),
        'desc' => trim($parts[1] ?? ''),
    ];
}

$androidText = $config['download.android_text'] ?? 'Download for Android';
$androidUrl = $config['download.android_url'] ?? '#';
$iosText = $config['download.ios_text'] ?? 'Download for iOS';
$iosUrl = $config['download.ios_url'] ?? '#';

$instanceId = 'le-download-' . uniqid();
?>

