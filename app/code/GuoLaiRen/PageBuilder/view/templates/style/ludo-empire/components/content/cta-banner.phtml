<?php
/**
 * LudoEmpire - CTA Banner Component
 * 
 * 行动召唤横幅，引导用户开始游戏或下载应用
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.title => 标题:text:Ready to Roll?
 * content.description => 描述:textarea:Download LudoEmpire now and start your journey to becoming the ultimate Ludo champion!
 * 
 * group:buttons => 按钮设置
 * buttons.primary_text => 主按钮文字:text:Play Now
 * buttons.primary_url => 主按钮链接:text:#games
 * buttons.secondary_text => 次按钮文字:text:Download App
 * buttons.secondary_url => 次按钮链接:text:#download
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$ctaBg = $colors['cta_bg'] ?? 'linear-gradient(135deg, #1a0a2e 0%, #200040 50%, #1a0a2e 100%)';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';

$title = $config['content.title'] ?? 'Ready to Roll?';
$description = $config['content.description'] ?? 'Download LudoEmpire now and start your journey to becoming the ultimate Ludo champion!';
$primaryText = $config['buttons.primary_text'] ?? 'Play Now';
$primaryUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($config['buttons.primary_url'] ?? '#games');
$secondaryText = $config['buttons.secondary_text'] ?? 'Download App';
$secondaryUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($config['buttons.secondary_url'] ?? '#download');

$instanceId = 'le-cta-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $ctaBg ?>;
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?>::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -10%;
            width: 50%;
            height: 200%;
            background: radial-gradient(ellipse, rgba(139, 92, 246, 0.12) 0%, transparent 60%);
            pointer-events: none;
        }
        
        #<?= $instanceId ?>::after {
            content: '';
            position: absolute;
            bottom: -50%;
            right: -10%;
            width: 50%;
            height: 200%;
            background: radial-gradient(ellipse, rgba(236, 72, 153, 0.1) 0%, transparent 60%);
            pointer-events: none;
        }
        
        #<?= $instanceId ?> .le-cta-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
            text-align: center;
            position: relative;
            z-index: 1;
        }
        
        #<?= $instanceId ?> .le-cta-emoji {
            font-size: 4rem;
            margin-bottom: 24px;
            animation: leFloat 3s ease-in-out infinite;
        }
        
        @keyframes leFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        #<?= $instanceId ?> .le-cta-title {
            font-size: 3rem;
            font-weight: 900;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
            background: linear-gradient(135deg, <?= $textPrimary ?>, <?= $accentSecondary ?>);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        #<?= $instanceId ?> .le-cta-desc {
            font-size: 1.2rem;
            color: <?= $textSecondary ?>;
            line-height: 1.7;
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        
        #<?= $instanceId ?> .le-cta-buttons {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        #<?= $instanceId ?> .le-cta-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 40px;
            background: <?= $buttonPrimaryBg ?>;
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 14px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 24px rgba(139, 92, 246, 0.4);
            text-decoration: none;
        }
        
        #<?= $instanceId ?> .le-cta-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(139, 92, 246, 0.5);
        }
        
        #<?= $instanceId ?> .le-cta-btn-primary svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }
        
        #<?= $instanceId ?> .le-cta-btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 40px;
            background: transparent;
            color: <?= $accentSecondary ?>;
            font-size: 1.1rem;
            font-weight: 700;
            border: 2px solid rgba(236, 72, 153, 0.5);
            border-radius: 14px;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        
        #<?= $instanceId ?> .le-cta-btn-secondary:hover {
            background: rgba(236, 72, 153, 0.1);
            border-color: <?= $accentSecondary ?>;
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-cta-title {
                font-size: 2rem;
            }
            
            #<?= $instanceId ?> .le-cta-desc {
                font-size: 1rem;
            }
            
            #<?= $instanceId ?> .le-cta-buttons {
                flex-direction: column;
            }
            
            #<?= $instanceId ?> .le-cta-btn-primary,
            #<?= $instanceId ?> .le-cta-btn-secondary {
                justify-content: center;
            }
        }
    </style>
    
    <div class="le-cta-container">
        <div class="le-cta-emoji">🎲</div>
        <h2 class="le-cta-title"><?= htmlspecialchars($title) ?></h2>
        <p class="le-cta-desc"><?= htmlspecialchars($description) ?></p>
        <div class="le-cta-buttons">
            <?php if ($primaryText): ?>
            <a href="<?= htmlspecialchars($primaryUrl) ?>" class="le-cta-btn-primary">
                <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                <?= htmlspecialchars($primaryText) ?>
            </a>
            <?php endif; ?>
            <?php if ($secondaryText): ?>
            <a href="<?= htmlspecialchars($secondaryUrl) ?>" class="le-cta-btn-secondary">
                <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" fill="currentColor"/></svg>
                <?= htmlspecialchars($secondaryText) ?>
            </a>
            <?php endif; ?>
        </div>
    </div>
</section>
