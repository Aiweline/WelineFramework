            #<?= $instanceId ?> .le-about-values-grid {
                grid-template-columns: 1fr;
            }
            
            #<?= $instanceId ?> .le-about-title {
                font-size: 1.75rem;
            }
            
            #<?= $instanceId ?> .le-about-stat-value {
                font-size: 1.75rem;
            }
        }
    </style>
    
    <div class="le-about-hero">
        <div class="le-about-container">
            <div class="le-about-badge"><?= htmlspecialchars($badge) ?></div>
            <h1 class="le-about-title"><?= htmlspecialchars($title) ?></h1>
            <p class="le-about-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
    </div>
    
    <?php if (!empty($stats)): ?>
    <div class="le-about-stats">
        <div class="le-about-container">
            <div class="le-about-stats-grid">
                <?php foreach ($stats as $stat): ?>
                <div class="le-about-stat">
                    <div class="le-about-stat-value"><?= htmlspecialchars($stat['value']) ?></div>
                    <div class="le-about-stat-label"><?= htmlspecialchars($stat['label']) ?></div>
                    <div class="le-about-stat-desc"><?= htmlspecialchars($stat['desc']) ?></div>
                </div>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
    <?php endif; ?>
    
    <div class="le-about-story">
        <div class="le-about-container">
            <div class="le-about-story-content">
                <?= nl2br(htmlspecialchars($story)) ?>
            </div>
        </div>
    </div>
    
    <?php if (!empty($values)): ?>
    <div class="le-about-values">
        <div class="le-about-container">
            <h2 class="le-about-values-title">Our Core Values</h2>
            <div class="le-about-values-grid">
                <?php foreach ($values as $val): ?>
                <div class="le-about-value-card">
                    <h3 class="le-about-value-title"><?= htmlspecialchars($val['title']) ?></h3>
                    <p class="le-about-value-desc"><?= htmlspecialchars($val['desc']) ?></p>
                </div>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
    <?php endif; ?>
</section>
