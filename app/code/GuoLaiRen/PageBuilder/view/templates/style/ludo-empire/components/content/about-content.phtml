        @media (max-width: 992px) {
            #<?= $instanceId ?> .le-about-stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-about-stats-grid {
                grid-template-columns: repeat(2, 1fr);
