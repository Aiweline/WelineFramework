            gap: 24px;
        }
        
        #<?= $instanceId ?> .le-about-stat {
            text-align: center;
            padding: 24px;
        }
        
        #<?= $instanceId ?> .le-about-stat-value {
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, <?= $accentPrimary ?>, <?= $accentSecondary ?>);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }
        
        #<?= $instanceId ?> .le-about-stat-label {
            font-size: 1rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 4px;
        }
        
        #<?= $instanceId ?> .le-about-stat-desc {
            font-size: 0.85rem;
