            color: <?= $textSecondary ?>;
            line-height: 1.8;
        }
        
        #<?= $instanceId ?> .le-about-values {
            background: <?= $sectionBg2 ?>;
            padding: 80px 0;
        }
        
        #<?= $instanceId ?> .le-about-values-title {
            font-size: 2rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            text-align: center;
            margin-bottom: 48px;
        }
        
        #<?= $instanceId ?> .le-about-values-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .le-about-value-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
            padding: 28px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .le-about-value-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(139, 92, 246, 0.15);
        }
        
        #<?= $instanceId ?> .le-about-value-title {
