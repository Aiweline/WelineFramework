<?php
/**
 * LudoEmpire 模板 - Content
 * 
 * 内容区域渲染文件，通过组件系统加载内容组件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:layout => 布局设置
 * layout.max_width => 最大宽度:number:1200|px
 * layout.padding_vertical => 上下内边距:responsive:60/80|px[MD]
 * layout.padding_horizontal => 左右内边距:responsive:20/40|px[MD]
 * 
 * group:style => 样式设置
 * style.background_color => 背景颜色:color:#090012
 * style.text_color => 文字颜色:color:#c4b5fd
 * style.heading_color => 标题颜色:color:#f5f3ff
 * style.link_color => 链接颜色:color:#a78bfa
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'ludo-empire';
if (empty($templateCode)) {
    $templateCode = 'ludo-empire';
}
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('le_content_color')) {
    function le_content_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('le_content_getConfig')) {
    function le_content_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// 布局配置
$maxWidth = le_content_getConfig($styleSettings, 'layout.max_width', '1200');
$bgColor = le_content_getConfig($styleSettings, 'style.background_color', le_content_color($colors, 'body_bg', '#090012'));
$textColor = le_content_getConfig($styleSettings, 'style.text_color', le_content_color($colors, 'text_secondary', '#c4b5fd'));
$headingColor = le_content_getConfig($styleSettings, 'style.heading_color', le_content_color($colors, 'text_primary', '#f5f3ff'));
$linkColor = le_content_getConfig($styleSettings, 'style.link_color', le_content_color($colors, 'accent_primary_light', '#a78bfa'));

// 获取布局配置
$layoutConfig = $this->getData('layout_config') ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
?>

<style>
    .le-content {
        background: <?= htmlspecialchars($bgColor) ?>;
        color: <?= htmlspecialchars($textColor) ?>;
        min-height: 50vh;
        padding-top: 80px;
    }
    
    .le-content-container {
        max-width: <?= intval($maxWidth) ?>px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    .le-content h1, .le-content h2, .le-content h3, .le-content h4 {
        color: <?= htmlspecialchars($headingColor) ?>;
    }
    
    .le-content a {
        color: <?= htmlspecialchars($linkColor) ?>;
        text-decoration: none;
        transition: color 0.3s ease;
    }
    
    .le-content a:hover {
        color: <?= htmlspecialchars($linkColor) ?>;
        opacity: 0.8;
    }
</style>

<main class="le-content">
    <?php
    $componentFiles = [
        'hero-slider' => 'content/hero-slider.phtml',
        'games' => 'content/games.phtml',
        'advantages' => 'content/advantages.phtml',
        'app-download' => 'content/app-download.phtml',
        'testimonials' => 'content/testimonials.phtml',
        'faq' => 'content/faq.phtml',
        'cta-banner' => 'content/cta-banner.phtml',
        'blog-list' => 'content/blog-list.phtml',
        'blog-detail' => 'content/blog-detail.phtml',
        'blog-category' => 'content/blog-category.phtml',
        'legal-content' => 'content/legal-content.phtml',
        'about-content' => 'content/about-content.phtml',
        'contact-content' => 'content/contact-content.phtml',
    ];
    
    if (!empty($contentComponents)) {
        foreach ($contentComponents as $index => $component) {
            $componentCode = $component['code'] ?? $component['component'] ?? '';
            $componentConfig = $component['config'] ?? [];
            
            if (empty($componentCode)) continue;
            
            $componentFile = $componentFiles[$componentCode] ?? null;
            if ($componentFile) {
                $this->assign('component_config', $componentConfig);
                $this->assign('component_instance_id', 'le-component-' . $componentCode . '-' . $index);
                $this->assign('colors', $colors);
                ?>
                <div class="le-component-wrapper" data-component="<?= htmlspecialchars($componentCode) ?>" data-index="<?= $index ?>">
                    <?= $this->fetchTemplate("GuoLaiRen_PageBuilder::templates/style/ludo-empire/components/{$componentFile}") ?>
                </div>
                <?php
            }
        }
    } else {
        if ($page) {
            $pageContent = $page->getData('content') ?? '';
            if ($pageContent) {
                echo '<div class="le-content-container">' . $pageContent . '</div>';
            }
        }
    }
    ?>
</main>
