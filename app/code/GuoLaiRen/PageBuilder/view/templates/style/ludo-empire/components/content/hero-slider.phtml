/**
 * LudoEmpire - Hero Slider Component
 * 
 * 首屏英雄区域，包含标题、描述、CTA按钮、游戏统计和装饰性骰子元素
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 顶部徽章文字:text:🎲 #1 Ludo Game
 * content.title => 主标题:textarea:Roll the Dice, Rule the Board!
 * content.description => 描述文字:textarea:Join millions of players worldwide in the ultimate Ludo experience. Play with friends, win real prizes, and become the king of the board!
 * 
 * group:cta => 按钮设置
 * cta.primary_text => 主按钮文字:text:Play Now
 * cta.primary_url => 主按钮链接:text:#games
 * cta.secondary_text => 次按钮文字:text:Download Free
 * cta.secondary_url => 次按钮链接:text:#download
 * 
 * group:stats => 统计数据
 * stats.items => 统计列表:textarea:10M+|Players Worldwide\r\n1M+|Daily Games\r\n100+|Tournaments|格式：数字|描述，一行一个
 * 
 * group:style => 样式设置
 * style.padding_top => 顶部内边距:number:120|px
 * style.padding_bottom => 底部内边距:number:80|px
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $colors['hero_bg'] ?? 'linear-gradient(135deg, #1a0a2e 0%, #0d0020 50%, #090012 100%)';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$accentPrimary = $colors['accent_primary'] ?? '#8b5cf6';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$accentTertiary = $colors['accent_tertiary'] ?? '#06b6d4';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? '🎲 #1 Ludo Game';
$title = $config['content.title'] ?? 'Roll the Dice, Rule the Board!';
$description = $config['content.description'] ?? 'Join millions of players worldwide in the ultimate Ludo experience. Play with friends, win real prizes, and become the king of the board!';

$primaryBtnText = $config['cta.primary_text'] ?? 'Play Now';
$primaryBtnUrl = $config['cta.primary_url'] ?? '#games';
$secondaryBtnText = $config['cta.secondary_text'] ?? 'Download Free';
$secondaryBtnUrl = $config['cta.secondary_url'] ?? '#download';

$statsRaw = $config['stats.items'] ?? "10M+|Players Worldwide\n1M+|Daily Games\n100+|Tournaments";
$stats = [];
$lines = preg_split('/[\r\n]+/', $statsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $value = trim($parts[0] ?? '');
    $label = trim($parts[1] ?? '');
    if (!empty($value)) {
        $stats[] = ['value' => $value, 'label' => $label];
    }
}

$paddingTop = $config['style.padding_top'] ?? '120';
$paddingBottom = $config['style.padding_bottom'] ?? '80';

$instanceId = 'le-hero-' . uniqid();
?>

