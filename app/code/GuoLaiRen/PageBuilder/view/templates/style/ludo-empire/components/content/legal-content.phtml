            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .le-legal-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 12px;
        }
        
        #<?= $instanceId ?> .le-legal-updated {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
        }
        
        #<?= $instanceId ?> .le-legal-content {
