            border-bottom: 1px solid <?= $borderLight ?>;
        }
        
        #<?= $instanceId ?> .le-legal-content h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin: 32px 0 12px;
        }
        
        #<?= $instanceId ?> .le-legal-content p {
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .le-legal-content ul, #<?= $instanceId ?> .le-legal-content ol {
