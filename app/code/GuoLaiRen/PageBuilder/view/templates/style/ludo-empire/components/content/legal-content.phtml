    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .le-legal-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .le-legal-header {
            margin-bottom: 48px;
        }
        
        #<?= $instanceId ?> .le-legal-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
