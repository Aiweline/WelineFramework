// 链接配置
$column1Title = le_footer_getConfig($styleSettings, 'links.column1_title', 'Games');
$column1Raw = le_footer_getConfig($styleSettings, 'links.column1_items', "Classic Ludo=>/games/classic\nQuick Ludo=>/games/quick\nTournaments=>/games/tournaments\nTeam Battle=>/games/team");
$column2Title = le_footer_getConfig($styleSettings, 'links.column2_title', 'Company');
