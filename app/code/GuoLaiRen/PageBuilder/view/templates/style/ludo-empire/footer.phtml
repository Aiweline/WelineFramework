$column3Raw = le_footer_getConfig($styleSettings, 'links.column3_items', "Help Center=>/help\nContact Us=>/contact\nFAQ=>/faq\nCommunity=>/community");

$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$column1Links = $parseLinks($column1Raw);
$column2Links = $parseLinks($column2Raw);
$column3Links = $parseLinks($column3Raw);

$copyrightText = le_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved. Play responsibly.');

$bgColor = le_footer_getConfig($styleSettings, 'style.background_color', le_footer_color($colors, 'footer_bg', '#06000e'));
$textColor = le_footer_getConfig($styleSettings, 'style.text_color', le_footer_color($colors, 'footer_text', '#7c6fad'));
$linkColor = le_footer_getConfig($styleSettings, 'style.link_color', le_footer_color($colors, 'footer_link', '#c4b5fd'));
$linkHoverColor = le_footer_getConfig($styleSettings, 'style.link_hover_color', le_footer_color($colors, 'footer_link_hover', '#ec4899'));

