if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('le_footer_color')) {
    function le_footer_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('le_footer_getConfig')) {
    function le_footer_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// 品牌配置
$brandName = le_footer_getConfig($styleSettings, 'brand.name', 'LudoEmpire');
