/**
 * RummyRoyal - Contact Content Component
 * 
 * 联系页面：表单 + 联系信息（邮箱、电话、地址）+ 社交链接
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Contact Us
 * content.title => 标题:text:Get in Touch
 * content.description => 描述:textarea:Have questions or need assistance? Our support team is here to help you 24/7.
 * 
 * group:contact => 联系信息
 * contact.email => 邮箱:text:support@rummyroyal.com
 * contact.phone => 电话:text:+91 1800-XXX-XXXX
 * contact.address => 地址:text:RummyRoyal HQ, Bangalore, India
 * contact.hours => 工作时间:text:24/7 Customer Support
 * 
 * group:social => 社交链接
 * social.items => 社交链接:textarea:Facebook|https://facebook.com\r\nTwitter|https://twitter.com\r\nInstagram|https://instagram.com\r\nYouTube|https://youtube.com|格式：名称|链接，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0718';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#1a0a2e';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';
$inputBg = $colors['input_bg'] ?? 'rgba(255, 255, 255, 0.05)';
$inputBorder = $colors['input_border'] ?? 'rgba(234, 179, 8, 0.15)';
$inputBorderFocus = $colors['input_border_focus'] ?? '#eab308';
$inputText = $colors['input_text'] ?? '#fef3c7';
$inputPlaceholder = $colors['input_placeholder'] ?? '#8b6f47';

$badge = $config['content.badge'] ?? 'Contact Us';
$title = $config['content.title'] ?? 'Get in Touch';
$description = $config['content.description'] ?? 'Have questions or need assistance? Our support team is here to help you 24/7.';

$email = $config['contact.email'] ?? 'support@rummyroyal.com';
$phone = $config['contact.phone'] ?? '+91 1800-XXX-XXXX';
$address = $config['contact.address'] ?? 'RummyRoyal HQ, Bangalore, India';
$hours = $config['contact.hours'] ?? '24/7 Customer Support';

$socialRaw = $config['social.items'] ?? "Facebook|https://facebook.com\nTwitter|https://twitter.com\nInstagram|https://instagram.com\nYouTube|https://youtube.com";
$socials = [];
$lines = preg_split('/[\r\n]+/', $socialRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $sName = trim($parts[0] ?? '');
    $sUrl = trim($parts[1] ?? '#');
    if (!empty($sName)) $socials[] = ['name' => $sName, 'url' => $sUrl];
}

$instanceId = 'rr-contact-' . uniqid();
