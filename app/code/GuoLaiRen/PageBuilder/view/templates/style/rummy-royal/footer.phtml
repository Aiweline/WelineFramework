<?php
/**
 * RummyRoyal 模板 - Footer
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:RummyRoyal
 * brand.description => 品牌描述:textarea:India's most trusted online rummy platform.
 * 
 * group:links => 链接设置
 * links.column1_title => 栏目1标题:text:Games
 * links.column1_items => 栏目1链接:textarea:Points Rummy=>/games\r\nPool Rummy=>/games\r\nDeals Rummy=>/games\r\nTournaments=>/games|格式：名称=>链接，一行一个
 * links.column2_title => 栏目2标题:text:Company
 * links.column2_items => 栏目2链接:textarea:About Us=>/about\r\nCareers=>/careers\r\nBlog=>/blog\r\nPress=>/press|格式：名称=>链接，一行一个
 * links.column3_title => 栏目3标题:text:Support
 * links.column3_items => 栏目3链接:textarea:Help Center=>/help\r\nContact Us=>/contact\r\nPrivacy Policy=>/privacy-policy\r\nTerms=>/terms-of-service|格式：名称=>链接，一行一个
 * 
 * group:contact => 联系信息
 * contact.email => 邮箱:text:support@rummyroyal.com
 * 
 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved.
 * copyright.disclaimer => 免责声明:textarea:Play responsibly. Must be 18+ to play. Rummy is a game of skill.
 * 
 * group:style => 样式设置
 * style.background_color => 背景颜色:color:#060310
 * style.text_color => 文字颜色:color:#8b6f47
 * style.link_color => 链接颜色:color:#d4a574
 * style.link_hover_color => 链接悬停颜色:color:#eab308
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

$templateCode = $page ? $page->getData('style') : 'rummy-royal';
if (empty($templateCode)) {
    $templateCode = 'rummy-royal';
}
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('rr_footer_color')) {
    function rr_footer_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('rr_footer_getConfig')) {
    function rr_footer_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

$brandName = rr_footer_getConfig($styleSettings, 'brand.name', 'RummyRoyal');
$brandDesc = rr_footer_getConfig($styleSettings, 'brand.description', 'India\'s most trusted online rummy platform.');

$col1Title = rr_footer_getConfig($styleSettings, 'links.column1_title', 'Games');
$col1Raw = rr_footer_getConfig($styleSettings, 'links.column1_items', "Points Rummy=>/games\nPool Rummy=>/games\nDeals Rummy=>/games\nTournaments=>/games");
$col2Title = rr_footer_getConfig($styleSettings, 'links.column2_title', 'Company');
$col2Raw = rr_footer_getConfig($styleSettings, 'links.column2_items', "About Us=>/about\nCareers=>/careers\nBlog=>/blog\nPress=>/press");
$col3Title = rr_footer_getConfig($styleSettings, 'links.column3_title', 'Support');
$col3Raw = rr_footer_getConfig($styleSettings, 'links.column3_items', "Help Center=>/help\nContact Us=>/contact\nPrivacy Policy=>/privacy-policy\nTerms=>/terms-of-service");

$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$col1Links = $parseLinks($col1Raw);
$col2Links = $parseLinks($col2Raw);
$col3Links = $parseLinks($col3Raw);

$contactEmail = rr_footer_getConfig($styleSettings, 'contact.email', 'support@rummyroyal.com');
$copyrightText = rr_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved.');
$disclaimer = rr_footer_getConfig($styleSettings, 'copyright.disclaimer', 'Play responsibly. Must be 18+ to play. Rummy is a game of skill.');

$bgColor = rr_footer_getConfig($styleSettings, 'style.background_color', rr_footer_color($colors, 'footer_bg', '#060310'));
$textColor = rr_footer_getConfig($styleSettings, 'style.text_color', rr_footer_color($colors, 'footer_text', '#8b6f47'));
$linkColor = rr_footer_getConfig($styleSettings, 'style.link_color', rr_footer_color($colors, 'footer_link', '#d4a574'));
$linkHoverColor = rr_footer_getConfig($styleSettings, 'style.link_hover_color', rr_footer_color($colors, 'footer_link_hover', '#eab308'));

$textPrimary = rr_footer_color($colors, 'text_primary', '#fef3c7');
$accentPrimary = rr_footer_color($colors, 'accent_primary', '#eab308');
$buttonPrimaryBg = rr_footer_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)');
$footerBorder = rr_footer_color($colors, 'footer_border', 'rgba(234, 179, 8, 0.08)');

$currentYear = date('Y');
?>

<?php
// Footer 渲染由 components/footer/links.phtml 处理
$this->assign('component_config', $styleSettings);
echo $this->fetchTemplate('GuoLaiRen_PageBuilder::templates/style/rummy-royal/components/footer/links.phtml');
?>
