$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['faq_bg'] ?? '#0a0514';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'FAQ';
$title = $config['content.title'] ?? 'Frequently Asked Questions';
$description = $config['content.description'] ?? 'Everything you need to know about playing rummy on RummyRoyal.';

$faqRaw = $config['faq.items'] ?? "Is online rummy legal in India?|Yes, the Supreme Court of India has declared rummy as a game of skill. It is legal to play online rummy for cash in most Indian states.\nHow do I withdraw my winnings?|You can withdraw your winnings instantly via UPI, bank transfer, or Paytm. Minimum withdrawal is ₹100 and processing is within minutes.\nIs it safe to play on RummyRoyal?|Absolutely. We use RNG-certified card shuffling, SSL encryption for data protection, and are licensed by recognized gaming authorities.\nWhat are the entry fees for games?|Entry fees vary by format. Practice tables are free. Cash games start from as low as ₹1 entry fee. Tournament entry ranges from ₹10 to ₹10,000.\nHow does the welcome bonus work?|New players get up to ₹5,000 welcome bonus on their first deposit. The bonus is released in installments as you play cash games.\nCan I play on my mobile phone?|Yes! Our app is available on Android and iOS. You can also play directly in your mobile browser without downloading.";

$faqs = [];
$lines = preg_split('/[\r\n]+/', $faqRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $question = trim($parts[0] ?? '');
    $answer = trim($parts[1] ?? '');
    if (!empty($question)) {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

$instanceId = 'rr-faq-' . uniqid();
?>

