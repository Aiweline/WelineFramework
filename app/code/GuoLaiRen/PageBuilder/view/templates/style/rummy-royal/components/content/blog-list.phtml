<?php
/**
 * RummyRoyal - Blog List Component
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $colors
 * @var array $component_config
 *
 * @fields_start
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Blog
 * content.title => 标题:text:Rummy Tips & News
 * content.description => 描述:textarea:Stay updated with the latest rummy strategies, tips, and platform news.
 * group:posts => 文章示例
 * posts.items => 文章列表:textarea:Mastering Points Rummy: A Beginner's Guide|Learn the fundamentals of Points Rummy and strategies to win consistently.|Strategy|5 min read\r\nTop 10 Rummy Tips from Pro Players|Expert tips that will elevate your rummy game to the next level.|Tips|7 min read\r\nUnderstanding Pool Rummy Variants|Deep dive into 101 Pool and 201 Pool rummy formats.|Guide|6 min read|格式：标题|描述|分类|阅读时长，一行一个
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0718';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'Blog';
$title = $config['content.title'] ?? 'Rummy Tips & News';
$description = $config['content.description'] ?? 'Stay updated with the latest rummy strategies, tips, and platform news.';
$isPreview = (bool)($this->getData('is_preview') ?? false);
$page = $this->getData('page');

$blogPosts = $this->getData('blog_posts');
if ((!is_array($blogPosts) || $blogPosts === []) && $page && method_exists($page, 'getData')) {
    $blogPosts = $page->getData('blog_posts') ?? [];
}

$normalizePost = static function (array $post, string $defaultCategory = 'Blog'): array {
    $title = trim((string)($post['title'] ?? ''));
    $description = trim((string)($post['description'] ?? $post['excerpt'] ?? $post['summary'] ?? ''));
    $content = trim(strip_tags((string)($post['content'] ?? '')));
    if ($description === '' && $content !== '') {
        $description = function_exists('mb_substr') ? mb_substr($content, 0, 140) : substr($content, 0, 140);
        $contentLength = function_exists('mb_strlen') ? mb_strlen($content) : strlen($content);
        $descriptionLength = function_exists('mb_strlen') ? mb_strlen($description) : strlen($description);
        if ($contentLength > $descriptionLength) {
            $description .= '...';
        }
    }

    $category = trim((string)($post['category_name'] ?? $post['category'] ?? ''));
    if ($category === '') {
        $tags = array_values(array_filter(array_map('trim', explode(',', (string)($post['tags'] ?? '')))));
        $category = $tags[0] ?? $defaultCategory;
    }

    $readTime = trim((string)($post['read_time'] ?? ''));
    if ($readTime === '') {
        $readingSource = trim($content !== '' ? $content : $description);
        if ($readingSource !== '') {
            $wordCount = count(preg_split('/\s+/u', $readingSource, -1, PREG_SPLIT_NO_EMPTY));
            $charCount = function_exists('mb_strlen') ? mb_strlen($readingSource) : strlen($readingSource);
            $minutes = $wordCount > 0 ? (int)ceil($wordCount / 180) : (int)ceil($charCount / 400);
            $readTime = max(1, $minutes) . ' min read';
        }
    }

    $url = trim((string)($post['url'] ?? '#'));
    $coverImage = trim((string)($post['cover_image'] ?? ''));

    return [
        'title' => $title,
        'description' => $description,
        'category' => $category,
        'read_time' => $readTime,
        'url' => $url !== '' ? $url : '#',
        'cover_image' => $coverImage,
    ];
};

$posts = [];
if (is_array($blogPosts) && $blogPosts !== []) {
    foreach ($blogPosts as $post) {
        if (is_array($post)) {
            $posts[] = $normalizePost($post, $badge);
        }
    }
} elseif ($isPreview) {
    $postsRaw = $config['posts.items'] ?? "Mastering Points Rummy: A Beginner's Guide|Learn the fundamentals of Points Rummy and strategies to win consistently.|Strategy|5 min read\nTop 10 Rummy Tips from Pro Players|Expert tips that will elevate your rummy game to the next level.|Tips|7 min read\nUnderstanding Pool Rummy Variants|Deep dive into 101 Pool and 201 Pool rummy formats.|Guide|6 min read\nRummyRoyal Tournament Schedule 2026|Complete schedule of upcoming tournaments with massive prize pools.|News|3 min read\nHow to Read Your Opponent's Hand|Advanced strategies for predicting opponent moves in rummy.|Strategy|8 min read\nRummy vs Poker: Key Differences|Understanding what makes rummy a unique skill-based card game.|Education|4 min read";
    foreach (preg_split('/[\r\n]+/', $postsRaw) as $line) {
        $line = trim($line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line);
        $posts[] = $normalizePost([
            'title' => trim($parts[0] ?? ''),
            'description' => trim($parts[1] ?? ''),
            'category' => trim($parts[2] ?? 'General'),
            'read_time' => trim($parts[3] ?? '5 min read'),
        ], $badge);
    }
}

$instanceId = 'rr-blog-list-' . uniqid();
?>

