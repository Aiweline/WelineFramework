<?php
/**
 * RummyRoyal - Footer Links Component
 * 
 * 页脚区域：品牌信息 + Games/Company/Support/Legal 四栏链接
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:RummyRoyal
 * brand.description => 品牌描述:textarea:India's most trusted online rummy platform. Play skill-based card games, win real cash prizes, and enjoy a premium gaming experience.
 * brand.show_logo => 显示Logo:select:yes|yes,no
 * 
 * group:links => 链接设置
 * links.use_custom_links => 使用自定义链接组:select:no|no,yes
 * links.col1_title => 栏目1标题:text:Games
 * links.col1_items => 栏目1链接:textarea:Points Rummy=>/games\r\nPool Rummy=>/games\r\nDeals Rummy=>/games\r\nTournaments=>/games|格式：名称=>链接（仅当开启自定义链接时生效）
 * links.col2_title => 栏目2标题:text:Company
 * links.col2_items => 栏目2链接:textarea:About Us=>/about\r\nBlog=>/blog\r\nCareers=>/careers|格式：名称=>链接
 * links.col3_title => 栏目3标题:text:Support
 * links.col3_items => 栏目3链接:textarea:Help Center=>/help\r\nContact Us=>/contact\r\nFAQ=>/faq|格式：名称=>链接
 * links.col4_title => 栏目4标题:text:Legal
 * links.col4_items => 栏目4链接:textarea:Privacy Policy=>/privacy-policy\r\nTerms of Service=>/terms-of-service\r\nRefund Policy=>/refund-policy|格式：名称=>链接
 * 
 * group:copyright => 版权设置
 * copyright.text => 底部标语:text:Play responsibly. Must be 18+ to play. Rummy is a game of skill.
 * copyright.show_year => 显示年份:select:yes|yes,no
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$footerBg = $colors['footer_bg'] ?? '#060310';
$footerText = $colors['footer_text'] ?? '#8b6f47';
$footerLink = $colors['footer_link'] ?? '#d4a574';
$footerLinkHover = $colors['footer_link_hover'] ?? '#eab308';
$footerBorder = $colors['footer_border'] ?? 'rgba(234, 179, 8, 0.08)';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#1a0a2e';

$brandName = $config['brand.name'] ?? 'RummyRoyal';
$brandDesc = $config['brand.description'] ?? 'India\'s most trusted online rummy platform. Play skill-based card games, win real cash prizes, and enjoy a premium gaming experience.';
$showLogo = ($config['brand.show_logo'] ?? 'yes') !== 'no';

$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

// 按页面类型分组的底栏列：列索引 => 该列包含的页面类型
$footerColTypes = [
    1 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME, \GuoLaiRen\PageBuilder\Model\Page::TYPE_ABOUT, \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG_LIST],
    2 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_CONTACT],
    3 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_TERMS_OF_SERVICE],
    4 => [\GuoLaiRen\PageBuilder\Model\Page::TYPE_PRIVACY_POLICY],
];
$footerColDefaultTitles = [1 => 'Main', 2 => 'Support', 3 => 'Terms', 4 => 'Legal'];

$useCustomLinks = ($config['links.use_custom_links'] ?? 'no') === 'yes';
$page = $this->getData('page');
$col1Links = [];
$col2Links = [];
$col3Links = [];
$col4Links = [];
$col1Title = $config['links.col1_title'] ?? 'Main';
$col2Title = $config['links.col2_title'] ?? 'Support';
$col3Title = $config['links.col3_title'] ?? 'Terms';
$col4Title = $config['links.col4_title'] ?? 'Legal';

if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $navPages = $page->getHeaderNavigationPages(20);
    $byCol = [1 => [], 2 => [], 3 => [], 4 => []];
    foreach ($navPages as $item) {
        $type = $item['type'] ?? '';
        foreach ($footerColTypes as $colIndex => $types) {
            if (in_array($type, $types, true)) {
                $labelKey = 'links.footer_label_' . $type;
                $label = isset($config[$labelKey]) && (string)$config[$labelKey] !== '' ? (string)$config[$labelKey] : ($item['title'] ?? '');
                $url = $item['url'] ?? '/';
                if (isset($item['type']) && $item['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
                    $label = __('Home');
                    $url = '/';
                }
                $byCol[$colIndex][] = ['name' => $label, 'url' => $url];
                break;
            }
        }
    }
    if (!empty($navPages)) {
        $col1Links = $byCol[1];
        $col2Links = $byCol[2];
        $col3Links = $byCol[3];
        $col4Links = $byCol[4];
        $col1Title = isset($config['links.col1_title']) && (string)$config['links.col1_title'] !== '' ? (string)$config['links.col1_title'] : $footerColDefaultTitles[1];
        $col2Title = isset($config['links.col2_title']) && (string)$config['links.col2_title'] !== '' ? (string)$config['links.col2_title'] : $footerColDefaultTitles[2];
        $col3Title = isset($config['links.col3_title']) && (string)$config['links.col3_title'] !== '' ? (string)$config['links.col3_title'] : $footerColDefaultTitles[3];
        $col4Title = isset($config['links.col4_title']) && (string)$config['links.col4_title'] !== '' ? (string)$config['links.col4_title'] : $footerColDefaultTitles[4];
    }
}
if ($useCustomLinks || (empty($col1Links) && empty($col2Links) && empty($col3Links) && empty($col4Links))) {
    $col1Title = $config['links.col1_title'] ?? 'Games';
    $col1Links = $parseLinks($config['links.col1_items'] ?? "Points Rummy=>/games\nPool Rummy=>/games\nDeals Rummy=>/games\nTournaments=>/games");
    $col2Title = $config['links.col2_title'] ?? 'Company';
    $col2Links = $parseLinks($config['links.col2_items'] ?? "About Us=>/about\nBlog=>/blog\nCareers=>/careers");
    $col3Title = $config['links.col3_title'] ?? 'Support';
    $col3Links = $parseLinks($config['links.col3_items'] ?? "Help Center=>/help\nContact Us=>/contact\nFAQ=>/faq");
    $col4Title = $config['links.col4_title'] ?? 'Legal';
    $col4Links = $parseLinks($config['links.col4_items'] ?? "Privacy Policy=>/privacy-policy\nTerms of Service=>/terms-of-service\nRefund Policy=>/refund-policy");
}
$footerColCount = (empty($col1Links) ? 0 : 1) + (empty($col2Links) ? 0 : 1) + (empty($col3Links) ? 0 : 1) + (empty($col4Links) ? 0 : 1);

$copyrightText = $config['copyright.text'] ?? 'Play responsibly. Must be 18+ to play. Rummy is a game of skill.';
$showYear = ($config['copyright.show_year'] ?? 'yes') !== 'no';
$currentYear = date('Y');

$instanceId = 'rr-footer-' . uniqid();
?>

<footer id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $footerBg ?>;
            padding: 80px 0 0;
            border-top: 1px solid <?= $footerBorder ?>;
        }
        
        #<?= $instanceId ?> .rr-ft-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .rr-ft-grid {
            display: grid;
            grid-template-columns: 2fr<?= $footerColCount > 0 ? ' repeat(' . (int)$footerColCount . ', 1fr)' : '' ?>;
            gap: 40px;
            padding-bottom: 60px;
            border-bottom: 1px solid <?= $footerBorder ?>;
        }
        
        #<?= $instanceId ?> .rr-ft-brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.25rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-ft-logo-icon {
            width: 40px;
            height: 40px;
            background: <?= $buttonPrimaryBg ?>;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #<?= $instanceId ?> .rr-ft-logo-icon svg {
            width: 20px;
            height: 20px;
            fill: <?= $buttonPrimaryText ?>;
        }
        
        #<?= $instanceId ?> .rr-ft-brand-desc {
            font-size: 0.88rem;
            color: <?= $footerText ?>;
            line-height: 1.7;
            max-width: 280px;
        }
        
        #<?= $instanceId ?> .rr-ft-col h4 {
            font-size: 0.95rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        #<?= $instanceId ?> .rr-ft-links {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        #<?= $instanceId ?> .rr-ft-link {
            font-size: 0.88rem;
            color: <?= $footerLink ?>;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        #<?= $instanceId ?> .rr-ft-link:hover {
            color: <?= $footerLinkHover ?>;
        }
        
        #<?= $instanceId ?> .rr-ft-bottom {
            padding: 24px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }
        
        #<?= $instanceId ?> .rr-ft-copyright {
            font-size: 0.82rem;
            color: <?= $footerText ?>;
        }
        
        #<?= $instanceId ?> .rr-ft-disclaimer {
            font-size: 0.8rem;
            color: <?= $footerText ?>;
            opacity: 0.7;
            max-width: 400px;
            text-align: right;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .rr-ft-grid {
                grid-template-columns: 1fr 1fr;
            }
            
            #<?= $instanceId ?> .rr-ft-brand {
                grid-column: 1 / -1;
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .rr-ft-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }
            
            #<?= $instanceId ?> .rr-ft-bottom {
                flex-direction: column;
                text-align: center;
            }
            
            #<?= $instanceId ?> .rr-ft-disclaimer {
                text-align: center;
                max-width: none;
            }
        }
    </style>
    
    <div class="rr-ft-container">
        <div class="rr-ft-grid">
            <!-- Brand -->
            <div class="rr-ft-brand">
                <?php if ($showLogo): ?>
                <div class="rr-ft-brand-logo">
                    <span class="rr-ft-logo-icon">
                        <svg viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .6-.4 1-1 1H6c-.6 0-1-.4-1-1v-1h14v1z"/></svg>
                    </span>
                    <span><?= htmlspecialchars($brandName) ?></span>
                </div>
                <?php endif; ?>
                <p class="rr-ft-brand-desc"><?= htmlspecialchars($brandDesc) ?></p>
            </div>
            
            <?php
            $footerCols = [
                ['title' => $col1Title, 'links' => $col1Links],
                ['title' => $col2Title, 'links' => $col2Links],
                ['title' => $col3Title, 'links' => $col3Links],
                ['title' => $col4Title, 'links' => $col4Links],
            ];
            foreach ($footerCols as $col):
                if (empty($col['links'])) continue;
            ?>
            <div class="rr-ft-col">
                <h4><?= htmlspecialchars($col['title']) ?></h4>
                <div class="rr-ft-links">
                    <?php foreach ($col['links'] as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="rr-ft-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
        
        <div class="rr-ft-bottom">
            <div class="rr-ft-copyright">
                <?php if ($showYear): ?>&copy; <?= $currentYear ?> <?= htmlspecialchars($brandName) ?>. All rights reserved.<?php endif; ?>
            </div>
            <div class="rr-ft-disclaimer"><?= htmlspecialchars($copyrightText) ?></div>
        </div>
    </div>
</footer>
