$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $colors['hero_bg'] ?? 'linear-gradient(135deg, #1a0a2e 0%, #120520 50%, #0a0514 100%)';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$accentSecondary = $colors['accent_secondary'] ?? '#dc2626';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#1a0a2e';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? '🏆 #1 Rated';
$title = $config['content.title'] ?? "India's Most Trusted Rummy Platform";
$description = $config['content.description'] ?? 'Join millions of players on India\'s premier rummy platform. Play skill-based card games, compete in tournaments, and win real cash prizes with instant withdrawals.';

$primaryBtnText = $config['cta.primary_text'] ?? 'Play Rummy Now';
$primaryBtnUrl = $config['cta.primary_url'] ?? '#games';
$secondaryBtnText = $config['cta.secondary_text'] ?? 'Download App';
$secondaryBtnUrl = $config['cta.secondary_url'] ?? '#download';

$statsRaw = $config['stats.items'] ?? "5M+|Active Players\n₹500Cr+|Winnings Paid\n24/7|Live Support";
$stats = [];
$lines = preg_split('/[\r\n]+/', $statsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $value = trim($parts[0] ?? '');
    $label = trim($parts[1] ?? '');
    if (!empty($value)) {
        $stats[] = ['value' => $value, 'label' => $label];
    }
}

$instanceId = 'rr-hero-' . uniqid();
?>

