            margin-right: auto;
        }
        
        #<?= $instanceId ?> .rr-about-story h2 {
            font-size: 2rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 24px;
            text-align: center;
        }
        
        #<?= $instanceId ?> .rr-about-story p {
            font-size: 1.05rem;
            color: <?= $textSecondary ?>;
            line-height: 1.8;
            text-align: center;
        }
        
        /* Values */
        #<?= $instanceId ?> .rr-about-values-title {
            font-size: 2rem;
            font-weight: 700;
