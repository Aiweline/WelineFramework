            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
        }
        
        #<?= $instanceId ?> .rr-about-cta h2 {
            font-size: 2rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-about-cta p {
            font-size: 1rem;
            color: <?= $textSecondary ?>;
            margin-bottom: 32px;
        }
        
        #<?= $instanceId ?> .rr-about-cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 32px;
            background: <?= $buttonPrimaryBg ?>;
            color: <?= $buttonPrimaryText ?>;
            font-size: 1rem;
