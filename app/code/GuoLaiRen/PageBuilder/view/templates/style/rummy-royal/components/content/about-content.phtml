            text-align: center;
            margin-bottom: 48px;
        }
        
        #<?= $instanceId ?> .rr-about-values {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 80px;
        }
        
        #<?= $instanceId ?> .rr-about-value {
            text-align: center;
            padding: 32px 20px;
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
