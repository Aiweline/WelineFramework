            }
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .rr-about-title {
                font-size: 2.25rem;
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .rr-about-stats,
            #<?= $instanceId ?> .rr-about-values {
                grid-template-columns: 1fr;
            }
        }
    </style>
    
    <div class="rr-about-container">
        <div class="rr-about-hero">
            <div class="rr-about-badge"><?= htmlspecialchars($badge) ?></div>
            <h1 class="rr-about-title"><?= htmlspecialchars($title) ?></h1>
            <p class="rr-about-desc"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <?php if (!empty($stats)): ?>
        <div class="rr-about-stats">
            <?php foreach ($stats as $stat): ?>
            <div class="rr-about-stat">
                <div class="rr-about-stat-value"><?= htmlspecialchars($stat['value']) ?></div>
                <div class="rr-about-stat-label"><?= htmlspecialchars($stat['label']) ?></div>
            </div>
            <?php endforeach; ?>
        </div>
        <?php endif; ?>
        
        <div class="rr-about-story">
            <h2><?= htmlspecialchars($storyTitle) ?></h2>
            <p><?= nl2br(htmlspecialchars($storyContent)) ?></p>
        </div>
        
        <?php if (!empty($values)): ?>
        <h2 class="rr-about-values-title">Our Core Values</h2>
        <div class="rr-about-values">
            <?php foreach ($values as $val): ?>
            <div class="rr-about-value">
                <div class="rr-about-value-icon"><?= $val['icon'] ?></div>
                <h3><?= htmlspecialchars($val['title']) ?></h3>
                <p><?= htmlspecialchars($val['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
        <?php endif; ?>
        
        <div class="rr-about-cta">
            <h2>Join the RummyRoyal Family</h2>
            <p>Start your rummy journey today and experience the thrill of skill-based gaming.</p>
            <a href="#" class="rr-about-cta-btn">Start Playing Now</a>
        </div>
    </div>
