<?php
/**
 * RummyRoyal - About Content Component
 * 
 * 关于页面：英雄横幅、统计数据、故事、价值观、团队和CTA
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:About Us
 * content.title => 标题:text:About RummyRoyal
 * content.description => 描述:textarea:Building India's most trusted and innovative online rummy platform since 2015.
 * 
 * group:stats => 统计数据
 * stats.items => 统计列表:textarea:10+|Years of Excellence\r\n5M+|Active Players\r\n100+|Team Members\r\n30+|Countries Served|格式：数值|标签，一行一个
 * 
 * group:story => 品牌故事
 * story.title => 故事标题:text:Our Story
 * story.content => 故事内容:textarea:RummyRoyal was founded with a simple vision: to bring the joy of rummy to every Indian household through a safe, fair, and innovative digital platform. What started as a small team of passionate card game enthusiasts has grown into India's leading online rummy destination, serving millions of players across the country.
 * 
 * group:values => 核心价值
 * values.items => 价值列表:textarea:Fair Play|Every game on RummyRoyal uses RNG-certified shuffling, ensuring complete fairness.|⚖️\r\nInnovation|We constantly push boundaries with new features, formats, and technology.|💡\r\nTrust|Your data security and financial safety are our top priorities.|🛡️\r\nCommunity|We foster a vibrant, inclusive community of card game enthusiasts.|🤝|格式：标题|描述|图标，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0718';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#1a0a2e';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'About Us';
$title = $config['content.title'] ?? 'About RummyRoyal';
$description = $config['content.description'] ?? 'Building India\'s most trusted and innovative online rummy platform since 2015.';

$statsRaw = $config['stats.items'] ?? "10+|Years of Excellence\n5M+|Active Players\n100+|Team Members\n30+|Countries Served";
$stats = [];
$lines = preg_split('/[\r\n]+/', $statsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $value = trim($parts[0] ?? '');
    $label = trim($parts[1] ?? '');
    if (!empty($value)) $stats[] = ['value' => $value, 'label' => $label];
}

$storyTitle = $config['story.title'] ?? 'Our Story';
$storyContent = $config['story.content'] ?? 'RummyRoyal was founded with a simple vision: to bring the joy of rummy to every Indian household through a safe, fair, and innovative digital platform.';

$valuesRaw = $config['values.items'] ?? "Fair Play|Every game on RummyRoyal uses RNG-certified shuffling, ensuring complete fairness.|⚖️\nInnovation|We constantly push boundaries with new features, formats, and technology.|💡\nTrust|Your data security and financial safety are our top priorities.|🛡️\nCommunity|We foster a vibrant, inclusive community of card game enthusiasts.|🤝";
$values = [];
$lines = preg_split('/[\r\n]+/', $valuesRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $vTitle = trim($parts[0] ?? '');
    $vDesc = trim($parts[1] ?? '');
    $vIcon = trim($parts[2] ?? '⭐');
    if (!empty($vTitle)) $values[] = ['title' => $vTitle, 'description' => $vDesc, 'icon' => $vIcon];
}

$instanceId = 'rr-about-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .rr-about-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .rr-about-hero {
            text-align: center;
            margin-bottom: 80px;
        }
        
        #<?= $instanceId ?> .rr-about-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(234, 179, 8, 0.12);
            border: 1px solid rgba(234, 179, 8, 0.25);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .rr-about-title {
            font-size: 3rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-about-desc {
            font-size: 1.2rem;
            color: <?= $textSecondary ?>;
            max-width: 650px;
            margin: 0 auto;
        }
        
        /* Stats */
        #<?= $instanceId ?> .rr-about-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 80px;
        }
        
        #<?= $instanceId ?> .rr-about-stat {
            text-align: center;
            padding: 32px 20px;
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
        }
        
        #<?= $instanceId ?> .rr-about-stat-value {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #eab308, #facc15);
