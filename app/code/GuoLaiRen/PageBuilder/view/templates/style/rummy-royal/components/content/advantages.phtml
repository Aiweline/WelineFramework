<?php
/**
 * RummyRoyal - Advantages Section Component
 * 
 * 平台核心优势展示区域，6卡片网格布局
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Why Choose Us
 * content.title => 标题:text:The RummyRoyal Advantage
 * content.description => 描述:textarea:We provide a safe, fair, and rewarding rummy experience with industry-leading features.
 * 
 * group:advantages => 优势列表
 * advantages.items => 优势列表:textarea:Instant Withdrawals|Withdraw your winnings instantly to your bank account or UPI. No waiting, no hassle.|💸\r\nCertified Fair Play|RNG-certified gameplay ensures every card deal is completely random and fair.|✅\r\n24/7 Live Support|Our dedicated support team is available round the clock via chat, email, and phone.|🎧\r\nMulti-Table Play|Play at multiple tables simultaneously and maximize your winning opportunities.|🎮\r\nSecure Payments|Bank-grade encryption protects all transactions. Multiple payment options available.|🔒\r\nExciting Bonuses|Welcome bonus, referral rewards, daily cashback, and seasonal tournaments.|🎁|格式：标题|描述|图标，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['advantages_bg'] ?? '#0d0718';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'Why Choose Us';
$title = $config['content.title'] ?? 'The RummyRoyal Advantage';
$description = $config['content.description'] ?? 'We provide a safe, fair, and rewarding rummy experience with industry-leading features.';

$advantagesRaw = $config['advantages.items'] ?? "Instant Withdrawals|Withdraw your winnings instantly to your bank account or UPI. No waiting, no hassle.|💸\nCertified Fair Play|RNG-certified gameplay ensures every card deal is completely random and fair.|✅\n24/7 Live Support|Our dedicated support team is available round the clock via chat, email, and phone.|🎧\nMulti-Table Play|Play at multiple tables simultaneously and maximize your winning opportunities.|🎮\nSecure Payments|Bank-grade encryption protects all transactions. Multiple payment options available.|🔒\nExciting Bonuses|Welcome bonus, referral rewards, daily cashback, and seasonal tournaments.|🎁";

$advantages = [];
$lines = preg_split('/[\r\n]+/', $advantagesRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $aTitle = trim($parts[0] ?? '');
    $aDesc = trim($parts[1] ?? '');
    $aIcon = trim($parts[2] ?? '⭐');
    if (!empty($aTitle)) {
        $advantages[] = ['title' => $aTitle, 'description' => $aDesc, 'icon' => $aIcon];
    }
}

$instanceId = 'rr-advantages-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .rr-adv-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .rr-adv-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .rr-adv-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(234, 179, 8, 0.12);
            border: 1px solid rgba(234, 179, 8, 0.25);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .rr-adv-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-adv-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .rr-adv-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .rr-adv-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 18px;
            padding: 32px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .rr-adv-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(234, 179, 8, 0.3);
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(234, 179, 8, 0.1);
        }
        
        #<?= $instanceId ?> .rr-adv-card-icon {
            width: 56px;
            height: 56px;
            background: linear-gradient(145deg, rgba(234, 179, 8, 0.15) 0%, rgba(220, 38, 38, 0.08) 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .rr-adv-card-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 10px;
        }
        
        #<?= $instanceId ?> .rr-adv-card-desc {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
            line-height: 1.6;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .rr-adv-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 768px) {
