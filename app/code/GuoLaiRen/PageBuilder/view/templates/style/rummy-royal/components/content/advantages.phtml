        @media (max-width: 576px) {
            #<?= $instanceId ?> .rr-adv-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    
    <div class="rr-adv-container">
        <div class="rr-adv-header">
            <div class="rr-adv-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="rr-adv-title"><?= htmlspecialchars($title) ?></h2>
            <p class="rr-adv-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="rr-adv-grid">
            <?php foreach ($advantages as $adv): ?>
            <div class="rr-adv-card">
                <div class="rr-adv-card-icon"><?= $adv['icon'] ?></div>
                <h3 class="rr-adv-card-title"><?= htmlspecialchars($adv['title']) ?></h3>
                <p class="rr-adv-card-desc"><?= htmlspecialchars($adv['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
