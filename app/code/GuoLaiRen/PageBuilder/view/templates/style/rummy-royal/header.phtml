<?php
/**
 * RummyRoyal 模板 - Header
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:RummyRoyal
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:44|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 背景颜色:color:rgba(10, 5, 20, 0.95)
 * navigation.text_color => 文字颜色:color:#fef3c7
 * navigation.link_hover_color => 链接悬停颜色:color:#eab308
 * navigation.links => 导航链接:textarea:Home=>/\r\nGames=>/games\r\nDownload=>/download\r\nFAQ=>/faq|格式：名称=>链接，一行一个
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Play Now
 * navigation.cta_url => CTA按钮链接:text:#hero
 * 
 * group:pixel => 像素统计:📊访客像素统计配置:配置访客像素统计功能，用于记录页面访问数据。像素统计会自动使用页面绑定的网站（website_id）进行数据关联。
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}:用于区分不同页面的统计来源，默认使用页面的 handle 作为像素名称。留空将自动使用页面的 handle。
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'rummy-royal';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'rummy-royal';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 辅助函数
if (!function_exists('rr_color')) {
    function rr_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('rr_getConfig')) {
    function rr_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// Logo配置
$logoDisplay = rr_getConfig($styleSettings, 'logo.display', 'yes');
$logoText = rr_getConfig($styleSettings, 'logo.text', 'RummyRoyal');
$logoUrl = rr_getConfig($styleSettings, 'logo.url', '');
$logoWidth = rr_getConfig($styleSettings, 'logo.width', '44');

// 导航配置
$navDisplay = rr_getConfig($styleSettings, 'navigation.display', 'yes');
$navBgColor = rr_getConfig($styleSettings, 'navigation.bg_color', 'rgba(10, 5, 20, 0.95)');
$navTextColor = rr_getConfig($styleSettings, 'navigation.text_color', '#fef3c7');
$navLinkHoverColor = rr_getConfig($styleSettings, 'navigation.link_hover_color', '#eab308');
$navLinksRaw = rr_getConfig($styleSettings, 'navigation.links', "Home=>/\nGames=>/games\nDownload=>/download\nFAQ=>/faq");
$showCta = rr_getConfig($styleSettings, 'navigation.show_cta', 'yes');
$ctaText = rr_getConfig($styleSettings, 'navigation.cta_text', 'Play Now');
$ctaUrl = rr_getConfig($styleSettings, 'navigation.cta_url', '#hero');

// 颜色配置
$accentPrimary = rr_color($colors, 'accent_primary', '#eab308');
$buttonPrimaryBg = rr_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)');

// 解析导航链接
$navLinks = [];
$lines = preg_split('/[\r\n]+/', $navLinksRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('=>', $line, 2);
    $name = trim($parts[0] ?? '');
    $url = trim($parts[1] ?? '#');
    if (!empty($name)) {
        $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
?>

<?php if ($navDisplay === 'yes'): ?>
<?php
    // Header 渲染由 components/header/nav.phtml 处理
    // 这里提供独立 header 区域渲染入口
    $this->assign('component_config', $styleSettings);
    echo $this->fetchTemplate('GuoLaiRen_PageBuilder::templates/style/rummy-royal/components/header/nav.phtml');
?>
<?php endif; ?>

<?php
// === 像素统计代码 ===
$isPreviewMode = (bool)($this->getData('is_preview') ?? false);
if (!$isPreviewMode && isset($_GET['preview']) && $_GET['preview'] === '1') {
    $isPreviewMode = true;
}

$pixelEnabled = rr_getConfig($styleSettings, 'pixel.enabled', 'yes');
$pixelEnabled = (string)($pixelEnabled ?? 'yes');
$pixelName = rr_getConfig($styleSettings, 'pixel.name', '');

if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}

$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;

if ($websiteId > 0 && !empty($pixelName) && !$isPreviewMode):
    \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_ID', (string)$websiteId, 3600 * 24 * 365);
    
    $websiteUrl = '';
    $websiteCode = '';
    try {
        if (class_exists('\Weline\Websites\Model\Website')) {
            $websiteModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Websites\Model\Website::class);
            $website = clone $websiteModel;
            $website->clear()->load($websiteId);
            if ($website->getId()) {
                $websiteUrl = $website->getData('url') ?? '';
                $websiteCode = $website->getData('code') ?? '';
            }
        }
    } catch (\Exception $e) {
        // 不影响像素功能
    }
    
    if (!empty($websiteUrl)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_URL', $websiteUrl, 3600 * 24 * 365);
    }
    
    if (!empty($websiteCode)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_CODE', $websiteCode, 3600 * 24 * 365);
    }
    
    $this->assign('pixel_name', htmlspecialchars($pixelName));
    $this->assign('pixel_enabled', htmlspecialchars($pixelEnabled));
?>
    <pixel name="{{pixel_name}}" enabled="{{pixel_enabled}}" />
<?php endif; ?>
