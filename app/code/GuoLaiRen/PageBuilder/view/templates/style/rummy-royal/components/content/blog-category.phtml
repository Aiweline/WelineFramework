<?php
/**
 * RummyRoyal - Blog Category Component
 * 
 * 博客分类列表展示
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Categories
 * content.title => 标题:text:Browse by Category
 * content.description => 描述:textarea:Explore our rummy content organized by topic.
 * 
 * group:categories => 分类列表
 * categories.items => 分类列表:textarea:Strategy|12 articles|Master rummy tactics and winning strategies.|/blog/category/strategy\r\nTips & Tricks|8 articles|Quick tips to improve your game instantly.|/blog/category/tips\r\nGuides|15 articles|Comprehensive guides for all rummy formats.|/blog/category/guides\r\nNews|6 articles|Latest platform updates and tournament news.|/blog/category/news\r\nEducation|10 articles|Learn the fundamentals of card games.|/blog/category/education|格式：分类名|文章数|描述|链接，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_2'] ?? '#110822';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'Categories';
$title = $config['content.title'] ?? 'Browse by Category';
$description = $config['content.description'] ?? 'Explore our rummy content organized by topic.';

$categoriesRaw = $config['categories.items'] ?? "Strategy|12 articles|Master rummy tactics and winning strategies.|/blog/category/strategy\nTips & Tricks|8 articles|Quick tips to improve your game instantly.|/blog/category/tips\nGuides|15 articles|Comprehensive guides for all rummy formats.|/blog/category/guides\nNews|6 articles|Latest platform updates and tournament news.|/blog/category/news\nEducation|10 articles|Learn the fundamentals of card games.|/blog/category/education";

$categories = [];
$lines = preg_split('/[\r\n]+/', $categoriesRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $cName = trim($parts[0] ?? '');
    $cCount = trim($parts[1] ?? '');
    $cDesc = trim($parts[2] ?? '');
    $cUrl = trim($parts[3] ?? '#');
    if (!empty($cName)) {
        $categories[] = ['name' => $cName, 'count' => $cCount, 'description' => $cDesc, 'url' => $cUrl];
    }
}

$instanceId = 'rr-blog-cat-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .rr-bc-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .rr-bc-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .rr-bc-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(234, 179, 8, 0.12);
            border: 1px solid rgba(234, 179, 8, 0.25);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .rr-bc-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-bc-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
        }
        
        #<?= $instanceId ?> .rr-bc-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        #<?= $instanceId ?> .rr-bc-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 24px 28px;
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 14px;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .rr-bc-item:hover {
            border-color: rgba(234, 179, 8, 0.3);
            background: rgba(255, 255, 255, 0.06);
            transform: translateX(4px);
        }
        
        #<?= $instanceId ?> .rr-bc-item-info h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 4px;
        }
        
        #<?= $instanceId ?> .rr-bc-item-info p {
            font-size: 0.85rem;
            color: <?= $textMuted ?>;
        }
        
        #<?= $instanceId ?> .rr-bc-item-count {
            padding: 6px 14px;
            background: rgba(234, 179, 8, 0.1);
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
            white-space: nowrap;
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .rr-bc-title {
                font-size: 1.85rem;
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .rr-bc-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
        }
    </style>
    
    <div class="rr-bc-container">
        <div class="rr-bc-header">
            <div class="rr-bc-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="rr-bc-title"><?= htmlspecialchars($title) ?></h2>
            <p class="rr-bc-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="rr-bc-list">
            <?php foreach ($categories as $cat): ?>
            <a href="<?= htmlspecialchars($cat['url']) ?>" class="rr-bc-item">
                <div class="rr-bc-item-info">
                    <h3><?= htmlspecialchars($cat['name']) ?></h3>
                    <p><?= htmlspecialchars($cat['description']) ?></p>
                </div>
                <span class="rr-bc-item-count"><?= htmlspecialchars($cat['count']) ?></span>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
