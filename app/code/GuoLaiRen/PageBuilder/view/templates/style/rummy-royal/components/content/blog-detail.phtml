            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        #<?= $instanceId ?> .rr-bd-related-link:last-child {
            border-bottom: none;
        }
        
        #<?= $instanceId ?> .rr-bd-related-link:hover {
            color: <?= $accentPrimary ?>;
        }
        
        #<?= $instanceId ?> .rr-bd-share-btns {
            display: flex;
            gap: 10px;
        }
        
        #<?= $instanceId ?> .rr-bd-share-btn {
            width: 40px;
            height: 40px;
            background: rgba(234, 179, 8, 0.1);
            border: 1px solid rgba(234, 179, 8, 0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        #<?= $instanceId ?> .rr-bd-share-btn:hover {
            background: rgba(234, 179, 8, 0.2);
            border-color: <?= $accentPrimary ?>;
        }
        
        #<?= $instanceId ?> .rr-bd-share-btn svg {
            width: 18px;
            height: 18px;
            fill: <?= $accentPrimary ?>;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .rr-bd-container {
                grid-template-columns: 1fr;
            }
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .rr-bd-title {
                font-size: 1.75rem;
            }
        }
    </style>
    
    <div class="rr-bd-container">
        <article class="rr-bd-main">
            <div class="rr-bd-meta">
                <span class="rr-bd-cat"><?= htmlspecialchars($category) ?></span>
                <span class="rr-bd-date"><?= htmlspecialchars($date) ?></span>
                <span class="rr-bd-time"><?= htmlspecialchars($readTime) ?></span>
            </div>
            <h1 class="rr-bd-title"><?= htmlspecialchars($title) ?></h1>
            <div class="rr-bd-body"><?= nl2br(htmlspecialchars($body)) ?></div>
        </article>
        
        <aside class="rr-bd-sidebar">
            <?php if ($showShare): ?>
            <div class="rr-bd-sidebar-card">
                <h3 class="rr-bd-sidebar-title">Share Article</h3>
                <div class="rr-bd-share-btns">
