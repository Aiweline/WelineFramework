        }
        
        #<?= $instanceId ?> .rr-bd-body {
            font-size: 1rem;
            color: <?= $textSecondary ?>;
            line-height: 1.8;
        }
        
        #<?= $instanceId ?> .rr-bd-body p {
            margin-bottom: 20px;
        }
        
        /* Sidebar */
        #<?= $instanceId ?> .rr-bd-sidebar-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
        }
        
        #<?= $instanceId ?> .rr-bd-sidebar-title {
            font-size: 1rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-bd-related-link {
            display: block;
            padding: 12px 0;
            border-bottom: 1px solid <?= $borderLight ?>;
            font-size: 0.9rem;
