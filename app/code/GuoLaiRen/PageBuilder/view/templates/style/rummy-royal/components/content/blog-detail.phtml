<?php
/**
 * RummyRoyal - Blog Detail Component
 * 
 * 单篇博客文章展示，含侧边栏、相关文章和分享按钮
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 文章设置
 * content.title => 文章标题:text:Mastering Points Rummy: A Complete Guide
 * content.category => 分类:text:Strategy
 * content.date => 发布日期:text:February 6, 2026
 * content.read_time => 阅读时间:text:8 min read
 * content.body => 文章内容:textarea:Points Rummy is the fastest and most popular variant of online rummy. In this guide, we cover everything you need to know to master this exciting card game format.
 * 
 * group:sidebar => 侧边栏设置
 * sidebar.show_related => 显示相关文章:select:yes|yes,no
 * sidebar.show_share => 显示分享按钮:select:yes|yes,no
 * sidebar.related_items => 相关文章:textarea:Top 10 Rummy Strategies|/blog/strategies\r\nPool Rummy Guide|/blog/pool-rummy\r\nTournament Tips|/blog/tournament-tips|格式：标题|链接，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0718';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$title = $config['content.title'] ?? 'Mastering Points Rummy: A Complete Guide';
$category = $config['content.category'] ?? 'Strategy';
$date = $config['content.date'] ?? 'February 6, 2026';
$readTime = $config['content.read_time'] ?? '8 min read';
$body = $config['content.body'] ?? 'Points Rummy is the fastest and most popular variant of online rummy. In this guide, we cover everything you need to know to master this exciting card game format.';

$showRelated = ($config['sidebar.show_related'] ?? 'yes') !== 'no';
$showShare = ($config['sidebar.show_share'] ?? 'yes') !== 'no';
$relatedRaw = $config['sidebar.related_items'] ?? "Top 10 Rummy Strategies|/blog/strategies\nPool Rummy Guide|/blog/pool-rummy\nTournament Tips|/blog/tournament-tips";
$relatedPosts = [];
$lines = preg_split('/[\r\n]+/', $relatedRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $rTitle = trim($parts[0] ?? '');
    $rUrl = trim($parts[1] ?? '#');
    if (!empty($rTitle)) {
        $relatedPosts[] = ['title' => $rTitle, 'url' => $rUrl];
    }
}

$instanceId = 'rr-blog-detail-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .rr-bd-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 48px;
        }
        
        #<?= $instanceId ?> .rr-bd-meta {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        
        #<?= $instanceId ?> .rr-bd-cat {
            padding: 6px 14px;
            background: rgba(234, 179, 8, 0.12);
            border: 1px solid rgba(234, 179, 8, 0.2);
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
        }
        
        #<?= $instanceId ?> .rr-bd-date,
        #<?= $instanceId ?> .rr-bd-time {
            font-size: 0.85rem;
            color: <?= $textMuted ?>;
        }
        
        #<?= $instanceId ?> .rr-bd-title {
            font-size: 2.25rem;
            font-weight: 700;
