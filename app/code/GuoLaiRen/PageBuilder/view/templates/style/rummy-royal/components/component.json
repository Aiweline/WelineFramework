            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-journal-text",
            "sort_order": 80,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "content/blog-list.phtml",
            "default_config": {
                "content.badge": "Blog",
                "content.title": "Rummy Tips & News"
