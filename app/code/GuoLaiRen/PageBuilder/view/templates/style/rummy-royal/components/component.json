            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-file-earmark-text",
            "sort_order": 90,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "layout", "style"],
            "file": "content/legal-content.phtml",
            "default_config": {
                "content.badge": "Legal",
                "content.title": "Legal Document",
                "layout.width": "medium"
            }
        },
        "about-content": {
            "name": "关于我们",
            "name_en": "About Content",
            "description": "关于页面，含英雄横幅、统计数据、故事、价值观和团队",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-info-circle",
            "sort_order": 91,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "stats", "story", "values", "style"],
            "file": "content/about-content.phtml",
            "default_config": {
                "content.badge": "About Us",
                "content.title": "About RummyRoyal"
            }
        },
        "contact-content": {
            "name": "联系我们",
            "name_en": "Contact Content",
            "description": "联系页面，含表单和联系信息",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-envelope",
            "sort_order": 92,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "contact", "form", "style"],
            "file": "content/contact-content.phtml",
            "default_config": {
                "content.badge": "Contact Us",
                "content.title": "Get in Touch"
            }
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer with Links",
            "description": "页脚区域，包含品牌信息、多栏链接和版权",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "icon": "bi-layout-text-window-reverse",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["brand", "links", "copyright", "style"],
            "file": "footer/links.phtml",
            "default_config": {
                "brand.name": "RummyRoyal",
                "brand.description": "India's most trusted online rummy platform. Play skill-based card games, win real cash prizes, and enjoy a premium gaming experience.",
                "links.items": "Games=>#games\nDownload=>#download\nFAQ=>#faq\nContact=>/contact",
                "copyright.text": "Play responsibly. 18+ only."
            }
        }
    },
    "nav_config": {
        "description": "导航可使用子页面配置",
        "use_subpages": true,
        "subpage_types": ["link", "anchor", "page"],
        "default_items": [
            {"text": "Home", "href": "#home", "type": "anchor"},
            {"text": "Games", "href": "#games", "type": "anchor"},
            {"text": "Download", "href": "#download", "type": "anchor"},
            {"text": "FAQ", "href": "#faq", "type": "anchor"}
        ]
    },
    "config_inheritance": {
        "description": "组件可以继承模板的配置项",
        "shared_configs": ["styles", "texts", "color_scheme"]
    }
}
