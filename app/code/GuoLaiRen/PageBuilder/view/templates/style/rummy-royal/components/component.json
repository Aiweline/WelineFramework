            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-file-text",
            "sort_order": 81,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "sidebar", "style"],
            "file": "content/blog-detail.phtml",
            "default_config": {
                "sidebar.show_related": "yes",
                "sidebar.show_share": "yes"
