{
    "template": "rummy-royal",
    "name": "RummyRoyal",
    "description": "Luxury gold + deep red dark theme for Indian Rummy gaming platforms",
    "version": "1.0.0",
    "author": "GuoLaiRen",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部导航区域",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav"
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "games", "advantages", "app-download", "testimonials", "faq", "cta-banner"]
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部链接和版权区域",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links"
        }
    },
    "components": {
        "header-nav": {
            "name": "导航栏",
            "name_en": "Navigation Header",
            "description": "页面顶部导航，支持Logo、导航链接和CTA按钮",
            "region": "header",
            "category": "header",
            "type": "section",
            "icon": "bi-menu-button-wide",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["header", "navigation", "cta_button", "color_scheme"],
            "file": "header/nav.phtml",
            "default_config": {
                "logo.display": "yes",
                "logo.text": "RummyRoyal",
                "logo.width": 44,
                "navigation.show_cta": "yes",
                "navigation.cta_text": "Play Now",
                "navigation.cta_url": "#hero"
            }
        },
        "hero-slider": {
            "name": "首屏英雄区",
            "name_en": "Hero Slider",
            "description": "全宽首屏区域，包含大标题、统计数据和CTA按钮",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-badge-hd",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "cta", "stats", "style"],
            "file": "content/hero-slider.phtml",
            "default_config": {
                "content.badge": "🏆 #1 Rated",
                "content.title": "India's Most Trusted Rummy Platform",
                "cta.primary_text": "Play Rummy Now",
                "cta.secondary_text": "Download App"
            }
        },
        "games": {
            "name": "游戏展示",
            "name_en": "Games Showcase",
            "description": "展示各类Rummy游戏模式，4列卡片布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-controller",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "games", "style"],
            "file": "content/games.phtml",
            "default_config": {
                "content.badge": "Game Variants",
                "content.title": "Choose Your Rummy Style"
            }
        },
        "advantages": {
            "name": "平台优势",
            "name_en": "Advantages Section",
            "description": "展示平台核心优势，6卡片网格布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-stars",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "content/advantages.phtml",
            "default_config": {
                "content.badge": "Why Choose Us",
                "content.title": "The RummyRoyal Advantage"
            }
        },
        "app-download": {
            "name": "应用下载",
            "name_en": "App Download Section",
            "description": "应用下载区域，包含下载按钮和安装指南",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-download",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "download", "features", "style"],
            "file": "content/app-download.phtml",
            "default_config": {
                "content.badge": "Download App",
                "content.title": "Play Rummy Anytime, Anywhere",
                "download.primary_text": "Google Play",
                "download.secondary_text": "Direct APK"
            }
        },
        "testimonials": {
            "name": "用户评价",
            "name_en": "Testimonials",
            "description": "会员评价展示区域，3列布局含星级评分",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-chat-quote",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "testimonials", "style"],
            "file": "content/testimonials.phtml",
            "default_config": {
                "content.badge": "Player Reviews",
                "content.title": "What Our Players Say"
            }
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ Section",
            "description": "FAQ手风琴展示，支持展开收起效果",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-question-circle",
            "sort_order": 60,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["faq", "style"],
            "file": "content/faq.phtml",
            "default_config": {
                "content.badge": "FAQ",
                "content.title": "Frequently Asked Questions"
            }
        },
        "cta-banner": {
            "name": "CTA横幅",
            "name_en": "CTA Banner",
            "description": "行动号召横幅区域，引导用户注册或下载",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-megaphone",
            "sort_order": 70,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "buttons", "style"],
            "file": "content/cta-banner.phtml",
            "default_config": {
                "content.title": "Ready to Win Big?",
                "buttons.primary_text": "Register Now",
                "buttons.secondary_text": "Download App"
            }
        },
        "blog-list": {
            "name": "博客列表",
            "name_en": "Blog List",
