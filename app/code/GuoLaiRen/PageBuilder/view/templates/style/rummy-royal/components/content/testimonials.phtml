<?php
/**
 * RummyRoyal - Testimonials Section Component
 * 
 * 会员评价展示区域，3列布局含星级评分、姓名、城市、赢金额
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Player Reviews
 * content.title => 标题:text:What Our Players Say
 * content.description => 描述:textarea:Thousands of players trust RummyRoyal for a fair and rewarding rummy experience.
 * 
 * group:testimonials => 评价列表
 * testimonials.items => 评价列表:textarea:Rajesh K.|Mumbai|5|₹2,50,000|Best rummy app I've played on. The interface is smooth and withdrawals are instant. Won my first tournament within a week!\r\nPriya S.|Bangalore|5|₹1,80,000|Love the multi-table feature! I can play Points and Pool simultaneously. Customer support is also very responsive.\r\nAmit V.|Delhi|4|₹3,20,000|RummyRoyal's fair play certification gives me confidence. The tournament prize pools are massive!|格式：姓名|城市|星级|赢金额|评价内容，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['testimonials_bg'] ?? '#110822';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';
$starFilled = $colors['star_filled'] ?? '#eab308';
$starEmpty = $colors['star_empty'] ?? 'rgba(234, 179, 8, 0.2)';

$badge = $config['content.badge'] ?? 'Player Reviews';
$title = $config['content.title'] ?? 'What Our Players Say';
$description = $config['content.description'] ?? 'Thousands of players trust RummyRoyal for a fair and rewarding rummy experience.';

$testimonialsRaw = $config['testimonials.items'] ?? "Rajesh K.|Mumbai|5|₹2,50,000|Best rummy app I've played on. The interface is smooth and withdrawals are instant. Won my first tournament within a week!\nPriya S.|Bangalore|5|₹1,80,000|Love the multi-table feature! I can play Points and Pool simultaneously. Customer support is also very responsive.\nAmit V.|Delhi|4|₹3,20,000|RummyRoyal's fair play certification gives me confidence. The tournament prize pools are massive!";

$testimonials = [];
$lines = preg_split('/[\r\n]+/', $testimonialsRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    $name = trim($parts[0] ?? '');
    $city = trim($parts[1] ?? '');
    $stars = intval(trim($parts[2] ?? '5'));
    $winnings = trim($parts[3] ?? '');
    $review = trim($parts[4] ?? '');
    if (!empty($name)) {
        $testimonials[] = ['name' => $name, 'city' => $city, 'stars' => $stars, 'winnings' => $winnings, 'review' => $review];
    }
}

$instanceId = 'rr-testimonials-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .rr-test-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .rr-test-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .rr-test-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(234, 179, 8, 0.12);
            border: 1px solid rgba(234, 179, 8, 0.25);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            color: <?= $accentPrimary ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .rr-test-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-test-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 600px;
            margin: 0 auto;
        }
        
        #<?= $instanceId ?> .rr-test-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .rr-test-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 18px;
            padding: 32px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .rr-test-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(234, 179, 8, 0.3);
            transform: translateY(-4px);
        }
        
        #<?= $instanceId ?> .rr-test-stars {
            display: flex;
            gap: 4px;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .rr-test-star {
            width: 18px;
            height: 18px;
        }
        
        #<?= $instanceId ?> .rr-test-star-filled {
            fill: <?= $starFilled ?>;
        }
        
        #<?= $instanceId ?> .rr-test-star-empty {
            fill: <?= $starEmpty ?>;
        }
        
        #<?= $instanceId ?> .rr-test-review {
            font-size: 0.95rem;
            color: <?= $textSecondary ?>;
            line-height: 1.7;
            margin-bottom: 24px;
            font-style: italic;
        }
        
        #<?= $instanceId ?> .rr-test-author {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        #<?= $instanceId ?> .rr-test-author-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        #<?= $instanceId ?> .rr-test-avatar {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, rgba(234, 179, 8, 0.2), rgba(220, 38, 38, 0.15));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 700;
            color: <?= $accentPrimary ?>;
        }
        
        #<?= $instanceId ?> .rr-test-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: <?= $textPrimary ?>;
        }
        
        #<?= $instanceId ?> .rr-test-city {
            font-size: 0.8rem;
            color: <?= $textMuted ?>;
        }
        
        #<?= $instanceId ?> .rr-test-winnings {
            padding: 6px 12px;
            background: rgba(234, 179, 8, 0.1);
            border: 1px solid rgba(234, 179, 8, 0.2);
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            color: <?= $accentPrimary ?>;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .rr-test-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .rr-test-title {
                font-size: 1.85rem;
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .rr-test-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    
    <div class="rr-test-container">
        <div class="rr-test-header">
            <div class="rr-test-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/></svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="rr-test-title"><?= htmlspecialchars($title) ?></h2>
            <p class="rr-test-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="rr-test-grid">
            <?php foreach ($testimonials as $t): ?>
            <div class="rr-test-card">
                <div class="rr-test-stars">
                    <?php for ($i = 1; $i <= 5; $i++): ?>
                    <svg class="rr-test-star" viewBox="0 0 24 24">
                        <path class="<?= $i <= $t['stars'] ? 'rr-test-star-filled' : 'rr-test-star-empty' ?>" d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                    </svg>
                    <?php endfor; ?>
                </div>
                
                <p class="rr-test-review">"<?= htmlspecialchars($t['review']) ?>"</p>
                
                <div class="rr-test-author">
                    <div class="rr-test-author-info">
                        <div class="rr-test-avatar"><?= htmlspecialchars(mb_substr($t['name'], 0, 1)) ?></div>
                        <div>
                            <div class="rr-test-name"><?= htmlspecialchars($t['name']) ?></div>
                            <div class="rr-test-city"><?= htmlspecialchars($t['city']) ?></div>
                        </div>
                    </div>
                    <?php if ($t['winnings']): ?>
                    <div class="rr-test-winnings">Won <?= htmlspecialchars($t['winnings']) ?></div>
                    <?php endif; ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
