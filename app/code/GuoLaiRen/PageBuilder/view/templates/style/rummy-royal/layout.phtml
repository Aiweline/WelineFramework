// 颜色辅助函数
if (!function_exists('rr_color')) {
    function rr_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

// 配置辅助函数
if (!function_exists('rr_getConfig')) {
    function rr_getConfig($settings, $key, $default = '') {
        $value = $settings[$key] ?? $default;
        if ($value === '' && $default !== '') {
            return $default;
        }
        return $value;
    }
}

// 获取页面标题和元数据
