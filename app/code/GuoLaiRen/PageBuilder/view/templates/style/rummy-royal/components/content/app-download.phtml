/**
 * RummyRoyal - App Download Section Component
 * 
 * 应用下载区域，含手机模型装饰、特性列表和下载按钮
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Download App
 * content.title => 标题:text:Play Rummy Anytime, Anywhere
 * content.description => 描述:textarea:Download the RummyRoyal app for the best mobile rummy experience. Lightweight, secure, and blazing fast tables.
 * 
 * group:download => 下载设置
 * download.primary_text => 主下载按钮:text:Google Play
 * download.primary_url => 主下载链接:text:#
 * download.secondary_text => 次下载按钮:text:Direct APK
 * download.secondary_url => 次下载链接:text:#
 * 
 * group:features => 特性列表
 * features.items => 特性列表:textarea:Lightweight|Under 25MB, installs in seconds\r\nSecure Login|OTP + biometric authentication\r\nFast Tables|Join a game in under 10 seconds|一行一个：标题|描述
 * 
 * group:checklist => 安装清单
 * checklist.title => 清单标题:text:Quick Install Guide
 * checklist.items => 清单项目:textarea:Download the APK|Tap the download button and save the official APK file.\r\nAllow Installation|Enable "Install from unknown sources" in your Android settings.\r\nOpen & Register|Launch the app, create your account, and claim your welcome bonus.|格式：标题|描述，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['download_bg'] ?? 'linear-gradient(135deg, #1a0a2e 0%, #0d0718 100%)';
$textPrimary = $colors['text_primary'] ?? '#fef3c7';
$textSecondary = $colors['text_secondary'] ?? '#d4a574';
$textMuted = $colors['text_muted'] ?? '#8b6f47';
$accentPrimary = $colors['accent_primary'] ?? '#eab308';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#facc15';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)';
$buttonPrimaryText = $colors['button_primary_text'] ?? '#1a0a2e';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(234, 179, 8, 0.12)';

$badge = $config['content.badge'] ?? 'Download App';
$title = $config['content.title'] ?? 'Play Rummy Anytime, Anywhere';
$description = $config['content.description'] ?? 'Download the RummyRoyal app for the best mobile rummy experience. Lightweight, secure, and blazing fast tables.';

$primaryBtnText = $config['download.primary_text'] ?? 'Google Play';
$primaryBtnUrl = $config['download.primary_url'] ?? '#';
$secondaryBtnText = $config['download.secondary_text'] ?? 'Direct APK';
$secondaryBtnUrl = $config['download.secondary_url'] ?? '#';

$featuresRaw = $config['features.items'] ?? "Lightweight|Under 25MB, installs in seconds\nSecure Login|OTP + biometric authentication\nFast Tables|Join a game in under 10 seconds";
$features = [];
$fLines = preg_split('/[\r\n]+/', $featuresRaw);
foreach ($fLines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $fTitle = trim($parts[0] ?? '');
    $fDesc = trim($parts[1] ?? '');
    if (!empty($fTitle)) {
        $features[] = ['title' => $fTitle, 'description' => $fDesc];
    }
}

$checklistTitle = $config['checklist.title'] ?? 'Quick Install Guide';
$checklistRaw = $config['checklist.items'] ?? "Download the APK|Tap the download button and save the official APK file.\nAllow Installation|Enable \"Install from unknown sources\" in your Android settings.\nOpen & Register|Launch the app, create your account, and claim your welcome bonus.";
$checklist = [];
$cLines = preg_split('/[\r\n]+/', $checklistRaw);
foreach ($cLines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    $cTitle = trim($parts[0] ?? '');
    $cDesc = trim($parts[1] ?? '');
    if (!empty($cTitle)) {
        $checklist[] = ['title' => $cTitle, 'description' => $cDesc];
    }
}

$instanceId = 'rr-download-' . uniqid();
?>

