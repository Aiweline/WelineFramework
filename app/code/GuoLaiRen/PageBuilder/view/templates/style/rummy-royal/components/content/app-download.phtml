    <script>
    (function(){
        var primaryUrl = <?= json_encode($primaryBtnUrl, JSON_UNESCAPED_SLASHES) ?>;
        var secondaryUrl = <?= json_encode($secondaryBtnUrl, JSON_UNESCAPED_SLASHES) ?>;
        document.querySelectorAll('#<?= $instanceId ?> [data-download-trigger="primary"]').forEach(function(el){
            el.addEventListener('click', function(){ window.location.href = primaryUrl; });
        });
        document.querySelectorAll('#<?= $instanceId ?> [data-download-trigger="secondary"]').forEach(function(el){
