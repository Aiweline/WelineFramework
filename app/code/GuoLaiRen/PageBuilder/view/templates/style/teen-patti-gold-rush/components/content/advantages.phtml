        width: 8px;
        height: 8px;
        border-radius: 999px;
        border: 0;
        padding: 0;
        background: rgba(255, 184, 227, 0.42);
        cursor: pointer;
        transition: width 0.22s ease, background-color 0.22s ease;
    }

    #<?= $componentId ?> .mobile-dot.is-active,
    #<?= $componentId ?> .mobile-dot[aria-current='true'] {
        width: 20px;
        background: linear-gradient(90deg, rgba(255, 120, 205, 0.96), rgba(169, 255, 94, 0.96));
    }
}

@media (max-width: 640px) {
    #<?= $componentId ?> .adv-cta {
        width: 100%;
    }

    #<?= $componentId ?> .mobile-reel {
        grid-auto-columns: minmax(88%, 1fr);
    }
}

@media (prefers-reduced-motion: reduce) {
    #<?= $componentId ?> .mobile-adv-card {
        transition: none;
    }
}
</style>

<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var reel = root.querySelector('[data-adv-reel]');
    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-adv-card]'));
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-adv-dot]'));

    if (!reel || cards.length === 0 || dots.length === 0) {
        return;
    }

    var setActive = function(index) {
        cards.forEach(function(card, idx) {
            card.classList.toggle('is-focus', idx === index);
        });
        dots.forEach(function(dot, idx) {
            var isCurrent = idx === index;
            dot.classList.toggle('is-active', isCurrent);
            if (isCurrent) {
                dot.setAttribute('aria-current', 'true');
            } else {
                dot.removeAttribute('aria-current');
            }
        });
    };

    dots.forEach(function(dot, idx) {
        dot.addEventListener('click', function() {
            if (cards[idx]) {
                cards[idx].scrollIntoView({behavior: 'smooth', inline: 'center', block: 'nearest'});
                setActive(idx);
            }
        });
    });

    if (!('IntersectionObserver' in window)) {
        return;
    }

    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.62) {
                var idx = parseInt(entry.target.getAttribute('data-adv-index') || '0', 10);
                setActive(idx);
            }
        });
    }, {
        root: reel,
        threshold: [0.62]
    });

    cards.forEach(function(card) {
        observer.observe(card);
    });
})();
</script>
