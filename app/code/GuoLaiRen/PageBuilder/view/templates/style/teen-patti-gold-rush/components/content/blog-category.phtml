<?php
/**
 * Teen Patti Gold Rush - Blog Category Component
 *
 * @fields_start
 * blog.title|Category title|text|Category Posts
 * blog.subtitle|Subtitle|text|Browse articles by category
 * blog.posts_per_page|Posts per page|number|9
 * blog.show_sidebar|Show sidebar|select:yes=Yes,no=No|yes
 * blog.show_category|Show category|select:yes=Yes,no=No|yes
 * blog.show_date|Show date|select:yes=Yes,no=No|yes
 * blog.show_author|Show author|select:yes=Yes,no=No|yes
 * blog.card_style|Card style|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? __('Category Posts'));
$subtitle = $getConfig('blog.subtitle', __('Browse articles by category'));
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#47c4ff');
$secondaryColor = $getConfig('color_scheme.secondary', '#34f3cd');
$bgColor = $getConfig('color_scheme.background', '#0f1528');
$textColor = $getConfig('color_scheme.text', '#f3f7ff');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};
?>

<section class="tpmst-section oct-blog-category" id="blog-category">
    <div class="section-inner">
        <header class="blog-head">
            <?php if (!empty($currentCategory['name'])): ?>
                <p class="category-pill"><?= htmlspecialchars($currentCategory['name']) ?></p>
            <?php endif; ?>

            <div class="blog-head-row">
                <h2><?= htmlspecialchars($title) ?></h2>
                <?php if (!empty($posts)): ?>
                    <span class="post-count"><?= count($posts) ?> <?= __('Posts') ?></span>
                <?php endif; ?>
            </div>

            <?php if ($subtitle): ?>
                <p class="head-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if (!empty($currentCategory['description'])): ?>
                <p class="head-desc"><?= htmlspecialchars($currentCategory['description']) ?></p>
            <?php endif; ?>

            <?php if (!empty($blogCategories)): ?>
                <nav class="category-rail" aria-label="Blog categories">
                    <?php foreach ($blogCategories as $category): ?>
                        <?php
                        $categoryName = $category['name'] ?? '';
                        $categoryUrl = $category['url'] ?? '#';
                        $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$category['id'] === (string)$currentCategory['id'];
                        if ($categoryName === '') {
                            continue;
                        }
                        ?>
                        <a href="<?= htmlspecialchars($categoryUrl) ?>" class="<?= $isActive ? 'active' : '' ?>">
                            <span><?= htmlspecialchars($categoryName) ?></span>
                            <?php if (isset($category['post_count'])): ?>
                                <em><?= (int)$category['post_count'] ?></em>
                            <?php endif; ?>
                        </a>
                    <?php endforeach; ?>
                </nav>
            <?php endif; ?>
        </header>

        <div class="blog-layout<?= $showSidebar ? ' with-sidebar' : ' full-width' ?>">
            <main class="posts-grid" aria-label="Category posts">
                <?php if (empty($posts)): ?>
                    <article class="empty-state">
                        <h3><?= __('No posts in this category yet') ?></h3>
                        <p><?= __('Try another category or return to the main blog index.') ?></p>
                        <a class="empty-link" href="/blog"><?= __('Back to Blog') ?></a>
                    </article>
                <?php else: ?>
                    <?php foreach ($posts as $index => $post): ?>
                        <?php
                        $postUrl = !empty($post['url']) ? $post['url'] : '#';
                        $postTitle = !empty($post['title']) ? $post['title'] : __('Untitled Post');
                        $postSummary = !empty($post['summary']) ? $post['summary'] : '';
                        $postImage = !empty($post['cover_image']) ? $post['cover_image'] : '';
                        $postCategory = !empty($post['category_name']) ? $post['category_name'] : '';
                        $postDate = $formatDate($post['published_at'] ?? '');
                        $postAuthor = !empty($post['author']) ? $post['author'] : '';
                        $laneClass = 'lane-' . (($index % 3) + 1);
                        ?>
                        <article class="post-card style-<?= htmlspecialchars($cardStyle) ?> <?= htmlspecialchars($laneClass) ?><?= $index === 0 && $cardStyle === 'featured' ? ' is-featured' : '' ?>">
                            <?php if ($postImage): ?>
                                <a class="post-image" href="<?= htmlspecialchars($postUrl) ?>">
                                    <img src="<?= htmlspecialchars($postImage) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>

                            <div class="post-body">
                                <div class="post-meta">
                                    <?php if ($showCategory && $postCategory): ?>
                                        <span class="post-chip"><?= htmlspecialchars($postCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $postDate): ?>
                                        <span class="post-date"><?= htmlspecialchars($postDate) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h3><a href="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($postTitle) ?></a></h3>

                                <?php if ($postSummary): ?>
                                    <p class="post-summary">
                                        <?= htmlspecialchars(mb_substr($postSummary, 0, 170)) ?><?= mb_strlen($postSummary) > 170 ? '...' : '' ?>
                                    </p>
                                <?php endif; ?>

                                <div class="post-footer">
                                    <?php if ($showAuthor && $postAuthor): ?>
                                        <span class="post-author"><?= htmlspecialchars($postAuthor) ?></span>
                                    <?php endif; ?>
                                    <a class="read-more" href="<?= htmlspecialchars($postUrl) ?>"><?= __('Read More') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                <?php endif; ?>
            </main>

            <?php if ($showSidebar): ?>
                <aside class="sidebar">
                    <?php if (!empty($blogCategories)): ?>
                        <section class="sidebar-card">
                            <h4><?= __('Categories') ?></h4>
                            <ul>
                                <?php foreach ($blogCategories as $category): ?>
                                    <?php
                                    $categoryName = $category['name'] ?? '';
                                    $categoryUrl = $category['url'] ?? '#';
                                    $isActive = !empty($currentCategory['id']) && !empty($category['id']) && (string)$category['id'] === (string)$currentCategory['id'];
                                    if ($categoryName === '') {
                                        continue;
                                    }
                                    ?>
                                    <li class="<?= $isActive ? 'active' : '' ?>">
                                        <a href="<?= htmlspecialchars($categoryUrl) ?>">
                                            <span><?= htmlspecialchars($categoryName) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <small><?= (int)$category['post_count'] ?></small>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($recent)): ?>
                        <section class="sidebar-card">
                            <h4><?= __('Recent Posts') ?></h4>
                            <ul class="recent-list">
                                <?php foreach ($recent as $post): ?>
                                    <?php
                                    $postUrl = $post['url'] ?? '#';
                                    $postTitle = $post['title'] ?? __('Untitled Post');
                                    $postDate = $formatDate($post['published_at'] ?? '');
                                    ?>
                                    <li>
                                        <a href="<?= htmlspecialchars($postUrl) ?>">
                                            <span class="recent-title"><?= htmlspecialchars($postTitle) ?></span>
                                            <?php if ($postDate): ?>
                                                <span class="recent-date"><?= htmlspecialchars($postDate) ?></span>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>
        </div>
    </div>
</section>

<style>
