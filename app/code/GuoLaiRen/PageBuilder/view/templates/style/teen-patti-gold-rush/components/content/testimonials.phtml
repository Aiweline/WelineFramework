<?php
/**
 * Teen Patti Gold Rush - Testimonials Component
 *
 * @component_start
 * code: testimonials
 * name: 用户评价
 * name_en: Testimonials
 * description: 用户评价展示，支持头像、评分和内容
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_rating => 显示评分:select:yes|yes,no
 * display.show_avatar => 显示头像:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#14183d
 * style.title_color => 标题颜色:color:#f7f3ff
 * style.title_font_size => 标题字号(PC端):number:36|px
 * style.title_font_size_mobile => 标题字号(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.1)
 * style.card_border_radius => 卡片圆角:number:14|px
 * style.card_border_left_color => 卡片高亮颜色:color:#ff5ab6
 * style.card_border_left_width => 卡片高亮宽度:number:3|px
 * style.card_padding => 卡片内边距:number:22|px
 * style.name_color => 姓名颜色:color:#fff5d3
 * style.name_font_size => 姓名字号:number:16|px
 * style.rating_color => 评分颜色:color:#ffd980
 * style.content_color => 内容文字颜色:color:#d9e7ff
 * style.content_font_size => 内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:58|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:68|px
 * style.section_padding_mobile => 区域内边距(移动端):number:42|px
 * style.card_gap => 卡片间距:number:20|px
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:|默认使用本地头像
 * avatars.avatar_2 => 评价2头像:textarea:|默认使用本地头像
 * avatars.avatar_3 => 评价3头像:textarea:|默认使用本地头像
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:What Players Notice First
 * texts.testimonial_1_name => 评价1姓名:text:Rajesh Kumar (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:4.9/5
 * texts.testimonial_1_content => 评价1内容:textarea:Teen Patti Gold Rush loads tables very quickly and results settle without delays.
 * texts.testimonial_2_name => 评价2姓名:text:Priya Sharma (Delhi)
 * texts.testimonial_2_rating => 评价2评分:text:4.8/5
 * texts.testimonial_2_content => 评价2内容:textarea:I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.
 * texts.testimonial_3_name => 评价3姓名:text:Amit Patel (Ahmedabad)
 * texts.testimonial_3_rating => 评价3评分:text:4.8/5
 * texts.testimonial_3_content => 评价3内容:textarea:The app flow is clean and withdrawals are easy to track from the wallet panel.
 *
 * @fields_end
 */

$componentId = 'gr-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#14183d'));
$titleColor = $getConfig('style.title_color', '#f7f3ff');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.1)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '14');
$cardAccentColor = $getConfig('style.card_border_left_color', '#ff5ab6');
$cardAccentWidth = (int)$getConfig('style.card_border_left_width', '3');
$cardPadding = (int)$getConfig('style.card_padding', '22');
$nameColor = $getConfig('style.name_color', '#fff5d3');
$nameFontSize = (int)$getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', '#ffd980');
$contentColor = $getConfig('style.content_color', '#d9e7ff');
$contentFontSize = (int)$getConfig('style.content_font_size', '14');
$avatarSize = (int)$getConfig('style.avatar_size', '58');
$avatarRadius = (int)$getConfig('style.avatar_border_radius', '50');
$sectionPadding = (int)$getConfig('style.section_padding', '68');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '42');
$cardGap = (int)$getConfig('style.card_gap', '20');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/user/Amit-Patel-3.avif');

$avatar1 = $getConfig('avatars.avatar_1', $getConfig('testimonials.avatar_1', '')) ?: $defaultAvatar1;
$avatar2 = $getConfig('avatars.avatar_2', $getConfig('testimonials.avatar_2', '')) ?: $defaultAvatar2;
$avatar3 = $getConfig('avatars.avatar_3', $getConfig('testimonials.avatar_3', '')) ?: $defaultAvatar3;

$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Notice First'));
$name1 = $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)');
$rating1 = $getConfig('texts.testimonial_1_rating', '4.9/5');
$content1 = $getConfig('texts.testimonial_1_content', 'Teen Patti Gold Rush loads tables very quickly and results settle without delays.');
$name2 = $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)');
$rating2 = $getConfig('texts.testimonial_2_rating', '4.8/5');
$content2 = $getConfig('texts.testimonial_2_content', 'I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.');
$name3 = $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)');
$rating3 = $getConfig('texts.testimonial_3_rating', '4.8/5');
$content3 = $getConfig('texts.testimonial_3_content', 'The app flow is clean and withdrawals are easy to track from the wallet panel.');

$cards = [
    ['avatar' => $avatar1, 'name' => $name1, 'rating' => $rating1, 'content' => $content1],
    ['avatar' => $avatar2, 'name' => $name2, 'rating' => $rating2, 'content' => $content2],
    ['avatar' => $avatar3, 'name' => $name3, 'rating' => $rating3, 'content' => $content3],
];
?>

<section id="<?= $componentId ?>" class="gr-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <div class="section-inner">
        <?php if ($showTitle): ?>
            <h2 id="<?= $componentId ?>-title" class="section-title"><?= htmlspecialchars($title) ?></h2>
        <?php endif; ?>

        <div class="review-wall">
            <?php foreach ($cards as $index => $card): ?>
                <article class="review-card review-card-<?= (int)($index + 1) ?>">
                    <div class="review-head">
                        <?php if ($showAvatar): ?>
                            <img src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
                        <?php endif; ?>
                        <div>
                            <h3><?= htmlspecialchars($card['name']) ?></h3>
                            <?php if ($showRating): ?>
                                <p class="rating"><?= htmlspecialchars($card['rating']) ?></p>
                            <?php endif; ?>
                        </div>
                    </div>
                    <p class="review-body"><?= htmlspecialchars($card['content']) ?></p>
                </article>
            <?php endforeach; ?>
        </div>

        <div class="mobile-review-list">
            <?php foreach ($cards as $index => $card): ?>
                <article class="mobile-review-item">
                    <div class="review-head">
                        <?php if ($showAvatar): ?>
                            <img src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
                        <?php endif; ?>
                        <div>
                            <h3><?= htmlspecialchars($card['name']) ?></h3>
                            <?php if ($showRating): ?>
                                <p class="rating"><?= htmlspecialchars($card['rating']) ?></p>
                            <?php endif; ?>
                        </div>
                    </div>
                    <p class="review-body"><?= htmlspecialchars($card['content']) ?></p>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    padding: <?= $sectionPadding ?>px 0;
    background-color: <?= htmlspecialchars($bgColor) ?>;
    background-image:
        repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.025) 0 2px, transparent 2px 18px),
        repeating-linear-gradient(-45deg, rgba(255, 255, 255, 0.02) 0 2px, transparent 2px 20px);
    box-shadow: inset 0 -120px 120px -96px rgba(14, 10, 22, 0.34);
}

#<?= $componentId ?>::before {
    content: '';
    position: absolute;
    left: -12%;
    top: -22%;
    width: min(560px, 48vw);
    height: min(560px, 48vw);
    border-radius: 50%;
    border: 1px solid rgba(255, 160, 223, 0.22);
    box-shadow:
        0 0 0 20px rgba(255, 160, 223, 0.05),
        0 0 0 40px rgba(255, 160, 223, 0.03);
    pointer-events: none;
}

#<?= $componentId ?>::after {
    content: '';
    position: absolute;
    right: -6%;
    bottom: -16%;
    width: min(520px, 46vw);
    height: min(520px, 46vw);
    background-image:
        radial-gradient(rgba(147, 255, 227, 0.4) 1px, transparent 1px),
        radial-gradient(rgba(255, 180, 136, 0.3) 1px, transparent 1px);
    background-size: 18px 18px, 24px 24px;
    background-position: 0 0, 12px 12px;
    opacity: 0.12;
    pointer-events: none;
}

#<?= $componentId ?> .section-inner {
    width: min(1240px, calc(100% - 1.2rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

#<?= $componentId ?> .section-title {
    margin: 0 0 1.5rem;
    color: <?= htmlspecialchars($titleColor) ?>;
    font-size: clamp(<?= $titleFontSizeMobile ?>px, 5vw, <?= $titleFontSize ?>px);
    line-height: 1.05;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.84rem;
    text-align: center;
}

#<?= $componentId ?> .section-title::before,
#<?= $componentId ?> .section-title::after {
    content: '';
    flex: 1 1 120px;
    max-width: 180px;
    min-width: 56px;
    height: 10px;
}

#<?= $componentId ?> .section-title::before {
    background:
        linear-gradient(90deg, rgba(169, 255, 94, 0), rgba(169, 255, 94, 0.84) 58%, rgba(255, 90, 182, 0.96) 100%) center/100% 2px no-repeat,
        linear-gradient(135deg, transparent 45%, rgba(255, 90, 182, 0.96) 46% 56%, transparent 57%) right center/10px 10px no-repeat;
}

#<?= $componentId ?> .section-title::after {
    background:
        linear-gradient(270deg, rgba(169, 255, 94, 0), rgba(169, 255, 94, 0.84) 58%, rgba(255, 90, 182, 0.96) 100%) center/100% 2px no-repeat,
        linear-gradient(-135deg, transparent 45%, rgba(255, 90, 182, 0.96) 46% 56%, transparent 57%) left center/10px 10px no-repeat;
}

#<?= $componentId ?> .review-wall {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: <?= $cardGap ?>px;
    align-items: stretch;
}

#<?= $componentId ?> .review-card,
#<?= $componentId ?> .mobile-review-item {
    position: relative;
    border-radius: <?= $cardBorderRadius ?>px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02)), <?= htmlspecialchars($cardBgColor) ?>;
    border: 1px solid rgba(255, 188, 228, 0.16);
    border-left: <?= max(1, $cardAccentWidth - 1) ?>px solid <?= htmlspecialchars($cardAccentColor) ?>;
    padding: <?= $cardPadding ?>px;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.22);
    overflow: hidden;
}

#<?= $componentId ?> .review-card::after,
#<?= $componentId ?> .mobile-review-item::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 0;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(169, 255, 94, 0), rgba(169, 255, 94, 0.82), rgba(255, 90, 182, 0));
    opacity: 0.26;
}

#<?= $componentId ?> .review-card-2 {
    transform: translateY(-4px);
}

#<?= $componentId ?> .review-card-1,
#<?= $componentId ?> .review-card-3 {
    transform: translateY(4px);
}

#<?= $componentId ?> .review-head {
    display: flex;
    align-items: center;
    gap: 0.72rem;
}

#<?= $componentId ?> .review-head img {
    width: <?= $avatarSize ?>px;
    height: <?= $avatarSize ?>px;
    border-radius: <?= $avatarRadius ?>%;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.34);
}

#<?= $componentId ?> .review-head h3 {
    margin: 0;
    color: <?= htmlspecialchars($nameColor) ?>;
    font-size: <?= $nameFontSize ?>px;
    line-height: 1.2;
}

#<?= $componentId ?> .review-head .rating {
    margin: 0.24rem 0 0;
    color: <?= htmlspecialchars($ratingColor) ?>;
    font-size: 0.84rem;
    font-weight: 700;
}

#<?= $componentId ?> .review-body {
    margin: 0.86rem 0 0;
    color: <?= htmlspecialchars($contentColor) ?>;
    font-size: <?= $contentFontSize ?>px;
    line-height: 1.72;
    opacity: 0.94;
}

#<?= $componentId ?> .mobile-review-list {
    display: none;
}

@media (max-width: 900px) {
    #<?= $componentId ?> {
        padding: <?= $sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .section-inner {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .section-title {
        margin-bottom: 1.1rem;
        gap: 0.56rem;
    }

    #<?= $componentId ?> .section-title::before,
    #<?= $componentId ?> .section-title::after {
        max-width: 100px;
        min-width: 40px;
        height: 8px;
    }

    #<?= $componentId ?> .review-wall {
        display: none;
    }

    #<?= $componentId ?> .mobile-review-list {
        display: grid;
        gap: 0.72rem;
    }

    #<?= $componentId ?> .mobile-review-item {
        transform: none !important;
    }
}
</style>
