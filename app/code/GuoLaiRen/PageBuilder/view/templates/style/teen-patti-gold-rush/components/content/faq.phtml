}

$leftFaqs = [];
$rightFaqs = [];
foreach ($faqItems as $item) {
    if ($item['index'] % 2 === 0) {
        $leftFaqs[] = $item;
    } else {
        $rightFaqs[] = $item;
    }
}

$renderFaqItem = function (array $item, string $scope) use ($componentId, $firstOpen) {
    $index = (int)$item['index'];
    $isOpen = $firstOpen && $index === 0;
    $idKey = $scope . '-' . $index;
    ?>
    <article class="faq-slip<?= $isOpen ? ' is-open' : '' ?>" data-faq-item="<?= htmlspecialchars($idKey) ?>" role="listitem">
        <button
            class="faq-question"
            type="button"
            id="<?= $componentId ?>-trigger-<?= htmlspecialchars($idKey) ?>"
            data-faq-trigger="<?= htmlspecialchars($idKey) ?>"
            aria-controls="<?= $componentId ?>-panel-<?= htmlspecialchars($idKey) ?>"
            aria-expanded="<?= $isOpen ? 'true' : 'false' ?>"
        >
            <span class="faq-index"><?= sprintf('%02d', $index + 1) ?></span>
            <span class="faq-copy">
                <strong><?= htmlspecialchars($item['question']) ?></strong>
            </span>
            <span class="faq-icon" aria-hidden="true"></span>
        </button>

        <div class="faq-answer-wrap<?= $isOpen ? ' is-open' : '' ?>" data-faq-panel-wrap="<?= htmlspecialchars($idKey) ?>">
            <div
                class="faq-answer"
                id="<?= $componentId ?>-panel-<?= htmlspecialchars($idKey) ?>"
                data-faq-panel="<?= htmlspecialchars($idKey) ?>"
                role="region"
                aria-labelledby="<?= $componentId ?>-trigger-<?= htmlspecialchars($idKey) ?>"
                aria-hidden="<?= $isOpen ? 'false' : 'true' ?>"
            >
                <p><?= nl2br(htmlspecialchars($item['answer'])) ?></p>
