            {"text": "Home", "href": "#home", "type": "anchor"},
            {"text": "About", "href": "#about", "type": "anchor"},
            {"text": "Blog", "href": "#blog", "type": "anchor"},
            {"text": "FAQs", "href": "#faqs", "type": "anchor"}
        ]
