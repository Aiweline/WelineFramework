{
    "$schema": "2.1.0",
    "template": "teen-patti-gold-rush",
    "name": "Teen Patti Gold Rush",
    "description": "Teen Patti Gold Rush 高动效棋牌落地页模板组件库",
    "version": "2.1.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航、Logo等",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "games", "advantages", "testimonials", "faq"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含版权、链接等",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "导航头部（Logo居中）",
            "name_en": "Navigation Header (Logo Centered)",
            "description": "Logo居中布局，包含导航菜单和下载按钮",
            "region": "header",
            "category": "header",
            "type": "section",
            "thumbnail": "asset/img/logo-icon-128.avif",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "slots": {
                "logo": {
                    "name": "Logo 区域",
                    "accepts": ["header"],
                    "slot_type": "header-logo",
                    "max": 1
                },
                "nav-links": {
                    "name": "导航链接",
                    "accepts": ["header"],
                    "slot_type": "header-nav-link",
                    "max": 10
                },
                "actions": {
                    "name": "操作按钮",
                    "accepts": ["header"],
                    "slot_type": "header-action",
                    "max": 3
                }
            },
            "config_groups": ["header", "navigation", "download_button", "color_scheme", "pixel"],
            "file": "header/nav.phtml"
        },
        "header-simple": {
            "name": "简洁头部",
            "name_en": "Simple Header",
            "description": "只包含Logo的简洁头部",
            "region": "header",
            "category": "header",
            "type": "section",
            "thumbnail": "asset/img/logo-icon-128.avif",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "slots": {
                "logo": {
                    "name": "Logo 区域",
                    "accepts": ["header"],
                    "slot_type": "header-logo",
                    "max": 1
                }
            },
            "config_groups": ["header"],
            "file": "header/simple.phtml"
        },
        "header-dark": {
            "name": "深色头部",
            "name_en": "Dark Header",
            "description": "深色背景的现代头部，带渐变下载按钮",
            "region": "header",
            "category": "header",
            "type": "section",
            "thumbnail": "asset/img/logo-icon-128.avif",
            "sort_order": 3,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "slots": {
                "logo": {
                    "name": "Logo 区域",
                    "accepts": ["header"],
                    "slot_type": "header-logo",
                    "max": 1
                },
                "nav-links": {
                    "name": "导航链接",
                    "accepts": ["header"],
                    "slot_type": "header-nav-link",
                    "max": 10
                },
                "cta": {
                    "name": "CTA 按钮",
                    "accepts": ["header"],
                    "slot_type": "header-cta",
                    "max": 2
                }
            },
            "config_groups": ["header", "navigation", "button", "style"],
            "file": "header/dark.phtml"
        },
        "slider": {
            "name": "轮播横幅",
            "name_en": "Banner Slider",
            "description": "首屏轮播Banner，支持多图轮播和自动播放",
            "region": "content",
            "category": "content",
            "type": "section",
            "thumbnail": "asset/img/banner-03.webp",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "slides": {
                    "name": "幻灯片",
                    "accepts": ["content", "widget"],
                    "slot_type": "slider-slide",
                    "max": 10
                }
            },
            "config_groups": ["slider"],
            "file": "content/slider.phtml"
        },
        "banner": {
            "name": "Banner横幅",
            "name_en": "Banner",
            "description": "首屏Banner横幅，支持响应式图片和下载按钮",
            "region": "content",
            "category": "content",
            "type": "section",
            "thumbnail": "asset/img/banner-03.webp",
            "sort_order": 11,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner"],
            "file": "content/banner.phtml"
        },
        "hero-slider": {
            "name": "首屏轮播Banner",
            "name_en": "Hero Slider",
            "description": "首屏轮播Banner，与导航重叠效果，支持响应式图片和下载按钮",
            "region": "content",
            "category": "content",
            "type": "section",
            "thumbnail": "asset/img/banner-03.webp",
            "sort_order": 12,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "slides": {
                    "name": "幻灯片",
                    "accepts": ["content", "widget"],
                    "slot_type": "hero-slide",
                    "max": 10
                },
                "cta": {
                    "name": "CTA 按钮",
                    "accepts": ["content", "widget"],
                    "slot_type": "hero-cta",
                    "max": 2
                }
            },
            "config_groups": ["banner", "hero", "download_btn", "layout"],
            "file": "content/hero-slider.phtml",
            "config_schema": {
                "banner.display": {"type": "select", "options": ["yes", "no"], "default": "yes", "label": "显示Banner"},
                "banner.image_mobile": {"type": "textarea", "default": "", "label": "移动端Banner图片"},
                "banner.image_desktop": {"type": "textarea", "default": "", "label": "PC端Banner图片"},
                "banner.alt": {"type": "text", "default": "Teen Patti Gold Rush hero banner", "label": "图片描述"},
                "banner.bg_color": {"type": "color", "default": "#130a24", "label": "背景基础色"},
                "hero.display": {"type": "select", "options": ["yes", "no"], "default": "yes", "label": "显示Hero"},
                "hero.title": {"type": "text", "default": "Spotlight Tables. Fast Route Shifts.", "label": "主标题"},
                "hero.subtitle": {"type": "textarea", "default": "Jump between Classic, AK47, Joker, and private tables with a cleaner action path from lobby pick to show call.", "label": "副标题"},
                "hero.cta_text": {"type": "text", "default": "DOWNLOAD APP", "label": "主按钮文字"},
                "hero.cta_url": {"type": "text", "default": "#download", "label": "主按钮链接"},
                "hero.image": {"type": "textarea", "default": "", "label": "Hero桌面图"},
                "hero.image_mobile": {"type": "textarea", "default": "", "label": "Hero移动图"},
                "hero.alt": {"type": "text", "default": "Teen Patti Gold Rush hero banner", "label": "Hero图片描述"},
                "hero.bg_color": {"type": "color", "default": "#130a24", "label": "Hero背景色"},
                "download_btn.display": {"type": "select", "options": ["yes", "no"], "default": "yes", "label": "显示下载按钮"},
                "download_btn.image": {"type": "textarea", "default": "", "label": "下载按钮图片"},
                "download_btn.alt": {"type": "text", "default": "DOWNLOAD APP", "label": "下载按钮描述"},
                "download_btn.url": {"type": "text", "default": "#download", "label": "下载按钮链接"},
                "layout.slider_classes": {"type": "textarea", "default": "rs-slider slider-style2", "label": "CSS类名"},
                "layout.margin_top": {"type": "number", "default": -75, "label": "顶部负边距(移动端)"},
                "layout.img_margin_top": {"type": "number", "default": -16, "label": "图片偏移"}
            }
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages Section",
            "description": "展示产品/应用的核心优势，三列卡片布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "thumbnail": "asset/img/our-advantages/icon01.webp",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "items": {
                    "name": "优势项目",
                    "accepts": ["content", "widget"],
                    "slot_type": "advantage-item",
                    "max": 12
