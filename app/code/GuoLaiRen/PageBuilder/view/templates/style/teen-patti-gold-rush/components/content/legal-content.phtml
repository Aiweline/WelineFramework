<?php
/**
 * Teen Patti Gold Rush - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录、更新时间显示，继承主题配色
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:60|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:|留空使用页面标题
 * header.icon => 自定义图标:text:|如:🔒 📜 💰
 * header.bg_color => 背景色:color:#150b1d
 * header.bg_gradient_end => 渐变结束色:color:#4d1a5f
 * header.title_color => 标题颜色:color:#ff5ab6
 * header.text_color => 文字颜色:color:#f4deef
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Contents
 * toc.items => 章节列表:textarea:|当页面正文为空时使用，一行一节，格式：标题=>内容
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.05)
 * toc.border_color => 目录边框色:color:rgba(255,255,255,0.1)
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:|当页面正文为空时显示
 * content.empty_text => 空内容提示:text:Legal content will appear here.
 * content.bg_color => 内容区背景色:color:#160d22
 * content.text_color => 内容文字颜色:color:#f4deef
 * content.heading_color => 标题颜色:color:#ff5ab6
 * content.link_color => 链接颜色:color:#59d7ff
 *
 * group:header_meta => 头部辅助信息
 * header.updated_label => 更新时间标签:text:Updated
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$showToc = $getConfigAny(['display.show_toc'], 'yes') !== 'no';
$showLastUpdated = $getConfigAny(['display.show_last_updated'], 'yes') !== 'no';
$showIcon = $getConfigAny(['display.show_icon'], 'yes') !== 'no';

$contentWidth = $getConfigAny(['layout.content_width'], 'narrow');
$headerPadding = max(28, (int)$getConfigAny(['layout.header_padding'], '80'));
$contentPadding = max(20, (int)$getConfigAny(['layout.content_padding'], '60'));

$headerTitle = $getConfigAny(['header.title'], '');
$headerIcon = $getConfigAny(['header.icon'], '');
$headerBgColorConfig = $getConfigAny(['header.bg_color'], '');
$headerGradientEndConfig = $getConfigAny(['header.bg_gradient_end'], '');
$headerTitleColorConfig = $getConfigAny(['header.title_color'], '');
$headerTextColorConfig = $getConfigAny(['header.text_color'], '');
$updatedLabel = (string)$getConfigAny(['header.updated_label'], 'Updated');

$tocTitle = (string)$getConfigAny(['toc.title'], 'Contents');
$tocItemsConfig = (string)$getConfigAny(['toc.items'], '');
$tocBgColorConfig = $getConfigAny(['toc.bg_color'], '');
$tocBorderColorConfig = $getConfigAny(['toc.border_color'], '');

$contentBody = trim((string)$getConfigAny(['content.body'], ''));
$contentEmptyText = (string)$getConfigAny(['content.empty_text'], 'Legal content will appear here.');
$contentBgColorConfig = $getConfigAny(['content.bg_color'], '');
$contentTextColorConfig = $getConfigAny(['content.text_color'], '');
$contentHeadingColorConfig = $getConfigAny(['content.heading_color'], '');
$contentLinkColorConfig = $getConfigAny(['content.link_color'], '');

$page = $this->getData('page');
$pageTitle = $headerTitle ?: ($page ? ($page->getData('title') ?? '') : '');
$pageContent = $page ? ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';
$pageType = $page ? ($page->getData('type') ?? '') : '';

if ($pageContent === '') {
    $sections = [];
    foreach (preg_split('/\r?\n/', $tocItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }

        if (strpos($line, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $line, 2));
        } elseif (strpos($line, '|') !== false) {
            $parts = array_map('trim', explode('|', $line, 2));
        } else {
            $parts = [$line, ''];
        }

        if (($parts[0] ?? '') === '') {
            continue;
        }

        $sections[] = [
            'title' => $parts[0],
            'content' => $parts[1] ?? '',
        ];
    }

    if ($contentBody !== '' || !empty($sections)) {
        $pageContent = '';
        if ($contentBody !== '') {
            $pageContent .= '<p>' . nl2br(htmlspecialchars($contentBody)) . '</p>';
        }
        foreach ($sections as $section) {
            $pageContent .= '<h2>' . htmlspecialchars((string)$section['title']) . '</h2>';
            if ((string)$section['content'] !== '') {
                $pageContent .= '<p>' . nl2br(htmlspecialchars((string)$section['content'])) . '</p>';
            }
        }
    }
}

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $headerBgColorConfig ?: ($colors['hero_bg'] ?? '#150b1d');
$heroGradientEnd = $headerGradientEndConfig ?: ($colors['hero_bg_gradient_end'] ?? '#4d1a5f');
$sectionBg = $contentBgColorConfig ?: ($colors['section_bg_1'] ?? '#160d22');
$textPrimary = $colors['text_primary'] ?? '#fff0f8';
$textSecondary = $contentTextColorConfig ?: ($colors['text_secondary'] ?? '#f4deef');
$textMuted = $headerTextColorConfig ?: ($colors['text_muted'] ?? '#be9fc9');
$accentPrimary = $headerTitleColorConfig ?: ($colors['accent_primary'] ?? '#ff5ab6');
$accentSecondary = $colors['accent_secondary'] ?? '#59d7ff';
$accentAlt = $colors['accent_primary_vibrant'] ?? '#a9ff5e';
$cardBg = $tocBgColorConfig ?: ($colors['card_bg'] ?? 'rgba(255, 244, 250, 0.09)');
$borderLight = $tocBorderColorConfig ?: ($colors['border_light'] ?? 'rgba(255, 206, 236, 0.22)');
$contentHeadingColor = $contentHeadingColorConfig ?: $accentPrimary;
$contentLinkColor = $contentLinkColorConfig ?: $accentSecondary;

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$currentIcon = $headerIcon ?: ($typeIcons[$pageType] ?? '📄');

$maxWidth = match ($contentWidth) {
    'wide' => '1200px',
    'medium' => '1000px',
    default => '820px',
};

$tocItems = [];
if ($showToc && $pageContent !== '') {
    preg_match_all('/<h2[^>]*>(.*?)<\/h2>/i', $pageContent, $matches);
    if (!empty($matches[1])) {
        foreach ($matches[1] as $index => $heading) {
            $tocItems[] = [
                'id' => 'section-' . ($index + 1),
                'title' => trim(strip_tags((string)$heading)),
            ];
        }

        $headingCounter = 0;
        $pageContent = preg_replace_callback('/<h2([^>]*)>(.*?)<\/h2>/i', static function ($match) use (&$headingCounter) {
            $headingCounter++;
            return '<h2' . $match[1] . ' id="section-' . $headingCounter . '">' . $match[2] . '</h2>';
        }, $pageContent);
    }
}

$instanceId = $component_instance_id ?? 'legal-content-' . uniqid();
?>

<section id="<?= $instanceId ?>" class="tpmst-section gdr-legal-content">
    <div class="gdr-inner">
        <div class="gdr-shell">
            <header class="gdr-legal-head">
                <div class="gdr-title-wrap">
                    <p class="gdr-kicker">Legal Center</p>
                    <h1>
                        <?php if ($showIcon): ?>
                            <span class="gdr-icon"><?= htmlspecialchars((string)$currentIcon) ?></span>
                        <?php endif; ?>
                        <?= htmlspecialchars((string)$pageTitle) ?>
                    </h1>
                </div>
                <?php if ($showLastUpdated && $lastUpdated): ?>
                    <p class="gdr-updated">
                        <?= htmlspecialchars($updatedLabel) ?>:
                        <time datetime="<?= date('Y-m-d', strtotime((string)$lastUpdated)) ?>"><?= date('F j, Y', strtotime((string)$lastUpdated)) ?></time>
                    </p>
                <?php endif; ?>
            </header>

            <div class="gdr-legal-grid<?= empty($tocItems) ? ' no-toc' : '' ?>">
                <?php if (!empty($tocItems)): ?>
                    <aside class="gdr-toc" aria-label="<?= htmlspecialchars($tocTitle) ?>">
                        <div class="gdr-toc-inner">
                            <h2><?= htmlspecialchars((string)$tocTitle) ?></h2>
                            <ol>
                                <?php foreach ($tocItems as $item): ?>
                                    <li>
                                        <a href="#<?= htmlspecialchars((string)$item['id']) ?>">
                                            <?= htmlspecialchars((string)$item['title']) ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ol>
                        </div>
                    </aside>
                <?php endif; ?>

                <article class="gdr-article">
                    <div class="gdr-article-body">
                        <?php if ($pageContent !== ''): ?>
                            <?= $pageContent ?>
                        <?php else: ?>
                            <p><?= htmlspecialchars($contentEmptyText) ?></p>
                        <?php endif; ?>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

