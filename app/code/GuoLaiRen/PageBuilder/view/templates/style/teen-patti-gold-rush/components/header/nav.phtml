$componentId = 'oct-header-nav-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function(array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$parseResponsive = function($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim($parts[0] ?? ''),
        'desktop' => trim($parts[1] ?? ($parts[0] ?? '')),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = function($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$sanitizeTitle = static function($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/logo-icon-128.avif');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '70/70') . 'px'));
$logoHeightConfig = $getConfigAny(['logo.height', 'header.logo.height'], '');
$logoHeight = empty($logoHeightConfig) ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));
$brandName = $sanitizeTitle((string)$getConfigAny(['logo.text', 'header.logo.text'], $page ? ($page->getData('title') ?: '') : ''));
if ($brandName === '') {
    $brandName = 'Teen Patti Gold Rush';
}
$brandSubline = trim((string)$getConfigAny(['logo.subline', 'header.logo.subline'], ''));

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], '#120915');
$navBgColorScrolled = $getConfigAny(['navigation.bg_color_scrolled'], 'rgba(18, 10, 32, 0.96)');
$navTextColor = $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#fff0f8');
$linkColor = $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#f2dbec');
$linkHoverColor = $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#ff5ab6');
$linkFontSize = $getConfigAny(['navigation.link_font_size'], '14');
$linkFontWeight = $getConfigAny(['navigation.link_font_weight'], '600');
$linkGap = $getConfigAny(['navigation.link_gap'], '26');
$navPaddingX = $getConfigAny(['navigation.padding_x'], '24');
$navPaddingY = $getConfigAny(['navigation.padding_y'], '12');
$navMinHeight = $getConfigAny(['navigation.min_height'], '72');
$navBoxShadow = $getConfigAny(['navigation.box_shadow'], '0 10px 30px rgba(0,0,0,0.26)');
$navBackdropBlur = $getConfigAny(['navigation.backdrop_blur'], '14');
$useCustomLinksRaw = $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], '');
$legacyUseSubpages = $getConfigAny(['navigation.use_subpages'], '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($legacyUseSubpages, 'no') !== 'yes';

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(12)
        : $page->getNavigationPages([], 12);
    foreach ($navigationPages as $navPage) {
        $type = trim((string)($navPage['type'] ?? ''));
        $configuredLabel = $type !== '' ? trim((string)$getConfigAny([
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], '')) : '';
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}
if (empty($navItems)) {
    $navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $text = trim((string)($parts[0] ?? ''));
        $href = trim((string)($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }
        if ($href === '') {
            $href = '/' . strtolower(preg_replace('/[^a-zA-Z0-9]+/', '-', $text));
        }
        $navItems[] = ['text' => $text, 'href' => $href];
    }
}
if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

$normalizePath = function($path) {
    $path = trim((string)$path);
    if ($path === '') {
        return '/';
    }
    $path = '/' . ltrim($path, '/');
    if (strlen($path) > 1) {
        $path = rtrim($path, '/');
    }
    return $path;
};

$requestPath = '/';
if (!empty($_SERVER['REQUEST_URI'])) {
    $parsedRequestPath = parse_url((string)$_SERVER['REQUEST_URI'], PHP_URL_PATH);
    if (is_string($parsedRequestPath) && $parsedRequestPath !== '') {
        $requestPath = $parsedRequestPath;
    }
}
$currentPath = $normalizePath($requestPath);

$hasActiveNav = false;
foreach ($navItems as $navIndex => $navItem) {
    $href = isset($navItem['href']) ? (string)$navItem['href'] : '';
    $path = parse_url($href, PHP_URL_PATH);
    $targetPath = is_string($path) && $path !== '' ? $normalizePath($path) : '';
    $isAnchor = strpos($href, '#') === 0;
    $isActive = !$isAnchor && $targetPath !== '' && $targetPath === $currentPath;
    $navItems[$navIndex]['is_active'] = $isActive;
    if ($isActive) {
        $hasActiveNav = true;
    }
}

if (!$hasActiveNav && !empty($navItems)) {
    $navItems[0]['is_active'] = true;
}

$downloadBtnDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
