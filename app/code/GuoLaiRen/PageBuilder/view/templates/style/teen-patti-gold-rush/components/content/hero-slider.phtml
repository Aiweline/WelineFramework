/**
 * Teen Patti Gold Rush - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: 首屏Hero
 * name_en: Hero Slider
 * description: 首屏Hero展示，兼容tpmst的Banner配置读取
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.webp
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置（TPMST兼容）
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用本地banner-2.jpg
 * banner.image_desktop => PC端Banner图片:textarea:|默认使用本地banner-03.webp
 * banner.alt => Banner图片描述:text:Teen Patti Gold Rush hero banner
 * banner.bg_color => Banner背景基础色:color:#130a24
 *
 * group:hero => Hero设置
 * hero.display => 显示Hero:select:yes|yes,no
 * hero.title => 主标题:text:Spotlight Tables. Fast Route Shifts.
 * hero.subtitle => 副标题:textarea:Jump between Classic, AK47, Joker, and private tables with a cleaner action path from lobby pick to show call.
 * hero.cta_text => 主按钮文字:text:DOWNLOAD APP
 * hero.cta_url => 主按钮链接:text:#download
 * hero.image => Hero桌面端图片:textarea:|留空使用Banner桌面图
 * hero.image_mobile => Hero移动端图片:textarea:|留空使用Banner移动图
 * hero.alt => Hero图片描述:text:Teen Patti Gold Rush hero banner
 * hero.bg_color => Hero背景基础色:color:#130a24
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:|默认使用本地download-btn-m.webp
 * download_btn.alt => 下载按钮描述:text:DOWNLOAD APP
 * download_btn.url => 下载按钮链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域附加类名:textarea:rs-slider slider-style2|额外附加类名
 * layout.margin_top => 顶部负边距:number:-75|px
 * layout.img_margin_top => 图片偏移:number:-16|px
 *
 * @fields_end
 */

$page = $this->getData('page') ?? $page ?? null;
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$normalizeSwitch = static function ($value, $default = 'yes') {
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }

    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);

    return trim($value);
};

$buildRouteChips = static function (array $values) {
    $tokens = [];
    $stopWords = [
        'teen', 'patti', 'gold', 'rush', 'with', 'and', 'from', 'into', 'your', 'that',
        'this', 'jump', 'between', 'private', 'table', 'tables', 'route', 'routes', 'hero',
    ];

    foreach ($values as $value) {
        $parts = preg_split('/\s+/', preg_replace('/[^a-z0-9]+/i', ' ', strtolower((string) $value))) ?: [];
        foreach ($parts as $part) {
            $part = trim((string) $part);
            if ($part === '' || in_array($part, $stopWords, true) || strlen($part) < 3) {
                continue;
            }
            $tokens[] = ucfirst($part);
        }
    }

    $tokens = array_values(array_unique($tokens));
    if (count($tokens) < 3) {
        return ['Classic', 'AK47', 'Joker'];
    }

    return array_slice($tokens, 0, 3);
};

$heroDisplay = $normalizeSwitch($getConfigAny(['hero.display', 'banner.display'], 'yes'), 'yes');
if ($heroDisplay !== 'yes') {
    return;
}

$pageTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Teen Patti Gold Rush';
$pageTitle = $sanitizeTitle($pageTitle);
if ($pageTitle === '') {
    $pageTitle = 'Teen Patti Gold Rush';
}

$heroTitle = $sanitizeTitle((string) $getConfigAny(['hero.title'], $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'Spotlight Tables. Fast Route Shifts.';
}

$heroSubtitle = trim((string) $getConfigAny(['hero.subtitle'], $page ? (string) ($page->getData('meta_description') ?: '') : ''));
if ($heroSubtitle === '') {
    $heroSubtitle = 'Jump between Classic, AK47, Joker, and private tables with a cleaner action path from lobby pick to show call.';
}

$brandName = $sanitizeTitle((string) $getConfigAny(['logo.text', 'header.logo.text'], $pageTitle));
if ($brandName === '') {
    $brandName = 'Teen Patti Gold Rush';
}

$heroAlt = trim((string) $getConfigAny(['hero.alt', 'banner.alt'], ''));
if ($heroAlt === '') {
    $heroAlt = $heroTitle;
}

$bannerBgColor = (string) $getConfigAny(['hero.bg_color', 'banner.bg_color'], '#130a24');

$downloadDisplay = $normalizeSwitch($getConfigAny(['download_btn.display'], 'yes'), 'yes') === 'yes';
$downloadBtnText = trim((string) $getConfigAny(['hero.cta_text', 'download_btn.alt'], 'DOWNLOAD APP'));
if ($downloadBtnText === '') {
    $downloadBtnText = 'DOWNLOAD APP';
}
$downloadBtnUrl = (string) $getConfigAny(['hero.cta_url', 'download_btn.url'], '#download');

$sliderClasses = (string) $getConfigAny(['layout.slider_classes'], 'rs-slider slider-style2');
$marginTop = (int) $getConfigAny(['layout.margin_top'], -75);
$imgMarginTop = (int) $getConfigAny(['layout.img_margin_top'], -16);

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/download-btn-m.webp');

$bannerImageMobile = trim((string) $getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$bannerImageDesktop = trim((string) $getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$downloadBtnImage = trim((string) $getConfigAny(['download_btn.image'], ''));

$finalBannerMobile = $bannerImageMobile !== '' ? $bannerImageMobile : (string) $defaultBannerMobile;
$finalBannerDesktop = $bannerImageDesktop !== '' ? $bannerImageDesktop : (string) $defaultBannerDesktop;
$finalDownloadBtn = $downloadBtnImage !== '' ? $downloadBtnImage : (string) $defaultDownloadBtn;

$instanceId = 'gr-hero-slider-' . uniqid();
$routeChips = $buildRouteChips([$heroTitle, $heroSubtitle, $brandName]);
?>

