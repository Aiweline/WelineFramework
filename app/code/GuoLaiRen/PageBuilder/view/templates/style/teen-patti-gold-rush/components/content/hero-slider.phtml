                    </picture>

                    <?php if ($downloadDisplay && $finalDownloadBtn !== ''): ?>
                        <div class="stage-download-mask">
                            <a class="hero-download" href="<?= htmlspecialchars($downloadBtnUrl) ?>" aria-label="<?= htmlspecialchars($downloadBtnText) ?>">
                                <img src="<?= htmlspecialchars($finalDownloadBtn) ?>" alt="<?= htmlspecialchars($downloadBtnText) ?>" loading="eager" decoding="async" width="220" height="58">
