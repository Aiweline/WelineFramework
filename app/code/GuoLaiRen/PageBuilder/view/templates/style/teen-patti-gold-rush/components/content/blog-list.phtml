<?php
/**
 * Teen Patti Gold Rush - Blog List Component
 *
 * @fields_start
 * blog.title|Blog list title|text|Latest Teen Patti Gold Rush Updates
 * blog.subtitle|Subtitle|text|Tips, patch notes, and strategy breakdowns from the Gold Rush desk
 * blog.posts_per_page|Posts per page|number|9
 * blog.show_sidebar|Show sidebar|select:yes=Yes,no=No|yes
 * blog.show_category|Show category|select:yes=Yes,no=No|yes
 * blog.show_date|Show date|select:yes=Yes,no=No|yes
 * blog.show_author|Show author|select:yes=Yes,no=No|yes
 * blog.card_style|Card style|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', __('Latest Teen Patti Gold Rush Updates'));
$subtitle = $getConfig('blog.subtitle', __('Tips, patch notes, and strategy breakdowns from the Gold Rush desk'));
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#ff5ab6');
$secondaryColor = $getConfig('color_scheme.secondary', '#59d7ff');
$bgColor = $getConfig('color_scheme.background', '#12081a');
$textColor = $getConfig('color_scheme.text', '#fff0f8');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $posts[0] ?? null;
$listPosts = array_slice($posts, 1);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};

$excerptText = static function ($text, $limit = 160) {
    $text = trim((string)$text);
    if ($text === '') {
        return '';
    }
    return mb_strlen($text) > $limit ? mb_substr($text, 0, $limit) . '...' : $text;
};
?>

<section class="tpmst-section gdr-blog-list" id="blog">
    <div class="gdr-inner">
        <header class="gdr-blog-head">
            <p class="gdr-kicker">Gold Rush Journal</p>
            <h2><?= htmlspecialchars((string)$title) ?></h2>
            <?php if ($subtitle): ?>
                <p class="gdr-subtitle"><?= htmlspecialchars((string)$subtitle) ?></p>
            <?php endif; ?>
        </header>

        <div class="gdr-layout<?= $showSidebar ? ' with-sidebar' : ' full' ?> style-<?= htmlspecialchars((string)$cardStyle) ?>">
            <main class="gdr-main" aria-label="Blog posts">
                <?php if (empty($posts)): ?>
                    <article class="gdr-empty">
                        <h3><?= __('No posts yet') ?></h3>
                        <p><?= __('Fresh Teen Patti Gold Rush updates will appear here soon.') ?></p>
                    </article>
                <?php else: ?>
                    <?php if ($featuredPost): ?>
                        <?php
                        $featuredUrl = $featuredPost['url'] ?? '#';
                        $featuredTitle = $featuredPost['title'] ?? __('Untitled Post');
                        $featuredSummary = $featuredPost['summary'] ?? '';
                        $featuredCategory = $featuredPost['category_name'] ?? '';
                        $featuredDate = $formatDate($featuredPost['published_at'] ?? '');
                        $featuredAuthor = $featuredPost['author'] ?? '';
                        $featuredImage = $featuredPost['cover_image'] ?? '';
                        ?>
                        <article class="gdr-featured-card">
                            <?php if ($featuredImage): ?>
                                <a href="<?= htmlspecialchars((string)$featuredUrl) ?>" class="gdr-featured-media">
                                    <img src="<?= htmlspecialchars((string)$featuredImage) ?>" alt="<?= htmlspecialchars((string)$featuredTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>

                            <div class="gdr-featured-body">
                                <div class="gdr-meta">
                                    <?php if ($showCategory && $featuredCategory): ?>
                                        <span class="gdr-chip"><?= htmlspecialchars((string)$featuredCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $featuredDate): ?>
                                        <time><?= htmlspecialchars((string)$featuredDate) ?></time>
                                    <?php endif; ?>
                                </div>

                                <h3><a href="<?= htmlspecialchars((string)$featuredUrl) ?>"><?= htmlspecialchars((string)$featuredTitle) ?></a></h3>

                                <?php if ($cardStyle !== 'minimal'): ?>
                                    <?php $summary = $excerptText($featuredSummary, 220); ?>
                                    <?php if ($summary !== ''): ?>
                                        <p class="gdr-summary"><?= htmlspecialchars((string)$summary) ?></p>
                                    <?php endif; ?>
                                <?php endif; ?>

                                <div class="gdr-footer-row">
                                    <?php if ($showAuthor && $featuredAuthor): ?>
                                        <span class="gdr-author"><?= htmlspecialchars((string)$featuredAuthor) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars((string)$featuredUrl) ?>" class="gdr-read-link"><?= __('Read Story') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($listPosts)): ?>
                        <div class="gdr-grid-cards">
                            <?php foreach ($listPosts as $index => $post): ?>
                                <?php
                                $postUrl = $post['url'] ?? '#';
                                $postTitle = $post['title'] ?? __('Untitled Post');
                                $postSummary = $post['summary'] ?? '';
                                $postCategory = $post['category_name'] ?? '';
                                $postDate = $formatDate($post['published_at'] ?? '');
                                $postAuthor = $post['author'] ?? '';
                                $postImage = $post['cover_image'] ?? '';
                                $lane = 'lane-' . (($index % 3) + 1);
                                ?>
                                <article class="gdr-card <?= htmlspecialchars((string)$lane) ?><?= $cardStyle === 'featured' && $index < 2 ? ' boost' : '' ?>">
                                    <?php if ($cardStyle !== 'minimal' && $postImage): ?>
                                        <a href="<?= htmlspecialchars((string)$postUrl) ?>" class="gdr-card-media">
                                            <img src="<?= htmlspecialchars((string)$postImage) ?>" alt="<?= htmlspecialchars((string)$postTitle) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>

                                    <div class="gdr-card-body">
                                        <div class="gdr-meta">
                                            <?php if ($showCategory && $postCategory): ?>
                                                <span class="gdr-chip"><?= htmlspecialchars((string)$postCategory) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && $postDate): ?>
                                                <time><?= htmlspecialchars((string)$postDate) ?></time>
                                            <?php endif; ?>
                                        </div>

                                        <h3><a href="<?= htmlspecialchars((string)$postUrl) ?>"><?= htmlspecialchars((string)$postTitle) ?></a></h3>

                                        <?php if ($cardStyle !== 'minimal'): ?>
                                            <?php $summary = $excerptText($postSummary, 145); ?>
                                            <?php if ($summary !== ''): ?>
                                                <p class="gdr-summary"><?= htmlspecialchars((string)$summary) ?></p>
                                            <?php endif; ?>
                                        <?php endif; ?>

                                        <div class="gdr-footer-row">
                                            <?php if ($showAuthor && $postAuthor): ?>
                                                <span class="gdr-author"><?= htmlspecialchars((string)$postAuthor) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars((string)$postUrl) ?>" class="gdr-read-link"><?= __('Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </main>

            <?php if ($showSidebar): ?>
                <aside class="gdr-sidebar">
                    <?php if (!empty($blogCategories)): ?>
                        <section class="gdr-side-card">
                            <h4><?= __('Categories') ?></h4>
                            <ul>
                                <?php foreach ($blogCategories as $category): ?>
                                    <?php
                                    $name = $category['name'] ?? '';
                                    $url = $category['url'] ?? '#';
                                    if ($name === '') {
                                        continue;
                                    }
                                    ?>
                                    <li><a href="<?= htmlspecialchars((string)$url) ?>"><?= htmlspecialchars((string)$name) ?></a></li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($recent)): ?>
                        <section class="gdr-side-card">
                            <h4><?= __('Recent Posts') ?></h4>
                            <ul class="gdr-recent-list">
                                <?php foreach ($recent as $post): ?>
                                    <?php
                                    $postUrl = $post['url'] ?? '#';
                                    $postTitle = $post['title'] ?? __('Untitled Post');
                                    $postDate = $formatDate($post['published_at'] ?? '');
                                    ?>
                                    <li>
                                        <a href="<?= htmlspecialchars((string)$postUrl) ?>">
                                            <span><?= htmlspecialchars((string)$postTitle) ?></span>
                                            <?php if ($postDate): ?>
                                                <em><?= htmlspecialchars((string)$postDate) ?></em>
                                            <?php endif; ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>
        </div>
    </div>
</section>

