}

@media (max-width: 980px) {
    #<?= $componentId ?> {
        padding: <?= (int)$sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .section-inner {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .games-grid {
