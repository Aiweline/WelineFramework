<?php
/**
 * Teen Patti Gold Rush - Games Component
 *
 * @component_start
 * code: games
 * name: 游戏介绍
 * name_en: Games Showcase
 * description: 游戏/产品介绍卡片，支持图片和描述
 * category: content
 * region: content
 * thumbnail: asset/img/game/game-i1.webp
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示卡片描述:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景基础色:color:#260f22
 * style.title_color => 标题颜色:color:#fff4d4
 * style.title_font_size => 标题字号(PC端):number:36|px
 * style.title_font_size_mobile => 标题字号(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.09)
 * style.card_border_radius => 卡片圆角:number:16|px
 * style.card_border_color => 卡片边框颜色:color:rgba(255,218,240,0.24)
 * style.card_title_color => 卡片标题颜色:color:#fff2db
 * style.card_title_font_size => 卡片标题字号:number:20|px
 * style.card_desc_color => 卡片描述颜色:color:#f4deff
 * style.card_desc_font_size => 卡片描述字号:number:14|px
 * style.section_padding => 区域内边距(PC端):number:68|px
 * style.section_padding_mobile => 区域内边距(移动端):number:42|px
 * style.card_gap => 卡片间距:number:24|px
 * style.card_content_padding => 卡片内容内边距:number:22|px
 * style.hover_transform => 悬停位移:number:5|px
 *
 * group:images => 图片配置
 * images.image_1_desktop => 游戏1桌面端图片:textarea:|默认使用本地图片
 * images.image_1_mobile => 游戏1移动端图片:textarea:|默认使用本地图片
 * images.image_2 => 游戏2图片:textarea:|默认使用本地图片
 * images.image_3 => 游戏3图片:textarea:|默认使用本地图片
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Multiples Game
 * texts.summary => 区域辅助文案:text:Three quick lanes covering Teen Patti, Rummy, and Slots.
 * texts.game_1_title => 游戏1标题:text:Teen Patti Classic
 * texts.game_1_desc => 游戏1描述:textarea:Core Teen Patti table flow with rapid room entry and stable rounds.
 * texts.game_2_title => 游戏2标题:text:Rummy Turbo
 * texts.game_2_desc => 游戏2描述:textarea:Sequence-focused matches with cleaner score rhythm and fast rematch entry.
 * texts.game_3_title => 游戏3标题:text:Slot Sprint
 * texts.game_3_desc => 游戏3描述:textarea:Short spin sessions designed for fast breaks between card tables.
 *
 * @fields_end
 */

$componentId = 'gr-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getCardValue = function ($index, array $keys, $default = '') use ($getConfigAny) {
    $prefixedKeys = [];
    foreach ($keys as $key) {
        $prefixedKeys[] = 'game_' . $index . '.' . $key;
        $prefixedKeys[] = $key;
    }
    return $getConfigAny($prefixedKeys, $default);
};

$joinLabels = static function (array $items) {
    $items = array_values(array_filter(array_map('trim', $items), static function ($item) {
        return $item !== '';
    }));
    $count = count($items);
    if ($count === 0) {
        return '';
    }
    if ($count === 1) {
        return $items[0];
    }
    if ($count === 2) {
        return $items[0] . ' and ' . $items[1];
    }

    $last = array_pop($items);
    return implode(', ', $items) . ', and ' . $last;
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$display = $getConfigAny(['display.show_section', 'games.display'], 'yes') !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfigAny(['display.show_title'], 'yes') !== 'no';
$showDescription = $getConfigAny(['display.show_description'], 'yes') !== 'no';

$bgColor = $getConfigAny(['style.bg_color', 'games.bg_color'], '#260f22');
$titleColor = $getConfigAny(['style.title_color'], '#fff4d4');
$titleFontSize = (int)$getConfigAny(['style.title_font_size'], '36');
$titleFontSizeMobile = (int)$getConfigAny(['style.title_font_size_mobile'], '24');
$cardBgColor = $getConfigAny(['style.card_bg_color'], 'rgba(255,255,255,0.09)');
$cardBorderRadius = (int)$getConfigAny(['style.card_border_radius'], '16');
$cardBorderColor = $getConfigAny(['style.card_border_color'], 'rgba(255,218,240,0.24)');
$cardTitleColor = $getConfigAny(['style.card_title_color'], '#fff2db');
$cardTitleFontSize = (int)$getConfigAny(['style.card_title_font_size'], '20');
$cardDescColor = $getConfigAny(['style.card_desc_color'], '#f4deff');
$cardDescFontSize = (int)$getConfigAny(['style.card_desc_font_size'], '14');
$sectionPadding = (int)$getConfigAny(['style.section_padding'], '68');
$sectionPaddingMobile = (int)$getConfigAny(['style.section_padding_mobile'], '42');
$cardGap = (int)$getConfigAny(['style.card_gap'], '24');
$cardContentPadding = (int)$getConfigAny(['style.card_content_padding'], '22');
$hoverTransform = (int)$getConfigAny(['style.hover_transform'], '5');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/game/game-i1.webp');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/game/game-i1-m.webp');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/game/game-i2.webp');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-gold-rush/asset/img/game/game-i3.webp');

$image1Desktop = $getCardValue(1, ['images.image_1_desktop', 'games.image_1_desktop'], '') ?: $defaultImage1Desktop;
$image1Mobile = $getCardValue(1, ['images.image_1_mobile', 'games.image_1_mobile'], '') ?: $defaultImage1Mobile;
$image2 = $getCardValue(2, ['images.image_2', 'games.image_2'], '') ?: $defaultImage2;
$image3 = $getCardValue(3, ['images.image_3', 'games.image_3'], '') ?: $defaultImage3;

$title = $getConfigAny(['texts.title', 'games.title', 'texts.games_title'], 'Multiples Game');
$title1 = $getCardValue(1, ['texts.game_1_title', 'texts.game_teen_patti_speed'], 'Teen Patti Classic');
$desc1 = $getCardValue(1, ['texts.game_1_desc', 'texts.game_teen_patti_speed_desc'], 'Core Teen Patti table flow with rapid room entry and stable rounds.');
$title2 = $getCardValue(2, ['texts.game_2_title', 'texts.game_rummy_master'], 'Rummy Turbo');
$desc2 = $getCardValue(2, ['texts.game_2_desc', 'texts.game_rummy_master_desc'], 'Sequence-focused matches with cleaner score rhythm and fast rematch entry.');
$title3 = $getCardValue(3, ['texts.game_3_title', 'texts.game_slots_meta'], 'Slot Sprint');
$desc3 = $getCardValue(3, ['texts.game_3_desc', 'texts.game_slots_meta_desc'], 'Short spin sessions designed for fast breaks between card tables.');
$brandName = $sanitizeTitle((string)$getConfigAny(['logo.text', 'header.logo.text'], $page ? ($page->getData('title') ?: '') : ''));
if ($brandName === '') {
    $brandName = 'Teen Patti Gold Rush';
}

$games = [
    [
        'title' => $title1,
        'desc' => $desc1,
        'desktop' => $image1Desktop,
        'mobile' => $image1Mobile,
        'label' => '01',
    ],
    [
        'title' => $title2,
        'desc' => $desc2,
        'desktop' => $image2,
        'mobile' => $image2,
        'label' => '02',
    ],
    [
        'title' => $title3,
        'desc' => $desc3,
        'desktop' => $image3,
        'mobile' => $image3,
        'label' => '03',
    ],
];
$gameTitles = array_values(array_filter(array_map(static function ($game) {
    return trim((string)($game['title'] ?? ''));
}, $games), static function ($item) {
    return $item !== '';
}));
$defaultSummary = 'Three quick lanes covering ' . $joinLabels(array_slice($gameTitles, 0, 3)) . '.';
$summary = trim((string)$getConfigAny(['texts.summary', 'texts.games_summary'], $defaultSummary));

$sectionLabelAttr = $showTitle ? ' aria-labelledby="' . $componentId . '-title"' : '';
?>

<section id="<?= $componentId ?>" class="gr-games"<?= $sectionLabelAttr ?>>
    <div class="section-inner">
        <?php if ($showTitle): ?>
            <header class="games-head">
                <span class="games-kicker"><?= htmlspecialchars($brandName) ?></span>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php if ($summary !== ''): ?>
                    <p class="games-summary"><?= htmlspecialchars($summary) ?></p>
                <?php endif; ?>
            </header>
        <?php endif; ?>

        <div class="games-grid" style="--game-gap: <?= (int)$cardGap ?>px; --game-radius: <?= (int)$cardBorderRadius ?>px; --hover-offset: <?= (int)$hoverTransform ?>px;">
            <?php foreach ($games as $game): ?>
                <article class="game-card">
                    <span class="game-label"><?= htmlspecialchars($game['label']) ?></span>
                    <div class="game-media">
                        <picture>
                            <?php if (!empty($game['mobile'])): ?>
                                <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile']) ?>">
                            <?php endif; ?>
                            <?php if (!empty($game['desktop'])): ?>
                                <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($game['desktop']) ?>">
                            <?php endif; ?>
                            <img src="<?= htmlspecialchars($game['desktop'] ?: $game['mobile']) ?>" alt="<?= htmlspecialchars($game['title']) ?>" loading="lazy" decoding="async">
                        </picture>
                    </div>
                    <div class="game-content">
                        <h3><?= htmlspecialchars($game['title']) ?></h3>
                        <?php if ($showDescription): ?>
                            <p><?= htmlspecialchars($game['desc']) ?></p>
                        <?php endif; ?>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>

        <div class="games-stack-mobile">
            <?php foreach ($games as $game): ?>
                <article class="mobile-game-card">
                    <span class="game-label"><?= htmlspecialchars($game['label']) ?></span>
                    <div class="game-media game-media-mobile">
                        <picture>
                            <?php if (!empty($game['mobile'])): ?>
                                <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile']) ?>">
                            <?php endif; ?>
                            <?php if (!empty($game['desktop'])): ?>
                                <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($game['desktop']) ?>">
                            <?php endif; ?>
                            <img src="<?= htmlspecialchars($game['desktop'] ?: $game['mobile']) ?>" alt="<?= htmlspecialchars($game['title']) ?>" loading="lazy" decoding="async">
                        </picture>
                    </div>
                    <div class="game-content">
                        <h3><?= htmlspecialchars($game['title']) ?></h3>
                        <?php if ($showDescription): ?>
                            <p><?= htmlspecialchars($game['desc']) ?></p>
                        <?php endif; ?>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

<style>
