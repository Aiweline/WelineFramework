<?php
/**
 * Andar Bahar Breeze Slider Component
 *
 * @component_start
 * code: slider
 * name: 轮播横幅
 * name_en: Banner Slider
 * description: 首屏轮播Banner，支持多图轮播和自动播放
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.svg
 * @component_end
 *
 * @fields_start
 *
 * group:slider => 轮播设置
 * slider.display => 显示轮播:select:yes|yes,no
 * slider.autoplay => 自动播放:select:yes|yes,no
 * slider.autoplay_interval => 播放间隔:number:5000|毫秒
 * slider.bg_color => 背景颜色:color:#f7fffc
 * slider.banner_image_mobile => 移动端图片:textarea:|默认使用本地banner-2.svg
 * slider.banner_image_desktop => PC端图片:textarea:|默认使用本地banner-03.svg
 * slider.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn.svg
 * slider.alt => 图片描述:text:Andar Bahar Breeze banner
 *
 * @fields_end
 */

$componentId = 'dts-slider-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$sliderDisplay = $getConfig('slider.display', 'yes') !== 'no';
if (!$sliderDisplay) {
    return;
}

$sliderAutoplay = $getConfig('slider.autoplay', 'yes') !== 'no';
$sliderInterval = max(2200, intval($getConfig('slider.autoplay_interval', '5000')));
$sliderBgColor = $getConfig('slider.bg_color', '#f7fffc');
$sliderBgGradientEnd = '#ffe7cf';
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/poker-header-bg.svg');

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/banner-2.svg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/banner-03.svg');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/download-btn.svg');

$bannerMobile = $getConfig('slider.banner_image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('slider.banner_image_desktop', '') ?: $defaultBannerDesktop;
$downloadBtnImg = $getConfig('slider.download_btn_image', '') ?: $defaultDownloadBtn;
$bannerAlt = $getConfig('slider.alt', 'Andar Bahar Breeze banner');
$autoplayClass = $sliderAutoplay ? 'is-autoplay' : '';
?>

<section id="<?= $componentId ?>" class="dts-slider-stage <?= $autoplayClass ?>">
    <div class="slider-shell">
        <div class="signal-stack signal-stack-left" aria-hidden="true">
            <span>Live Tables</span>
            <span>Fast Match</span>
        </div>

        <div class="slider-frame">
            <div class="frame-head">
                <span class="frame-chip">Broadcast Deck</span>
                <span class="frame-chip muted">Mobile + Desktop</span>
            </div>

            <div class="frame-screen">
                <picture>
                    <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerMobile) ?>">
                    <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerDesktop) ?>">
                    <img class="slider-image"
                         src="<?= htmlspecialchars($bannerMobile) ?>"
                         alt="<?= htmlspecialchars($bannerAlt) ?>"
                         fetchpriority="high"
                         decoding="async">
                </picture>
            </div>

            <?php if ($downloadBtnImg): ?>
                <div class="download-dock" aria-label="Download app">
                    <img src="<?= htmlspecialchars($downloadBtnImg) ?>"
                         alt="DOWNLOAD APP"
                         width="210"
                         height="54">
                </div>
            <?php endif; ?>
        </div>

        <div class="signal-stack signal-stack-right" aria-hidden="true">
            <span>Precision Bid</span>
            <span>Ranked Ready</span>
        </div>
    </div>
</section>

