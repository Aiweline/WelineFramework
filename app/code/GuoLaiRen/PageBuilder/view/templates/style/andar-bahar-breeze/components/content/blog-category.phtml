<?php
/**
 * Andar Bahar Breeze Blog Category Component
 *
 * @fields_start
 * blog.title|分类标题|text|Category Posts
 * blog.subtitle|副标题|text|Browse articles by category
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=特色|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$componentId = 'abb-blog-category-' . uniqid();

$getConfig = function($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? __('Category Posts'));
$subtitle = $getConfig('blog.subtitle', __('Browse articles by category'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#59c7bf');
$secondaryColor = $getConfig('color_scheme.secondary', '#8dc9ff');
$bgColor = $getConfig('color_scheme.background', '#f7fffc');
$textColor = $getConfig('color_scheme.text', '#21444b');
$patternBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/poker-header-bg.svg');

$leadPost = $blogPosts[0] ?? null;
$trailPosts = array_slice($blogPosts, 1);
$postCount = count($blogPosts);
$activeCategoryName = $currentCategory['name'] ?? __('Breeze Journal');
$categoryInitial = mb_strtoupper(mb_substr((string)$activeCategoryName, 0, 1));
$trailClass = 'trail-' . preg_replace('/[^a-z0-9-]+/i', '', (string)$cardStyle);
?>

<section id="<?= $componentId ?>" class="abb-blog-category">
    <div class="category-shell">
        <header class="category-banner">
            <div class="banner-copy">
                <?php if (!empty($currentCategory['name'])): ?>
                    <span class="banner-chip"><?= htmlspecialchars($currentCategory['name']) ?></span>
                <?php endif; ?>
                <h2><?= htmlspecialchars($title) ?></h2>
                <?php if ($subtitle): ?>
                    <p class="banner-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
                <?php if (!empty($currentCategory['description'])): ?>
                    <p class="banner-description"><?= htmlspecialchars($currentCategory['description']) ?></p>
                <?php endif; ?>
            </div>

            <div class="banner-meter" aria-hidden="true">
                <div class="meter-mark"><?= htmlspecialchars($categoryInitial) ?></div>
                <div class="meter-copy">
                    <strong><?= (int)$postCount ?></strong>
                    <span><?= __('Posts in this lane') ?></span>
                    <small><?= __('Guides, room updates, payment notes, and match-day reads collected under one category.') ?></small>
                </div>
            </div>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="category-empty">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <p><?= __('No posts are available in this category yet. Please check back soon.') ?></p>
                <a href="/blog" class="back-link"><?= __('Back to blog list') ?></a>
            </div>
        <?php else: ?>
            <?php if ($leadPost): ?>
                <article class="lead-stage">
                    <div class="lead-track"></div>
                    <div class="lead-copy">
                        <div class="lead-meta">
                            <span class="lead-kicker"><?= __('Category Lead') ?></span>
                            <?php if ($showCategory && !empty($leadPost['category_name'])): ?>
                                <span class="lead-pill"><?= htmlspecialchars($leadPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($leadPost['published_at'])): ?>
                                <span class="lead-date"><?= date('M d, Y', strtotime($leadPost['published_at'])) ?></span>
                            <?php endif; ?>
                        </div>

                        <h3>
                            <a href="<?= htmlspecialchars($leadPost['url']) ?>"><?= htmlspecialchars($leadPost['title']) ?></a>
                        </h3>

                        <?php if (!empty($leadPost['summary'])): ?>
                            <p class="lead-summary"><?= htmlspecialchars(mb_substr($leadPost['summary'], 0, 220)) ?><?= mb_strlen($leadPost['summary']) > 220 ? '...' : '' ?></p>
                        <?php endif; ?>

                        <div class="lead-foot">
                            <?php if ($showAuthor && !empty($leadPost['author'])): ?>
                                <span class="lead-author"><?= htmlspecialchars($leadPost['author']) ?></span>
                            <?php endif; ?>
                            <a href="<?= htmlspecialchars($leadPost['url']) ?>" class="story-action">
                                <?= __('Read Article') ?>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                </svg>
                            </a>
                        </div>
                    </div>

                    <?php if (!empty($leadPost['cover_image'])): ?>
                        <a href="<?= htmlspecialchars($leadPost['url']) ?>" class="lead-media">
                            <img src="<?= htmlspecialchars($leadPost['cover_image']) ?>" alt="<?= htmlspecialchars($leadPost['title']) ?>" loading="lazy">
                        </a>
                    <?php endif; ?>
                </article>
            <?php endif; ?>

            <div class="category-layout<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="story-trail <?= htmlspecialchars($trailClass) ?>">
                    <?php foreach ($trailPosts as $index => $post): ?>
                        <article class="trail-card<?= $cardStyle === 'featured' && $index === 0 ? ' is-expanded' : '' ?>">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="trail-media">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>

                            <div class="trail-copy">
                                <div class="trail-meta">
                                    <?php if ($showCategory && !empty($post['category_name'])): ?>
                                        <span class="trail-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($post['published_at'])): ?>
                                        <span class="trail-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h3>
                                    <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a>
                                </h3>

                                <?php if (!empty($post['summary'])): ?>
                                    <p class="trail-summary"><?= htmlspecialchars(mb_substr($post['summary'], 0, 160)) ?><?= mb_strlen($post['summary']) > 160 ? '...' : '' ?></p>
                                <?php endif; ?>

                                <div class="trail-foot">
                                    <?php if ($showAuthor && !empty($post['author'])): ?>
                                        <span class="trail-author"><?= htmlspecialchars($post['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($post['url']) ?>" class="story-action">
