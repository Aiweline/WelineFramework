$summary = $getConfig('texts.summary', 'Swipe through player notes to see what stands out first in this Andar Bahar landing page: clearer entry paths, lighter mobile rhythm, and table actions that stay easy to read.');
$avgLabel = $getConfig('texts.avg_label', 'Average Rating');
$reviewLabelSingular = $getConfig('texts.review_label_singular', 'visible review');
$reviewLabelPlural = $getConfig('texts.review_label_plural', 'visible reviews');

$parseRating = function($raw) {
    $raw = trim((string)$raw);
    if ($raw === '') return 0;
    if (is_numeric($raw)) return (int)$raw;
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    [
        'name' => 'Aarav Sinha',
        'tag' => 'Fast Lobby Entry',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'I can scan the Andar Bahar lobby quickly and move into a table without second-guessing the buttons.',
    ],
    [
        'name' => 'Meera Joshi',
        'tag' => 'Mobile Round Player',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'On mobile the card flow stays clear, so bets and round actions never feel cramped or hidden.',
    ],
    [
        'name' => 'Rohan Verma',
        'tag' => 'Daily Table Check-in',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'The bright look is fresh, but it still feels like a real Andar Bahar site instead of a generic promo skin.',
    ],
    [
        'name' => 'Ananya Pillai',
        'tag' => 'Quick Stakes View',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Table options, entry paths, and call-to-action buttons are easier to spot here than on most game landing pages.',
    ],
    [
        'name' => 'Kabir Rao',
        'tag' => 'Late Session Table',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'The review section feels active, and the whole homepage keeps a clean rhythm without losing its gaming energy.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i - 1] ?? ['name' => '', 'tag' => '', 'rating' => '⭐⭐⭐⭐⭐', 'text' => ''];
    $name = trim((string)$getConfig("texts.testimonial_{$i}_name", $defaults['name']));
    $tag = trim((string)$getConfig("texts.testimonial_{$i}_tag", $defaults['tag']));
    $ratingText = $getConfig("texts.testimonial_{$i}_rating", $defaults['rating']);
    $content = trim((string)$getConfig("texts.testimonial_{$i}_content", $defaults['text']));
    $avatar = trim((string)$getConfig("avatars.avatar_{$i}", ''));

    if ($name !== '' && $content !== '') {
        $ratingValue = max(0, min(5, $parseRating($ratingText)));
        $ratingDisplay = is_numeric($ratingText) ? str_repeat('★', (int)$ratingText) : (string)$ratingText;
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => $ratingValue,
            'rating_text' => trim($ratingDisplay) !== '' ? $ratingDisplay : str_repeat('★', max(1, $ratingValue)),
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($testimonials)) {
    foreach ($defaultTestimonials as $fallback) {
        $testimonials[] = [
            'name' => $fallback['name'],
            'tag' => $fallback['tag'],
            'rating' => $parseRating($fallback['rating']),
            'rating_text' => $fallback['rating'],
            'text' => $fallback['text'],
            'avatar' => '',
        ];
    }
}

$totalRating = array_sum(array_column($testimonials, 'rating'));
$avgRating = count($testimonials) ? $totalRating / count($testimonials) : 0;
$avgRatingLabel = number_format($avgRating, 1);
$avgRatingStars = str_repeat('★', max(1, (int)round($avgRating)));

$buildInitials = function($name) {
    $parts = preg_split('/\s+/', trim((string)$name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};
