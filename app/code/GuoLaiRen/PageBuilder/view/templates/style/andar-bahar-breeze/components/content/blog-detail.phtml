$componentId = 'abb-blog-detail-' . uniqid();

$getConfig = function($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCover = $getConfig('blog.show_cover', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showTags = $getConfig('blog.show_tags', 'yes') === 'yes';
$showShare = $getConfig('blog.show_share', 'yes') === 'yes';
$showRelated = $getConfig('blog.show_related', 'yes') === 'yes';
$relatedCount = (int)$getConfig('blog.related_count', 3);
if ($relatedCount <= 0) {
    $relatedCount = 3;
}

$primaryColor = $getConfig('color_scheme.primary', '#59c7bf');
$secondaryColor = $getConfig('color_scheme.secondary', '#8dc9ff');
$bgColor = $getConfig('color_scheme.background', '#f7fffc');
$textColor = $getConfig('color_scheme.text', '#21444b');
$patternBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/poker-header-bg.svg');

$tags = [];
if (!empty($currentPost['tags'])) {
    $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', $currentPost['tags']);
    $tags = array_values(array_filter(array_map('trim', $tags), static function($item) {
        return $item !== '';
    }));
}

$requestUri = (string)\w_env('request.uri', '');
$shareSourceUrl = $requestUri;
$httpHost = (string)\w_env('server.http_host', '');
if ($httpHost !== '') {
    $httpsFlag = (string)\w_env('server.https', '');
    $scheme = ($httpsFlag !== '' && $httpsFlag !== 'off') ? 'https' : 'http';
    $shareSourceUrl = $scheme . '://' . $httpHost . $requestUri;
}
$shareUrl = rawurlencode($shareSourceUrl);
$shareTitle = rawurlencode((string)($currentPost['title'] ?? ''));

$contentPreview = trim(strip_tags((string)($currentPost['content'] ?? '')));
$estimatedUnits = max(str_word_count($contentPreview), (int)ceil(mb_strlen($contentPreview) / 5));
$readMinutes = max(1, (int)ceil($estimatedUnits / 180));

$showTagDock = $showTags && !empty($tags);
$showShareDock = $showShare;
$showSidebarBlocks = $showSidebar && (!empty($blogCategories) || !empty($recentPosts));
