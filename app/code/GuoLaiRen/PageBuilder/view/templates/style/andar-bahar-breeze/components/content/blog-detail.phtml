    <?php if ($showShareDock): ?>
        <script>
        (function () {
            var root = document.getElementById('<?= $componentId ?>');
            if (!root) {
                return;
            }

            var copyButton = root.querySelector('.share-copy');
            var toast = document.getElementById('<?= $componentId ?>-copy-toast');
            if (!copyButton) {
                return;
            }

            var showToast = function () {
                if (!toast) {
                    return;
                }

                toast.classList.add('is-visible');
                if (toast._timer) {
                    window.clearTimeout(toast._timer);
                }
                toast._timer = window.setTimeout(function () {
                    toast.classList.remove('is-visible');
                }, 2200);
            };

            var fallbackCopy = function () {
                var temp = document.createElement('input');
                temp.value = window.location.href;
                temp.setAttribute('readonly', 'readonly');
                document.body.appendChild(temp);
                temp.select();
                document.execCommand('copy');
                document.body.removeChild(temp);
                showToast();
            };

            copyButton.addEventListener('click', function () {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(window.location.href).then(showToast).catch(fallbackCopy);
                    return;
                }

                fallbackCopy();
            });
        })();
        </script>
    <?php endif; ?>
