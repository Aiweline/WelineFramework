    #<?= $componentId ?> {
        padding: <?= htmlspecialchars($sectionPaddingMobile) ?>px 0 64px;
    }

    #<?= $componentId ?> .faq-columns {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var triggers = Array.prototype.slice.call(root.querySelectorAll('[data-faq-trigger]'));

    function getFaqParts(key, trigger) {
        return {
            card: trigger ? trigger.closest('[data-faq-card]') : root.querySelector('[data-faq-card="' + key + '"]'),
            wrap: root.querySelector('[data-faq-panel-wrap="' + key + '"]'),
            panel: root.querySelector('[data-faq-panel="' + key + '"]')
        };
    }

    function setFaqState(parts, expanded) {
        if (parts.card) {
            parts.card.classList.toggle('is-open', expanded);
        }

        if (parts.wrap) {
            parts.wrap.classList.toggle('is-open', expanded);
        }

        if (parts.panel) {
            parts.panel.hidden = !expanded;
            parts.panel.setAttribute('tabindex', expanded ? '0' : '-1');
        }
    }

    triggers.forEach(function(trigger) {
        var key = trigger.getAttribute('data-faq-trigger');
        var parts = getFaqParts(key, trigger);
        var expanded = trigger.getAttribute('aria-expanded') === 'true';

        trigger.classList.toggle('is-active', expanded);
        setFaqState(parts, expanded);
    });

    triggers.forEach(function(trigger) {
        trigger.addEventListener('click', function() {
            var key = trigger.getAttribute('data-faq-trigger');
            var parts = getFaqParts(key, trigger);
            var expanded = trigger.getAttribute('aria-expanded') === 'true';

            trigger.classList.toggle('is-active', !expanded);
            trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            setFaqState(parts, !expanded);
        });
    });
})();
</script>
