<?php
/**
 * Andar Bahar Breeze - About Content Component
 *
 * @component_start
 * code: about-content
 * name: 关于我们内容
 * name_en: About Content
 * description: 品牌关于页面内容展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_stats => 显示数据统计:select:yes|yes,no
 * display.show_values => 显示价值观:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:About Andar Bahar Breeze
 * hero.subtitle => 页面副标题:textarea:Andar Bahar Breeze softens the landing flow with lighter surfaces, cleaner reading rhythm, and faster access to the right table or support route.
 *
 * group:stats => 数据统计
 * stats.stat_1_number => 统计1数字:text:5+
 * stats.stat_1_label => 统计1标签:text:Years refining table flow
 * stats.stat_2_number => 统计2数字:text:1M+
 * stats.stat_2_label => 统计2标签:text:Andar Bahar sessions served
 * stats.stat_3_number => 统计3数字:text:24/7
 * stats.stat_3_label => 统计3标签:text:Support route coverage
 * stats.stat_4_number => 统计4数字:text:3-step
 * stats.stat_4_label => 统计4标签:text:Mobile entry path
 * stats.highlight_label => 主数据辅助标签:text:Current Reach
 *
 * group:story => 故事区块
 * story.kicker => 故事辅助标签:text:Brand Canvas
 * story.title => 标题:text:Our Story
 * story.content => 内容:textarea:Andar Bahar Breeze keeps the familiar Andar Bahar pace while reorganizing how players read sections, compare routes, and move through support on smaller screens.
 *
 * group:values => 价值观区块
 * values.kicker => 价值观辅助标签:text:Principles
 * values.title => 标题:text:Our Core Values
 * values.subtitle => 副标题:text:Three editable principles keep the page flexible when creating new Andar Bahar sites.
 * values.value_1_icon => 价值1图标:text:⚖️
 * values.value_1_title => 价值1标题:text:Fair Play
 * values.value_1_desc => 价值1描述:textarea:Rule cues, table context, and result expectations should stay clear before players commit to a room.
 * values.value_2_icon => 价值2图标:text:💠
 * values.value_2_title => 价值2标题:text:Readable Flow
 * values.value_2_desc => 价值2描述:textarea:Light surfaces and consistent spacing should keep browsing calm across desktop and mobile.
 * values.value_3_icon => 价值3图标:text:💬
 * values.value_3_title => 价值3标题:text:Support Access
 * values.value_3_desc => 价值3描述:textarea:Help routes for account, payment, and gameplay questions should feel easy to spot and quick to use.
 *
 * @fields_end
 */

$page = $this->getData('page');
$componentId = 'abb-about-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if ($getConfig('display.show_section', $getConfig('about.display', 'yes')) === 'no') {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'About Andar Bahar Breeze';
}
$subtitle = trim((string)$getConfig('hero.subtitle', 'Andar Bahar Breeze softens the landing flow with lighter surfaces, cleaner reading rhythm, and faster access to the right table or support route.'));

$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultNumbers = ['5+', '1M+', '24/7', '3-step'];
    $defaultLabels = [
        'Years refining table flow',
        'Andar Bahar sessions served',
        'Support route coverage',
        'Mobile entry path',
    ];
    $number = trim((string)$getConfig("stats.stat_{$i}_number", $defaultNumbers[$i - 1]));
    $label = trim((string)$getConfig("stats.stat_{$i}_label", $defaultLabels[$i - 1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'value' => $number,
        'label' => $label,
    ];
}

if (empty($stats)) {
    $statsRaw = (string)$getConfig('stats.items', "5+|Years refining table flow\n1M+|Andar Bahar sessions served\n24/7|Support route coverage\n3-step|Mobile entry path");
    if (strpos($statsRaw, '\\n') !== false && strpos($statsRaw, "\n") === false) {
        $statsRaw = str_replace('\\n', "\n", $statsRaw);
    }
    foreach (preg_split('/[\r\n]+/', $statsRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim($parts[0] ?? '') !== '') {
            $stats[] = [
                'value' => trim($parts[0]),
                'label' => trim($parts[1] ?? ''),
            ];
        }
    }
}

$storyTitle = trim((string)$getConfig('story.title', 'Our Story'));
$storyKicker = trim((string)$getConfig('story.kicker', 'Brand Canvas'));
$storyContent = trim((string)$getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Andar Bahar Breeze keeps the familiar Andar Bahar pace while reorganizing how players read sections, compare routes, and move through support on smaller screens.';
}
$storyParagraphs = preg_split('/[\r\n]+/', trim((string)$storyContent));
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function($item) {
    return $item !== '';
}));
if (empty($storyParagraphs) && trim((string)$storyContent) !== '') {
    $storyParagraphs = [trim((string)$storyContent)];
}

$valuesTitle = trim((string)$getConfig('values.title', 'Our Core Values'));
$valuesKicker = trim((string)$getConfig('values.kicker', 'Principles'));
$valuesSubtitle = trim((string)$getConfig('values.subtitle', 'Three editable principles keep the page flexible when creating new Andar Bahar sites.'));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $defaults = [
        ['⚖️', 'Fair Play', 'Rule cues, table context, and result expectations should stay clear before players commit to a room.'],
        ['💠', 'Readable Flow', 'Light surfaces and consistent spacing should keep browsing calm across desktop and mobile.'],
        ['💬', 'Support Access', 'Help routes for account, payment, and gameplay questions should feel easy to spot and quick to use.'],
    ];
    $itemTitle = trim((string)$getConfig("values.value_{$i}_title", $defaults[$i - 1][1]));
    $itemDesc = trim((string)$getConfig("values.value_{$i}_desc", $defaults[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'title' => $itemTitle,
        'description' => $itemDesc,
        'icon' => trim((string)$getConfig("values.value_{$i}_icon", $defaults[$i - 1][0])),
    ];
}

if (empty($values)) {
    $valuesRaw = (string)$getConfig('values.items', "Fair Play|Rule cues, table context, and result expectations should stay clear before players commit to a room.|⚖️\nReadable Flow|Light surfaces and consistent spacing should keep browsing calm across desktop and mobile.|💠\nSupport Access|Help routes for account, payment, and gameplay questions should feel easy to spot and quick to use.|💬");
    if (strpos($valuesRaw, '\\n') !== false && strpos($valuesRaw, "\n") === false) {
        $valuesRaw = str_replace('\\n', "\n", $valuesRaw);
    }
    foreach (preg_split('/[\r\n]+/', $valuesRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line);
        if (trim($parts[0] ?? '') !== '') {
            $values[] = [
                'title' => trim($parts[0]),
                'description' => trim($parts[1] ?? ''),
                'icon' => trim($parts[2] ?? '★'),
            ];
        }
    }
}

$heroStats = array_slice($stats, 0, 3);
$storyStat = $stats[3] ?? ($stats[0] ?? null);
$storyStatLabel = trim((string)$getConfig('stats.highlight_label', 'Current Reach'));
?>

<section id="<?= $componentId ?>" class="abb-about">
    <div class="about-shell">
        <header class="about-stage">
            <div class="about-intro">
                <h1><?= htmlspecialchars($title) ?></h1>

                <?php if ($subtitle !== ''): ?>
                    <p class="about-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>

                <?php if ($showStats && !empty($heroStats)): ?>
                    <div class="about-glance" aria-label="Brand highlights">
                        <?php foreach ($heroStats as $stat): ?>
                            <article class="glance-card">
                                <strong><?= htmlspecialchars($stat['value']) ?></strong>
                                <span><?= htmlspecialchars($stat['label']) ?></span>
                            </article>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>

            <aside class="story-lens">
                <div class="story-head">
                    <?php if ($storyKicker !== ''): ?>
                        <span class="story-kicker"><?= htmlspecialchars($storyKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($storyTitle) ?></h2>
                </div>

                <div class="story-copy">
                    <?php foreach ($storyParagraphs as $paragraph): ?>
                        <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                    <?php endforeach; ?>
                </div>

                <?php if ($showStats && $storyStat): ?>
                    <div class="story-beacon">
                        <?php if ($storyStatLabel !== ''): ?>
                            <span class="beacon-label"><?= htmlspecialchars($storyStatLabel) ?></span>
                        <?php endif; ?>
                        <strong><?= htmlspecialchars($storyStat['value']) ?></strong>
                        <p><?= htmlspecialchars($storyStat['label']) ?></p>
                    </div>
                <?php endif; ?>
            </aside>
        </header>

        <?php if ($showStats && count($stats) > 3): ?>
            <section class="metrics-runway" aria-label="Extended statistics">
                <?php foreach (array_slice($stats, 3) as $index => $stat): ?>
                    <article class="metric-pill metric-pill-<?= (int)$index ?>">
                        <strong><?= htmlspecialchars($stat['value']) ?></strong>
                        <span><?= htmlspecialchars($stat['label']) ?></span>
                    </article>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage">
                <div class="values-head">
                    <?php if ($valuesKicker !== ''): ?>
                        <span class="values-kicker"><?= htmlspecialchars($valuesKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-ribbon">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-panel<?= $index === 0 ? ' is-wide' : '' ?><?= $index === 2 ? ' is-offset' : '' ?>">
                            <div class="value-mark"><?= htmlspecialchars($value['icon']) ?></div>
                            <div class="value-copy">
                                <h3><?= htmlspecialchars($value['title']) ?></h3>
                                <p><?= htmlspecialchars($value['description']) ?></p>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>

