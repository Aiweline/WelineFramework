<?php
/**
 * Andar Bahar Breeze Banner Component
 *
 * 独立的 Banner 横幅组件，用于 content 区域
 *
 * @component_start
 * code: banner
 * name: Banner横幅
 * name_en: Banner
 * description: 首屏Banner横幅，支持响应式图片和下载按钮
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.svg
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端图片:textarea:|默认使用本地banner-2.svg
 * banner.image_desktop => PC端图片:textarea:|默认使用本地banner-03.svg
 * banner.alt => 图片描述:text:Andar Bahar Breeze banner
 * banner.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn.svg
 * banner.bg_color => 背景颜色:color:#f7fffc
 * banner.bg_gradient_end => 背景渐变色结束:color:#ffe7cf
 * banner.image_offset_top => 图片向上偏移:number:90|px（用于与header重叠效果）
 * banner.image_offset_top_mobile => 移动端容器向上偏移:number:75|px
 *
 * @fields_end
 */

$componentId = 'dts-banner-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$bannerDisplay = $getConfig('banner.display', 'yes') !== 'no';
if (!$bannerDisplay) {
    return;
}

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/banner-2.svg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/banner-03.svg');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/download-btn.svg');

$bannerMobile = $getConfig('banner.image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('banner.image_desktop', '') ?: $defaultBannerDesktop;
$bannerAlt = $getConfig('banner.alt', 'Andar Bahar Breeze banner');
$bannerDownloadImg = $getConfig('banner.download_btn_image', '') ?: $defaultDownloadBtn;
$bannerBgColor = $getConfig('banner.bg_color', '#f7fffc');
$bannerBgGradientEnd = $getConfig('banner.bg_gradient_end', '#ffe7cf');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/poker-header-bg.svg');

$bannerImageOffsetTop = intval($getConfig('banner.image_offset_top', '90'));
$bannerImageOffsetTopMobile = intval($getConfig('banner.image_offset_top_mobile', '75'));
?>

<div id="<?= $componentId ?>" class="dts-banner-component">
    <section class="dts-banner">
        <div class="banner-shell">
            <div class="banner-stack">
                <span class="stack-label stack-label-left">Arena Cover</span>
                <span class="stack-label stack-label-right">Responsive Visual</span>

                <div class="stack-layer layer-back" aria-hidden="true"></div>
                <div class="stack-layer layer-mid" aria-hidden="true"></div>

                <div class="banner-screen">
                    <picture>
                        <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerMobile) ?>">
                        <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerDesktop) ?>">
                        <img class="banner-image"
                             src="<?= htmlspecialchars($bannerMobile) ?>"
                             alt="<?= htmlspecialchars($bannerAlt) ?>"
                             fetchpriority="high"
                             decoding="async">
                    </picture>
                </div>

                <?php if ($bannerDownloadImg): ?>
                    <div class="banner-pocket" aria-label="Download app">
                        <img src="<?= htmlspecialchars($bannerDownloadImg) ?>"
                             alt="DOWNLOAD APP"
                             width="210"
                             height="54">
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </section>
</div>

