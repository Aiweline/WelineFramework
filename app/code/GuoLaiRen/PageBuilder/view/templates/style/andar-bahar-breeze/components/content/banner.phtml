        radial-gradient(620px 280px at 82% 22%, rgba(141, 201, 255, 0.12), transparent 72%),
        linear-gradient(180deg, <?= htmlspecialchars($bannerBgColor) ?> 0%, <?= htmlspecialchars($bannerBgGradientEnd) ?> 100%);
