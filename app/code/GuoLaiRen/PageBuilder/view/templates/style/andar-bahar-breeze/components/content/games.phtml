    background:
        radial-gradient(620px 260px at 12% 8%, rgba(255, 231, 169, 0.18), transparent 72%),
        radial-gradient(680px 320px at 88% 12%, rgba(89, 199, 191, 0.18), transparent 74%),
        linear-gradient(135deg, <?= htmlspecialchars($bgColor) ?> 0%, #21444b 48%, #1b5962 100%);
