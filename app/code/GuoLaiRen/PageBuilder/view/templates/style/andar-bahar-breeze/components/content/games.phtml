    }
}

@media (max-width: 760px) {
    #<?= $componentId ?> {
        padding: <?= $sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .game-card,
    #<?= $componentId ?> .game-body,
    #<?= $componentId ?> .game-body-featured {
