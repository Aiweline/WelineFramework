<?php
/**
 * Andar Bahar Breeze - Games Showcase Component
 *
 * @component_start
 * code: games-showcase
 * name: 游戏展示区
 * name_en: Games Showcase
 * description: 参考原始games逻辑的三卡游戏展示，使用更有层次的特色排版
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_subtitle => 显示副标题:select:yes|yes,no
 * display.show_description => 显示卡片描述:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#183940
 * style.accent_color => 强调色:color:#59c7bf
 * style.title_color => 标题颜色:color:#f5fffc
 * style.subtitle_color => 副标题颜色:color:rgba(228,245,242,0.8)
 * style.panel_bg_color => 外层面板背景:color:rgba(255,255,255,0.1)
 * style.card_bg_color => 内容卡片背景:color:rgba(247,255,252,0.94)
 * style.card_border_color => 卡片边框色:color:rgba(255,255,255,0.16)
 * style.card_radius => 卡片圆角:number:24|px
 * style.section_padding => 区域内边距(PC端):number:88|px
 * style.section_padding_mobile => 区域内边距(移动端):number:52|px
 * style.card_gap => 卡片间距:number:24|px
 *
 * group:images => 图片配置
 * images.image_1_desktop => 游戏1桌面端图片:textarea:|留空使用默认图
 * images.image_1_mobile => 游戏1移动端图片:textarea:|留空使用默认图
 * images.image_2 => 游戏2图片:textarea:|留空使用默认图
 * images.image_3 => 游戏3图片:textarea:|留空使用默认图
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Explore the Breeze Game Lounge
 * texts.subtitle => 副标题:textarea:The original games block is still about showing actual card games. This version keeps that meaning, but uses a featured game stage instead of a basic repeated grid.
 * texts.game_1_title => 游戏1标题:text:Andar Bahar Classic
 * texts.game_1_desc => 游戏1描述:textarea:The signature deck game stays front and center with quicker table recognition and a cleaner hero-style presentation.
 * texts.game_1_link => 游戏1链接:text:#download
 * texts.game_2_title => 游戏2标题:text:Teen Patti Live
 * texts.game_2_desc => 游戏2描述:textarea:A brighter live-card option for players who want a sharper social table and faster glance reading.
 * texts.game_2_link => 游戏2链接:text:#download
 * texts.game_3_title => 游戏3标题:text:Rummy Circle
 * texts.game_3_desc => 游戏3描述:textarea:A calmer card flow built around structured hands, steady pacing, and a softer lounge feel.
 * texts.game_3_link => 游戏3链接:text:#download
 *
 * @fields_end
 */

$componentId = 'abb-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#183940');
$accentColor = $getConfig('style.accent_color', '#59c7bf');
$titleColor = $getConfig('style.title_color', '#f5fffc');
$subtitleColor = $getConfig('style.subtitle_color', 'rgba(228,245,242,0.8)');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.1)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(247,255,252,0.94)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,255,255,0.16)');
$cardRadius = (int)$getConfig('style.card_radius', '24');
$sectionPadding = (int)$getConfig('style.section_padding', '88');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '52');
$cardGap = (int)$getConfig('style.card_gap', '24');

$title = $getConfig('texts.title', 'Explore the Breeze Game Lounge');
$subtitle = $getConfig('texts.subtitle', 'The original games block is still about showing actual card games. This version keeps that meaning, but uses a featured game stage instead of a basic repeated grid.');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/game/breeze-game-1.svg');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/game/breeze-game-1-m.svg');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/game/breeze-game-2.svg');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/game/breeze-game-3.svg');

$image1Desktop = $getConfig('images.image_1_desktop', '') ?: $defaultImage1Desktop;
$image1Mobile = $getConfig('images.image_1_mobile', '') ?: $defaultImage1Mobile;
$image2 = $getConfig('images.image_2', '') ?: $defaultImage2;
$image3 = $getConfig('images.image_3', '') ?: $defaultImage3;

$fallbackGames = [
    [
        'name' => $getConfig('texts.game_1_title', 'Andar Bahar Classic'),
        'description' => $getConfig('texts.game_1_desc', 'The signature deck game stays front and center with quicker table recognition and a cleaner hero-style presentation.'),
        'link' => $getConfig('texts.game_1_link', '#download'),
        'image' => $image1Desktop,
        'image_mobile' => $image1Mobile,
        'label' => 'Featured deck',
        'tone' => 'teal',
    ],
    [
        'name' => $getConfig('texts.game_2_title', 'Teen Patti Live'),
        'description' => $getConfig('texts.game_2_desc', 'A brighter live-card option for players who want a sharper social table and faster glance reading.'),
        'link' => $getConfig('texts.game_2_link', '#download'),
        'image' => $image2,
        'image_mobile' => $image2,
        'label' => 'Live card room',
        'tone' => 'sand',
    ],
    [
        'name' => $getConfig('texts.game_3_title', 'Rummy Circle'),
        'description' => $getConfig('texts.game_3_desc', 'A calmer card flow built around structured hands, steady pacing, and a softer lounge feel.'),
        'link' => $getConfig('texts.game_3_link', '#download'),
        'image' => $image3,
        'image_mobile' => $image3,
        'label' => 'Calm table pick',
        'tone' => 'sky',
    ],
];

$games = [];
$gamesConfig = $getConfig('games.items', '');
foreach (preg_split('/\r?\n/', str_replace('\\n', "\n", $gamesConfig)) as $line) {
    $line = trim($line);
    if ($line === '') {
        continue;
    }

    $parts = array_map('trim', explode('|', $line));
    if (count($parts) >= 2) {
        $games[] = [
            'name' => $parts[0],
            'description' => $parts[1],
            'link' => $parts[2] ?? '#download',
        ];
    }
}

$mergedGames = [];
for ($i = 0; $i < 3; $i++) {
    $base = $fallbackGames[$i];
    $source = $games[$i] ?? [];
    $mergedGames[] = [
        'name' => $source['name'] ?? $base['name'],
        'description' => $source['description'] ?? $base['description'],
        'link' => $source['link'] ?? $base['link'],
        'image' => $base['image'],
        'image_mobile' => $base['image_mobile'],
        'label' => $base['label'],
        'tone' => $base['tone'],
    ];
}

$games = $mergedGames;
$featuredGame = $games[0];
$sideGames = array_slice($games, 1);
?>

<section id="<?= $componentId ?>" class="abb-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <span class="games-kicker">Game lounge</span>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showSubtitle): ?>
                <p class="games-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </header>

        <div class="games-stage">
            <article class="game-card game-card-featured game-tone-<?= htmlspecialchars($featuredGame['tone']) ?>">
                <div class="game-card-glow" aria-hidden="true"></div>
                <div class="game-media game-media-featured">
                    <picture>
                        <source media="(max-width: 767px)" srcset="<?= htmlspecialchars($featuredGame['image_mobile']) ?>">
                        <source media="(min-width: 768px)" srcset="<?= htmlspecialchars($featuredGame['image']) ?>">
                        <img src="<?= htmlspecialchars($featuredGame['image_mobile']) ?>" alt="<?= htmlspecialchars($featuredGame['name']) ?>">
                    </picture>
                </div>
                <div class="game-body game-body-featured">
                    <div class="game-topline">
                        <span class="game-pill"><?= htmlspecialchars($featuredGame['label']) ?></span>
                        <span class="game-pill game-pill-soft">Breeze selection</span>
                    </div>
                    <h3><?= htmlspecialchars($featuredGame['name']) ?></h3>
                    <?php if ($showDescription): ?>
                        <p><?= htmlspecialchars($featuredGame['description']) ?></p>
                    <?php endif; ?>
                    <a class="game-link" href="<?= htmlspecialchars($featuredGame['link']) ?>">Open game</a>
                </div>
            </article>

            <div class="game-side-stack">
                <?php foreach ($sideGames as $game): ?>
                    <article class="game-card game-card-side game-tone-<?= htmlspecialchars($game['tone']) ?>">
                        <div class="game-card-glow" aria-hidden="true"></div>
                        <div class="game-media game-media-side">
                            <img src="<?= htmlspecialchars($game['image']) ?>" alt="<?= htmlspecialchars($game['name']) ?>">
                        </div>
                        <div class="game-body">
                            <div class="game-topline">
                                <span class="game-pill"><?= htmlspecialchars($game['label']) ?></span>
                            </div>
                            <h3><?= htmlspecialchars($game['name']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= htmlspecialchars($game['description']) ?></p>
                            <?php endif; ?>
                            <a class="game-link" href="<?= htmlspecialchars($game['link']) ?>">Open game</a>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

<style>
