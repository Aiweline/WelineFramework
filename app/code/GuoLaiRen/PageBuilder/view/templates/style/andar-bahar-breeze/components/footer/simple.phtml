<?php
/**
 * Generic simple footer component.
 *
 * @component_start
 * code: footer-simple
 * name: 简洁底部
 * name_en: Simple Footer
 * description: 只包含版权信息的简洁底部
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 * group:content => 内容配置
 * content.copyright_text => 版权信息:text:© 2026 All rights reserved
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#0f172a
 * style.text_color => 文字颜色:color:#94a3b8
 * style.padding => 内边距:number:20|px
 * style.text_align => 对齐方式:select:center|left,center,right
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$componentId = 'generic-footer-simple-' . uniqid();
$getConfig = function ($key, $default = '') use ($styleSettings, $componentConfig) {
    if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
        return $styleSettings[$key];
    }
    return $default;
};
$copyrightText = (string)$getConfig('content.copyright_text', '© 2026 All rights reserved');
$bgColor = (string)$getConfig('style.bg_color', '#0f172a');
$textColor = (string)$getConfig('style.text_color', '#94a3b8');
$padding = max(0, (int)$getConfig('style.padding', '20'));
$textAlign = (string)$getConfig('style.text_align', 'center');
?>
<style>
#<?= $componentId ?> { background: <?= htmlspecialchars($bgColor) ?>; padding: <?= $padding ?>px 0; width: 100%; }
#<?= $componentId ?> .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; text-align: <?= htmlspecialchars($textAlign) ?>; }
#<?= $componentId ?> p { color: <?= htmlspecialchars($textColor) ?>; font-size: 12px; margin: 0; }
</style>
<footer id="<?= $componentId ?>" class="theme-footer-simple">
    <div class="footer-inner">
        <p><?= htmlspecialchars($copyrightText) ?></p>
    </div>
</footer>
