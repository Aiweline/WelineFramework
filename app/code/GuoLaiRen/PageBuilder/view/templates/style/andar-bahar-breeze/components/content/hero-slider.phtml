    ],
    [
        'title' => $getConfig('hero.card_2_title', 'Fast Table Entry'),
        'text' => $getConfig('hero.card_2_text', 'Primary actions stay close to the fold so players can move from landing to table browsing without extra scanning.'),
    ],
    [
        'title' => $getConfig('hero.card_3_title', 'Bright Mobile Read'),
