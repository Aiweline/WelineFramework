$ctaSecondaryText = $getConfig('hero.secondary_cta_text', 'Browse the Tables');
$ctaSecondaryUrl = $getConfig('hero.secondary_cta_url', '#tables');
$heroTagsRaw = (string) $getConfig('hero.tags', 'Andar Bahar landing, Quick table access, Responsive mobile view');
$artBadge = $getConfig('hero.art_badge', 'Andar Bahar Breeze');
$artMetaLabel = $getConfig('hero.art_meta_label', 'Light-table preview');
$artMetaValue = $getConfig('hero.art_meta_value', 'Clear room entry and softer mobile rhythm');
