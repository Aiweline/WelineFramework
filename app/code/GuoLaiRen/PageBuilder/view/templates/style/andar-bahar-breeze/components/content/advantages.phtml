$componentId = 'abb-advantages-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#fff4e7');
$titleColor = $getConfig('style.title_color', '#21444b');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.84)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(95,170,175,0.16)');
$cardTitleColor = $getConfig('style.card_title_color', '#21444b');
$cardDescColor = $getConfig('style.card_desc_color', '#55797f');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');
$cardGap = $getConfig('style.card_gap', '24');
