$kicker = $getConfig('texts.kicker', 'Andar Bahar layout notes');
$title = $getConfig('texts.title', 'Why Andar Bahar Breeze Feels Cleaner');
$summary = $getConfig('texts.summary', 'This section focuses on Andar Bahar table browsing, clearer card reading, and a lighter mobile path for quick room entry.');
