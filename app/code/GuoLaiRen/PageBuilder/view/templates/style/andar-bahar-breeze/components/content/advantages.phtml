    [
        'icon' => $getConfig('texts.advantage_1_icon', ''),
        'title' => $getConfig('texts.advantage_1_title', 'Quick Table Recognition'),
        'desc' => $getConfig('texts.advantage_1_desc', 'Hero spacing, card sizing, and CTA placement guide visitors toward Andar Bahar tables without crowding the page.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_2_icon', ''),
        'title' => $getConfig('texts.advantage_2_title', 'Card-Led Visual Balance'),
        'desc' => $getConfig('texts.advantage_2_desc', 'Light panels and softer contrast keep table labels, feature copy, and card artwork readable during longer browsing.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_3_icon', ''),
        'title' => $getConfig('texts.advantage_3_title', 'Mobile Tap Confidence'),
        'desc' => $getConfig('texts.advantage_3_desc', 'Menus, buttons, and stacked sections stay touch-friendly so players can move from scroll to room entry with less friction.'),
