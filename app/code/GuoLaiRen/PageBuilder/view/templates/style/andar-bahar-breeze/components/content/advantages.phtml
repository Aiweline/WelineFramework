@keyframes abb-adv-arc-left {
    0%, 100% { transform: rotate(-12deg) translate3d(0, 0, 0); }
    50% { transform: rotate(-9deg) translate3d(12px, -6px, 0); }
}

@keyframes abb-adv-arc-right {
    0%, 100% { transform: rotate(10deg) translate3d(0, 0, 0); }
    50% { transform: rotate(7deg) translate3d(-12px, 7px, 0); }
