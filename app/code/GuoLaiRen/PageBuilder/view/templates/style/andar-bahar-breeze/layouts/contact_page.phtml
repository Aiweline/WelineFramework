<?php
/**
 * Generic contact page layout for PageBuilder themes.
 */

$layoutConfig = $layout_config ?? [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];
$isVisualMode = ($mode ?? 'live') === 'visual';
$pageTitle = $page->getData('title') ?? 'Contact Us';
$pageContent = $page->getData('content') ?? '';
?>
<!DOCTYPE html>
<html lang="<?= $lang ?? 'en' ?>">
<head>
    <?php $this->renderHead($page, $style_setting); ?>
</head>
<body class="page-contact">
    <header class="site-header" data-region="header"<?= $isVisualMode ? ' data-slot-name="Header"' : '' ?>>
        <?php $this->renderRegionComponents('header', $headerComponents, $page); ?>
    </header>
    <main class="site-content contact-content" data-region="content"<?= $isVisualMode ? ' data-slot-name="Content"' : '' ?>>
        <div class="content-container">
            <?php if (empty($contentComponents)): ?>
                <article class="page-article">
                    <h1 class="page-title"><?= htmlspecialchars($pageTitle) ?></h1>
                    <?php if ($pageContent): ?>
                        <div class="page-intro"><?= $pageContent ?></div>
                    <?php endif; ?>
                    <div class="contact-form-wrapper">
                        <form class="contact-form" method="post" action="">
                            <div class="form-group">
                                <label for="name">Name *</label>
                                <input type="text" id="name" name="name" required>
                            </div>
                            <div class="form-group">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email" required>
                            </div>
                            <div class="form-group">
                                <label for="subject">Subject</label>
                                <input type="text" id="subject" name="subject">
                            </div>
                            <div class="form-group">
                                <label for="message">Message *</label>
                                <textarea id="message" name="message" rows="5" required></textarea>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">Send Message</button>
                            </div>
                        </form>
                    </div>
                </article>
            <?php else: ?>
                <?php $this->renderRegionComponents('content', $contentComponents, $page); ?>
            <?php endif; ?>
        </div>
    </main>
    <footer class="site-footer" data-region="footer"<?= $isVisualMode ? ' data-slot-name="Footer"' : '' ?>>
        <?php $this->renderRegionComponents('footer', $footerComponents, $page); ?>
    </footer>
    <?php $this->renderFooterScripts($page, $style_setting); ?>
</body>
</html>
