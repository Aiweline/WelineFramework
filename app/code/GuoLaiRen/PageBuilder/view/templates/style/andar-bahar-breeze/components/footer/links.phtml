<?php
/**
 * Andar Bahar Breeze - Footer Component
 *
 * @component_start
 * code: footer-links
 * name: 页脚链接
 * name_en: Footer Links
 * description: 轻量微风风页脚，支持多列链接与品牌信息
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:footer => Footer设置
 * footer.logo_text => Logo文字:text:Andar Bahar Breeze
 * footer.logo_url => Logo图片URL:textarea:|留空使用默认图标
 * footer.tagline => 口号:text:Fresh visuals. Clear tables.
 * footer.description => 品牌说明:text:A lighter Andar Bahar space with quick tables, clear navigation, and mobile-friendly support access.
 *
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nTables=>#tables\r\nWhy Breeze=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq\r\nSupport=>/contact|配置格式：名字=>url，一行一个
 * content.copyright_text => 版权信息:text:© 2026 Andar Bahar Breeze. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. Play responsibly and check local rules before participating in any gaming-related activity.
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * @fields_end
 */

$componentId = 'abb-footer-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (is_array($componentConfig) && array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (is_array($styleSettings) && array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$logoText = $getConfig('footer.logo_text', 'Andar Bahar Breeze');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/andar-bahar-breeze/asset/img/breeze-logo-icon.svg');
$logoUrl = $getConfig('footer.logo_url', '') ?: $logoIconUrl;
$tagline = $getConfig('footer.tagline', 'Fresh visuals. Clear tables.');
$description = $getConfig('footer.description', 'A lighter Andar Bahar space with quick tables, clear navigation, and mobile-friendly support access.');
$copyright = trim((string)$getConfigAny([
    'content.copyright_text',
    'content_footer_labels.content.copyright_text',
    'content_footer_labels.copyright_text',
    'footer.copyright',
], '© 2026 Andar Bahar Breeze. All rights reserved.'));
if ($copyright === '') {
    $copyright = '© 2026 Andar Bahar Breeze. All rights reserved.';
}
$disclaimerText = trim((string)$getConfigAny([
    'content.disclaimer_text',
    'content_footer_labels.content.disclaimer_text',
    'content_footer_labels.disclaimer_text',
    'footer.disclaimer_text',
], '18+ Only. Play responsibly and check local rules before participating in any gaming-related activity.'));
if ($disclaimerText === '') {
    $disclaimerText = '18+ Only. Play responsibly and check local rules before participating in any gaming-related activity.';
}

$links = [];
$useCustomLinks = $getConfig('content.use_custom_links', 'yes') === 'yes';

if (!$useCustomLinks && $page) {
    $subpages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $subpages = $page->getHeaderNavigationPages(30);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $subpages = $page->getNavigationPages([], 30);
    } else {
        $subpages = $page->getData('subpages') ?: [];
    }
    foreach ($subpages as $subpage) {
        $pageType = trim((string)($subpage['type'] ?? ''));
        $label = $pageType !== '' ? trim((string)$getConfig('content.footer_label_' . $pageType, '')) : '';
        $links[] = [
            'text' => $label !== '' ? $label : ($subpage['title'] ?? ''),
            'href' => $subpage['url'] ?? '#',
        ];
    }
}

if (empty($links)) {
    $linksConfig = $getConfig('content.footer_links', "Home=>/\r\nTables=>#tables\r\nWhy Breeze=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq\r\nSupport=>/contact");

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = (strpos($linksConfig, "\n") !== false && strpos($linksConfig, ',') === false)
        ? preg_split('/\r?\n/', $linksConfig)
        : explode(',', $linksConfig);

    foreach ($items as $item) {
        $item = trim($item);
        if ($item === '') continue;
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            continue;
        }
        if (count($parts) >= 2) {
            $links[] = ['text' => $parts[0], 'href' => $parts[1]];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

$socials = [
    ['label' => 'FB', 'href' => '#'],
    ['label' => 'IG', 'href' => '#'],
    ['label' => 'TG', 'href' => '#'],
    ['label' => 'YT', 'href' => '#'],
];
?>

<footer id="<?= $componentId ?>" class="abb-footer">
    <div class="footer-breeze" aria-hidden="true">
        <span class="breeze-band band-one"></span>
        <span class="breeze-band band-two"></span>
        <span class="breeze-band band-three"></span>
        <span class="breeze-glow glow-left"></span>
        <span class="breeze-glow glow-right"></span>
    </div>

    <div class="footer-shell">
        <div class="footer-brand-card">
            <div class="footer-brand-top">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>">
                <div>
                    <strong><?= htmlspecialchars($logoText) ?></strong>
                    <span><?= htmlspecialchars($tagline) ?></span>
                </div>
            </div>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </div>

        <div class="footer-links-area">
            <nav class="footer-nav" aria-label="Footer navigation">
                <?php foreach ($links as $link): ?>
                    <a href="<?= htmlspecialchars($link['href']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                <?php endforeach; ?>
            </nav>

            <div class="footer-social">
                <?php foreach ($socials as $social): ?>
                    <a class="social-link" href="<?= htmlspecialchars($social['href']) ?>"><?= htmlspecialchars($social['label']) ?></a>
                <?php endforeach; ?>
            </div>
        </div>
    </div>

    <div class="footer-base">
        <p class="footer-copyright"><?= htmlspecialchars($copyright) ?></p>
        <p class="footer-disclaimer"><?= htmlspecialchars($disclaimerText) ?></p>
    </div>
</footer>

