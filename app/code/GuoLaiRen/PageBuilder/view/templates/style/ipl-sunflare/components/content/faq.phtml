<?php
/**
 * @component_start
 * code: faq
 * name: 常见问题
 * name_en: FAQ
 * description: FAQ折叠面板
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_intro => 显示简介:select:yes|yes,no
 * display.first_open => 首个问题默认展开:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景主色:color:#221426
 * style.accent_color => 强调色:color:#ff4d8d
 * style.title_color => 标题颜色:color:#ffe6d1
 * style.text_color => 正文颜色:color:#d9b495
 * style.panel_bg_color => 卡片背景色:color:rgba(41, 24, 48, 0.88)
 * style.card_border_color => 卡片边框色:color:rgba(255, 106, 61, 0.18)
 * style.card_radius => 卡片圆角:number:22|px
 * style.section_padding => 区域内边距(PC端):number:64|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 *
 * group:texts => 文本内容
 * texts.badge => 徽标文字:text:Sunflare Support
 * texts.title => 区域标题:text:Frequently Asked Questions
 * texts.intro => 简介:textarea:Everything critical is easy to scan: pace cues, trust points, and the quick answers users usually seek first.
 * texts.tag_1 => 标签1:text:Quick Rooms
 * texts.tag_2 => 标签2:text:Table Trust
 * texts.tag_3 => 标签3:text:Mobile Readability
 * texts.faq_1_question => 问题1:text:What makes this theme different from the sunrise template?
 * texts.faq_1_answer => 答案1:textarea:This theme changes visual choreography: route panels, spotlight testimonials, and timeline FAQ while preserving the same config keys and PHP fallback logic.
 * texts.faq_2_question => 问题2:text:Can I still override content in the visual editor?
 * texts.faq_2_answer => 答案2:textarea:Yes. Titles, intro, questions, answers, ratings, and display switches continue to map to existing configuration fields.
 * texts.faq_3_question => 问题3:text:Is responsive behavior handled for phones first?
 * texts.faq_3_answer => 答案3:textarea:Yes. Sections collapse cleanly, touch targets remain generous, and horizontal areas become scroll-safe on narrow screens.
 * texts.faq_4_question => 问题4:text:Can individual FAQ rows be hidden without code edits?
 * texts.faq_4_answer => 答案4:textarea:Yes. Empty question-answer pairs are skipped automatically, and display flags let you hide intro/title behavior quickly.
 * texts.faq_5_question => 问题5:text:
 * texts.faq_5_answer => 答案5:textarea:
 * texts.faq_6_question => 问题6:text:
 * texts.faq_6_answer => 答案6:textarea:
 *
 * @fields_end
 */

$componentId = 'isf-faq-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showIntro = $getConfig('display.show_intro', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

$bgColor = $getConfig('style.bg_color', '#221426');
$accentColor = $getConfig('style.accent_color', '#ff4d8d');
$titleColor = $getConfig('style.title_color', '#ffe6d1');
$textColor = $getConfig('style.text_color', '#d9b495');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(41, 24, 48, 0.88)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255, 106, 61, 0.18)');
$cardRadius = (int)$getConfig('style.card_radius', '22');
$sectionPadding = (int)$getConfig('style.section_padding', '64');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '48');

$badgeText = $getConfig('texts.badge', 'Sunflare Support');
$title = $getConfig('texts.title', 'Frequently Asked Questions');
$intro = $getConfig('texts.intro', 'Everything critical is easy to scan: pace cues, trust points, and the quick answers users usually seek first.');
$tags = array_filter([
    trim((string)$getConfig('texts.tag_1', 'Quick Rooms')),
    trim((string)$getConfig('texts.tag_2', 'Table Trust')),
    trim((string)$getConfig('texts.tag_3', 'Mobile Readability')),
]);

$defaults = [
    ['question' => 'What makes this theme different from the sunrise template?', 'answer' => 'This theme changes visual choreography: route panels, spotlight testimonials, and timeline FAQ while preserving the same config keys and PHP fallback logic.'],
    ['question' => 'Can I still override content in the visual editor?', 'answer' => 'Yes. Titles, intro, questions, answers, ratings, and display switches continue to map to existing configuration fields.'],
    ['question' => 'Is responsive behavior handled for phones first?', 'answer' => 'Yes. Sections collapse cleanly, touch targets remain generous, and horizontal areas become scroll-safe on narrow screens.'],
    ['question' => 'Can individual FAQ rows be hidden without code edits?', 'answer' => 'Yes. Empty question-answer pairs are skipped automatically, and display flags let you hide intro/title behavior quickly.'],
    ['question' => 'Will fallback content still render if values are missing?', 'answer' => 'Yes. If no valid row is configured, defaults keep the section complete and readable.'],
    ['question' => 'Can this module power standalone FAQ pages too?', 'answer' => 'Yes. The same component can be reused in FAQ page layout JSON without additional logic changes.'],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i - 1] ?? ['question' => '', 'answer' => ''];
    $question = trim((string)$getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string)$getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

if (empty($faqs)) {
    $faqs = array_slice($defaults, 0, 4);
}

$initialActiveIndex = $firstOpen ? 0 : null;
?>

<section id="<?= $componentId ?>" class="isf-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell">
        <div class="faq-layout">
            <aside class="faq-intro-pane" id="faq">
                <?php if ($showIntro && $badgeText !== ''): ?>
                    <span class="faq-badge"><?= htmlspecialchars($badgeText) ?></span>
                <?php endif; ?>

                <?php if ($showTitle): ?>
                    <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php endif; ?>

                <?php if ($showIntro && $intro !== ''): ?>
                    <p><?= htmlspecialchars($intro) ?></p>
                <?php endif; ?>

                <?php if (!empty($tags)): ?>
                    <div class="faq-tags">
                        <?php foreach ($tags as $tag): ?>
                            <span><?= htmlspecialchars($tag) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </aside>

            <div class="faq-list" role="list">
                <?php foreach ($faqs as $index => $faq): ?>
                    <?php $isOpen = $initialActiveIndex !== null && $index === $initialActiveIndex; ?>
                    <article class="faq-card<?= $isOpen ? ' is-open' : '' ?>" role="listitem" data-faq-item="<?= (int)$index ?>">
                        <button
                            type="button"
                            class="faq-trigger"
                            id="<?= $componentId ?>-trigger-<?= (int)$index ?>"
                            aria-controls="<?= $componentId ?>-panel-<?= (int)$index ?>"
                            aria-expanded="<?= $isOpen ? 'true' : 'false' ?>"
                            data-faq-trigger="<?= (int)$index ?>"
                        >
                            <span class="faq-count"><?= sprintf('%02d', $index + 1) ?></span>
                            <span class="faq-question"><?= htmlspecialchars($faq['question']) ?></span>
                            <span class="faq-indicator" aria-hidden="true">+</span>
                        </button>

                        <div
                            class="faq-panel<?= $isOpen ? ' is-open' : '' ?>"
                            id="<?= $componentId ?>-panel-<?= (int)$index ?>"
                            data-faq-panel="<?= (int)$index ?>"
                            role="region"
                            aria-labelledby="<?= $componentId ?>-trigger-<?= (int)$index ?>"
                            <?= $isOpen ? '' : 'hidden' ?>
                        >
                            <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

