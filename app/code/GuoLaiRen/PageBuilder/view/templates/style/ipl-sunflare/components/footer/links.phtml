#<?= $componentId ?> .link-column a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(255,155,74,0.92), rgba(255,106,61,0.86));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
}

#<?= $componentId ?> .link-column a:hover {
    color: <?= htmlspecialchars($linkHoverColor) ?>;
}

#<?= $componentId ?> .link-column a:hover::after {
    transform: scaleX(1);
}

#<?= $componentId ?> .footer-bottom {
    position: relative;
    z-index: 1;
    border-top: 1px solid <?= htmlspecialchars($borderColor) ?>;
    padding: 0.66rem 0;
}

#<?= $componentId ?> .footer-bottom p {
    width: min(<?= $maxWidth ?>px, calc(100% - (<?= $paddingHorizontal ?> * 2)));
    margin: 0 auto;
    color: <?= htmlspecialchars($textColor) ?>;
    font-size: 0.74rem;
    line-height: 1.5;
}

#<?= $componentId ?> .footer-disclaimer {
    margin-top: 0.28rem;
    color: <?= htmlspecialchars($textColor) ?>;
    opacity: 0.82;
}

@media (max-width: 768px) {
    #<?= $componentId ?> .footer-shell {
        grid-template-columns: minmax(0, 1fr);
        gap: 0.82rem;
    }

    #<?= $componentId ?> .link-column {
        justify-content: flex-start;
        gap: 0.32rem 0.48rem;
    }
}

@media (max-width: 520px) {
    #<?= $componentId ?> .footer-bottom p {
        font-size: 0.7rem;
    }
}
</style>
<?php if ($standaloneShell): ?>
</body>
</html>
<?php endif; ?>
