<?php
/**
 * IPL Sunflare - Footer Component
 *
 * @component_start
 * code: footer-links
 * name: 页脚链接
 * name_en: Footer Links
 * description: 暖色赛道风页脚，支持多列链接与品牌信息
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示风险提示:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no

 * group:style => 样式配置
 * style.background_color => 背景颜色:color:#271912
 * style.text_color => 文字颜色:color:#d1a98d
 * style.link_color => 链接颜色:color:#dcb993
 * style.link_hover_color => 链接悬停颜色:color:#ffe6d1
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:rgba(180,105,55,0.2)

 * group:layout => 布局设置
 * layout.max_width => 最大宽度:number:1260
 * layout.padding_horizontal => 左右内边距:responsive:10/10|px[MD]
 * layout.padding_vertical => 上下内边距:responsive:16/24|px[MD]

 * group:footer => 页脚品牌设置
 * footer.logo_text => 品牌名称:text:IPL Sunflare
 * footer.logo_url => 品牌图标:textarea:|留空使用默认图标
 * footer.tagline => 品牌副文案:text:IPL pace. Sunflare energy.
 *
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.use_subpages => 兼容旧版-使用子页面生成链接:select:no|yes,no
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nMatch Modes=>#modes\r\nAdvantages=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|配置格式：名字=>url，一行一个
 * content.copyright_text => 版权信息:text:© 2026 IPL Sunflare. All rights reserved.
 * content.disclaimer_text => 风险提示:textarea:18+ Only. IPL Sunflare is for adult users only. Play responsibly and follow your local gaming regulations.
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:

 * group:typography => 排版设置
 * typography.font_size => 字体大小:responsive:12/14|px[MD]
 * typography.line_height => 行高:number:1.65
 *
 * @fields_end
 */

$componentId = 'isf-footer-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$standaloneShell = !($this->getData('__pagebuilder_shell_managed'));

$getConfigAny = function(array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string)($parts[0] ?? '')),
        'desktop' => trim((string)($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';
$borderTop = $normalizeToggle($getConfig('style.border_top', 'yes')) !== 'no';
$backgroundColor = (string)$getConfig('style.background_color', '#271912');
$textColor = (string)$getConfig('style.text_color', '#d1a98d');
$linkColor = (string)$getConfig('style.link_color', '#dcb993');
$linkHoverColor = (string)$getConfig('style.link_hover_color', '#ffe6d1');
$borderColor = (string)$getConfig('style.border_color', 'rgba(180,105,55,0.2)');
$maxWidth = (int)$getConfig('layout.max_width', '1260');
$paddingHorizontal = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_horizontal', '10/10') . 'px'));
$paddingVertical = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_vertical', '16/24') . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float)$getConfig('typography.line_height', '1.65');

$logoText = (string)$getConfig('footer.logo_text', 'IPL Sunflare');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/ipl-logo-icon.svg');
$logoUrl = (string)$getConfig('footer.logo_url', '') ?: $logoIconUrl;
$tagline = (string)$getConfig('footer.tagline', 'IPL pace. Sunflare energy.');
$defaultCopyright = '© 2026 IPL Sunflare. All rights reserved.';
$defaultDisclaimer = '18+ Only. IPL Sunflare is for adult users only. Play responsibly and follow your local gaming regulations.';
$copyright = trim((string)$getConfig('content.copyright_text', ''));
$legacyCopyright = trim((string)$getConfig('content_footer_labels.content.copyright_text', ''));
if ($legacyCopyright !== '' && ($copyright === '' || $copyright === $defaultCopyright)) {
    $copyright = $legacyCopyright;
}
if ($copyright === '') {
    $copyright = $defaultCopyright;
}
$disclaimer = trim((string)$getConfig('content.disclaimer_text', ''));
$legacyDisclaimer = trim((string)$getConfig('content_footer_labels.content.disclaimer_text', ''));
if ($legacyDisclaimer !== '' && ($disclaimer === '' || $disclaimer === $defaultDisclaimer)) {
    $disclaimer = $legacyDisclaimer;
}
if ($disclaimer === '') {
    $disclaimer = $defaultDisclaimer;
}

$links = [];
$useCustomLinksRaw = (string)$getConfig('content.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('content.use_subpages', 'no'), 'no') !== 'yes';

if (!$useCustomLinks && $page) {
    $subpages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(20)
        : (method_exists($page, 'getNavigationPages') ? $page->getNavigationPages([], 20) : ($page->getData('subpages') ?: []));
    foreach ($subpages as $subpage) {
        $text = trim((string)($subpage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = (string)($subpage['type'] ?? '');
        $configuredLabel = trim((string)$getConfigAny([
            'content_footer_labels.content.footer_label_' . $type,
            'content.footer_label_' . $type,
        ], ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => $subpage['url'] ?? '#',
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string)$getConfig('content.footer_links', '');
    if (trim($linksConfig) === '') {
        $linksConfig = "Home=>/\nMatch Modes=>#modes\nAdvantages=>#advantages\nReviews=>#reviews\nFAQ=>#faq\nSupport=>/contact";
    }

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }

    foreach ($items as $item) {
        $item = trim((string)$item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            continue;
        }
        if (count($parts) >= 2) {
            $links[] = ['text' => $parts[0], 'href' => $parts[1]];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

?>
<?php if ($standaloneShell): ?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars((string)$logoText) ?></title>
</head>
<body>
<?php endif; ?>

<footer id="<?= $componentId ?>" class="isf-footer">
    <div class="footer-glow" aria-hidden="true"></div>

    <div class="footer-shell">
        <div class="brand-column">
            <a class="brand-link" href="/" aria-label="<?= htmlspecialchars($logoText) ?> home">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>">
                <div>
                    <strong><?= htmlspecialchars($logoText) ?></strong>
                    <span><?= htmlspecialchars($tagline) ?></span>
                </div>
            </a>
        </div>

        <?php if ($showLinks): ?>
            <nav class="link-column" aria-label="Footer links">
                <?php foreach ($links as $index => $link): ?>
                    <?php if ($index > 0): ?>
                        <span class="link-sep" aria-hidden="true">·</span>
                    <?php endif; ?>
                    <a href="<?= htmlspecialchars($link['href']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>
    </div>

    <div class="footer-bottom">
        <?php if ($showCopyright): ?>
            <p class="footer-copyright"><?= htmlspecialchars($copyright) ?></p>
        <?php endif; ?>
        <?php if ($showDisclaimer): ?>
            <p class="footer-disclaimer"><?= htmlspecialchars($disclaimer) ?></p>
        <?php endif; ?>
    </div>
</footer>

<style>
#<?= $componentId ?> {
    position: relative;
    margin-top: clamp(2.4rem, 5vw, 4rem);
    background:
        radial-gradient(520px 220px at 12% -10%, rgba(255, 106, 61, 0.24), transparent 72%),
        radial-gradient(560px 240px at 88% -8%, rgba(255, 77, 141, 0.22), transparent 72%),
        linear-gradient(180deg, <?= htmlspecialchars($backgroundColor) ?> 0%, <?= htmlspecialchars($backgroundColor) ?> 100%);
    <?php if ($borderTop): ?>border-top: 1px solid <?= htmlspecialchars($borderColor) ?>;<?php endif; ?>
    overflow: hidden;
    font-size: <?= $fontSize ?>;
    line-height: <?= htmlspecialchars((string)$lineHeight) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
}

#<?= $componentId ?> .footer-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
        repeating-linear-gradient(120deg, rgba(255,255,255,0.1) 0 1px, transparent 1px 26px),
        linear-gradient(180deg, rgba(255,255,255,0.24) 0%, rgba(255,255,255,0) 58%);
    opacity: 0.5;
}

#<?= $componentId ?> .footer-shell {
    width: min(<?= $maxWidth ?>px, calc(100% - (<?= $paddingHorizontal ?> * 2)));
    margin: 0 auto;
    padding: <?= $paddingVertical ?> 0 calc(<?= $paddingVertical ?> * 0.7);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    position: relative;
    z-index: 1;
}

#<?= $componentId ?> .brand-column {
    display: grid;
    gap: 0.9rem;
}

#<?= $componentId ?> .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    text-decoration: none;
}

#<?= $componentId ?> .brand-link img {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    border: 1px solid rgba(180, 105, 55, 0.24);
    box-shadow: 0 10px 18px rgba(180, 105, 55, 0.2);
    background: rgba(34, 21, 32, 0.72);
}

#<?= $componentId ?> .brand-link strong {
    display: block;
    color: <?= htmlspecialchars($textColor) ?>;
    font-size: 0.98rem;
    font-weight: 800;
}

#<?= $componentId ?> .brand-link span {
    display: block;
    margin-top: 0.14rem;
    color: <?= htmlspecialchars($textColor) ?>;
    font-size: 0.78rem;
    font-weight: 700;
    opacity: 0.82;
}

#<?= $componentId ?> .link-column {
    display: flex;
    flex-wrap: wrap;
    gap: 0.24rem 0.5rem;
    justify-content: flex-end;
    align-content: flex-start;
    align-items: center;
}

#<?= $componentId ?> .link-column .link-sep {
    color: #9d7457;
    font-size: 0.72rem;
    line-height: 1;
    opacity: 0.78;
}

#<?= $componentId ?> .link-column a {
    position: relative;
    color: <?= htmlspecialchars($linkColor) ?>;
    text-decoration: none;
