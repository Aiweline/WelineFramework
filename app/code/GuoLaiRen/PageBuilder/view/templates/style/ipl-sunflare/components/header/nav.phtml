<?php
/**
 * IPL Sunflare - Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航栏
 * name_en: Navigation Bar
 * description: 暖色赛道感导航，支持移动端菜单和滚动光效
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:IPL Sunflare
 * logo.subline => Logo副标题:text:Heatwave Edition
 * logo.url => Logo图片地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:responsive:46/46|px
 * logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#0f090f
 * navigation.text_color => 导航文字颜色:color:#ffe6d1
 * navigation.link_color => 链接颜色:color:#d6b29a
 * navigation.link_hover_color => 链接悬停颜色:color:#ff9671
 * navigation.items => 导航项:textarea:Home=>/\r\nMatch Modes=>#modes\r\nAdvantages=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|格式：文本=>链接
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * navigation.use_subpages => 兼容旧版-使用子页面作为导航:select:no|yes,no
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文字:text:Join Live Table
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff6a3d
 * download_button.bg_hover_color => 按钮悬停背景色:color:#ff4d8d
 * download_button.text_color => 按钮文字颜色:color:#190a13
 * @fields_end
 */

$componentId = 'isf-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);
$standaloneShell = !($this->getData('__pagebuilder_shell_managed'));

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function(array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string)($parts[0] ?? '')),
        'desktop' => trim((string)($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$sanitizeTitle = function($value) {
    $value = trim((string)$value);
    if ($value === '') return $value;
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text'], 'IPL Sunflare'));
if ($logoText === '') {
    $logoText = 'IPL Sunflare';
}
$logoSubline = trim((string)$getConfigAny(['logo.subline', 'header.logo.subline'], 'Heatwave Edition'));
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/ipl-logo-icon.svg');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '46/46') . 'px'));
$logoHeightConfig = trim((string)$getConfigAny(['logo.height', 'header.logo.height'], ''));
$logoHeight = $logoHeightConfig !== '' ? $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px')) : $logoWidth;

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = (string)$getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], '#0f090f');
$navTextColor = (string)$getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#ffe6d1');
$navLinkColor = (string)$getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#d6b29a');
$navLinkHoverColor = (string)$getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#ff9671');
$navItemsConfig = (string)$getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nMatch Modes=>#modes\nAdvantages=>#advantages\nReviews=>#reviews\nFAQ=>#faq");
$useCustomLinksRaw = $getConfig('navigation.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('navigation.use_subpages', 'no'), 'no') !== 'yes';
$useSubpages = !$useCustomLinks;
$showCta = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string)$getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Join Live Table'));
$ctaUrl = (string)$getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download');
$ctaBgColor = (string)$getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff6a3d');
$ctaBgHoverColor = (string)$getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], '#ff4d8d');
$ctaTextColor = (string)$getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#190a13');
$ctaUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($ctaUrl);

$navPatternUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/stadium-grid.svg');
$heatPatternUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/heatwave-pattern.svg');
$navItems = [];

if ($useSubpages && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $type = (string)($navPage['type'] ?? '');
        $configuredLabel = trim((string)$getConfigAny([
            'navigation_labels.navigation.label_' . $type,
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], ''));
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
            'type' => $type,
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim($line);
        if ($line === '' || strpos($line, '=>') === false) continue;
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

$pageTitleRaw = $page ? ($page->getData('title') ?: '') : '';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'IPL Sunflare';
}
