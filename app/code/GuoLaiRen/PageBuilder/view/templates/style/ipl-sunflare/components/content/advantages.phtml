$componentId = 'isf-advantages-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#2a140a');
$titleColor = $getConfig('style.title_color', '#ff9b4a');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(34, 21, 32, 0.86)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255, 106, 61, 0.16)');
$cardTitleColor = $getConfig('style.card_title_color', '#ffe6d1');
$cardDescColor = $getConfig('style.card_desc_color', '#d9b495');
$sectionPadding = (int)$getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '48');
$cardGap = (int)$getConfig('style.card_gap', '24');

$title = $getConfig('texts.title', 'Why IPL Sunflare Feels Quicker');
$kicker = trim((string)$getConfig('texts.kicker', 'IPL Sunflare Edge'));
$summary = trim((string)$getConfig('texts.summary', 'Every layer is tuned for faster room discovery, quicker match entry, and smoother repeat rounds.'));
$leadChip = trim((string)$getConfig('texts.lead_chip', 'Speed Advantage'));
$items = [
    [
        'icon' => $getConfig('texts.advantage_1_icon', '🔥'),
        'title' => $getConfig('texts.advantage_1_title', 'One-Tap Match Entry'),
        'desc' => $getConfig('texts.advantage_1_desc', 'Lobby paths are streamlined so players can choose a mode and enter a live round in seconds.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_2_icon', '📈'),
        'title' => $getConfig('texts.advantage_2_title', 'Realtime Table Heat'),
        'desc' => $getConfig('texts.advantage_2_desc', 'Live activity signals highlight active rooms first, reducing search time before every game.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_3_icon', '⚡'),
        'title' => $getConfig('texts.advantage_3_title', 'Low-Friction Mobile Flow'),
        'desc' => $getConfig('texts.advantage_3_desc', 'Tap zones and hierarchy are tuned for one-hand play, so repeat rounds stay fast and clear.'),
    ],
];

$primary = $items[0] ?? ['icon' => '🔥', 'title' => '', 'desc' => ''];
$supportCards = array_slice($items, 1);
$milestones = [
    ['label' => $getConfig('texts.metric_1_label', 'Avg Join Time'), 'value' => $getConfig('texts.metric_1_value', '< 10s')],
    ['label' => $getConfig('texts.metric_2_label', 'Live Rooms'), 'value' => $getConfig('texts.metric_2_value', '24/7 Activity')],
    ['label' => $getConfig('texts.metric_3_label', 'Tap Path'), 'value' => $getConfig('texts.metric_3_value', '2-Step Entry')],
];
?>

<section id="<?= $componentId ?>" class="isf-advantages" aria-labelledby="<?= $componentId ?>-title">
    <div class="adv-shell">
        <?php if ($showTitle): ?>
            <header class="adv-head" id="advantages">
                <?php if ($kicker !== ''): ?>
                    <span class="adv-kicker"><?= htmlspecialchars($kicker) ?></span>
                <?php endif; ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php if ($showDescription && $summary !== ''): ?>
                    <p><?= htmlspecialchars($summary) ?></p>
                <?php endif; ?>
            </header>
        <?php endif; ?>

        <div class="adv-stage" style="--isf-gap: <?= (int)$cardGap ?>px;">
            <article class="lead-card">
                <div class="lead-top">
                    <?php if ($leadChip !== ''): ?>
                        <span class="lead-chip"><?= htmlspecialchars($leadChip) ?></span>
                    <?php endif; ?>
                    <span class="lead-icon"><?= htmlspecialchars($primary['icon']) ?></span>
                </div>
                <h3><?= htmlspecialchars($primary['title']) ?></h3>
                <p><?= htmlspecialchars($primary['desc']) ?></p>

                <div class="milestone-grid" aria-label="Primary metrics">
                    <?php foreach ($milestones as $milestone): ?>
                        <article class="milestone-card">
                            <span><?= htmlspecialchars($milestone['label']) ?></span>
                            <strong><?= htmlspecialchars($milestone['value']) ?></strong>
                        </article>
                    <?php endforeach; ?>
                </div>
            </article>

            <div class="support-lane">
                <?php foreach ($supportCards as $index => $item): ?>
                    <article class="support-card">
                        <div class="support-card-head">
                            <span class="support-index"><?= sprintf('%02d', $index + 2) ?></span>
                            <span class="support-icon"><?= htmlspecialchars($item['icon']) ?></span>
                        </div>
                        <h3><?= htmlspecialchars($item['title']) ?></h3>
                        <p><?= htmlspecialchars($item['desc']) ?></p>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
