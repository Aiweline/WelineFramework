<?php
/**
 * IPL Sunflare - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: 联系方式和表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Contact IPL Sunflare
 * hero.subtitle => 页面副标题:textarea:Need help with tables, account access, or cricket-night support? Use the routes below to reach the right IPL Sunflare desk.
 * hero.bg_color => 顶部背景色:color:#1a0c18
 * hero.bg_gradient_end => 顶部渐变结束色:color:#2a1729
 * hero.title_color => 标题颜色:color:#ffe6d1
 *
 * group:panel => 面板辅助文案
 * panel.form_kicker => 表单面板提示:text:Match Desk Request
 * panel.response_title => 响应面板标题:text:Response Route
 * panel.social_title => 社交区域标题:text:Live Updates
 *
 * group:contact_info => 联系信息
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.email => 邮箱:text:support@iplsunflare.com
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:
 * social.twitter => Twitter链接:text:
 * social.linkedin => LinkedIn链接:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Request
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Topic
 * form.message_label => 消息字段标签:text:Message
 * form.name_placeholder => 姓名占位:text:Enter your name
 * form.email_placeholder => 邮箱占位:text:Enter your email
 * form.phone_placeholder => 电话占位:text:Optional
 * form.subject_placeholder => 主题占位:text:Account / Payment / Match / Partner
 * form.message_placeholder => 消息占位:textarea:Tell us what happened and what result you expect...
 * form.submit_text => 提交按钮:text:Submit Request
 * form.success_message => 成功提示:text:Share your account detail, match context, and expected outcome so the team can route it quickly.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Support hub location
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$page = $this->getData('page');
$componentId = 'ipl-contact-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'Contact IPL Sunflare';
}
$description = trim((string)$getConfig('hero.subtitle', 'Need help with tables, account access, or cricket-night support? Use the routes below to reach the right IPL Sunflare desk.'));
$heroBg = trim((string)$getConfig('hero.bg_color', '#1a0c18'));
$heroBgEnd = trim((string)$getConfig('hero.bg_gradient_end', '#2a1729'));
$heroTitleColor = trim((string)$getConfig('hero.title_color', '#ffe6d1'));
$formKicker = trim((string)$getConfig('panel.form_kicker', 'Match Desk Request'));
$responseTitle = trim((string)$getConfig('panel.response_title', 'Response Route'));
$socialTitle = trim((string)$getConfig('panel.social_title', 'Live Updates'));

$email = trim((string)$getConfig('contact_info.email', 'support@iplsunflare.com'));
$phone = trim((string)$getConfig('contact_info.phone', '+91 1800-XXX-XXXX'));
$address = trim((string)$getConfig('contact_info.address', 'Mumbai, India'));
$hours = trim((string)$getConfig('contact_info.work_hours', '24/7 Customer Support'));
$addressLabel = trim((string)$getConfig('contact_info.address_label', 'Address'));
$phoneLabel = trim((string)$getConfig('contact_info.phone_label', 'Phone'));
$emailLabel = trim((string)$getConfig('contact_info.email_label', 'Email'));
$workHoursLabel = trim((string)$getConfig('contact_info.work_hours_label', 'Support Hours'));

$formTitle = trim((string)$getConfig('form.title', 'Send A Support Request'));
$formNameLabel = trim((string)$getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string)$getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string)$getConfig('form.subject_label', 'Topic'));
$formMessageLabel = trim((string)$getConfig('form.message_label', 'Message'));
$formNamePlaceholder = trim((string)$getConfig('form.name_placeholder', 'Enter your name'));
$formEmailPlaceholder = trim((string)$getConfig('form.email_placeholder', 'Enter your email'));
$formPhonePlaceholder = trim((string)$getConfig('form.phone_placeholder', 'Optional'));
$formSubjectPlaceholder = trim((string)$getConfig('form.subject_placeholder', 'Account / Payment / Match / Partner'));
$formMessagePlaceholder = trim((string)$getConfig('form.message_placeholder', 'Tell us what happened and what result you expect...'));
$formSubmitText = trim((string)$getConfig('form.submit_text', 'Submit Request'));
$formSuccessMessage = trim((string)$getConfig('form.success_message', 'Share your account detail, match context, and expected outcome so the team can route it quickly.'));
$mapTitle = trim((string)$getConfig('map.title', 'Support hub location'));
$mapEmbedUrl = trim((string)$getConfig('map.embed_url', ''));
$mapHeight = max(240, (int)$getConfig('map.height', 360));

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];

$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string)$getConfig($key, ''));
    if ($url === '') {
        continue;
    }
    $socials[] = [
        'name' => $label,
        'url' => $url,
    ];
}

$channels = [];
if ($email !== '') {
    $channels[] = ['icon' => '📧', 'label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email];
}
if ($phone !== '') {
    $channels[] = ['icon' => '📞', 'label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone];
}
if ($address !== '') {
    $channels[] = ['icon' => '📍', 'label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address];
}
if ($hours !== '') {
    $channels[] = ['icon' => '🕐', 'label' => $workHoursLabel !== '' ? $workHoursLabel : 'Support Hours', 'value' => $hours];
}
?>

<section id="<?= $componentId ?>" class="ipl-contact">
    <div class="contact-shell">
        <header class="contact-head">
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <?php if ($showInfo && !empty($channels)): ?>
            <div class="contact-quick" aria-label="Contact channels">
                <?php foreach ($channels as $index => $channel): ?>
                    <article class="quick-card" style="--channel-delay: <?= (float)$index * 0.6 ?>s">
                        <span class="quick-icon"><?= htmlspecialchars($channel['icon']) ?></span>
                        <span class="quick-label"><?= htmlspecialchars($channel['label']) ?></span>
                        <strong><?= htmlspecialchars($channel['value']) ?></strong>
                    </article>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>

        <div class="desk-grid<?= !$showForm ? ' no-form' : '' ?>">
            <?php if ($showForm): ?>
            <section class="message-panel">
                <header class="panel-head">
                    <?php if ($formKicker !== ''): ?>
                        <span class="panel-kicker"><?= htmlspecialchars($formKicker) ?></span>
                    <?php endif; ?>
                    <?php if ($formTitle !== ''): ?>
                        <h2><?= htmlspecialchars($formTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($formSuccessMessage !== ''): ?>
                        <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                    <?php endif; ?>
                </header>

                <form class="contact-form">
                    <div class="field field-half">
                        <label><?= htmlspecialchars($formNameLabel) ?></label>
                        <input type="text" placeholder="<?= htmlspecialchars($formNamePlaceholder) ?>">
                    </div>
                    <div class="field field-half">
                        <label><?= htmlspecialchars($formEmailLabel) ?></label>
                        <input type="email" placeholder="<?= htmlspecialchars($formEmailPlaceholder) ?>">
                    </div>
                    <div class="field field-half">
                        <label><?= htmlspecialchars($phoneLabel !== '' ? $phoneLabel : 'Phone') ?></label>
                        <input type="text" placeholder="<?= htmlspecialchars($formPhonePlaceholder) ?>">
                    </div>
                    <div class="field field-half">
                        <label><?= htmlspecialchars($formSubjectLabel) ?></label>
                        <input type="text" placeholder="<?= htmlspecialchars($formSubjectPlaceholder) ?>">
                    </div>
                    <div class="field">
                        <label><?= htmlspecialchars($formMessageLabel) ?></label>
                        <textarea placeholder="<?= htmlspecialchars($formMessagePlaceholder) ?>"></textarea>
                    </div>
                    <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                </form>
            </section>
            <?php endif; ?>

            <aside class="response-panel">
                <?php if ($responseTitle !== ''): ?>
                    <h3><?= htmlspecialchars($responseTitle) ?></h3>
                <?php endif; ?>
                <?php if ($pageContent !== ''): ?>
                    <div class="response-copy"><?= $pageContent ?></div>
                <?php elseif (!empty($channels)): ?>
                    <ol class="route-list">
                        <?php foreach ($channels as $channel): ?>
                            <li>
                                <strong><?= htmlspecialchars($channel['label']) ?></strong>
                                <span><?= htmlspecialchars($channel['value']) ?></span>
                            </li>
                        <?php endforeach; ?>
                    </ol>
                <?php endif; ?>

                <?php if ($showSocial && !empty($socials)): ?>
                    <div class="social-strip">
                        <?php if ($socialTitle !== ''): ?>
                            <span><?= htmlspecialchars($socialTitle) ?></span>
                        <?php endif; ?>
                        <div class="social-links">
                            <?php foreach ($socials as $social): ?>
                                <a href="<?= htmlspecialchars($social['url']) ?>" target="_blank" rel="noopener">
                                    <?= htmlspecialchars($social['name']) ?>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    </div>
                <?php endif; ?>
            </aside>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="contact-map">
                <?php if ($mapTitle !== ''): ?>
                    <h2 class="map-title"><?= htmlspecialchars($mapTitle) ?></h2>
                <?php endif; ?>
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int)$mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

