                             alt="<?= htmlspecialchars($bannerAlt) ?>"
                             fetchpriority="high"
                             decoding="async">
                    </picture>
                </div>

                <?php if ($bannerDownloadImg): ?>
                    <?php if ($bannerDownloadUrl !== ''): ?>
                    <a class="banner-pocket"
                       href="<?= htmlspecialchars($bannerDownloadUrl) ?>"
                       aria-label="<?= htmlspecialchars($bannerDownloadAlt !== '' ? $bannerDownloadAlt : 'Download app') ?>"
                       <?php if ($bannerDownloadNewTab): ?>target="_blank" rel="noopener noreferrer"<?php endif; ?>>
                    <?php else: ?>
                    <div class="banner-pocket" aria-label="<?= htmlspecialchars($bannerDownloadAlt !== '' ? $bannerDownloadAlt : 'Download app') ?>">
