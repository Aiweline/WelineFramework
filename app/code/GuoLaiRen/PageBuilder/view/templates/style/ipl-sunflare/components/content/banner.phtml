<?php
/**
 * IPL Sunflare Banner Component
 *
 * 独立的 Banner 横幅组件，用于 content 区域
 *
 * @component_start
 * code: banner
 * name: Banner横幅
 * name_en: Banner
 * description: 首屏Banner横幅，支持响应式图片和下载按钮
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.svg
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端图片:textarea:|默认使用本地banner-2.svg
 * banner.image_desktop => PC端图片:textarea:|默认使用本地banner-03.svg
 * banner.alt => 图片描述:text:IPL Sunflare banner
 * banner.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn.svg
 * banner.download_btn_alt => 下载按钮描述:text:Download app
 * banner.download_url => 下载按钮链接:text:#download
 * banner.download_target => 新窗口打开:select:no|yes,no
 * banner.bg_color => 背景颜色:color:#120a14
 * banner.bg_gradient_end => 背景渐变色结束:color:#2b1832
 * banner.image_offset_top => 图片向上偏移:number:90|px（用于与header重叠效果）
 * banner.image_offset_top_mobile => 移动端容器向上偏移:number:26|px
 * banner.chip_1_text => 漂浮标签1:text:Heatwave
 * banner.chip_2_text => 漂浮标签2:text:Live Table
 * banner.chip_3_text => 漂浮标签3:text:Quick Join
 * banner.stack_label_left => 叠层左标签:text:Arena Cover
 * banner.stack_label_right => 叠层右标签:text:Responsive Visual
 *
 * @fields_end
 */

$componentId = 'dts-banner-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$bannerDisplay = $getConfig('banner.display', 'yes') !== 'no';
if (!$bannerDisplay) {
    return;
}

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/banner-2.svg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/banner-03.svg');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/download-btn.svg');

$bannerMobile = $getConfig('banner.image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('banner.image_desktop', '') ?: $defaultBannerDesktop;
$bannerAlt = $getConfig('banner.alt', 'IPL Sunflare banner');
$bannerDownloadImg = $getConfig('banner.download_btn_image', '') ?: $defaultDownloadBtn;
$bannerDownloadAlt = trim((string)$getConfig('banner.download_btn_alt', 'Download app'));
$bannerDownloadUrl = trim((string)$getConfig('banner.download_url', '#download'));
$bannerDownloadNewTab = $getConfig('banner.download_target', 'no') === 'yes';
$bannerBgColor = $getConfig('banner.bg_color', '#120a14');
$bannerBgGradientEnd = $getConfig('banner.bg_gradient_end', '#2b1832');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/poker-header-bg.svg');

$bannerImageOffsetTop = max(0, intval($getConfig('banner.image_offset_top', '70')));
$bannerImageOffsetTopMobile = max(0, intval($getConfig('banner.image_offset_top_mobile', '26')));
if ($bannerImageOffsetTopMobile > 40) {
    $bannerImageOffsetTopMobile = 40;
}

$chipOneText = trim((string)$getConfig('banner.chip_1_text', 'Heatwave'));
$chipTwoText = trim((string)$getConfig('banner.chip_2_text', 'Live Table'));
$chipThreeText = trim((string)$getConfig('banner.chip_3_text', 'Quick Join'));
$stackLabelLeft = trim((string)$getConfig('banner.stack_label_left', 'Arena Cover'));
$stackLabelRight = trim((string)$getConfig('banner.stack_label_right', 'Responsive Visual'));
?>

<div id="<?= $componentId ?>" class="dts-banner-component">
    <section class="dts-banner">
        <div class="banner-shell">
            <div class="banner-floaters" aria-hidden="true">
                <?php if ($chipOneText !== ''): ?><span class="floating-chip chip-a"><?= htmlspecialchars($chipOneText) ?></span><?php endif; ?>
                <?php if ($chipTwoText !== ''): ?><span class="floating-chip chip-b"><?= htmlspecialchars($chipTwoText) ?></span><?php endif; ?>
