$componentId = 'isf-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function(array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';
$showOverview = $getConfig('display.show_overview', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#081e17');
$accentColor = $getConfig('style.accent_color', '#42e7c6');
$titleColor = $getConfig('style.title_color', '#8cf5cc');
$subtitleColor = $getConfig('style.subtitle_color', '#b8e6d5');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(9, 33, 27, 0.86)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(12, 41, 34, 0.9)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(69, 189, 150, 0.22)');
$cardRadius = (int)$getConfig('style.card_radius', '24');
$sectionPadding = (int)$getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '48');
$cardGap = (int)$getConfig('style.card_gap', '24');

$title = $getConfig('texts.title', 'Choose Your Match Route');
$kicker = trim((string)$getConfig('texts.kicker', 'IPL Match Route Board'));
$subtitle = $getConfig('texts.subtitle', 'Pick the IPL route that matches your pace, from instant-entry rooms to private focused tables.');
$tagsConfig = $getConfig('texts.tags', "Turbo Entry\nLive Heat\nPrivate Rooms");
$overviewLabel = trim((string)$getConfig('texts.overview_label', 'Route Map'));
$overviewSummary = trim((string)$getConfig('texts.overview_summary', 'Routes now run in an alternating timeline lane, so players can compare pace, room style, and entry path in one scan.'));
$linkText = trim((string)$getConfig('texts.link_text', 'Enter Route'));

$tags = array_values(array_filter(array_map('trim', preg_split('/[\r\n\|]+/', $tagsConfig))));

$legacyGamesConfig = $getConfig('games.items', "Turbo Toss|Fast queue table built for short IPL rounds and quick re-entry.|#turbo\r\nClassic Arena|Balanced room with steady pace for daily IPL sessions.|#classic\r\nSunflare Prime|Premium route with refined visuals and focused match flow.|#prime\r\nPrivate Circle|Invite-only table for friend groups and controlled pace.|#private\r\nStreak Rush|High-tempo room for players chasing continuous win runs.|#streak\r\nRookie Deck|Guided route with lower pressure onboarding and clearer hints.|#rookie");
$legacyGames = [];
foreach (preg_split('/\r?\n/', str_replace('\\n', "\n", $legacyGamesConfig)) as $line) {
    $line = trim($line);
    if ($line === '') {
        continue;
    }

    $parts = array_map('trim', explode('|', $line));
    if (count($parts) >= 2) {
        $legacyGames[] = [
            'title' => $parts[0],
            'desc' => $parts[1],
            'url' => $parts[2] ?? '#',
        ];
    }
}

$cardDefaults = [
    ['title' => 'Turbo Toss', 'desc' => 'Fast queue table built for short IPL rounds and quick re-entry.', 'url' => '#turbo', 'badge' => 'Sprint Route', 'tempo' => 'Powerplay', 'focus' => 'Fast queue-in', 'mood' => 'Stadium spark'],
    ['title' => 'Classic Arena', 'desc' => 'Balanced room with steady pace for daily IPL sessions.', 'url' => '#classic', 'badge' => 'Classic Route', 'tempo' => 'Steady Overs', 'focus' => 'Balanced session', 'mood' => 'Calm rhythm'],
    ['title' => 'Sunflare Prime', 'desc' => 'Premium route with refined visuals and focused match flow.', 'url' => '#prime', 'badge' => 'Prime Route', 'tempo' => 'Prime Flow', 'focus' => 'Refined room', 'mood' => 'Polished focus'],
    ['title' => 'Private Circle', 'desc' => 'Invite-only table for friend groups and controlled pace.', 'url' => '#private', 'badge' => 'Private Route', 'tempo' => 'Private Pace', 'focus' => 'Invite control', 'mood' => 'Quiet circle'],
    ['title' => 'Streak Rush', 'desc' => 'High-tempo room for players chasing continuous win runs.', 'url' => '#streak', 'badge' => 'Streak Route', 'tempo' => 'Chase Mode', 'focus' => 'Win-streak rhythm', 'mood' => 'High pressure'],
    ['title' => 'Rookie Deck', 'desc' => 'Guided route with lower pressure onboarding and clearer hints.', 'url' => '#rookie', 'badge' => 'Rookie Route', 'tempo' => 'Warmup Lane', 'focus' => 'Beginner guide', 'mood' => 'Smooth start'],
];

$getCardValue = function ($index, $field, $default = '') use ($getConfigAny, $legacyGames, $cardDefaults) {
    $legacyCard = $legacyGames[$index - 1] ?? [];
    $fallback = $legacyCard[$field] ?? ($cardDefaults[$index - 1][$field] ?? $default);

    $keys = $field === 'url'
        ? ['game_' . $index . '.links.game_' . $index . '_url', 'links.game_' . $index . '_url']
        : ['game_' . $index . '.texts.game_' . $index . '_' . $field, 'texts.game_' . $index . '_' . $field];

    return $getConfigAny($keys, $fallback);
};

$legacyBadgeConfig = $getConfig('texts.badges', "Sprint Route\nClassic Route\nPrime Route\nPrivate Route\nStreak Route\nRookie Route");
$legacyTempoConfig = $getConfig('texts.tempo_labels', "Powerplay\nSteady Overs\nPrime Flow\nPrivate Pace\nChase Mode\nWarmup Lane");
$legacyFocusConfig = $getConfig('texts.focus_labels', "Fast queue-in\nBalanced session\nRefined room\nInvite control\nWin-streak rhythm\nBeginner guide");
$legacyMoodConfig = $getConfig('texts.mood_labels', "Stadium spark\nCalm rhythm\nPolished focus\nQuiet circle\nHigh pressure\nSmooth start");

$normalizeTextareaLines = static function ($value) {
    $value = str_replace('\\n', "\n", (string)$value);
    return array_values(array_filter(array_map('trim', preg_split('/\r?\n/', $value))));
};

$legacyBadges = $normalizeTextareaLines($legacyBadgeConfig);
$legacyTempoLabels = $normalizeTextareaLines($legacyTempoConfig);
$legacyFocusLabels = $normalizeTextareaLines($legacyFocusConfig);
$legacyMoodLabels = $normalizeTextareaLines($legacyMoodConfig);

$games = [];
for ($index = 1; $index <= 6; $index++) {
    $legacyIndex = $index - 1;
    $groupPrefix = 'game_' . $index . '.';
    $games[] = [
        'name' => $getCardValue($index, 'title'),
        'description' => $getCardValue($index, 'desc'),
        'link' => $getCardValue($index, 'url', '#'),
        'badge' => $getConfigAny([$groupPrefix . 'texts.game_' . $index . '_badge', 'texts.game_' . $index . '_badge'], $legacyBadges[$legacyIndex] ?? ($cardDefaults[$legacyIndex]['badge'] ?? 'Route')),
        'tempo' => $getConfigAny([$groupPrefix . 'texts.game_' . $index . '_tempo', 'texts.game_' . $index . '_tempo'], $legacyTempoLabels[$legacyIndex] ?? ($cardDefaults[$legacyIndex]['tempo'] ?? 'Balanced')),
        'focus' => $getConfigAny([$groupPrefix . 'texts.game_' . $index . '_focus', 'texts.game_' . $index . '_focus'], $legacyFocusLabels[$legacyIndex] ?? ($cardDefaults[$legacyIndex]['focus'] ?? 'Quick entry')),
        'mood' => $getConfigAny([$groupPrefix . 'texts.game_' . $index . '_mood', 'texts.game_' . $index . '_mood'], $legacyMoodLabels[$legacyIndex] ?? ($cardDefaults[$legacyIndex]['mood'] ?? 'Warm pace')),
    ];
}

if (empty($games)) {
    return;
}

$defaultTags = ['Quick Match Entry', 'Live Route Ladder', 'Mobile Ready'];
$tags = !empty($tags) ? $tags : $defaultTags;

?>

<section id="<?= $componentId ?>" class="isf-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head">
            <?php if ($kicker !== ''): ?>
                <span class="games-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showSubtitle): ?>
                <p class="games-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>

            <?php if ($showTags && !empty($tags)): ?>
                <div class="games-tags" aria-label="Tag highlights">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="games-layout" style="--isf-gap: <?= (int)$cardGap ?>px; --isf-radius: <?= max(16, $cardRadius) ?>px;">
            <aside class="route-overview" aria-label="Route overview">
                <?php if ($showOverview && ($overviewLabel !== '' || $overviewSummary !== '')): ?>
                    <div class="overview-head">
                        <?php if ($overviewLabel !== ''): ?>
                            <span><?= htmlspecialchars($overviewLabel) ?></span>
                        <?php endif; ?>
                        <?php if ($overviewSummary !== ''): ?>
                            <p><?= htmlspecialchars($overviewSummary) ?></p>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>

                <div class="route-track">
                    <?php foreach ($games as $index => $game): ?>
                        <article class="route-stop" style="--stop-order: <?= (int)$index ?>;">
                            <span class="stop-node" aria-hidden="true"></span>
                            <div class="stop-copy">
                                <div class="stop-head">
                                    <span class="stop-index"><?= sprintf('%02d', $index + 1) ?></span>
                                    <span class="stop-badge"><?= htmlspecialchars((string)$game['badge']) ?></span>
                                    <span class="stop-tempo"><?= htmlspecialchars((string)$game['tempo']) ?></span>
                                </div>
                                <strong><?= htmlspecialchars($game['name']) ?></strong>
                                <p class="stop-desc"><?= htmlspecialchars($game['description']) ?></p>
                                <small><?= htmlspecialchars((string)$game['focus']) ?> · <?= htmlspecialchars((string)$game['mood']) ?></small>
                            </div>
                            <a class="stop-link" href="<?= htmlspecialchars($game['link']) ?>"><?= htmlspecialchars($linkText !== '' ? $linkText : 'Enter Route') ?></a>
                        </article>
                    <?php endforeach; ?>
                </div>
            </aside>
        </div>
    </div>
</section>

