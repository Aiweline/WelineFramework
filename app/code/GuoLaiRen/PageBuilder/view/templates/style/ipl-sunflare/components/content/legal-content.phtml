    color: #1eb980;
}

#<?= $componentId ?> .legal-content blockquote {
    margin: 1.2rem 0;
    padding: 1rem 1.1rem;
    border-left: 4px solid rgba(242, 169, 59, 0.65);
    background: rgba(242, 169, 59, 0.08);
    border-radius: 0 14px 14px 0;
}

#<?= $componentId ?> .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0;
}

#<?= $componentId ?> .legal-content th,
