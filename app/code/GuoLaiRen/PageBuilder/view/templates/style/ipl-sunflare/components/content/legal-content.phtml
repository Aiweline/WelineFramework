    padding: 0.8rem 0.9rem;
    border: 1px solid rgba(122, 161, 192, 0.18);
    text-align: left;
}

#<?= $componentId ?> .legal-content th {
    color: #ffe6d1;
    background: rgba(242, 169, 59, 0.16);
}

@media (max-width: 1024px) {
    #<?= $componentId ?> .legal-layout.has-toc {
        grid-template-columns: 1fr;
    }

