    position: relative;
    padding: 84px 0;
    min-height: 100vh;
    background:
        radial-gradient(720px 360px at 10% 8%, rgba(242, 107, 79, 0.08), transparent 72%),
        radial-gradient(680px 360px at 88% 16%, rgba(242, 169, 59, 0.1), transparent 70%),
        linear-gradient(180deg, var(--ipl-legal-hero-bg) 0%, var(--ipl-legal-hero-end) 48%, var(--ipl-legal-hero-bg) 100%);
}

