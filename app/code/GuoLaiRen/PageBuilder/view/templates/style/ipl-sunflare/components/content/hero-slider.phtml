$componentId = 'isf-hero-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function(array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$display = $normalizeToggle($getConfigAny(['hero.display', 'banner.display'], 'yes')) !== 'no';
if (!$display) {
    return;
}

$sliderClasses = trim((string)$getConfig('layout.slider_classes', 'isf-hero'));
$marginTop = (int)$getConfig('layout.margin_top', 0);
$imgMarginTop = (int)$getConfig('layout.img_margin_top', 0);
$title = $getConfigAny(['hero.title', 'banner.title'], 'Play Faster in the IPL Sunflare Arena');
$heroKicker = trim((string)$getConfig('hero.kicker', 'IPL Inspired Heatwave Design'));
$subtitle = $getConfigAny(['hero.subtitle', 'banner.subtitle'], 'A warm, motion-driven landing experience built for quick sessions, clear action points, and mobile-first readability.');
$heroAlt = $getConfigAny(['hero.alt', 'banner.alt'], 'IPL Sunflare hero');
$heroBgColor = $getConfigAny(['hero.bg_color', 'banner.bg_color'], '#150912');
$ctaText = $getConfigAny(['hero.cta_text', 'banner.download_btn_alt'], 'Start Match');
$ctaUrl = $getConfigAny(['hero.cta_url', 'download_btn.url'], '#download');
$ctaSecondaryText = $getConfig('hero.secondary_cta_text', 'Explore Modes');
$ctaSecondaryUrl = $getConfig('hero.secondary_cta_url', '#modes');
$heroImage = trim((string)$getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$heroImage = $heroImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/hero-info-graphic.svg');
$heroImageMobile = trim((string)$getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$heroImageMobile = $heroImageMobile !== '' ? $heroImageMobile : $heroImage;
$bgImage = trim((string)$getConfig('hero.bg_image', ''));
$bgImage = $bgImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/ipl-sunflare/asset/img/heatwave-pattern.svg');
$downloadBtnDisplay = $normalizeToggle($getConfig('download_btn.display', 'no'), 'no') !== 'no';
$downloadBtnImage = trim((string)$getConfigAny(['download_btn.image', 'banner.download_btn_image'], ''));
$downloadBtnAlt = trim((string)$getConfigAny(['download_btn.alt', 'banner.download_btn_alt', 'hero.cta_text'], 'Join Live Table'));
$downloadBtnUrl = trim((string)$getConfigAny(['download_btn.url', 'hero.cta_url'], '#download'));

$heroSignals = [
    ['value' => $getConfig('stage.signal_1_value', '10s'), 'label' => $getConfig('stage.signal_1_label', 'Average turn')],
    ['value' => $getConfig('stage.signal_2_value', '24/7'), 'label' => $getConfig('stage.signal_2_label', 'Live activity')],
    ['value' => $getConfig('stage.signal_3_value', '1 Tap'), 'label' => $getConfig('stage.signal_3_label', 'Room entry')],
];

$heroTracks = [
    ['label' => $getConfig('stage.track_1_label', 'Fast Queue'), 'value' => $getConfig('stage.track_1_value', 'Mode selection stays one glance away')],
    ['label' => $getConfig('stage.track_2_label', 'Readable UI'), 'value' => $getConfig('stage.track_2_value', 'Cards and actions stay clear on small screens')],
    ['label' => $getConfig('stage.track_3_label', 'High Rhythm'), 'value' => $getConfig('stage.track_3_value', 'Layouts are tuned for back-to-back sessions')],
];

$heroTickerConfig = (string)$getConfig('stage.ticker_items', "Live Heat\nQuick Join\nTouch Ready\nUltra Responsive\nWarm Palette\nModular Config");
$heroTicker = array_values(array_filter(array_map('trim', preg_split('/\r?\n/', str_replace('\\n', "\n", $heroTickerConfig)))));
if (empty($heroTicker)) {
    $heroTicker = ['Live Heat', 'Quick Join', 'Touch Ready', 'Ultra Responsive', 'Warm Palette', 'Modular Config'];
}
$stageBadge = trim((string)$getConfig('stage.badge', 'Feature Spotlight'));
?>

<section id="<?= $componentId ?>" class="isf-hero <?= htmlspecialchars($sliderClasses) ?>" aria-labelledby="<?= $componentId ?>-title">
    <div class="hero-background" style="background-image: url('<?= htmlspecialchars($bgImage) ?>');"></div>

    <div class="hero-shell">
        <div class="hero-marquee" aria-label="Hero highlights">
            <div class="marquee-track">
                <?php foreach (array_merge($heroTicker, $heroTicker) as $item): ?>
                    <span><?= htmlspecialchars($item) ?></span>
                <?php endforeach; ?>
            </div>
        </div>

        <div class="hero-grid">
            <div class="hero-copy-zone">
                <?php if ($heroKicker !== ''): ?>
                    <span class="hero-kicker"><?= htmlspecialchars($heroKicker) ?></span>
                <?php endif; ?>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h1>
                <p class="hero-subtitle"><?= htmlspecialchars($subtitle) ?></p>

                <div class="hero-actions">
                    <?php if ($ctaText !== ''): ?>
                        <a class="hero-primary" href="<?= htmlspecialchars($ctaUrl) ?>"><?= htmlspecialchars($ctaText) ?></a>
                    <?php endif; ?>
                    <?php if ($ctaSecondaryText !== ''): ?>
                        <a class="hero-secondary" href="<?= htmlspecialchars($ctaSecondaryUrl) ?>"><?= htmlspecialchars($ctaSecondaryText) ?></a>
                    <?php endif; ?>
                </div>

                <div class="hero-signals" aria-label="Realtime signals">
                    <?php foreach ($heroSignals as $signal): ?>
                        <article class="signal-card">
                            <strong><?= htmlspecialchars($signal['value']) ?></strong>
                            <span><?= htmlspecialchars($signal['label']) ?></span>
                        </article>
                    <?php endforeach; ?>
                </div>
            </div>

            <div class="hero-stage-zone" id="modes">
                <div class="stage-halo halo-one" aria-hidden="true"></div>
                <div class="stage-halo halo-two" aria-hidden="true"></div>

                <div class="stage-main-card">
                    <?php if ($stageBadge !== ''): ?>
                        <span class="stage-badge"><?= htmlspecialchars($stageBadge) ?></span>
                    <?php endif; ?>
                    <div class="stage-screen">
                        <picture>
                            <source media="(max-width: 767px)" srcset="<?= htmlspecialchars($heroImageMobile) ?>">
                            <img src="<?= htmlspecialchars($heroImage) ?>" alt="<?= htmlspecialchars($heroAlt) ?>" style="margin-top: <?= (int)$imgMarginTop ?>px;">
                        </picture>
                    </div>
                </div>

                <?php if ($downloadBtnDisplay && $downloadBtnImage !== ''): ?>
                    <a class="hero-download" href="<?= htmlspecialchars($downloadBtnUrl) ?>" aria-label="<?= htmlspecialchars($downloadBtnAlt) ?>">
                        <img src="<?= htmlspecialchars($downloadBtnImage) ?>" alt="<?= htmlspecialchars($downloadBtnAlt) ?>" loading="lazy" decoding="async">
                    </a>
                <?php endif; ?>

                <div class="hero-track-list" aria-label="Feature track">
                    <?php foreach ($heroTracks as $index => $track): ?>
                        <article class="track-item">
                            <span class="track-count"><?= sprintf('%02d', $index + 1) ?></span>
                            <div>
                                <strong><?= htmlspecialchars($track['label']) ?></strong>
                                <p><?= htmlspecialchars($track['value']) ?></p>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            </div>
        </div>
    </div>
</section>

