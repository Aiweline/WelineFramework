    border: 1px solid rgba(255, 192, 129, 0.28);
    background: rgba(255, 153, 72, 0.14);
    font-size: 1.24rem;
}

#<?= $componentId ?> .value-card h3 {
    margin-top: 0.7rem;
    color: <?= htmlspecialchars($valuesTitleColor) ?>;
    font-size: 1.1rem;
}

#<?= $componentId ?> .value-card p {
    margin: 0;
    color: <?= htmlspecialchars($valuesTextColor) ?>;
    font-size: 0.92rem;
    line-height: 1.72;
}

@keyframes dts-core-pulse {
    0%,
    100% {
        transform: scale(1);
        opacity: 0.62;
    }
    50% {
        transform: scale(1.08);
        opacity: 0.9;
    }
}

