#<?= $componentId ?> .values-head {
    max-width: 760px;
}

#<?= $componentId ?> .values-head h2 {
    margin-top: 0.95rem;
    color: <?= htmlspecialchars($valuesTitleColor) ?>;
    font-size: clamp(1.85rem, 3.2vw, 2.9rem);
    line-height: 1.08;
}

#<?= $componentId ?> .values-head p {
    margin-top: 0.75rem;
    color: <?= htmlspecialchars($valuesTextColor) ?>;
    line-height: 1.75;
