<?php
/**
 * IPL Sunflare - About Content Component
 *
 * @component_start
 * code: about-content
 * name: 关于我们内容
 * name_en: About Content
 * description: 品牌关于页面内容展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_stats => 显示数据统计:select:yes|yes,no
 * display.show_values => 显示价值观:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:About IPL Sunflare
 * hero.subtitle => 页面副标题:textarea:IPL Sunflare keeps cricket-night energy, brighter scan paths, and faster table understanding across desktop and mobile.
 * hero.bg_color => 背景基础色:color:#1a0c18
 * hero.bg_gradient_end => 渐变结束色:color:#2a1729
 * hero.title_color => 标题颜色:color:#ffe8d2
 * hero.text_color => 文字颜色:color:#ffdabd
 * hero.padding => 区域内边距:number:92|px
 *
 * group:stats => 数据统计
 * stats.stat_1_number => 统计1数字:text:24/7
 * stats.stat_1_label => 统计1标签:text:Support coverage
 * stats.stat_2_number => 统计2数字:text:Fast
 * stats.stat_2_label => 统计2标签:text:Table reading flow
 * stats.stat_3_number => 统计3数字:text:Glow
 * stats.stat_3_label => 统计3标签:text:High-contrast section rhythm
 * stats.stat_4_number => 统计4数字:text:Mobile
 * stats.stat_4_label => 统计4标签:text:Responsive card system
 * stats.card_bg => 统计卡片背景基础色:color:#482539
 * stats.number_color => 统计数值颜色:color:#ff62a1
 * stats.label_color => 统计说明颜色:color:#ffd6b8
 *
 * group:story => 故事区块
 * story.title => 标题:text:Why IPL Sunflare Exists
 * story.content => 内容:textarea:IPL Sunflare keeps the original PHP data structure intact while giving cricket-style landing pages a stronger rhythm, warmer contrast, and faster visual scanning.
 * story.bg_color => 故事卡片背景基础色:color:#482539
 * story.text_color => 故事正文颜色:color:#ffd6b8
 *
 * group:values => 价值观区块
 * values.title => 标题:text:What This Theme Prioritizes
 * values.subtitle => 副标题:text:Three editable principles keep the page useful when creating new IPL-style sites.
 * values.kicker => 区块提示:text:Platform Principles
 * values.bg_color => 价值观卡片背景基础色:color:#482539
 * values.title_color => 价值观标题颜色:color:#ffe8d2
 * values.text_color => 价值观描述颜色:color:#ffd6b8
 * values.value_1_icon => 价值1图标:text:🏏
 * values.value_1_title => 价值1标题:text:Match Clarity
 * values.value_1_desc => 价值1描述:textarea:Keep room information, trust cues, and action points readable at a glance.
 * values.value_2_icon => 价值2图标:text:🔥
 * values.value_2_title => 价值2标题:text:Sunflare Motion
 * values.value_2_desc => 价值2描述:textarea:Use motion and contrast for emphasis without crowding the interface on smaller screens.
 * values.value_3_icon => 价值3图标:text:📱
 * values.value_3_title => 价值3标题:text:Responsive Entry
 * values.value_3_desc => 价值3描述:textarea:Keep the same energetic layout while preserving a smooth mobile reading path.
 *
 * @fields_end
 */

$componentId = 'ipl-about-' . uniqid();
$page = $this->getData('page');

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showSection = $getConfig('display.show_section', $getConfig('about.display', 'yes')) !== 'no';
if (!$showSection) {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';

$heroBgColor = trim((string)$getConfig('hero.bg_color', '#1a0c18'));
$heroBgGradientEnd = trim((string)$getConfig('hero.bg_gradient_end', '#2a1729'));
$heroTitleColor = trim((string)$getConfig('hero.title_color', '#ffe8d2'));
$heroTextColor = trim((string)$getConfig('hero.text_color', '#ffdabd'));
$sectionPadding = (int)$getConfig('hero.padding', '92');

$statsCardBg = trim((string)$getConfig('stats.card_bg', '#482539'));
$statsNumberColor = trim((string)$getConfig('stats.number_color', '#ff62a1'));
$statsLabelColor = trim((string)$getConfig('stats.label_color', '#ffd6b8'));

$storyBgColor = trim((string)$getConfig('story.bg_color', '#482539'));
$storyTextColor = trim((string)$getConfig('story.text_color', '#ffd6b8'));

$valuesKicker = trim((string)$getConfig('values.kicker', 'Platform Principles'));
$valuesBgColor = trim((string)$getConfig('values.bg_color', '#482539'));
$valuesTitleColor = trim((string)$getConfig('values.title_color', '#ffe8d2'));
$valuesTextColor = trim((string)$getConfig('values.text_color', '#ffd6b8'));

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'About IPL Sunflare';
}
$subtitle = trim((string)$getConfig('hero.subtitle', 'IPL Sunflare keeps cricket-night energy, brighter scan paths, and faster table understanding across desktop and mobile.'));

$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultStats = [
        ['24/7', 'Support coverage'],
        ['Fast', 'Table reading flow'],
        ['Glow', 'High-contrast section rhythm'],
        ['Mobile', 'Responsive card system'],
    ];
    $value = trim((string)$getConfig("stats.stat_{$i}_number", $defaultStats[$i - 1][0]));
    $label = trim((string)$getConfig("stats.stat_{$i}_label", $defaultStats[$i - 1][1]));
    if ($value === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'value' => $value,
        'label' => $label,
    ];
}

$storyTitle = trim((string)$getConfig('story.title', 'Why IPL Sunflare Exists'));
$storyContent = trim((string)$getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'IPL Sunflare keeps the original PHP data structure intact while giving cricket-style landing pages a stronger rhythm, warmer contrast, and faster visual scanning.';
}
$storyParagraphs = preg_split('/[\r\n]+/', trim((string)$storyContent));
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function($item) {
    return $item !== '';
}));
if (empty($storyParagraphs) && trim((string)$storyContent) !== '') {
    $storyParagraphs = [trim((string)$storyContent)];
}

$valuesTitle = trim((string)$getConfig('values.title', 'What This Theme Prioritizes'));
$valuesSubtitle = trim((string)$getConfig('values.subtitle', 'Three editable principles keep the page useful when creating new IPL-style sites.'));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $defaultValues = [
        ['🏏', 'Match Clarity', 'Keep room information, trust cues, and action points readable at a glance.'],
        ['🔥', 'Sunflare Motion', 'Use motion and contrast for emphasis without crowding the interface on smaller screens.'],
        ['📱', 'Responsive Entry', 'Keep the same energetic layout while preserving a smooth mobile reading path.'],
    ];
    $itemTitle = trim((string)$getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $itemDesc = trim((string)$getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'title' => $itemTitle,
        'description' => $itemDesc,
        'icon' => trim((string)$getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
    ];
}

$coreStat = $stats[0] ?? null;
$orbitStats = array_slice($stats, 1);
?>

<section id="<?= $componentId ?>" class="ipl-about">
    <div class="about-shell">
        <div class="hero-grid">
            <header class="sun-core">
                <h1><?= htmlspecialchars($title) ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p class="core-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>

                <?php if ($showStats && $coreStat): ?>
                    <article class="core-stat" aria-label="Primary stat">
                        <strong><?= htmlspecialchars($coreStat['value']) ?></strong>
                        <span><?= htmlspecialchars($coreStat['label']) ?></span>
                    </article>
                <?php endif; ?>
            </header>

            <aside class="story-board">
                <span class="story-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                <div class="story-flow">
                    <?php foreach ($storyParagraphs as $paragraph): ?>
                        <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                    <?php endforeach; ?>
                </div>
            </aside>
        </div>

        <?php if ($showStats && !empty($orbitStats)): ?>
            <section class="orbit-wrap" aria-label="Brand statistics">
                <?php foreach ($orbitStats as $index => $stat): ?>
                    <article class="orbit-node" style="--node-delay: <?= (float)$index * 0.8 ?>s">
                        <strong><?= htmlspecialchars($stat['value']) ?></strong>
                        <span><?= htmlspecialchars($stat['label']) ?></span>
                    </article>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-section">
                <header class="values-head">
                    <?php if ($valuesKicker !== ''): ?>
                        <span class="values-kicker"><?= htmlspecialchars($valuesKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </header>

                <div class="values-lane" role="list">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-card" role="listitem" style="--card-order: <?= (int)$index ?>">
                            <span class="value-icon"><?= htmlspecialchars($value['icon']) ?></span>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <p><?= htmlspecialchars($value['description']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>

<style>
