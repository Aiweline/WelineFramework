    }
}

@keyframes dts-node-sheen {
    0% {
        transform: translateX(-110%);
    }
    45%,
    100% {
        transform: translateX(120%);
    }
}

@media (max-width: 1080px) {
    #<?= $componentId ?> .hero-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    #<?= $componentId ?> {
        padding: 72px 0;
    }

    #<?= $componentId ?> .about-shell {
