    padding: 1rem;
    position: relative;
    overflow: hidden;
    animation: dts-orbit-float 6s ease-in-out infinite;
    animation-delay: var(--node-delay, 0s);
}

#<?= $componentId ?> .orbit-node::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 15%, rgba(255, 214, 146, 0.16) 48%, transparent 82%);
    transform: translateX(-110%);
    animation: dts-node-sheen 5.8s ease-in-out infinite;
    animation-delay: calc(var(--node-delay, 0s) + 1.1s);
    pointer-events: none;
}

#<?= $componentId ?> .orbit-node strong {
    display: block;
    color: <?= htmlspecialchars($statsNumberColor) ?>;
    font-size: 1.66rem;
    line-height: 1.06;
}

#<?= $componentId ?> .orbit-node span {
    margin-top: 0.4rem;
    display: block;
    color: <?= htmlspecialchars($statsLabelColor) ?>;
    font-size: 0.9rem;
    line-height: 1.6;
}

#<?= $componentId ?> .values-section {
    display: grid;
    gap: 1rem;
