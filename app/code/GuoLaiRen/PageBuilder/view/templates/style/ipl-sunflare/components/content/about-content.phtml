    padding: clamp(1.2rem, 2.5vw, 1.8rem);
    display: grid;
    gap: 0.9rem;
    align-content: start;
    background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0) 100%),
        <?= htmlspecialchars($storyBgColor) ?>;
}

#<?= $componentId ?> .story-kicker,
#<?= $componentId ?> .values-kicker {
    color: #ff62a1;
    border: 1px solid rgba(255, 102, 166, 0.36);
    background: rgba(255, 77, 141, 0.14);
}

#<?= $componentId ?> .story-flow {
    display: grid;
    gap: 0.8rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(255, 184, 110, 0.28);
}

#<?= $componentId ?> .story-flow p {
    margin: 0;
    color: <?= htmlspecialchars($storyTextColor) ?>;
    line-height: 1.8;
    font-size: 0.96rem;
}

