    background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0) 100%),
        <?= htmlspecialchars($valuesBgColor) ?>;
}

#<?= $componentId ?> .value-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
