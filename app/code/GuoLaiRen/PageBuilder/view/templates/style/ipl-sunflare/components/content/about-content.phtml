    border-radius: 24px;
    border: 1px solid rgba(255, 202, 146, 0.2);
    background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0) 100%),
        <?= htmlspecialchars($statsCardBg) ?>;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
}

