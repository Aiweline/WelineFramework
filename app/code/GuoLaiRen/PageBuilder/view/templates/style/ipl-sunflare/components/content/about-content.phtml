}

#<?= $componentId ?> .core-stat strong {
    color: <?= htmlspecialchars($statsNumberColor) ?>;
    font-size: clamp(1.8rem, 3.4vw, 2.8rem);
    line-height: 0.95;
}

#<?= $componentId ?> .core-stat span {
    color: <?= htmlspecialchars($statsLabelColor) ?>;
    font-size: 0.9rem;
}

