$componentId = 'isf-testimonials-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';
$showAvg = $getConfig('display.show_avg', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#131b2f');
$accentColor = $getConfig('style.accent_color', '#ff4d8d');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(34, 21, 32, 0.86)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255, 106, 61, 0.18)');
$textColor = $getConfig('style.text_color', '#ffe6d1');
$sectionPadding = (int)$getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '48');

$title = $getConfig('texts.title', 'What Players Notice First');
$kicker = trim((string)$getConfig('texts.kicker', 'Player Voices'));
$summary = trim((string)$getConfig('texts.summary', 'Real IPL player feedback, presented as a live track so visitors can scan trust signals quickly.'));
$avgSuffix = trim((string)$getConfig('texts.avg_suffix', '/ 5.0 from active route reviews'));

$parseRating = function($raw) {
    $raw = trim((string)$raw);
    if ($raw === '') return 0;
    if (is_numeric($raw)) return (int)$raw;
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    [
        'name' => 'Aarav Sinha',
        'tag' => 'Powerplay Route',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Powerplay rooms open quickly, and I can jump into the next IPL round without hunting for buttons.',
    ],
    [
        'name' => 'Meera Joshi',
        'tag' => 'Daily Chase Lobby',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'On mobile, route cards are clear and taps are stable, so entering a match feels instant.',
    ],
    [
        'name' => 'Rohan Verma',
        'tag' => 'Sunflare Prime',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Prime tables feel polished but still fast, and the warm colors make long IPL sessions easier to read.',
    ],
    [
        'name' => 'Ananya Pillai',
        'tag' => 'Private Circle',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Private room entry is straightforward, and invite flow is clean when our group starts late-night matches.',
    ],
    [
        'name' => 'Kabir Rao',
        'tag' => 'Late Overs',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'Live route comparisons help me pick pace quickly, especially when I switch between chase and rookie tables.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i - 1] ?? ['name' => '', 'tag' => '', 'rating' => '⭐⭐⭐⭐⭐', 'text' => ''];
    $name = trim((string)$getConfig("texts.testimonial_{$i}_name", $defaults['name']));
    $tag = trim((string)$getConfig("texts.testimonial_{$i}_tag", $defaults['tag']));
    $ratingText = $getConfig("texts.testimonial_{$i}_rating", $defaults['rating']);
    $content = trim((string)$getConfig("texts.testimonial_{$i}_content", $defaults['text']));
    $avatar = trim((string)$getConfig("avatars.avatar_{$i}", ''));

    if ($name !== '' && $content !== '') {
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating_text' => $ratingText,
            'rating_num' => $parseRating($ratingText),
            'content' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($testimonials)) {
    foreach ($defaultTestimonials as $defaults) {
        $testimonials[] = [
            'name' => $defaults['name'],
            'tag' => $defaults['tag'],
            'rating_text' => $defaults['rating'],
            'rating_num' => $parseRating($defaults['rating']),
            'content' => $defaults['text'],
            'avatar' => '',
        ];
    }
}

$totalRating = 0;
foreach ($testimonials as $item) {
    $totalRating += (int)$item['rating_num'];
}
$avgRating = count($testimonials) > 0 ? round($totalRating / count($testimonials), 1) : 5.0;

$rows = [[], []];
foreach ($testimonials as $index => $item) {
    $rows[$index % 2][] = $item;
}

if (empty($rows[0])) {
    $rows[0] = $testimonials;
}

if (empty($rows[1])) {
    $rows[1] = count($testimonials) > 1 ? array_reverse($testimonials) : $testimonials;
}

$ensureCards = static function(array $source, int $min = 3): array {
    if (empty($source)) {
        return [];
    }

    $expanded = $source;
    $cursor = 0;
    while (count($expanded) < $min) {
        $expanded[] = $source[$cursor % count($source)];
        $cursor++;
    }

    return $expanded;
};

$rowASeed = $ensureCards($rows[0], 3);
$rowBSeed = $ensureCards($rows[1], 3);
$rowATrack = array_merge($rowASeed, $rowASeed);
$rowBTrack = array_merge($rowBSeed, $rowBSeed);

$rowADuration = max(34, count($rowASeed) * 16);
$rowBDuration = max(40, count($rowBSeed) * 17);

$getInitials = static function($name) {
    $name = trim((string)$name);
    if ($name === '') {
        return 'U';
    }

    $parts = preg_split('/\s+/', $name);
    $initials = '';
    foreach ($parts as $part) {
        if ($part === '') continue;
        $initials .= mb_substr($part, 0, 1);
        if (mb_strlen($initials) >= 2) break;
    }

    return mb_strtoupper($initials ?: mb_substr($name, 0, 1));
};
