 * code: blog-detail
 * name: Mela Reading Stage
 * name_en: Blog Detail
 * description: Editorial article page with reading sheet, share tools, and related story ribbon.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * blog.show_sidebar|显示侧边栏|select:yes=Yes,no=No|yes
 * blog.show_cover|显示封面图|select:yes=Yes,no=No|yes
 * blog.show_author|显示作者|select:yes=Yes,no=No|yes
 * blog.show_date|显示日期|select:yes=Yes,no=No|yes
 * blog.show_tags|显示标签|select:yes=Yes,no=No|yes
 * blog.show_share|显示分享按钮|select:yes=Yes,no=No|yes
 * blog.show_related|显示相关文章|select:yes=Yes,no=No|yes
 * blog.related_count|相关文章数量|number|3
 * blog.not_found_title|未找到标题|text|Article not found
 * blog.not_found_desc|未找到描述|text|The article you are looking for is unavailable right now.
 * blog.back_to_blog_text|返回博客文案|text|Back to Blog
 * blog.breadcrumb_home_text|面包屑首页文案|text|Home
 * blog.breadcrumb_blog_text|面包屑博客文案|text|Blog
 * blog.views_suffix|阅读量后缀|text|views
 * blog.tags_title|标签标题|text|Tags
 * blog.share_title|分享标题|text|Share
 * blog.share_facebook_text|Facebook按钮文案|text|Facebook
 * blog.share_twitter_text|Twitter按钮文案|text|Twitter
 * blog.share_linkedin_text|LinkedIn按钮文案|text|LinkedIn
 * blog.share_copy_text|复制链接按钮文案|text|Copy Link
 * blog.copy_success_text|复制成功提示|text|Link copied.
 * blog.categories_title|分类标题|text|Categories
 * blog.recent_posts_title|最近文章标题|text|Recent Posts
 * blog.related_title|相关文章标题|text|Related Articles
 * @fields_end
 */

$componentId = 'mela-blog-detail-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$currentPost = $this->getData('current_post') ?: [];
$relatedPosts = $this->getData('related_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCover = $getConfig('blog.show_cover', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showTags = $getConfig('blog.show_tags', 'yes') === 'yes';
$showShare = $getConfig('blog.show_share', 'yes') === 'yes';
$showRelated = $getConfig('blog.show_related', 'yes') === 'yes';
$relatedCount = (int) $getConfig('blog.related_count', '3');
if ($relatedCount <= 0) {
    $relatedCount = 3;
}
$notFoundTitle = trim((string) $getConfig('blog.not_found_title', 'Article not found'));
$notFoundDesc = trim((string) $getConfig('blog.not_found_desc', 'The article you are looking for is unavailable right now.'));
$backToBlogText = trim((string) $getConfig('blog.back_to_blog_text', 'Back to Blog'));
$breadcrumbHomeText = trim((string) $getConfig('blog.breadcrumb_home_text', 'Home'));
$breadcrumbBlogText = trim((string) $getConfig('blog.breadcrumb_blog_text', 'Blog'));
$viewsSuffix = trim((string) $getConfig('blog.views_suffix', 'views'));
$tagsTitle = trim((string) $getConfig('blog.tags_title', 'Tags'));
$shareTitle = trim((string) $getConfig('blog.share_title', 'Share'));
$shareFacebookText = trim((string) $getConfig('blog.share_facebook_text', 'Facebook'));
$shareTwitterText = trim((string) $getConfig('blog.share_twitter_text', 'Twitter'));
$shareLinkedinText = trim((string) $getConfig('blog.share_linkedin_text', 'LinkedIn'));
$shareCopyText = trim((string) $getConfig('blog.share_copy_text', 'Copy Link'));
$copySuccessText = trim((string) $getConfig('blog.copy_success_text', 'Link copied.'));
$categoriesTitle = trim((string) $getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string) $getConfig('blog.recent_posts_title', 'Recent Posts'));
$relatedTitle = trim((string) $getConfig('blog.related_title', 'Related Articles'));

$primaryColor = $getConfig('color_scheme.primary', $colors['accent_primary'] ?? '#ff5a36');
$secondaryColor = $getConfig('color_scheme.secondary', $colors['accent_secondary'] ?? '#00c2a8');
$bgColor = $getConfig('color_scheme.background', $colors['blog_bg'] ?? 'linear-gradient(180deg, #fff7de 0%, #ffeec7 100%)');
$textColor = $getConfig('color_scheme.text', $colors['text_primary'] ?? '#2d170b');
$mutedColor = $colors['text_muted'] ?? '#97725a';
$surface = $colors['card_bg'] ?? 'rgba(255,255,255,0.82)';
$borderLight = $colors['border_light'] ?? 'rgba(45,23,11,0.12)';

$formatDate = static function ($value, $format = 'F d, Y') {
    $timestamp = strtotime((string) $value);
    return $timestamp ? date($format, $timestamp) : '';
};

$tags = [];
if (!empty($currentPost['tags'])) {
    $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', (string) $currentPost['tags']);
    $tags = array_values(array_filter(array_map('trim', $tags), static function ($tag) {
        return $tag !== '';
    }));
}

$hasRail = $showSidebar || ($showShare && !empty($currentPost)) || ($showTags && !empty($tags));
?>
<?php if (empty($currentPost)): ?>
<section id="<?= $componentId ?>" class="mela-blog-detail empty-state">
    <div class="detail-shell">
        <div class="detail-empty wow animate__fadeInUp">
            <h2><?= htmlspecialchars($notFoundTitle !== '' ? $notFoundTitle : 'Article not found') ?></h2>
            <p><?= htmlspecialchars($notFoundDesc !== '' ? $notFoundDesc : 'The article you are looking for is unavailable right now.') ?></p>
            <a class="detail-back-link" href="/blog"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
        </div>
    </div>
</section>
<style>
#<?= $componentId ?> {
    padding: clamp(7rem, 11vw, 8.6rem) 0 clamp(3rem, 6vw, 4.4rem);
    background: <?= htmlspecialchars($bgColor) ?>;
}

#<?= $componentId ?> .detail-shell {
    width: var(--mela-shell, min(1280px, calc(100% - 1.2rem)));
    margin: 0 auto;
}

#<?= $componentId ?> .detail-empty {
    padding: 1.6rem;
    border-radius: 2rem;
    border: 1px solid <?= htmlspecialchars($borderLight) ?>;
    background: <?= htmlspecialchars($surface) ?>;
    box-shadow: 0 20px 38px rgba(45,23,11,0.08);
}

#<?= $componentId ?> .detail-empty h2 {
    margin: 0;
}

#<?= $componentId ?> .detail-empty p {
    margin: 0.8rem 0 0;
    color: <?= htmlspecialchars($mutedColor) ?>;
}

#<?= $componentId ?> .detail-back-link {
    display: inline-flex;
    margin-top: 1rem;
    color: <?= htmlspecialchars($secondaryColor) ?>;
    font-weight: 700;
}
</style>
<?php else: ?>
<section id="<?= $componentId ?>" class="mela-blog-detail" aria-labelledby="<?= $componentId ?>-title">
    <span class="detail-float float-a" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="detail-float float-b" aria-hidden="true" data-mela-parallax data-mela-speed="0.06"></span>

    <div class="detail-shell">
        <nav class="detail-breadcrumb wow animate__fadeInUp" aria-label="Breadcrumb">
            <a href="/"><?= htmlspecialchars($breadcrumbHomeText !== '' ? $breadcrumbHomeText : 'Home') ?></a>
            <span>/</span>
            <a href="/blog"><?= htmlspecialchars($breadcrumbBlogText !== '' ? $breadcrumbBlogText : 'Blog') ?></a>
            <span>/</span>
            <strong><?= htmlspecialchars($currentPost['title']) ?></strong>
        </nav>

        <header class="detail-hero<?= $showCover && !empty($currentPost['cover_image']) ? ' has-cover' : '' ?>">
            <div class="hero-copy wow animate__fadeInUp">
                <?php if (!empty($currentPost['category_name'])): ?>
                    <span class="hero-chip"><?= htmlspecialchars($currentPost['category_name']) ?></span>
                <?php endif; ?>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($currentPost['title']) ?></h1>
                <div class="hero-meta">
                    <?php if ($showDate && !empty($currentPost['published_at'])): ?>
                        <span><?= htmlspecialchars($formatDate($currentPost['published_at'])) ?></span>
                    <?php endif; ?>
                    <?php if ($showAuthor && !empty($currentPost['author'])): ?>
                        <span><?= htmlspecialchars($currentPost['author']) ?></span>
                    <?php endif; ?>
                    <?php if (!empty($currentPost['view_count'])): ?>
                        <span><?= number_format((int) $currentPost['view_count']) ?> <?= htmlspecialchars($viewsSuffix !== '' ? $viewsSuffix : 'views') ?></span>
                    <?php endif; ?>
                </div>
                <?php if (!empty($currentPost['summary'])): ?>
                    <div class="hero-summary">
                        <p><?= htmlspecialchars($currentPost['summary']) ?></p>
                    </div>
                <?php endif; ?>
            </div>

            <?php if ($showCover && !empty($currentPost['cover_image'])): ?>
                <figure class="hero-cover wow animate__fadeInUp" data-wow-delay="0.06s">
                    <img src="<?= htmlspecialchars($currentPost['cover_image']) ?>" alt="<?= htmlspecialchars($currentPost['title']) ?>">
                </figure>
            <?php endif; ?>
        </header>

        <div class="detail-stage<?= $hasRail ? ' has-rail' : '' ?>">
            <article class="reading-sheet wow animate__fadeInUp" data-wow-delay="0.08s">
                <span class="reading-suits" aria-hidden="true">♠ ♥ ♦ ♣</span>
                <div class="article-content">
                    <?= $currentPost['content'] ?? '' ?>
                </div>
                <div class="article-navigation">
                    <a href="/blog"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
                </div>
            </article>

            <?php if ($hasRail): ?>
                <aside class="reader-rail">
                    <?php if ($showTags && !empty($tags)): ?>
                        <section class="rail-card wow animate__fadeInUp" aria-labelledby="<?= $componentId ?>-tags-title">
                            <h2 id="<?= $componentId ?>-tags-title"><?= htmlspecialchars($tagsTitle !== '' ? $tagsTitle : 'Tags') ?></h2>
                            <div class="tag-list">
                                <?php foreach ($tags as $tag): ?>
                                    <a href="/blog/tag/<?= urlencode($tag) ?>">#<?= htmlspecialchars($tag) ?></a>
                                <?php endforeach; ?>
                            </div>
                        </section>
                    <?php endif; ?>

                    <?php if ($showShare): ?>
                        <section class="rail-card wow animate__fadeInUp" data-wow-delay="0.04s" aria-labelledby="<?= $componentId ?>-share-title">
                            <h2 id="<?= $componentId ?>-share-title"><?= htmlspecialchars($shareTitle !== '' ? $shareTitle : 'Share') ?></h2>
                            <div class="share-grid">
                                <button type="button" data-share="facebook"><?= htmlspecialchars($shareFacebookText !== '' ? $shareFacebookText : 'Facebook') ?></button>
                                <button type="button" data-share="twitter"><?= htmlspecialchars($shareTwitterText !== '' ? $shareTwitterText : 'Twitter') ?></button>
                                <button type="button" data-share="linkedin"><?= htmlspecialchars($shareLinkedinText !== '' ? $shareLinkedinText : 'LinkedIn') ?></button>
                                <button type="button" data-share="copy"><?= htmlspecialchars($shareCopyText !== '' ? $shareCopyText : 'Copy Link') ?></button>
                            </div>
                            <p class="share-status" hidden></p>
                        </section>
                    <?php endif; ?>

                    <?php if ($showSidebar && !empty($blogCategories)): ?>
                        <section class="rail-card wow animate__fadeInUp" data-wow-delay="0.08s" aria-labelledby="<?= $componentId ?>-categories-title">
                            <h2 id="<?= $componentId ?>-categories-title"><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h2>
                            <div class="category-stack">
                                <?php foreach ($blogCategories as $category): ?>
                                    <a href="<?= htmlspecialchars($category['url']) ?>"><?= htmlspecialchars($category['name']) ?></a>
                                <?php endforeach; ?>
                            </div>
                        </section>
                    <?php endif; ?>

                    <?php if ($showSidebar && !empty($recentPosts)): ?>
                        <section class="rail-card wow animate__fadeInUp" data-wow-delay="0.1s" aria-labelledby="<?= $componentId ?>-recent-title">
                            <h2 id="<?= $componentId ?>-recent-title"><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h2>
                            <div class="recent-stack">
                                <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                    <a class="recent-item" href="<?= htmlspecialchars($post['url']) ?>">
                                        <?php if (!empty($post['cover_image'])): ?>
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                        <?php endif; ?>
                                        <span>
                                            <strong><?= htmlspecialchars($post['title']) ?></strong>
                                            <?php if (!empty($post['published_at'])): ?>
                                                <em><?= htmlspecialchars($formatDate($post['published_at'], 'M d, Y')) ?></em>
                                            <?php endif; ?>
                                        </span>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </section>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>
        </div>

        <?php if ($showRelated && !empty($relatedPosts)): ?>
            <section class="related-stage wow animate__fadeInUp" data-wow-delay="0.12s" aria-labelledby="<?= $componentId ?>-related-title">
                <header class="related-head">
                    <span class="related-suits" aria-hidden="true">♦</span>
                    <h2 id="<?= $componentId ?>-related-title"><?= htmlspecialchars($relatedTitle !== '' ? $relatedTitle : 'Related Articles') ?></h2>
                </header>
                <div class="related-grid">
                    <?php foreach (array_slice($relatedPosts, 0, $relatedCount) as $post): ?>
                        <article class="related-card">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a class="related-media" href="<?= htmlspecialchars($post['url']) ?>">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>
                            <div class="related-copy">
                                <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                <?php if (!empty($post['published_at'])): ?>
                                    <p><?= htmlspecialchars($formatDate($post['published_at'], 'M d, Y')) ?></p>
                                <?php endif; ?>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>
