<?php
/**
 * Three Patti Mela Pop - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: Mela Hero
 * name_en: Mela Hero
 * description: Poster-stacked bright hero with hero-first config, marquee motion, and download focus.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置（TPMST兼容）
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用本地banner-2.jpg
 * banner.image_desktop => PC端Banner图片:textarea:|默认使用本地banner-03.webp
 * banner.alt => Banner图片描述:text:Three Patti Mela Pop hero
 * banner.bg_color => Banner背景颜色:color:#ffe067
 *
 * group:hero => Hero设置
 * hero.display => 显示Hero:select:yes|yes,no
 * hero.title => 主标题:text:|留空使用页面标题
 * hero.subtitle => 副标题:textarea:|留空使用页面描述
 * hero.cta_text => 主按钮文字:text:Download
 * hero.cta_url => 主按钮链接:text:#download
 * hero.image => 桌面端Hero图片:textarea:|默认使用本地banner-03.webp
 * hero.image_mobile => 移动端Hero图片:textarea:|默认使用本地banner-2.jpg
 * hero.alt => Hero图片描述:text:Three Patti Mela Pop hero
 * hero.bg_color => Hero背景色:color:#ffe067
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:|默认使用本地download-btn-m.webp
 * download_btn.alt => 下载按钮描述:text:Download
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域附加类名:textarea:mela-hero-stage|Hero区域的附加类名
 * layout.margin_top => 移动端顶部重叠:number:-72|px
 * layout.img_margin_top => 桌面端图片偏移:number:0|px
 *
 * @fields_end
 */

$page = $this->getData('page') ?? $page ?? null;
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$sanitizeTitle = static function ($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$normalizeDisplay = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }

    if ($value === 0 || $value === '0') {
        return 'yes';
    }

    if ($value === 1 || $value === '1') {
        return 'no';
    }

    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$heroDisplay = $normalizeDisplay($getConfig('hero.display', $getConfig('banner.display', 'yes')));
if ($heroDisplay !== 'yes') {
    return;
}

$brandName = trim((string)$getConfig('app_info.app_name', $getConfig('texts.app_name', '')));
if ($brandName === '' && $page) {
    $brandName = (string)($page->getData('title') ?: '');
}
$brandName = $sanitizeTitle($brandName);
if ($brandName === '') {
    $brandName = 'Three Patti Mela Pop';
}

$pageTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : $brandName;
$pageTitle = $sanitizeTitle($pageTitle);
if ($pageTitle === '') {
    $pageTitle = $brandName;
}

$heroTitle = $sanitizeTitle((string)$getConfig('hero.title', ''));
$legacyBannerTitle = $sanitizeTitle((string)$getConfig('banner.alt', ''));
$legacyBannerTitleLooksSafe = $legacyBannerTitle !== ''
    && stripos($legacyBannerTitle, 'banner') === false
    && stripos($legacyBannerTitle, 'hero') === false
    && stripos($legacyBannerTitle, 'teenpatti master') === false
    && stripos($legacyBannerTitle, 'teen patti master') === false;
if ($heroTitle === '' && $legacyBannerTitleLooksSafe) {
    $heroTitle = $legacyBannerTitle;
}
if ($heroTitle === '') {
    $heroTitle = $pageTitle;
}

$heroAlt = trim((string)$getConfig('hero.alt', ''));
if ($heroAlt === '') {
    $heroAlt = trim((string)$getConfig('banner.alt', ''));
}
if ($heroAlt === '' || stripos($heroAlt, 'teenpatti master') !== false || stripos($heroAlt, 'teen patti master') !== false) {
    $heroAlt = $heroTitle;
}

$pageSummary = trim((string)$getConfig('hero.subtitle', ''));
if ($pageSummary === '') {
    $pageSummary = $page ? trim((string)($page->getData('meta_description') ?: '')) : '';
}

$bgColor = $getConfig('hero.bg_color', $getConfig('banner.bg_color', $colors['hero_bg'] ?? '#ffe067'));
$downloadBtnDisplay = $normalizeDisplay($getConfig('download_btn.display', 'yes')) === 'yes';
$heroCtaText = trim((string)$getConfig('hero.cta_text', $getConfig('download_btn.alt', $getConfig('banner.download_btn_alt', 'Download'))));
if ($heroCtaText === '' || strtolower($heroCtaText) === 'download app') {
    $heroCtaText = 'Download';
}
$downloadBtnAlt = trim((string)$getConfig('download_btn.alt', $getConfig('banner.download_btn_alt', $heroCtaText)));
if ($downloadBtnAlt === '' || strtolower($downloadBtnAlt) === 'download app') {
    $downloadBtnAlt = $heroCtaText;
}
$downloadBtnUrl = $getConfig('hero.cta_url', $getConfig('download_btn.url', '#download'));
$sliderClasses = trim((string)$getConfig('layout.slider_classes', $getConfig('banner.slider_classes', 'mela-hero-stage')));
$marginTop = (int)$getConfig('layout.margin_top', '-72');
$imgMarginTop = (int)$getConfig('layout.img_margin_top', '0');

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/download-btn-m.webp');

$bannerImageMobile = trim((string)$getConfig('hero.image_mobile', $getConfig('banner.image_mobile', '')));
$bannerImageDesktop = trim((string)$getConfig('hero.image', $getConfig('banner.image_desktop', '')));
$downloadBtnImage = trim((string)$getConfig('download_btn.image', $getConfig('banner.download_btn_image', '')));

$finalBannerMobile = $bannerImageMobile !== '' ? $bannerImageMobile : (string)($defaultBannerMobile ?? '');
$finalBannerDesktop = $bannerImageDesktop !== '' ? $bannerImageDesktop : (string)($defaultBannerDesktop ?? '');
if ($finalBannerMobile === '') {
    $finalBannerMobile = $finalBannerDesktop;
}
if ($finalBannerDesktop === '') {
    $finalBannerDesktop = $finalBannerMobile;
}
$finalDownloadBtn = $downloadBtnImage !== '' ? $downloadBtnImage : (string)($defaultDownloadBtn ?? '');

$appendHeroTag = static function (array &$tags, $value) {
    $value = trim((string)$value);
    if ($value === '' || in_array($value, $tags, true)) {
        return;
    }
    $tags[] = $value;
};

$titleWords = preg_split('/\s+/', $heroTitle !== '' ? $heroTitle : $brandName);
$titleWords = array_values(array_filter(array_map('trim', is_array($titleWords) ? $titleWords : [])));
$heroTags = [];
foreach (array_slice($titleWords, 0, 3) as $word) {
    $appendHeroTag($heroTags, $word);
}
if (count($heroTags) < 3 && $page) {
    $navigationPages = $page->getNavigationPages([], 3);
    foreach ($navigationPages as $navPage) {
        $appendHeroTag($heroTags, $navPage['title'] ?? '');
        if (count($heroTags) >= 3) {
            break;
        }
    }
}
if (count($heroTags) < 3) {
    $brandWords = preg_split('/\s+/', $brandName);
    foreach (array_values(array_filter(array_map('trim', is_array($brandWords) ? $brandWords : []))) as $word) {
        $appendHeroTag($heroTags, $word);
        if (count($heroTags) >= 3) {
            break;
        }
    }
}
if (empty($heroTags)) {
    $appendHeroTag($heroTags, $brandName !== '' ? $brandName : $pageTitle);
}
$heroTags = array_slice($heroTags, 0, 3);

$marqueeParts = array_fill(0, 5, $heroTitle);
$posterSeed = $heroTags[0] ?? ($brandName !== '' ? $brandName : $pageTitle);
$posterStamp = strtoupper(substr(preg_replace('/[^A-Za-z0-9]/', '', $posterSeed), 0, 8));
if ($posterStamp === '') {
    $posterStamp = 'APP';
}
$componentId = 'mela-hero-' . uniqid();
?>
<section id="<?= $componentId ?>" class="mela-hero <?= htmlspecialchars($sliderClasses) ?>" aria-labelledby="<?= $componentId ?>-title" data-download-anchor>
    <span class="hero-orbit orbit-a" data-mela-parallax data-mela-speed="0.05" aria-hidden="true"></span>
    <span class="hero-orbit orbit-b" data-mela-parallax data-mela-speed="0.08" aria-hidden="true"></span>
    <span class="hero-confetti confetti-a" data-mela-parallax data-mela-speed="0.04" aria-hidden="true"></span>
    <span class="hero-confetti confetti-b" data-mela-parallax data-mela-speed="0.06" aria-hidden="true"></span>

    <div class="hero-marquee" aria-hidden="true">
        <div class="hero-marquee-track">
            <?php foreach ($marqueeParts as $part): ?>
                <span><?= htmlspecialchars($part) ?></span>
            <?php endforeach; ?>
        </div>
    </div>

    <div class="hero-shell">
        <div class="hero-grid">
            <header class="hero-copy wow animate__fadeInUp">
                <span class="hero-kicker"><?= htmlspecialchars($heroTags[0] ?? $brandName) ?></span>
                <h1 id="<?= $componentId ?>-title"><span><?= htmlspecialchars($heroTitle) ?></span></h1>
                <?php if ($pageSummary !== ''): ?>
                    <p class="hero-summary"><?= htmlspecialchars($pageSummary) ?></p>
                <?php endif; ?>

                <div class="hero-chip-row" aria-label="Hero highlights">
                    <?php foreach ($heroTags as $index => $tag): ?>
                        <span class="hero-chip hero-chip-<?= (int)$index + 1 ?> wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.06 * ($index + 1), 2)) ?>s"><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>

                <?php if ($downloadBtnDisplay): ?>
                    <a class="hero-cta wow animate__fadeInUp" data-wow-delay="0.2s" href="<?= htmlspecialchars($downloadBtnUrl) ?>">
                        <span class="cta-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M12 3v10.17l3.59-3.58L17 11l-5 5-5-5 1.41-1.41L12 13.17V3h2Zm-7 14h14v2H5v-2Z" fill="currentColor"></path>
                            </svg>
                        </span>
                        <span><?= htmlspecialchars($heroCtaText) ?></span>
                    </a>
                <?php endif; ?>
            </header>

            <div class="hero-stage wow animate__fadeInRight" data-wow-delay="0.12s">
                <div class="poster-layer poster-layer-back" aria-hidden="true"></div>
                <div class="poster-layer poster-layer-mid" aria-hidden="true"></div>

                <div class="hero-mini-card mini-left">
                    <strong><?= htmlspecialchars($heroTags[1] ?? $heroTags[0]) ?></strong>
                    <span><?= htmlspecialchars($brandName) ?></span>
                </div>
                <div class="hero-mini-card mini-right">
                    <strong><?= htmlspecialchars($heroTags[2] ?? $heroTags[0]) ?></strong>
                    <span><?= htmlspecialchars($downloadBtnAlt) ?></span>
                </div>

                <article class="poster-card">
                    <span class="poster-stamp" aria-hidden="true"><?= htmlspecialchars($posterStamp) ?></span>
                    <div class="poster-notch poster-notch-left" aria-hidden="true"></div>
                    <div class="poster-notch poster-notch-right" aria-hidden="true"></div>
                    <picture>
                        <?php if ($finalBannerMobile !== ''): ?>
                            <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($finalBannerMobile) ?>">
                        <?php endif; ?>
                        <?php if ($finalBannerDesktop !== ''): ?>
                            <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($finalBannerDesktop) ?>">
                        <?php endif; ?>
                        <img src="<?= htmlspecialchars($finalBannerDesktop !== '' ? $finalBannerDesktop : $finalBannerMobile) ?>" alt="<?= htmlspecialchars($heroAlt) ?>" fetchpriority="high" decoding="async">
                    </picture>
                </article>

                <?php if ($downloadBtnDisplay && $finalDownloadBtn !== ''): ?>
                    <a class="hero-download-sticker" href="<?= htmlspecialchars($downloadBtnUrl) ?>" aria-label="<?= htmlspecialchars($downloadBtnAlt) ?>">
                        <img src="<?= htmlspecialchars($finalDownloadBtn) ?>" alt="<?= htmlspecialchars($downloadBtnAlt) ?>" loading="eager" decoding="async">
                    </a>
                <?php endif; ?>
            </div>
        </div>
    </div>
</section>
