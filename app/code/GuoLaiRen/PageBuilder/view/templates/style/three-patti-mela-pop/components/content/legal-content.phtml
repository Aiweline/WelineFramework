<?php
/**
 * Three Patti Mela Pop - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律内容
 * name_en: Legal Content
 * description: 法律内容页面组件，支持目录导航与文档内容排版
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示最后更新:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:60|px
 *
 * group:header => 页头设置
 * header.title => 页面标题:text:
 * header.icon => 页头图标:text:
 * header.updated_label => 更新时间前缀:text:Updated
 * header.bg_color => 背景颜色:color:#ffe067
 * header.bg_gradient_end => 渐变结束色:color:#ff8e3c
 * header.title_color => 标题颜色:color:#2d170b
 * header.text_color => 文字颜色:color:#6b4b34
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Contents
 * toc.items => 章节:textarea:标题|段落内容，一行一节（当页面内容为空时由配置渲染）
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.76)
 * toc.border_color => 目录边框颜色:color:rgba(45,23,11,0.12)
 *
 * group:content => 内容设置
 * content.body => 引言/正文:textarea:（当页面内容为空时显示）
 * content.empty_text => 空内容提示:text:Content will appear here.
 * content.bg_color => 内容背景基础色:color:#fff7e8
 * content.text_color => 内容文字颜色:color:#6b4b34
 * content.heading_color => 内容标题颜色:color:#ff5a36
 * content.link_color => 内容链接颜色:color:#ff5a36
 *
 * @fields_end
 */

$componentId = 'mela-legal-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showToc = $normalizeToggle($getConfig('display.show_toc', $getConfig('show_toc', 'yes'))) !== 'no';
$showLastUpdated = $normalizeToggle($getConfig('display.show_last_updated', $getConfig('show_last_updated', 'yes'))) !== 'no';
$showIcon = $normalizeToggle($getConfig('display.show_icon', $getConfig('show_icon', 'yes'))) !== 'no';

$contentWidth = $getConfig('layout.content_width', $getConfig('content_width', 'narrow'));
$headerPadding = (int) $getConfig('layout.header_padding', '80');
$contentPadding = (int) $getConfig('layout.content_padding', '60');

$pageTitle = trim((string) $getConfig('header.title', $page ? ($page->getData('title') ?: 'Policy') : 'Policy'));
if ($pageTitle === '') {
    $pageTitle = 'Policy';
}
$headerIcon = trim((string) $getConfig('header.icon', ''));
$heroBg = $getConfig('header.bg_color', $colors['hero_bg'] ?? '#ffe067');
$heroGradientEnd = $getConfig('header.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ff8e3c');
$heroTitleColor = $getConfig('header.title_color', $colors['heading_color'] ?? '#2d170b');
$heroTextColor = $getConfig('header.text_color', $colors['text_secondary'] ?? '#6b4b34');
$updatedLabelPrefix = trim((string) $getConfig('header.updated_label', 'Updated'));
$tocTitle = trim((string) $getConfig('toc.title', 'Contents'));
$tocBg = $getConfig('toc.bg_color', $colors['card_bg'] ?? 'rgba(255,255,255,0.76)');
$tocBorderColor = $getConfig('toc.border_color', $colors['border_light'] ?? 'rgba(45,23,11,0.12)');
$contentBg = $getConfig('content.bg_color', 'linear-gradient(180deg, rgba(255,255,255,0.94) 0%, rgba(255,247,232,0.94) 100%)');
$contentBgStyle = trim((string) $contentBg);
if ($contentBgStyle !== '') {
    $contentBgStyle = 'linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,250,241,0.95)), ' . $contentBgStyle;
}
$contentTextColor = $getConfig('content.text_color', $colors['text_secondary'] ?? '#6b4b34');
$contentHeadingColor = $getConfig('content.heading_color', $colors['heading_color_alt'] ?? '#ff5a36');
$contentLinkColor = $getConfig('content.link_color', $colors['link_color'] ?? '#ff5a36');
$emptyText = trim((string) $getConfig('content.empty_text', 'Content will appear here.'));

$pageType = $page ? (string) ($page->getData('type') ?: '') : '';
$pageContentRaw = trim((string) ($page ? ($page->getData('content') ?: '') : ''));
$fallbackBody = trim((string)$getConfig('content.body', ''));
$fallbackTocRaw = trim((string)$getConfig('toc.items', ''));
if ($pageContentRaw === '' && ($fallbackBody !== '' || $fallbackTocRaw !== '')) {
    $rebuiltContent = [];
    if ($fallbackBody !== '') {
        $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($fallbackBody)) . '</p>';
    }
    foreach (preg_split('/[\r\n]+/', $fallbackTocRaw) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $sectionTitle = trim((string)($parts[0] ?? ''));
        $sectionBody = trim((string)($parts[1] ?? ''));
        if ($sectionTitle === '') {
            continue;
        }
        $rebuiltContent[] = '<h2>' . htmlspecialchars($sectionTitle) . '</h2>';
        if ($sectionBody !== '') {
            $rebuiltContent[] = '<p>' . nl2br(htmlspecialchars($sectionBody)) . '</p>';
        }
    }
    $pageContentRaw = implode('', $rebuiltContent);
}
$lastUpdated = $page ? (string) ($page->getData('updated_at') ?: $page->getData('created_at') ?: '') : '';
$updatedLabel = '';
$updatedIso = '';
if ($lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $updatedLabel = date('F d, Y', $timestamp);
        $updatedIso = date('c', $timestamp);
    }
}

$typeIcons = [
    'privacy_policy' => 'P',
    'terms_of_service' => 'T',
    'refund_policy' => 'R',
    'shipping_policy' => 'S',
    'cookie_policy' => 'C',
];
$currentIcon = $headerIcon !== '' ? $headerIcon : ($typeIcons[$pageType] ?? 'L');
$maxWidth = [
    'wide' => '1280px',
    'medium' => '1080px',
    'narrow' => '920px',
][$contentWidth] ?? '920px';

$slugify = static function ($text) {
    $text = trim((string) preg_replace('/\s+/u', ' ', strip_tags($text)));
    $slug = strtolower($text);
    $slug = preg_replace('/[^a-z0-9]+/i', '-', $slug);
    return trim((string) $slug, '-') ?: 'section';
};

$tocItems = [];
$usedSlugs = [];
if ($pageContentRaw !== '' && strpos($pageContentRaw, '<') !== false) {
    $processedContent = preg_replace_callback('/<h([2-4])([^>]*)>(.*?)<\/h\1>/is', function ($matches) use (&$tocItems, &$usedSlugs, $slugify) {
        $level = (int) $matches[1];
        $attrs = (string) $matches[2];
        $inner = (string) $matches[3];
        $text = trim((string) preg_replace('/\s+/u', ' ', strip_tags($inner)));
        if ($text === '') {
            return $matches[0];
        }
        if (preg_match('/\sid=("|\')(.*?)\1/i', $attrs, $attrMatch)) {
            $id = $attrMatch[2];
        } else {
            $base = $slugify($text);
            $count = ($usedSlugs[$base] ?? 0) + 1;
            $usedSlugs[$base] = $count;
            $id = $count > 1 ? $base . '-' . $count : $base;
            $attrs .= ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '"';
        }
        $tocItems[] = ['id' => $id, 'text' => $text, 'level' => $level];
        return '<h' . $level . $attrs . '>' . $inner . '</h' . $level . '>';
    }, $pageContentRaw);
} else {
    $processedContent = $pageContentRaw !== '' ? '<p>' . nl2br(htmlspecialchars($pageContentRaw)) . '</p>' : '<p>' . htmlspecialchars($emptyText !== '' ? $emptyText : 'Content will appear here.') . '</p>';
}

$hasToc = $showToc && !empty($tocItems);
$textPrimary = $colors['text_primary'] ?? '#2d170b';
$textMuted = $colors['text_muted'] ?? '#97725a';
$borderLight = $colors['border_light'] ?? 'rgba(45,23,11,0.12)';
?>
<section id="<?= $componentId ?>" class="mela-legal-page" aria-labelledby="<?= $componentId ?>-title">
    <span class="legal-float float-a" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="legal-float float-b" aria-hidden="true" data-mela-parallax data-mela-speed="0.07"></span>

    <div class="legal-shell" style="max-width: <?= htmlspecialchars($maxWidth) ?>;">
        <header class="legal-masthead wow animate__fadeInUp">
            <?php if ($showIcon): ?>
                <span class="legal-seal" aria-hidden="true"><?= htmlspecialchars($currentIcon) ?></span>
            <?php endif; ?>
            <div class="legal-headings">
                <span class="legal-suits" aria-hidden="true">♠ ♥ ♦ ♣</span>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($pageTitle) ?></h1>
                <?php if ($showLastUpdated && $updatedLabel !== ''): ?>
                    <p><?php if ($updatedLabelPrefix !== ''): ?><?= htmlspecialchars($updatedLabelPrefix) ?> <?php endif; ?><time datetime="<?= htmlspecialchars($updatedIso) ?>"><?= htmlspecialchars($updatedLabel) ?></time></p>
                <?php endif; ?>
            </div>
        </header>

        <div class="legal-assembly<?= !$hasToc ? ' no-toc' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-index wow animate__fadeInUp" aria-labelledby="<?= $componentId ?>-toc-title">
                    <h2 id="<?= $componentId ?>-toc-title"><?= htmlspecialchars($tocTitle !== '' ? $tocTitle : 'Contents') ?></h2>
                    <nav aria-label="Legal contents navigation">
                        <ol>
                            <?php foreach ($tocItems as $index => $item): ?>
                                <li class="level-<?= (int) $item['level'] ?>">
                                    <a href="#<?= htmlspecialchars($item['id']) ?>">
                                        <span class="toc-number"><?= str_pad((string) ($index + 1), 2, '0', STR_PAD_LEFT) ?></span>
                                        <span class="toc-text"><?= htmlspecialchars($item['text']) ?></span>
                                    </a>
                                </li>
                            <?php endforeach; ?>
                        </ol>
                    </nav>
                </aside>
            <?php endif; ?>

            <article class="legal-document wow animate__fadeInUp" data-wow-delay="0.08s">
                <div class="legal-binder" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
                <div class="legal-prose">
                    <?= $processedContent ?>
                </div>
            </article>
        </div>
    </div>
</section>
