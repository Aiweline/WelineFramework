<?php
/**
 * Three Patti Mela Pop - Blog List Component
 *
 * @component_start
 * code: blog-list
 * name: Mela Blog Showcase
 * name_en: Blog List
 * description: Magazine-style blog landing page with spotlight story, support rail, and reading shelf.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * blog.title|博客标题|text|Latest Blog Posts
 * blog.subtitle|副标题|text|Stay updated with our latest news and table notes.
 * blog.posts_per_page|每页文章数|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=Yes,no=No|yes
 * blog.show_category|显示分类|select:yes=Yes,no=No|yes
 * blog.show_date|显示日期|select:yes=Yes,no=No|yes
 * blog.show_author|显示作者|select:yes=Yes,no=No|yes
 * blog.card_style|卡片样式|select:default=Default,minimal=Minimal,featured=Featured|default
 * blog.empty_title|空状态标题|text|No articles published yet
 * blog.empty_desc|空状态描述|text|Please check back soon for new updates and playing guides.
 * blog.read_article_text|首篇文章按钮文案|text|Read Article
 * blog.read_more_text|列表按钮文案|text|Read More
 * blog.categories_title|分类标题|text|Categories
 * blog.recent_posts_title|最近文章标题|text|Recent Posts
 * @fields_end
 */

$componentId = 'mela-blog-list-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$title = trim((string) $getConfig('blog.title', 'Latest Blog Posts'));
$subtitle = trim((string) $getConfig('blog.subtitle', 'Stay updated with our latest news and table notes.'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = trim((string) $getConfig('blog.card_style', 'default'));
if (!in_array($cardStyle, ['default', 'minimal', 'featured'], true)) {
    $cardStyle = 'default';
}
$emptyTitle = trim((string) $getConfig('blog.empty_title', 'No articles published yet'));
$emptyDesc = trim((string) $getConfig('blog.empty_desc', 'Please check back soon for new updates and playing guides.'));
$readArticleText = trim((string) $getConfig('blog.read_article_text', 'Read Article'));
$readMoreText = trim((string) $getConfig('blog.read_more_text', 'Read More'));
$categoriesTitle = trim((string) $getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string) $getConfig('blog.recent_posts_title', 'Recent Posts'));

$primaryColor = $getConfig('color_scheme.primary', $colors['accent_primary'] ?? '#ff5a36');
$secondaryColor = $getConfig('color_scheme.secondary', $colors['accent_secondary'] ?? '#00c2a8');
$bgColor = $getConfig('color_scheme.background', $colors['blog_bg'] ?? 'linear-gradient(180deg, #fff7de 0%, #ffeec7 100%)');
$textColor = $getConfig('color_scheme.text', $colors['text_primary'] ?? '#2d170b');
$mutedColor = $colors['text_muted'] ?? '#97725a';
$surface = $colors['card_bg'] ?? 'rgba(255,255,255,0.76)';
$borderLight = $colors['border_light'] ?? 'rgba(45,23,11,0.12)';

$excerpt = static function ($text, $length = 150) {
    $text = trim((string) $text);
    if ($text === '') {
        return '';
    }
    return mb_strlen($text) > $length ? mb_substr($text, 0, $length) . '...' : $text;
};
$formatDate = static function ($value) {
    $timestamp = strtotime((string) $value);
    return $timestamp ? date('M d, Y', $timestamp) : '';
};

$leadPost = $blogPosts[0] ?? null;
$featureRail = array_slice($blogPosts, 1, 2);
$gridPosts = array_slice($blogPosts, 3);
if ($leadPost === null && !empty($featureRail)) {
    $leadPost = array_shift($featureRail);
}
?>
<section id="<?= $componentId ?>" class="mela-blog-list mode-<?= htmlspecialchars($cardStyle) ?>" aria-labelledby="<?= $componentId ?>-title">
    <span class="blog-float float-a" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="blog-float float-b" aria-hidden="true" data-mela-parallax data-mela-speed="0.06"></span>

    <div class="blog-shell">
        <header class="blog-showcase<?= $leadPost ? ' has-lead' : '' ?>">
            <div class="showcase-copy wow animate__fadeInUp">
                <span class="showcase-suits" aria-hidden="true">♠ ♥ ♦ ♣</span>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title !== '' ? $title : 'Latest Blog Posts') ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>

                <?php if (!empty($blogCategories)): ?>
                    <nav class="category-lane" aria-label="Blog categories">
                        <?php foreach (array_slice($blogCategories, 0, 7) as $index => $category): ?>
                            <a class="category-pill wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.04 * (($index % 6) + 1), 2)) ?>s" href="<?= htmlspecialchars($category['url']) ?>">
                                <span><?= htmlspecialchars($category['name']) ?></span>
                                <?php if (isset($category['post_count'])): ?>
                                    <em><?= (int) $category['post_count'] ?></em>
                                <?php endif; ?>
                            </a>
                        <?php endforeach; ?>
                    </nav>
                <?php endif; ?>
            </div>

            <?php if ($leadPost): ?>
                <article class="lead-story wow animate__fadeInUp" data-wow-delay="0.05s">
                    <?php if (!empty($leadPost['cover_image'])): ?>
                        <a class="lead-media" href="<?= htmlspecialchars($leadPost['url']) ?>">
                            <img src="<?= htmlspecialchars($leadPost['cover_image']) ?>" alt="<?= htmlspecialchars($leadPost['title']) ?>" loading="lazy" decoding="async">
                        </a>
                    <?php endif; ?>
                    <div class="lead-copy">
                        <div class="post-meta">
                            <?php if ($showCategory && !empty($leadPost['category_name'])): ?>
                                <span class="meta-chip"><?= htmlspecialchars($leadPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($leadPost['published_at'])): ?>
                                <span class="meta-date"><?= htmlspecialchars($formatDate($leadPost['published_at'])) ?></span>
                            <?php endif; ?>
                        </div>
                        <h2><a href="<?= htmlspecialchars($leadPost['url']) ?>"><?= htmlspecialchars($leadPost['title']) ?></a></h2>
                        <?php if (!empty($leadPost['summary'])): ?>
                            <p><?= htmlspecialchars($excerpt($leadPost['summary'], 220)) ?></p>
                        <?php endif; ?>
                        <div class="lead-foot">
                            <?php if ($showAuthor && !empty($leadPost['author'])): ?>
                                <span class="meta-author"><?= htmlspecialchars($leadPost['author']) ?></span>
                            <?php endif; ?>
                            <a class="story-link" href="<?= htmlspecialchars($leadPost['url']) ?>"><?= htmlspecialchars($readArticleText !== '' ? $readArticleText : 'Read Article') ?></a>
                        </div>
                    </div>
                </article>
            <?php endif; ?>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="blog-empty wow animate__fadeInUp">
                <h2><?= htmlspecialchars($emptyTitle !== '' ? $emptyTitle : 'No articles published yet') ?></h2>
                <p><?= htmlspecialchars($emptyDesc !== '' ? $emptyDesc : 'Please check back soon for new updates and playing guides.') ?></p>
            </div>
        <?php else: ?>
            <div class="blog-stage<?= $showSidebar ? '' : ' no-sidebar' ?>">
                <div class="blog-feed">
                    <?php if (!empty($featureRail)): ?>
                        <section class="feature-rail" aria-label="Featured stories">
                            <?php foreach ($featureRail as $index => $post): ?>
                                <article class="rail-card wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.05 * ($index + 1), 2)) ?>s">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <a class="rail-media" href="<?= htmlspecialchars($post['url']) ?>">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>
                                    <div class="rail-copy">
                                        <div class="post-meta">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span class="meta-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span class="meta-date"><?= htmlspecialchars($formatDate($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>
                                        <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                        <?php if (!empty($post['summary'])): ?>
                                            <p><?= htmlspecialchars($excerpt($post['summary'], 150)) ?></p>
                                        <?php endif; ?>
                                        <div class="rail-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span class="meta-author"><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a class="story-link" href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </section>
                    <?php endif; ?>

                    <?php if (!empty($gridPosts)): ?>
                        <section class="story-grid" aria-label="More stories">
                            <?php foreach ($gridPosts as $index => $post): ?>
                                <article class="story-card wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.04 * (($index % 6) + 1), 2)) ?>s">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <a class="story-media" href="<?= htmlspecialchars($post['url']) ?>">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>
                                    <div class="story-copy">
                                        <div class="post-meta">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span class="meta-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span class="meta-date"><?= htmlspecialchars($formatDate($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>
                                        <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                        <?php if (!empty($post['summary'])): ?>
                                            <p><?= htmlspecialchars($excerpt($post['summary'], 135)) ?></p>
                                        <?php endif; ?>
                                        <div class="story-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span class="meta-author"><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a class="story-link" href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </section>
                    <?php endif; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="blog-sidebar">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="sidebar-card wow animate__fadeInUp" aria-labelledby="<?= $componentId ?>-categories-title">
                                <h2 id="<?= $componentId ?>-categories-title"><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h2>
                                <div class="sidebar-list category-stack">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>">
                                            <span><?= htmlspecialchars($category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <em><?= (int) $category['post_count'] ?></em>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="sidebar-card wow animate__fadeInUp" data-wow-delay="0.08s" aria-labelledby="<?= $componentId ?>-recent-title">
                                <h2 id="<?= $componentId ?>-recent-title"><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h2>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a class="recent-item" href="<?= htmlspecialchars($post['url']) ?>">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <em><?= htmlspecialchars($formatDate($post['published_at'])) ?></em>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>
