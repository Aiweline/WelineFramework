<?php
/**
 * Three Patti Mela Pop - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们
 * name_en: Contact Content
 * description: 联系页面内容组件，展示联系信息、社交方式、表单与地图
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 页面头部
 * hero.title => 页面标题:text:Contact Us
 * hero.subtitle => 页面副标题:textarea:We would love to hear from you. Reach the right desk through the routes below.
 * hero.bg_color => 背景颜色:color:#ffe067
 * hero.bg_gradient_end => 渐变结束色:color:#ff8e3c
 * hero.title_color => 标题颜色:color:#2d170b
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@example.com
 * contact_info.work_hours_label => 工作时间标签:text:Hours
 * contact_info.work_hours => 工作时间:text:24/7 Support
 *
 * group:social => 社交链接
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook:text:
 * social.twitter => Twitter:text:
 * social.linkedin => LinkedIn:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send us a Message
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.submit_text => 提交按钮文字:text:Send Message
 * form.success_message => 成功提示:text:Thanks for your message. We will get back to you soon.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Location map
 * map.embed_url => 地图嵌入地址:textarea:
 * map.height => 地图高度:number:400|px
 *
 * @fields_end
 */

$componentId = 'mela-contact-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showMap = $normalizeToggle($getConfig('display.show_map', $getConfig('show_map', 'yes'))) !== 'no';
$showForm = $normalizeToggle($getConfig('display.show_form', $getConfig('show_form', 'yes'))) !== 'no';
$showSocial = $normalizeToggle($getConfig('display.show_social', $getConfig('show_social', 'yes'))) !== 'no';
$showInfo = $normalizeToggle($getConfig('display.show_info', $getConfig('show_info', 'yes'))) !== 'no';

$pageTitle = trim((string) $getConfig('hero.title', $page ? ($page->getData('title') ?: 'Contact Us') : 'Contact Us'));
if ($pageTitle === '') {
    $pageTitle = 'Contact Us';
}
$pageSubtitle = trim((string) $getConfig('hero.subtitle', $page ? ($page->getData('meta_description') ?: '') : ''));
$pageIntro = $page ? (string) ($page->getData('content') ?: '') : '';

$heroBg = $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#ffe067');
$heroGradientEnd = $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ff8e3c');
$heroTitleColor = $getConfig('hero.title_color', $colors['heading_color'] ?? '#2d170b');

$addressLabel = trim((string) $getConfig('contact_info.address_label', 'Address'));
$address = trim((string) $getConfig('contact_info.address', 'Mumbai, India'));
$phoneLabel = trim((string) $getConfig('contact_info.phone_label', 'Phone'));
$phone = trim((string) $getConfig('contact_info.phone', '+91 1800-XXX-XXXX'));
$emailLabel = trim((string) $getConfig('contact_info.email_label', 'Email'));
$email = trim((string) $getConfig('contact_info.email', 'support@example.com'));
$workHoursLabel = trim((string) $getConfig('contact_info.work_hours_label', 'Hours'));
$workHours = trim((string) $getConfig('contact_info.work_hours', '24/7 Support'));

$socialSeed = [
    'WeChat' => trim((string) $getConfig('social.wechat', '')),
    'Weibo' => trim((string) $getConfig('social.weibo', '')),
    'Facebook' => trim((string) $getConfig('social.facebook', '')),
    'Twitter' => trim((string) $getConfig('social.twitter', '')),
    'LinkedIn' => trim((string) $getConfig('social.linkedin', '')),
];
$socials = [];
foreach ($socialSeed as $label => $value) {
    if ($value === '') {
        continue;
    }
    $socials[] = [
        'label' => $label,
        'value' => $value,
        'href' => preg_match('/^https?:\/\//i', $value) ? $value : '',
        'mark' => strtoupper(substr(preg_replace('/[^A-Za-z]/', '', $label), 0, 2) ?: substr($label, 0, 2)),
    ];
}

$formTitle = trim((string) $getConfig('form.title', 'Send us a Message'));
$formNameLabel = trim((string) $getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string) $getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string) $getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string) $getConfig('form.message_label', 'Message'));
$formSubmitText = trim((string) $getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string) $getConfig('form.success_message', 'Thanks for your message. We will get back to you soon.'));
$mapTitle = trim((string) $getConfig('map.title', 'Location map'));
$mapEmbedUrl = trim((string) $getConfig('map.embed_url', ''));
$mapHeight = (int) $getConfig('map.height', '400');
if ($mapHeight < 280) {
    $mapHeight = 280;
}

$textPrimary = $colors['text_primary'] ?? '#2d170b';
$textSecondary = $colors['text_secondary'] ?? '#6b4b34';
$textMuted = $colors['text_muted'] ?? '#97725a';
$borderLight = $colors['border_light'] ?? 'rgba(45,23,11,0.12)';
$surface = $colors['card_bg'] ?? 'rgba(255,255,255,0.76)';
$buttonBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #ff5a36 0%, #ffb703 100%)';
$buttonText = $colors['button_primary_text'] ?? '#fffdf8';
$accentPrimary = $colors['accent_primary'] ?? '#ff5a36';
$accentSecondary = $colors['accent_secondary'] ?? '#00c2a8';

$routeSeed = [
    ['label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address, 'href' => ''],
    ['label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone, 'href' => $phone !== '' ? 'tel:' . preg_replace('/\s+/', '', $phone) : ''],
    ['label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email, 'href' => $email !== '' ? 'mailto:' . $email : ''],
    ['label' => $workHoursLabel !== '' ? $workHoursLabel : 'Hours', 'value' => $workHours, 'href' => ''],
];
$contactItems = [];
foreach ($routeSeed as $route) {
    if (trim((string) $route['value']) === '') {
        continue;
    }
    $contactItems[] = $route;
}
foreach ($contactItems as $index => &$route) {
    $route['slot'] = str_pad((string) ($index + 1), 2, '0', STR_PAD_LEFT);
}
unset($route);

$hasBrief = $showInfo && ($pageIntro !== '' || ($showSocial && !empty($socials)));
$hasRoutes = $showInfo && !empty($contactItems);
?>
<section id="<?= $componentId ?>" class="mela-contact-page" aria-labelledby="<?= $componentId ?>-title">
    <span class="contact-float float-a" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="contact-float float-b" aria-hidden="true" data-mela-parallax data-mela-speed="0.06"></span>

    <div class="contact-shell">
        <header class="contact-hero<?= $hasRoutes ? ' has-routes' : ' hero-copy-only' ?>">
            <div class="hero-copy wow animate__fadeInUp">
                <span class="hero-suits" aria-hidden="true">♠ ♥ ♦ ♣</span>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($pageTitle) ?></h1>
                <?php if ($pageSubtitle !== ''): ?>
                    <p><?= htmlspecialchars($pageSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <?php if ($hasRoutes): ?>
                <dl class="route-board" aria-label="Contact routes">
                    <?php foreach ($contactItems as $index => $item): ?>
                        <div class="route-card wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.05 * ($index + 1), 2)) ?>s">
                            <dt>
                                <span class="route-order"><?= htmlspecialchars($item['slot']) ?></span>
                                <span class="route-label"><?= htmlspecialchars($item['label']) ?></span>
                            </dt>
                            <?php echo '<dd>'; ?>
                            <?php if ($item['href'] !== ''): ?>
                                <a href="<?= htmlspecialchars($item['href']) ?>"><?= htmlspecialchars($item['value']) ?></a>
                            <?php else: ?>
                                <p><?= nl2br(htmlspecialchars($item['value'])) ?></p>
                            <?php endif; ?>
                            <?php echo '</dd>'; ?>
                        </div>
                    <?php endforeach; ?>
                </dl>
            <?php endif; ?>
        </header>

        <?php if ($hasBrief || $showForm): ?>
            <div class="contact-stage<?= (!$hasBrief || !$showForm) ? ' stage-single' : '' ?>">
                <?php if ($hasBrief): ?>
                    <section class="contact-brief" aria-labelledby="<?= $componentId ?>-brief-title">
                        <div class="brief-card wow animate__fadeInUp">
                            <h2 id="<?= $componentId ?>-brief-title"><?= htmlspecialchars($pageTitle) ?></h2>
                            <?php if ($pageIntro !== ''): ?>
                                <div class="brief-prose"><?= $pageIntro ?></div>
                            <?php endif; ?>
                        </div>

                        <?php if ($showSocial && !empty($socials)): ?>
                            <div class="social-shelf" aria-label="Social links">
                                <?php foreach ($socials as $index => $social): ?>
                                    <?php if ($social['href'] !== ''): ?>
                                        <a
                                            class="social-card wow animate__fadeInUp"
                                            data-wow-delay="<?= htmlspecialchars(number_format(0.05 * (($index % 5) + 1), 2)) ?>s"
                                            href="<?= htmlspecialchars($social['href']) ?>"
                                            target="_blank"
                                            rel="noopener"
                                        >
                                            <span class="social-mark" aria-hidden="true"><?= htmlspecialchars($social['mark']) ?></span>
                                            <span class="social-meta">
                                                <strong><?= htmlspecialchars($social['label']) ?></strong>
                                                <small><?= htmlspecialchars($social['value']) ?></small>
                                            </span>
                                        </a>
                                    <?php else: ?>
                                        <div
                                            class="social-card wow animate__fadeInUp"
                                            data-wow-delay="<?= htmlspecialchars(number_format(0.05 * (($index % 5) + 1), 2)) ?>s"
                                        >
                                            <span class="social-mark" aria-hidden="true"><?= htmlspecialchars($social['mark']) ?></span>
                                            <span class="social-meta">
                                                <strong><?= htmlspecialchars($social['label']) ?></strong>
                                                <small><?= htmlspecialchars($social['value']) ?></small>
                                            </span>
                                        </div>
                                    <?php endif; ?>
                                <?php endforeach; ?>
                            </div>
                        <?php endif; ?>
                    </section>
                <?php endif; ?>

                <?php if ($showForm): ?>
                    <section class="contact-form-panel wow animate__fadeInUp" data-wow-delay="0.08s" aria-labelledby="<?= $componentId ?>-form-title">
                        <div class="form-head">
                            <div>
                                <span class="form-suits" aria-hidden="true">♠</span>
                                <h2 id="<?= $componentId ?>-form-title"><?= htmlspecialchars($formTitle !== '' ? $formTitle : 'Send us a Message') ?></h2>
                                <?php if ($formSuccessMessage !== ''): ?>
                                    <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                                <?php endif; ?>
                            </div>
                        </div>

                        <form class="contact-form" action="#" method="post" onsubmit="return false;" data-success-text="<?= htmlspecialchars($formSuccessMessage) ?>">
                            <div class="field-grid">
                                <label>
                                    <span><?= htmlspecialchars($formNameLabel !== '' ? $formNameLabel : 'Full Name') ?></span>
                                    <input type="text" name="name" autocomplete="name" placeholder="Your name" required>
                                </label>
                                <label>
                                    <span><?= htmlspecialchars($formEmailLabel !== '' ? $formEmailLabel : 'Email Address') ?></span>
                                    <input type="email" name="email" autocomplete="email" placeholder="name@example.com" required>
                                </label>
                            </div>
                            <label>
                                <span><?= htmlspecialchars($formSubjectLabel !== '' ? $formSubjectLabel : 'Subject') ?></span>
                                <input type="text" name="subject" placeholder="Account, gameplay, or payout issue">
                            </label>
                            <label>
                                <span><?= htmlspecialchars($formMessageLabel !== '' ? $formMessageLabel : 'Message') ?></span>
                                <textarea name="message" rows="6" placeholder="Share your table, UID, device, or payment details so the support desk can route the request quickly." required></textarea>
                            </label>
                            <button type="submit">
                                <span><?= htmlspecialchars($formSubmitText !== '' ? $formSubmitText : 'Send Message') ?></span>
                            </button>
                            <p class="contact-form-status" hidden></p>
                        </form>
                    </section>
                <?php endif; ?>
            </div>
        <?php endif; ?>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="contact-map wow animate__fadeInUp" data-wow-delay="0.12s" aria-label="<?= htmlspecialchars($mapTitle !== '' ? $mapTitle : 'Location map') ?>">
                <div class="map-frame">
                    <span class="map-suits" aria-hidden="true">♣</span>
                    <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" title="<?= htmlspecialchars($mapTitle !== '' ? $mapTitle : 'Location map') ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>
