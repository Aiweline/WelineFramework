<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }
    var form = root.querySelector('.contact-form');
    if (!form) {
        return;
    }
    var status = form.querySelector('.contact-form-status');
    form.addEventListener('submit', function (event) {
        event.preventDefault();
        if (!status) {
            return;
        }
        status.hidden = false;
        status.textContent = form.getAttribute('data-success-text') || 'Thanks for your message.';
        form.reset();
    });
})();
</script>
