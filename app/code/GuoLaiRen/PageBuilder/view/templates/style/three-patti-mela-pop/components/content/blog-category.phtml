<?php
/**
 * Three Patti Mela Pop - Blog Category Component
 *
 * @component_start
 * code: blog-category
 * name: Mela Category Stream
 * name_en: Blog Category
 * description: Flowing category archive with spotlight lead, alternating stream cards, and bright archive rail.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * blog.title|博客标题|text|Category Posts
 * blog.subtitle|副标题|text|Browse articles by category
 * blog.show_sidebar|显示侧边栏|select:yes=Yes,no=No|yes
 * blog.show_category|显示分类|select:yes=Yes,no=No|yes
 * blog.show_date|显示日期|select:yes=Yes,no=No|yes
 * blog.show_author|显示作者|select:yes=Yes,no=No|yes
 * blog.card_style|卡片样式|select:default=Default,minimal=Minimal,featured=Featured|default
 * blog.article_singular|文章数量单数标签|text|Article
 * blog.article_plural|文章数量复数标签|text|Articles
 * blog.empty_title|空状态标题|text|No posts in this category yet
 * blog.empty_desc|空状态描述|text|Check back later or return to the main blog list.
 * blog.back_to_blog_text|返回博客文案|text|Back to Blog
 * blog.read_article_text|聚焦文章按钮文案|text|Read Article
 * blog.read_more_text|列表按钮文案|text|Read More
 * blog.categories_title|分类标题|text|Categories
 * blog.recent_posts_title|最近文章标题|text|Recent Posts
 * @fields_end
 */

$componentId = 'mela-blog-category-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$title = trim((string) $getConfig('blog.title', $currentCategory['name'] ?? 'Category Posts'));
$subtitle = trim((string) $getConfig('blog.subtitle', 'Browse articles by category'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = trim((string) $getConfig('blog.card_style', 'default'));
if (!in_array($cardStyle, ['default', 'minimal', 'featured'], true)) {
    $cardStyle = 'default';
}
$articleSingular = trim((string) $getConfig('blog.article_singular', 'Article'));
$articlePlural = trim((string) $getConfig('blog.article_plural', 'Articles'));
$emptyTitle = trim((string) $getConfig('blog.empty_title', 'No posts in this category yet'));
$emptyDesc = trim((string) $getConfig('blog.empty_desc', 'Check back later or return to the main blog list.'));
$backToBlogText = trim((string) $getConfig('blog.back_to_blog_text', 'Back to Blog'));
$readArticleText = trim((string) $getConfig('blog.read_article_text', 'Read Article'));
$readMoreText = trim((string) $getConfig('blog.read_more_text', 'Read More'));
$categoriesTitle = trim((string) $getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string) $getConfig('blog.recent_posts_title', 'Recent Posts'));

$primaryColor = $getConfig('color_scheme.primary', $colors['accent_primary'] ?? '#ff5a36');
$secondaryColor = $getConfig('color_scheme.secondary', $colors['accent_secondary'] ?? '#00c2a8');
$bgColor = $getConfig('color_scheme.background', $colors['blog_bg'] ?? 'linear-gradient(180deg, #fff7de 0%, #ffeec7 100%)');
$textColor = $getConfig('color_scheme.text', $colors['text_primary'] ?? '#2d170b');
$mutedColor = $colors['text_muted'] ?? '#97725a';
$surface = $colors['card_bg'] ?? 'rgba(255,255,255,0.76)';
$borderLight = $colors['border_light'] ?? 'rgba(45,23,11,0.12)';

$excerpt = static function ($text, $length = 150) {
    $text = trim((string) $text);
    if ($text === '') {
        return '';
    }
    return mb_strlen($text) > $length ? mb_substr($text, 0, $length) . '...' : $text;
};
$formatDate = static function ($value) {
    $timestamp = strtotime((string) $value);
    return $timestamp ? date('M d, Y', $timestamp) : '';
};

$categoryDescription = trim((string) ($currentCategory['description'] ?? ''));
$currentCategoryId = $currentCategory['id'] ?? null;
$spotlightPost = $blogPosts[0] ?? null;
$streamPosts = array_slice($blogPosts, 1);
if ($spotlightPost === null && !empty($streamPosts)) {
    $spotlightPost = array_shift($streamPosts);
}
?>
<section id="<?= $componentId ?>" class="mela-blog-category mode-<?= htmlspecialchars($cardStyle) ?>" aria-labelledby="<?= $componentId ?>-title">
    <span class="blog-float float-a" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="blog-float float-b" aria-hidden="true" data-mela-parallax data-mela-speed="0.06"></span>

    <div class="blog-shell">
        <header class="category-masthead">
            <div class="masthead-copy wow animate__fadeInUp">
                <?php if (!empty($currentCategory['name'])): ?>
                    <span class="category-badge"><?= htmlspecialchars($currentCategory['name']) ?></span>
                <?php endif; ?>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title !== '' ? $title : 'Category Posts') ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
                <?php if ($categoryDescription !== ''): ?>
                    <div class="category-description"><?= htmlspecialchars($categoryDescription) ?></div>
                <?php endif; ?>
            </div>

            <div class="category-count wow animate__fadeInUp" data-wow-delay="0.06s" aria-label="Category post count">
                <span class="count-suits" aria-hidden="true">♣</span>
                <strong><?= count($blogPosts) ?></strong>
                <span><?= htmlspecialchars(count($blogPosts) === 1 ? ($articleSingular !== '' ? $articleSingular : 'Article') : ($articlePlural !== '' ? $articlePlural : 'Articles')) ?></span>
            </div>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="category-empty wow animate__fadeInUp">
                <h2><?= htmlspecialchars($emptyTitle !== '' ? $emptyTitle : 'No posts in this category yet') ?></h2>
                <p><?= htmlspecialchars($emptyDesc !== '' ? $emptyDesc : 'Check back later or return to the main blog list.') ?></p>
                <a class="empty-link" href="/blog"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
            </div>
        <?php else: ?>
            <?php if ($spotlightPost): ?>
                <article class="spotlight-ribbon wow animate__fadeInUp" data-wow-delay="0.04s">
                    <div class="spotlight-copy">
                        <div class="post-meta">
                            <?php if ($showCategory && !empty($spotlightPost['category_name'])): ?>
                                <span class="meta-chip"><?= htmlspecialchars($spotlightPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($spotlightPost['published_at'])): ?>
                                <span class="meta-date"><?= htmlspecialchars($formatDate($spotlightPost['published_at'])) ?></span>
                            <?php endif; ?>
                        </div>
                        <h2><a href="<?= htmlspecialchars($spotlightPost['url']) ?>"><?= htmlspecialchars($spotlightPost['title']) ?></a></h2>
                        <?php if (!empty($spotlightPost['summary'])): ?>
                            <p><?= htmlspecialchars($excerpt($spotlightPost['summary'], 220)) ?></p>
                        <?php endif; ?>
                        <div class="spotlight-foot">
                            <?php if ($showAuthor && !empty($spotlightPost['author'])): ?>
                                <span class="meta-author"><?= htmlspecialchars($spotlightPost['author']) ?></span>
                            <?php endif; ?>
                            <a class="story-link" href="<?= htmlspecialchars($spotlightPost['url']) ?>"><?= htmlspecialchars($readArticleText !== '' ? $readArticleText : 'Read Article') ?></a>
                        </div>
                    </div>
                    <?php if (!empty($spotlightPost['cover_image'])): ?>
                        <a class="spotlight-media" href="<?= htmlspecialchars($spotlightPost['url']) ?>">
                            <img src="<?= htmlspecialchars($spotlightPost['cover_image']) ?>" alt="<?= htmlspecialchars($spotlightPost['title']) ?>" loading="lazy" decoding="async">
                        </a>
                    <?php endif; ?>
                </article>
            <?php endif; ?>

            <div class="category-flow<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="stream-list">
                    <?php foreach ($streamPosts as $index => $post): ?>
                        <article class="stream-card<?= $index % 2 ? ' is-reverse' : '' ?> wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.05 * (($index % 6) + 1), 2)) ?>s">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a class="stream-media" href="<?= htmlspecialchars($post['url']) ?>">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>
                            <div class="stream-copy">
                                <div class="post-meta">
                                    <?php if ($showCategory && !empty($post['category_name'])): ?>
                                        <span class="meta-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($post['published_at'])): ?>
                                        <span class="meta-date"><?= htmlspecialchars($formatDate($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>
                                <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                <?php if (!empty($post['summary'])): ?>
                                    <p><?= htmlspecialchars($excerpt($post['summary'], 170)) ?></p>
                                <?php endif; ?>
                                <div class="stream-foot">
                                    <?php if ($showAuthor && !empty($post['author'])): ?>
                                        <span class="meta-author"><?= htmlspecialchars($post['author']) ?></span>
                                    <?php endif; ?>
                                    <a class="story-link" href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Read More') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="stream-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card wow animate__fadeInUp" aria-labelledby="<?= $componentId ?>-categories-title">
                                <h2 id="<?= $componentId ?>-categories-title"><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></h2>
                                <div class="category-stack">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php $isActive = $currentCategoryId !== null && isset($category['id']) && (string) $category['id'] === (string) $currentCategoryId; ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="<?= $isActive ? 'is-active' : '' ?>">
                                            <span><?= htmlspecialchars($category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <em><?= (int) $category['post_count'] ?></em>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card wow animate__fadeInUp" data-wow-delay="0.08s" aria-labelledby="<?= $componentId ?>-recent-title">
                                <h2 id="<?= $componentId ?>-recent-title"><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></h2>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a class="recent-item" href="<?= htmlspecialchars($post['url']) ?>">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy" decoding="async">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <em><?= htmlspecialchars($formatDate($post['published_at'])) ?></em>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>
