<?php
/**
 * Three Patti Mela Pop - Testimonials Component
 *
 * @component_start
 * code: testimonials
 * name: 用户评价
 * name_en: Testimonials
 * description: 用户评价展示模块，采用亮色口碑墙布局
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_rating => 显示评分:select:yes|yes,no
 * display.show_avatar => 显示头像:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#ffe1f1
 * style.title_color => 标题颜色:color:#2d170b
 * style.title_font_size => 标题字体大小(PC端):number:36|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.76)
 * style.card_border_radius => 卡片圆角:number:20|px
 * style.card_border_left_color => 卡片高亮色:color:#ff5a36
 * style.card_border_left_width => 卡片高亮宽度:number:4|px
 * style.card_padding => 卡片内边距:number:25|px
 * style.name_color => 姓名颜色:color:#2d170b
 * style.name_font_size => 姓名字号:number:16|px
 * style.rating_color => 评分颜色:color:#00c2a8
 * style.content_color => 评价内容颜色:color:#6b4b34
 * style.content_font_size => 评价内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:60|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * style.card_gap => 卡片间距:number:20|px
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:|默认使用本地头像
 * avatars.avatar_2 => 评价2头像:textarea:|默认使用本地头像
 * avatars.avatar_3 => 评价3头像:textarea:|默认使用本地头像
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Testimonials
 * texts.testimonial_1_name => 评价1姓名:text:Rajesh Kumar (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_1_content => 评价1内容:textarea:The bright layout makes it easy to jump from the hero straight into the section I need.
 * texts.testimonial_2_name => 评价2姓名:text:Priya Sharma (Delhi)
 * texts.testimonial_2_rating => 评价2评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_2_content => 评价2内容:textarea:The mobile cards feel lively without getting cluttered, and the FAQ is much easier to scan.
 * texts.testimonial_3_name => 评价3姓名:text:Amit Patel (Ahmedabad)
 * texts.testimonial_3_rating => 评价3评分:text:⭐⭐⭐⭐☆
 * texts.testimonial_3_content => 评价3内容:textarea:The poster-style game section stands out right away and still keeps the content readable.
 *
 * @fields_end
 */

$componentId = 'mela-testimonials-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', $colors['testimonials_bg'] ?? '#ffe1f1'));
$titleColor = $getConfig('style.title_color', $colors['heading_color'] ?? '#2d170b');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', $colors['card_bg'] ?? 'rgba(255,255,255,0.76)');
$cardBorderRadius = $getConfig('style.card_border_radius', '20');
$cardBorderLeftColor = $getConfig('style.card_border_left_color', $colors['accent_primary'] ?? '#ff5a36');
$cardBorderLeftWidth = $getConfig('style.card_border_left_width', '4');
$cardPadding = $getConfig('style.card_padding', '25');
$nameColor = $getConfig('style.name_color', $colors['heading_color'] ?? '#2d170b');
$nameFontSize = $getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', $colors['accent_secondary'] ?? '#00c2a8');
$contentColor = $getConfig('style.content_color', $colors['text_secondary'] ?? '#6b4b34');
$contentFontSize = $getConfig('style.content_font_size', '14');
$avatarSize = $getConfig('style.avatar_size', '60');
$avatarBorderRadius = $getConfig('style.avatar_border_radius', '50');
$sectionPadding = $getConfig('style.section_padding', '60');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '40');
$cardGap = $getConfig('style.card_gap', '20');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/user/Amit-Patel-3.avif');

$title = $getConfig('texts.title', $getConfig('testimonials.title', $getConfig('texts.testimonials_title', 'Testimonials')));
$cards = [
    [
        'avatar' => $getConfig('avatars.avatar_1', $getConfig('testimonials.avatar_1', '')) ?: $defaultAvatar1,
        'name' => $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)'),
        'rating' => $getConfig('texts.testimonial_1_rating', '⭐⭐⭐⭐⭐'),
        'content' => $getConfig('texts.testimonial_1_content', 'The bright layout makes it easy to jump from the hero straight into the section I need.'),
    ],
    [
        'avatar' => $getConfig('avatars.avatar_2', $getConfig('testimonials.avatar_2', '')) ?: $defaultAvatar2,
        'name' => $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)'),
        'rating' => $getConfig('texts.testimonial_2_rating', '⭐⭐⭐⭐⭐'),
        'content' => $getConfig('texts.testimonial_2_content', 'The mobile cards feel lively without getting cluttered, and the FAQ is much easier to scan.'),
    ],
    [
        'avatar' => $getConfig('avatars.avatar_3', $getConfig('testimonials.avatar_3', '')) ?: $defaultAvatar3,
        'name' => $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)'),
        'rating' => $getConfig('texts.testimonial_3_rating', '⭐⭐⭐⭐☆'),
        'content' => $getConfig('texts.testimonial_3_content', 'The poster-style game section stands out right away and still keeps the content readable.'),
    ],
];
?>
<section id="<?= $componentId ?>" class="mela-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <span class="testimonials-glow glow-left" aria-hidden="true" data-mela-parallax data-mela-speed="0.04"></span>
    <span class="testimonials-glow glow-right" aria-hidden="true" data-mela-parallax data-mela-speed="0.06"></span>

    <div class="testimonials-shell">
        <header class="testimonials-header">
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title" class="testimonials-title wow animate__fadeInUp"><span><?= htmlspecialchars($title) ?></span></h2>
            <?php endif; ?>
        </header>

        <div class="testimonials-wall">
            <?php foreach ($cards as $index => $card): ?>
                <article class="quote-card quote-card-<?= $index + 1 ?> wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.08 * ($index + 1), 2)) ?>s">
                    <div class="quote-card-top">
                        <?php if ($showAvatar): ?>
                            <img class="quote-avatar" src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
                        <?php endif; ?>
                        <div class="quote-person">
                            <h3><?= htmlspecialchars($card['name']) ?></h3>
                            <?php if ($showRating): ?>
                                <p class="quote-rating"><?= htmlspecialchars($card['rating']) ?></p>
                            <?php endif; ?>
                        </div>
                    </div>
                    <p class="quote-body"><?= nl2br(htmlspecialchars($card['content'])) ?></p>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>
