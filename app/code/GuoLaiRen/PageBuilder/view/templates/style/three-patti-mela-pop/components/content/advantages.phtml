$componentId = 'mela-advantages-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$joinLabels = static function (array $items) {
    $items = array_values(array_filter(array_map('trim', $items), static function ($item) {
        return $item !== '';
    }));
    $count = count($items);
    if ($count === 0) {
        return '';
    }
    if ($count === 1) {
        return $items[0];
    }
    if ($count === 2) {
        return $items[0] . ' and ' . $items[1];
    }

    $last = array_pop($items);
    return implode(', ', $items) . ', and ' . $last;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
