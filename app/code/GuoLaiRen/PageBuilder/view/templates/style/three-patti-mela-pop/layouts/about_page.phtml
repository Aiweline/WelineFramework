<?php
/**
 * Three Patti Mela Pop - About Page Layout
 */

$page = $page ?? $this->getData('page');
$styleSettingsRaw = $style_setting ?? $this->getData('style') ?: $this->getData('style_settings') ?: [];
$styleSettings = is_array($styleSettingsRaw) ? $styleSettingsRaw : [];
$templateCode = 'three-patti-mela-pop';

$layoutConfigRaw = $layout_config ?? $this->getData('layout_config') ?? [];
if (is_string($layoutConfigRaw)) {
    $layoutConfig = json_decode($layoutConfigRaw, true) ?: [];
} else {
    $layoutConfig = is_array($layoutConfigRaw) ? $layoutConfigRaw : [];
}

$headerRaw = $layoutConfig['header'] ?? [];
$footerRaw = $layoutConfig['footer'] ?? [];
$headerComponents = is_array($headerRaw) && !isset($headerRaw[0]) && isset($headerRaw['component'])
    ? [['code' => $headerRaw['component'], 'enabled' => true, 'config' => $headerRaw['config'] ?? []]]
    : (is_array($headerRaw) ? $headerRaw : []);
$contentComponents = is_array($layoutConfig['content'] ?? null) ? $layoutConfig['content'] : [];
$footerComponents = is_array($footerRaw) && !isset($footerRaw[0]) && isset($footerRaw['component'])
    ? [['code' => $footerRaw['component'], 'enabled' => true, 'config' => $footerRaw['config'] ?? []]]
    : (is_array($footerRaw) ? $footerRaw : []);

if (empty($headerComponents)) {
    $headerComponents = [['code' => 'header-nav', 'enabled' => true, 'config' => []]];
}

if (empty($contentComponents)) {
    $contentComponents = [[
        'code' => 'about-content',
        'enabled' => true,
        'instance_id' => 'about-content-default-fallback',
        'config' => [
            'layout' => 'standard',
            'show_team' => true,
            'show_values' => true,
            'show_stats' => true,
            'show_cta' => true,
        ],
    ]];
}

if (empty($footerComponents)) {
    $footerComponents = [['code' => 'footer-links', 'enabled' => true, 'config' => []]];
}

$componentFiles = [
    'header-nav' => 'header/nav.phtml',
    'header-simple' => 'header/simple.phtml',
    'header-dark' => 'header/dark.phtml',
    'about-content' => 'content/about-content.phtml',
    'footer-links' => 'footer/links.phtml',
    'footer-simple' => 'footer/simple.phtml',
];

$renderComponent = function (array $component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? $component['component'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];

    if (!$enabled || $code === '') {
        return '';
    }

    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        return '<!-- Component not found: ' . htmlspecialchars($code, ENT_QUOTES, 'UTF-8') . ' -->';
    }

    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);

    try {
        return $this->fetchTemplate('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/components/' . $file);
    } catch (\Throwable $e) {
        return '<!-- Error loading component ' . htmlspecialchars($code, ENT_QUOTES, 'UTF-8') . ': ' . htmlspecialchars($e->getMessage(), ENT_QUOTES, 'UTF-8') . ' -->';
    }
};

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);

$metaTitle = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'About Us';
$metaDescription = $page ? ($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? ($page->getData('meta_keywords') ?: '') : '';
$pageIcon = $page ? ($page->getData('icon') ?: '') : '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars((string)$metaTitle) ?></title>
    <?php if ($pageIcon): ?>
    <link rel="icon" type="image/x-icon" href="<?= htmlspecialchars((string)$pageIcon) ?>">
    <?php else: ?>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <?php endif; ?>
    <?php if ($metaDescription): ?>
    <meta name="description" content="<?= htmlspecialchars((string)$metaDescription) ?>">
    <?php endif; ?>
    <?php if ($metaKeywords): ?>
    <meta name="keywords" content="<?= htmlspecialchars((string)$metaKeywords) ?>">
    <?php endif; ?>
    <w:template>GuoLaiRen_PageBuilder::base/tracking.phtml</w:template>
    <?php $localCssUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/css/home.css'); ?>
    <link rel="stylesheet" type="text/css" href="<?= htmlspecialchars($localCssUrl) ?>">
</head>
<body class="page-about">
    <div style="display:none;">
        <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
    </div>
    <header data-region="header">
        <?php foreach ($headerComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
                <?= $renderComponent((array)$component) ?>
            <?php endif; ?>
        <?php endforeach; ?>
    </header>
    <main data-region="content">
        <?php foreach ($contentComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
                <?= $renderComponent((array)$component) ?>
            <?php endif; ?>
        <?php endforeach; ?>
    </main>
    <footer data-region="footer">
        <?php foreach ($footerComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
                <?= $renderComponent((array)$component) ?>
            <?php endif; ?>
        <?php endforeach; ?>
    </footer>
</body>
</html>
