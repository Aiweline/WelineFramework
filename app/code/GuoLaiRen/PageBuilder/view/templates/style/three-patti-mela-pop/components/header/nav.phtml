<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var toggle = root.querySelector('.nav-toggle');
    var panel = document.getElementById('<?= $mobilePanelId ?>');
    var closeButton = panel ? panel.querySelector('.mobile-close') : null;
    var backdropButton = panel ? panel.querySelector('.mobile-backdrop') : null;
    var desktopMq = window.matchMedia('(min-width: 1081px)');

    var syncState = function (open) {
        root.classList.toggle('is-open', open);
        root.dataset.mobileOpen = open ? 'true' : 'false';
        document.body.classList.toggle('mela-lock', open);
        if (toggle) {
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
        if (panel) {
            panel.setAttribute('aria-hidden', open ? 'false' : 'true');
        }
    };

    var setOpen = function (open) {
        syncState(open);
    };

    var syncScroll = function () {
        root.classList.toggle('is-scrolled', (window.scrollY || window.pageYOffset || 0) > 18);
    };

    if (toggle && panel) {
        toggle.addEventListener('click', function () {
            setOpen(root.dataset.mobileOpen !== 'true');
        });

        if (closeButton) {
            closeButton.addEventListener('click', function () {
                setOpen(false);
            });
        }

        if (backdropButton) {
            backdropButton.addEventListener('click', function () {
                setOpen(false);
            });
        }

        panel.querySelectorAll('a').forEach(function (link) {
            link.addEventListener('click', function () {
                setOpen(false);
            });
        });

        if (desktopMq.addEventListener) {
            desktopMq.addEventListener('change', function (event) {
                if (event.matches) {
                    setOpen(false);
                }
            });
        } else if (desktopMq.addListener) {
            desktopMq.addListener(function (event) {
                if (event.matches) {
                    setOpen(false);
                }
            });
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && root.dataset.mobileOpen === 'true') {
                setOpen(false);
            }
        });
    }

    syncState(false);
    syncScroll();
    window.addEventListener('scroll', syncScroll, { passive: true });
})();
</script>
