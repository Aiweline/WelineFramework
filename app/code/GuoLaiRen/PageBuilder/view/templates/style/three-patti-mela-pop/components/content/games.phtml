];
$gameTitles = array_values(array_filter(array_map(static function ($card) {
    return trim((string)($card['title'] ?? ''));
}, $cards), static function ($item) {
    return $item !== '';
}));
$gamesSummary = '';
if ($showDescription && !empty($gameTitles)) {
    $defaultSummary = 'Three play routes moving through ' . $joinLabels(array_slice($gameTitles, 0, 3)) . '.';
    $gamesSummary = trim((string)$getConfig('texts.summary', $getConfig('texts.games_summary', $defaultSummary)));
