$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/game/game-i2.webp');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/game/game-i3.webp');

$title = $getConfig('texts.title', $getConfig('games.title', $getConfig('texts.games_title', 'Game Modes')));
$cards = [
    [
        'title' => $getConfig('texts.game_1_title', $getConfig('texts.game_teen_patti', 'Three Patti')),
        'desc' => $getConfig('texts.game_1_desc', $getConfig('texts.game_teen_patti_desc', 'Three-card action with quick rounds, bluff pressure, and a clean mobile-first table flow.')),
        'desktop' => $getConfig('images.image_1_desktop', $getConfig('games.image_1_desktop', '')) ?: $defaultImage1Desktop,
        'mobile' => $getConfig('images.image_1_mobile', $getConfig('games.image_1_mobile', '')) ?: $defaultImage1Mobile,
    ],
    [
        'title' => $getConfig('texts.game_2_title', $getConfig('texts.game_rummy', 'Rummy')),
        'desc' => $getConfig('texts.game_2_desc', $getConfig('texts.game_rummy_desc', 'Sequence building and set play for players who want a longer tactical rhythm.')),
        'desktop' => $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2,
        'mobile' => $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2,
