                            <span class="game-index">0<?= $index + 1 ?></span>
                            <span class="game-suit-mark" aria-hidden="true"></span>
                        </div>
                        <h3><?= htmlspecialchars($card['title']) ?></h3>
                        <?php if ($showDescription): ?>
