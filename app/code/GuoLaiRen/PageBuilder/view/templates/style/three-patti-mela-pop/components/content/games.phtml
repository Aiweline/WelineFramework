                <?php endif; ?>
                <?php if (!empty($gameTitles)): ?>
                    <div class="games-tags" aria-label="Game mode highlights">
                        <?php foreach (array_slice($gameTitles, 0, 3) as $index => $gameTitle): ?>
                            <span class="wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.05 * ($index + 1), 2)) ?>s"><?= htmlspecialchars($gameTitle) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>
        </header>

        <div class="games-board">
            <?php foreach ($cards as $index => $card): ?>
                <article class="game-poster poster-<?= $index + 1 ?> wow animate__fadeInUp" data-wow-delay="<?= htmlspecialchars(number_format(0.08 * ($index + 1), 2)) ?>s">
                    <div class="game-poster-media">
                        <?php if ($index === 0): ?>
