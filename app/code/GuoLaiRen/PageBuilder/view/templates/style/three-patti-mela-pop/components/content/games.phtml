    [
        'title' => $getConfig('texts.game_3_title', $getConfig('texts.game_slots', 'Slots')),
        'desc' => $getConfig('texts.game_3_desc', $getConfig('texts.game_slots_desc', 'Short bursts of chance-driven play that balance the card-heavy sections of the site.')),
        'desktop' => $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3,
        'mobile' => $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3,
