$componentId = 'mela-games-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$joinLabels = static function (array $items) {
    $items = array_values(array_filter(array_map('trim', $items), static function ($item) {
        return $item !== '';
    }));
    $count = count($items);
    if ($count === 0) {
        return '';
    }
    if ($count === 1) {
        return $items[0];
    }
    if ($count === 2) {
        return $items[0] . ' and ' . $items[1];
    }

    $last = array_pop($items);
    return implode(', ', $items) . ', and ' . $last;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', $colors['games_bg'] ?? '#dcfff6'));
$titleColor = $getConfig('style.title_color', $colors['heading_color'] ?? '#2d170b');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', $colors['card_bg'] ?? 'rgba(255,255,255,0.76)');
$cardBorderRadius = $getConfig('style.card_border_radius', '20');
$cardBorderColor = $getConfig('style.card_border_color', $colors['card_border'] ?? 'rgba(45,23,11,0.12)');
$cardTitleColor = $getConfig('style.card_title_color', $colors['heading_color'] ?? '#2d170b');
$cardTitleFontSize = $getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', $colors['text_secondary'] ?? '#6b4b34');
$cardDescFontSize = $getConfig('style.card_desc_font_size', '14');
$sectionPadding = $getConfig('style.section_padding', '60');
