}
if (empty($links)) {
    $linksConfig = trim((string)$getConfig('footer.links', $getConfig('content.footer_links', '')));
    if ($linksConfig === '') {
        $linksConfig = 'Home|/,Blog|/blog,FAQ|/faqs,About|/about,Privacy|/privacy-policy';
    }
    $items = (strpos($linksConfig, "\n") !== false && strpos($linksConfig, ',') === false)
        ? preg_split('/\r?\n/', $linksConfig)
        : explode(',', $linksConfig);
    foreach ($items as $item) {
        $item = trim((string)$item);
        if ($item === '') {
            continue;
        }
        $delimiter = strpos($item, '|') !== false ? '|' : (strpos($item, '=>') !== false ? '=>' : null);
        if (!$delimiter) {
            continue;
        }
        $parts = array_map('trim', explode($delimiter, $item, 2));
        if (count($parts) === 2 && $parts[0] !== '' && $parts[1] !== '') {
            $links[] = ['text' => $parts[0], 'href' => $parts[1]];
        }
    }
}
