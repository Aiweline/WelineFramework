        font-size: 0.88rem;
    }

    #<?= $componentId ?> .footer-disclaimer {
        max-width: none;
        text-align: left;
    }

    #<?= $floatingId ?> {
        min-height: auto;
        flex-direction: column;
        justify-content: center;
        gap: 0.25rem;
        padding: 0.65rem 0.65rem 0.58rem;
        border-radius: 28px;
    }

    #<?= $floatingId ?> .floating-icon {
        width: 2.7rem;
        height: 2.7rem;
    }

    #<?= $floatingId ?> .floating-text {
        font-size: 0.82rem;
        line-height: 1;
    }
}
</style>
<script>
(function () {
    var doc = document.documentElement;
    var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
        doc.classList.add('mela-wow-ready');
        document.querySelectorAll('.wow').forEach(function (node) {
            node.style.visibility = 'visible';
        });
    } else if (window.WOW && !window.__melaWowInit) {
        doc.classList.add('mela-wow-ready');
        new window.WOW({
            boxClass: 'wow',
            animateClass: 'animate__animated',
            offset: 70,
            mobile: true,
            live: false
        }).init();
        window.__melaWowInit = true;
    } else {
        doc.classList.add('mela-wow-ready');
        document.querySelectorAll('.wow').forEach(function (node) {
            node.style.visibility = 'visible';
        });
    }

    var trigger = document.getElementById('<?= $floatingId ?>');
    if (trigger) {
        trigger.addEventListener('click', function (event) {
            var href = trigger.getAttribute('href') || '';
            if (!href || href.charAt(0) !== '#') {
                return;
            }
            var target = document.querySelector(href)
                || document.getElementById('download')
                || document.querySelector('[data-download-anchor]')
                || document.querySelector('.hero-download-sticker')
                || document.querySelector('.hero-cta')
                || document.getElementById('hero');
            if (!target) {
                return;
            }
            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    }

    var parallaxNodes = Array.prototype.slice.call(document.querySelectorAll('[data-mela-parallax]'));
    if (parallaxNodes.length && !reducedMotion) {
        var ticking = false;
        var updateParallax = function () {
            var scrollTop = window.scrollY || window.pageYOffset || 0;
            parallaxNodes.forEach(function (node) {
                var speed = parseFloat(node.getAttribute('data-mela-speed') || '0.06');
                node.style.transform = 'translate3d(0,' + ((scrollTop * speed) * -1).toFixed(2) + 'px,0)';
            });
            ticking = false;
        };
        updateParallax();
        window.addEventListener('scroll', function () {
            if (!ticking) {
                window.requestAnimationFrame(updateParallax);
                ticking = true;
            }
        }, { passive: true });
    }
})();
</script>
