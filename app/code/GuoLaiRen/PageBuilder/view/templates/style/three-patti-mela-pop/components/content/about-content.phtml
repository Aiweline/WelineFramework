$componentId = 'mela-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$showStats = $normalizeToggle($getConfig('display.show_stats', $getConfig('show_stats', 'yes'))) !== 'no';
$showValues = $normalizeToggle($getConfig('display.show_values', $getConfig('show_values', 'yes'))) !== 'no';
$showTeam = $normalizeToggle($getConfig('display.show_team', $getConfig('show_team', 'yes'))) !== 'no';
$showCta = $normalizeToggle($getConfig('display.show_cta', $getConfig('show_cta', 'yes'))) !== 'no';

$pageTitle = trim((string)$getConfig('hero.title', $page ? ($page->getData('title') ?: 'About Us') : 'About Us'));
