    font-family: Arial, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", sans-serif;
    line-height: 1.6;
    padding: 0 !important;
    margin: 0 !important;
}
#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor) ?>;
    height: <?= htmlspecialchars($headerHeight) ?>;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
}

#<?= $componentId ?> .tpmst-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
}

#<?= $componentId ?> .tpmst-header-logo a {
    display: flex;
    align-items: center;
}

#<?= $componentId ?> .tpmst-header-logo img {
    height: auto;
    transition: transform 0.3s ease;
}

#<?= $componentId ?> .tpmst-header-logo a:hover img {
    transform: scale(1.05);
}

#<?= $componentId ?> .tpmst-header-nav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 30px;
}

#<?= $componentId ?> .tpmst-header-nav a {
    color: <?= htmlspecialchars($navColor) ?>;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.5px;
    position: relative;
    padding: 5px 0;
    transition: color 0.3s ease;
}

#<?= $componentId ?> .tpmst-header-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
