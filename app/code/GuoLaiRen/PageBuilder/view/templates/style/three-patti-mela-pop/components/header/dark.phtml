}

#<?= $componentId ?> .tpmst-header-nav a:hover {
    color: <?= htmlspecialchars($accentColor) ?>;
}

#<?= $componentId ?> .tpmst-header-nav a:hover::after {
    width: 100%;
}

#<?= $componentId ?> .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: linear-gradient(135deg, <?= htmlspecialchars($accentColor) ?>, #ff6b6b);
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(233, 69, 96, 0.4);
}

#<?= $componentId ?> .btn-download:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(233, 69, 96, 0.5);
}

#<?= $componentId ?> .btn-icon {
    font-size: 16px;
}

#<?= $componentId ?> .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
