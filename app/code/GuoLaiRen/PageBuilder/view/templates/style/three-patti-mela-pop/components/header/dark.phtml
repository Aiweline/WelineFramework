    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
}

#<?= $componentId ?> .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 3px;
    background: <?= htmlspecialchars($navColor) ?>;
    border-radius: 2px;
    transition: all 0.3s ease;
}

/* 响应式 */
@media (max-width: 768px) {
    #<?= $componentId ?> .tpmst-header-nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: <?= htmlspecialchars($bgColor) ?>;
        padding: 20px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
    }
    
    #<?= $componentId ?> .tpmst-header-nav.active {
