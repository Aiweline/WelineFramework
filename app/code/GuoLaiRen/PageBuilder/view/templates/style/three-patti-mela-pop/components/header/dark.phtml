<?php
/**
 * TPMST 深色头部组件 - Dark Header Component
 * 
 * 深色背景的现代头部，包含 Logo、导航和渐变按钮
 * 
 * @component_start
 * code: header-dark
 * name: 深色头部
 * name_en: Dark Header
 * region: header
 * category: header
 * @component_end
 * 
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo地址:textarea:|留空使用默认
 * logo.width => Logo宽度:text:160px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.use_subpages => 使用子页面作为导航:select:no|yes,no
 * navigation.items => 导航项:textarea:Home#home,About#about,Games#games,FAQ#faq|格式: 名称#链接（use_subpages=yes时忽略）
 * 
 * group:button => 按钮设置
 * button.display => 显示按钮:select:yes|yes,no
 * button.text => 按钮文字:text:Download Now
 * button.url => 按钮链接:text:#download
 * 
 * group:style => 样式设置
 * style.background => 背景色:color:#1a1a2e
 * style.nav_color => 导航文字色:color:#ffffff
 * style.accent_color => 强调色:color:#e94560
 * style.height => 头部高度:text:70px
 * @fields_end
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */

// 生成唯一组件ID
$componentId = 'tpmst-header-dark-' . uniqid();

// 获取数据
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

// 合并配置：component_config 优先于 style_settings
$config = array_merge($styleSettings, $componentConfig);

// 辅助函数：读取配置，支持 group.field 格式
// 同时兼容旧格式 group.group.field（历史数据兼容）
$getConfig = function($key, $default = '') use ($config) {
    // 优先查找标准格式 (如 button.text)
    if (isset($config[$key]) && $config[$key] !== '') {
        return $config[$key];
    }
    // 兼容旧格式：尝试 group.group.field 格式 (如 button.button.text)
    $parts = explode('.', $key);
    if (count($parts) === 2) {
        $legacyKey = $parts[0] . '.' . $key; // button.text -> button.button.text
        if (isset($config[$legacyKey]) && $config[$legacyKey] !== '') {
            return $config[$legacyKey];
        }
    }
    return $default;
};

// Logo 配置
$logoDisplayValue = $getConfig('logo.display', 'yes');
$showLogo = !in_array($logoDisplayValue, ['no', '0', 0], true);
$logoUrl = $getConfig('logo.url', '');
$logoWidth = $getConfig('logo.width', '160px');

// 如果没有配置 Logo，使用默认
if (empty($logoUrl)) {
    $logoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/three-patti-mela-pop/asset/img/logo/logo.avif');
}

// 导航配置
$navDisplayValue = $getConfig('navigation.display', 'yes');
$showNav = !in_array($navDisplayValue, ['no', '0', 0], true);
$useSubpages = $getConfig('navigation.use_subpages', 'no') === 'yes';

$navItems = [];

// 优先使用真实子页面作为导航
if ($useSubpages && $page) {
    $navigationPages = $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $navItems[] = [
            'text' => $navPage['title'] ?? '',
            'href' => $navPage['url'] ?? '/', // SEO 友好的 /handle URL
        ];
    }
}

// 如果没有子页面，使用配置的导航项
if (empty($navItems)) {
    $navItemsRaw = $getConfig('navigation.items', 'Home#home,About#about,Games#games,FAQ#faq');
    if (!empty($navItemsRaw)) {
        foreach (explode(',', $navItemsRaw) as $item) {
            $parts = explode('#', trim($item));
            if (count($parts) >= 2) {
                $href = trim($parts[1]);
                // 如果不是锚点链接（#开头），则作为 URL 路径
                if (strpos($href, '#') !== 0 && strpos($href, '/') !== 0 && strpos($href, 'http') !== 0) {
                    $href = '/' . $href;
                } elseif (strpos($href, '#') === 0 && strlen($href) > 1) {
                    // 保持锚点格式
                    $href = '#' . ltrim($href, '#');
                }
                $navItems[] = ['text' => trim($parts[0]), 'href' => $href];
            } elseif (count($parts) === 1 && !empty(trim($parts[0]))) {
                // 只有名称没有链接，自动生成 URL
                $text = trim($parts[0]);
                $navItems[] = ['text' => $text, 'href' => '/' . strtolower(preg_replace('/[^a-zA-Z0-9]+/', '-', $text))];
            }
        }
    }
}

// 最后的默认值
if (empty($navItems)) {
    if ($page) {
        $defaultPages = $page->getNavigationPages([], 5);
        foreach ($defaultPages as $navPage) {
            $navItems[] = ['text' => $navPage['title'], 'href' => $navPage['url']];
        }
    }
    if (empty($navItems)) {
        $navItems = [
            ['text' => 'Home', 'href' => '/'],
            ['text' => 'About', 'href' => '/about'],
            ['text' => 'Games', 'href' => '/games'],
            ['text' => 'FAQ', 'href' => '/faq'],
        ];
    }
}

// 按钮配置
$buttonDisplayValue = $getConfig('button.display', 'yes');
$showButton = !in_array($buttonDisplayValue, ['no', '0', 0], true);
$buttonText = $getConfig('button.text', 'Download Now');
$buttonUrl = $getConfig('button.url', '#download');

// 样式配置
$bgColor = $getConfig('style.background', '#1a1a2e');
$navColor = $getConfig('style.nav_color', '#ffffff');
$accentColor = $getConfig('style.accent_color', '#e94560');
$headerHeight = $getConfig('style.height', '70px');
?>

<!-- 深色头部组件 -->
<header id="<?= $componentId ?>" class="tpmst-section tpmst-header-dark-component">
    <div class="tpmst-section-inner">
        <?php if ($showLogo): ?>
        <div class="tpmst-header-logo">
            <a href="/">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="Logo" style="width: <?= htmlspecialchars($logoWidth) ?>">
            </a>
        </div>
        <?php endif; ?>
        
        <?php if ($showNav && !empty($navItems)): ?>
        <nav class="tpmst-header-nav">
            <ul>
                <?php foreach ($navItems as $item): ?>
                <li><a href="<?= htmlspecialchars($item['href']) ?>"><?= htmlspecialchars($item['text']) ?></a></li>
                <?php endforeach; ?>
            </ul>
        </nav>
        <?php endif; ?>
        
        <?php if ($showButton): ?>
        <div class="tpmst-header-action">
            <a href="<?= htmlspecialchars($buttonUrl) ?>" class="btn-download">
                <span class="btn-icon">⬇</span>
                <span class="btn-text"><?= htmlspecialchars($buttonText) ?></span>
            </a>
        </div>
        <?php endif; ?>
        
        <button class="mobile-menu-toggle" aria-label="Toggle Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<style id="<?= $componentId ?>-styles">
/* ============================================
   深色头部组件样式 - Dark Header Styles
   组件ID: <?= $componentId ?>

   ============================================ */

   * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

