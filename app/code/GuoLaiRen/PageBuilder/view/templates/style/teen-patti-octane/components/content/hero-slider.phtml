    <div class="particle-layer" aria-hidden="true">
        <?php foreach ($particles as $particle): ?>
            <span style="--s: <?= (float)$particle['size'] ?>px; --x: <?= (float)$particle['left'] ?>%; --y: <?= (float)$particle['top'] ?>%; --dur: <?= (float)$particle['duration'] ?>s; --delay: -<?= (float)$particle['delay'] ?>s; --dx: <?= (float)$particle['dx'] ?>px; --dy: <?= (float)$particle['dy'] ?>px; --opa: <?= number_format((float)$particle['opacity'], 2, '.', '') ?>; --shape: <?= htmlspecialchars($particle['shape']) ?>;"></span>
        <?php endforeach; ?>
