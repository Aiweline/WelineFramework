 * hero.image_mobile => 首屏移动端图片:textarea:|留空使用本地banner-2.jpg
 * hero.alt => 首屏图片描述:text:Teen Patti Octane hero banner
 * hero.bg_color => 首屏背景色:color:#1b0f08
 *
 * group:download_btn => 下载按钮资源
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载按钮图片:textarea:|留空使用本地download-btn-m.webp
 * hero.cta_text => 下载按钮文本:text:DOWNLOAD APP
 * hero.cta_url => 下载按钮链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 区域CSS类:textarea:rs-slider slider-style2|额外类名
 * layout.margin_top => PC端顶部重叠:number:-75|px
 * layout.img_margin_top => 图片顶部偏移:number:-28|px
 *
 * group:routes => 路线标签
 * routes.route_1 => 路线1文本:text:Classic Teen Patti
 * routes.route_2 => 路线2文本:text:AK47 Table
 * routes.route_3 => 路线3文本:text:Joker Teen Patti
 * routes.route_4 => 路线4文本:text:Muflis Table
 * routes.route_5 => 路线5文本:text:Private Teen Patti
 *
 * group:flow_1 => 流程卡片1
 * flow.step_1_title => 流程1标题:text:Pick Variant
 * flow.step_1_desc => 流程1描述:textarea:Switch between Classic, AK47, Joker, and Muflis lobbies with live seat updates.
 *
 * group:flow_2 => 流程卡片2
 * flow.step_2_title => 流程2标题:text:Set Boot
 * flow.step_2_desc => 流程2描述:textarea:Confirm boot value and wallet balance before entering the Teen Patti table.
 *
 * group:flow_3 => 流程卡片3
 * flow.step_3_title => 流程3标题:text:Play Blind / Chaal
 * flow.step_3_desc => 流程3描述:textarea:Use one-thumb controls for blind, seen, sideshow, and show actions.
 *
 * group:signal_1 => 信号卡片1
 * signal.signal_1_title => 信号1标题:text:Low-Lag Dealing
 * signal.signal_1_desc => 信号1描述:textarea:Card reveals and action confirmations stay synchronized across the table.
 *
 * group:signal_2 => 信号卡片2
 * signal.signal_2_title => 信号2标题:text:Live Pot Clarity
 * signal.signal_2_desc => 信号2描述:textarea:Boot, chaal, and pot values remain readable during fast round turns.
 *
 * group:signal_3 => 信号卡片3
 * signal.signal_3_title => 信号3标题:text:Fast Rejoin Loop
 * signal.signal_3_desc => 信号3描述:textarea:Exit and re-seat quickly without losing your preferred Teen Patti route.
 *
 * @fields_end
 */

$page = $this->getData('page') ?? $page ?? null;
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeSwitch = static function ($value, $default = 'yes') {
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    if ($value === true || $value === 'true' || $value === 'yes') {
        return 'yes';
    }
    if ($value === false || $value === 'false' || $value === 'no') {
        return 'no';
    }
    return $default;
};

$bannerDisplay = $normalizeSwitch($getConfigAny(['hero.display', 'banner.display'], 'yes'), 'yes');
if ($bannerDisplay !== 'yes') {
    return;
}

$heroTitle = trim((string)$getConfig('hero.title', 'Boot-To-Show Speed Lane'));
$heroSubtitle = trim((string)$getConfig('hero.subtitle', 'From blind opening to final show, this Teen Patti layout keeps route choice, pot status, and action timing clear on every screen.'));
$heroKicker = $page ? (string)($page->getData('title') ?: 'Teen Patti Octane') : 'Teen Patti Octane';
$bannerAlt = (string)$getConfigAny(['hero.alt', 'banner.alt'], 'Teen Patti Octane hero banner');
$bannerBgColor = (string)$getConfigAny(['hero.bg_color', 'banner.bg_color'], '#1b0f08');

$downloadDisplay = $normalizeSwitch($getConfig('download_btn.display', 'yes'), 'yes') === 'yes';
$downloadBtnAlt = (string)$getConfigAny(['download_btn.hero.cta_text', 'hero.cta_text', 'download_btn.alt'], 'DOWNLOAD APP');
$downloadBtnUrl = (string)$getConfigAny(['download_btn.hero.cta_url', 'hero.cta_url', 'download_btn.url'], '#download');

$sliderClasses = (string)$getConfig('layout.slider_classes', 'rs-slider slider-style2');
$marginTop = (int)$getConfig('layout.margin_top', -75);
$imgMarginTop = (int)$getConfig('layout.img_margin_top', -28);

$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/download-btn-m.webp');

$bannerImageMobile = trim((string)$getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$bannerImageDesktop = trim((string)$getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$downloadBtnImage = trim((string)$getConfig('download_btn.image', ''));

$finalBannerMobile = $bannerImageMobile !== '' ? $bannerImageMobile : (string)$defaultBannerMobile;
$finalBannerDesktop = $bannerImageDesktop !== '' ? $bannerImageDesktop : (string)$defaultBannerDesktop;
$finalDownloadBtn = $downloadBtnImage !== '' ? $downloadBtnImage : (string)$defaultDownloadBtn;

$instanceId = 'oct-hero-slider-' . uniqid();

$routeDefaults = [
    'Classic Teen Patti',
    'AK47 Table',
    'Joker Teen Patti',
    'Muflis Table',
    'Private Teen Patti',
];
$routeBadges = [];
for ($index = 1; $index <= 5; $index++) {
    $routeLabel = trim((string)$getConfig("routes.route_{$index}", $routeDefaults[$index - 1]));
    if ($routeLabel !== '') {
        $routeBadges[] = $routeLabel;
    }
}
$mobileRouteBadges = array_slice($routeBadges, 0, 4);

$flowDefaults = [
    [
        'title' => 'Pick Variant',
        'desc' => 'Switch between Classic, AK47, Joker, and Muflis lobbies with live seat updates.',
    ],
    [
        'title' => 'Set Boot',
        'desc' => 'Confirm boot value and wallet balance before entering the Teen Patti table.',
    ],
    [
        'title' => 'Play Blind / Chaal',
        'desc' => 'Use one-thumb controls for blind, seen, sideshow, and show actions.',
    ],
];
$flowSteps = [];
for ($index = 1; $index <= 3; $index++) {
    $flowTitle = trim((string)$getConfigAny([
        "flow_{$index}.flow.step_{$index}_title",
        "flow.step_{$index}_title",
    ], $flowDefaults[$index - 1]['title']));
    $flowDesc = trim((string)$getConfigAny([
        "flow_{$index}.flow.step_{$index}_desc",
        "flow.step_{$index}_desc",
    ], $flowDefaults[$index - 1]['desc']));
    if ($flowTitle === '' && $flowDesc === '') {
        continue;
    }
    $flowSteps[] = [
        'step' => sprintf('Step %02d', $index),
        'title' => $flowTitle,
        'desc' => $flowDesc,
    ];
}

$signalDefaults = [
    [
        'title' => 'Low-Lag Dealing',
        'desc' => 'Card reveals and action confirmations stay synchronized across the table.',
    ],
    [
        'title' => 'Live Pot Clarity',
        'desc' => 'Boot, chaal, and pot values remain readable during fast round turns.',
    ],
    [
        'title' => 'Fast Rejoin Loop',
        'desc' => 'Exit and re-seat quickly without losing your preferred Teen Patti route.',
    ],
];
$signalCards = [];
for ($index = 1; $index <= 3; $index++) {
    $signalTitle = trim((string)$getConfigAny([
        "signal_{$index}.signal.signal_{$index}_title",
        "signal.signal_{$index}_title",
    ], $signalDefaults[$index - 1]['title']));
    $signalDesc = trim((string)$getConfigAny([
        "signal_{$index}.signal.signal_{$index}_desc",
        "signal.signal_{$index}_desc",
    ], $signalDefaults[$index - 1]['desc']));
    if ($signalTitle === '' && $signalDesc === '') {
        continue;
    }
    $signalCards[] = [
        'title' => $signalTitle,
        'desc' => $signalDesc,
    ];
}

$particles = [];
for ($i = 0; $i < 46; $i++) {
    $size = 3 + (($i * 7) % 19);
    $left = (($i * 11) % 96) + (($i % 2) * 0.5);
    $top = (($i * 17) % 94) + (($i % 3) * 0.5);
    $duration = 6.8 + (($i * 5) % 28) / 3.5;
    $delay = (($i * 9) % 21) / 2;
    $dx = (($i % 2 === 0) ? 1 : -1) * (6 + (($i * 3) % 26));
    $dy = -1 * (10 + (($i * 4) % 30));
    $opacity = 0.14 + (($i % 5) * 0.075);
    $shapeType = $i % 3;
    $shape = '999px';
    if ($shapeType === 1) {
        $shape = '28% 72% 56% 44% / 42% 58% 42% 58%';
    } elseif ($shapeType === 2) {
        $shape = '6px';
    }

    $particles[] = [
        'size' => $size,
        'left' => $left,
        'top' => $top,
        'duration' => $duration,
        'delay' => $delay,
        'dx' => $dx,
        'dy' => $dy,
        'opacity' => $opacity,
        'shape' => $shape,
    ];
}
?>

