<?php
/**
 * Teen Patti Octane - Testimonials Component
 *
 * @component_start
 * code: testimonials
 * name: 用户评价
 * name_en: Testimonials
 * description: 用户评价展示，支持头像、评分和内容
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示设置
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_rating => 显示评分:select:yes|yes,no
 * display.show_avatar => 显示头像:select:yes|yes,no
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#2a170f
 * style.title_color => 标题颜色:color:#ffd6a8
 * style.title_font_size => 标题字号(PC端):number:36|px
 * style.title_font_size_mobile => 标题字号(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,245,232,0.08)
 * style.card_border_radius => 卡片圆角:number:14|px
 * style.card_border_left_color => 卡片强调色:color:#53e0c5
 * style.card_border_left_width => 卡片强调边宽:number:3|px
 * style.card_padding => 卡片内边距:number:24|px
 * style.name_color => 姓名颜色:color:#ffd6a8
 * style.name_font_size => 姓名字号:number:16|px
 * style.rating_color => 评分颜色:color:#ffc27a
 * style.content_color => 内容颜色:color:#fff5ea
 * style.content_font_size => 内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:58|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * style.card_gap => 卡片间距:number:20|px
 *
 * group:avatars => 头像设置
 * avatars.avatar_1 => 评价1头像:textarea:|默认使用本地头像
 * avatars.avatar_2 => 评价2头像:textarea:|默认使用本地头像
 * avatars.avatar_3 => 评价3头像:textarea:|默认使用本地头像
 *
 * group:texts => 文本设置
 * texts.title => 区域标题:text:What Players Notice First
 * texts.testimonial_1_name => 评价1姓名:text:Rajesh Kumar (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:4.9/5
 * texts.testimonial_1_content => 评价1内容:textarea:Teen Patti Octane loads tables very quickly and results settle without delays.
 * texts.testimonial_2_name => 评价2姓名:text:Priya Sharma (Delhi)
 * texts.testimonial_2_rating => 评价2评分:text:4.8/5
 * texts.testimonial_2_content => 评价2内容:textarea:I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.
 * texts.testimonial_3_name => 评价3姓名:text:Amit Patel (Ahmedabad)
 * texts.testimonial_3_rating => 评价3评分:text:4.8/5
 * texts.testimonial_3_content => 评价3内容:textarea:The app flow is clean and withdrawals are easy to track from the wallet panel.
 *
 * @fields_end
 */

$componentId = 'oct-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#2a170f'));
$titleColor = $getConfig('style.title_color', '#ffd6a8');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,245,232,0.08)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '14');
$cardAccentColor = $getConfig('style.card_border_left_color', '#53e0c5');
$cardAccentWidth = (int)$getConfig('style.card_border_left_width', '3');
$cardPadding = (int)$getConfig('style.card_padding', '24');
$nameColor = $getConfig('style.name_color', '#ffd6a8');
$nameFontSize = (int)$getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', '#ffc27a');
$contentColor = $getConfig('style.content_color', '#fff5ea');
$contentFontSize = (int)$getConfig('style.content_font_size', '14');
$avatarSize = (int)$getConfig('style.avatar_size', '58');
$avatarRadius = (int)$getConfig('style.avatar_border_radius', '50');
$sectionPadding = (int)$getConfig('style.section_padding', '60');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '40');
$cardGap = (int)$getConfig('style.card_gap', '20');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/user/Amit-Patel-3.avif');

$avatar1 = $getConfig('avatars.avatar_1', $getConfig('testimonials.avatar_1', '')) ?: $defaultAvatar1;
$avatar2 = $getConfig('avatars.avatar_2', $getConfig('testimonials.avatar_2', '')) ?: $defaultAvatar2;
$avatar3 = $getConfig('avatars.avatar_3', $getConfig('testimonials.avatar_3', '')) ?: $defaultAvatar3;

$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Notice First'));
$name1 = $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)');
$rating1 = $getConfig('texts.testimonial_1_rating', '4.9/5');
$content1 = $getConfig('texts.testimonial_1_content', 'Teen Patti Octane loads tables very quickly and results settle without delays.');
$name2 = $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)');
$rating2 = $getConfig('texts.testimonial_2_rating', '4.8/5');
$content2 = $getConfig('texts.testimonial_2_content', 'I like the match rhythm. It feels smooth on mobile and tournament alerts are clear.');
$name3 = $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)');
$rating3 = $getConfig('texts.testimonial_3_rating', '4.8/5');
$content3 = $getConfig('texts.testimonial_3_content', 'The app flow is clean and withdrawals are easy to track from the wallet panel.');

$cards = [
    ['avatar' => $avatar1, 'name' => $name1, 'rating' => $rating1, 'content' => $content1],
    ['avatar' => $avatar2, 'name' => $name2, 'rating' => $rating2, 'content' => $content2],
    ['avatar' => $avatar3, 'name' => $name3, 'rating' => $rating3, 'content' => $content3],
];

$trackCards = array_merge($cards, $cards);
?>

<section id="<?= $componentId ?>" class="oct-testimonials">
    <div class="section-inner">
        <?php if ($showTitle): ?>
            <h2 class="section-title"><?= htmlspecialchars($title) ?></h2>
        <?php endif; ?>

        <div class="track-shell">
            <div class="track-row" aria-label="Player testimonials">
                <?php foreach ($trackCards as $index => $card): ?>
                    <article class="quote-card" style="--delay: <?= $index * 0.18 ?>s;">
                        <div class="quote-head">
                            <?php if ($showAvatar): ?>
                                <img src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
                            <?php endif; ?>
                            <div>
                                <h3><?= htmlspecialchars($card['name']) ?></h3>
                                <?php if ($showRating): ?>
                                    <p class="rating"><?= htmlspecialchars($card['rating']) ?></p>
                                <?php endif; ?>
                            </div>
                        </div>
                        <p class="quote-body"><?= htmlspecialchars($card['content']) ?></p>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    padding: <?= $sectionPadding ?>px 0;
    background:
        radial-gradient(860px 260px at 10% 0%, rgba(83, 224, 197, 0.18), transparent 68%),
        radial-gradient(760px 280px at 90% 100%, rgba(255, 122, 74, 0.18), transparent 68%),
        <?= htmlspecialchars($bgColor) ?>;
    border-top: 1px solid rgba(255, 224, 196, 0.14);
}

#<?= $componentId ?> .section-inner {
    width: min(1240px, calc(100% - 1.2rem));
    margin: 0 auto;
}

#<?= $componentId ?> .section-title {
    margin: 0 0 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    text-align: center;
    color: <?= htmlspecialchars($titleColor) ?>;
    font-size: clamp(<?= $titleFontSizeMobile ?>px, 5vw, <?= $titleFontSize ?>px);
}

#<?= $componentId ?> .section-title::before,
#<?= $componentId ?> .section-title::after {
    content: '';
    flex: 1 1 120px;
    max-width: 180px;
    min-width: 54px;
    height: 10px;
}

#<?= $componentId ?> .section-title::before {
    background:
        linear-gradient(90deg, rgba(83, 224, 197, 0), rgba(83, 224, 197, 0.74) 58%, rgba(255, 186, 124, 0.92) 100%) center/100% 2px no-repeat,
        linear-gradient(135deg, transparent 45%, rgba(255, 186, 124, 0.92) 46% 56%, transparent 57%) right center/10px 10px no-repeat;
}

#<?= $componentId ?> .section-title::after {
    background:
        linear-gradient(270deg, rgba(83, 224, 197, 0), rgba(83, 224, 197, 0.74) 58%, rgba(255, 186, 124, 0.92) 100%) center/100% 2px no-repeat,
        linear-gradient(-135deg, transparent 45%, rgba(255, 186, 124, 0.92) 46% 56%, transparent 57%) left center/10px 10px no-repeat;
}

#<?= $componentId ?> .track-shell {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    padding: 0.35rem 0;
}

#<?= $componentId ?> .track-shell::before,
#<?= $componentId ?> .track-shell::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 8%;
    z-index: 2;
    pointer-events: none;
}

#<?= $componentId ?> .track-shell::before {
    left: 0;
    background: linear-gradient(90deg, <?= htmlspecialchars($bgColor) ?>, rgba(0, 0, 0, 0));
}

#<?= $componentId ?> .track-shell::after {
    right: 0;
    background: linear-gradient(270deg, <?= htmlspecialchars($bgColor) ?>, rgba(0, 0, 0, 0));
}

#<?= $componentId ?> .track-row {
    display: flex;
    width: max-content;
    gap: <?= $cardGap ?>px;
    animation: oct-track 34s linear infinite;
}

#<?= $componentId ?> .quote-card {
    width: min(360px, calc(100vw - 2.6rem));
    border-radius: <?= $cardBorderRadius ?>px;
    background: <?= htmlspecialchars($cardBgColor) ?>;
    border: 1px solid rgba(255, 224, 196, 0.18);
    border-left: <?= $cardAccentWidth ?>px solid <?= htmlspecialchars($cardAccentColor) ?>;
    padding: <?= $cardPadding ?>px;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    position: relative;
}

#<?= $componentId ?> .quote-card::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 0;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(83, 224, 197, 0), rgba(83, 224, 197, 0.85), rgba(255, 106, 61, 0));
    opacity: 0.3;
}

#<?= $componentId ?> .quote-head {
    display: flex;
    align-items: center;
    gap: 0.72rem;
}

#<?= $componentId ?> .quote-head img {
    width: <?= $avatarSize ?>px;
    height: <?= $avatarSize ?>px;
    border-radius: <?= $avatarRadius ?>%;
    object-fit: cover;
    border: 1px solid rgba(255, 239, 221, 0.34);
}

#<?= $componentId ?> .quote-head h3 {
    margin: 0;
    color: <?= htmlspecialchars($nameColor) ?>;
    font-size: <?= $nameFontSize ?>px;
}

#<?= $componentId ?> .quote-head .rating {
    margin: 0.2rem 0 0;
    color: <?= htmlspecialchars($ratingColor) ?>;
    font-size: 0.86rem;
    font-weight: 700;
}

#<?= $componentId ?> .quote-body {
    margin: 0.9rem 0 0;
    color: <?= htmlspecialchars($contentColor) ?>;
    font-size: <?= $contentFontSize ?>px;
    line-height: 1.72;
    opacity: 0.92;
}

@keyframes oct-track {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(calc(-50% - <?= (int)($cardGap / 2) ?>px));
    }
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= $sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .section-inner {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .section-title {
        margin-bottom: 24px;
        gap: 0.58rem;
    }

    #<?= $componentId ?> .section-title::before,
    #<?= $componentId ?> .section-title::after {
        max-width: 96px;
        min-width: 40px;
        height: 8px;
    }

    #<?= $componentId ?> .track-row {
        animation-duration: 26s;
    }

    #<?= $componentId ?> .track-shell::before,
    #<?= $componentId ?> .track-shell::after {
        width: 14%;
    }
}

@media (prefers-reduced-motion: reduce) {
    #<?= $componentId ?> .track-row {
        animation: none;
        width: 100%;
        flex-wrap: wrap;
    }

    #<?= $componentId ?> .quote-card {
        width: 100%;
    }
}
</style>
