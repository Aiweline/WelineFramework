<?php
/**
 * Teen Patti Octane Footer Links Component
 *
 * @component_start
 * code: footer-links
 * name: 链接底部（Octane）
 * name_en: Octane Footer Links
 * description: 轻量导航、免责声明与版权信息
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_links => 显示链接:select:yes|yes,no
 * display.show_disclaimer => 显示免责声明:select:yes|yes,no
 * display.show_copyright => 显示版权信息:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.background_color => 背景颜色:color:#0a0a1a
 * style.text_color => 文字颜色:color:#8b8b8b
 * style.link_color => 链接颜色:color:#bebebe
 * style.link_hover_color => 链接悬停颜色:color:#ffd700
 * style.link_font_size => 链接字号:number:14|px
 * style.link_font_weight => 链接字重:number:500
 * style.link_gap => 链接间距:number:15|px
 * style.border_top => 显示顶部边框:select:yes|yes,no
 * style.border_color => 边框颜色:color:#333333
 * style.border_width => 边框宽度:number:1|px
 * style.section_padding => 区域内边距(PC端):number:30|px
 * style.section_padding_mobile => 区域内边距(移动端):number:20|px
 * style.separator_display => 显示分隔符:select:yes|yes,no
 * style.separator_char => 分隔符字符:text:
 * style.separator_color => 分隔符颜色:color:#8b8b8b
 *
 * group:disclaimer => 免责声明样式
 * disclaimer.bg_color => 免责声明背景:color:rgba(255,255,255,0.05)
 * disclaimer.border_radius => 免责声明圆角:number:8|px
 * disclaimer.padding => 免责声明内边距:number:15|px
 * disclaimer.font_size => 免责声明字号:number:12|px
 * disclaimer.text_color => 免责声明颜色:color:#8b8b8b
 *
 * group:copyright => 版权信息样式
 * copyright.font_size => 版权字号:number:12|px
 * copyright.text_color => 版权颜色:color:#8b8b8b
 * copyright.margin_top => 版权上边距:number:15|px
 *
 * group:content => 内容配置
 * content.use_custom_links => 使用自定义链接组:select:yes|yes,no
 * content.footer_links => 页脚链接:textarea:Home=>/\r\nFAQ=>/faq\r\nBlog=>/blog\r\nAbout=>/about\r\nPrivacy=>/privacy|配置格式：名字=>url，一行一个
 * content.copyright_text => 版权信息:text:© 2026 Teen Patti Octane. All rights reserved.
 * content.disclaimer_text => 免责声明:textarea:18+ Only. Teen Patti Octane is intended for adult players. Play responsibly and follow local gaming regulations.
 * group:content_footer_labels => 页脚菜单显示名称（有对应页面时显示，留空使用页面标题）
 * content.footer_label_home_page => 首页:text:
 * content.footer_label_about_page => 关于我们:text:
 * content.footer_label_blog_list => 博客:text:
 * content.footer_label_contact_page => 联系我们:text:
 * content.footer_label_terms_of_service => 条款:text:
 * content.footer_label_privacy_policy => 隐私政策:text:
 *
 * group:floating => 悬浮下载
 * floating.show => 显示悬浮下载:select:yes|yes,no
 * floating.text => 按钮文案:text:Download App
 * floating.subtext => 副文案:text:Quick Install
 * floating.url => 下载链接:text:#download
 * floating.image_url => 图标图片:text:|留空则使用主题内置 SVG 图标
 *
 * @fields_end
 */

$componentId = 'oct-footer-links-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function(array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$showLinks = $getConfig('display.show_links', 'yes') !== 'no';
$showDisclaimer = $getConfig('display.show_disclaimer', 'yes') !== 'no';
$showCopyright = $getConfig('display.show_copyright', 'yes') !== 'no';

$bgColor = $getConfig('style.background_color', '#091423');
$textColor = $getConfig('style.text_color', '#95a8bf');
$linkColor = $getConfig('style.link_color', '#c8d9ec');
$linkHoverColor = $getConfig('style.link_hover_color', '#ffd166');
$linkFontSize = $getConfig('style.link_font_size', '14');
$linkFontWeight = $getConfig('style.link_font_weight', '600');
$linkGap = $getConfig('style.link_gap', '16');
$borderTop = $getConfig('style.border_top', 'yes') !== 'no';
$borderColor = $getConfig('style.border_color', 'rgba(255,255,255,0.14)');
$borderWidth = $getConfig('style.border_width', '1');
$sectionPadding = $getConfig('style.section_padding', '30');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '20');
$separatorDisplay = $getConfig('style.separator_display', 'yes') !== 'no';
$separatorChar = $getConfig('style.separator_char', '|');
if ($separatorChar === '') {
    $separatorChar = '|';
}
$separatorColor = $getConfig('style.separator_color', '#95a8bf');

$disclaimerBgColor = $getConfig('disclaimer.bg_color', 'rgba(255,255,255,0.04)');
$disclaimerBorderRadius = $getConfig('disclaimer.border_radius', '10');
$disclaimerPadding = $getConfig('disclaimer.padding', '14');
$disclaimerFontSize = $getConfig('disclaimer.font_size', '12');
$disclaimerTextColor = $getConfig('disclaimer.text_color', '#95a8bf');

$copyrightFontSize = $getConfig('copyright.font_size', '12');
$copyrightTextColor = $getConfig('copyright.text_color', '#95a8bf');
$copyrightMarginTop = $getConfig('copyright.margin_top', '14');

$useCustomLinks = $getConfig('content.use_custom_links', 'yes') !== 'no';
$copyrightText = $getConfigAny([
    'content.copyright_text',
    'content_footer_labels.content.copyright_text',
], '© 2026 Teen Patti Octane. All rights reserved.');
$disclaimerText = $getConfigAny([
    'content.disclaimer_text',
    'content_footer_labels.content.disclaimer_text',
], '18+ Only. Teen Patti Octane is intended for adult players. Play responsibly and follow local gaming regulations.');
$standaloneShell = !($this->getData('__oct_shell_managed') || $this->getData('__pagebuilder_shell_managed'));
$showFloating = $getConfig('floating.show', 'yes') !== 'no';
$floatingText = $getConfig('floating.text', 'Download App');
$floatingSubtext = $getConfig('floating.subtext', 'Quick Install');
$floatingUrl = $getConfig('floating.url', '#download');
$floatingImageUrl = trim((string)$getConfig('floating.image_url', ''));
$defaultFloatingIcon = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/floating-download-orbit.svg');
if ($floatingImageUrl === '') {
    $floatingImageUrl = $defaultFloatingIcon;
}

$footerLinks = [];
if (!$useCustomLinks && $page) {
    $subpages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $subpages = $page->getHeaderNavigationPages(30);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $subpages = $page->getNavigationPages([], 30);
    } else {
        $subpages = $page->getData('subpages') ?: [];
    }
    foreach ($subpages as $subpage) {
        $type = trim((string)($subpage['type'] ?? ''));
        $label = $type !== '' ? trim((string)$getConfig('content.footer_label_' . $type, '')) : '';
        $footerLinks[] = [
            'text' => $label !== '' ? $label : ($subpage['title'] ?? ''),
            'url' => $subpage['url'] ?? '#',
        ];
    }
}
if (empty($footerLinks)) {
    $footerLinksText = trim((string)$getConfig('content.footer_links', "Home=>/\nFAQ=>/faq\nBlog=>/blog\nAbout=>/about\nPrivacy=>/privacy"));
    if (strpos($footerLinksText, '\\n') !== false && strpos($footerLinksText, "\n") === false) {
        $footerLinksText = str_replace('\\n', "\n", $footerLinksText);
    }
    $items = (strpos($footerLinksText, "\n") !== false || strpos($footerLinksText, '=>') !== false)
        ? preg_split('/\r?\n/', $footerLinksText)
        : explode(',', $footerLinksText);
    foreach ($items as $link) {
        $link = trim((string)$link);
        if ($link === '') {
            continue;
        }
        $delimiter = strpos($link, '=>') !== false ? '=>' : (strpos($link, '|') !== false ? '|' : null);
        if ($delimiter === null) {
            continue;
        }
        $parts = explode($delimiter, $link, 2);
        $footerLinks[] = [
            'text' => trim((string)$parts[0]),
            'url' => trim((string)($parts[1] ?? '#')) ?: '#',
        ];
    }
}
?>

<footer id="<?= $componentId ?>" class="oct-footer">
    <div class="oct-footer-inner">
        <?php if ($showLinks && !empty($footerLinks)): ?>
            <nav class="oct-links" aria-label="Footer Navigation">
                <?php foreach ($footerLinks as $index => $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                    <?php if ($separatorDisplay && $index < count($footerLinks) - 1): ?>
                        <span class="oct-sep"><?= htmlspecialchars($separatorChar) ?></span>
                    <?php endif; ?>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>

        <?php if ($showDisclaimer && $disclaimerText !== ''): ?>
            <p class="oct-disclaimer"><?= nl2br(htmlspecialchars($disclaimerText)) ?></p>
        <?php endif; ?>

        <?php if ($showCopyright): ?>
            <p class="oct-copy"><?= htmlspecialchars($copyrightText) ?></p>
        <?php endif; ?>
    </div>
</footer>
<?php if ($showFloating): ?>
    <a class="oct-floating-download" href="<?= htmlspecialchars($floatingUrl) ?>" aria-label="<?= htmlspecialchars($floatingText) ?>">
        <?php if ($floatingImageUrl !== ''): ?>
            <img src="<?= htmlspecialchars($floatingImageUrl) ?>" alt="<?= htmlspecialchars($floatingText) ?>" loading="lazy" decoding="async">
        <?php endif; ?>
        <span class="oct-floating-copy">
            <small><?= htmlspecialchars($floatingSubtext) ?></small>
            <strong><?= htmlspecialchars($floatingText) ?></strong>
        </span>
    </a>
<?php endif; ?>

<style>
#<?= $componentId ?> {
    background:
        radial-gradient(700px 240px at 15% 0%, rgba(73, 215, 255, 0.08), transparent 70%),
        radial-gradient(560px 220px at 88% 0%, rgba(255, 122, 47, 0.1), transparent 70%),
        <?= htmlspecialchars($bgColor) ?>;
    <?= $borderTop ? 'border-top: ' . (int)$borderWidth . 'px solid ' . htmlspecialchars($borderColor) . ';' : '' ?>
    padding: <?= (int)$sectionPadding ?>px 0;
    width: 100%;
    margin-top: 0;
}

#<?= $componentId ?> .oct-footer-inner {
    width: min(1180px, calc(100% - 1.2rem));
    margin: 0 auto;
    display: grid;
    gap: 0.9rem;
    text-align: center;
}

#<?= $componentId ?> .oct-links {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: <?= (int)$linkGap ?>px;
    color: <?= htmlspecialchars($linkColor) ?>;
}

#<?= $componentId ?> .oct-links a {
    color: inherit;
    text-decoration: none;
    font-size: <?= (int)$linkFontSize ?>px;
    font-weight: <?= (int)$linkFontWeight ?>;
    letter-spacing: 0.01em;
    opacity: 0.88;
    transition: color 0.25s ease, opacity 0.25s ease;
}

#<?= $componentId ?> .oct-links a:hover {
    color: <?= htmlspecialchars($linkHoverColor) ?>;
    opacity: 1;
}

#<?= $componentId ?> .oct-sep {
    color: <?= htmlspecialchars($separatorColor) ?>;
    opacity: 0.45;
    user-select: none;
}

#<?= $componentId ?> .oct-disclaimer {
    margin: 0;
    padding: <?= (int)$disclaimerPadding ?>px;
    border-radius: <?= (int)$disclaimerBorderRadius ?>px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: <?= htmlspecialchars($disclaimerBgColor) ?>;
    color: <?= htmlspecialchars($disclaimerTextColor) ?>;
    font-size: <?= (int)$disclaimerFontSize ?>px;
    line-height: 1.72;
}

#<?= $componentId ?> .oct-copy {
    margin: <?= (int)$copyrightMarginTop ?>px 0 0;
    color: <?= htmlspecialchars($copyrightTextColor) ?>;
    font-size: <?= (int)$copyrightFontSize ?>px;
    opacity: 0.9;
}

#<?= $componentId ?> + .oct-floating-download {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 45;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    border-radius: 999px;
    padding: 0.34rem 0.78rem 0.34rem 0.34rem;
    background: linear-gradient(122deg, #ffe27a 0%, #ffb052 46%, #ff6e42 100%);
    border: 1px solid rgba(255, 248, 228, 0.88);
    box-shadow: 0 18px 36px rgba(255, 99, 46, 0.48), 0 8px 18px rgba(0, 0, 0, 0.26);
    backdrop-filter: blur(4px);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

#<?= $componentId ?> + .oct-floating-download::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 203, 96, 0.68);
    opacity: 0;
    transform: scale(0.86);
    animation: oct-float-ping 2.8s ease-out infinite;
    pointer-events: none;
}

#<?= $componentId ?> + .oct-floating-download:hover {
    transform: translateY(-2px);
    filter: saturate(1.12);
    box-shadow: 0 22px 40px rgba(255, 99, 46, 0.56), 0 10px 20px rgba(0, 0, 0, 0.3);
}

#<?= $componentId ?> + .oct-floating-download img {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(255, 251, 236, 0.92);
    background: rgba(12, 27, 43, 0.9);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.24);
}

#<?= $componentId ?> + .oct-floating-download .oct-floating-copy {
    display: grid;
    gap: 0.06rem;
    line-height: 1.1;
}

#<?= $componentId ?> + .oct-floating-download small {
    color: rgba(86, 38, 14, 0.9);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
}

#<?= $componentId ?> + .oct-floating-download strong {
    color: #2f170b;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 0 rgba(255, 247, 230, 0.55);
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= (int)$sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .oct-footer-inner {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .oct-links {
        gap: 0.55rem 0.72rem;
    }

    #<?= $componentId ?> .oct-sep {
        display: none;
    }

    #<?= $componentId ?> + .oct-floating-download {
        right: 12px;
        bottom: 12px;
        gap: 0.45rem;
        padding: 0.3rem 0.66rem 0.3rem 0.3rem;
    }

    #<?= $componentId ?> + .oct-floating-download img {
        width: 38px;
        height: 38px;
    }

    #<?= $componentId ?> + .oct-floating-download strong {
        font-size: 0.76rem;
    }
}

@keyframes oct-float-ping {
    0% {
        opacity: 0.48;
        transform: scale(0.86);
    }

    75% {
        opacity: 0;
        transform: scale(1.12);
    }

    100% {
        opacity: 0;
        transform: scale(1.12);
    }
}
</style>
<?php if ($standaloneShell): ?>
</body>
</html>
<?php endif; ?>
