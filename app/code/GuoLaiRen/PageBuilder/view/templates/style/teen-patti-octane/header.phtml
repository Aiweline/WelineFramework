 * header.download_button.text_color => 按钮文字颜色:color:#ffffff
 * header.download_button.size => 按钮字体大小:responsive:12/12|px[保持当前主题视觉]
 * header.download_button.padding => 按钮内边距:responsive:10/10|px[保持当前主题视觉]
 * header.download_button.border_radius => 按钮圆角:number:10|px
 * header.download_button.extra_classes => 按钮额外CSS类:textarea:|当前主题主要使用内联样式，可留空
 * header.download_button.url => 下载链接:text:#download
 *
 * group:banner => Banner横幅区域设置（Hero/Banner）【已独立为组件hero-slider】
 * banner.display => 显示Banner区域:select:no|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|已迁移到hero-slider组件
 * banner.image_desktop => PC端Banner图片:textarea:|已迁移到hero-slider组件
 * banner.alt => Banner图片描述:text:Teen Patti Octane hero
 * banner.download_btn_image => Banner下载按钮图片:textarea:|已迁移到hero-slider组件
 * banner.download_btn_alt => Banner下载按钮描述:text:DOWNLOAD APP
 * banner.bg_color => Banner背景颜色:color:#1b0f08
 * banner.padding_v => Banner上下内边距:responsive:0/0|px[MD]
 * banner.slider_classes => Banner区域CSS类:textarea:rs-slider slider-style2
 *
 * group:color_scheme => 全局色系设置
 * color_scheme.scheme => 选择色系:select:default|default,blue,purple,green,red
 *
 * group:pixel => 像素统计
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

$templateCode = $page ? $page->getData('style') : 'teen-patti-octane';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'teen-patti-octane';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__pagebuilder_shell_managed', true);
$this->assign('__oct_shell_managed', true);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
