$componentId = 'oct-games-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#2a120d'));
$titleColor = $getConfig('style.title_color', '#ffd6a8');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,245,232,0.08)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '16');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,233,207,0.18)');
$cardTitleColor = $getConfig('style.card_title_color', '#ffd6a8');
$cardTitleFontSize = (int)$getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', '#fff5ea');
$cardDescFontSize = (int)$getConfig('style.card_desc_font_size', '14');
$sectionPadding = (int)$getConfig('style.section_padding', '60');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '40');
$cardGap = (int)$getConfig('style.card_gap', '24');
$cardContentPadding = (int)$getConfig('style.card_content_padding', '22');
$hoverTransform = (int)$getConfig('style.hover_transform', '5');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/game/game-i1.webp');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/game/game-i1-m.webp');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/game/game-i2.webp');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/game/game-i3.webp');

$image1Desktop = $getConfig('images.image_1_desktop', $getConfig('games.image_1_desktop', '')) ?: $defaultImage1Desktop;
$image1Mobile = $getConfig('images.image_1_mobile', $getConfig('games.image_1_mobile', '')) ?: $defaultImage1Mobile;
$image2 = $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2;
$image3 = $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3;

$kicker = $getConfig('texts.kicker', 'Teen Patti Octane');
$panelChip = $getConfig('texts.panel_chip', 'Teen Patti Octane');
$title = $getConfig('texts.title', $getConfig('games.title', 'Multiples Game'));
$summary = $getConfig('texts.summary', $getConfig('texts.games_summary', 'Three quick routes covering Teen Patti, Rummy, and Slots.'));
$game1Tag = $getConfig('texts.game_1_tag', 'Route 01');
$game1Stamp = $getConfig('texts.game_1_stamp', 'Main Table');
$title1 = $getConfig('texts.game_1_title', $getConfig('texts.game_teen_patti', 'Teen Patti Classic'));
$desc1 = $getConfig('texts.game_1_desc', $getConfig('texts.game_teen_patti_desc', 'Core Teen Patti table flow with rapid room entry and stable rounds.'));
$game2Tag = $getConfig('texts.game_2_tag', 'Route 02');
$game2Stamp = $getConfig('texts.game_2_stamp', 'Skill Table');
$title2 = $getConfig('texts.game_2_title', $getConfig('texts.game_rummy', 'Rummy Turbo'));
$desc2 = $getConfig('texts.game_2_desc', $getConfig('texts.game_rummy_desc', 'Sequence-focused matches with cleaner score rhythm and fast rematch entry.'));
$game3Tag = $getConfig('texts.game_3_tag', 'Route 03');
$game3Stamp = $getConfig('texts.game_3_stamp', 'Break Table');
$title3 = $getConfig('texts.game_3_title', $getConfig('texts.game_slots', 'Slot Sprint'));
$desc3 = $getConfig('texts.game_3_desc', $getConfig('texts.game_slots_desc', 'Short spin sessions designed for fast breaks between card tables.'));

$games = [
    [
        'title' => $title1,
        'desc' => $desc1,
        'desktop' => $image1Desktop,
        'mobile' => $image1Mobile,
        'tag' => $game1Tag,
        'stamp' => $game1Stamp,
    ],
    [
        'title' => $title2,
        'desc' => $desc2,
        'desktop' => $image2,
        'mobile' => $image2,
        'tag' => $game2Tag,
        'stamp' => $game2Stamp,
    ],
    [
        'title' => $title3,
        'desc' => $desc3,
        'desktop' => $image3,
        'mobile' => $image3,
        'tag' => $game3Tag,
        'stamp' => $game3Stamp,
    ],
];

$leadGame = $games[0] ?? null;
$sideGames = array_slice($games, 1);
?>

<section id="<?= $componentId ?>" class="oct-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="section-inner">
        <?php if ($showTitle): ?>
            <header class="games-head games-head-mobile">
                <span class="games-kicker"><?= htmlspecialchars($kicker) ?></span>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            </header>
        <?php endif; ?>

        <div class="games-desktop-board" style="--route-gap: <?= (int)$cardGap ?>px; --route-radius: <?= (int)$cardBorderRadius ?>px;">
            <div class="board-left-column<?= $showTitle ? '' : ' no-title' ?>">
                <?php if ($showTitle): ?>
                    <article class="board-title-panel">
                        <div><span class="board-chip"><?= htmlspecialchars($panelChip) ?></span></div>
                        <h2><?= htmlspecialchars($title) ?></h2>
                        <p><?= htmlspecialchars($summary) ?></p>
                    </article>
                <?php endif; ?>

                <?php if ($leadGame): ?>
                    <article class="route-card route-lead">
                        <span class="route-code"><?= htmlspecialchars($leadGame['tag']) ?></span>
                        <span class="route-stamp"><?= htmlspecialchars($leadGame['stamp']) ?></span>
                        <div class="route-image">
                            <picture>
                                <?php if (!empty($leadGame['mobile'])): ?>
                                    <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($leadGame['mobile']) ?>">
                                <?php endif; ?>
                                <?php if (!empty($leadGame['desktop'])): ?>
                                    <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($leadGame['desktop']) ?>">
                                <?php endif; ?>
                                <img src="<?= htmlspecialchars($leadGame['desktop'] ?: $leadGame['mobile']) ?>" alt="<?= htmlspecialchars($leadGame['title']) ?>" loading="lazy" decoding="async">
                            </picture>
                        </div>

                        <div class="route-content">
                            <h3><?= htmlspecialchars($leadGame['title']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= htmlspecialchars($leadGame['desc']) ?></p>
                            <?php endif; ?>
                        </div>
                    </article>
                <?php endif; ?>
            </div>

            <div class="board-right-column">
                <?php foreach ($sideGames as $index => $game): ?>
                    <article class="route-card route-side route-side-<?= (int)($index + 1) ?>">
                        <span class="route-code"><?= htmlspecialchars($game['tag']) ?></span>
                        <span class="route-stamp"><?= htmlspecialchars($game['stamp']) ?></span>
                        <div class="route-image">
                            <picture>
                                <?php if (!empty($game['mobile'])): ?>
                                    <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile']) ?>">
                                <?php endif; ?>
                                <?php if (!empty($game['desktop'])): ?>
                                    <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($game['desktop']) ?>">
                                <?php endif; ?>
                                <img src="<?= htmlspecialchars($game['desktop'] ?: $game['mobile']) ?>" alt="<?= htmlspecialchars($game['title']) ?>" loading="lazy" decoding="async">
                            </picture>
                        </div>

                        <div class="route-content">
                            <h3><?= htmlspecialchars($game['title']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= htmlspecialchars($game['desc']) ?></p>
                            <?php endif; ?>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>

        <div class="games-mobile-bento" aria-label="Mobile match bento board">
            <?php if ($leadGame): ?>
                <article class="bento-card bento-main">
                    <header class="bento-top">
                        <span class="bento-route"><?= htmlspecialchars($leadGame['tag']) ?></span>
                        <span class="bento-seal"><?= htmlspecialchars($leadGame['stamp']) ?></span>
                    </header>
                    <div class="bento-image">
                        <picture>
                            <?php if (!empty($leadGame['mobile'])): ?>
                                <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($leadGame['mobile']) ?>">
                            <?php endif; ?>
                            <?php if (!empty($leadGame['desktop'])): ?>
                                <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($leadGame['desktop']) ?>">
                            <?php endif; ?>
                            <img src="<?= htmlspecialchars($leadGame['desktop'] ?: $leadGame['mobile']) ?>" alt="<?= htmlspecialchars($leadGame['title']) ?>" loading="lazy" decoding="async">
                        </picture>
                    </div>
                    <div class="bento-copy">
                        <h3><?= htmlspecialchars($leadGame['title']) ?></h3>
                        <?php if ($showDescription): ?>
                            <p><?= htmlspecialchars($leadGame['desc']) ?></p>
                        <?php endif; ?>
                    </div>
                </article>
            <?php endif; ?>

            <div class="bento-split">
                <?php foreach ($sideGames as $index => $game): ?>
                    <article class="bento-card bento-mini bento-mini-<?= (int)($index + 1) ?>">
                        <header class="bento-top">
                            <span class="bento-route"><?= htmlspecialchars($game['tag']) ?></span>
                            <span class="bento-seal"><?= htmlspecialchars($game['stamp']) ?></span>
                        </header>
                        <div class="bento-image">
                            <picture>
                                <?php if (!empty($game['mobile'])): ?>
                                    <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($game['mobile']) ?>">
                                <?php endif; ?>
                                <?php if (!empty($game['desktop'])): ?>
                                    <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($game['desktop']) ?>">
                                <?php endif; ?>
                                <img src="<?= htmlspecialchars($game['desktop'] ?: $game['mobile']) ?>" alt="<?= htmlspecialchars($game['title']) ?>" loading="lazy" decoding="async">
                            </picture>
                        </div>
                        <div class="bento-copy">
                            <h3><?= htmlspecialchars($game['title']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= htmlspecialchars($game['desc']) ?></p>
                            <?php endif; ?>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

