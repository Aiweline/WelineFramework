 * hero.title => 页面标题:text:Contact Teen Patti Octane
 * hero.subtitle => 页面副标题:textarea:Need support or business help? Reach us through the channels below.
 * hero.bg_color => 背景颜色:color:#1b0f08
 * hero.bg_gradient_end => 渐变结束色:color:#34190c
 * hero.title_color => 标题颜色:color:#ffd6a8
 *
 * group:contact_info => 联系信息
 * contact_info.title => 联系区标题:text:Contact Info
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址内容:textarea:Mumbai Operations Hub, Andheri East, Maharashtra, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话内容:text:+91 98765 43210
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱内容:text:support@teenpattioctane.com
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间内容:text:24/7 Player Support
 *
 * group:social => 社交链接
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:https://facebook.com
 * social.twitter => Twitter链接:text:https://x.com
 * social.linkedin => LinkedIn链接:text:https://linkedin.com
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Message
 * form.name_label => 姓名标签:text:Name
 * form.name_placeholder => 姓名占位:text:Your name
 * form.email_label => 邮箱标签:text:Email
 * form.email_placeholder => 邮箱占位:text:you@example.com
 * form.subject_label => 主题标签:text:Topic
 * form.subject_placeholder => 主题占位:text:How can we help?
 * form.message_label => 留言标签:text:Message
 * form.message_placeholder => 留言占位:text:Share your request
 * form.submit_text => 提交按钮文本:text:Send Message
 * form.success_message => 成功提示:text:Thanks. Our team will reply soon.
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Address
 * map.embed_url => 地图嵌入地址:textarea:
 * map.height => 地图高度:number:400|px
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$config = array_merge(
    is_array($styleSettings) ? $styleSettings : [],
    is_array($componentConfig) ? $componentConfig : []
);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#1b0f08');
$heroGradientEnd = $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#34190c');
$heroTitleColor = $getConfig('hero.title_color', $colors['heading_color'] ?? '#ffd6a8');

$textPrimary = $colors['text_primary'] ?? '#fff5ea';
$textSecondary = $colors['text_secondary'] ?? '#f2ddca';
$textMuted = $colors['text_muted'] ?? '#c5ad95';
$sectionBg1 = $colors['section_bg_1'] ?? '#16100b';
$sectionBg2 = $colors['section_bg_2'] ?? '#27170f';
$cardBg = $colors['card_bg'] ?? 'rgba(255,245,232,0.08)';
$borderLight = $colors['border_light'] ?? 'rgba(255,233,207,0.16)';
$buttonBg = $colors['button_primary_bg'] ?? 'linear-gradient(100deg, #ff9f4d 0%, #ff4d4d 100%)';
$buttonText = $colors['button_primary_text'] ?? '#2b140d';

$page = $this->getData('page');
$pageTitle = $page ? (string)($page->getData('title') ?: 'Contact Teen Patti Octane') : 'Contact Teen Patti Octane';

$heroKicker = $getConfig('hero.kicker', 'Contact');
$heroTitle = $getConfig('hero.title', $pageTitle);
$heroSubtitle = $getConfig('hero.subtitle', 'Need support or business help? Reach us through the channels below.');

$contactInfoTitle = $getConfig('contact_info.title', 'Contact Info');
$addressLabel = $getConfig('contact_info.address_label', 'Address');
$contactAddress = $getConfig('contact_info.address', 'Mumbai Operations Hub, Andheri East, Maharashtra, India');
$phoneLabel = $getConfig('contact_info.phone_label', 'Phone');
$contactPhone = $getConfig('contact_info.phone', '+91 98765 43210');
$emailLabel = $getConfig('contact_info.email_label', 'Email');
$contactEmail = $getConfig('contact_info.email', 'support@teenpattioctane.com');
$workHoursLabel = $getConfig('contact_info.work_hours_label', 'Support Hours');
$contactWorkHours = $getConfig('contact_info.work_hours', '24/7 Player Support');

$formTitle = $getConfig('form.title', 'Send A Support Message');
$formNameLabel = $getConfig('form.name_label', 'Name');
$formNamePlaceholder = $getConfig('form.name_placeholder', 'Your name');
$formEmailLabel = $getConfig('form.email_label', 'Email');
$formEmailPlaceholder = $getConfig('form.email_placeholder', 'you@example.com');
$formSubjectLabel = $getConfig('form.subject_label', 'Topic');
$formSubjectPlaceholder = $getConfig('form.subject_placeholder', 'How can we help?');
$formMessageLabel = $getConfig('form.message_label', 'Message');
$formMessagePlaceholder = $getConfig('form.message_placeholder', 'Share your request');
$formSubmitText = $getConfig('form.submit_text', 'Send Message');
$formSuccessMessage = $getConfig('form.success_message', 'Thanks. Our team will reply soon.');

$mapTitle = $getConfig('map.title', 'Address');
$mapEmbedUrl = trim((string)$getConfig('map.embed_url', ''));
$mapHeight = (int)$getConfig('map.height', '400');

$socialLinks = [
    ['name' => 'Facebook', 'url' => trim((string)$getConfig('social.facebook', '')), 'label' => 'FB'],
    ['name' => 'Twitter', 'url' => trim((string)$getConfig('social.twitter', '')), 'label' => 'X'],
    ['name' => 'LinkedIn', 'url' => trim((string)$getConfig('social.linkedin', '')), 'label' => 'IN'],
    ['name' => 'WeChat', 'url' => trim((string)$getConfig('social.wechat', '')), 'label' => 'WC'],
    ['name' => 'Weibo', 'url' => trim((string)$getConfig('social.weibo', '')), 'label' => 'WB'],
];
$socialLinks = array_values(array_filter($socialLinks, function ($item) {
    return $item['url'] !== '';
}));

$instanceId = $component_instance_id ?? 'contact-content-' . uniqid();
?>

<section id="<?= $instanceId ?>" class="oct-contact-content">
    <div class="contact-hero">
        <div class="section-inner">
            <p class="hero-kicker"><?= htmlspecialchars($heroKicker) ?></p>
            <h1><?= htmlspecialchars($heroTitle) ?></h1>
            <p><?= htmlspecialchars($heroSubtitle) ?></p>
            <div class="hero-actions">
                <a href="tel:<?= htmlspecialchars(preg_replace('/\s+/', '', $contactPhone)) ?>">
                    <strong><?= htmlspecialchars($contactPhone) ?></strong>
                    <span><?= htmlspecialchars($phoneLabel) ?></span>
                </a>
                <a href="mailto:<?= htmlspecialchars($contactEmail) ?>">
                    <strong><?= htmlspecialchars($contactEmail) ?></strong>
                    <span><?= htmlspecialchars($emailLabel) ?></span>
                </a>
                <div>
                    <strong><?= htmlspecialchars($contactWorkHours) ?></strong>
                    <span><?= htmlspecialchars($workHoursLabel) ?></span>
                </div>
            </div>
        </div>
    </div>

    <div class="contact-main">
        <div class="section-inner contact-grid<?= $showForm ? '' : ' no-form' ?>">
            <?php if ($showInfo): ?>
                <aside class="contact-info">
                    <h2><?= htmlspecialchars($contactInfoTitle) ?></h2>

                    <div class="info-list">
                        <article class="info-card">
                            <h3><?= htmlspecialchars($addressLabel) ?></h3>
                            <p><?= nl2br(htmlspecialchars($contactAddress)) ?></p>
                        </article>
                        <article class="info-card">
                            <h3><?= htmlspecialchars($phoneLabel) ?></h3>
                            <p><a href="tel:<?= htmlspecialchars(preg_replace('/\s+/', '', $contactPhone)) ?>"><?= htmlspecialchars($contactPhone) ?></a></p>
                        </article>
                        <article class="info-card">
                            <h3><?= htmlspecialchars($emailLabel) ?></h3>
                            <p><a href="mailto:<?= htmlspecialchars($contactEmail) ?>"><?= htmlspecialchars($contactEmail) ?></a></p>
                        </article>
                        <article class="info-card">
                            <h3><?= htmlspecialchars($workHoursLabel) ?></h3>
                            <p><?= htmlspecialchars($contactWorkHours) ?></p>
                        </article>
                    </div>

                    <?php if ($showSocial && !empty($socialLinks)): ?>
                        <div class="social-row">
                            <?php foreach ($socialLinks as $link): ?>
                                <a href="<?= htmlspecialchars($link['url']) ?>" target="_blank" rel="noopener" aria-label="<?= htmlspecialchars($link['name']) ?>">
                                    <span><?= htmlspecialchars($link['label']) ?></span>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <div class="contact-form-wrap">
                    <h2><?= htmlspecialchars($formTitle) ?></h2>
                    <form class="contact-form" onsubmit="return false;" aria-label="contact form">
                        <div class="form-row">
                            <label>
                                <?= htmlspecialchars($formNameLabel) ?>
                                <input type="text" name="name" placeholder="<?= htmlspecialchars($formNamePlaceholder) ?>" required>
                            </label>
                            <label>
                                <?= htmlspecialchars($formEmailLabel) ?>
                                <input type="email" name="email" placeholder="<?= htmlspecialchars($formEmailPlaceholder) ?>" required>
                            </label>
                        </div>

                        <label>
                            <?= htmlspecialchars($formSubjectLabel) ?>
                            <input type="text" name="topic" placeholder="<?= htmlspecialchars($formSubjectPlaceholder) ?>">
                        </label>

                        <label>
                            <?= htmlspecialchars($formMessageLabel) ?>
                            <textarea name="message" rows="5" placeholder="<?= htmlspecialchars($formMessagePlaceholder) ?>" required></textarea>
                        </label>

                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                        <p class="form-note"><?= htmlspecialchars($formSuccessMessage) ?></p>
                    </form>
                </div>
            <?php endif; ?>
        </div>
    </div>

    <?php if ($showMap): ?>
        <div class="contact-map" style="--map-h: <?= $mapHeight ?>px;">
            <div class="section-inner">
                <?php if ($mapEmbedUrl !== ''): ?>
                    <div class="map-frame">
                        <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map"></iframe>
                    </div>
                <?php else: ?>
                    <div class="map-placeholder">
                        <?php if ($contactAddress !== ''): ?>
                            <h3><?= htmlspecialchars($mapTitle) ?></h3>
                            <p><?= nl2br(htmlspecialchars($contactAddress)) ?></p>
                        <?php endif; ?>
                        <?php if ($contactWorkHours !== ''): ?>
                            <p class="map-meta"><?= htmlspecialchars($contactWorkHours) ?></p>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    <?php endif; ?>
</section>

