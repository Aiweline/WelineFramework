                                            href="#<?= htmlspecialchars($item['id']) ?>"
                                            class="level-<?= (int)($item['level'] ?? 2) ?>"
                                        ><?= htmlspecialchars($item['title']) ?></a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </div>
                    </nav>
