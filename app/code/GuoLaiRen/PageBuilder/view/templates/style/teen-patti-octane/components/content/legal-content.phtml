<?php
/**
 * 通用法律内容组件
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录、更新时间显示，继承主题配色
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:60|px
 *
 * group:header => 头部设置
 * header.kicker => 顶部提示:text:Legal Center
 * header.title => 页面标题:text:|留空使用页面标题
 * header.icon => 自定义图标:text:|如:🔒 📜 💰
 * header.updated_label => 更新时间标签:text:Last Updated
 * header.bg_color => 背景色:color:#0c0060
 * header.bg_gradient_end => 渐变结束色:color:#1d1850
 * header.title_color => 标题颜色:color:#ffd700
 * header.text_color => 文字颜色:color:#cccccc
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.items => 自定义目录项:textarea:|留空时自动从正文标题提取，一行一个，格式：标题=>#锚点
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.05)
 * toc.border_color => 目录边框色:color:rgba(255,255,255,0.1)
 *
 * group:content => 内容设置
 * content.body => 正文HTML:textarea:|留空使用页面正文
 * content.empty_text => 空内容提示:text:Content will appear here soon.
 * content.bg_color => 内容区背景色:color:#0d0e13
 * content.text_color => 内容文字颜色:color:#cccccc
 * content.heading_color => 标题颜色:color:#ffd700
 * content.link_color => 链接颜色:color:#ffd700
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$config = array_merge(
    is_array($styleSettings) ? $styleSettings : [],
    is_array($componentConfig) ? $componentConfig : []
);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string)$getConfig('layout.content_width', 'narrow');
$headerPadding = max(36, (int)$getConfig('layout.header_padding', '80'));
$contentPadding = max(24, (int)$getConfig('layout.content_padding', '60'));

$headerTitle = trim((string)$getConfig('header.title', ''));
$headerKicker = trim((string)$getConfig('header.kicker', 'Legal Center'));
$headerIcon = trim((string)$getConfig('header.icon', ''));
$updatedLabel = trim((string)$getConfig('header.updated_label', 'Last Updated'));
$headerBgColorConfig = $getConfig('header.bg_color', '');
$headerGradientEndConfig = $getConfig('header.bg_gradient_end', '');
$headerTitleColorConfig = $getConfig('header.title_color', '');
$headerTextColorConfig = $getConfig('header.text_color', '');

$tocTitle = $getConfig('toc.title', 'On This Page');
$tocItemsConfig = trim((string)$getConfig('toc.items', ''));
$tocBgColorConfig = $getConfig('toc.bg_color', '');
$tocBorderColorConfig = $getConfig('toc.border_color', '');

$contentBodyConfig = trim((string)$getConfig('content.body', ''));
$emptyText = trim((string)$getConfig('content.empty_text', 'Content will appear here soon.'));
$contentBgColorConfig = $getConfig('content.bg_color', '');
$contentTextColorConfig = $getConfig('content.text_color', '');
$contentHeadingColorConfig = $getConfig('content.heading_color', '');
$contentLinkColorConfig = $getConfig('content.link_color', '');

$page = $this->getData('page');
$pageTitle = $headerTitle ?: ($page ? (string)($page->getData('title') ?? '') : '');
$pageTitle = trim($pageTitle) !== '' ? trim($pageTitle) : 'Legal Document';
$pageContentRaw = $contentBodyConfig !== '' ? $contentBodyConfig : ($page ? (string)($page->getData('content') ?? '') : '');
$lastUpdated = $page ? (string)($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';
$pageType = $page ? (string)($page->getData('type') ?? '') : '';

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $headerBgColorConfig ?: ($colors['hero_bg'] ?? '#0c0060');
$heroGradientEnd = $headerGradientEndConfig ?: ($colors['hero_bg_gradient_end'] ?? '#1d1850');
$sectionBg1 = $contentBgColorConfig ?: ($colors['section_bg_1'] ?? '#0d0e13');
$sectionBg2 = $colors['section_bg_2'] ?? '#1d1850';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $contentTextColorConfig ?: ($colors['text_secondary'] ?? '#cccccc');
$textMuted = $headerTextColorConfig ?: ($colors['text_muted'] ?? '#8b8b8b');
$accentPrimary = $headerTitleColorConfig ?: ($colors['accent_primary'] ?? '#ffd700');
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#ffed4e';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(90deg, #ffd700 0%, #ffa500 100%)';
$cardBg = $tocBgColorConfig ?: ($colors['card_bg'] ?? 'rgba(255,255,255,0.05)');
$borderLight = $tocBorderColorConfig ?: ($colors['border_light'] ?? 'rgba(255,255,255,0.1)');
$contentHeadingColor = $contentHeadingColorConfig ?: $accentPrimary;
$contentLinkColor = $contentLinkColorConfig ?: $accentPrimary;

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$currentIcon = $headerIcon ?: ($typeIcons[$pageType] ?? '📄');

$maxWidth = match ($contentWidth) {
    'wide' => '1200px',
    'medium' => '1000px',
    default => '800px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $tocItemsConfig !== '') {
    foreach (preg_split('/\r?\n/', $tocItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $title = trim((string)($parts[0] ?? ''));
        $target = trim((string)($parts[1] ?? ''));
        if ($title === '' || $target === '') {
            continue;
        }
        $tocItems[] = [
            'id' => ltrim($target, '#'),
            'title' => $title,
            'level' => 2,
        ];
    }
} elseif ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $text = trim(strip_tags((string)$matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $tocItems[] = [
            'id' => $id,
            'title' => $text,
            'level' => (int)$matches[1],
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}

if (trim($pageContent) === '') {
    $pageContent = '<p>' . nl2br(htmlspecialchars($emptyText, ENT_QUOTES, 'UTF-8')) . '</p>';
}

$hasToc = $showToc && !empty($tocItems);
$formattedUpdated = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('M j, Y', $timestamp);
    }
}

$instanceId = $component_instance_id ?? 'legal-content-' . uniqid();
?>

<section class="tpmst-section legal-content-component" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            padding: 44px 0 62px;
            background:
                radial-gradient(720px 240px at 6% 0%, rgba(83, 224, 197, 0.14), transparent 72%),
                radial-gradient(860px 300px at 95% 100%, rgba(255, 142, 84, 0.12), transparent 72%),
                <?= $sectionBg1 ?>;
            min-height: 60vh;
            width: 100%;
        }

        #<?= $instanceId ?> .tpmst-section-inner {
            max-width: <?= $maxWidth ?>;
