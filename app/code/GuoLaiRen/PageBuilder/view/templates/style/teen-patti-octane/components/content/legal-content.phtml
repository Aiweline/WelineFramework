                linear-gradient(132deg, rgba(83, 224, 197, 0.14), rgba(83, 224, 197, 0) 44%),
                linear-gradient(160deg, rgba(255, 156, 106, 0.16), rgba(255, 156, 106, 0) 58%),
                linear-gradient(135deg, <?= $heroBg ?> 0%, <?= $heroGradientEnd ?> 100%);
        }

        #<?= $instanceId ?> .legal-head-main {
            display: grid;
            gap: 0.45rem;
        }

        #<?= $instanceId ?> .legal-kicker {
            margin: 0;
