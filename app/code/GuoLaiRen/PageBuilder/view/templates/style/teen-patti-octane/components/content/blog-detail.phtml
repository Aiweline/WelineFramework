<?php
/**
 * Teen Patti Octane - Blog Detail Component
 *
 * @fields_start
 * blog.show_sidebar|Show sidebar|select:yes=Yes,no=No|yes
 * blog.show_cover|Show cover image|select:yes=Yes,no=No|yes
 * blog.show_author|Show author|select:yes=Yes,no=No|yes
 * blog.show_date|Show date|select:yes=Yes,no=No|yes
 * blog.show_tags|Show tags|select:yes=Yes,no=No|yes
 * blog.show_share|Show share buttons|select:yes=Yes,no=No|yes
 * blog.show_related|Show related posts|select:yes=Yes,no=No|yes
 * blog.related_count|Related post count|number|3
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$currentPost = $this->getData('current_post') ?: [];
$relatedPosts = $this->getData('related_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCover = $getConfig('blog.show_cover', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showTags = $getConfig('blog.show_tags', 'yes') === 'yes';
$showShare = $getConfig('blog.show_share', 'yes') === 'yes';
$showRelated = $getConfig('blog.show_related', 'yes') === 'yes';
$relatedCount = max(1, (int)$getConfig('blog.related_count', 3));

$primaryColor = $getConfig('color_scheme.primary', '#ff8a3d');
$secondaryColor = $getConfig('color_scheme.secondary', '#53e0c5');
$bgColor = $getConfig('color_scheme.background', '#16100b');
$textColor = $getConfig('color_scheme.text', '#fff5ea');

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('F d, Y', $timestamp) : (string)$value;
};

$related = array_slice($relatedPosts, 0, $relatedCount);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : $related;
?>

<section class="tpmst-section oct-blog-detail">
    <div class="section-inner">
        <?php if (empty($currentPost)): ?>
            <article class="empty-state">
                <h2><?= __('Article Not Found') ?></h2>
                <p><?= __('The article you are looking for is unavailable.') ?></p>
                <a href="/blog" class="back-link"><?= __('Back to Blog') ?></a>
            </article>
        <?php else: ?>
            <?php
            $postTitle = $currentPost['title'] ?? __('Untitled Post');
            $postUrl = $currentPost['url'] ?? (\w_env_request_uri() ?: '/blog');
            $postDate = $formatDate($currentPost['published_at'] ?? '');
            $postAuthor = $currentPost['author'] ?? '';
            $postCover = $currentPost['cover_image'] ?? '';
            $postSummary = $currentPost['summary'] ?? '';
            $postContent = $currentPost['content'] ?? '';
            $postCategory = $currentPost['category_name'] ?? '';
            $postViews = !empty($currentPost['view_count']) ? (int)$currentPost['view_count'] : 0;

            $tags = [];
            if (!empty($currentPost['tags'])) {
                $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', (string)$currentPost['tags']);
                $tags = array_values(array_filter(array_map('trim', $tags), function ($tag) {
                    return $tag !== '';
                }));
            }
            ?>

            <nav class="breadcrumb" aria-label="breadcrumb">
                <a href="/"><?= __('Home') ?></a>
                <span>/</span>
                <a href="/blog"><?= __('Blog') ?></a>
                <span>/</span>
                <span><?= htmlspecialchars(mb_substr($postTitle, 0, 40)) ?><?= mb_strlen($postTitle) > 40 ? '...' : '' ?></span>
            </nav>

            <div class="detail-layout<?= $showSidebar ? ' with-sidebar' : ' full-width' ?>">
                <article class="article-card">
                    <header class="article-hero">
                        <?php if ($postCategory !== ''): ?>
                            <span class="article-pill"><?= htmlspecialchars($postCategory) ?></span>
                        <?php endif; ?>

                        <h1><?= htmlspecialchars($postTitle) ?></h1>

                        <div class="article-meta">
                            <?php if ($showDate && $postDate): ?>
                                <span><?= htmlspecialchars($postDate) ?></span>
                            <?php endif; ?>
                            <?php if ($showAuthor && $postAuthor): ?>
                                <span><?= htmlspecialchars($postAuthor) ?></span>
                            <?php endif; ?>
                            <?php if ($postViews > 0): ?>
                                <span><?= $postViews ?> <?= __('views') ?></span>
                            <?php endif; ?>
                        </div>

                        <?php if ($showShare): ?>
                            <div class="article-share article-share-top">
                                <button type="button" data-share="facebook" data-url="<?= htmlspecialchars($postUrl) ?>">Facebook</button>
                                <button type="button" data-share="twitter" data-url="<?= htmlspecialchars($postUrl) ?>" data-title="<?= htmlspecialchars($postTitle) ?>">X</button>
                                <button type="button" data-share="linkedin" data-url="<?= htmlspecialchars($postUrl) ?>" data-title="<?= htmlspecialchars($postTitle) ?>">LinkedIn</button>
                                <button type="button" data-share="copy" data-url="<?= htmlspecialchars($postUrl) ?>"><?= __('Copy Link') ?></button>
                            </div>
                        <?php endif; ?>
                    </header>

                    <?php if ($showCover && $postCover): ?>
                        <div class="article-cover">
                            <img src="<?= htmlspecialchars($postCover) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                        </div>
                    <?php endif; ?>

                    <?php if ($postSummary): ?>
                        <aside class="article-summary">
                            <strong><?= __('Quick View') ?></strong>
                            <p><?= htmlspecialchars($postSummary) ?></p>
                        </aside>
                    <?php endif; ?>

                    <div class="article-content"><?= $postContent ?></div>

                    <?php if ($showTags && !empty($tags)): ?>
                        <div class="article-tags">
                            <?php foreach ($tags as $tag): ?>
                                <a href="/blog/tag/<?= urlencode($tag) ?>">#<?= htmlspecialchars($tag) ?></a>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <div class="article-nav">
                        <a href="/blog" class="back-link"><?= __('Back to Blog') ?></a>
                    </div>
                </article>

                <?php if ($showSidebar): ?>
                    <aside class="sidebar">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="sidebar-card">
                                <h4><?= __('Categories') ?></h4>
                                <ul>
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php
                                        $name = $category['name'] ?? '';
                                        $url = $category['url'] ?? '#';
                                        if ($name === '') {
                                            continue;
                                        }
                                        ?>
                                        <li><a href="<?= htmlspecialchars($url) ?>"><?= htmlspecialchars($name) ?></a></li>
                                    <?php endforeach; ?>
                                </ul>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recent)): ?>
                            <section class="sidebar-card">
                                <h4><?= __('Recent Posts') ?></h4>
                                <ul class="recent-list">
                                    <?php foreach ($recent as $post): ?>
                                        <?php
                                        $url = $post['url'] ?? '#';
                                        $name = $post['title'] ?? __('Untitled Post');
                                        $date = $formatDate($post['published_at'] ?? '');
                                        ?>
                                        <li>
                                            <a href="<?= htmlspecialchars($url) ?>">
                                                <span class="recent-title"><?= htmlspecialchars($name) ?></span>
                                                <?php if ($date): ?>
                                                    <span class="recent-date"><?= htmlspecialchars($date) ?></span>
                                                <?php endif; ?>
                                            </a>
                                        </li>
                                    <?php endforeach; ?>
                                </ul>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>

            <?php if ($showRelated && !empty($related)): ?>
                <section class="related-wrap">
                    <div class="related-head">
                        <h3><?= __('Related Articles') ?></h3>
                        <span><?= count($related) ?> <?= __('Items') ?></span>
                    </div>
                    <div class="related-grid">
                        <?php foreach ($related as $post): ?>
                            <?php
                            $url = $post['url'] ?? '#';
                            $name = $post['title'] ?? __('Untitled Post');
                            $date = $formatDate($post['published_at'] ?? '');
                            $image = $post['cover_image'] ?? '';
                            ?>
                            <article class="related-card">
                                <?php if ($image): ?>
                                    <a class="related-image" href="<?= htmlspecialchars($url) ?>">
                                        <img src="<?= htmlspecialchars($image) ?>" alt="<?= htmlspecialchars($name) ?>" loading="lazy" decoding="async">
                                    </a>
                                <?php endif; ?>
                                <div class="related-body">
                                    <h4><a href="<?= htmlspecialchars($url) ?>"><?= htmlspecialchars($name) ?></a></h4>
                                    <?php if ($date): ?>
                                        <p><?= htmlspecialchars($date) ?></p>
                                    <?php endif; ?>
                                </div>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </section>
            <?php endif; ?>
        <?php endif; ?>
    </div>
</section>

