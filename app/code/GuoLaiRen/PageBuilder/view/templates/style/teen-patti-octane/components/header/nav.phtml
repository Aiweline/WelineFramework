<?php
/**
 * Teen Patti Octane Header Navigation Component
 *
 * @component_start
 * code: header-nav
 * name: 导航头部（Octane）
 * name_en: Octane Navigation Header
 * description: 高对比导航，支持移动端抽屉与下载CTA
 * category: header
 * region: header
 * thumbnail: asset/img/logo-icon-128.avif
 * @component_end
 *
 * @fields_start
 *
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文本:text:Teen Patti Octane
 * logo.subline => Logo副标题:text:Fast Table Flow
 * logo.url => Logo地址:textarea:|默认使用本地logo-icon-128.avif
 * logo.width => Logo宽度:responsive:70/70|px
 * logo.height => Logo高度:responsive:|px[可选，默认使用width值]
 *
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#0a0a0f
 * navigation.bg_color_scrolled => 滚动后背景色:color:rgba(10, 10, 15, 0.98)
 * navigation.text_color => 导航文字颜色:color:#ffffff
 * navigation.link_color => 链接颜色:color:#ffffff
 * navigation.link_hover_color => 链接悬停颜色:color:#ffd700
 * navigation.link_font_size => 链接字号:number:14|px
 * navigation.link_font_weight => 链接字重:number:500
 * navigation.link_gap => 链接间距:number:40|px
 * navigation.padding_x => 水平内边距:number:24|px
 * navigation.padding_y => 垂直内边距:number:12|px
 * navigation.min_height => 最小高度:number:70|px
 * navigation.box_shadow => 阴影:text:0 2px 10px rgba(0,0,0,0.5)
 * navigation.backdrop_blur => 背景模糊:number:10|px
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.items => 导航项配置:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQs=>/faqs|配置格式：名字=>url，一行一个
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:DOWNLOAD APP
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#ff6b35
 * download_button.bg_hover_color => 按钮悬停背景色:color:#e55a2b
 * download_button.text_color => 按钮文字颜色:color:#ffffff
 * download_button.font_size => 按钮字号:number:12|px
 * download_button.font_weight => 按钮字重:number:700
 * download_button.border_radius => 按钮圆角:number:8|px
 * download_button.padding_x => 按钮水平内边距:number:20|px
 * download_button.padding_y => 按钮垂直内边距:number:10|px
 *
 * @fields_end
 */

$componentId = 'oct-header-nav-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function(array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = function($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim($parts[0] ?? ''),
        'desktop' => trim($parts[1] ?? ($parts[0] ?? '')),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = function($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$defaultLogoUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/teen-patti-octane/asset/img/logo-icon-128.avif');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $defaultLogoUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '70/70') . 'px'));
$logoHeightConfig = $getConfigAny(['logo.height', 'header.logo.height'], '');
$logoHeight = empty($logoHeightConfig) ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], '#08131f');
$navBgColorScrolled = $getConfig('navigation.bg_color_scrolled', 'rgba(8, 19, 31, 0.94)');
$navTextColor = $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#eaf4ff');
$linkColor = $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#eaf4ff');
$linkHoverColor = $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#ffd166');
$linkFontSize = $getConfig('navigation.link_font_size', '14');
$linkFontWeight = $getConfig('navigation.link_font_weight', '600');
$linkGap = $getConfig('navigation.link_gap', '26');
$navPaddingX = $getConfig('navigation.padding_x', '24');
$navPaddingY = $getConfig('navigation.padding_y', '12');
$navMinHeight = $getConfig('navigation.min_height', '72');
$navBoxShadow = $getConfig('navigation.box_shadow', '0 10px 30px rgba(0,0,0,0.26)');
$navBackdropBlur = $getConfig('navigation.backdrop_blur', '14');
$useCustomLinks = $normalizeToggle($getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], 'yes'), 'yes') === 'yes';

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $navigationPages = $page->getHeaderNavigationPages(12);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $navigationPages = $page->getNavigationPages([], 12);
    }
    foreach ($navigationPages as $navPage) {
        $type = trim((string)($navPage['type'] ?? ''));
        $label = $type !== '' ? trim((string)$getConfigAny([
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], '')) : '';
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}
if (empty($navItems)) {
    $navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $text = trim((string)($parts[0] ?? ''));
        $href = trim((string)($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }
        if ($href === '') {
            $href = '/' . strtolower(preg_replace('/[^a-zA-Z0-9]+/', '-', $text));
        }
        $navItems[] = ['text' => $text, 'href' => $href];
    }
}
if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

$downloadBtnDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$downloadBtnText = trim((string)$getConfigAny(['download_button.text', 'header.download_button.text'], 'DOWNLOAD APP'));
if ($downloadBtnText === '') {
    $downloadBtnText = 'DOWNLOAD APP';
}
$downloadBtnUrl = $getConfigAny(['download_button.url', 'header.download_button.url'], '#download');
$downloadBtnBgColor = $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#ff7a2f');
$downloadBtnBgHoverColor = $getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], '#e45f18');
$downloadBtnTextColor = $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#ffffff');
$headerDownloadSize = trim((string)$getConfig('header.download_button.size', ''));
$downloadBtnFontSizeCss = $getConfig('download_button.font_size', '') !== ''
    ? ((int)$getConfig('download_button.font_size', '12') . 'px')
    : ($headerDownloadSize !== '' ? $genResponsiveCSS($parseResponsive($headerDownloadSize . 'px')) : '12px');
$downloadBtnFontWeight = $getConfig('download_button.font_weight', '700');
$downloadBtnRadius = $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '10');
$headerDownloadPadding = trim((string)$getConfig('header.download_button.padding', ''));
$downloadBtnPaddingXCss = $getConfig('download_button.padding_x', '') !== ''
    ? ((int)$getConfig('download_button.padding_x', '18') . 'px')
    : ($headerDownloadPadding !== '' ? 'calc(' . $genResponsiveCSS($parseResponsive($headerDownloadPadding . 'px')) . ' * 1.8)' : '18px');
$downloadBtnPaddingYCss = $getConfig('download_button.padding_y', '') !== ''
    ? ((int)$getConfig('download_button.padding_y', '10') . 'px')
    : ($headerDownloadPadding !== '' ? $genResponsiveCSS($parseResponsive($headerDownloadPadding . 'px')) : '10px');

$brandName = trim((string)$getConfigAny(['logo.text', 'header.logo.text'], ''));
if ($brandName === '' && $page) {
    $brandName = (string)($page->getData('title') ?: '');
}
if ($brandName === '') {
    $brandName = 'Teen Patti Octane';
}
$brandSubline = trim((string)$getConfigAny(['logo.subline', 'header.logo.subline'], ''));
if ($brandSubline === '') {
    $brandHighlights = array_slice(array_map(static function ($item) {
        return trim((string)($item['text'] ?? ''));
    }, $navItems), 0, 2);
    $brandHighlights = array_values(array_filter($brandHighlights, static function ($item) {
        return $item !== '';
    }));
    $brandSubline = implode(' / ', $brandHighlights);
}
if ($brandSubline === '') {
    $brandSubline = 'Fast Table Flow';
}
$standaloneShell = !($this->getData('__oct_shell_managed') || $this->getData('__pagebuilder_shell_managed'));
$pageTitle = $page ? (string)($page->getData('meta_title') ?: $page->getData('title') ?: $brandName) : $brandName;
?>
<?php if ($standaloneShell): ?>
