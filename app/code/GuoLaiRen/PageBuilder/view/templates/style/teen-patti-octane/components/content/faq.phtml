 * style.question_font_size_mobile => 问题字号(移动端):number:14|px
 * style.question_padding => 问题内边距:number:18|px
 * style.question_hover_bg => 问题悬停背景色:color:rgba(255,245,232,0.08)
 * style.icon_color => 图标颜色:color:#53e0c5
 * style.icon_size => 图标尺寸:number:18|px
 * style.answer_color => 答案颜色:color:#fff5ea
 * style.answer_font_size => 答案字号:number:14|px
 * style.answer_padding => 答案内边距:number:18|px
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 *
 * group:texts => 文本设置
 * texts.title => 区域标题:text:FAQs
 * texts.intro => 区域摘要:text:Short answers about installs, switching rooms, payouts, and connection stability.
 * texts.faq_1_question => 问题1:text:Is Teen Patti Octane safe for real-money play?
 * texts.faq_1_answer => 答案1:textarea:Teen Patti Octane uses protected sessions and transaction checks. Always use the official app source.
 * texts.faq_2_question => 问题2:text:How do I download the latest APK build?
 * texts.faq_2_answer => 答案2:textarea:Use the official download button on this page and allow installation from trusted sources on Android.
 * texts.faq_3_question => 问题3:text:Can I switch between Teen Patti, Rummy, and Slots quickly?
 * texts.faq_3_answer => 答案3:textarea:Yes. The lobby is designed for quick route switching so you can jump between card modes in a few taps.
 * texts.faq_4_question => 问题4:text:How are withdrawals handled?
 * texts.faq_4_answer => 答案4:textarea:Wallet history tracks each payout request so you can review status updates from a single panel.
 * texts.faq_5_question => 问题5:text:Does it work smoothly on low-network conditions?
 * texts.faq_5_answer => 答案5:textarea:Gameplay is optimized for unstable networks, and active rounds recover with session continuity.
 *
 * @fields_end
 */

$componentId = 'oct-faq-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'yes') === 'yes';

$bgColor = $getConfig('style.bg_color', $getConfig('faq.bg_color', '#1a120d'));
$titleColor = $getConfig('style.title_color', '#ffd6a8');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$itemBgColor = $getConfig('style.item_bg_color', 'rgba(255,245,232,0.08)');
$itemBorderRadius = (int)$getConfig('style.item_border_radius', '12');
$itemBorderColor = $getConfig('style.item_border_color', 'rgba(255,233,207,0.18)');
$itemGap = (int)$getConfig('style.item_gap', '14');
$questionColor = $getConfig('style.question_color', '#ffd6a8');
$questionFontSize = (int)$getConfig('style.question_font_size', '16');
$questionFontSizeMobile = (int)$getConfig('style.question_font_size_mobile', '14');
$questionPadding = (int)$getConfig('style.question_padding', '18');
$questionHoverBg = $getConfig('style.question_hover_bg', 'rgba(255,245,232,0.08)');
$iconColor = $getConfig('style.icon_color', '#53e0c5');
$iconSize = (int)$getConfig('style.icon_size', '18');
$answerColor = $getConfig('style.answer_color', '#fff5ea');
$answerFontSize = (int)$getConfig('style.answer_font_size', '14');
$answerPadding = (int)$getConfig('style.answer_padding', '18');
$sectionPadding = (int)$getConfig('style.section_padding', '60');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '40');

$title = $getConfig('texts.title', $getConfig('faq.title', 'FAQs'));
$intro = $getConfig('texts.intro', $getConfig('texts.faq_intro', 'Short answers about installs, switching rooms, payouts, and connection stability.'));

$faqs = [
    [
        'question' => $getConfig('texts.faq_1_question', $getConfig('texts.faq_question_1', 'Is Teen Patti Octane safe for real-money play?')),
        'answer' => $getConfig('texts.faq_1_answer', $getConfig('texts.faq_answer_1', 'Teen Patti Octane uses protected sessions and transaction checks. Always use the official app source.')),
    ],
    [
        'question' => $getConfig('texts.faq_2_question', $getConfig('texts.faq_question_2', 'How do I download the latest APK build?')),
        'answer' => $getConfig('texts.faq_2_answer', $getConfig('texts.faq_answer_2', 'Use the official download button on this page and allow installation from trusted sources on Android.')),
    ],
    [
        'question' => $getConfig('texts.faq_3_question', $getConfig('texts.faq_question_3', 'Can I switch between Teen Patti, Rummy, and Slots quickly?')),
        'answer' => $getConfig('texts.faq_3_answer', $getConfig('texts.faq_answer_3', 'Yes. The lobby is designed for quick route switching so you can jump between card modes in a few taps.')),
    ],
    [
        'question' => $getConfig('texts.faq_4_question', $getConfig('texts.faq_question_4', 'How are withdrawals handled?')),
        'answer' => $getConfig('texts.faq_4_answer', $getConfig('texts.faq_answer_4', 'Wallet history tracks each payout request so you can review status updates from a single panel.')),
    ],
    [
        'question' => $getConfig('texts.faq_5_question', $getConfig('texts.faq_question_5', 'Does it work smoothly on low-network conditions?')),
        'answer' => $getConfig('texts.faq_5_answer', $getConfig('texts.faq_answer_5', 'Gameplay is optimized for unstable networks, and active rounds recover with session continuity.')),
    ],
];
?>

<section id="<?= $componentId ?>" class="oct-faq">
    <div class="section-inner">
        <?php if ($showTitle): ?>
            <h2 class="section-title"><?= htmlspecialchars($title) ?></h2>
            <?php if ($intro !== ''): ?>
                <p class="section-intro"><?= htmlspecialchars($intro) ?></p>
            <?php endif; ?>
        <?php endif; ?>

        <div class="faq-list">
            <?php foreach ($faqs as $index => $faq): ?>
                <article class="faq-item<?= ($firstOpen && $index === 0) ? ' is-open' : '' ?>" data-faq-item>
                    <button class="faq-question" type="button" aria-expanded="<?= ($firstOpen && $index === 0) ? 'true' : 'false' ?>">
                        <span class="faq-index"><?= sprintf('%02d', $index + 1) ?></span>
                        <span class="faq-text"><?= htmlspecialchars($faq['question']) ?></span>
                        <span class="faq-icon" aria-hidden="true"></span>
                    </button>
                    <div class="faq-answer"<?= ($firstOpen && $index === 0) ? '' : ' hidden' ?>>
                        <?= nl2br(htmlspecialchars($faq['answer'])) ?>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    padding: <?= $sectionPadding ?>px 0;
    background:
        radial-gradient(720px 260px at 92% 0%, rgba(83, 224, 197, 0.16), transparent 66%),
        radial-gradient(780px 300px at 0% 100%, rgba(255, 122, 74, 0.15), transparent 68%),
        <?= htmlspecialchars($bgColor) ?>;
    border-top: 1px solid rgba(255, 224, 196, 0.14);
}

#<?= $componentId ?> .section-inner {
    width: min(980px, calc(100% - 1.2rem));
    margin: 0 auto;
}

#<?= $componentId ?> .section-title {
    margin: 0 0 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    text-align: center;
    color: <?= htmlspecialchars($titleColor) ?>;
    font-size: clamp(<?= $titleFontSizeMobile ?>px, 5vw, <?= $titleFontSize ?>px);
}

#<?= $componentId ?> .section-intro {
    margin: -12px auto 28px;
    max-width: 720px;
    text-align: center;
    color: <?= htmlspecialchars($answerColor) ?>;
    line-height: 1.72;
}

#<?= $componentId ?> .section-title::before,
#<?= $componentId ?> .section-title::after {
    content: '';
    flex: 1 1 120px;
