    height: 10px;
}

#<?= $componentId ?> .section-title::before {
    background:
        linear-gradient(90deg, rgba(83, 224, 197, 0), rgba(83, 224, 197, 0.74) 58%, rgba(255, 186, 124, 0.92) 100%) center/100% 2px no-repeat,
        linear-gradient(135deg, transparent 45%, rgba(255, 186, 124, 0.92) 46% 56%, transparent 57%) right center/10px 10px no-repeat;
}

#<?= $componentId ?> .section-title::after {
    background:
        linear-gradient(270deg, rgba(83, 224, 197, 0), rgba(83, 224, 197, 0.74) 58%, rgba(255, 186, 124, 0.92) 100%) center/100% 2px no-repeat,
        linear-gradient(-135deg, transparent 45%, rgba(255, 186, 124, 0.92) 46% 56%, transparent 57%) left center/10px 10px no-repeat;
}

#<?= $componentId ?> .faq-list {
    display: grid;
    gap: <?= $itemGap ?>px;
}

#<?= $componentId ?> .faq-item {
    border-radius: <?= $itemBorderRadius ?>px;
    border: 1px solid <?= htmlspecialchars($itemBorderColor) ?>;
    background: <?= htmlspecialchars($itemBgColor) ?>;
    overflow: hidden;
    transition: border-color 0.25s ease, background 0.25s ease;
}

#<?= $componentId ?> .faq-item.is-open {
    border-color: rgba(83, 224, 197, 0.5);
    background: rgba(30, 18, 12, 0.9);
}

#<?= $componentId ?> .faq-question {
    width: 100%;
    border: 0;
    background: transparent;
    color: <?= htmlspecialchars($questionColor) ?>;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.72rem;
    padding: <?= $questionPadding ?>px;
    text-align: left;
    cursor: pointer;
    font-size: <?= $questionFontSize ?>px;
    font-weight: 700;
}

#<?= $componentId ?> .faq-question:hover {
    background: <?= htmlspecialchars($questionHoverBg) ?>;
}

#<?= $componentId ?> .faq-index {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: #53e0c5;
    border: 1px solid rgba(83, 224, 197, 0.38);
    border-radius: 999px;
    padding: 0.16rem 0.45rem;
    font-weight: 800;
}

#<?= $componentId ?> .faq-icon {
    width: <?= $iconSize ?>px;
    height: <?= $iconSize ?>px;
    position: relative;
    color: <?= htmlspecialchars($iconColor) ?>;
}

#<?= $componentId ?> .faq-icon::before,
#<?= $componentId ?> .faq-icon::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: <?= $iconSize ?>px;
    height: 2px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease;
}

#<?= $componentId ?> .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
}

#<?= $componentId ?> .faq-item.is-open .faq-icon::after {
    transform: translate(-50%, -50%) rotate(0deg);
}

#<?= $componentId ?> .faq-answer {
    padding: 0 <?= $answerPadding ?>px <?= $answerPadding ?>px calc(<?= $answerPadding ?>px + 2.7rem);
    color: <?= htmlspecialchars($answerColor) ?>;
    font-size: <?= $answerFontSize ?>px;
    line-height: 1.78;
    opacity: 0.92;
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= $sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .section-inner {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .faq-question {
        font-size: <?= $questionFontSizeMobile ?>px;
        padding: 14px;
    }

    #<?= $componentId ?> .faq-answer {
        padding: 0 14px 14px 14px;
    }

    #<?= $componentId ?> .section-title {
        margin-bottom: 24px;
        gap: 0.58rem;
    }

    #<?= $componentId ?> .section-title::before,
    #<?= $componentId ?> .section-title::after {
        max-width: 96px;
        min-width: 40px;
        height: 8px;
    }

    #<?= $componentId ?> .faq-index {
        display: none;
    }
}
</style>

<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) return;

    var items = root.querySelectorAll('[data-faq-item]');
    items.forEach(function (item) {
        var button = item.querySelector('.faq-question');
        var answer = item.querySelector('.faq-answer');

        if (!button || !answer) return;

        button.addEventListener('click', function () {
            var isOpen = item.classList.contains('is-open');

            items.forEach(function (other) {
                var otherBtn = other.querySelector('.faq-question');
                var otherAnswer = other.querySelector('.faq-answer');
                other.classList.remove('is-open');
                if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
                if (otherAnswer) otherAnswer.hidden = true;
            });

            if (!isOpen) {
                item.classList.add('is-open');
                button.setAttribute('aria-expanded', 'true');
                answer.hidden = false;
            }
        });
    });
})();
</script>
