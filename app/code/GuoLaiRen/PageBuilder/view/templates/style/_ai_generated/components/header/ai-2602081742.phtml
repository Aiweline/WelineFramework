<script>
// 奢华头部交互效果
const header = component;

// 滚动效果 - 头部固定和阴影增强
let lastScrollTop = 0;
let ticking = false;

function updateHeaderOnScroll() {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > 50) {
        header.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.5)';
        header.style.backdropFilter = 'blur(10px)';
        header.style.background = 'linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(10, 10, 15, 0.95) 100%)';
        
        // 添加微妙的缩放效果
        const scale = 1 - Math.min(scrollTop * 0.0005, 0.05);
        header.style.transform = `scale(${scale})`;
        header.style.transformOrigin = 'top center';
    } else {
        header.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.3)';
        header.style.backdropFilter = 'none';
        header.style.background = 'linear-gradient(135deg, var(--pb-velvet) 0%, #0a0a0f 100%)';
        header.style.transform = 'none';
    }
    
    // 导航链接高亮
    const sections = document.querySelectorAll('section[id], div[id]');
    const navLinks = header.querySelectorAll('.ai-header-nav-link');
    
    let current = '';
    sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (scrollTop >= sectionTop - 200) {
            current = section.getAttribute('id');
        }
    });
    
    navLinks.forEach(link => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        if (href && href.includes('#')) {
            const targetId = href.split('#')[1];
            if (targetId === current) {
                link.classList.add('active');
            }
        }
    });
    
    lastScrollTop = scrollTop;
    ticking = false;
}

window.addEventListener('scroll', function() {
    if (!ticking) {
        window.requestAnimationFrame(updateHeaderOnScroll);
        ticking = true;
    }
});

// 鼠标移动效果
header.addEventListener('mousemove', function(e) {
    const x = e.clientX / window.innerWidth;
    const y = e.clientY / window.innerHeight;
    
    const decorationLine = header.querySelector('.luxury-header__decoration-line');
    if (decorationLine) {
        decorationLine.style.background = `linear-gradient(90deg, 
            transparent 10%, 
            rgba(212, 175, 55, ${0.1 + y * 0.2}) 30%, 
            rgba(212, 175, 55, ${0.1 + x * 0.2}) 70%, 
            transparent 90%)`;
    }
});

// 导航链接悬停效果增强
const navLinks = header.querySelectorAll('.ai-header-nav-link');
navLinks.forEach(link => {
    link.addEventListener('mouseenter', function() {
        const text = this.querySelector('.ai-header-nav-link-text');
        if (text) {
            text.style.transform = 'translateY(-1px)';
        }
    });
    
    link.addEventListener('mouseleave', function() {
        const text = this.querySelector('.ai-header-nav-link-text');
        if (text) {
            text.style.transform = 'none';
        }
    });
});

// CTA按钮悬停效果
const ctaButton = header.querySelector('.ai-header-cta');
if (ctaButton) {
    ctaButton.addEventListener('mouseenter', function() {
        const arrow = this.querySelector('svg');
        if (arrow) {
            arrow.style.transform = 'translateX(4px) rotate(-45deg)';
        }
    });
    
    ctaButton.addEventListener('mouseleave', function() {
        const arrow = this.querySelector('svg');
        if (arrow) {
            arrow.style.transform = 'none';
        }
    });
}

// 徽章动画
const badge = header.querySelector('.luxury-header__badge');
if (badge) {
    setInterval(() => {
        badge.style.transform = 'translateY(-2px)';
        setTimeout(() => {
            badge.style.transform = 'none';
        }, 300);
    }, 5000);
}

// 添加CSS动画
const style = document.createElement('style');
style.textContent = `
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
    }
    
    @keyframes sparkle {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.1); }
    }
    
    .luxury-header__badge {
        animation: float 3s ease-in-out infinite;
    }
    
    .luxury-header__badge-icon {
        animation: sparkle 2s ease-in-out infinite;
    }
`;
document.head.appendChild(style);

// 初始化
updateHeaderOnScroll();
</script>