<script>
// 移动端菜单切换
const menuToggle = component.querySelector('.ai-header-luxury__menu-toggle');
const nav = component.querySelector('.ai-header-luxury__nav');

if (menuToggle && nav) {
    menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', !isExpanded);
        nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
        
        // 动画效果
        if (nav.style.display === 'flex') {
            nav.style.opacity = '0';
            nav.style.transform = 'translateY(-20px)';
            nav.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            
            setTimeout(() => {
                nav.style.opacity = '1';
                nav.style.transform = 'translateY(0)';
            }, 10);
        }
    });
}

// 滚动效果 - 添加阴影
let lastScrollTop = 0;
const header = component;

window.addEventListener('scroll', () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > 50) {
        header.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.3)';
        header.style.backdropFilter = 'blur(10px)';
        header.style.backgroundColor = 'rgba(10, 10, 15, 0.95)';
    } else {
        header.style.boxShadow = 'none';
        header.style.backdropFilter = 'none';
        header.style.backgroundColor = '';
    }
    
    lastScrollTop = scrollTop;
});

// 导航链接悬停效果增强
const navLinks = component.querySelectorAll('.ai-header-luxury__nav-link');
navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => {
        link.style.transform = 'translateY(-2px)';
    });
    
    link.addEventListener('mouseleave', () => {
        link.style.transform = 'translateY(0)';
    });
});

// CTA按钮悬停效果增强
const ctaButton = component.querySelector('.ai-header-luxury__cta');
if (ctaButton) {
    ctaButton.addEventListener('mouseenter', () => {
        ctaButton.style.transform = 'translateY(-2px) scale(1.05)';
    });
    
    ctaButton.addEventListener('mouseleave', () => {
        ctaButton.style.transform = 'translateY(0) scale(1)';
    });
}
</script>