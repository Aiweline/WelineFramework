<script>
// 移动端菜单切换
const hamburger = component.querySelector('.luxury-header__hamburger');
const nav = component.querySelector('.luxury-header__nav');

if (hamburger && nav) {
    hamburger.addEventListener('click', (e) => {
        e.stopPropagation();
        nav.classList.toggle('active');
        hamburger.classList.toggle('active');
    });
    
    // 点击菜单外区域关闭菜单
    document.addEventListener('click', (e) => {
        if (!component.contains(e.target) && nav.classList.contains('active')) {
            nav.classList.remove('active');
            hamburger.classList.remove('active');
        }
    });
    
    // 点击导航链接关闭菜单
    const navLinks = component.querySelectorAll('.luxury-header__nav-link');
    navLinks.forEach(link => {
        link.addEventListener('click', () => {
            nav.classList.remove('active');
            hamburger.classList.remove('active');
        });
    });
}

// 搜索功能
const searchInput = component.querySelector('.luxury-header__search-input');
const searchButton = component.querySelector('.luxury-header__search-button');

if (searchInput && searchButton) {
    searchButton.addEventListener('click', () => {
        const query = searchInput.value.trim();
        if (query) {
            window.location.href = '/search?q=' + encodeURIComponent(query);
        }
    });
    
    searchInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            const query = searchInput.value.trim();
            if (query) {
                window.location.href = '/search?q=' + encodeURIComponent(query);
            }
        }
    });
}

// 滚动效果 - 添加阴影和模糊效果
let lastScroll = 0;
window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > 50) {
        component.style.boxShadow = '0 5px 20px rgba(0, 0, 0, 0.3)';
        component.style.backdropFilter = 'blur(10px)';
        component.style.backgroundColor = 'color-mix(in srgb, var(--pb-bg) 95%, transparent)';
    } else {
        component.style.boxShadow = '0 2px 20px rgba(0, 0, 0, 0.2)';
        component.style.backdropFilter = 'none';
        component.style.backgroundColor = '';
    }
    
    lastScroll = currentScroll;
});

// 导航链接激活状态
const navLinks = component.querySelectorAll('.luxury-header__nav-link');
const currentPath = window.location.pathname;

navLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (href && href !== '#' && currentPath.includes(href.replace(/^\//, ''))) {
        link.classList.add('active');
    }
});

// 平滑滚动到锚点
const smoothScrollLinks = component.querySelectorAll('a[href^="#"]');
smoothScrollLinks.forEach(link => {
    link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href.startsWith('#')) {
            e.preventDefault();
            const targetId = href.substring(1);
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
                window.scrollTo({
                    top: targetElement.offsetTop - 100,
                    behavior: 'smooth'
                });
            }
        }
    });
});
</script>