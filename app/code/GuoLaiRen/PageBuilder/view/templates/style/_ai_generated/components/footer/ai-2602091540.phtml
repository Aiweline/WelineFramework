<script>
const footer = component;
const goldLinks = footer.querySelectorAll('.pb-footer__links-link, .pb-footer__policy-link');

goldLinks.forEach(link => {
    link.addEventListener('mouseenter', () => {
        link.style.textShadow = '0 0 8px rgba(255, 215, 0, 0.5)';
    });
    
    link.addEventListener('mouseleave', () => {
        link.style.textShadow = 'none';
    });
});

const socialLinks = footer.querySelectorAll('.pb-footer__social-link');
socialLinks.forEach(social => {
    social.addEventListener('mouseenter', () => {
        social.style.boxShadow = '0 6px 20px rgba(212, 175, 55, 0.4)';
    });
    
    social.addEventListener('mouseleave', () => {
        social.style.boxShadow = '0 4px 12px rgba(212, 175, 55, 0.3)';
    });
});

const paymentIcons = footer.querySelectorAll('.pb-footer__payment-icon');
paymentIcons.forEach(icon => {
    icon.addEventListener('mouseenter', () => {
        icon.style.transform = 'translateY(-3px) scale(1.05)';
    });
    
    icon.addEventListener('mouseleave', () => {
        icon.style.transform = 'translateY(0) scale(1)';
    });
});

const certBadges = footer.querySelectorAll('.pb-footer__cert-badge');
certBadges.forEach(badge => {
    badge.addEventListener('mouseenter', () => {
        badge.style.boxShadow = '0 0 15px rgba(212, 175, 55, 0.3)';
    });
    
    badge.addEventListener('mouseleave', () => {
        badge.style.boxShadow = 'none';
    });
});
</script>