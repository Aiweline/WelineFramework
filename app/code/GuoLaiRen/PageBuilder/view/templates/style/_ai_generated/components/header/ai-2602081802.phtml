<script>
// 移动端菜单切换
const mobileToggle = component.querySelector('.ai-header-luxury__mobile-toggle');
const nav = component.querySelector('.ai-header-luxury__nav');

if (mobileToggle && nav) {
    mobileToggle.addEventListener('click', () => {
        mobileToggle.classList.toggle('active');
        nav.classList.toggle('active');
    });
}

// 滚动效果 - 添加滚动时添加阴影
let lastScrollTop = 0;
const header = component;

window.addEventListener('scroll', () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > 50) {
        header.style.boxShadow = '0 5px 20px rgba(0, 0, 0, 0.4)';
        header.style.backdropFilter = 'blur(15px)';
    } else {
        header.style.boxShadow = '0 10px 30px rgba(0, 0, 0, 0.3)';
        header.style.backdropFilter = 'blur(10px)';
    }
    
    lastScrollTop = scrollTop;
});

// 导航链接激活状态
const navLinks = component.querySelectorAll('.ai-header-luxury__nav-link');
const currentPath = window.location.pathname;

navLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (href && href !== '#' && currentPath.includes(href.replace(/^\/+/, ''))) {
        link.classList.add('active');
    }
    
    link.addEventListener('click', () => {
        // 移动端点击后关闭菜单
        if (window.innerWidth <= 768) {
            mobileToggle?.classList.remove('active');
            nav?.classList.remove('active');
        }
    });
});
</script>