<script>
// 社交图标悬停效果增强
const socialIcons = component.querySelectorAll('[class*="-social-icon"]');
socialIcons.forEach(icon => {
    icon.addEventListener('mouseenter', () => {
        icon.style.transform = 'translateY(-4px) scale(1.1)';
        icon.style.boxShadow = '0 8px 20px rgba(255, 215, 0, 0.2)';
    });
    
    icon.addEventListener('mouseleave', () => {
        icon.style.transform = 'translateY(0) scale(1)';
        icon.style.boxShadow = 'none';
    });
});

// 链接点击动画
const columnLinks = component.querySelectorAll('[class*="-column-link"]');
columnLinks.forEach(link => {
    link.addEventListener('click', (e) => {
        // 添加点击反馈
        link.style.transform = 'translateX(8px)';
        setTimeout(() => {
            link.style.transform = '';
        }, 300);
    });
});

// 金牌徽章闪烁效果
const goldBadge = component.querySelector('[class*="-gold-badge"]');
if (goldBadge) {
    setInterval(() => {
        goldBadge.style.boxShadow = '0 0 20px rgba(255, 215, 0, 0.3)';
        setTimeout(() => {
            goldBadge.style.boxShadow = 'none';
        }, 1000);
    }, 3000);
}

// 滚动时显示边框效果
let lastScrollTop = 0;
const footer = component;

const handleScroll = () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    const scrollDirection = scrollTop > lastScrollTop ? 'down' : 'up';
    
    if (scrollDirection === 'up' && scrollTop < 100) {
        footer.style.borderTop = '2px solid rgba(255, 215, 0, 0.5)';
    } else {
        footer.style.borderTop = 'none';
    }
    
    lastScrollTop = scrollTop;
};

// 监听滚动
window.addEventListener('scroll', handleScroll);
handleScroll(); // 初始调用
</script>