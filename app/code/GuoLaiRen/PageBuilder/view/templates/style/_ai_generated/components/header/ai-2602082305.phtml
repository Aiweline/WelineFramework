<script>
const menuToggle = component.querySelector('.luxury-header__menu-toggle');
const nav = component.querySelector('.luxury-header__nav');
const navList = component.querySelector('.luxury-header__nav-list');

if (menuToggle && nav && navList) {
    menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', !isExpanded);
        nav.classList.toggle('luxury-header__nav--active');
        menuToggle.classList.toggle('luxury-header__menu-toggle--active');
        
        if (!isExpanded) {
            navList.style.maxHeight = navList.scrollHeight + 'px';
        } else {
            navList.style.maxHeight = null;
        }
    });
}

let lastScrollTop = 0;
const header = component;

window.addEventListener('scroll', () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > 100) {
        header.classList.add('luxury-header--scrolled');
        
        if (scrollTop > lastScrollTop && scrollTop > 200) {
            header.classList.add('luxury-header--hidden');
        } else {
            header.classList.remove('luxury-header--hidden');
        }
    } else {
        header.classList.remove('luxury-header--scrolled', 'luxury-header--hidden');
    }
    
    lastScrollTop = scrollTop;
});

const navLinks = component.querySelectorAll('.luxury-header__nav-link');
navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => {
        link.classList.add('luxury-header__nav-link--active');
    });
    
    link.addEventListener('mouseleave', () => {
        link.classList.remove('luxury-header__nav-link--active');
    });
});
</script>