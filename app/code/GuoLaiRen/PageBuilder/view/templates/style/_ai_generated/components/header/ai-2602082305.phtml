<?php
$component_config = $component_config ?? [];
$getConfig = $getConfig ?? static function (string $key, $default = null) use ($component_config) {
    $value = $component_config;
    foreach (explode('.', $key) as $segment) {
        if (!is_array($value) || !array_key_exists($segment, $value)) {
            return $default;
        }
        $value = $value[$segment];
    }
    return $value;
};
$luxurySlogan = $getConfig('luxury.slogan', __('EXCLUSIVE LUXURY'));
$showLogo = $getConfig('logo.show', 'yes') !== 'no';
$logoText = $getConfig('logo.text', __('品牌名称'));
$logoImage = $getConfig('logo.image', '');
$showNav = $getConfig('nav.show', 'yes') !== 'no';
$navItems = $getConfig('nav.items', []);
$showCta = $getConfig('cta.show', 'yes') !== 'no';
$ctaText = $getConfig('cta.text', __('立即咨询'));
$ctaUrl = $getConfig('cta.url', '#');
?>
<header id="<?= $componentId ?>" class="luxury-header">
    <div class="luxury-header__container">
        <?php if ($showLogo): ?>
        <div class="luxury-header__logo">
            <?php if (!empty($logoImage)): ?>
            <img src="<?= htmlspecialchars($logoImage) ?>" alt="<?= htmlspecialchars($logoText) ?>" loading="lazy" class="luxury-header__logo-image">
            <?php else: ?>
            <div class="luxury-header__logo-text">
                <span class="luxury-header__logo-main"><?= htmlspecialchars($logoText) ?></span>
                <span class="luxury-header__logo-sub"><?= htmlspecialchars($luxurySlogan) ?></span>
            </div>
            <?php endif; ?>
        </div>
        <?php endif; ?>

        <?php if ($showNav && !empty($navItems)): ?>
        <nav class="luxury-header__nav">
            <ul class="luxury-header__nav-list">
                <?php foreach ($navItems as $item): ?>
                <li class="luxury-header__nav-item">
                    <a href="<?= htmlspecialchars($item['href']) ?>" class="luxury-header__nav-link">
                        <span class="luxury-header__nav-text"><?= htmlspecialchars($item['text']) ?></span>
                        <span class="luxury-header__nav-decoration"></span>
                    </a>
                </li>
                <?php endforeach; ?>
            </ul>
        </nav>
        <?php endif; ?>

        <div class="luxury-header__actions">
            <?php if ($showCta): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="luxury-header__cta">
                <span class="luxury-header__cta-text"><?= htmlspecialchars($ctaText) ?></span>
                <span class="luxury-header__cta-icon">→</span>
            </a>
            <?php endif; ?>
            
            <button class="luxury-header__menu-toggle" aria-label="<?= __('菜单') ?>">
                <span class="luxury-header__menu-icon"></span>
            </button>
        </div>
    </div>
</header>
