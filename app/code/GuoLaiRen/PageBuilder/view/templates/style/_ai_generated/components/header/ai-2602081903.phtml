<script>
// 移动端菜单切换
const menuToggle = component.querySelector('.ai-header-luxury__menu-toggle');
const nav = component.querySelector('.ai-header-luxury__nav');

if (menuToggle && nav) {
    menuToggle.addEventListener('click', function() {
        nav.classList.toggle('active');
        this.classList.toggle('active');
        
        // 菜单图标动画
        const menuIcon = this.querySelector('.ai-header-luxury__menu-icon');
        if (menuIcon) {
            if (nav.classList.contains('active')) {
                menuIcon.style.transform = 'translate(-50%, -50%) rotate(45deg)';
                menuIcon.style.background = '#FFD700';
                menuIcon.style.width = '20px';
                
                menuIcon.style.setProperty('--before-transform', 'translateY(8px) rotate(90deg)');
                menuIcon.style.setProperty('--after-transform', 'translateY(-8px) rotate(90deg)');
                
                const before = menuIcon.querySelector('::before');
                const after = menuIcon.querySelector('::after');
                
                if (before) before.style.transform = 'translateY(8px) rotate(90deg)';
                if (after) after.style.transform = 'translateY(-8px) rotate(90deg)';
            } else {
                menuIcon.style.transform = 'translate(-50%, -50%) rotate(0)';
                menuIcon.style.background = '';
                menuIcon.style.width = '';
                
                const before = menuIcon.querySelector('::before');
                const after = menuIcon.querySelector('::after');
                
                if (before) before.style.transform = '';
                if (after) after.style.transform = '';
            }
        }
    });
    
    // 点击菜单外区域关闭菜单
    document.addEventListener('click', function(event) {
        if (!component.contains(event.target) && nav.classList.contains('active')) {
            nav.classList.remove('active');
            menuToggle.classList.remove('active');
        }
    });
}

// 滚动效果 - 添加阴影和缩小效果
let lastScrollTop = 0;
const header = component;

window.addEventListener('scroll', function() {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > 50) {
        header.style.boxShadow = '0 5px 20px rgba(0, 0, 0, 0.3)';
        header.style.height = '80px';
        header.querySelector('.ai-header-luxury__container').style.height = '80px';
    } else {
        header.style.boxShadow = 'none';
        header.style.height = '';
        header.querySelector('.ai-header-luxury__container').style.height = '';
    }
    
    lastScrollTop = scrollTop;
});

// 导航链接悬停效果增强
const navLinks = component.querySelectorAll('.ai-header-luxury__nav-link');
navLinks.forEach(link => {
    link.addEventListener('mouseenter', function() {
        const decoration = this.querySelector('.ai-header-luxury__nav-decoration');
        if (decoration) {
            decoration.style.transition = 'width 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
        }
    });
    
    link.addEventListener('mouseleave', function() {
        const decoration = this.querySelector('.ai-header-luxury__nav-decoration');
        if (decoration) {
            decoration.style.transition = 'width 0.3s ease';
        }
    });
});

// CTA按钮悬停效果
const ctaButton = component.querySelector('.ai-header-luxury__cta');
if (ctaButton) {
    ctaButton.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-2px) scale(1.05)';
    });
    
    ctaButton.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0) scale(1)';
    });
}
</script>