<?php
$component_config = $component_config ?? [];
$getConfig = $getConfig ?? static function (string $key, $default = null) use ($component_config) {
    $value = $component_config;
    foreach (explode('.', $key) as $segment) {
        if (!is_array($value) || !array_key_exists($segment, $value)) {
            return $default;
        }
        $value = $value[$segment];
    }
    return $value;
};
$showBrand = $getConfig('brand.show', 'yes') !== 'no';
$brandLogo = $getConfig('brand.logo', '');
$brandName = $getConfig('brand.name', __('品牌名称'));
$brandDesc = $getConfig('brand.desc', '');
$showLinks = $getConfig('links.show', 'yes') !== 'no';
$linksRaw = $getConfig('links.items', [
    ['text' => __('关于我们'), 'href' => '#about'],
    ['text' => __('联系我们'), 'href' => '#contact'],
    ['text' => __('隐私政策'), 'href' => '#privacy'],
]);
$links = is_array($linksRaw) ? $linksRaw : [];
$copyright = $getConfig('copyright.text', '');
?>
<footer id="<?= $componentId ?>" class="luxury-footer">
    <div class="luxury-footer__container">
        <?php if ($showBrand): ?>
        <div class="luxury-footer__brand">
            <?php if (!empty($brandLogo)): ?>
            <img src="<?= htmlspecialchars($brandLogo) ?>" alt="<?= htmlspecialchars($brandName) ?>" loading="lazy" class="luxury-footer__logo">
            <?php endif; ?>
            <div class="luxury-footer__brand-text">
                <div class="luxury-footer__brand-name"><?= htmlspecialchars($brandName) ?></div>
                <?php if (!empty($brandDesc)): ?>
                <div class="luxury-footer__brand-desc"><?= htmlspecialchars($brandDesc) ?></div>
                <?php endif; ?>
            </div>
        </div>
        <?php endif; ?>

        <?php if ($showLinks && !empty($links)): ?>
        <ul class="luxury-footer__links">
            <?php foreach ($links as $item): ?>
            <li class="luxury-footer__link-item">
                <a href="<?= htmlspecialchars($item['href'] ?? '#') ?>" class="luxury-footer__link"><?= htmlspecialchars($item['text'] ?? '') ?></a>
            </li>
            <?php endforeach; ?>
        </ul>
        <?php endif; ?>
    </div>
    <?php if (!empty($copyright)): ?>
    <div class="luxury-footer__copyright"><?= htmlspecialchars($copyright) ?></div>
    <?php endif; ?>
</footer>
<style>
#componentId {
    background: var(--pb-bg);
    color: var(--pb-text);
    border-top: 1px solid var(--pb-border);
}
#componentId .luxury-footer__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
}
#componentId .luxury-footer__brand {
    display: flex;
    align-items: center;
    gap: 14px;
}
#componentId .luxury-footer__logo {
    height: 40px;
    width: auto;
}
#componentId .luxury-footer__brand-name {
    font-weight: 700;
    color: var(--pb-heading);
}
#componentId .luxury-footer__brand-desc {
    font-size: 0.85rem;
    color: var(--pb-text-muted);
}
#componentId .luxury-footer__links {
    list-style: none;
    display: flex;
    gap: 18px;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
}
#componentId .luxury-footer__link {
    color: var(--pb-link);
    text-decoration: none;
    font-size: 0.9rem;
}
#componentId .luxury-footer__link:hover {
    color: var(--pb-link-hover);
}
#componentId .luxury-footer__copyright {
    text-align: center;
    padding: 12px 16px 24px;
    font-size: 0.8rem;
    color: var(--pb-text-muted);
}
</style>