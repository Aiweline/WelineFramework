{
    "name": "AI Component Frameworks",
    "description": "基础框架模板，供AI生成组件时使用",
    "version": "1.0.0",
    
    "frameworks": {
        "header": {
            "file": "header_framework.phtml",
            "description": "头部组件框架，包含固定的导航结构",
            "placeholders": {
                "COMPONENT_NAME": "组件名称",
                "COMPONENT_NAME_EN": "组件英文名称",
                "COMPONENT_DESC": "组件描述",
                "EXTRA_FIELDS": "额外的字段定义",
                "PHP_VARIABLES": "额外的PHP变量准备代码",
                "CSS_EXTRA": "额外的CSS样式",
                "HTML_EXTRA": "额外的HTML内容",
                "JS_CONTENT": "JavaScript代码"
            },
            "fixed_sections": [
                "导航数据获取逻辑",
                "Logo配置逻辑",
                "响应式菜单切换"
            ]
        },
        "content": {
            "file": "content_framework.phtml",
            "description": "内容组件框架，通用的内容区块结构",
            "placeholders": {
                "COMPONENT_NAME": "组件名称",
                "COMPONENT_NAME_EN": "组件英文名称",
                "COMPONENT_DESC": "组件描述",
                "EXTRA_FIELDS": "额外的字段定义",
                "PHP_VARIABLES": "额外的PHP变量准备代码",
                "CSS_EXTRA": "额外的CSS样式",
                "CSS_RESPONSIVE": "响应式CSS样式",
                "HTML_CONTENT": "主体HTML内容",
                "JS_CONTENT": "JavaScript代码"
            },
            "fixed_sections": [
                "基础数据获取",
                "标题/副标题/描述结构"
            ]
        },
        "footer": {
            "file": "footer_framework.phtml",
            "description": "底部组件框架，包含固定的版权和链接结构",
            "placeholders": {
                "COMPONENT_NAME": "组件名称",
                "COMPONENT_NAME_EN": "组件英文名称",
                "COMPONENT_DESC": "组件描述",
                "EXTRA_FIELDS": "额外的字段定义",
                "PHP_VARIABLES": "额外的PHP变量准备代码",
                "CSS_EXTRA": "额外的CSS样式",
                "CSS_RESPONSIVE": "响应式CSS样式",
                "HTML_EXTRA_COLUMN": "额外的链接列",
                "HTML_EXTRA": "额外的主体内容",
                "FOOTER_EXTRA_TEXT": "底部额外文字",
                "JS_CONTENT": "JavaScript代码"
            },
            "fixed_sections": [
                "品牌信息展示",
                "链接列解析",
                "社交媒体图标",
                "版权信息"
            ]
        }
    },
    
    "ai_response_format": {
        "description": "AI应返回的JSON格式",
        "required_fields": ["html_content"],
        "optional_fields": ["extra_fields", "php_variables", "css_extra", "css_responsive", "js_content"],
        "example": {
            "extra_fields": "group:custom => 自定义设置\ncustom.field1 => 字段1:text:默认值",
            "php_variables": "$customVar = $getConfig('custom.field1', '默认值');",
            "css_extra": ".custom-class { color: red; }",
            "css_responsive": ".custom-class { font-size: 14px; }",
            "html_content": "<div class=\"custom-class\"><?= htmlspecialchars($customVar) ?></div>",
            "js_content": "console.log('Component loaded');"
        }
    }
}
