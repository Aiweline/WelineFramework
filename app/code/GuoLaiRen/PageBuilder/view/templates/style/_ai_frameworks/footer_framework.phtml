$brandName = $getConfig('brand.name', 'Brand Name');
$brandDesc = $getConfig('brand.description', 'Your trusted partner for quality services.');

// 链接配置
$col1Title = $getConfig('links.column1_title', 'Quick Links');
$col1Items = $parseLinks($getConfig('links.column1_items', "Home=>/\nAbout=>/about\nServices=>/services\nContact=>/contact"));
$col2Title = $getConfig('links.column2_title', 'Legal');
$col2Items = $parseLinks($getConfig('links.column2_items', "Privacy Policy=>/privacy\nTerms of Service=>/terms"));

