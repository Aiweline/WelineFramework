}

/* AI生成的额外CSS */
{{CSS_EXTRA}}
</style>

<!-- Header HTML结构 -->
<header id="<?= $componentId ?>" class="ai-component ai-header">
    <div class="ai-header-container">
        <!-- Logo -->
        <?php if ($showLogo): ?>
        <a href="/" class="ai-header-logo">
            <?php if ($logoImage): ?>
                <img src="<?= htmlspecialchars($logoImage) ?>" alt="<?= htmlspecialchars($logoText) ?>" loading="lazy">
            <?php endif; ?>
            <span><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        
        <!-- Mobile Toggle -->
        <button class="ai-header-toggle" onclick="this.classList.toggle('active'); document.querySelector('#<?= $componentId ?> .ai-header-nav').classList.toggle('active');" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>
        
        <!-- Navigation -->
        <?php if ($showNav): ?>
        <nav class="ai-header-nav">
            <ul class="ai-header-nav-links">
                <?php foreach ($navItems as $index => $navItem): ?>
                    <?php 
                    $navHref = $navItem['href'] ?? '#';
                    $navText = $navItem['text'] ?? '';
                    $isActive = $index === 0;
                    ?>
                    <li><a href="<?= htmlspecialchars($navHref) ?>" class="ai-header-nav-link <?= $isActive ? 'active' : '' ?>"><?= htmlspecialchars($navText) ?></a></li>
                <?php endforeach; ?>
            </ul>
            
            <?php if ($showCta): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="ai-header-cta"><?= htmlspecialchars($ctaText) ?></a>
            <?php endif; ?>
        </nav>
        <?php endif; ?>
        
        <!-- AI生成的额外HTML -->
        {{HTML_EXTRA}}
    </div>
</header>

