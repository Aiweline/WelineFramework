<?php
/**
 * AI Component Framework - Header
 * 
 * 头部组件框架模板，包含固定的导航结构
 * AI只需填充特定区域的代码
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $component_config 组件配置
 * 
 * @component_start
 * name => {{COMPONENT_NAME}}
 * name_en => {{COMPONENT_NAME_EN}}
 * description => {{COMPONENT_DESC}}
 * category => header
 * type => section
 * sort_order => 10
 * compatible_styles => *
 * ai_generated => true
 * @component_end
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.image => Logo图片URL:textarea:|留空使用默认文字Logo
 * logo.text => Logo文字:text:Brand Name
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * 
 * group:cta => CTA按钮
 * cta.show => 显示CTA按钮:select:yes|yes,no
 * cta.text => 按钮文字:text:Get Started
 * cta.url => 按钮链接:text:#contact
 * 
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#0a0a0f
 * style.text_color => 文字颜色:color:#ffffff
 * style.link_color => 链接颜色:color:#b8b8d0
 * style.link_hover_color => 链接悬停颜色:color:#7c3aed
 * style.accent_color => 强调色:color:#7c3aed
 * 
 * {{EXTRA_FIELDS}}
 * 
 * @fields_end
 */

// ===== 固定的PHP数据获取部分 =====
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$componentId = 'ai-header-' . uniqid();

// Logo配置
$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoImage = $getConfig('logo.image', '');
$logoText = $getConfig('logo.text', 'Brand Name');
$logoWidth = (int)$getConfig('logo.width', 40);

// 导航配置（必须使用真实子页面）
$showNav = $getConfig('navigation.display', 'yes') !== 'no';
$navItems = [];

if ($page) {
    $navigationPages = $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $navItems[] = [
            'text' => $navPage['title'] ?? '',
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

// 如果没有真实子页面，则不显示导航
if (empty($navItems)) {
    $showNav = false;
}

// CTA配置
$showCta = $getConfig('cta.show', 'yes') !== 'no';
$ctaText = $getConfig('cta.text', 'Get Started');
$ctaUrl = $getConfig('cta.url', '#contact');

// 样式配置
$bgColor = $getConfig('style.bg_color', '#0a0a0f');
$textColor = $getConfig('style.text_color', '#ffffff');
$linkColor = $getConfig('style.link_color', '#b8b8d0');
$linkHoverColor = $getConfig('style.link_hover_color', '#7c3aed');
$accentColor = $getConfig('style.accent_color', '#7c3aed');

// ===== AI生成的额外PHP变量 =====
// 使用try-catch包装AI生成的代码，防止错误中断渲染
try {
    {{PHP_VARIABLES}}
} catch (\Throwable $e) {
    // 静默处理AI生成代码的错误，记录日志
    error_log('[AI Component Error] ' . $componentId . ': ' . $e->getMessage());
}
?>

<!-- AI生成的CSS样式 -->
<style>
/* 基础样式 */
