}

#<?= $componentId ?> .<?= $cls ?>-nav-link:hover,
#<?= $componentId ?> .<?= $cls ?>-nav-link.active {
    color: var(--header-link-hover);
}

#<?= $componentId ?> .<?= $cls ?>-nav-link:hover::after,
#<?= $componentId ?> .<?= $cls ?>-nav-link.active::after {
    width: 100%;
}

#<?= $componentId ?> .<?= $cls ?>-cta {
    padding: 10px 22px;
    background: var(--header-primary);
    color: <?= htmlspecialchars($ctaTextColor) ?>;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--header-primary) 30%, transparent);
    transition: all 0.25s ease;
}

#<?= $componentId ?> .<?= $cls ?>-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px color-mix(in srgb, var(--header-primary) 50%, transparent);
}

#<?= $componentId ?> .<?= $cls ?>-toggle {
    display: none;
    flex-direction: column;
