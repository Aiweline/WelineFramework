<?php
/**
 * AI Component Framework - Header
 * 
 * 头部组件框架模板，包含固定的导航结构
 * AI只需填充特定区域的代码
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $component_config 组件配置
 * 
 * @component_start
 * name => {{COMPONENT_NAME}}
 * name_en => {{COMPONENT_NAME_EN}}
 * description => {{COMPONENT_DESC}}
 * category => header
 * type => section
 * sort_order => 10
 * compatible_styles => *
 * ai_generated => true
 * @component_end
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.image => Logo图片URL:textarea:|留空使用默认文字Logo
 * logo.text => Logo文字:text:Brand Name
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * 
 * group:cta => CTA按钮
 * cta.show => 显示CTA按钮:select:yes|yes,no
 * cta.text => 按钮文字:text:Get Started
 * cta.url => 按钮链接:text:#contact
 * 
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#0f0f1a
 * style.text_color => 文字颜色:color:#ffffff
 * style.link_color => 链接颜色:color:#a0a0b8
 * style.link_hover_color => 链接悬停颜色:color:#6366f1
 * style.accent_color => 强调色:color:#6366f1
 * 
 * {{EXTRA_FIELDS}}
 * 
 * @fields_end
 */

// ===== 固定的PHP数据获取部分 =====
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$parseNavItems = function($raw) {
    $items = [];
    $lines = preg_split('/\r?\n/', (string)($raw ?? ''));
    foreach ($lines as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        if (strpos($line, '=>') !== false) {
            [$text, $href] = array_pad(explode('=>', $line, 2), 2, '#');
        } else {
            $text = $line;
            $href = '#';
        }
        $text = trim((string)$text);
        $href = trim((string)$href);
        if ($text !== '') {
            $items[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
    return $items;
};

$componentId = 'header-' . substr(uniqid(), -8);
$cls = $componentId;

$normalizeNavPath = function($value) {
    $path = parse_url((string)$value, PHP_URL_PATH);
    $path = is_string($path) ? $path : (string)$value;
    $path = trim($path);
    if ($path === '' || $path === '#') {
        return '';
    }
    return trim($path, '/');
};

// Logo配置
$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoImage = $getConfig('logo.image', '');
$logoText = $getConfig('logo.text', 'Brand Name');
$logoWidth = (int)$getConfig('logo.width', 40);

// 导航配置（必须使用真实子页面）
$showNav = $getConfig('navigation.display', 'yes') !== 'no';
$navItems = [];

$configuredNav = $parseNavItems($getConfig('navigation.items', ''));
if ($configuredNav === [] && isset($config['nav_items']) && is_array($config['nav_items'])) {
    foreach ($config['nav_items'] as $item) {
        if (!is_array($item)) {
            continue;
        }
        $text = trim((string)($item['text'] ?? $item['title'] ?? $item['label'] ?? ''));
        $href = trim((string)($item['href'] ?? $item['url'] ?? '#'));
        if ($text !== '') {
            $configuredNav[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if ($configuredNav !== []) {
    $navItems = $configuredNav;
} elseif ($page) {
    $navigationPages = $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $navItems[] = [
            'text' => $navPage['title'] ?? '',
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    $showNav = false;
}

$currentPageType = '';
if ($page) {
    foreach (['type', 'page_type', 'page_key'] as $field) {
        $candidate = trim((string)$page->getData($field));
        if ($candidate !== '') {
            $currentPageType = $candidate;
            break;
        }
    }
}
if ($currentPageType === '' && isset($_GET['page_type'])) {
    $currentPageType = trim((string)$_GET['page_type']);
}
$currentPath = isset($_SERVER['REQUEST_URI']) ? $normalizeNavPath((string)$_SERVER['REQUEST_URI']) : '';
$currentPagePath = match ($currentPageType) {
    'home_page', 'home', 'index' => '',
    'about_page', 'about' => 'about',
    'contact_page', 'contact' => 'contact',
    'blog_list', 'blog_category', 'blog' => 'blog',
    'privacy_policy', 'privacy' => 'privacy',
    'terms_of_service', 'terms' => 'terms',
    'refund_policy', 'refund' => 'refund',
    'shipping_policy', 'shipping' => 'shipping',
    'cookie_policy', 'cookies' => 'cookies',
    'custom_page', 'page' => 'page',
    default => $currentPath,
};
$isNavItemActive = function($href, $index) use ($normalizeNavPath, $currentPagePath, $currentPath) {
    $navPath = $normalizeNavPath($href);
    if ($currentPagePath !== '' || $currentPath !== '') {
        if ($currentPagePath === '' && $navPath === '') {
            return true;
        }
        return $navPath !== '' && $navPath === $currentPagePath;
    }

    return $index === 0;
};

// CTA配置
$showCta = $getConfig('cta.show', 'yes') !== 'no';
$ctaText = $getConfig('cta.text', 'Get Started');
$ctaUrl = $getConfig('cta.url', '#contact');

// 样式配置
$bgColor = $getConfig('style.bg_color', '#0f0f1a');
$textColor = $getConfig('style.text_color', '#ffffff');
$linkColor = $getConfig('style.link_color', '#a0a0b8');
$linkHoverColor = $getConfig('style.link_hover_color', '#6366f1');
$accentColor = $getConfig('style.accent_color', '#6366f1');
$normalizeHexColor = function($value) {
    $value = trim((string)$value);
    if (preg_match('/^#?([0-9a-f]{3}|[0-9a-f]{6})$/i', $value, $matches) !== 1) {
        return '';
    }
    $hex = strtolower($matches[1]);
    if (strlen($hex) === 3) {
        $hex = $hex[0] . $hex[0] . $hex[1] . $hex[1] . $hex[2] . $hex[2];
    }
    return '#' . $hex;
};
$relativeLuminance = function($hex) {
    $hex = ltrim((string)$hex, '#');
    if (strlen($hex) !== 6) {
        return 0.0;
    }
    $channels = [
        hexdec(substr($hex, 0, 2)) / 255,
        hexdec(substr($hex, 2, 2)) / 255,
        hexdec(substr($hex, 4, 2)) / 255,
    ];
    foreach ($channels as $index => $channel) {
        $channels[$index] = $channel <= 0.03928
            ? $channel / 12.92
            : pow(($channel + 0.055) / 1.055, 2.4);
    }
    return 0.2126 * $channels[0] + 0.7152 * $channels[1] + 0.0722 * $channels[2];
};
$contrastRatio = function($first, $second) use ($relativeLuminance) {
    $a = $relativeLuminance($first);
    $b = $relativeLuminance($second);
    return (max($a, $b) + 0.05) / (min($a, $b) + 0.05);
};
$pickReadableTextColor = function($background) use ($normalizeHexColor, $contrastRatio) {
    $background = $normalizeHexColor($background);
    if ($background === '') {
        return '#ffffff';
    }
    $dark = '#1a2c38';
    $light = '#ffffff';
    return $contrastRatio($background, $dark) >= $contrastRatio($background, $light) ? $dark : $light;
};
$ensureReadableColor = function($candidate, $background) use ($normalizeHexColor, $contrastRatio, $pickReadableTextColor) {
    $candidate = $normalizeHexColor($candidate);
    $background = $normalizeHexColor($background);
    if ($candidate !== '' && $background !== '' && $contrastRatio($background, $candidate) >= 4.5) {
        return $candidate;
    }
    return $pickReadableTextColor($background);
};
$linkHoverColor = $ensureReadableColor($linkHoverColor, $bgColor);
$configuredCtaTextColor = $normalizeHexColor($getConfig('style.cta_text_color', ''));
$ctaTextColor = $ensureReadableColor($configuredCtaTextColor, $accentColor);

// ===== AI生成的额外PHP变量 =====
try {
    /* {{PHP_VARIABLES}} */
} catch (\Throwable $e) {
    w_log_error('[AI Component Error] ' . $componentId . ': ' . $e->getMessage());
}
?>

<style>
#<?= $componentId ?> {
    --header-primary: <?= htmlspecialchars($accentColor) ?>;
    --header-bg: <?= htmlspecialchars($bgColor) ?>;
    --header-text: <?= htmlspecialchars($textColor) ?>;
    --header-link: <?= htmlspecialchars($linkColor) ?>;
    --header-link-hover: <?= htmlspecialchars($linkHoverColor) ?>;
    --header-border: rgba(255, 255, 255, 0.1);

    background: var(--header-bg);
    color: var(--header-text);
    position: relative;
    z-index: 1000;
    box-shadow: 0 1px 0 var(--header-border), 0 4px 20px rgba(0,0,0,0.04);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

#<?= $componentId ?> .<?= $cls ?>-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
