<?php
/**
 * AI Component Framework - Header
 * 
 * 头部组件框架模板，包含固定的导航结构
 * AI只需填充特定区域的代码
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $component_config 组件配置
 * 
 * @component_start
 * name => {{COMPONENT_NAME}}
 * name_en => {{COMPONENT_NAME_EN}}
 * description => {{COMPONENT_DESC}}
 * category => header
 * type => section
 * sort_order => 10
 * compatible_styles => *
 * ai_generated => true
 * @component_end
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.image => Logo图片URL:textarea:|留空使用默认文字Logo
 * logo.text => Logo文字:text:Brand Name
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * 
 * group:cta => CTA按钮
 * cta.show => 显示CTA按钮:select:yes|yes,no
 * cta.text => 按钮文字:text:Get Started
 * cta.url => 按钮链接:text:#contact
 * 
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#0f0f1a
 * style.text_color => 文字颜色:color:#ffffff
 * style.link_color => 链接颜色:color:#a0a0b8
 * style.link_hover_color => 链接悬停颜色:color:#6366f1
 * style.accent_color => 强调色:color:#6366f1
 * 
 * {{EXTRA_FIELDS}}
 * 
 * @fields_end
 */

// ===== 固定的PHP数据获取部分 =====
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$componentId = 'header-' . substr(uniqid(), -8);
$cls = $componentId;

// Logo配置
$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoImage = $getConfig('logo.image', '');
$logoText = $getConfig('logo.text', 'Brand Name');
$logoWidth = (int)$getConfig('logo.width', 40);

// 导航配置（必须使用真实子页面）
$showNav = $getConfig('navigation.display', 'yes') !== 'no';
$navItems = [];

if ($page) {
    $navigationPages = $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $navItems[] = [
            'text' => $navPage['title'] ?? '',
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    $showNav = false;
}

// CTA配置
$showCta = $getConfig('cta.show', 'yes') !== 'no';
$ctaText = $getConfig('cta.text', 'Get Started');
$ctaUrl = $getConfig('cta.url', '#contact');

// 样式配置
$bgColor = $getConfig('style.bg_color', '#0f0f1a');
$textColor = $getConfig('style.text_color', '#ffffff');
$linkColor = $getConfig('style.link_color', '#a0a0b8');
$linkHoverColor = $getConfig('style.link_hover_color', '#6366f1');
$accentColor = $getConfig('style.accent_color', '#6366f1');

// ===== AI生成的额外PHP变量 =====
try {
    {{PHP_VARIABLES}}
} catch (\Throwable $e) {
    w_log_error('[AI Component Error] ' . $componentId . ': ' . $e->getMessage());
}
?>

<style>
#<?= $componentId ?> {
    --header-primary: <?= htmlspecialchars($accentColor) ?>;
    --header-bg: <?= htmlspecialchars($bgColor) ?>;
    --header-text: <?= htmlspecialchars($textColor) ?>;
    --header-link: <?= htmlspecialchars($linkColor) ?>;
    --header-link-hover: <?= htmlspecialchars($linkHoverColor) ?>;
    --header-border: rgba(255, 255, 255, 0.1);

    background: var(--header-bg);
    color: var(--header-text);
    position: relative;
    z-index: 1000;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

#<?= $componentId ?> .<?= $cls ?>-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

#<?= $componentId ?> .<?= $cls ?>-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--header-text);
    text-decoration: none;
    transition: opacity 0.2s ease;
}

#<?= $componentId ?> .<?= $cls ?>-logo:hover {
    opacity: 0.85;
}

#<?= $componentId ?> .<?= $cls ?>-logo img {
    height: <?= $logoWidth ?>px;
    width: auto;
    object-fit: contain;
}

#<?= $componentId ?> .<?= $cls ?>-nav {
    display: flex;
    align-items: center;
    gap: 40px;
}

#<?= $componentId ?> .<?= $cls ?>-nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 32px;
}

#<?= $componentId ?> .<?= $cls ?>-nav-link {
    color: var(--header-link);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
}

#<?= $componentId ?> .<?= $cls ?>-nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--header-primary);
    transition: width 0.25s ease;
}

#<?= $componentId ?> .<?= $cls ?>-nav-link:hover,
#<?= $componentId ?> .<?= $cls ?>-nav-link.active {
    color: var(--header-link-hover);
}

#<?= $componentId ?> .<?= $cls ?>-nav-link:hover::after,
#<?= $componentId ?> .<?= $cls ?>-nav-link.active::after {
    width: 100%;
}

#<?= $componentId ?> .<?= $cls ?>-cta {
    padding: 10px 22px;
    background: var(--header-primary);
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s ease;
}

#<?= $componentId ?> .<?= $cls ?>-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
}

#<?= $componentId ?> .<?= $cls ?>-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    cursor: pointer;
    background: transparent;
    border: none;
}

#<?= $componentId ?> .<?= $cls ?>-toggle span {
    width: 22px;
    height: 2px;
    background: var(--header-text);
    border-radius: 1px;
    transition: all 0.3s ease;
}

{{CSS_EXTRA}}

@media (max-width: 992px) {
    #<?= $componentId ?> .<?= $cls ?>-nav {
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--header-bg);
        flex-direction: column;
        justify-content: flex-start;
        padding: 32px 24px;
        transform: translateX(100%);
        transition: transform 0.3s ease;
        gap: 24px;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-nav.active {
        transform: translateX(0);
    }
    
    #<?= $componentId ?> .<?= $cls ?>-nav-links {
        flex-direction: column;
        width: 100%;
        gap: 0;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-nav-link {
        display: block;
        padding: 14px 0;
        font-size: 1rem;
        border-bottom: 1px solid var(--header-border);
    }
    
    #<?= $componentId ?> .<?= $cls ?>-nav-link::after {
        display: none;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-cta {
        width: 100%;
        text-align: center;
        padding: 14px;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-toggle {
        display: flex;
    }
}
</style>

<header id="<?= $componentId ?>">
    <div class="<?= $cls ?>-container">
        <?php if ($showLogo): ?>
        <a href="/" class="<?= $cls ?>-logo">
            <?php if ($logoImage): ?>
                <img src="<?= htmlspecialchars($logoImage) ?>" alt="<?= htmlspecialchars($logoText) ?>" loading="lazy">
            <?php endif; ?>
            <span><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        
        <button class="<?= $cls ?>-toggle" onclick="this.classList.toggle('active'); document.querySelector('#<?= $componentId ?> .<?= $cls ?>-nav').classList.toggle('active');" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>
        
        <?php if ($showNav): ?>
        <nav class="<?= $cls ?>-nav">
            <ul class="<?= $cls ?>-nav-links">
                <?php foreach ($navItems as $index => $navItem): ?>
                    <?php 
                    $navHref = $navItem['href'] ?? '#';
                    $navText = $navItem['text'] ?? '';
                    $isActive = $index === 0;
                    ?>
                    <li><a href="<?= htmlspecialchars($navHref) ?>" class="<?= $cls ?>-nav-link <?= $isActive ? 'active' : '' ?>"><?= htmlspecialchars($navText) ?></a></li>
                <?php endforeach; ?>
            </ul>
            
            <?php if ($showCta): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="<?= $cls ?>-cta"><?= htmlspecialchars($ctaText) ?></a>
            <?php endif; ?>
        </nav>
        <?php endif; ?>
        
        {{HTML_EXTRA}}
    </div>
</header>

<?php 
$_jsPlaceholder = <<<'JSEOF'
{{JS_CONTENT}}
JSEOF;
$jsContent = trim($_jsPlaceholder);
$_hasValidJs = !empty($jsContent) && strpos($jsContent, '{{') !== 0 && strlen($jsContent) > 5;
if ($_hasValidJs): 
?>
<script>
(function() {
    const component = document.getElementById('<?= $componentId ?>');
    <?= $jsContent ?>
})();
</script>
<?php endif; ?>
