<?php
/**
 * AI Component Framework - Content
 * 
 * 内容组件框架模板，通用的内容区块结构
 * AI只需填充特定区域的代码
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $component_config 组件配置
 * 
 * @component_start
 * name => {{COMPONENT_NAME}}
 * name_en => {{COMPONENT_NAME_EN}}
 * description => {{COMPONENT_DESC}}
 * category => content
 * type => section
 * sort_order => 50
 * compatible_styles => *
 * ai_generated => true
 * @component_end
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.title => 标题:text:Section Title
 * content.subtitle => 副标题:text:
 * content.description => 描述:textarea:
 * 
 * group:layout => 布局设置
 * layout.container_width => 容器宽度:select:1200|960,1200,1400,full
 * layout.padding_top => 顶部间距:number:80|px
 * layout.padding_bottom => 底部间距:number:80|px
 * layout.text_align => 文字对齐:select:center|left,center,right
 * 
 * group:style => 样式设置
 * style.bg_type => 背景类型:select:color|color,gradient,image
 * style.bg_color => 背景颜色:color:#ffffff
 * style.bg_gradient => 渐变背景:text:linear-gradient(135deg, #111827 0%, #f59e0b 100%)
 * style.bg_image => 背景图片:textarea:
 * style.text_color => 文字颜色:color:#374151
 * style.title_color => 标题颜色:color:#111827
 * style.accent_color => 强调色:color:#f59e0b
 * 
 * {{EXTRA_FIELDS}}
 * 
 * @fields_end
 */

// ===== 固定的PHP数据获取部分 =====
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};
$sanitizeVisibleText = static function (string $text, string $fallback = ''): string {
    $text = trim(preg_replace('/\s+/u', ' ', $text) ?? $text);
    if ($text === '') {
        return $fallback;
    }
    if (preg_match('/\b(?:AI_GENERATED_[A-Z0-9_]+|task_key|section_code|block_key|page_type|home_page|about_page|shared:[a-z0-9:_-]+|page:[a-z0-9:_-]+)\b/iu', $text)) {
        return $fallback;
    }

    return $text;
};

$componentId = 'content-' . substr(uniqid(), -8);
$cls = $componentId;

// 内容配置
$title = $sanitizeVisibleText((string)$getConfig('content.title', 'Section Title'), 'Section Title');
$subtitle = $sanitizeVisibleText((string)$getConfig('content.subtitle', ''), '');
$description = $sanitizeVisibleText((string)$getConfig('content.description', ''), '');

// 布局配置
$containerWidth = $getConfig('layout.container_width', '1200');
$paddingTop = (int)$getConfig('layout.padding_top', 80);
$paddingBottom = (int)$getConfig('layout.padding_bottom', 80);
$textAlign = $getConfig('layout.text_align', 'center');

// 样式配置
$bgType = $getConfig('style.bg_type', 'color');
$bgColor = $getConfig('style.bg_color', '#ffffff');
$bgGradient = $getConfig('style.bg_gradient', 'linear-gradient(135deg, #111827 0%, #f59e0b 100%)');
$bgImage = $getConfig('style.bg_image', '');
$textColor = $getConfig('style.text_color', '#374151');
$titleColor = $getConfig('style.title_color', '#111827');
$accentColor = $getConfig('style.accent_color', '#f59e0b');

// 计算背景样式
$bgStyle = match($bgType) {
    'gradient' => $bgGradient,
    'image' => $bgImage ? "url('" . htmlspecialchars($bgImage) . "') center/cover no-repeat" : $bgColor,
    default => $bgColor,
};

// 容器宽度
$maxWidth = $containerWidth === 'full' ? '100%' : $containerWidth . 'px';

// ===== AI生成的额外PHP变量 =====
try {
    {{PHP_VARIABLES}}
} catch (\Throwable $e) {
    w_log_error('[AI Component Error] ' . $componentId . ': ' . $e->getMessage());
}
?>

<style>
#<?= $componentId ?> {
    --section-primary: <?= htmlspecialchars($accentColor) ?>;
    --section-bg: <?= htmlspecialchars($bgColor) ?>;
    --section-text: <?= htmlspecialchars($textColor) ?>;
    --section-heading: <?= htmlspecialchars($titleColor) ?>;
    --section-muted: color-mix(in srgb, <?= htmlspecialchars($textColor) ?> 70%, transparent);
    --section-border: color-mix(in srgb, <?= htmlspecialchars($textColor) ?> 12%, transparent);

    background: <?= $bgStyle ?>;
    color: var(--section-text);
    padding: <?= $paddingTop ?>px 24px <?= $paddingBottom ?>px;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

#<?= $componentId ?> .<?= $cls ?>-container {
    max-width: <?= $maxWidth ?>;
    margin: 0 auto;
    text-align: <?= htmlspecialchars($textAlign) ?>;
}

#<?= $componentId ?> .<?= $cls ?>-header {
    margin-bottom: 48px;
}

#<?= $componentId ?> .<?= $cls ?>-subtitle {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--section-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
}

#<?= $componentId ?> .<?= $cls ?>-title {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--section-heading);
    margin: 0 0 16px 0;
    line-height: 1.2;
    letter-spacing: -0.025em;
}

#<?= $componentId ?> .<?= $cls ?>-description {
    font-size: 1.125rem;
    line-height: 1.75;
    max-width: 680px;
    margin: 0 auto;
    color: var(--section-muted);
}

#<?= $componentId ?> .<?= $cls ?>-body {
    /* AI 内容区域 */
}

{{CSS_EXTRA}}

@media (max-width: 768px) {
    #<?= $componentId ?> {
        padding: <?= max(48, (int)($paddingTop * 0.6)) ?>px 20px <?= max(48, (int)($paddingBottom * 0.6)) ?>px;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-header {
        margin-bottom: 36px;
    }
    
    #<?= $componentId ?> .<?= $cls ?>-description {
        font-size: 1rem;
    }
    
    {{CSS_RESPONSIVE}}
}
</style>

<section id="<?= $componentId ?>">
    <div class="<?= $cls ?>-container">
        <?php if ($title || $subtitle || $description): ?>
        <div class="<?= $cls ?>-header">
            <?php if ($subtitle): ?>
            <div class="<?= $cls ?>-subtitle"><?= htmlspecialchars($subtitle) ?></div>
            <?php endif; ?>
            
            <?php if ($title): ?>
            <h2 class="<?= $cls ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            
            <?php if ($description): ?>
            <p class="<?= $cls ?>-description"><?= nl2br(htmlspecialchars($description)) ?></p>
            <?php endif; ?>
        </div>
        <?php endif; ?>
        
        <div class="<?= $cls ?>-body">
            {{HTML_CONTENT}}
        </div>
    </div>
</section>

<?php 
$_jsPlaceholder = <<<'JSEOF'
{{JS_CONTENT}}
JSEOF;
$jsContent = trim($_jsPlaceholder);
$_hasValidJs = !empty($jsContent) && strpos($jsContent, '{{') !== 0 && strlen($jsContent) > 5;
if ($_hasValidJs): 
?>
<script>
(function() {
    const component = document.getElementById('<?= $componentId ?>');
    <?= $jsContent ?>
})();
</script>
<?php endif; ?>
