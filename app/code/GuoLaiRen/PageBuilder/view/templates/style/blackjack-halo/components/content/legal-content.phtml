<?php
/**
 * Blackjack Halo - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: 法律文档内容展示组件，支持目录与更新时间
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:wide|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:72|px
 * layout.content_padding => 内容内边距:number:32|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.updated_label => 更新时间前缀:text:Last Updated
 * header.updated_short_label => 更新时间短标签:text:Updated
 * header.bg_color => 背景色:color:#f7f5ed
 * header.bg_gradient_end => 渐变结束色:color:#eef4e8
 * header.title_color => 标题颜色:color:#1f312d
 * header.text_color => 文字颜色:color:#667c72
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Policy Map
 * toc.section_count_label => 章节统计标签:text:Sections
 * toc.overview_label => 无目录统计标签:text:Overview
 * toc.first_stop_label => 首段标签:text:First Stop
 * toc.first_section_fallback => 首段回退标题:text:Policy Overview
 * toc.items => 章节配置:textarea:
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.95)
 * toc.border_color => 目录边框色:color:rgba(32,53,45,0.08)
 *
 * group:content => 内容设置
 * content.body => 引言内容:textarea:
 * content.empty_text => 空内容提示:text:Content will be displayed here.
 * content.bg_color => 内容区背景色:color:rgba(255,255,255,0.95)
 * content.text_color => 内容文字颜色:color:#5e7269
 * content.heading_color => 标题颜色:color:#1f312d
 * content.link_color => 链接颜色:color:#a17928
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$page = $this->getData('page');
$componentId = 'bkh-legal-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string)$getConfig('layout.content_width', 'wide');
$headerPadding = max(40, (int)$getConfig('layout.header_padding', 72));
$contentPadding = max(24, (int)$getConfig('layout.content_padding', 32));

$pageType = $page ? (string)($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string)($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string)($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';

$headerTitle = trim((string)$getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}
$updatedLabelPrefix = trim((string)$getConfig('header.updated_label', 'Last Updated'));
$updatedShortLabel = trim((string)$getConfig('header.updated_short_label', 'Updated'));

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$headerIcon = trim((string)$getConfig('header.icon', $typeIcons[$pageType] ?? '📄'));
$tocTitle = trim((string)$getConfig('toc.title', 'Policy Map'));
$sectionCountLabel = trim((string)$getConfig('toc.section_count_label', 'Sections'));
$overviewLabel = trim((string)$getConfig('toc.overview_label', 'Overview'));
$firstStopLabel = trim((string)$getConfig('toc.first_stop_label', 'First Stop'));
$firstSectionFallback = trim((string)$getConfig('toc.first_section_fallback', 'Policy Overview'));
$tocItemsConfig = trim((string)$getConfig('toc.items', ''));

$heroBg = (string)$getConfig('header.bg_color', '#f7f5ed');
$heroBgEnd = (string)$getConfig('header.bg_gradient_end', '#eef4e8');
$heroTitleColor = (string)$getConfig('header.title_color', '#1f312d');
$heroTextColor = (string)$getConfig('header.text_color', '#667c72');
$tocBg = (string)$getConfig('toc.bg_color', 'rgba(255,255,255,0.95)');
$tocBorder = (string)$getConfig('toc.border_color', 'rgba(32,53,45,0.08)');
$contentBg = (string)$getConfig('content.bg_color', 'rgba(255,255,255,0.95)');
$contentText = (string)$getConfig('content.text_color', '#5e7269');
$contentHeading = (string)$getConfig('content.heading_color', '#1f312d');
$contentLink = (string)$getConfig('content.link_color', '#a17928');
$introContent = trim((string)$getConfig('content.body', ''));
$contentEmptyText = trim((string)$getConfig('content.empty_text', 'Content will be displayed here.'));

$maxWidth = match ($contentWidth) {
    'narrow' => '900px',
    'medium' => '1080px',
    default => '1220px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int)$matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}
$pageContent = trim((string)$pageContent);
if ($pageContent === '' && $tocItemsConfig !== '') {
    $rebuiltSections = [];
    foreach (preg_split('/[\r\n]+/', $tocItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        $heading = trim((string)($parts[0] ?? ''));
        $body = trim((string)($parts[1] ?? ''));
        if ($heading === '') {
            continue;
        }
        $slug = strtolower((string)preg_replace('/[^a-z0-9]+/i', '-', $heading));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (count($tocItems) + 1);
        $tocItems[] = [
            'id' => $id,
            'text' => $heading,
            'level' => 2,
        ];
        $rebuiltSections[] = '<h2 id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . htmlspecialchars($heading) . '</h2>';
        if ($body !== '') {
            $rebuiltSections[] = '<p>' . nl2br(htmlspecialchars($body)) . '</p>';
        }
    }
    $pageContent = implode('', $rebuiltSections);
}

$hasToc = $showToc && !empty($tocItems);
$sectionCount = count($tocItems);
$firstSection = $tocItems[0]['text'] ?? $firstSectionFallback;
$formattedUpdated = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('F j, Y', $timestamp);
    }
}
?>

<section
    id="<?= $componentId ?>"
    class="bkh-legal"
    style="--bkh-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --bkh-legal-header-padding: <?= (int)$headerPadding ?>px; --bkh-legal-content-padding: <?= (int)$contentPadding ?>px; --bkh-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="legal-shell">
        <header class="policy-head">
            <div class="policy-copy">
                <?php if ($showIcon && $headerIcon !== ''): ?>
                    <span class="policy-kicker"><?= htmlspecialchars($headerIcon) ?></span>
                <?php endif; ?>
                <h1><?= htmlspecialchars($headerTitle) ?></h1>
                <?php if ($formattedUpdated !== ''): ?>
                    <p class="policy-summary"><?= htmlspecialchars($updatedLabelPrefix) ?>: <?= htmlspecialchars($formattedUpdated) ?></p>
                <?php endif; ?>
            </div>

            <aside class="policy-compass">
                <span class="compass-label"><?= htmlspecialchars($tocTitle) ?></span>
                <div class="compass-stat">
                    <strong><?= htmlspecialchars(str_pad((string)max($sectionCount, 1), 2, '0', STR_PAD_LEFT)) ?></strong>
                    <span><?= htmlspecialchars($hasToc ? $sectionCountLabel : $overviewLabel) ?></span>
                </div>
                <div class="compass-copy">
                    <p><strong><?= htmlspecialchars($firstStopLabel) ?>:</strong> <?= htmlspecialchars((string)$firstSection) ?></p>
                    <?php if ($formattedUpdated !== ''): ?>
                        <p><strong><?= htmlspecialchars($updatedShortLabel) ?>:</strong> <?= htmlspecialchars($formattedUpdated) ?></p>
                    <?php endif; ?>
                </div>
            </aside>
        </header>

        <?php if ($hasToc): ?>
            <nav class="policy-map" aria-label="Table of contents">
                <?php foreach ($tocItems as $index => $item): ?>
                    <a href="#<?= htmlspecialchars($item['id']) ?>" class="map-stop level-<?= (int)$item['level'] ?>">
                        <span class="stop-index"><?= htmlspecialchars(str_pad((string)($index + 1), 2, '0', STR_PAD_LEFT)) ?></span>
                        <span class="stop-text"><?= htmlspecialchars($item['text']) ?></span>
                    </a>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>

        <section class="policy-stage">
            <article class="policy-article<?= !$hasToc ? ' no-toc' : '' ?>">
                <?php if ($formattedUpdated !== ''): ?>
                    <div class="article-head">
                        <time datetime="<?= htmlspecialchars(date('c', strtotime($lastUpdated))) ?>"><?= htmlspecialchars($formattedUpdated) ?></time>
                    </div>
                <?php endif; ?>

                <div class="legal-content">
                    <?php if ($introContent !== ''): ?>
                        <div class="legal-intro">
                            <p><?= nl2br(htmlspecialchars($introContent)) ?></p>
                        </div>
                    <?php endif; ?>
                    <?php if ($pageContent !== ''): ?>
                        <?= $pageContent ?>
                    <?php else: ?>
                        <p><?= htmlspecialchars($contentEmptyText) ?></p>
                    <?php endif; ?>
                </div>
            </article>
        </section>
    </div>
</section>

