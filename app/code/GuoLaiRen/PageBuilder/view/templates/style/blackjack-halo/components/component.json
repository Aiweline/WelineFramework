{
    "$schema": "2.1.0",
    "template": "blackjack-halo",
    "name": "Blackjack Halo",
    "description": "Responsive light blackjack landing theme with distinct module structures, flexible tpmst-compatible data fallbacks, and animated Halo visuals.",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航与品牌入口",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主内容区域，可按顺序放置多个模块",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "advantages", "games-showcase", "testimonials", "faq"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含链接、社交与版权信息",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "Halo 导航",
            "name_en": "Halo Navigation",
            "description": "浅色悬浮导航，支持移动端折叠菜单与底部流光轨迹",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation"],
            "file": "header/nav.phtml"
        },
        "hero-slider": {
            "name": "Hero 首屏",
            "name_en": "Hero Section",
            "description": "Halo 环形舞台首屏，兼容 tpmst banner 和 download 按钮配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["hero"],
            "file": "content/hero-slider.phtml"
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages",
            "description": "扇面卡片布局，展示 Blackjack Halo 的核心亮点",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["section"],
            "file": "content/advantages.phtml"
        },
        "games-showcase": {
            "name": "牌桌展示",
            "name_en": "Games Showcase",
            "description": "等宽牌桌陈列布局，兼容 tpmst 游戏图片和文本配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["section", "games"],
            "file": "content/games.phtml"
        },
        "slider": {
            "name": "轮播横幅",
            "name_en": "Slider",
            "description": "兼容原有 Banner/Slider 数据配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 35,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["slider"],
            "file": "content/slider.phtml"
        },
        "banner": {
            "name": "静态横幅",
            "name_en": "Banner",
            "description": "兼容原有 Banner 图片与下载按钮配置",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 36,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner"],
            "file": "content/banner.phtml"
        },
        "testimonials": {
            "name": "玩家评价",
            "name_en": "Testimonials",
            "description": "轻量 Quote Reel 布局，保留评分、头像和默认回退逻辑",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": [],
            "file": "content/testimonials.phtml"
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ",
            "description": "Blackjack Slip 风格 FAQ，问题紧凑排列并在卡片内部展开答案",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": [],
            "file": "content/faq.phtml"
        },
        "about-content": {
            "name": "关于页内容",
            "name_en": "About Content",
            "description": "品牌介绍页内容组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 60,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/about-content.phtml"
        },
        "contact-content": {
            "name": "联系页内容",
            "name_en": "Contact Content",
            "description": "联系页和支持入口组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 61,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/contact-content.phtml"
        },
        "legal-content": {
            "name": "法律页内容",
            "name_en": "Legal Content",
            "description": "政策与条款页面组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 62,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/legal-content.phtml"
        },
        "blog-list": {
            "name": "博客列表",
            "name_en": "Blog List",
            "description": "博客列表页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 63,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-list.phtml"
        },
        "blog-category": {
            "name": "博客分类",
            "name_en": "Blog Category",
            "description": "博客分类列表页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 64,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-category.phtml"
        },
        "blog-detail": {
            "name": "博客详情",
            "name_en": "Blog Detail",
            "description": "博客详情页组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 65,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-detail.phtml"
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer Links",
            "description": "Halo Rail 装饰页脚，支持品牌信息、导航和社交按钮",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "config_groups": ["footer"],
            "file": "footer/links.phtml"
        }
    }
}
