 * style.title_font_size => 标题字体大小(PC端):number:36|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.88)
 * style.card_border_radius => 卡片圆角:number:24|px
 * style.card_border_left_color => 卡片左边框色:color:#d3a03a
 * style.card_border_left_width => 卡片左边框宽度:number:4|px
 * style.card_padding => 卡片内边距:number:22|px
 * style.name_color => 姓名颜色:color:#20352d
 * style.name_font_size => 姓名字号:number:16|px
 * style.rating_color => 评分颜色:color:#d3a03a
 * style.content_color => 评价内容颜色:color:#61756d
 * style.content_font_size => 评价内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:58|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:72|px
 * style.section_padding_mobile => 区域内边距(移动端):number:46|px
 * style.card_gap => 卡片间距:number:18|px
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:
 * avatars.avatar_2 => 评价2头像:textarea:
 * avatars.avatar_3 => 评价3头像:textarea:
 *
 * group:texts => 评价内容
 * texts.title => 区域标题:text:What Blackjack Players Notice First
 * texts.kicker => 区域提示:text:Player reel
 * texts.avg_label => 平均评分标签:text:Average Rating
 * texts.notes_label => 评价数量标签:text:Player Notes
 * texts.testimonial_1_name => 评价1姓名:text:Arjun Mehta (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_1_content => 评价1内容:textarea:The table cards are cleaner than most casino landers. I can tell where to go without the page feeling flat.
 * texts.testimonial_2_name => 评价2姓名:text:Kavya Nair (Bengaluru)
 * texts.testimonial_2_rating => 评价2评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_2_content => 评价2内容:textarea:Mobile spacing is excellent. The page still feels premium, but it is much easier to read between rounds.
 * texts.testimonial_3_name => 评价3姓名:text:Rahul Sethi (Delhi)
 * texts.testimonial_3_rating => 评价3评分:text:⭐⭐⭐⭐☆
 * texts.testimonial_3_content => 评价3内容:textarea:Blackjack-first details come through quickly. The room choices feel distinct instead of being clones with new colors.
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'bkh-testimonials-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#eef4ed'));
$titleColor = $getConfig('style.title_color', '#1e5b46');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.88)');
$cardBorderRadius = $getConfig('style.card_border_radius', '24');
$cardBorderLeftColor = $getConfig('style.card_border_left_color', '#d3a03a');
$cardBorderLeftWidth = $getConfig('style.card_border_left_width', '4');
$cardPadding = $getConfig('style.card_padding', '22');
$nameColor = $getConfig('style.name_color', '#20352d');
$nameFontSize = $getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', '#d3a03a');
$contentColor = $getConfig('style.content_color', '#61756d');
$contentFontSize = $getConfig('style.content_font_size', '14');
$avatarSize = $getConfig('style.avatar_size', '58');
$avatarBorderRadius = $getConfig('style.avatar_border_radius', '50');
$sectionPadding = $getConfig('style.section_padding', '72');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '46');
$cardGap = $getConfig('style.card_gap', '18');

$title = $getConfig('texts.title', $getConfig('testimonials.title', 'What Blackjack Players Notice First'));
$kicker = trim((string)$getConfig('texts.kicker', 'Player reel'));
$avgLabel = trim((string)$getConfig('texts.avg_label', 'Average Rating'));
$notesLabel = trim((string)$getConfig('texts.notes_label', 'Player Notes'));

$defaults = [
    ['name' => 'Arjun Mehta (Mumbai)', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'The table cards are cleaner than most casino landers. I can tell where to go without the page feeling flat.'],
    ['name' => 'Kavya Nair (Bengaluru)', 'rating' => '⭐⭐⭐⭐⭐', 'content' => 'Mobile spacing is excellent. The page still feels premium, but it is much easier to read between rounds.'],
    ['name' => 'Rahul Sethi (Delhi)', 'rating' => '⭐⭐⭐⭐☆', 'content' => 'Blackjack-first details come through quickly. The room choices feel distinct instead of being clones with new colors.'],
];

$parseStars = function($value) {
    preg_match_all('/[★⭐]/u', (string)$value, $matches);
    return count($matches[0] ?? []);
};

$buildInitials = function($name) {
    $parts = preg_split('/\s+/', trim((string)$name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};

$items = [];
for ($i = 1; $i <= 3; $i++) {
    $default = $defaults[$i - 1];
    $name = $getConfig("texts.testimonial_{$i}_name", $default['name']);
    $rating = $getConfig("texts.testimonial_{$i}_rating", $default['rating']);
    $content = $getConfig("texts.testimonial_{$i}_content", $default['content']);
    $avatar = trim((string)$getConfig("avatars.avatar_{$i}", ''));

    $items[] = [
        'name' => $name,
        'rating' => $rating,
        'stars' => max(1, $parseStars($rating)),
        'content' => $content,
        'avatar' => $avatar,
        'initials' => $buildInitials($name),
    ];
}

$avgRating = 0;
foreach ($items as $item) {
    $avgRating += $item['stars'];
}
$avgRating = count($items) ? number_format($avgRating / count($items), 1) : '0.0';
?>

<section id="<?= $componentId ?>" class="bkh-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <div class="test-shell">
        <header class="test-head" id="reviews">
            <?php if ($kicker !== ''): ?>
                <span class="test-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
        </header>

        <div class="test-stage">
            <aside class="test-summary test-reveal">
                <div class="summary-surface">
                    <?php if ($showRating): ?>
                        <div class="summary-score">
                            <span class="summary-label"><?= htmlspecialchars($avgLabel) ?></span>
                            <div class="summary-score-row">
                                <strong><?= htmlspecialchars($avgRating) ?></strong>
                                <div class="summary-stars" aria-hidden="true">
                                    <?php for ($star = 1; $star <= 5; $star++): ?>
                                        <span class="<?= $star <= (int)round((float)$avgRating) ? 'is-on' : '' ?>">★</span>
                                    <?php endfor; ?>
                                </div>
                            </div>
                        </div>
                    <?php else: ?>
                        <div class="summary-score summary-score-plain">
                            <span class="summary-label"><?= htmlspecialchars($notesLabel) ?></span>
                            <div class="summary-score-row">
                                <strong><?= count($items) ?></strong>
                            </div>
                        </div>
                    <?php endif; ?>

                    <div class="tes-nav">
                        <button type="button" class="tes-button tes-prev" aria-label="Previous reviews">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M14.75 5.75 8.5 12l6.25 6.25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                            </svg>
                        </button>
                        <button type="button" class="tes-button tes-next" aria-label="Next reviews">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M9.25 5.75 15.5 12l-6.25 6.25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </aside>

            <div class="test-viewport-wrap test-reveal">
                <div class="test-viewport">
                    <div class="test-track" role="list">
                        <?php foreach ($items as $index => $item): ?>
                            <article
                                class="quote-card<?= $index < 2 ? ' is-active' : '' ?>"
                                role="listitem"
                                data-card-index="<?= (int)$index ?>"
                                style="--quote-delay: <?= number_format($index * 0.08, 2, '.', '') ?>s;"
                            >
                                <div class="quote-mark">0<?= (int)($index + 1) ?></div>
                                <div class="quote-top">
                                    <?php if ($showAvatar): ?>
                                        <div class="quote-avatar">
                                            <?php if ($item['avatar'] !== ''): ?>
                                                <img src="<?= htmlspecialchars($item['avatar']) ?>" alt="<?= htmlspecialchars($item['name']) ?>">
                                            <?php else: ?>
                                                <span><?= htmlspecialchars($item['initials']) ?></span>
                                            <?php endif; ?>
                                        </div>
                                    <?php endif; ?>

                                    <div class="quote-meta">
                                        <strong><?= htmlspecialchars($item['name']) ?></strong>
                                        <?php if ($showRating): ?>
                                            <span><?= htmlspecialchars($item['rating']) ?></span>
                                        <?php endif; ?>
                                    </div>
                                </div>

                                <p class="quote-text"><?= htmlspecialchars($item['content']) ?></p>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </div>

                <div class="test-progress" aria-hidden="true">
                    <span></span>
                </div>
            </div>
        </div>
    </div>
</section>

