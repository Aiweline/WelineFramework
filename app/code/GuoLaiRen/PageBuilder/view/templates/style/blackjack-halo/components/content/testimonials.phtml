        flex-basis: 100%;
    }
}

@media (max-width: 767px) {
    #<?= $componentId ?> {
        padding: <?= (int)$sectionPaddingMobile ?>px 0;
    }

    #<?= $componentId ?> .test-shell {
        width: min(1180px, calc(100% - 0.9rem));
    }

    #<?= $componentId ?> .test-head {
        margin-bottom: 1.1rem;
    }

    #<?= $componentId ?> .summary-surface {
        gap: 0.9rem;
        padding: 1rem 0.9rem;
        border-radius: 24px;
    }

    #<?= $componentId ?> .summary-score-row {
        align-items: center;
        gap: 0.65rem;
    }

    #<?= $componentId ?> .summary-score strong {
        font-size: 2.2rem;
    }

    #<?= $componentId ?> .summary-stars {
        font-size: 0.92rem;
    }

    #<?= $componentId ?> .tes-button {
        width: 42px;
        height: 42px;
    }

    #<?= $componentId ?> .quote-card {
        padding: 18px;
        border-radius: 22px;
    }

    #<?= $componentId ?> .quote-mark {
        top: 0.85rem;
        right: 0.85rem;
        font-size: 2rem;
    }

    #<?= $componentId ?> .quote-top {
        gap: 0.72rem;
        margin-bottom: 0.92rem;
    }

    #<?= $componentId ?> .quote-meta span {
        font-size: 0.86rem;
    }
}

@media (prefers-reduced-motion: reduce) {
    #<?= $componentId ?> .test-reveal,
    #<?= $componentId ?> .test-track,
    #<?= $componentId ?> .quote-card,
    #<?= $componentId ?> .test-progress span,
    #<?= $componentId ?> .tes-button {
        animation: none;
        transition: none;
    }
}
</style>

<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    const stage = root.querySelector('.test-stage');
    const viewport = root.querySelector('.test-viewport');
    const track = root.querySelector('.test-track');
    const cards = Array.from(root.querySelectorAll('.quote-card'));
    const prevButton = root.querySelector('.tes-prev');
    const nextButton = root.querySelector('.tes-next');

    if (!track || !cards.length || !viewport) {
        return;
    }

    let activeIndex = 0;
    let resizeFrame = null;
    let dragStartX = null;
    let dragCurrentX = null;
    let suppressClickUntil = 0;

    const getVisibleCount = () => window.matchMedia('(max-width: 960px)').matches ? 1 : 2;
    const getMaxIndex = () => Math.max(cards.length - getVisibleCount(), 0);
    const getGap = () => {
        const styles = window.getComputedStyle(track);
        return parseFloat(styles.columnGap || styles.gap || '0');
    };

    const update = () => {
        const visibleCount = getVisibleCount();
        const maxIndex = getMaxIndex();
        const firstCard = cards[0];

        activeIndex = Math.min(activeIndex, maxIndex);

        if (firstCard) {
            const offset = activeIndex * (firstCard.getBoundingClientRect().width + getGap());
            track.style.transform = `translate3d(${-offset}px, 0, 0)`;
        }

        cards.forEach((card, index) => {
            const isActive = index >= activeIndex && index < activeIndex + visibleCount;
            card.classList.toggle('is-active', isActive);
        });

        if (prevButton) {
            prevButton.disabled = maxIndex === 0;
        }

        if (nextButton) {
            nextButton.disabled = maxIndex === 0;
        }

        const progress = maxIndex > 0 ? (activeIndex / maxIndex) * 100 : 0;
        root.style.setProperty('--track-progress', `${progress}%`);
    };

    const step = (direction) => {
        const maxIndex = getMaxIndex();
        if (maxIndex === 0) {
            update();
            return;
        }

        activeIndex += direction;

        if (activeIndex < 0) {
            activeIndex = maxIndex;
        }

        if (activeIndex > maxIndex) {
            activeIndex = 0;
        }

        update();
    };

    const startDrag = (clientX) => {
        dragStartX = clientX;
        dragCurrentX = clientX;
        viewport.classList.add('is-dragging');
    };

    const moveDrag = (clientX) => {
        if (dragStartX === null) {
            return;
        }

        dragCurrentX = clientX;
    };

    const endDrag = () => {
        if (dragStartX === null || dragCurrentX === null) {
            dragStartX = null;
            dragCurrentX = null;
            viewport.classList.remove('is-dragging');
            return;
        }

        const deltaX = dragCurrentX - dragStartX;

        dragStartX = null;
        dragCurrentX = null;
        viewport.classList.remove('is-dragging');

        if (Math.abs(deltaX) < 42) {
            return;
        }

        suppressClickUntil = Date.now() + 280;
        step(deltaX < 0 ? 1 : -1);
    };

    if (prevButton) {
        prevButton.addEventListener('click', () => step(-1));
    }

    if (nextButton) {
        nextButton.addEventListener('click', () => step(1));
    }

    cards.forEach((card, index) => {
        card.addEventListener('click', () => {
            if (Date.now() < suppressClickUntil) {
                return;
            }
            activeIndex = Math.min(index, getMaxIndex());
            update();
        });
    });

    viewport.addEventListener('touchstart', (event) => {
        if (event.touches[0]) {
            startDrag(event.touches[0].clientX);
        }
    }, { passive: true });

    viewport.addEventListener('touchmove', (event) => {
        if (event.touches[0]) {
            moveDrag(event.touches[0].clientX);
        }
    }, { passive: true });

    viewport.addEventListener('touchend', endDrag, { passive: true });
    viewport.addEventListener('touchcancel', endDrag, { passive: true });

    viewport.addEventListener('mousedown', (event) => {
        startDrag(event.clientX);
    });

    window.addEventListener('mousemove', (event) => {
        moveDrag(event.clientX);
    });

    window.addEventListener('mouseup', endDrag);

    if ('IntersectionObserver' in window && stage) {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    stage.classList.add('is-visible');
                    observer.disconnect();
                }
            });
        }, { threshold: 0.22 });

        observer.observe(stage);
    } else if (stage) {
        stage.classList.add('is-visible');
    }

    window.addEventListener('resize', () => {
        if (resizeFrame) {
            window.cancelAnimationFrame(resizeFrame);
        }

        resizeFrame = window.requestAnimationFrame(update);
    });

    update();
})();
</script>
