<script>
(function() {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) return;

    var items = Array.prototype.slice.call(root.querySelectorAll('[data-faq-item]'));
    if (!items.length) return;

    var setItemState = function(item, open) {
        var trigger = item.querySelector('[data-faq-trigger]');
        var wrap = item.querySelector('[data-faq-panel-wrap]');
        var panel = item.querySelector('[data-faq-panel]');
        item.classList.toggle('is-open', open);
        if (wrap) wrap.classList.toggle('is-open', open);
        if (trigger) trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (panel) panel.setAttribute('aria-hidden', open ? 'false' : 'true');
        var helper = item.querySelector('.faq-copy em');
        if (helper) helper.textContent = open ? 'Tap to close' : 'Tap to open';
    };

    items.forEach(function(item) {
        var trigger = item.querySelector('[data-faq-trigger]');
        if (!trigger) return;
        trigger.addEventListener('click', function() {
            var willOpen = !item.classList.contains('is-open');
            items.forEach(function(other) { setItemState(other, false); });
            if (willOpen) {
                setItemState(item, true);
            }
        });
    });
})();
</script>
