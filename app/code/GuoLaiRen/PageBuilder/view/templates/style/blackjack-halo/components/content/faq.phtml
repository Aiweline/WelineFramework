<?php
/**
 * Blackjack Halo FAQ Component
 *
 * @component_start
 * code: faq
 * name: 常见问题
 * name_en: FAQ
 * description: Blackjack Slip 风格 FAQ，保留 tpmst 读取规范
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.first_open => 首个问题默认展开:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#f7f4ed
 * style.title_color => 标题颜色:color:#16352d
 * style.title_font_size => 标题字体大小(PC端):number:36|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:24|px
 * style.item_bg_color => 问题卡片背景色:color:rgba(255,255,255,0.84)
 * style.item_border_radius => 问题卡片圆角:number:24|px
 * style.item_border_color => 问题卡片边框色:color:rgba(31,122,91,0.12)
 * style.item_gap => 问题间距:number:18|px
 * style.question_color => 问题文字颜色:color:#1f312d
 * style.question_font_size => 问题字号(PC端):number:16|px
 * style.question_font_size_mobile => 问题字号(移动端):number:14|px
 * style.question_padding => 问题内边距:number:20|px
 * style.question_hover_bg => 问题悬停背景:color:rgba(31,122,91,0.06)
 * style.icon_color => 图标颜色:color:#1f7a5b
 * style.icon_size => 图标大小:number:18|px
 * style.answer_color => 答案文字颜色:color:#5e746a
 * style.answer_font_size => 答案字号:number:14|px
 * style.answer_padding => 答案内边距:number:20|px
 * style.section_padding => 区域内边距(PC端):number:68|px
 * style.section_padding_mobile => 区域内边距(移动端):number:46|px
 *
 * group:texts => FAQ内容
 * texts.title => 区域标题:text:Blackjack Halo FAQs
 * texts.kicker => 区域提示:text:Pit Notes
 * texts.intro => 区域辅助文案:textarea:Table setup, room entry, and layout questions stay compact until the player opens the answer.
 * texts.open_hint => 展开提示:text:Tap to open
 * texts.close_hint => 收起提示:text:Tap to close
 * texts.faq_1_question => 问题1:text:Is Blackjack Halo only for blackjack landing pages?
 * texts.faq_1_answer => 答案1:textarea:Yes. The defaults, visuals, and microcopy are built around blackjack room entry, felt readability, and table selection flow.
 * texts.faq_2_question => 问题2:text:Can I replace the hero art and keep the same PHP logic?
 * texts.faq_2_answer => 答案2:textarea:Yes. The hero still reads banner and download button settings using the same fallback pattern, so visuals can change without changing the data structure.
 * texts.faq_3_question => 问题3:text:Does the light palette still work well on mobile?
 * texts.faq_3_answer => 答案3:textarea:Yes. Contrast, spacing, and action sizing are all tuned so the page stays easy to scan on smaller screens.
 * texts.faq_4_question => 问题4:text:Can table links and CTA targets be changed from config?
 * texts.faq_4_answer => 答案4:textarea:Yes. Navigation links, hero CTA, and footer links all respect the existing component configuration rules.
 * texts.faq_5_question => 问题5:text:What happens if some FAQ items are empty?
 * texts.faq_5_answer => 答案5:textarea:Empty items are skipped safely, and the component falls back to built-in defaults so the section still renders cleanly.
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'bkh-faq-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) return;
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

$bgColor = $getConfig('style.bg_color', $getConfig('faq.bg_color', '#f7f4ed'));
$titleColor = $getConfig('style.title_color', '#16352d');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$itemBgColor = $getConfig('style.item_bg_color', 'rgba(255,255,255,0.84)');
$itemBorderRadius = $getConfig('style.item_border_radius', '24');
$itemBorderColor = $getConfig('style.item_border_color', 'rgba(31,122,91,0.12)');
$itemGap = $getConfig('style.item_gap', '18');
$questionColor = $getConfig('style.question_color', '#1f312d');
$questionFontSize = $getConfig('style.question_font_size', '16');
$questionFontSizeMobile = $getConfig('style.question_font_size_mobile', '14');
$questionPadding = $getConfig('style.question_padding', '20');
$questionHoverBg = $getConfig('style.question_hover_bg', 'rgba(31,122,91,0.06)');
$iconColor = $getConfig('style.icon_color', '#1f7a5b');
$iconSize = $getConfig('style.icon_size', '18');
$answerColor = $getConfig('style.answer_color', '#5e746a');
$answerFontSize = $getConfig('style.answer_font_size', '14');
$answerPadding = $getConfig('style.answer_padding', '20');
$sectionPadding = $getConfig('style.section_padding', '68');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '46');

$title = $getConfig('texts.title', $getConfig('faq.title', 'Blackjack Halo FAQs'));
$kicker = trim((string)$getConfig('texts.kicker', 'Pit Notes'));
$intro = trim((string)$getConfig('texts.intro', 'Table setup, room entry, and layout questions stay compact until the player opens the answer.'));
$openHint = trim((string)$getConfig('texts.open_hint', 'Tap to open'));
$closeHint = trim((string)$getConfig('texts.close_hint', 'Tap to close'));

$defaults = [
    [
        'question' => 'Is Blackjack Halo only for blackjack landing pages?',
        'answer' => 'Yes. The defaults, visuals, and microcopy are built around blackjack room entry, felt readability, and table selection flow.',
    ],
    [
        'question' => 'Can I replace the hero art and keep the same PHP logic?',
        'answer' => 'Yes. The hero still reads banner and download button settings using the same fallback pattern, so visuals can change without changing the data structure.',
    ],
    [
        'question' => 'Does the light palette still work well on mobile?',
        'answer' => 'Yes. Contrast, spacing, and action sizing are all tuned so the page stays easy to scan on smaller screens.',
    ],
    [
        'question' => 'Can table links and CTA targets be changed from config?',
        'answer' => 'Yes. Navigation links, hero CTA, and footer links all respect the existing component configuration rules.',
    ],
    [
        'question' => 'What happens if some FAQ items are empty?',
        'answer' => 'Empty items are skipped safely, and the component falls back to built-in defaults so the section still renders cleanly.',
    ],
];

$faqs = [];
for ($i = 1; $i <= 5; $i++) {
    $default = $defaults[$i - 1] ?? ['question' => '', 'answer' => ''];
    $question = trim((string)$getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string)$getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

if (empty($faqs)) {
    $faqs = $defaults;
}
?>

<section id="<?= $componentId ?>" class="bkh-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell">
        <header class="faq-head" id="faq">
            <?php if ($kicker !== ''): ?>
                <span class="faq-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($intro !== ''): ?>
                <p class="faq-lede"><?= htmlspecialchars($intro) ?></p>
            <?php endif; ?>
        </header>

        <div class="faq-stack" role="list">
            <?php foreach ($faqs as $index => $faq): ?>
                <?php $isOpen = $firstOpen && $index === 0; ?>
                <article class="faq-slip<?= $isOpen ? ' is-open' : '' ?>" data-faq-item="<?= (int)$index ?>" role="listitem">
                    <button
                        type="button"
                        class="faq-question"
                        id="<?= $componentId ?>-trigger-<?= (int)$index ?>"
                        data-faq-trigger="<?= (int)$index ?>"
                        aria-controls="<?= $componentId ?>-panel-<?= (int)$index ?>"
                        aria-expanded="<?= $isOpen ? 'true' : 'false' ?>"
                    >
                        <span class="faq-number"><?= sprintf('%02d', $index + 1) ?></span>
                        <span class="faq-copy">
                            <strong><?= htmlspecialchars($faq['question']) ?></strong>
                            <em><?= htmlspecialchars($isOpen ? $closeHint : $openHint) ?></em>
                        </span>
                        <span class="faq-icon" aria-hidden="true">+</span>
                    </button>
                    <div class="faq-answer-wrap<?= $isOpen ? ' is-open' : '' ?>" data-faq-panel-wrap="<?= (int)$index ?>">
                        <div class="faq-answer-inner">
                            <div
                                class="faq-answer"
                                id="<?= $componentId ?>-panel-<?= (int)$index ?>"
                                data-faq-panel="<?= (int)$index ?>"
                                role="region"
                                aria-labelledby="<?= $componentId ?>-trigger-<?= (int)$index ?>"
                                aria-hidden="<?= $isOpen ? 'false' : 'true' ?>"
                            >
                                <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
                            </div>
                        </div>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

