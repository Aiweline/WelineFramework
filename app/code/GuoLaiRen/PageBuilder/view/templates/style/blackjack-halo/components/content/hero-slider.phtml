        'detail' => $getConfig('lanes.lane_2_desc', 'A cleaner path to live sessions with seat cues and pace notes surfaced earlier.'),
    ],
    [
        'label' => $getConfig('lanes.lane_3_label', 'High Limit'),
        'title' => $getConfig('lanes.lane_3_title', 'VIP Salon Access'),
        'detail' => $getConfig('lanes.lane_3_desc', 'Premium blackjack rooms stay distinct instead of feeling like the same card with a new color.'),
