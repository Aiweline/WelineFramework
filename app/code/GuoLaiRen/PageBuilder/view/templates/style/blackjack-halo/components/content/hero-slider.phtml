$page = $this->getData('page') ?? null;
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'bkh-hero-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function(array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$display = $normalizeToggle($getConfigAny(['hero.display', 'banner.display'], 'yes')) !== 'no';
if (!$display) {
    return;
}

$bannerBgColor = $getConfigAny(['hero.bg_color', 'banner.bg_color'], '#f6faf4');
$bannerAlt = $getConfigAny(['hero.alt', 'banner.alt'], 'Blackjack Halo table preview');
$bannerImageDesktop = trim((string)$getConfigAny(['hero.image', 'banner.image_desktop'], ''));
$bannerImageMobile = trim((string)$getConfigAny(['hero.image_mobile', 'banner.image_mobile'], ''));
$downloadDisplay = $normalizeToggle($getConfig('download_btn.display', 'yes')) !== 'no';
$downloadImage = trim((string)$getConfig('download_btn.image', ''));
$downloadAlt = $getConfig('download_btn.alt', 'Download Blackjack Halo');
$downloadUrl = $getConfig('download_btn.url', '#download');
$sliderClasses = trim((string)$getConfig('layout.slider_classes', 'bkh-hero-shell'));
$marginTop = (int)$getConfig('layout.margin_top', '-28');
$imgMarginTop = (int)$getConfig('layout.img_margin_top', '-0');

$defaultDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/hero-blackjack-halo.svg');
$defaultMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/hero-blackjack-halo-mobile.svg');
$defaultDownload = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/download-btn-halo.svg');

$finalDesktop = $bannerImageDesktop !== '' ? $bannerImageDesktop : $defaultDesktop;
$finalMobile = $bannerImageMobile !== '' ? $bannerImageMobile : $defaultMobile;
$finalDownload = $downloadImage !== '' ? $downloadImage : $defaultDownload;

$rawTitle = $getConfig('hero.title', '');
if ($rawTitle === '') {
    $rawTitle = $page ? ($page->getData('title') ?: 'Blackjack Halo') : 'Blackjack Halo';
}
$rawTitle = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', trim((string)$rawTitle));
$title = $rawTitle !== '' ? $rawTitle : 'Step Into a Cleaner Blackjack Table';

$subtitle = $getConfig('hero.subtitle', '');
if ($subtitle === '') {
    $subtitle = $page ? ($page->getData('meta_description') ?: '') : '';
}
if ($subtitle !== '' && (mb_strpos($subtitle, '预览模式') !== false || stripos($subtitle, 'preview') !== false)) {
    $subtitle = '';
}
if ($subtitle === '') {
    $subtitle = 'Blackjack Halo keeps classic 21 play familiar while making room stakes, live tables, and mobile entry easier to scan in one pass.';
}

$heroKicker = $getConfig('hero.kicker', 'Blackjack Halo');
$secondaryCtaText = $getConfig('hero.cta_text', 'View Tables');
$secondaryCtaUrl = $getConfig('hero.cta_url', '#tables');
$note1Title = $getConfig('notes.note_1_title', 'Stake board first');
$note1Desc = $getConfig('notes.note_1_desc', 'Minimums, chips, and table focus stay readable before the player even taps in.');
$note2Title = $getConfig('notes.note_2_title', 'Live route visible');
$note2Desc = $getConfig('notes.note_2_desc', 'Classic rooms, live dealer paths, and VIP jumps stay separated instead of blending together.');

$highlights = [
    [
        'label' => $getConfig('lanes.lane_1_label', 'Classic Entry'),
        'title' => $getConfig('lanes.lane_1_title', 'Standard 21 Rooms'),
        'detail' => $getConfig('lanes.lane_1_desc', 'Visible stakes, clear chip prompts, and the fastest route into regular blackjack tables.'),
    ],
    [
        'label' => $getConfig('lanes.lane_2_label', 'Live Route'),
