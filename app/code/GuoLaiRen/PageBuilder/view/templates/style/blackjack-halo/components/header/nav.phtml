 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:Blackjack Halo
 * logo.subline => Logo副标题:text:Light blackjack route
 * logo.url => Logo图片地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:responsive:48/48|px
 * logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:rgba(249,248,242,0.82)
 * navigation.bg_color_scrolled => 滚动后导航背景色:color:rgba(249,248,242,0.94)
 * navigation.text_color => 导航文字颜色:color:#1f312d
 * navigation.link_color => 链接颜色:color:#49665b
 * navigation.link_hover_color => 链接悬停颜色:color:#14523f
 * navigation.items => 导航项:textarea:Home=>/\r\nTables=>#tables\r\nWhy Halo=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|配置格式：名字=>url，一行一个
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * navigation.use_subpages => 兼容旧版-使用子页面作为导航:select:no|yes,no
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文字:text:Open Table
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#1f7a5b
 * download_button.bg_hover_color => 按钮悬停背景色:color:#15523e
 * download_button.text_color => 按钮文字颜色:color:#f7f4ea
 * @fields_end
 */

$componentId = 'bkh-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$config = array_merge($styleSettings, $componentConfig);
$standaloneShell = !($this->getData('__pagebuilder_shell_managed'));

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function(array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string)$value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string)($parts[0] ?? '')),
        'desktop' => trim((string)($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function($parsed) {
    $mobile = (float)$parsed['mobile'];
    $desktop = (float)$parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$sanitizeTitle = static function($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$metaTitleRaw = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Blackjack Halo';
$metaTitle = $sanitizeTitle($metaTitleRaw);
if ($metaTitle === '') {
    $metaTitle = 'Blackjack Halo';
}
$metaDescription = $page ? (string)($page->getData('meta_description') ?: '') : '';
$metaKeywords = $page ? (string)($page->getData('meta_keywords') ?: '') : '';

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text'], 'Blackjack Halo'));
if ($logoText === '') {
    $logoText = 'Blackjack Halo';
}
$logoSubline = trim((string)$getConfigAny(['logo.subline', 'header.logo.subline'], 'Light blackjack route'));
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/halo-logo-icon.svg');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '48/48') . 'px'));
$logoHeightConfig = trim((string)$getConfigAny(['logo.height', 'header.logo.height'], ''));
$logoHeight = $logoHeightConfig !== '' ? $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px')) : $logoWidth;

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
$navBgColor = (string)$getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], 'rgba(249,248,242,0.82)');
$navBgColorScrolled = (string)$getConfig('navigation.bg_color_scrolled', 'rgba(249,248,242,0.94)');
$navTextColor = (string)$getConfigAny(['navigation.text_color', 'header.navigation.text_color'], '#1f312d');
$navLinkColor = (string)$getConfigAny(['navigation.link_color', 'header.navigation.link_color'], '#49665b');
$navLinkHoverColor = (string)$getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], '#14523f');
$navItemsConfig = (string)$getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nTables=>#tables\nWhy Halo=>#advantages\nReviews=>#reviews\nFAQ=>#faq");
$useCustomLinksRaw = (string)$getConfig('navigation.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('navigation.use_subpages', 'no'), 'no') !== 'yes';

$showCta = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string)$getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Open Table'));
$ctaUrl = (string)$getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download');
$ctaBgColor = (string)$getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], '#1f7a5b');
$ctaBgHoverColor = (string)$getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], '#15523e');
$ctaTextColor = (string)$getConfigAny(['download_button.text_color', 'header.download_button.text_color'], '#f7f4ea');
$ctaUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($ctaUrl);
$ctaResolvedHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaResolvedHref, 'nav');

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : (method_exists($page, 'getNavigationPages') ? $page->getNavigationPages([], 10) : []);
    foreach ($navigationPages as $navPage) {
        $text = trim((string)($navPage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = (string)($navPage['type'] ?? '');
        $configuredLabel = trim((string)$getConfigAny([
            'navigation_labels.navigation.label_' . $type,
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], ''));
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => (string)($navPage['url'] ?? '#'),
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '') {
            continue;
        }
        if (strpos($line, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $line, 2));
        } elseif (strpos($line, '|') !== false) {
            $parts = array_map('trim', explode('|', $line, 2));
        } else {
            $parts = [$line, '#'];
        }
        if (($parts[0] ?? '') === '') {
            continue;
        }
        $navItems[] = [
            'text' => $parts[0],
            'href' => ($parts[1] ?? '') !== '' ? $parts[1] : '#',
        ];
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}
