<?php if ($navDisplay): ?>
<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) return;

    const toggle = root.querySelector('.nav-toggle');
    const links = root.querySelectorAll('.mobile-link, .mobile-cta');
    const setOpen = (open) => {
        root.dataset.mobileOpen = open ? 'true' : 'false';
        if (toggle) {
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
    };

    const syncScroll = () => {
        root.classList.toggle('is-scrolled', window.scrollY > 12);
    };

    if (toggle) {
        toggle.addEventListener('click', () => {
            setOpen(root.dataset.mobileOpen !== 'true');
        });
    }

    links.forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
    });

    syncScroll();
    window.addEventListener('scroll', syncScroll, { passive: true });
})();
</script>
<?php endif; ?>
