 * hero.bg_gradient_end => 顶部渐变结束色:color:#eef4e8
 * hero.title_color => 标题颜色:color:#1f312d

 * group:info => 联系面板
 * info.kicker => 联系面板提示:text:Support Routes
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.email => 邮箱:text:support@blackjackhalo.com
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.address => 地址:text:Mumbai, India
 * contact_info.work_hours_label => 支持时间标签:text:Support Hours
 * contact_info.work_hours => 支持时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:
 * social.twitter => Twitter链接:text:
 * social.linkedin => LinkedIn链接:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send the Halo Desk a Message
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.name_placeholder => 姓名占位:text:Enter your name
 * form.email_placeholder => 邮箱占位:text:Enter your email
 * form.subject_placeholder => 主题占位:text:Tell us what this is about
 * form.message_placeholder => 消息占位:textarea:Share the issue, room, or account detail here...
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share the table, account, or payout context once so the right blackjack support lane can pick it up faster.

 * group:message => 留言面板
 * message.kicker => 留言面板提示:text:Message Queue

 * group:notes => 说明面板
 * notes.kicker => 说明面板提示:text:Desk Notes
 * notes.title => 说明面板标题:text:Support Context

 * group:social_panel => 社交面板
 * social_panel.title => 社交面板标题:text:Follow Blackjack Halo
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Support hub location
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'bkh-contact-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', $getConfig('display.show_channels', 'yes')) !== 'no';

$page = $this->getData('page');
$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $getConfig('content.title', $pageTitle)));
if ($title === '') {
    $title = 'Contact Blackjack Halo';
}
$heroBadge = trim((string)$getConfig('hero.badge', 'Contact Desk'));
$description = trim((string)$getConfig('hero.subtitle', $getConfig('content.description', 'Need help with tables, account access, or room setup? The Blackjack Halo team is available throughout the day.')));
$heroBg = trim((string)$getConfig('hero.bg_color', '#f7f5ed'));
$heroBgEnd = trim((string)$getConfig('hero.bg_gradient_end', '#eef4e8'));
$heroTitleColor = trim((string)$getConfig('hero.title_color', '#1f312d'));
$infoKicker = trim((string)$getConfig('info.kicker', 'Support Routes'));

$email = trim((string)$getConfig('contact_info.email', $getConfig('contact.email', 'support@blackjackhalo.com')));
$phone = trim((string)$getConfig('contact_info.phone', $getConfig('contact.phone', '+91 1800-XXX-XXXX')));
$address = trim((string)$getConfig('contact_info.address', $getConfig('contact.address', 'Mumbai, India')));
$hours = trim((string)$getConfig('contact_info.work_hours', $getConfig('contact.hours', '24/7 Customer Support')));
$addressLabel = trim((string)$getConfig('contact_info.address_label', 'Address'));
$phoneLabel = trim((string)$getConfig('contact_info.phone_label', 'Phone'));
$emailLabel = trim((string)$getConfig('contact_info.email_label', 'Email'));
$workHoursLabel = trim((string)$getConfig('contact_info.work_hours_label', 'Support Hours'));

$formTitle = trim((string)$getConfig('form.title', $getConfig('content.form_title', 'Send the Halo Desk a Message')));
$formNameLabel = trim((string)$getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string)$getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string)$getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string)$getConfig('form.message_label', 'Message'));
$formNamePlaceholder = trim((string)$getConfig('form.name_placeholder', 'Enter your name'));
$formEmailPlaceholder = trim((string)$getConfig('form.email_placeholder', 'Enter your email'));
$formSubjectPlaceholder = trim((string)$getConfig('form.subject_placeholder', 'Tell us what this is about'));
$formMessagePlaceholder = trim((string)$getConfig('form.message_placeholder', 'Share the issue, room, or account detail here...'));
$formSubmitText = trim((string)$getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string)$getConfig('form.success_message', $getConfig('content.form_intro', 'Share the table, account, or payout context once so the right blackjack support lane can pick it up faster.')));
$messageKicker = trim((string)$getConfig('message.kicker', 'Message Queue'));
$notesKicker = trim((string)$getConfig('notes.kicker', 'Desk Notes'));
$notesTitle = trim((string)$getConfig('notes.title', 'Support Context'));
$socialPanelTitle = trim((string)$getConfig('social_panel.title', 'Follow Blackjack Halo'));
$mapTitle = trim((string)$getConfig('map.title', 'Support hub location'));
$mapEmbedUrl = trim((string)$getConfig('map.embed_url', ''));
$mapHeight = max(240, (int)$getConfig('map.height', 360));

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string)$getConfig($key, ''));
    if ($url === '') {
        continue;
    }
    $socials[] = [
        'name' => $label,
        'url' => $url,
    ];
}

if (empty($socials)) {
    $socialRaw = (string)$getConfig('social.items', "Facebook|#\nTwitter|#\nInstagram|#\nYouTube|#");
    if (strpos($socialRaw, '\\n') !== false && strpos($socialRaw, "\n") === false) {
        $socialRaw = str_replace('\\n', "\n", $socialRaw);
    }
    foreach (preg_split('/[\r\n]+/', $socialRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim($parts[0] ?? '') !== '') {
            $socials[] = [
                'name' => trim($parts[0]),
                'url' => trim($parts[1] ?? '#'),
            ];
        }
    }
}

$channels = [];
$channelDefaults = [
    ['code' => '01', 'label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email],
    ['code' => '02', 'label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone],
    ['code' => '03', 'label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address],
    ['code' => '04', 'label' => $workHoursLabel !== '' ? $workHoursLabel : 'Support Hours', 'value' => $hours],
];
foreach ($channelDefaults as $channel) {
    if (($channel['value'] ?? '') === '') {
        continue;
    }
    $channels[] = $channel;
}
?>

<section id="<?= $componentId ?>" class="bkh-contact">
    <div class="contact-shell">
        <header class="contact-hero">
            <?php if ($heroBadge !== ''): ?>
                <span class="hero-badge"><?= htmlspecialchars($heroBadge) ?></span>
            <?php endif; ?>
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <div class="contact-stage<?= !$showInfo ? ' no-info' : '' ?><?= !$showForm ? ' no-form' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="route-panel">
                    <article class="route-summary">
                        <?php if ($infoKicker !== ''): ?>
                            <span class="panel-kicker"><?= htmlspecialchars($infoKicker) ?></span>
                        <?php endif; ?>
                        <h2><?= htmlspecialchars($hours !== '' ? $hours : $title) ?></h2>
                        <?php if ($description !== ''): ?>
                            <p><?= htmlspecialchars($description) ?></p>
                        <?php endif; ?>
                    </article>

                    <?php if (!empty($channels)): ?>
                        <div class="route-list">
                            <?php foreach ($channels as $channel): ?>
                                <article class="route-card">
                                    <span class="route-code"><?= htmlspecialchars($channel['code']) ?></span>
                                    <div class="route-body">
                                        <span class="route-label"><?= htmlspecialchars($channel['label']) ?></span>
                                        <strong><?= htmlspecialchars($channel['value']) ?></strong>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <section class="message-panel">
                    <div class="message-head">
                        <?php if ($messageKicker !== ''): ?>
                            <span class="panel-kicker"><?= htmlspecialchars($messageKicker) ?></span>
                        <?php endif; ?>
                        <h2><?= htmlspecialchars($formTitle) ?></h2>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </div>

                    <form class="contact-form">
                        <div class="field-grid">
                            <label class="field field-half">
                                <span><?= htmlspecialchars($formNameLabel) ?></span>
                                <input type="text" placeholder="<?= htmlspecialchars($formNamePlaceholder) ?>">
                            </label>
                            <label class="field field-half">
                                <span><?= htmlspecialchars($formEmailLabel) ?></span>
                                <input type="email" placeholder="<?= htmlspecialchars($formEmailPlaceholder) ?>">
                            </label>
                        </div>

                        <label class="field">
                            <span><?= htmlspecialchars($formSubjectLabel) ?></span>
                            <input type="text" placeholder="<?= htmlspecialchars($formSubjectPlaceholder) ?>">
                        </label>

                        <label class="field">
                            <span><?= htmlspecialchars($formMessageLabel) ?></span>
                            <textarea placeholder="<?= htmlspecialchars($formMessagePlaceholder) ?>"></textarea>
                        </label>

                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </section>
            <?php endif; ?>

            <aside class="follow-panel">
                <article class="follow-note">
                    <?php if ($notesKicker !== ''): ?>
                        <span class="panel-kicker"><?= htmlspecialchars($notesKicker) ?></span>
                    <?php endif; ?>
                    <?php if ($notesTitle !== ''): ?>
                        <h2><?= htmlspecialchars($notesTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($pageContent !== ''): ?>
                        <div class="follow-richtext"><?= $pageContent ?></div>
                    <?php elseif ($formSuccessMessage !== ''): ?>
                        <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                    <?php endif; ?>
                </article>

                <?php if ($showSocial && !empty($socials)): ?>
                    <article class="follow-links">
                        <?php if ($socialPanelTitle !== ''): ?>
                            <span class="social-title"><?= htmlspecialchars($socialPanelTitle) ?></span>
                        <?php endif; ?>
                        <div class="social-grid">
                            <?php foreach ($socials as $social): ?>
                                <a href="<?= htmlspecialchars($social['url']) ?>" class="social-link" target="_blank" rel="noopener" title="<?= htmlspecialchars($social['name']) ?>">
                                    <strong><?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?></strong>
                                    <span><?= htmlspecialchars($social['name']) ?></span>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    </article>
                <?php endif; ?>
            </aside>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="contact-map">
                <?php if ($mapTitle !== ''): ?>
                    <h2 class="map-title"><?= htmlspecialchars($mapTitle) ?></h2>
                <?php endif; ?>
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int)$mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

