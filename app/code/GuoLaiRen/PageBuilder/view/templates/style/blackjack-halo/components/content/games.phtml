<?php
/**
 * Blackjack Halo Games Showcase Component
 *
 * @component_start
 * code: games-showcase
 * name: 游戏介绍
 * name_en: Games Showcase
 * description: Blackjack Halo 牌桌展示，遵循 tpmst 游戏字段规范
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示卡片描述:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#f7fbf5
 * style.title_color => 标题颜色:color:#1e5b46
 * style.title_font_size => 标题字体大小(PC端):number:36|px
 * style.title_font_size_mobile => 标题字体大小(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.88)
 * style.card_border_radius => 卡片圆角:number:26|px
 * style.card_border_color => 卡片边框色:color:rgba(31,122,91,0.12)
 * style.card_title_color => 卡片标题颜色:color:#20352d
 * style.card_title_font_size => 卡片标题字号:number:20|px
 * style.card_desc_color => 卡片描述颜色:color:#61756d
 * style.card_desc_font_size => 卡片描述字号:number:14|px
 * style.section_padding => 区域内边距(PC端):number:76|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 * style.card_gap => 卡片间距:number:22|px
 * style.card_content_padding => 卡片内容内边距:number:20|px
 * style.hover_transform => 悬停上移距离:number:5|px
 *
 * group:images => 图片配置
 * images.image_1_desktop => 游戏1桌面端图片:textarea:|默认使用本地 game-blackjack-classic.svg
 * images.image_1_mobile => 游戏1移动端图片:textarea:|默认使用本地 game-blackjack-classic.svg
 * images.image_2 => 游戏2图片:textarea:|默认使用本地 game-blackjack-live.svg
 * images.image_3 => 游戏3图片:textarea:|默认使用本地 game-blackjack-vip.svg
 *
 * group:texts => 游戏文本
 * texts.kicker => 顶部提示:text:Dealer shelf
 * texts.game_1_badge => 游戏1标签:text:Core table
 * texts.game_1_meta => 游戏1补充标签:text:Steady pace
 * texts.title => 区域标题:text:Choose Your Halo Table
 * texts.game_1_title => 游戏1标题:text:Classic Blackjack
 * texts.game_1_desc => 游戏1描述:textarea:For players who want the cleanest read of the felt, balanced pacing, and a familiar room flow.
 * texts.game_2_badge => 游戏2标签:text:Live flow
 * texts.game_2_meta => 游戏2补充标签:text:Sharper tempo
 * texts.game_2_title => 游戏2标题:text:Live Dealer Room
 * texts.game_2_desc => 游戏2描述:textarea:Sharper motion, clearer seat cues, and a more active session pace for players who like live-room energy.
 * texts.game_3_badge => 游戏3标签:text:Premium route
 * texts.game_3_meta => 游戏3补充标签:text:Quiet polish
 * texts.game_3_title => 游戏3标题:text:VIP Halo Salon
 * texts.game_3_desc => 游戏3描述:textarea:A more curated high-limit feel with polished card presentation and a calmer premium route.
 *
 * @fields_end
