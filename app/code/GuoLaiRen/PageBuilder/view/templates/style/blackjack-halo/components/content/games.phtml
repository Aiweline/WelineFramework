$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'bkh-games-' . uniqid();

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showDescription = $getConfig('display.show_description', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('games.bg_color', '#f7fbf5'));
$titleColor = $getConfig('style.title_color', '#1e5b46');
$titleFontSize = $getConfig('style.title_font_size', '36');
$titleFontSizeMobile = $getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.88)');
$cardBorderRadius = $getConfig('style.card_border_radius', '26');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(31,122,91,0.12)');
$cardTitleColor = $getConfig('style.card_title_color', '#20352d');
$cardTitleFontSize = $getConfig('style.card_title_font_size', '20');
$cardDescColor = $getConfig('style.card_desc_color', '#61756d');
$cardDescFontSize = $getConfig('style.card_desc_font_size', '14');
$sectionPadding = $getConfig('style.section_padding', '76');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');
$cardGap = $getConfig('style.card_gap', '22');
$cardContentPadding = $getConfig('style.card_content_padding', '20');
$hoverTransform = $getConfig('style.hover_transform', '5');

$defaultImage1Desktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/game-blackjack-classic.svg');
$defaultImage1Mobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/game-blackjack-classic.svg');
$defaultImage2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/game-blackjack-live.svg');
$defaultImage3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/blackjack-halo/asset/img/game-blackjack-vip.svg');

$image1Desktop = $getConfig('images.image_1_desktop', $getConfig('games.image_1_desktop', '')) ?: $defaultImage1Desktop;
$image1Mobile = $getConfig('images.image_1_mobile', $getConfig('games.image_1_mobile', '')) ?: $defaultImage1Mobile;
$image2 = $getConfig('images.image_2', $getConfig('games.image_2', '')) ?: $defaultImage2;
$image3 = $getConfig('images.image_3', $getConfig('games.image_3', '')) ?: $defaultImage3;

$kicker = $getConfig('texts.kicker', 'Dealer shelf');
$title = $getConfig('texts.title', $getConfig('games.title', 'Choose Your Halo Table'));
$badge1 = $getConfig('texts.game_1_badge', 'Core table');
$meta1 = $getConfig('texts.game_1_meta', 'Steady pace');
$title1 = $getConfig('texts.game_1_title', 'Classic Blackjack');
$desc1 = $getConfig('texts.game_1_desc', 'For players who want the cleanest read of the felt, balanced pacing, and a familiar room flow.');
$badge2 = $getConfig('texts.game_2_badge', 'Live flow');
$meta2 = $getConfig('texts.game_2_meta', 'Sharper tempo');
$title2 = $getConfig('texts.game_2_title', 'Live Dealer Room');
$desc2 = $getConfig('texts.game_2_desc', 'Sharper motion, clearer seat cues, and a more active session pace for players who like live-room energy.');
$badge3 = $getConfig('texts.game_3_badge', 'Premium route');
$meta3 = $getConfig('texts.game_3_meta', 'Quiet polish');
$title3 = $getConfig('texts.game_3_title', 'VIP Halo Salon');
$desc3 = $getConfig('texts.game_3_desc', 'A more curated high-limit feel with polished card presentation and a calmer premium route.');

$items = [
    [
        'title' => $title1,
        'desc' => $desc1,
        'desktop' => $image1Desktop,
        'mobile' => $image1Mobile,
        'tag' => $badge1,
        'meta' => $meta1,
    ],
    [
        'title' => $title2,
        'desc' => $desc2,
        'desktop' => $image2,
        'mobile' => $image2,
        'tag' => $badge2,
        'meta' => $meta2,
    ],
    [
        'title' => $title3,
        'desc' => $desc3,
        'desktop' => $image3,
        'mobile' => $image3,
        'tag' => $badge3,
        'meta' => $meta3,
    ],
];
?>

<section id="<?= $componentId ?>" class="bkh-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <span class="games-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
        </header>

        <div class="games-track" role="list">
            <?php foreach ($items as $index => $item): ?>
                <article class="game-card game-card-<?= (int)$index ?>" role="listitem">
                    <div class="game-media">
                        <picture>
                            <source media="(max-width: 767px)" srcset="<?= htmlspecialchars($item['mobile']) ?>">
                            <img src="<?= htmlspecialchars($item['desktop']) ?>" alt="<?= htmlspecialchars($item['title']) ?>" loading="lazy">
                        </picture>
                    </div>

                    <div class="game-body">
                        <div class="game-topline">
                            <span class="game-tag"><?= htmlspecialchars($item['tag']) ?></span>
                            <span class="game-meta"><?= htmlspecialchars($item['meta']) ?></span>
                        </div>
                        <h3><?= htmlspecialchars($item['title']) ?></h3>
                        <?php if ($showDescription): ?>
                            <p><?= htmlspecialchars($item['desc']) ?></p>
                        <?php endif; ?>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>

