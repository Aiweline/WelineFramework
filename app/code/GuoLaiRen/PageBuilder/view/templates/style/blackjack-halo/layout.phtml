<?php
/**
 * Blackjack Halo - Main Layout
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$templateCode = 'blackjack-halo';

$layoutConfig = $this->getData('layout_config') ?: [];
$headerComponents = $layoutConfig['header'] ?? [];
$contentComponents = $layoutConfig['content'] ?? [];
$footerComponents = $layoutConfig['footer'] ?? [];

if (empty($headerComponents)) {
    $headerComponents = [['code' => 'header-nav', 'enabled' => true, 'config' => []]];
}

if (empty($contentComponents)) {
    $contentComponents = [
        ['code' => 'hero-slider', 'enabled' => true, 'config' => []],
        ['code' => 'advantages', 'enabled' => true, 'config' => []],
        ['code' => 'games-showcase', 'enabled' => true, 'config' => []],
        ['code' => 'testimonials', 'enabled' => true, 'config' => []],
        ['code' => 'faq', 'enabled' => true, 'config' => []],
    ];
}

if (empty($footerComponents)) {
    $footerComponents = [['code' => 'footer-links', 'enabled' => true, 'config' => []]];
}

$componentFiles = [
    'header-nav' => 'header/nav.phtml',
    'hero-slider' => 'content/hero-slider.phtml',
    'advantages' => 'content/advantages.phtml',
    'games-showcase' => 'content/games.phtml',
    'slider' => 'content/slider.phtml',
    'banner' => 'content/banner.phtml',
    'testimonials' => 'content/testimonials.phtml',
    'faq' => 'content/faq.phtml',
    'about-content' => 'content/about-content.phtml',
    'contact-content' => 'content/contact-content.phtml',
    'legal-content' => 'content/legal-content.phtml',
    'blog-list' => 'content/blog-list.phtml',
    'blog-category' => 'content/blog-category.phtml',
    'blog-detail' => 'content/blog-detail.phtml',
    'footer-links' => 'footer/links.phtml',
];

$renderComponent = function($component) use ($componentFiles, $page, $styleSettings) {
    $code = $component['code'] ?? '';
    $enabled = $component['enabled'] ?? true;
    $componentConfig = $component['config'] ?? [];

    if (!$enabled || $code === '') {
        return '';
    }

    $file = $componentFiles[$code] ?? null;
    if (!$file) {
        return "<!-- Component not found: {$code} -->";
    }

    ob_start();
    $this->assign('page', $page);
    $this->assign('style', $styleSettings);
    $this->assign('style_settings', $styleSettings);
    $this->assign('component_config', $componentConfig);
    echo $this->fetchTemplate("GuoLaiRen_PageBuilder::style/blackjack-halo/components/{$file}");
    return ob_get_clean();
};

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sanitizeTitle = function($value) {
    $value = trim((string)$value);
    if ($value === '') return $value;
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$pageTitleRaw = $page ? $page->getData('title') : 'Blackjack Halo';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'Blackjack Halo';
}
$pageDescription = $page ? $page->getData('meta_description') : '';
?>
