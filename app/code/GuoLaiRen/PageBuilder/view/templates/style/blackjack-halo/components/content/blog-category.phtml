    position: relative;
    padding: 84px 0;
    background:
        radial-gradient(920px 420px at 12% 8%, rgba(31, 122, 91, 0.14), transparent 68%),
        radial-gradient(760px 360px at 88% 16%, rgba(208, 160, 63, 0.16), transparent 68%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 28%),
        <?= htmlspecialchars($bgColor) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
    overflow: hidden;
}

