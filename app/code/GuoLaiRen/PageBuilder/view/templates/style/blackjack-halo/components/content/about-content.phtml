<?php
/**
 * Blackjack Halo - About Content Component
 *
 * @component_start
 * code: about-content
 * name: 关于我们内容
 * name_en: About Content
 * description: Blackjack Halo 关于页面内容展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_stats => 显示数据统计:select:yes|yes,no
 * display.show_values => 显示价值观:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:About Blackjack Halo
 * hero.subtitle => 页面副标题:textarea:Blackjack Halo reframes classic blackjack with lighter pacing, clearer room discovery, and calmer mobile reading.
 * hero.bg_color => 背景基础色:color:#f7f5ed
 * hero.bg_gradient_end => 渐变结束色:color:#eef4e8
 * hero.title_color => 标题颜色:color:#1f312d
 * hero.text_color => 文字颜色:color:#62786f
 * hero.padding => 区域内边距:number:92|px
 *
 * group:stats => 数据统计
 * stats.stat_1_number => 统计1数字:text:3-step
 * stats.stat_1_label => 统计1标签:text:Room discovery flow
 * stats.stat_2_number => 统计2数字:text:24/7
 * stats.stat_2_label => 统计2标签:text:Support desk coverage
 * stats.stat_3_number => 统计3数字:text:4.9/5
 * stats.stat_3_label => 统计3标签:text:Average layout rating
 * stats.stat_4_number => 统计4数字:text:100%
 * stats.stat_4_label => 统计4标签:text:Blackjack-first routing
 * stats.card_bg => 统计卡片背景基础色:color:#ffffff
 * stats.number_color => 统计数值颜色:color:#1f312d
 * stats.label_color => 统计说明颜色:color:#657b71
 * stats.highlight_label => 核心数据提示:text:Halo Snapshot
 *
 * group:story => 故事区块
 * story.title => 标题:text:Why Halo Was Built
 * story.content => 内容:textarea:Blackjack Halo started with one goal: make blackjack landers feel easier to scan without losing the premium table mood.\n\nInstead of repeating the same room cards and stacked sections, the experience breaks the route into cleaner reading lanes, clearer visual stops, and calmer mobile spacing.
 * story.bg_color => 故事卡片背景基础色:color:#ffffff
 * story.text_color => 故事正文颜色:color:#647a70
 *
 * group:values => 价值观区块
 * values.title => 标题:text:What Guides Every Halo Screen
 * values.subtitle => 副标题:text:Three editable cues keep the page focused on table discovery, trust, and mobile reading.
 * values.kicker => 区块提示:text:Operating Principles
 * values.bg_color => 价值观卡片背景基础色:color:#ffffff
 * values.title_color => 价值观标题颜色:color:#1f312d
 * values.text_color => 价值观描述颜色:color:#667c72
 * values.value_1_icon => 价值1图标:text:01
 * values.value_1_title => 价值1标题:text:Table Clarity
 * values.value_1_desc => 价值1描述:textarea:Players should understand the room type, pace, and next action at first glance.
 * values.value_2_icon => 价值2图标:text:02
 * values.value_2_title => 价值2标题:text:Fair Dealing
 * values.value_2_desc => 价值2描述:textarea:Rules, expectations, and trust cues should appear before friction appears.
 * values.value_3_icon => 价值3图标:text:03
 * values.value_3_title => 价值3标题:text:Mobile Calm
 * values.value_3_desc => 价值3描述:textarea:Spacing, contrast, and card rhythm should stay readable during fast blackjack browsing.
 *
 * @fields_end
 */

$page = $this->getData('page');
$componentId = 'bkh-about-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if ($getConfig('display.show_section', $getConfig('about.display', 'yes')) === 'no') {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';

$heroBgColor = trim((string)$getConfig('hero.bg_color', '#f7f5ed'));
$heroBgGradientEnd = trim((string)$getConfig('hero.bg_gradient_end', '#eef4e8'));
$heroTitleColor = trim((string)$getConfig('hero.title_color', '#1f312d'));
$heroTextColor = trim((string)$getConfig('hero.text_color', '#62786f'));
$sectionPadding = (int)$getConfig('hero.padding', '92');

$statsCardBg = trim((string)$getConfig('stats.card_bg', '#ffffff'));
$statsNumberColor = trim((string)$getConfig('stats.number_color', '#1f312d'));
$statsLabelColor = trim((string)$getConfig('stats.label_color', '#657b71'));
$statsHighlightLabel = trim((string)$getConfig('stats.highlight_label', 'Halo Snapshot'));

$storyBgColor = trim((string)$getConfig('story.bg_color', '#ffffff'));
$storyTextColor = trim((string)$getConfig('story.text_color', '#647a70'));

$valuesKicker = trim((string)$getConfig('values.kicker', 'Operating Principles'));
$valuesBgColor = trim((string)$getConfig('values.bg_color', '#ffffff'));
$valuesTitleColor = trim((string)$getConfig('values.title_color', '#1f312d'));
$valuesTextColor = trim((string)$getConfig('values.text_color', '#667c72'));

$pageTitle = $page ? trim((string)($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string)($page->getData('content') ?? '')) : '';

$title = trim((string)$getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'About Blackjack Halo';
}
$subtitle = trim((string)$getConfig('hero.subtitle', 'Blackjack Halo reframes classic blackjack with lighter pacing, clearer room discovery, and calmer mobile reading.'));

$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $defaultNumbers = ['3-step', '24/7', '4.9/5', '100%'];
    $defaultLabels = ['Room discovery flow', 'Support desk coverage', 'Average layout rating', 'Blackjack-first routing'];
    $number = trim((string)$getConfig("stats.stat_{$i}_number", $defaultNumbers[$i - 1]));
    $label = trim((string)$getConfig("stats.stat_{$i}_label", $defaultLabels[$i - 1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'value' => $number,
        'label' => $label,
    ];
}

if (empty($stats)) {
    $statsRaw = (string)$getConfig('stats.items', "3-step|Room discovery flow\n24/7|Support desk coverage\n4.9/5|Average layout rating\n100%|Blackjack-first routing");
    if (strpos($statsRaw, '\\n') !== false && strpos($statsRaw, "\n") === false) {
        $statsRaw = str_replace('\\n', "\n", $statsRaw);
    }
    foreach (preg_split('/[\r\n]+/', $statsRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim($parts[0] ?? '') !== '') {
            $stats[] = [
                'value' => trim($parts[0]),
                'label' => trim($parts[1] ?? ''),
            ];
        }
    }
}

$storyTitle = trim((string)$getConfig('story.title', 'Why Halo Was Built'));
$storyContent = trim((string)$getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = "Blackjack Halo started with one goal: make blackjack landers feel easier to scan without losing the premium table mood.\n\nInstead of repeating the same room cards and stacked sections, the experience breaks the route into cleaner reading lanes, clearer visual stops, and calmer mobile spacing.";
}
$storyParagraphs = preg_split('/[\r\n]+/', trim((string) $storyContent));
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs) && trim((string) $storyContent) !== '') {
    $storyParagraphs = [trim((string) $storyContent)];
}

$valuesTitle = trim((string)$getConfig('values.title', 'What Guides Every Halo Screen'));
$valuesSubtitle = trim((string)$getConfig('values.subtitle', 'Three editable cues keep the page focused on table discovery, trust, and mobile reading.'));
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $defaults = [
        ['01', 'Table Clarity', 'Players should understand the room type, pace, and next action at first glance.'],
        ['02', 'Fair Dealing', 'Rules, expectations, and trust cues should appear before friction appears.'],
        ['03', 'Mobile Calm', 'Spacing, contrast, and card rhythm should stay readable during fast blackjack browsing.'],
    ];
    $itemTitle = trim((string)$getConfig("values.value_{$i}_title", $defaults[$i - 1][1]));
    $itemDesc = trim((string)$getConfig("values.value_{$i}_desc", $defaults[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'title' => $itemTitle,
        'description' => $itemDesc,
        'icon' => trim((string)$getConfig("values.value_{$i}_icon", $defaults[$i - 1][0])),
    ];
}

if (empty($values)) {
    $valuesRaw = (string)$getConfig('values.items', "Table Clarity|Players should understand the room type, pace, and next action at first glance.|01\nFair Dealing|Rules, expectations, and trust cues should appear before friction appears.|02\nMobile Calm|Spacing, contrast, and card rhythm should stay readable during fast blackjack browsing.|03");
    if (strpos($valuesRaw, '\\n') !== false && strpos($valuesRaw, "\n") === false) {
        $valuesRaw = str_replace('\\n', "\n", $valuesRaw);
    }
    foreach (preg_split('/[\r\n]+/', $valuesRaw) as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line);
        if (trim($parts[0] ?? '') !== '') {
            $values[] = [
                'title' => trim($parts[0]),
                'description' => trim($parts[1] ?? ''),
                'icon' => trim($parts[2] ?? '01'),
            ];
        }
    }
}

$leadStat = $stats[0] ?? null;
$trailStats = array_slice($stats, 1);
?>

<section id="<?= $componentId ?>" class="bkh-about">
    <div class="about-shell">
        <header class="about-stage">
            <div class="stage-copy">
                <h1><?= htmlspecialchars($title) ?></h1>

                <?php if ($subtitle !== ''): ?>
                    <p class="stage-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>

                <?php if (!empty($stats)): ?>
                    <div class="stage-pulse" aria-label="Halo highlights">
                        <?php foreach (array_slice($stats, 0, 3) as $stat): ?>
                            <span><?= htmlspecialchars($stat['label']) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>

            <div class="story-column">
                <article class="story-panel">
                    <span class="panel-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                    <div class="story-copy">
                        <?php foreach ($storyParagraphs as $paragraph): ?>
                            <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                        <?php endforeach; ?>
                    </div>
                </article>

                <?php if ($showStats && $leadStat): ?>
                    <article class="lead-stat-card">
                        <span class="lead-label"><?= htmlspecialchars($statsHighlightLabel) ?></span>
                        <strong><?= htmlspecialchars($leadStat['value']) ?></strong>
                        <p><?= htmlspecialchars($leadStat['label']) ?></p>
                    </article>
                <?php endif; ?>
            </div>
        </header>

        <?php if ($showStats && !empty($trailStats)): ?>
            <section class="metric-runway" aria-label="Halo metrics">
                <?php foreach ($trailStats as $index => $stat): ?>
                    <article class="metric-card metric-card-<?= (int) $index ?>">
                        <span class="metric-index">0<?= (int) ($index + 2) ?></span>
                        <strong><?= htmlspecialchars($stat['value']) ?></strong>
                        <p><?= htmlspecialchars($stat['label']) ?></p>
                    </article>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage">
                <div class="values-head">
                    <?php if ($valuesKicker !== ''): ?>
                        <span class="panel-kicker"><?= htmlspecialchars($valuesKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-card<?= $index === 0 ? ' is-featured' : '' ?>">
                            <span class="value-icon"><?= htmlspecialchars($value['icon']) ?></span>
                            <div class="value-body">
                                <h3><?= htmlspecialchars($value['title']) ?></h3>
                                <p><?= htmlspecialchars($value['description']) ?></p>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>
    </div>
</section>

