 .footer-download-float {
    position: fixed;
    right: 18px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
    width: min(168px, 24vw);
    aspect-ratio: 320 / 520;
    z-index: 999;
    display: block;
    text-decoration: none;
    pointer-events: auto;
    transform-origin: 75% 100%;
    animation: bkh-float-drift 5.2s ease-in-out infinite;
}

 .footer-download-float img,
 .float-aura {
    position: absolute;
}

 .footer-download-float::before {
    content: '';
    position: absolute;
    left: 18%;
    right: 8%;
    bottom: 4px;
    height: 18px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(9, 20, 17, 0.26) 0%, rgba(9, 20, 17, 0.08) 58%, rgba(9, 20, 17, 0) 78%);
    transform: translateY(100%);
