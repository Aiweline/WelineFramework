$paddingVertical = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_vertical', '20/32') . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float)$getConfig('typography.line_height', '1.65');

$logoText = $getConfig('footer.logo_text', 'Blackjack Halo');
