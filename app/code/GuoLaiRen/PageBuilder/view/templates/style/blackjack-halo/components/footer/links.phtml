], '18+ Only. Play responsibly and check local rules before participating in any gaming-related activity.');
$showFloatingDownload = $normalizeToggle($getConfig('download.show_floating', 'yes')) !== 'no';
$downloadImage = trim((string) $getConfig('download.image', '')) ?: $floatingDownloadDefault;
$downloadAlt = $getConfig('download.alt', 'Download Blackjack Halo');
$downloadPrimaryUrl = trim((string) $getConfig('download.primary_url', ''));
if ($downloadPrimaryUrl === '') {
    $downloadPrimaryUrl = $getConfigAny(['download_button.url', 'header.download_button.url', 'download_btn.url'], '#download');
}
$downloadPrimaryUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($downloadPrimaryUrl);
$downloadResolvedHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$downloadPrimaryUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadResolvedHref, 'footer-floating');

$links = [];
$useCustomLinks = $normalizeToggle($getConfig('content.use_custom_links', 'yes'), 'yes') === 'yes';

if (!$useCustomLinks && $page) {
    $subpages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(20)
        : (method_exists($page, 'getNavigationPages') ? $page->getNavigationPages([], 20) : ($page->getData('subpages') ?: []));
    foreach ($subpages as $subpage) {
        $text = trim((string)($subpage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = (string)($subpage['type'] ?? '');
        $configuredLabel = trim((string)$getConfigAny([
            'content_footer_labels.content.footer_label_' . $type,
            'content.footer_label_' . $type,
        ], ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => $subpage['url'] ?? '#',
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string)$getConfig('content.footer_links', "Home=>/\nTables=>#tables\nWhy Halo=>#advantages\nReviews=>#reviews\nFAQ=>#faq\nSupport=>/contact");

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }

    foreach ($items as $item) {
        $item = trim((string)$item);
        if ($item === '') {
            continue;
        }
        if (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } elseif (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } else {
            continue;
        }
        if (count($parts) >= 2) {
            $links[] = ['text' => $parts[0], 'href' => $parts[1]];
        }
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

