}

 .footer-download-float .float-aura {
    border-radius: 999px;
    pointer-events: none;
}

 .footer-download-float .aura-back {
    inset: 22% 8% 15% 15%;
    background: radial-gradient(circle, rgba(243, 209, 122, 0.36) 0%, rgba(243, 209, 122, 0.14) 44%, rgba(243, 209, 122, 0) 78%);
    filter: blur(16px);
    animation: bkh-float-glow 4.8s ease-in-out infinite;
}

 .footer-download-float .aura-front {
    inset: auto 10% 16% auto;
    width: 42%;
    height: 22%;
    background: radial-gradient(circle, rgba(30, 122, 90, 0.2) 0%, rgba(30, 122, 90, 0) 76%);
    filter: blur(10px);
}

.footer-download-float img {
    inset: 0;
    position: absolute;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 22px 28px rgba(7, 18, 15, 0.22));
    transition: transform 0.24s ease, filter 0.24s ease;
}

 .footer-download-float:hover img {
    transform: translateY(-4px) scale(1.03);
    filter: drop-shadow(0 26px 32px rgba(7, 18, 15, 0.28));
}

@keyframes bkh-footer-streak {
    0% { transform: translateX(0); opacity: 0; }
    10% { opacity: 1; }
    52% { opacity: 1; }
    70% { opacity: 0.28; }
    100% { transform: translateX(150vw); opacity: 0; }
}

@keyframes bkh-float-drift {
    0% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
    100% { transform: translateY(0); }
}

@keyframes bkh-float-glow {
