            <span class="sunrise-spark spark-one"></span>
            <span class="sunrise-spark spark-two"></span>
            <span class="sunrise-spark spark-three"></span>
        </div>
    </div>

    <div class="footer-shell">
        <div class="footer-brand-card">
            <div class="footer-brand-top">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>">
                <div>
                    <strong><?= htmlspecialchars($logoText) ?></strong>
                    <span><?= htmlspecialchars($tagline) ?></span>
                </div>
            </div>
