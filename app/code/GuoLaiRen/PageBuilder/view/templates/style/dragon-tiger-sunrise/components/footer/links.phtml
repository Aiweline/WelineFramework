        <div class="footer-links-area">
            <nav class="footer-nav" aria-label="Footer navigation">
                <?php foreach ($links as $link): ?>
                    <a href="<?= htmlspecialchars($link['href']) ?>"><?= htmlspecialchars($link['text']) ?></a>
                <?php endforeach; ?>
            </nav>

            <div class="footer-social">
                <?php foreach ($socials as $social): ?>
                    <a class="social-link" href="<?= htmlspecialchars($social['href']) ?>"><?= htmlspecialchars($social['label']) ?></a>
                <?php endforeach; ?>
            </div>
        </div>
    </div>

    <div class="footer-base">
        <p class="footer-copyright"><?= htmlspecialchars($copyright) ?></p>
        <p class="footer-disclaimer"><?= htmlspecialchars($disclaimerText) ?></p>
