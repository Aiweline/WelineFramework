 * texts.testimonial_1_name => 评价1姓名:text:Aarav Sinha
 * texts.testimonial_1_tag => 评价1标签:text:Quick Flip Table
 * texts.testimonial_1_rating => 评价1评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_1_content => 评价1内容:textarea:The layout is unexpectedly easy on the eyes. I can read the room fast and still enjoy the look.
 * texts.testimonial_2_name => 评价2姓名:text:Meera Joshi
 * texts.testimonial_2_tag => 评价2标签:text:Everyday Player
 * texts.testimonial_2_rating => 评价2评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_2_content => 评价2内容:textarea:Feels lighter than most game landing pages. Mobile actions are obvious and clean.
 * texts.testimonial_3_name => 评价3姓名:text:Rohan Verma
 * texts.testimonial_3_tag => 评价3标签:text:Golden Room
 * texts.testimonial_3_rating => 评价3评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_3_content => 评价3内容:textarea:The cards do not look recycled. The whole page reads like a proper product, not a template recolor.
 * texts.testimonial_4_name => 评价4姓名:text:Ananya Pillai
 * texts.testimonial_4_tag => 评价4标签:text:Private Lounge
 * texts.testimonial_4_rating => 评价4评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_4_content => 评价4内容:textarea:Strong spacing, bright palette, and still enough energy for gaming traffic. Nicely balanced.
 * texts.testimonial_5_name => 评价5姓名:text:Kabir Rao
 * texts.testimonial_5_tag => 评价5标签:text:Night Session
 * texts.testimonial_5_rating => 评价5评分:text:⭐⭐⭐⭐☆
 * texts.testimonial_5_content => 评价5内容:textarea:The hover details are subtle, but the wall of reviews still feels alive.
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:
 * avatars.avatar_2 => 评价2头像:textarea:
 * avatars.avatar_3 => 评价3头像:textarea:
 * avatars.avatar_4 => 评价4头像:textarea:
 * avatars.avatar_5 => 评价5头像:textarea:
 *
 * @fields_end
 */

$componentId = 'dts-testimonials-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) return;

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';
$showAvg = $getConfig('display.show_avg', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#fff3e4');
$accentColor = $getConfig('style.accent_color', '#f3b53f');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.82)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(242,107,79,0.18)');
$textColor = $getConfig('style.text_color', '#3f2418');
$sectionPadding = $getConfig('style.section_padding', '80');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');

$kicker = $getConfig('texts.kicker', 'Player notes');
$title = $getConfig('texts.title', 'What Players Notice First');
$summary = $getConfig('texts.summary', 'Reviews are arranged like a bright editorial wall, with one featured note and a lighter spread of quick reactions.');
$avgLabel = $getConfig('texts.avg_label', 'Average Rating');
$reviewLabelSingular = $getConfig('texts.review_label_singular', 'visible review');
$reviewLabelPlural = $getConfig('texts.review_label_plural', 'visible reviews');
$spotlightLabel = $getConfig('texts.spotlight_label', 'Spotlight note');

$parseRating = function($raw) {
    $raw = trim((string)$raw);
    if ($raw === '') return 0;
    if (is_numeric($raw)) return (int)$raw;
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaultTestimonials = [
    [
        'name' => 'Aarav Sinha',
        'tag' => 'Quick Flip Table',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'The layout is unexpectedly easy on the eyes. I can read the room fast and still enjoy the look.',
    ],
    [
        'name' => 'Meera Joshi',
        'tag' => 'Everyday Player',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Feels lighter than most game landing pages. Mobile actions are obvious and clean.',
    ],
    [
        'name' => 'Rohan Verma',
        'tag' => 'Golden Room',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'The cards do not look recycled. The whole page reads like a proper product, not a template recolor.',
    ],
    [
        'name' => 'Ananya Pillai',
        'tag' => 'Private Lounge',
        'rating' => '⭐⭐⭐⭐⭐',
        'text' => 'Strong spacing, bright palette, and still enough energy for gaming traffic. Nicely balanced.',
    ],
    [
        'name' => 'Kabir Rao',
        'tag' => 'Night Session',
        'rating' => '⭐⭐⭐⭐☆',
        'text' => 'The hover details are subtle, but the wall of reviews still feels alive.',
    ],
];

$testimonials = [];
for ($i = 1; $i <= 5; $i++) {
    $defaults = $defaultTestimonials[$i - 1] ?? ['name' => '', 'tag' => '', 'rating' => '⭐⭐⭐⭐⭐', 'text' => ''];
    $name = trim((string)$getConfig("texts.testimonial_{$i}_name", $defaults['name']));
    $tag = trim((string)$getConfig("texts.testimonial_{$i}_tag", $defaults['tag']));
    $ratingText = $getConfig("texts.testimonial_{$i}_rating", $defaults['rating']);
    $content = trim((string)$getConfig("texts.testimonial_{$i}_content", $defaults['text']));
    $avatar = trim((string)$getConfig("avatars.avatar_{$i}", ''));

    if ($name !== '' && $content !== '') {
        $ratingValue = max(0, min(5, $parseRating($ratingText)));
        $ratingDisplay = is_numeric($ratingText) ? str_repeat('★', (int)$ratingText) : (string)$ratingText;
        $testimonials[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => $ratingValue,
            'rating_text' => trim($ratingDisplay) !== '' ? $ratingDisplay : str_repeat('★', max(1, $ratingValue)),
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($testimonials)) {
    foreach ($defaultTestimonials as $fallback) {
        $testimonials[] = [
            'name' => $fallback['name'],
            'tag' => $fallback['tag'],
            'rating' => $parseRating($fallback['rating']),
            'rating_text' => $fallback['rating'],
            'text' => $fallback['text'],
            'avatar' => '',
        ];
    }
}

$totalRating = array_sum(array_column($testimonials, 'rating'));
$avgRating = count($testimonials) ? $totalRating / count($testimonials) : 0;
$avgRatingLabel = number_format($avgRating, 1);
$spotlight = $testimonials[0] ?? null;
$cards = array_slice($testimonials, 1);
if (empty($cards) && $spotlight) {
    $cards = [$spotlight];
}

$buildInitials = function($name) {
    $parts = preg_split('/\s+/', trim((string)$name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};
?>

<section id="<?= $componentId ?>" class="dts-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <div class="voices-shell">
        <?php if ($showTitle): ?>
            <header class="voices-header" id="reviews">
                <?php if ($kicker !== ''): ?>
                    <span class="voices-kicker"><?= htmlspecialchars($kicker) ?></span>
                <?php endif; ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php if ($summary !== ''): ?>
                    <p><?= htmlspecialchars($summary) ?></p>
                <?php endif; ?>
            </header>
        <?php endif; ?>

        <div class="voices-layout">
            <aside class="voices-summary">
                <?php if ($showAvg): ?>
                    <div class="summary-rating-card">
                        <span><?= htmlspecialchars($avgLabel) ?></span>
                        <strong><?= htmlspecialchars($avgRatingLabel) ?></strong>
                        <p><?= count($testimonials) ?> <?= htmlspecialchars(count($testimonials) === 1 ? $reviewLabelSingular : $reviewLabelPlural) ?></p>
                    </div>
                <?php endif; ?>

                <?php if ($spotlight): ?>
                    <article class="spotlight-card">
                        <span class="spotlight-kicker"><?= htmlspecialchars($spotlightLabel) ?></span>
                        <blockquote><?= htmlspecialchars($spotlight['text']) ?></blockquote>
                        <footer>
                            <?php if ($showAvatar): ?>
                                <div class="spotlight-avatar">
                                    <?php if (!empty($spotlight['avatar'])): ?>
                                        <img src="<?= htmlspecialchars($spotlight['avatar']) ?>" alt="<?= htmlspecialchars($spotlight['name']) ?>">
                                    <?php else: ?>
                                        <?= htmlspecialchars($buildInitials($spotlight['name'])) ?>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                            <div>
                                <strong><?= htmlspecialchars($spotlight['name']) ?></strong>
                                <?php if ($spotlight['tag'] !== ''): ?>
                                    <span><?= htmlspecialchars($spotlight['tag']) ?></span>
                                <?php endif; ?>
                                <?php if ($showRating): ?>
                                    <small><?= htmlspecialchars($spotlight['rating_text']) ?></small>
                                <?php endif; ?>
                            </div>
                        </footer>
                    </article>
                <?php endif; ?>
            </aside>

            <div class="voices-wall">
                <?php foreach ($cards as $index => $t): ?>
                    <article class="voice-card voice-card-<?= $index % 4 ?>">
                        <div class="voice-card-top">
                            <?php if ($showAvatar): ?>
                                <div class="voice-avatar">
                                    <?php if (!empty($t['avatar'])): ?>
                                        <img src="<?= htmlspecialchars($t['avatar']) ?>" alt="<?= htmlspecialchars($t['name']) ?>">
                                    <?php else: ?>
                                        <?= htmlspecialchars($buildInitials($t['name'])) ?>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                            <div class="voice-meta">
                                <strong><?= htmlspecialchars($t['name']) ?></strong>
                                <?php if ($t['tag'] !== ''): ?>
                                    <span><?= htmlspecialchars($t['tag']) ?></span>
                                <?php endif; ?>
                            </div>
                        </div>

                        <?php if ($showRating): ?>
                            <div class="voice-stars"><?= htmlspecialchars($t['rating_text']) ?></div>
                        <?php endif; ?>

                        <p><?= htmlspecialchars($t['text']) ?></p>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

