$componentId = 'dts-games-' . uniqid();
$gradientId = $componentId . '-arc-gradient';
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeLines = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$parseLegacyGames = static function ($value) use ($normalizeLines) {
    $games = [];
    foreach ($normalizeLines((string) $value) as $line) {
        $parts = array_map('trim', explode('|', $line));
        $title = $parts[0] ?? '';
        if ($title === '') {
            continue;
        }
        $games[] = [
            'title' => $title,
            'description' => $parts[1] ?? '',
            'url' => $parts[2] ?? '#',
        ];
    }
    return $games;
};

$parseLegacyBadgeList = static function ($value) use ($normalizeLines) {
    return $normalizeLines((string) $value);
};

$getLegacyIndexed = static function (array $items, $index, $field, $default = '') {
    return isset($items[$index][$field]) && $items[$index][$field] !== '' ? $items[$index][$field] : $default;
};

$getLegacyToken = static function (array $items, $index, $default = '') {
    return isset($items[$index]) && $items[$index] !== '' ? $items[$index] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', 'yes') !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', '#fffaf4');
$accentColor = $getConfig('style.accent_color', '#efbc57');
$titleColor = $getConfig('style.title_color', '#b5482a');
$subtitleColor = $getConfig('style.subtitle_color', '#6f4b37');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.82)');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.84)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(234,123,93,0.16)');
$cardRadius = (int)$getConfig('style.card_radius', '24');
$sectionPadding = (int)$getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '48');
$cardGap = (int)$getConfig('style.card_gap', '24');

$kicker = $getConfig('texts.kicker', 'Table atlas');
$title = $getConfig('texts.title', 'Choose Your Sunrise Table');
$subtitle = $getConfig('texts.subtitle', 'Every table keeps the same core logic, but the speed, mood, and stakes can shift fast.');
$tagsConfig = $getConfig('texts.tags', 'Quick Flip|Classic Pace|Private Lounge');
$ctaText = trim((string)$getConfig('texts.cta_text', 'Enter table'));
$routeMapLabel = $getConfig('texts.route_map_label', 'Route map');
$routeMapSummary = $getConfig('texts.route_map_summary', 'Follow the sunrise curve, pick a route, then open the right-hand stage for the full room profile.');
$routePrefix = $getConfig('texts.route_prefix', 'Route');
$metaPlayStyleLabel = $getConfig('texts.meta_play_style_label', 'Play style');
$metaPlayStyleNote = $getConfig('texts.meta_play_style_note', 'This route keeps the look bright while giving the table its own surface mood.');
$metaTableFocusLabel = $getConfig('texts.meta_table_focus_label', 'Table focus');
$metaAccessLabel = $getConfig('texts.meta_access_label', 'Access note');
$metaAccessNote = $getConfig('texts.meta_access_note', 'Use the main action to enter the selected route directly.');
if ($ctaText === '') {
    $ctaText = 'Enter table';
}

$tags = array_values(array_filter(array_map('trim', preg_split('/[\r\n\|]+/', $tagsConfig))));
$legacyGames = $parseLegacyGames($getConfigAny(['games.items'], ''));
$legacyBadges = $parseLegacyBadgeList($getConfigAny(['texts.badges'], ''));
$defaultGames = [
    ['badge' => 'Hot Table', 'title' => 'Quick Flip', 'description' => 'Short-format room for rapid back-to-back rounds', 'url' => '#quick'],
    ['badge' => 'Fast Entry', 'title' => 'Classic Table', 'description' => 'Balanced pace with clear rhythm for everyday players', 'url' => '#classic'],
    ['badge' => 'Beginner Friendly', 'title' => 'Golden Room', 'description' => 'Softer visual lobby with premium table styling', 'url' => '#golden'],
    ['badge' => 'High Energy', 'title' => 'Private Lounge', 'description' => 'Invite-only room for friend circles and focused sessions', 'url' => '#private'],
    ['badge' => 'VIP Ready', 'title' => 'Streak Table', 'description' => 'Designed for players chasing fast win runs', 'url' => '#streak'],
    ['badge' => 'Night Mode', 'title' => 'Learn & Play', 'description' => 'A low-pressure room for new users to understand the flow', 'url' => '#learn'],
];

$games = [];
$badges = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaultGames[$i - 1];
    $badge = (string)$getConfigAny([
        'game_' . $i . '.texts.game_' . $i . '_badge',
        'texts.game_' . $i . '_badge',
    ], $getLegacyToken($legacyBadges, $i - 1, $default['badge']));
    $games[] = [
        'name' => (string)$getConfigAny([
            'game_' . $i . '.texts.game_' . $i . '_title',
            'texts.game_' . $i . '_title',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'title', $default['title'])),
        'description' => (string)$getConfigAny([
            'game_' . $i . '.texts.game_' . $i . '_desc',
            'texts.game_' . $i . '_desc',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'description', $default['description'])),
        'link' => (string)$getConfigAny([
            'game_' . $i . '.links.game_' . $i . '_url',
            'links.game_' . $i . '_url',
        ], $getLegacyIndexed($legacyGames, $i - 1, 'url', $default['url'])),
    ];
    $badges[] = $badge;
}

if (empty($games)) {
    return;
}

$defaultTags = ['Quick entry', 'Steady rhythm', 'Private focus'];
$defaultBadges = ['Open Table', 'Active Route', 'Sunrise Pick'];
$tags = !empty($tags) ? $tags : $defaultTags;
$badges = !empty($badges) ? $badges : $defaultBadges;

$gameCount = count($games);
$pathStart = ['x' => 34, 'y' => 92];
$pathControl = ['x' => 6, 'y' => 50];
$pathEnd = ['x' => 34, 'y' => 8];
$selectorPath = sprintf(
    'M %.2F %.2F Q %.2F %.2F %.2F %.2F',
    $pathStart['x'],
    $pathStart['y'],
    $pathControl['x'],
    $pathControl['y'],
    $pathEnd['x'],
    $pathEnd['y']
);

$nodePositions = [];
foreach ($games as $index => $game) {
    $t = $gameCount > 1 ? $index / ($gameCount - 1) : 0.5;
    $oneMinusT = 1 - $t;
    $x = ($oneMinusT * $oneMinusT * $pathStart['x']) + (2 * $oneMinusT * $t * $pathControl['x']) + ($t * $t * $pathEnd['x']);
    $y = ($oneMinusT * $oneMinusT * $pathStart['y']) + (2 * $oneMinusT * $t * $pathControl['y']) + ($t * $t * $pathEnd['y']);
    $nodePositions[$index] = [
        'x' => number_format($x, 2, '.', ''),
        'y' => number_format($y, 2, '.', ''),
    ];
}
?>

<section id="<?= $componentId ?>" class="dts-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head">
            <?php if ($kicker !== ''): ?>
                <span class="games-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showSubtitle): ?>
                <p class="games-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>

            <?php if ($showTags && !empty($tags)): ?>
                <div class="games-tags" aria-label="Table themes">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="atlas-layout">
            <div class="selector-wrap">
                <div class="selector-orbit" role="tablist" aria-label="Sunrise tables">
                    <svg class="selector-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                        <defs>
                            <linearGradient id="<?= htmlspecialchars($gradientId) ?>" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#ea7b5d"/>
                                <stop offset="100%" stop-color="<?= htmlspecialchars($accentColor) ?>"/>
                            </linearGradient>
                        </defs>
                        <path class="orbit-path-shadow" d="<?= htmlspecialchars($selectorPath) ?>"></path>
                        <path class="orbit-path-base" d="<?= htmlspecialchars($selectorPath) ?>"></path>
                        <path class="orbit-path-glow" d="<?= htmlspecialchars($selectorPath) ?>"></path>
                        <circle class="orbit-runner" r="1.8" fill="url(#<?= htmlspecialchars($gradientId) ?>)">
                            <animateMotion dur="<?= max(7, min(12, $gameCount + 4)) ?>s" repeatCount="indefinite" path="<?= htmlspecialchars($selectorPath) ?>" />
                        </circle>
                    </svg>

                    <div class="selector-caption">
                        <?php if ($routeMapLabel !== ''): ?>
                            <span class="selector-caption-kicker"><?= htmlspecialchars($routeMapLabel) ?></span>
                        <?php endif; ?>
                        <strong><?= (int)$gameCount ?> table paths</strong>
                        <?php if ($routeMapSummary !== ''): ?>
                            <p><?= htmlspecialchars($routeMapSummary) ?></p>
                        <?php endif; ?>
                    </div>

                    <?php foreach ($games as $index => $game): ?>
                        <?php
                        $badge = $badges[$index % count($badges)] ?? 'Open Table';
                        $isActive = $index === 0;
                        $position = $nodePositions[$index];
                        ?>
                        <button
                            type="button"
                            class="table-stop<?= $isActive ? ' is-active' : '' ?>"
                            role="tab"
                            id="<?= $componentId ?>-tab-<?= (int)$index ?>"
                            aria-selected="<?= $isActive ? 'true' : 'false' ?>"
                            aria-controls="<?= $componentId ?>-panel-<?= (int)$index ?>"
                            tabindex="<?= $isActive ? '0' : '-1' ?>"
                            data-table-trigger="<?= (int)$index ?>"
                            style="--node-x: <?= htmlspecialchars($position['x']) ?>%; --node-y: <?= htmlspecialchars($position['y']) ?>%;"
                        >
                            <span class="stop-pin"><?= sprintf('%02d', $index + 1) ?></span>
                            <span class="stop-card">
                                <strong><?= htmlspecialchars($game['name']) ?></strong>
                                <small><?= htmlspecialchars($badge) ?></small>
                            </span>
                        </button>
                    <?php endforeach; ?>
                </div>
            </div>

            <div class="games-stage">
                <?php foreach ($games as $index => $game): ?>
                    <?php
                    $badge = $badges[$index % count($badges)] ?? 'Open Table';
                    $tag = $tags[$index % count($tags)] ?? 'Sunrise Mode';
                    $isActive = $index === 0;
                    ?>
                    <article
                        class="table-panel-frame<?= $isActive ? ' is-active' : '' ?>"
                        id="<?= $componentId ?>-panel-<?= (int)$index ?>"
                        role="tabpanel"
                        aria-labelledby="<?= $componentId ?>-tab-<?= (int)$index ?>"
                        data-table-panel="<?= (int)$index ?>"
                        <?= $isActive ? '' : 'hidden' ?>
                    >
                        <div class="table-panel-main">
                            <div class="panel-sun" aria-hidden="true"></div>

                            <div class="panel-topline">
                                <span class="panel-route"><?= htmlspecialchars($routePrefix) ?> <?= sprintf('%02d', $index + 1) ?></span>
                                <span class="panel-badge"><?= htmlspecialchars($badge) ?></span>
                            </div>

                            <div class="panel-copy">
                                <h3><?= htmlspecialchars($game['name']) ?></h3>
                                <p><?= htmlspecialchars($game['description']) ?></p>
                            </div>

                            <div class="panel-actions">
                                <a href="<?= htmlspecialchars($game['link']) ?>" class="panel-link"><?= htmlspecialchars($ctaText) ?></a>
                            </div>
                        </div>

                        <div class="panel-meta-grid">
                            <article class="meta-card">
                                <span class="meta-label"><?= htmlspecialchars($metaPlayStyleLabel) ?></span>
                                <strong><?= htmlspecialchars($tag) ?></strong>
                                <p><?= htmlspecialchars($metaPlayStyleNote) ?></p>
                            </article>

                            <article class="meta-card">
                                <span class="meta-label"><?= htmlspecialchars($metaTableFocusLabel) ?></span>
                                <strong><?= htmlspecialchars($game['name']) ?></strong>
                                <p><?= htmlspecialchars($game['description']) ?></p>
                            </article>

                            <article class="meta-card is-accent">
                                <span class="meta-label"><?= htmlspecialchars($metaAccessLabel) ?></span>
                                <strong><?= htmlspecialchars($badge) ?></strong>
                                <p><?= htmlspecialchars($metaAccessNote) ?></p>
                            </article>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

