<?php
/**
 * Dragon Tiger Sunrise - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: 联系方式和表单展示组件
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.title => 页面标题:text:Contact Dragon Tiger Sunrise
 * hero.subtitle => 页面副标题:textarea:Need help with room access, account questions, or Dragon Tiger support? Use the contact routes below to reach the right desk.
 * hero.bg_color => 背景色:color:#fff7ed
 * hero.bg_gradient_end => 渐变结束色:color:#ffe8d1
 * hero.title_color => 标题颜色:color:#3f2418
 *
 * group:contact_info => 联系信息
 * contact_info.address_label => 地址标签:text:Address
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone_label => 电话标签:text:Phone
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email_label => 邮箱标签:text:Email
 * contact_info.email => 邮箱:text:support@dragontigersunrise.com
 * contact_info.work_hours_label => 工作时间标签:text:Support Hours
 * contact_info.work_hours => 工作时间:text:24/7 Customer Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook链接:text:
 * social.twitter => Twitter链接:text:
 * social.linkedin => LinkedIn链接:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Request
 * form.name_label => 姓名字段标签:text:Full Name
 * form.email_label => 邮箱字段标签:text:Email Address
 * form.subject_label => 主题字段标签:text:Subject
 * form.message_label => 消息字段标签:text:Message
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share your UID, device, and issue details so the support team can route the request faster.
 * form.queue_label => 表单辅助标签:text:Message Queue
 *
 * group:support => 辅助文案
 * support.summary_kicker => 联系摘要标签:text:Support Center
 * support.summary_text => 联系摘要说明:textarea:Use the fastest route for gameplay help, payment questions, partnership requests, or account support.
 * support.social_title => 社交区域标题:text:Social Links
 *
 * group:map => 地图设置
 * map.title => 地图标题:text:Location map
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$componentId = 'dts-contact-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($styleSettings, $componentConfig) {
    if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
        return $styleSettings[$key];
    }
    return $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$title = trim((string) $getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'Contact Dragon Tiger Sunrise';
}
$description = trim((string) $getConfig('hero.subtitle', 'Need help with room access, account questions, or Dragon Tiger support? Use the contact routes below to reach the right desk.'));

$addressLabel = trim((string) $getConfig('contact_info.address_label', 'Address'));
$phoneLabel = trim((string) $getConfig('contact_info.phone_label', 'Phone'));
$emailLabel = trim((string) $getConfig('contact_info.email_label', 'Email'));
$workHoursLabel = trim((string) $getConfig('contact_info.work_hours_label', 'Support Hours'));
$email = trim((string) $getConfig('contact_info.email', 'support@dragontigersunrise.com'));
$phone = trim((string) $getConfig('contact_info.phone', '+91 1800-XXX-XXXX'));
$address = trim((string) $getConfig('contact_info.address', 'Mumbai, India'));
$hours = trim((string) $getConfig('contact_info.work_hours', '24/7 Customer Support'));

$formTitle = trim((string) $getConfig('form.title', 'Send A Support Request'));
$formNameLabel = trim((string) $getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string) $getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string) $getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string) $getConfig('form.message_label', 'Message'));
$formSubmitText = trim((string) $getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string) $getConfig('form.success_message', 'Share your UID, device, and issue details so the support team can route the request faster.'));
$formQueueLabel = trim((string) $getConfig('form.queue_label', 'Message Queue'));
$supportSummaryKicker = trim((string) $getConfig('support.summary_kicker', 'Support Center'));
$supportSummaryText = trim((string) $getConfig('support.summary_text', 'Use the fastest route for gameplay help, payment questions, partnership requests, or account support.'));
$supportSocialTitle = trim((string) $getConfig('support.social_title', 'Social Links'));
$mapTitle = trim((string) $getConfig('map.title', 'Location map'));
$mapEmbedUrl = trim((string) $getConfig('map.embed_url', ''));
$mapHeight = max(240, (int) $getConfig('map.height', 360));

$contactCards = [];
if ($email !== '') {
    $contactCards[] = ['label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email, 'icon' => 'EM', 'href' => 'mailto:' . $email];
}
if ($phone !== '') {
    $contactCards[] = ['label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone, 'icon' => 'PH', 'href' => 'tel:' . preg_replace('/[^0-9+]/', '', $phone)];
}
if ($address !== '') {
    $contactCards[] = ['label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address, 'icon' => 'AD', 'href' => ''];
}
if ($hours !== '') {
    $contactCards[] = ['label' => $workHoursLabel !== '' ? $workHoursLabel : 'Support Hours', 'value' => $hours, 'icon' => '24', 'href' => ''];
}

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string) $getConfig($key, ''));
    if ($url === '') {
        continue;
    }
    $socials[] = ['name' => $label, 'url' => $url];
}

$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#fff7ed');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe8d1');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#3f2418');
$cardBg = (string) ($colors['card_bg'] ?? 'rgba(255,250,244,0.92)');
$cardBorder = (string) ($colors['border_light'] ?? 'rgba(122,161,192,0.22)');
$accentPrimary = (string) ($colors['accent_primary'] ?? '#f26b4f');
$accentSecondary = (string) ($colors['accent_secondary'] ?? '#f3b53f');
$buttonBg = (string) ($colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f3b53f 0%, #d95438 100%)');
$buttonText = (string) ($colors['button_primary_text'] ?? '#fff7ed');
?>

<section
    id="<?= $componentId ?>"
    class="dts-contact"
    style="--dts-contact-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-card-bg: <?= htmlspecialchars($cardBg, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-card-border: <?= htmlspecialchars($cardBorder, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-accent-primary: <?= htmlspecialchars($accentPrimary, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-accent-secondary: <?= htmlspecialchars($accentSecondary, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-button-bg: <?= htmlspecialchars($buttonBg, ENT_QUOTES, 'UTF-8') ?>; --dts-contact-button-text: <?= htmlspecialchars($buttonText, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="contact-shell">
        <header class="contact-hero">
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <div class="contact-layout<?= !$showForm ? ' no-form' : '' ?><?= !$showInfo ? ' no-info' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="support-rail">
                    <article class="support-summary">
                        <?php if ($supportSummaryKicker !== ''): ?>
                            <span class="summary-kicker"><?= htmlspecialchars($supportSummaryKicker) ?></span>
                        <?php endif; ?>
                        <?php if ($hours !== ''): ?>
                            <h2><?= htmlspecialchars($hours) ?></h2>
                        <?php endif; ?>
                        <?php if ($pageContent !== ''): ?>
                            <div class="support-note"><?= $pageContent ?></div>
                        <?php elseif ($supportSummaryText !== ''): ?>
                            <p><?= htmlspecialchars($supportSummaryText) ?></p>
                        <?php endif; ?>
                    </article>

                    <?php if (!empty($contactCards)): ?>
                        <div class="channel-grid">
                            <?php foreach ($contactCards as $channel): ?>
                                <?php if ($channel['href'] !== ''): ?>
                                    <a href="<?= htmlspecialchars($channel['href']) ?>" class="channel-card">
                                        <div class="channel-mark"><?= htmlspecialchars($channel['icon']) ?></div>
                                        <span class="channel-label"><?= htmlspecialchars($channel['label']) ?></span>
                                        <strong><?= htmlspecialchars($channel['value']) ?></strong>
                                    </a>
                                <?php else: ?>
                                    <div class="channel-card">
                                        <div class="channel-mark"><?= htmlspecialchars($channel['icon']) ?></div>
                                        <span class="channel-label"><?= htmlspecialchars($channel['label']) ?></span>
                                        <strong><?= htmlspecialchars($channel['value']) ?></strong>
                                    </div>
                                <?php endif; ?>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <?php if ($showSocial && !empty($socials)): ?>
                        <div class="social-panel">
                            <?php if ($supportSocialTitle !== ''): ?>
                                <span class="social-title"><?= htmlspecialchars($supportSocialTitle) ?></span>
                            <?php endif; ?>
                            <div class="social-links">
                                <?php foreach ($socials as $social): ?>
                                    <a href="<?= htmlspecialchars($social['url']) ?>" class="social-link" target="_blank" rel="noopener" title="<?= htmlspecialchars($social['name']) ?>">
                                        <span><?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?></span>
                                        <small><?= htmlspecialchars($social['name']) ?></small>
                                    </a>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <div class="message-dock">
                    <div class="dock-head">
                        <?php if ($formQueueLabel !== ''): ?>
                            <span class="dock-kicker"><?= htmlspecialchars($formQueueLabel) ?></span>
                        <?php endif; ?>
                        <?php if ($formTitle !== ''): ?>
                            <h2><?= htmlspecialchars($formTitle) ?></h2>
                        <?php endif; ?>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </div>

                    <form class="contact-form">
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formNameLabel !== '' ? $formNameLabel : 'Full Name') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formNameLabel !== '' ? $formNameLabel : 'Full Name') ?>">
                        </div>
                        <div class="field field-half">
                            <label><?= htmlspecialchars($formEmailLabel !== '' ? $formEmailLabel : 'Email Address') ?></label>
                            <input type="email" placeholder="<?= htmlspecialchars($formEmailLabel !== '' ? $formEmailLabel : 'Email Address') ?>">
                        </div>
                        <div class="field">
                            <label><?= htmlspecialchars($formSubjectLabel !== '' ? $formSubjectLabel : 'Subject') ?></label>
                            <input type="text" placeholder="<?= htmlspecialchars($formSubjectLabel !== '' ? $formSubjectLabel : 'Subject') ?>">
                        </div>
                        <div class="field">
                            <label><?= htmlspecialchars($formMessageLabel !== '' ? $formMessageLabel : 'Message') ?></label>
                            <textarea placeholder="<?= htmlspecialchars($formMessageLabel !== '' ? $formMessageLabel : 'Message') ?>"></textarea>
                        </div>
                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </div>
            <?php endif; ?>
        </div>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="map-stage" aria-label="<?= htmlspecialchars($mapTitle !== '' ? $mapTitle : 'Location map') ?>">
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int) $mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

