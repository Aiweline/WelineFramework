    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
}

#<?= $componentId ?> .legal-layout.has-toc {
    grid-template-columns: minmax(240px, 0.32fr) minmax(0, 0.68fr);
}

#<?= $componentId ?> .toc-card,
#<?= $componentId ?> .legal-article {
    border-radius: 24px;
    border: 1px solid var(--dts-legal-toc-border);
    box-shadow: 0 22px 52px rgba(194, 130, 94, 0.14);
}

#<?= $componentId ?> .legal-toc {
    position: sticky;
    top: 110px;
}

#<?= $componentId ?> .toc-card {
    padding: 1.15rem;
    background: linear-gradient(160deg, var(--dts-legal-toc-bg) 0%, rgba(255, 239, 224, 0.88) 100%);
}

#<?= $componentId ?> .toc-title {
    display: block;
    color: #8f725f;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

#<?= $componentId ?> .toc-links {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.4rem;
}

#<?= $componentId ?> .toc-link {
    color: rgba(111, 75, 55, 0.78);
    text-decoration: none;
    line-height: 1.55;
    padding: 0.45rem 0.55rem;
    border-radius: 12px;
}

#<?= $componentId ?> .toc-link.level-3 {
    margin-left: 0.85rem;
    font-size: 0.92rem;
}

#<?= $componentId ?> .legal-article {
    padding: var(--dts-legal-content-padding);
    background: linear-gradient(160deg, var(--dts-legal-content-bg) 0%, rgba(255, 246, 236, 0.94) 100%);
}

#<?= $componentId ?> .legal-article.no-toc {
    max-width: var(--dts-legal-max-width);
    margin: 0 auto;
    width: 100%;
}

#<?= $componentId ?> .legal-content {
    color: var(--dts-legal-content-text);
    line-height: 1.85;
    font-size: 1rem;
}

#<?= $componentId ?> .legal-content h2,
#<?= $componentId ?> .legal-content h3 {
    scroll-margin-top: 120px;
    color: var(--dts-legal-heading);
}

#<?= $componentId ?> .legal-content h2 {
    margin: 2rem 0 0.9rem;
    font-size: 1.55rem;
    line-height: 1.2;
}

#<?= $componentId ?> .legal-content h3 {
    margin: 1.6rem 0 0.7rem;
    font-size: 1.2rem;
}

#<?= $componentId ?> .legal-content a {
    color: var(--dts-legal-link);
}

#<?= $componentId ?> .legal-content p,
#<?= $componentId ?> .legal-content ul,
#<?= $componentId ?> .legal-content ol,
#<?= $componentId ?> .legal-content table,
#<?= $componentId ?> .legal-content blockquote {
    margin-top: 1rem;
}

@media (max-width: 980px) {
    #<?= $componentId ?> .legal-layout.has-toc {
        grid-template-columns: 1fr;
    }

    #<?= $componentId ?> .legal-toc {
        position: static;
    }
}

@media (max-width: 768px) {
    #<?= $componentId ?> {
        padding: 72px 0;
    }

    #<?= $componentId ?> .legal-shell {
        width: calc(100% - 1rem);
    }

    #<?= $componentId ?> .toc-card,
    #<?= $componentId ?> .legal-article {
        border-radius: 20px;
    }

    #<?= $componentId ?> .legal-article {
        padding: 1.2rem;
    }
}
</style>
