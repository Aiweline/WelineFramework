 * values.title => 标题:text:What The Theme Prioritizes
 * values.subtitle => 副标题:text:Three editable pillars keep the about page useful when creating new Dragon Tiger sites.
 * values.value_1_icon => 价值1图标:text:☀️
 * values.value_1_title => 价值1标题:text:Clear Reading
 * values.value_1_desc => 价值1描述:textarea:Use stronger hierarchy so players can understand trust signals, page purpose, and next actions faster.
 * values.value_2_icon => 价值2图标:text:🔥
 * values.value_2_title => 价值2标题:text:Warm Motion
 * values.value_2_desc => 价值2描述:textarea:Keep the layout lively without sacrificing responsive stability on mobile screens.
 * values.value_3_icon => 价值3图标:text:🃏
 * values.value_3_title => 价值3标题:text:Game Relevance
 * values.value_3_desc => 价值3描述:textarea:Default copy stays tied to Dragon Tiger instead of generic marketing text that editors cannot reuse.
 * values.bg_color => 背景色:color:#fff1e1
 *
 * group:team => 团队区块
 * team.title => 标题:text:Theme Roles
 * team.subtitle => 副标题:text:Reusable profile cards for the teams behind operations, trust, content, and product updates.
 * team.member_1_icon => 成员1头像:text:🛎️
 * team.member_1_name => 成员1姓名:text:Support Desk
 * team.member_1_role => 成员1职位:text:Player issue routing
 * team.member_2_icon => 成员2头像:text:🛡️
 * team.member_2_name => 成员2姓名:text:Trust Review
 * team.member_2_role => 成员2职位:text:Policy and fairness review
 * team.member_3_icon => 成员3头像:text:🌅
 * team.member_3_name => 成员3姓名:text:Theme Product
 * team.member_3_role => 成员3职位:text:Dragon Tiger page flow design
 * team.member_4_icon => 成员4头像:text:✍️
 * team.member_4_name => 成员4姓名:text:Content Ops
 * team.member_4_role => 成员4职位:text:Guide and landing copy updates
 *
 * group:cta => 底部CTA
 * cta.title => CTA标题:text:Need a custom about page flow?
 * cta.description => CTA描述:textarea:Use the editable title, story, values, team, and CTA fields to adapt this page for each new Dragon Tiger site.
 * cta.button_text => 按钮文字:text:Contact Support
 * cta.button_url => 按钮链接:text:/contact
 * cta.button_bg => 按钮背景:color:linear-gradient(135deg, #f3b53f 0%, #d95438 100%)
 * cta.button_text_color => 按钮文字颜色:color:#fff7ed
 *
 * @fields_end
 */

$componentId = 'dts-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'yes') !== 'no';
$showCta = $getConfig('display.show_cta', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$heroTitle = trim((string) $getConfig('hero.title', $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'About Dragon Tiger Sunrise';
}
$heroSubtitle = trim((string) $getConfig('hero.subtitle', 'A brighter Dragon Tiger landing flow with faster table reading, clearer trust cues, and a warmer mobile-first rhythm.'));
$heroPadding = max(52, (int) $getConfig('hero.padding', 88));

$storyTitle = trim((string) $getConfig('story.title', 'Why This Theme Exists'));
$storySubtitle = trim((string) $getConfig('story.subtitle', 'Designed to keep Dragon Tiger pages warm, fast, and easier to scan on every device.'));
$storyContent = trim((string) $getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Dragon Tiger Sunrise keeps the original PHP structure and data rules from tpmst while giving the theme a lighter visual system, softer contrast, and clearer section pacing.';
}
$storyParagraphs = preg_split('/[\r\n]+/', $storyContent);
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs)) {
    $storyParagraphs = [$storyContent];
}

$stats = [];
$defaultStats = [
    ['24/7', 'Support coverage'],
    ['1-tap', 'Room entry path'],
    ['3-layer', 'Sunrise contrast system'],
    ['Mobile', 'Responsive table flow'],
];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $defaultStats[$i - 1][0]));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $defaultStats[$i - 1][1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'number' => $number,
        'label' => $label,
    ];
}

$valuesTitle = trim((string) $getConfig('values.title', 'What The Theme Prioritizes'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'Three editable pillars keep the about page useful when creating new Dragon Tiger sites.'));
$defaultValues = [
    ['☀️', 'Clear Reading', 'Use stronger hierarchy so players can understand trust signals, page purpose, and next actions faster.'],
    ['🔥', 'Warm Motion', 'Keep the layout lively without sacrificing responsive stability on mobile screens.'],
    ['🃏', 'Game Relevance', 'Default copy stays tied to Dragon Tiger instead of generic marketing text that editors cannot reuse.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $title = trim((string) $getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $desc = trim((string) $getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($title === '' && $desc === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string) $getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
        'title' => $title,
        'description' => $desc,
    ];
}

$teamTitle = trim((string) $getConfig('team.title', 'Theme Roles'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', 'Reusable profile cards for the teams behind operations, trust, content, and product updates.'));
$defaultMembers = [
    ['🛎️', 'Support Desk', 'Player issue routing'],
    ['🛡️', 'Trust Review', 'Policy and fairness review'],
    ['🌅', 'Theme Product', 'Dragon Tiger page flow design'],
    ['✍️', 'Content Ops', 'Guide and landing copy updates'],
];
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $name = trim((string) $getConfig("team.member_{$i}_name", $defaultMembers[$i - 1][1]));
    $role = trim((string) $getConfig("team.member_{$i}_role", $defaultMembers[$i - 1][2]));
    if ($name === '' && $role === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => trim((string) $getConfig("team.member_{$i}_icon", $defaultMembers[$i - 1][0])),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string) $getConfig('cta.title', 'Need a custom about page flow?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Use the editable title, story, values, team, and CTA fields to adapt this page for each new Dragon Tiger site.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact'));

$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#fff7ed');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe8d1');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#3f2418');
$heroTextColor = (string) $getConfig('hero.text_color', $colors['text_secondary'] ?? '#6f4b37');
$storyBg = (string) $getConfig('story.bg_color', $colors['section_bg_2'] ?? '#fff4e6');
$storyTitleColor = (string) $getConfig('story.title_color', $colors['accent_secondary'] ?? '#b5482a');
$valuesBg = (string) $getConfig('values.bg_color', $colors['section_bg_3'] ?? '#fff1e1');
$statsCardBg = (string) $getConfig('stats.card_bg', $colors['card_bg'] ?? 'rgba(255,250,244,0.9)');
$statsNumberColor = (string) $getConfig('stats.number_color', $colors['accent_primary'] ?? '#f3b53f');
$statsLabelColor = (string) $getConfig('stats.label_color', $colors['text_muted'] ?? '#8f725f');
$statsLeadLabel = trim((string) $getConfig('stats.lead_label', 'Sunrise Snapshot'));
$ctaButtonBg = (string) $getConfig('cta.button_bg', $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #f3b53f 0%, #d95438 100%)');
$ctaButtonTextColor = (string) $getConfig('cta.button_text_color', $colors['button_primary_text'] ?? '#fff7ed');
?>

<section
    id="<?= $componentId ?>"
    class="dts-about"
    style="--dts-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --dts-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --dts-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --dts-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --dts-about-stats-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --dts-about-stat-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-stat-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --dts-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --dts-about-hero-padding: <?= (int) $heroPadding ?>px;"
>
    <div class="about-shell">
        <header class="about-hero">
            <div class="hero-copy">
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <?php if ($heroSubtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($heroSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="story-panel">
                <?php if ($storyTitle !== ''): ?>
                    <span class="story-kicker"><?= htmlspecialchars($storyTitle) ?></span>
                <?php endif; ?>
                <?php if ($storySubtitle !== ''): ?>
                    <h2><?= htmlspecialchars($storySubtitle) ?></h2>
                <?php endif; ?>
                <?php foreach ($storyParagraphs as $paragraph): ?>
                    <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                <?php endforeach; ?>
            </div>
        </header>

        <?php if ($showStats && !empty($stats)): ?>
            <section class="stats-belt" aria-label="Brand statistics">
                <?php $leadStat = $stats[0] ?? null; ?>
                <?php $trailStats = array_slice($stats, 1); ?>

                <?php if ($leadStat): ?>
                    <article class="lead-stat">
                        <?php if ($statsLeadLabel !== ''): ?>
                            <span class="stat-overline"><?= htmlspecialchars($statsLeadLabel) ?></span>
                        <?php endif; ?>
                        <strong><?= htmlspecialchars($leadStat['number']) ?></strong>
                        <span class="stat-caption"><?= htmlspecialchars($leadStat['label']) ?></span>
                    </article>
                <?php endif; ?>

                <?php if (!empty($trailStats)): ?>
                    <div class="stat-grid">
                        <?php foreach ($trailStats as $stat): ?>
                            <article class="stat-card">
                                <strong><?= htmlspecialchars($stat['number']) ?></strong>
                                <span><?= htmlspecialchars($stat['label']) ?></span>
                            </article>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-stage">
                <div class="values-header">
                    <?php if ($valuesTitle !== ''): ?>
                        <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="values-grid">
                    <?php foreach ($values as $index => $value): ?>
                        <?php $cardClass = $index === 0 ? ' is-featured' : (($index % 3 === 2) ? ' is-tall' : ''); ?>
                        <article class="value-card<?= $cardClass ?>">
                            <div class="value-mark"><?= htmlspecialchars($value['icon']) ?></div>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <p><?= htmlspecialchars($value['description']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showTeam && !empty($teamMembers)): ?>
            <section class="team-stage">
                <div class="team-header">
                    <?php if ($teamTitle !== ''): ?>
                        <h2><?= htmlspecialchars($teamTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="team-grid">
                    <?php foreach ($teamMembers as $member): ?>
                        <article class="team-card">
                            <span class="team-icon"><?= htmlspecialchars($member['icon']) ?></span>
                            <h3><?= htmlspecialchars($member['name']) ?></h3>
                            <p><?= htmlspecialchars($member['role']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
            <section class="cta-band">
                <div class="cta-copy">
                    <?php if ($ctaTitle !== ''): ?>
                        <h2><?= htmlspecialchars($ctaTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription) ?></p>
                    <?php endif; ?>
                </div>
                <?php if ($ctaButtonText !== ''): ?>
                    <a href="<?= htmlspecialchars($ctaButtonUrl) ?>" class="cta-link"><?= htmlspecialchars($ctaButtonText) ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>

