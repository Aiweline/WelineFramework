    [
        'icon' => $getConfig('texts.advantage_3_icon', '🛡️'),
        'title' => $getConfig('texts.advantage_3_title', 'Confident Table Flow'),
        'desc' => $getConfig('texts.advantage_3_desc', 'Rules, trust points, and important actions are surfaced without clutter.'),
