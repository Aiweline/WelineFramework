                            <span><?= htmlspecialchars($metric['label']) ?></span>
                            <strong><?= htmlspecialchars($metric['value']) ?></strong>
                        </div>
                    <?php endforeach; ?>
                </div>
            </article>

            <div class="adv-right-column">
                <?php foreach ($secondary as $index => $item): ?>
                    <article class="adv-card">
                        <div class="adv-card-top">
                            <span class="adv-count"><?= sprintf('%02d', $index + 2) ?></span>
