                <?php endif; ?>
                <div class="feature-mark"><?= htmlspecialchars($primary['icon']) ?></div>
                <h3><?= htmlspecialchars($primary['title']) ?></h3>
                <p><?= htmlspecialchars($primary['desc']) ?></p>

                <div class="feature-metrics">
                    <?php foreach ($benefitMetrics as $metric): ?>
