<?php
/**
 * Dragon Tiger Sunrise - Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航栏
 * name_en: Navigation Bar
 * description: 晨曦风格玻璃导航，支持移动端菜单与流光效果
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:Dragon Tiger Sunrise
 * logo.subline => Logo副标题:text:Light-table edition
 * logo.url => Logo图片URL:textarea:|留空使用默认图标
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.items => 导航项:textarea:Home=>/\r\nTables=>#tables\r\nWhy Us=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|格式：文本=>链接
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * group:download_button => 下载按钮
 * download_button.text => 下载按钮文本:text:Play Bright
 * download_button.url => 下载链接:text:#download
 * @fields_end
 */

$componentId = 'dts-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }
    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }
    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeToggle = static function($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$sanitizeTitle = function($value) {
    $value = trim((string)$value);
    if ($value === '') return $value;
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text'], 'Dragon Tiger Sunrise'));
if ($logoText === '') {
    $logoText = 'Dragon Tiger Sunrise';
}
$logoSubline = trim((string)$getConfigAny(['logo.subline', 'header.logo.subline'], 'Light-table edition'));
if ($logoSubline === '') {
    $logoSubline = 'Light-table edition';
}
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/sunrise-logo-icon.svg');
$logoUrl = $getConfigAny(['logo.url', 'header.logo.url'], '') ?: ($page && $page->getData('logo') ? $page->getData('logo') : $logoIconUrl);

$navItemsConfig = (string) $getConfigAny([
    'navigation.items',
    'header.navigation.items',
    'navigation_labels.navigation.items',
], "Home=>/\nTables=>#tables\nWhy Us=>#advantages\nReviews=>#reviews\nFAQ=>#faq");
$useCustomLinks = $normalizeToggle($getConfigAny([
    'navigation.use_custom_links',
    'header.navigation.use_custom_links',
    'navigation_labels.navigation.use_custom_links',
], 'yes')) === 'yes';
$ctaText = trim((string) $getConfigAny([
    'download_button.text',
    'header.download_button.text',
    'navigation.cta_text',
    'header.navigation.cta_text',
    'navigation_labels.navigation.cta_text',
], 'Play Bright'));
if ($ctaText === '') {
    $ctaText = 'Play Bright';
}
$ctaUrl = (string) $getConfigAny([
    'download_button.url',
    'header.download_button.url',
    'navigation.cta_url',
    'header.navigation.cta_url',
    'navigation_labels.navigation.cta_url',
], '#download');
$ctaUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($ctaUrl);
$navBgUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/nav-bg.svg');
$bodyBgUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/poker-header-bg.svg');
$navItems = [];

$pageTitleRaw = $page ? ($page->getData('title') ?: '') : '';
$pageTitle = $sanitizeTitle($pageTitleRaw);
if ($pageTitle === '') {
    $pageTitle = 'Dragon Tiger Sunrise';
}

if (!$useCustomLinks && $page) {
    $navigationPages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $navigationPages = $page->getHeaderNavigationPages(10);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $navigationPages = $page->getNavigationPages([], 10);
    }
    foreach ($navigationPages as $navPage) {
        $pageType = trim((string)($navPage['type'] ?? ''));
        $label = $pageType !== '' ? trim((string)$getConfigAny([
            'navigation.label_' . $pageType,
            'header.navigation.label_' . $pageType,
            'navigation_labels.navigation.label_' . $pageType,
        ], '')) : '';
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
            'type' => $navPage['type'] ?? '',
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim($line);
        if ($line === '' || strpos($line, '=>') === false) continue;
        [$text, $href] = array_map('trim', explode('=>', $line, 2));
        if ($text !== '') {
            $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
        }
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}
