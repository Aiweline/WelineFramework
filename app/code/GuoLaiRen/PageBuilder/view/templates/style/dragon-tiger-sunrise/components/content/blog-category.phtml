<?php
/**
 * Dragon Tiger Sunrise Blog Category Component
 *
 * @fields_start
 * blog.title|分类标题|text|Category Posts
 * blog.subtitle|副标题|text|Browse articles by category
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=特色|default
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', $currentCategory['name'] ?? __('Category Posts'));
$subtitle = $getConfig('blog.subtitle', __('Browse articles by category'));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';

$primaryColor = $getConfig('color_scheme.primary', '#f26b4f');
$secondaryColor = $getConfig('color_scheme.secondary', '#f3b53f');
$bgColor = $getConfig('color_scheme.background', '#fff7ed');
$textColor = $getConfig('color_scheme.text', '#3f2418');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/poker-header-bg.svg');

$spotlightPost = $blogPosts[0] ?? null;
$streamPosts = array_slice($blogPosts, 1);
?>

<section class="dts-blog-category" id="blog-category">
    <div class="category-shell">
        <header class="category-masthead">
            <?php if (!empty($currentCategory['name'])): ?>
                <span class="category-chip"><?= htmlspecialchars($currentCategory['name']) ?></span>
            <?php endif; ?>
            <h2><?= htmlspecialchars($title) ?></h2>
            <?php if ($subtitle): ?>
                <p class="category-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if (!empty($currentCategory['description'])): ?>
                <p class="category-description"><?= htmlspecialchars($currentCategory['description']) ?></p>
            <?php endif; ?>
        </header>

        <?php if (empty($blogPosts)): ?>
            <div class="category-empty">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <p><?= __('No posts are available in this category yet. Please check back soon.') ?></p>
                <a href="/blog" class="back-link"><?= __('Back to blog list') ?></a>
            </div>
        <?php else: ?>
            <?php if ($spotlightPost): ?>
                <article class="spotlight-story">
                    <div class="spotlight-copy">
                        <span class="spotlight-kicker">Category Lead</span>
                        <h3>
                            <a href="<?= htmlspecialchars($spotlightPost['url']) ?>"><?= htmlspecialchars($spotlightPost['title']) ?></a>
                        </h3>
                        <div class="spotlight-meta">
                            <?php if ($showCategory && !empty($spotlightPost['category_name'])): ?>
                                <span><?= htmlspecialchars($spotlightPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($spotlightPost['published_at'])): ?>
                                <span><?= date('M d, Y', strtotime($spotlightPost['published_at'])) ?></span>
                            <?php endif; ?>
                            <?php if ($showAuthor && !empty($spotlightPost['author'])): ?>
                                <span><?= htmlspecialchars($spotlightPost['author']) ?></span>
                            <?php endif; ?>
                        </div>
                        <?php if (!empty($spotlightPost['summary'])): ?>
                            <p><?= htmlspecialchars(mb_substr($spotlightPost['summary'], 0, 220)) ?><?= mb_strlen($spotlightPost['summary']) > 220 ? '...' : '' ?></p>
                        <?php endif; ?>
                        <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="story-action">
                            <?= __('Read Article') ?>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                            </svg>
                        </a>
                    </div>

                    <?php if (!empty($spotlightPost['cover_image'])): ?>
                        <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="spotlight-media">
                            <img src="<?= htmlspecialchars($spotlightPost['cover_image']) ?>" alt="<?= htmlspecialchars($spotlightPost['title']) ?>" loading="lazy">
                        </a>
                    <?php endif; ?>
                </article>
            <?php endif; ?>

            <div class="category-stream<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="stream-list">
                    <?php foreach ($streamPosts as $post): ?>
                        <article class="stream-card">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="stream-media">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>

                            <div class="stream-copy">
                                <div class="stream-meta">
                                    <?php if ($showCategory && !empty($post['category_name'])): ?>
                                        <span class="stream-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($post['published_at'])): ?>
                                        <span class="stream-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>

                                <?php if (!empty($post['summary'])): ?>
                                    <p><?= htmlspecialchars(mb_substr($post['summary'], 0, 170)) ?><?= mb_strlen($post['summary']) > 170 ? '...' : '' ?></p>
                                <?php endif; ?>

                                <div class="stream-foot">
                                    <?php if ($showAuthor && !empty($post['author'])): ?>
                                        <span class="stream-author"><?= htmlspecialchars($post['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($post['url']) ?>" class="story-action">
                                        <?= __('Read More') ?>
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="stream-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card">
                                <h4><?= __('Categories') ?></h4>
                                <div class="category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php $active = !empty($currentCategory['id']) && isset($category['id']) && $category['id'] == $currentCategory['id']; ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-entry<?= $active ? ' is-active' : '' ?>">
                                            <span><?= htmlspecialchars($category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <small><?= (int)$category['post_count'] ?></small>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card">
                                <h4><?= __('Recent Posts') ?></h4>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 5) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

