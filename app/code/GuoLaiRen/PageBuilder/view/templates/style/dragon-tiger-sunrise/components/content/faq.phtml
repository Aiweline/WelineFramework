<?php
/**
 * @component_start
 * code: faq
 * name: 常见问题
 * name_en: FAQ
 * description: FAQ折叠面板
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_intro => 显示简介:select:yes|yes,no
 * display.first_open => 首个问题默认展开:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景主色:color:#fff0dc
 * style.accent_color => 强调色:color:#f3b53f
 * style.title_color => 标题颜色:color:#3f2418
 * style.text_color => 正文颜色:color:#6f4b37
 * style.panel_bg_color => 卡片背景色:color:rgba(255,255,255,0.88)
 * style.card_border_color => 卡片边框色:color:rgba(242,107,79,0.18)
 * style.card_radius => 卡片圆角:number:22|px
 * style.section_padding => 区域内边距(PC端):number:64|px
 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 *
 * group:texts => 文本内容
 * texts.badge => 徽标文字:text:Sunrise Support
 * texts.title => 区域标题:text:Frequently Asked Questions
 * texts.intro => 简介:textarea:Everything important is kept visible: table pace, trust notes, and the quick answers players usually look for first.
 * texts.tag_1 => 标签1:text:Quick Rooms
 * texts.tag_2 => 标签2:text:Table Trust
 * texts.tag_3 => 标签3:text:Mobile Readability
 * texts.timeline_kicker => 时间线标签:text:Questions Timeline
 * texts.timeline_summary => 时间线说明:textarea:Tap any stop to expand the answer right inside the timeline.
 * texts.expand_hint => 展开提示:text:Tap to read answer
 * texts.collapse_hint => 收起提示:text:Tap to collapse
 * texts.expand_text => 展开按钮文字:text:Expand
 * texts.close_text => 收起按钮文字:text:Close
 * texts.answer_kicker => 答案标签:text:FAQ Answer
 * texts.question_prefix => 问题前缀:text:Question
 * texts.faq_1_question => 问题1:text:What makes this theme different from darker gaming templates?
 * texts.faq_1_answer => 答案1:textarea:It uses a light editorial layout, softer contrast, and new section structures while keeping the same PHP-driven configuration patterns.
 * texts.faq_2_question => 问题2:text:Can the default content still be overridden from config?
 * texts.faq_2_answer => 答案2:textarea:Yes. Titles, intro text, questions, answers, and display switches all still follow the same config fallback rules.
 * texts.faq_3_question => 问题3:text:Is the layout responsive on mobile first?
 * texts.faq_3_answer => 答案3:textarea:Yes. Cards collapse into a single column, sticky summary content resets properly, and tap targets stay large.
 * texts.faq_4_question => 问题4:text:Can I hide part of this section without editing code?
 * texts.faq_4_answer => 答案4:textarea:Yes. Badge, title, intro, and the first-open behavior can all be controlled by the existing component settings.
 * texts.faq_5_question => 问题5:text:
 * texts.faq_5_answer => 答案5:textarea:
 * texts.faq_6_question => 问题6:text:
 * texts.faq_6_answer => 答案6:textarea:
 *
 * @fields_end
 */

$componentId = 'dts-faq-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) return;

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showIntro = $getConfig('display.show_intro', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

$bgColor = $getConfig('style.bg_color', '#fff0dc');
$accentColor = $getConfig('style.accent_color', '#f3b53f');
$titleColor = $getConfig('style.title_color', '#3f2418');
$textColor = $getConfig('style.text_color', '#6f4b37');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.88)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(242,107,79,0.18)');
$cardRadius = $getConfig('style.card_radius', '22');
$sectionPadding = $getConfig('style.section_padding', '64');
$sectionPaddingMobile = $getConfig('style.section_padding_mobile', '48');

$badgeText = $getConfig('texts.badge', 'Sunrise Support');
$title = $getConfig('texts.title', 'Frequently Asked Questions');
$intro = $getConfig('texts.intro', 'Everything important is kept visible: table pace, trust notes, and the quick answers players usually look for first.');
$timelineKicker = $getConfig('texts.timeline_kicker', 'Questions Timeline');
$timelineSummary = $getConfig('texts.timeline_summary', 'Tap any stop to expand the answer right inside the timeline.');
$expandHintText = $getConfig('texts.expand_hint', 'Tap to read answer');
$collapseHintText = $getConfig('texts.collapse_hint', 'Tap to collapse');
$expandActionText = $getConfig('texts.expand_text', 'Expand');
$closeActionText = $getConfig('texts.close_text', 'Close');
$answerKicker = $getConfig('texts.answer_kicker', 'FAQ Answer');
$questionPrefix = $getConfig('texts.question_prefix', 'Question');
$tags = array_filter([
    trim((string)$getConfig('texts.tag_1', 'Quick Rooms')),
    trim((string)$getConfig('texts.tag_2', 'Table Trust')),
    trim((string)$getConfig('texts.tag_3', 'Mobile Readability')),
]);

$defaults = [
    ['question' => 'What makes this theme different from darker gaming templates?', 'answer' => 'It uses a light editorial layout, softer contrast, and new section structures while keeping the same PHP-driven configuration patterns.'],
    ['question' => 'Can the default content still be overridden from config?', 'answer' => 'Yes. Titles, intro text, questions, answers, and display switches all still follow the same config fallback rules.'],
    ['question' => 'Is the layout responsive on mobile first?', 'answer' => 'Yes. Cards collapse into a single column, sticky summary content resets properly, and tap targets stay large.'],
    ['question' => 'Can I hide part of this section without editing code?', 'answer' => 'Yes. Badge, title, intro, and the first-open behavior can all be controlled by the existing component settings.'],
    ['question' => 'Will empty questions fall back safely?', 'answer' => 'Yes. Empty slots are skipped, and the built-in defaults continue to render a complete section when needed.'],
    ['question' => 'Can this module work on standalone FAQ pages too?', 'answer' => 'Yes. The same component is reused in the FAQ page layout with the same rendering logic.'],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i - 1] ?? ['question' => '', 'answer' => ''];
    $question = trim((string)$getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string)$getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqs[] = ['question' => $question, 'answer' => $answer];
    }
}

if (empty($faqs)) {
    $faqs = array_slice($defaults, 0, 4);
}

$faqItems = [];
foreach ($faqs as $index => $faq) {
    $faqItems[] = [
        'index' => $index,
        'question' => $faq['question'],
        'answer' => $faq['answer'],
    ];
}

$initialActiveIndex = $firstOpen ? 0 : null;
?>

<section id="<?= $componentId ?>" class="dts-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell">
        <header class="faq-head" id="faq">
            <?php if ($showIntro && $badgeText !== ''): ?>
                <span class="faq-badge"><?= htmlspecialchars($badgeText) ?></span>
            <?php endif; ?>

            <?php if ($showTitle): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>

            <?php if ($showIntro && $intro !== ''): ?>
                <p class="faq-intro"><?= htmlspecialchars($intro) ?></p>
            <?php endif; ?>

            <?php if (!empty($tags)): ?>
                <div class="faq-tags">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="faq-browser">
            <div class="faq-switch-hint" aria-hidden="true">
                <?php if ($timelineKicker !== ''): ?>
                    <span class="switch-kicker"><?= htmlspecialchars($timelineKicker) ?></span>
                <?php endif; ?>
                <?php if ($timelineSummary !== ''): ?>
                    <span class="switch-copy"><?= htmlspecialchars($timelineSummary) ?></span>
                <?php endif; ?>
            </div>

            <div class="faq-topic-bar" role="list">
                <?php foreach ($faqItems as $faq): ?>
                    <?php $isOpen = $initialActiveIndex !== null && $faq['index'] === $initialActiveIndex; ?>
                    <article class="faq-item<?= $isOpen ? ' is-open' : '' ?>" data-faq-item="<?= (int)$faq['index'] ?>" role="listitem">
                        <button
                            type="button"
                            class="faq-topic<?= $isOpen ? ' is-active' : '' ?>"
                            id="<?= $componentId ?>-trigger-<?= (int)$faq['index'] ?>"
                            data-faq-trigger="<?= (int)$faq['index'] ?>"
                            aria-controls="<?= $componentId ?>-panel-<?= (int)$faq['index'] ?>"
                            aria-expanded="<?= $isOpen ? 'true' : 'false' ?>"
                        >
                            <span class="topic-number"><?= sprintf('%02d', $faq['index'] + 1) ?></span>
                            <span class="topic-copy">
                                <strong><?= htmlspecialchars($faq['question']) ?></strong>
                                <span class="topic-label"><?= htmlspecialchars($isOpen ? $collapseHintText : $expandHintText) ?></span>
                            </span>
                            <span class="topic-action" aria-hidden="true" data-topic-action><?= htmlspecialchars($isOpen ? $closeActionText : $expandActionText) ?></span>
                        </button>

                        <div class="faq-inline-wrap<?= $isOpen ? ' is-open' : '' ?>" data-faq-panel-wrap="<?= (int)$faq['index'] ?>" aria-hidden="<?= $isOpen ? 'false' : 'true' ?>">
                            <div class="faq-inline-inner">
                                <article
                                    class="faq-inline-panel"
                                    id="<?= $componentId ?>-panel-<?= (int)$faq['index'] ?>"
                                    data-faq-panel="<?= (int)$faq['index'] ?>"
                                    role="region"
                                    tabindex="<?= $isOpen ? '0' : '-1' ?>"
                                    aria-labelledby="<?= $componentId ?>-trigger-<?= (int)$faq['index'] ?>"
                                >
                                    <div class="inline-accent" aria-hidden="true"></div>
                                    <div class="inline-glow inline-glow-left" aria-hidden="true"></div>
                                    <div class="inline-glow inline-glow-right" aria-hidden="true"></div>
                                    <span class="inline-watermark" aria-hidden="true"><?= sprintf('%02d', $faq['index'] + 1) ?></span>
                                    <div class="inline-topline">
                                        <?php if ($answerKicker !== ''): ?>
                                            <span class="inline-kicker"><?= htmlspecialchars($answerKicker) ?></span>
                                        <?php endif; ?>
                                        <span class="inline-step"><?= htmlspecialchars($questionPrefix) ?> <?= sprintf('%02d', $faq['index'] + 1) ?></span>
                                    </div>
                                    <h3><?= htmlspecialchars($faq['question']) ?></h3>
                                    <div class="inline-divider" aria-hidden="true"></div>
                                    <div class="inline-copy">
                                        <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
                                    </div>
                                </article>
                            </div>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

