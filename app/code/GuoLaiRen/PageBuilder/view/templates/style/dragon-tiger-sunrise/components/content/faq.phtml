<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) return;
    const closeActionText = <?= json_encode((string) $closeActionText) ?>;
    const expandActionText = <?= json_encode((string) $expandActionText) ?>;
    const collapseHintText = <?= json_encode((string) $collapseHintText) ?>;
    const expandHintText = <?= json_encode((string) $expandHintText) ?>;

    const items = Array.from(root.querySelectorAll('[data-faq-item]'));
    const buttons = Array.from(root.querySelectorAll('[data-faq-trigger]'));
    const panelWraps = Array.from(root.querySelectorAll('[data-faq-panel-wrap]'));
    const panels = Array.from(root.querySelectorAll('[data-faq-panel]'));

    const syncState = (activeIndex = null, shouldScroll = false) => {
        items.forEach((item) => {
            const index = Number(item.dataset.faqItem);
            const isOpen = activeIndex !== null && index === activeIndex;
            const button = item.querySelector('[data-faq-trigger]');
            const wrap = item.querySelector('[data-faq-panel-wrap]');
            const panel = item.querySelector('[data-faq-panel]');
            const action = item.querySelector('[data-topic-action]');
            const label = item.querySelector('.topic-label');

            item.classList.toggle('is-open', isOpen);

            if (button) {
                button.classList.toggle('is-active', isOpen);
                button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            }

            if (action) {
                action.textContent = isOpen ? closeActionText : expandActionText;
            }

            if (label) {
                label.textContent = isOpen ? collapseHintText : expandHintText;
            }

            if (wrap) {
                wrap.classList.toggle('is-open', isOpen);
                wrap.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
            }

            if (panel) {
                panel.setAttribute('tabindex', isOpen ? '0' : '-1');
            }
        });

        if (shouldScroll && activeIndex !== null && window.matchMedia('(max-width: 640px)').matches) {
            const target = root.querySelector('[data-faq-item="' + activeIndex + '"]');
            if (target) {
                const rect = target.getBoundingClientRect();
                if (rect.top < 72 || rect.top > window.innerHeight * 0.52) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        }
    };

    buttons.forEach((button, buttonIndex) => {
        button.addEventListener('click', () => {
            const index = Number(button.dataset.faqTrigger);
            const isOpen = button.getAttribute('aria-expanded') === 'true';
            syncState(isOpen ? null : index, true);
        });

        button.addEventListener('keydown', (event) => {
            const key = event.key;
            if (!['ArrowDown', 'ArrowUp', 'Home', 'End'].includes(key)) {
                return;
            }

            event.preventDefault();

            let nextIndex = buttonIndex;
            if (key === 'ArrowDown') {
                nextIndex = (buttonIndex + 1) % buttons.length;
            } else if (key === 'ArrowUp') {
                nextIndex = (buttonIndex - 1 + buttons.length) % buttons.length;
            } else if (key === 'Home') {
                nextIndex = 0;
            } else if (key === 'End') {
                nextIndex = buttons.length - 1;
            }

            buttons[nextIndex].focus();
        });
    });

    if (<?= $initialActiveIndex === null ? 'true' : 'false' ?>) {
        syncState(null);
    }
})();
</script>
