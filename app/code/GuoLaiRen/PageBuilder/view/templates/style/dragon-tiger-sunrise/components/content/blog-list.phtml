        position: static;
    }
}

@media (max-width: 768px) {
    .dts-blog-list {
        padding: 64px 0;
    }

    .dts-blog-list .blog-shell {
        padding: 0 15px;
    }

    .dts-blog-list .story-grid {
        grid-template-columns: 1fr;
    }

    .dts-blog-list .story-grid.style-featured .story-card.is-wide {
