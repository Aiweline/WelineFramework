    padding: 1.1rem;
}

.dts-blog-list .rail-card h4 {
    color: #3f2418;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.dts-blog-list .category-cloud {
    margin-top: 0.85rem;
