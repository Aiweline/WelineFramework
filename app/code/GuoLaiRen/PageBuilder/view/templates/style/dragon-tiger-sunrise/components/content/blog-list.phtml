    margin-top: 1rem;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.08;
}

.dts-blog-list .featured-copy h3 a,
.dts-blog-list .story-title a {
    color: #3f2418;
    text-decoration: none;
    transition: color 0.25s ease;
}

.dts-blog-list .featured-copy h3 a:hover,
.dts-blog-list .story-title a:hover {
    color: <?= htmlspecialchars($secondaryColor) ?>;
}

.dts-blog-list .featured-summary,
.dts-blog-list .story-summary {
    margin-top: 0.9rem;
    color: rgba(111, 75, 55, 0.78);
    line-height: 1.74;
}

.dts-blog-list .featured-footer,
.dts-blog-list .story-foot {
    margin-top: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
}

.dts-blog-list .story-author {
    color: rgba(143, 114, 95, 0.74);
    font-size: 0.88rem;
}

.dts-blog-list .story-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: <?= htmlspecialchars($primaryColor) ?>;
    text-decoration: none;
    font-weight: 700;
    transition: gap 0.25s ease, color 0.25s ease;
}

.dts-blog-list .story-link:hover {
    gap: 0.72rem;
    color: <?= htmlspecialchars($secondaryColor) ?>;
}

.dts-blog-list .news-deck {
    display: grid;
    gap: 1rem;
}

.dts-blog-list .news-deck.has-rail {
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.3fr);
    align-items: start;
}

