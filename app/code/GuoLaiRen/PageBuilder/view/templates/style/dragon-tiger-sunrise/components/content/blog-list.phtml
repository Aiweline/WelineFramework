    box-shadow: 0 22px 52px rgba(194, 130, 94, 0.14);
}

.dts-blog-list .featured-story {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: 1rem;
    overflow: hidden;
    margin-bottom: 1rem;
}

.dts-blog-list .featured-media {
    min-height: 100%;
    position: relative;
    display: block;
    background: rgba(242, 169, 59, 0.14);
}

.dts-blog-list .featured-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

