    position: relative;
    padding: 84px 0;
    background:
        radial-gradient(1200px 600px at 15% 10%, rgba(242, 107, 79, 0.16), transparent 60%),
        radial-gradient(800px 500px at 85% 20%, rgba(242, 169, 59, 0.16), transparent 55%),
        <?= htmlspecialchars($bgColor) ?>;
    color: <?= htmlspecialchars($textColor) ?>;
    overflow: hidden;
}

.dts-blog-list::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('<?= $pokerBg ?>') center top/cover no-repeat;
    opacity: 0.1;
    pointer-events: none;
}

