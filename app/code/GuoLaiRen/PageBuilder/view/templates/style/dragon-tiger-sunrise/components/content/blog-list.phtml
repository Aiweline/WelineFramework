    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.82rem;
    border-radius: 999px;
    border: 1px solid rgba(242, 107, 79, 0.22);
    background: rgba(242, 107, 79, 0.08);
    color: #b5482a;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

