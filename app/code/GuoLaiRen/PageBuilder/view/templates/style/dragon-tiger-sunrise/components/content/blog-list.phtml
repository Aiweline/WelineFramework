    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
}

.dts-blog-list .story-card {
    overflow: hidden;
}

.dts-blog-list .story-grid.style-featured .story-card.is-wide {
    grid-column: span 2;
}

.dts-blog-list .story-cover {
    position: relative;
    display: block;
    padding-top: 60%;
    overflow: hidden;
}

.dts-blog-list .story-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
}

.dts-blog-list .story-card:hover .story-cover img {
    transform: scale(1.05);
}

