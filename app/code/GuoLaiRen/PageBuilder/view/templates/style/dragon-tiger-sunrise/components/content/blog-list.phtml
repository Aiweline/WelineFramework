}

.dts-blog-list .recent-link strong {
    color: #3f2418;
    font-size: 0.92rem;
    line-height: 1.45;
}

.dts-blog-list .recent-link small {
    color: rgba(143, 114, 95, 0.66);
    font-size: 0.76rem;
}

.dts-blog-list .blog-empty {
    text-align: center;
