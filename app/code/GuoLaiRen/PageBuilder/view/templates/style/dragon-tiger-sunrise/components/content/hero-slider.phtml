$componentId = 'dts-hero-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$kicker = $getConfig('hero.kicker', 'Sunrise table experience');
$title = $getConfig('hero.title', 'Bright Tables Begin at Dragon Tiger Sunrise');
$subtitle = $getConfig('hero.subtitle', 'A lighter, faster Dragon Tiger landing experience with quick rooms, crisp calls, and all-day mobile flow.');
$ctaText = $getConfig('hero.cta_text', 'Join the Table');
$ctaUrl = $getConfig('hero.cta_url', '#download');
$ctaSecondaryText = $getConfig('hero.secondary_cta_text', 'See the Modes');
$ctaSecondaryUrl = $getConfig('hero.secondary_cta_url', '#tables');
$heroTagsRaw = (string) $getConfig('hero.tags', 'Sunlit interface, Fast scan hierarchy, Mobile-first pacing');
$posterBadge = $getConfig('hero.poster_badge', 'Editorial game preview');
$heroImage = trim((string)$getConfig('hero.image', ''));
$heroImage = $heroImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/hero-info-graphic.svg');
$bgImage = trim((string)$getConfig('hero.bg_image', ''));
$bgImage = $bgImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/dragon-tiger-sunrise/asset/img/poker-header-bg.svg');

$heroSignals = [
    ['value' => $getConfig('hero.signal_1_value', '10s'), 'label' => $getConfig('hero.signal_1_label', 'Round pace')],
    ['value' => $getConfig('hero.signal_2_value', '2-card'), 'label' => $getConfig('hero.signal_2_label', 'Core reveal')],
    ['value' => $getConfig('hero.signal_3_value', '24/7'), 'label' => $getConfig('hero.signal_3_label', 'Open rooms')],
];

$heroPanels = [
    ['label' => $getConfig('hero.panel_1_label', 'Quick Entry'), 'value' => $getConfig('hero.panel_1_value', 'Tap in, sit down, start fast')],
    ['label' => $getConfig('hero.panel_2_label', 'Bright UI'), 'value' => $getConfig('hero.panel_2_value', 'Readable chips and clean odds blocks')],
    ['label' => $getConfig('hero.panel_3_label', 'Mobile Flow'), 'value' => $getConfig('hero.panel_3_value', 'Large touch zones, easy one-hand play')],
];

$heroTags = array_values(array_filter(array_map('trim', preg_split('/[\r\n,]+/', $heroTagsRaw) ?: []), static function ($item) {
    return $item !== '';
}));
?>

<section id="<?= $componentId ?>" class="dts-hero">
    <div class="hero-backdrop" style="background-image: url('<?= htmlspecialchars($bgImage) ?>');"></div>

    <div class="hero-shell">
        <div class="hero-topline">
            <?php if ($kicker !== ''): ?>
                <span class="hero-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <div class="hero-tagline" aria-label="Hero highlights">
                <?php foreach ($heroTags as $tag): ?>
                    <span><?= htmlspecialchars($tag) ?></span>
                <?php endforeach; ?>
            </div>
        </div>

        <header class="hero-headline">
            <h1><?= htmlspecialchars($title) ?></h1>
            <p class="hero-subtitle"><?= htmlspecialchars($subtitle) ?></p>

            <div class="hero-actions">
                <?php if ($ctaText !== ''): ?>
                    <a class="hero-primary" href="<?= htmlspecialchars($ctaUrl) ?>"><?= htmlspecialchars($ctaText) ?></a>
                <?php endif; ?>
                <?php if ($ctaSecondaryText !== ''): ?>
                    <a class="hero-secondary" href="<?= htmlspecialchars($ctaSecondaryUrl) ?>"><?= htmlspecialchars($ctaSecondaryText) ?></a>
                <?php endif; ?>
            </div>
        </header>

        <div class="hero-stage">
            <div class="hero-orbit orbit-one" aria-hidden="true"></div>
            <div class="hero-orbit orbit-two" aria-hidden="true"></div>

            <div class="hero-cue-cloud">
                <?php foreach ($heroSignals as $index => $signal): ?>
                    <article class="hero-cue cue-<?= (int)$index ?>">
                        <strong><?= htmlspecialchars($signal['value']) ?></strong>
                        <span><?= htmlspecialchars($signal['label']) ?></span>
                    </article>
                <?php endforeach; ?>
            </div>

            <div class="hero-poster">
                <?php if ($posterBadge !== ''): ?>
                    <span class="poster-badge"><?= htmlspecialchars($posterBadge) ?></span>
                <?php endif; ?>
                <div class="poster-frame">
                    <img src="<?= htmlspecialchars($heroImage) ?>" alt="<?= htmlspecialchars($title) ?>">
                </div>
            </div>

            <div class="hero-track" aria-label="Hero feature track">
                <?php foreach ($heroPanels as $index => $panel): ?>
                    <article class="track-stop">
                        <span class="track-index"><?= sprintf('%02d', $index + 1) ?></span>
                        <strong><?= htmlspecialchars($panel['label']) ?></strong>
                        <p><?= htmlspecialchars($panel['value']) ?></p>
