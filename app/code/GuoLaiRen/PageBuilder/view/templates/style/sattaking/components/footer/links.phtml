/**
 * Satta King 786 - Footer Links Component
 * 
 * 页脚链接区域，简洁的品牌信息和导航链接
 * 基于 https://www.insattaking786.com/ 原网站结构
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:Satta King 786
 * brand.description => 品牌描述:textarea:An informational guide to satta king formats, schedules, and Android access. Always check local laws and follow responsible play practices.
 * brand.show_logo => 显示Logo:select:yes|yes,no
 * 
 * group:links => 链接设置
 * links.items => 导航链接:textarea:Download App=>#download\r\nGames=>#games\r\nFAQ=>#faq\r\nContact=>/contact|格式：名称=>链接，一行一个
 * links.style => 链接样式:select:inline|inline,grid|inline=一行显示,grid=网格显示
 * 
 * group:copyright => 版权设置
 * copyright.text => 底部标语:text:Designed for clarity, speed, and compliance-first guidance.
 * copyright.show_year => 显示年份:select:yes|yes,no
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$footerBg = $colors['footer_bg'] ?? '#08081a';
$footerText = $colors['footer_text'] ?? '#6b6b8a';
$footerLink = $colors['footer_link'] ?? '#b8b8d0';
$footerLinkHover = $colors['footer_link_hover'] ?? '#a855f7';
$footerBorder = $colors['footer_border'] ?? 'rgba(255, 255, 255, 0.06)';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)';

// 品牌配置
$brandName = $config['brand.name'] ?? 'Satta King 786';
$brandDesc = $config['brand.description'] ?? 'An informational guide to satta king formats, schedules, and Android access. Always check local laws and follow responsible play practices.';
$showLogo = ($config['brand.show_logo'] ?? 'yes') !== 'no';

// 链接配置
$linksRaw = $config['links.items'] ?? "Download App=>#download\nGames=>#games\nFAQ=>#faq\nContact=>/contact";
$linksStyle = $config['links.style'] ?? 'inline';

// 解析链接
$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$navLinks = $parseLinks($linksRaw);

// 版权配置
$copyrightText = $config['copyright.text'] ?? 'Designed for clarity, speed, and compliance-first guidance.';
$showYear = ($config['copyright.show_year'] ?? 'yes') !== 'no';

$currentYear = date('Y');
$instanceId = 'sk-footer-' . uniqid();
?>

