$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'sattaking';
if (empty($templateCode)) {
    $templateCode = 'sattaking';
}
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 辅助函数
if (!function_exists('sk_footer_color')) {
    function sk_footer_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('sk_footer_getConfig')) {
    function sk_footer_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// 品牌配置
$brandName = sk_footer_getConfig($styleSettings, 'brand.name', 'Satta King 786');
$brandDesc = sk_footer_getConfig($styleSettings, 'brand.description', 'Informational hub for satta-related formats and schedules.');

// 链接配置
$column1Title = sk_footer_getConfig($styleSettings, 'links.column1_title', 'Quick Links');
$column1Raw = sk_footer_getConfig($styleSettings, 'links.column1_items', "Home=>/\nGames=>/games\nDownload App=>/download\nFAQ=>/faq");
$column2Title = sk_footer_getConfig($styleSettings, 'links.column2_title', 'Legal');
$column2Raw = sk_footer_getConfig($styleSettings, 'links.column2_items', "Privacy Policy=>/privacy\nTerms of Service=>/terms\nDisclaimer=>/disclaimer");

// 解析链接
$parseLinks = function($raw) {
    $links = [];
    $lines = preg_split('/[\r\n]+/', $raw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $links[] = ['name' => $name, 'url' => $url];
        }
    }
    return $links;
};

$column1Links = $parseLinks($column1Raw);
$column2Links = $parseLinks($column2Raw);

// 联系信息
$contactEmail = sk_footer_getConfig($styleSettings, 'contact.email', 'contact@example.com');

// 版权配置
$copyrightText = sk_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved.');
$disclaimer = sk_footer_getConfig($styleSettings, 'copyright.disclaimer', 'For educational purposes only. We do not promote gambling.');

// 样式配置
$bgColor = sk_footer_getConfig($styleSettings, 'style.background_color', sk_footer_color($colors, 'footer_bg', '#08081a'));
