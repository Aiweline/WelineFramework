$linkColor = sk_footer_getConfig($styleSettings, 'style.link_color', sk_footer_color($colors, 'footer_link', '#b8b8d0'));
$linkHoverColor = sk_footer_getConfig($styleSettings, 'style.link_hover_color', sk_footer_color($colors, 'footer_link_hover', '#a855f7'));

$textPrimary = sk_footer_color($colors, 'text_primary', '#ffffff');
$accentPrimary = sk_footer_color($colors, 'accent_primary', '#7c3aed');
$buttonPrimaryBg = sk_footer_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)');
$footerBorder = sk_footer_color($colors, 'footer_border', 'rgba(255, 255, 255, 0.06)');

