<?php
/**
 * Satta King 786 - Header Navigation Component
 * 
 * 导航组件，支持从子页面动态获取导航项
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.image => Logo图片URL:textarea:|留空使用默认文字Logo
 * logo.text => Logo文字:text:Satta King 786
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:no|no,yes
 * navigation.items => 导航项配置:textarea:Home=>#hero\r\nDownload App=>#download\r\nGames=>#games\r\nFAQ=>#faq\r\nContact Us=>/contact|格式：名称=>链接，一行一个（仅当开启自定义链接时生效）
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Download App
 * navigation.cta_url => CTA按钮链接:text:#download
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$navBg = $colors['nav_bg'] ?? 'rgba(10, 10, 26, 0.95)';
$navText = $colors['nav_text'] ?? '#ffffff';
$navLink = $colors['nav_link'] ?? '#b8b8d0';
$navLinkHover = $colors['nav_link_hover'] ?? '#a855f7';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)';

// Logo配置
$showLogo = ($config['logo.display'] ?? 'yes') !== 'no';
$logoImage = $config['logo.image'] ?? '';
$logoText = $config['logo.text'] ?? 'Satta King 786';
$logoWidth = $config['logo.width'] ?? 40;

// 导航配置
$useCustomLinks = ($config['navigation.use_custom_links'] ?? 'no') === 'yes';
$navItemsRaw = $config['navigation.items'] ?? "Home=>#hero\nDownload App=>#download\nGames=>#games\nFAQ=>#faq\nContact Us=>/contact";
$showCta = ($config['navigation.show_cta'] ?? 'yes') !== 'no';
$ctaText = $config['navigation.cta_text'] ?? 'Download App';
$ctaUrl = $config['navigation.cta_url'] ?? '#download';

// 导航项：默认按网站页面类型自动生成；开启「使用自定义导航链接」时用 navigation.items
$navItems = [];
$page = $this->getData('page');
if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $headerPages = $page->getHeaderNavigationPages(10);
    foreach ($headerPages as $navPage) {
        $type = $navPage['type'] ?? '';
        $labelKey = 'navigation.label_' . $type;
        $configuredLabel = trim((string)($config[$labelKey] ?? ''));
        $title = $navPage['title'] ?? '';
        $url = $navPage['url'] ?? '/';
        if (isset($navPage['type']) && $navPage['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
            $title = __('Home');
            $url = '/';
        }
        $navItems[] = ['name' => $configuredLabel !== '' ? $configuredLabel : $title, 'url' => $url];
    }
}
if ($useCustomLinks || empty($navItems)) {
    $navItems = [];
    $lines = preg_split('/[\r\n]+/', $navItemsRaw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $navItems[] = ['name' => $name, 'url' => $url ?: '#'];
        }
    }
}
if (empty($navItems)) {
    $navItems = [
        ['name' => 'Home', 'url' => '#hero'],
        ['name' => 'Download App', 'url' => '#download'],
        ['name' => 'Games', 'url' => '#games'],
        ['name' => 'FAQ', 'url' => '#faq'],
        ['name' => 'Contact Us', 'url' => '/contact'],
    ];
}

$instanceId = 'sk-nav-' . uniqid();
?>

<nav class="sk-nav" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= htmlspecialchars($navBg) ?>;
            backdrop-filter: blur(10px);
            padding: 0 20px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        #<?= $instanceId ?> .sk-nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.25rem;
            font-weight: 700;
            color: <?= $navText ?>;
        }
        
        #<?= $instanceId ?> .sk-nav-logo img {
            height: <?= $logoWidth ?>px;
            width: auto;
        }
        
        #<?= $instanceId ?> .sk-nav-logo-icon {
            width: <?= $logoWidth ?>px;
            height: <?= $logoWidth ?>px;
            background: <?= $buttonPrimaryBg ?>;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #<?= $instanceId ?> .sk-nav-logo-icon svg {
            width: 24px;
            height: 24px;
            fill: #ffffff;
        }
        
        #<?= $instanceId ?> .sk-nav-menu {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        #<?= $instanceId ?> .sk-nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        #<?= $instanceId ?> .sk-nav-link {
            color: <?= $navLink ?>;
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.3s ease;
            position: relative;
        }
        
        #<?= $instanceId ?> .sk-nav-link:hover {
            color: <?= $navLinkHover ?>;
        }
        
        #<?= $instanceId ?> .sk-nav-link::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: <?= $accentPrimary ?>;
            transition: width 0.3s ease;
        }
        
        #<?= $instanceId ?> .sk-nav-link:hover::after {
            width: 100%;
        }
        
        #<?= $instanceId ?> .sk-nav-cta {
            padding: 10px 20px;
            background: <?= $buttonPrimaryBg ?>;
            color: #ffffff;
            font-size: 0.9rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .sk-nav-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);
        }
        
        #<?= $instanceId ?> .sk-nav-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            padding: 8px;
            cursor: pointer;
        }
        
        #<?= $instanceId ?> .sk-nav-toggle span {
            width: 24px;
            height: 2px;
            background: <?= $navText ?>;
            transition: all 0.3s ease;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .sk-nav-menu {
                position: fixed;
                top: 80px;
                left: 0;
                right: 0;
                bottom: 0;
                background: <?= $navBg ?>;
                flex-direction: column;
                justify-content: flex-start;
                padding: 40px 20px;
                gap: 0;
                transform: translateX(100%);
                transition: transform 0.3s ease;
            }
            
            #<?= $instanceId ?> .sk-nav-menu.active {
                transform: translateX(0);
            }
            
            #<?= $instanceId ?> .sk-nav-links {
                flex-direction: column;
                width: 100%;
                gap: 0;
            }
            
            #<?= $instanceId ?> .sk-nav-link {
                display: block;
                padding: 16px 0;
                font-size: 1.1rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                width: 100%;
            }
            
            #<?= $instanceId ?> .sk-nav-link::after {
                display: none;
            }
            
            #<?= $instanceId ?> .sk-nav-cta {
                margin-top: 24px;
                width: 100%;
                text-align: center;
                padding: 16px;
            }
            
            #<?= $instanceId ?> .sk-nav-toggle {
                display: flex;
            }
            
            #<?= $instanceId ?> .sk-nav-toggle.active span:nth-child(1) {
                transform: rotate(45deg) translate(5px, 5px);
            }
            
            #<?= $instanceId ?> .sk-nav-toggle.active span:nth-child(2) {
                opacity: 0;
            }
            
            #<?= $instanceId ?> .sk-nav-toggle.active span:nth-child(3) {
                transform: rotate(-45deg) translate(5px, -5px);
            }
        }
    </style>
    
    <!-- Logo -->
    <?php if ($showLogo): ?>
    <a href="/" class="sk-nav-logo">
        <?php if ($logoImage): ?>
            <img src="<?= htmlspecialchars($logoImage) ?>" alt="<?= htmlspecialchars($logoText) ?>">
        <?php else: ?>
            <span class="sk-nav-logo-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </span>
        <?php endif; ?>
        <span><?= htmlspecialchars($logoText) ?></span>
    </a>
    <?php endif; ?>
    
    <!-- Mobile Toggle -->
    <button class="sk-nav-toggle" onclick="this.classList.toggle('active'); document.querySelector('#<?= $instanceId ?> .sk-nav-menu').classList.toggle('active');">
        <span></span>
        <span></span>
        <span></span>
    </button>
    
    <!-- Navigation Menu -->
    <div class="sk-nav-menu">
        <div class="sk-nav-links">
            <?php foreach ($navItems as $item): ?>
            <a href="<?= htmlspecialchars($item['url']) ?>" class="sk-nav-link"><?= htmlspecialchars($item['name']) ?></a>
            <?php endforeach; ?>
        </div>
        
        <?php if ($showCta): ?>
        <a href="<?= htmlspecialchars($ctaUrl) ?>" class="sk-nav-cta"><?= htmlspecialchars($ctaText) ?></a>
        <?php endif; ?>
    </div>
</nav>
