<?php
/**
 * Satta King 786 - Platform Overview Section Component
 * 
 * 平台概述区域，展示数据结构和特性
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Platform Overview
 * content.title => 标题:text:How data is structured on the platform
 * content.description => 描述:textarea:We organize listings around markets, timing windows, and standardized number formats so users can navigate information confidently.
 * 
 * group:features => 特性列表
 * features.items => 特性列表:textarea:Market timing blocks|Every market follows scheduled rounds. The platform groups them into morning, afternoon, and evening blocks for clarity.|⏰\r\nResult format layers|Entries are tagged as single, jodi, or panna so you can interpret outcomes without confusion.|📊\r\nArchive and verification|Historical results remain searchable with timestamps, making it easier to cross-check data.|🔍\r\nReal-time update cues|Live indicators show when a market is open, closed, or pending the next update.|⚡\r\nRegional labels|Popular markets appear with location tags for quick scanning.|🌍\r\nClear notation legend|Each format includes a short legend so new users can learn notation fast.|📚|格式：标题|描述|图标，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['section_bg_1'] ?? '#0f0f1f';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $colors['text_secondary'] ?? '#b8b8d0';
$textMuted = $colors['text_muted'] ?? '#6b6b8a';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a855f7';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';

// 内容配置
$badge = $config['content.badge'] ?? 'Platform Overview';
$title = $config['content.title'] ?? 'How data is structured on the platform';
$description = $config['content.description'] ?? 'We organize listings around markets, timing windows, and standardized number formats so users can navigate information confidently.';

// 特性列表
$featuresRaw = $config['features.items'] ?? "Market timing blocks|Every market follows scheduled rounds grouped into morning, afternoon, and evening blocks.|⏰\nResult format layers|Entries are tagged as single, jodi, or panna for easy interpretation.|📊\nArchive and verification|Historical results remain searchable with timestamps.|🔍\nReal-time update cues|Live indicators show market status.|⚡\nRegional labels|Popular markets appear with location tags.|🌍\nClear notation legend|Each format includes a short legend for new users.|📚";

$features = [];
$lines = preg_split('/[\r\n]+/', $featuresRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line);
    $featureTitle = trim($parts[0] ?? '');
    $featureDesc = trim($parts[1] ?? '');
    $featureIcon = trim($parts[2] ?? '📌');
    
    if (!empty($featureTitle)) {
        $features[] = [
            'title' => $featureTitle,
            'description' => $featureDesc,
            'icon' => $featureIcon,
        ];
    }
}

$instanceId = 'sk-platform-' . uniqid();
?>

<section class="sk-platform" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .sk-platform-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .sk-platform-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .sk-platform-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(124, 58, 237, 0.15);
            border: 1px solid rgba(124, 58, 237, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 500;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .sk-platform-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .sk-platform-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .sk-platform-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .sk-platform-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 16px;
            padding: 28px;
            transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .sk-platform-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(124, 58, 237, 0.3);
            transform: translateY(-4px);
        }
        
        #<?= $instanceId ?> .sk-platform-card-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(59, 130, 246, 0.2) 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .sk-platform-card-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: <?= $textPrimary ?>;
            margin-bottom: 10px;
        }
        
        #<?= $instanceId ?> .sk-platform-card-desc {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
            line-height: 1.6;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .sk-platform-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .sk-platform-title {
                font-size: 1.75rem;
            }
            
            #<?= $instanceId ?> .sk-platform-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    
    <div class="sk-platform-container">
        <div class="sk-platform-header">
            <div class="sk-platform-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                </svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="sk-platform-title"><?= htmlspecialchars($title) ?></h2>
            <p class="sk-platform-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="sk-platform-grid">
            <?php foreach ($features as $feature): ?>
            <div class="sk-platform-card">
                <div class="sk-platform-card-icon"><?= $feature['icon'] ?></div>
                <h3 class="sk-platform-card-title"><?= htmlspecialchars($feature['title']) ?></h3>
                <p class="sk-platform-card-desc"><?= htmlspecialchars($feature['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
