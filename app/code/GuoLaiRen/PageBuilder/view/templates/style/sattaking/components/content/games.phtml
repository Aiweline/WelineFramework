<?php
/**
 * Satta King 786 - Popular Games Section Component
 * 
 * 热门游戏/市场展示区域
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Popular Games
 * content.title => 标题:text:Well-known markets and formats
 * content.description => 描述:textarea:These market categories are commonly listed in schedules. Rules and timings differ, so always review each market's structure.
 * 
 * group:games => 游戏列表
 * games.items => 游戏列表:textarea:Gali|Often featured as a late-night market with compact result windows and rapid updates.|🌙\r\nDesawar|Known for morning result postings with single and jodi emphasis in listings.|☀️\r\nFaridabad|A major market that typically features multiple rounds and detailed result archives.|📈\r\nGhaziabad|Frequently tracked with structured timing labels and a focus on pana breakdowns.|📊|格式：名称|描述|图标，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['games_bg'] ?? '#141428';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $colors['text_secondary'] ?? '#b8b8d0';
$textMuted = $colors['text_muted'] ?? '#6b6b8a';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a855f7';
$accentSecondary = $colors['accent_secondary'] ?? '#3b82f6';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';

// 内容配置
$badge = $config['content.badge'] ?? 'Popular Games';
$title = $config['content.title'] ?? 'Well-known markets and formats';
$description = $config['content.description'] ?? 'These market categories are commonly listed in schedules. Rules and timings differ, so always review each market\'s structure.';

// 游戏列表
$gamesRaw = $config['games.items'] ?? "Gali|Often featured as a late-night market with compact result windows and rapid updates.|🌙\nDesawar|Known for morning result postings with single and jodi emphasis in listings.|☀️\nFaridabad|A major market that typically features multiple rounds and detailed result archives.|📈\nGhaziabad|Frequently tracked with structured timing labels and a focus on pana breakdowns.|📊";

$games = [];
$lines = preg_split('/[\r\n]+/', $gamesRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line);
    $gameName = trim($parts[0] ?? '');
    $gameDesc = trim($parts[1] ?? '');
    $gameIcon = trim($parts[2] ?? '🎮');
    
    if (!empty($gameName)) {
        $games[] = [
            'name' => $gameName,
            'description' => $gameDesc,
            'icon' => $gameIcon,
        ];
    }
}

$instanceId = 'sk-games-' . uniqid();
?>

<section class="sk-games" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .sk-games-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .sk-games-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .sk-games-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(124, 58, 237, 0.15);
            border: 1px solid rgba(124, 58, 237, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 500;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .sk-games-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .sk-games-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .sk-games-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .sk-games-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            padding: 32px 24px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?> .sk-games-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: <?= $buttonPrimaryBg ?>;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        #<?= $instanceId ?> .sk-games-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(124, 58, 237, 0.4);
            transform: translateY(-6px);
        }
        
        #<?= $instanceId ?> .sk-games-card:hover::before {
            opacity: 1;
        }
        
        #<?= $instanceId ?> .sk-games-card-icon {
            width: 72px;
            height: 72px;
            background: linear-gradient(145deg, rgba(124, 58, 237, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 20px;
            transition: transform 0.3s ease;
        }
        
        #<?= $instanceId ?> .sk-games-card:hover .sk-games-card-icon {
            transform: scale(1.1);
        }
        
        #<?= $instanceId ?> .sk-games-card-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: <?= $textPrimary ?>;
            margin-bottom: 12px;
        }
        
        #<?= $instanceId ?> .sk-games-card-desc {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
            line-height: 1.6;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .sk-games-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .sk-games-title {
                font-size: 1.75rem;
            }
            
            #<?= $instanceId ?> .sk-games-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    
    <div class="sk-games-container">
        <div class="sk-games-header">
            <div class="sk-games-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                </svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="sk-games-title"><?= htmlspecialchars($title) ?></h2>
            <p class="sk-games-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="sk-games-grid">
            <?php foreach ($games as $game): ?>
            <div class="sk-games-card">
                <div class="sk-games-card-icon"><?= $game['icon'] ?></div>
                <h3 class="sk-games-card-name"><?= htmlspecialchars($game['name']) ?></h3>
                <p class="sk-games-card-desc"><?= htmlspecialchars($game['description']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
