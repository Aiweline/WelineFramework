$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['section_bg_2'] ?? '#141428';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $colors['text_secondary'] ?? '#b8b8d0';
$textMuted = $colors['text_muted'] ?? '#6b6b8a';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a855f7';
$accentSecondary = $colors['accent_secondary'] ?? '#3b82f6';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';

// 内容配置
$badge = $config['content.badge'] ?? 'App Download';
$title = $config['content.title'] ?? 'Android access designed for clarity';
$description = $config['content.description'] ?? 'Use the app to check schedules, save favorite markets, and review formats with a clean interface.';

// 下载配置
$downloadTitle = $config['download.title'] ?? 'Choose the preferred download path';
$downloadDesc = $config['download.description'] ?? 'Get the official Android build with clear release notes and version labeling.';
$primaryBtnText = $config['download.primary_text'] ?? 'Primary Download';
$primaryBtnUrl = $config['download.primary_url'] ?? '#';
$secondaryBtnText = $config['download.secondary_text'] ?? 'Need Help?';
$secondaryBtnUrl = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl($config['download.secondary_url'] ?? '#faq');

// 特性列表
$featuresRaw = $config['features.items'] ?? "Lightweight install\nResult history\nMarket reminders";
$features = array_filter(array_map('trim', preg_split('/[\r\n]+/', $featuresRaw)));

// 安装清单
$checklistTitle = $config['checklist.title'] ?? 'Quick install checklist';
$checklistRaw = $config['checklist.items'] ?? "Confirm the source|Use official download links and verify the app name before installing\nAllow install prompts|Enable installation for trusted sources only when prompted\nReview permissions|Check notifications and storage access before you confirm";

$checklist = [];
$lines = preg_split('/[\r\n]+/', $checklistRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line, 2);
    $itemTitle = trim($parts[0] ?? '');
    $itemDesc = trim($parts[1] ?? '');
    
    if (!empty($itemTitle)) {
        $checklist[] = [
            'title' => $itemTitle,
            'description' => $itemDesc,
        ];
    }
}

$instanceId = 'sk-download-' . uniqid();
?>

