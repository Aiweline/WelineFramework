    </style>
    
    <div class="sk-faq-container">
        <div class="sk-faq-header">
            <div class="sk-faq-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/>
                </svg>
                <?= htmlspecialchars($badge) ?>
            </div>
            <h2 class="sk-faq-title"><?= htmlspecialchars($title) ?></h2>
            <p class="sk-faq-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="sk-faq-list">
            <?php foreach ($faqs as $index => $faq): ?>
            <div class="sk-faq-item<?= $index === 0 ? ' active' : '' ?>">
                <div class="sk-faq-question" onclick="this.parentElement.classList.toggle('active')">
                    <span class="sk-faq-question-text"><?= htmlspecialchars($faq['question']) ?></span>
                    <span class="sk-faq-question-icon">
                        <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                    </span>
                </div>
                <div class="sk-faq-answer">
                    <div class="sk-faq-answer-content"><?= htmlspecialchars($faq['answer']) ?></div>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
