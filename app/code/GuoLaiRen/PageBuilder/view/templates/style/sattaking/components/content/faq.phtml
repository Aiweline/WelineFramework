<?php
/**
 * Satta King 786 - FAQ Section Component
 * 
 * 常见问题展示区域，支持手风琴展开效果
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:FAQ Snapshot
 * content.title => 标题:text:Quick answers about the platform
 * content.description => 描述:textarea:Concise responses to common questions. Visit the full FAQ page for more detail.
 * 
 * group:faq => FAQ列表
 * faq.items => FAQ列表:textarea:What does satta king mean in online listings?|It is a common label used to group result schedules, market names, and updates in one place.\r\nIs satta king 786 a separate market?|It usually refers to a curated set of markets and result feeds rather than a single standalone market.\r\nHow are results displayed on the platform?|Results follow standard notation such as single, jodi, and panna, with timing stamps for each round.\r\nCan I browse without creating an account?|Yes, basic schedules and format explanations are accessible without sign-in, while alerts require setup.\r\nWhat should I check before downloading the app?|Confirm the source, review permissions, and make sure the package name matches the official listing.\r\nDoes this site promise winnings or financial gain?|No. The content is informational and does not guarantee outcomes or profits.|格式：问题|回答，一行一个
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$sectionBg = $colors['faq_bg'] ?? '#0c0c1e';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $colors['text_secondary'] ?? '#b8b8d0';
$textMuted = $colors['text_muted'] ?? '#6b6b8a';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a855f7';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';

// 内容配置
$badge = $config['content.badge'] ?? 'FAQ Snapshot';
$title = $config['content.title'] ?? 'Quick answers about the platform';
$description = $config['content.description'] ?? 'Concise responses to common questions. Visit the full FAQ page for more detail.';

// FAQ列表
$faqRaw = $config['faq.items'] ?? "What does satta king mean in online listings?|It is a common label used to group result schedules, market names, and updates in one place.\nIs satta king 786 a separate market?|It usually refers to a curated set of markets and result feeds rather than a single standalone market.\nHow are results displayed on the platform?|Results follow standard notation such as single, jodi, and panna, with timing stamps for each round.\nCan I browse without creating an account?|Yes, basic schedules and format explanations are accessible without sign-in, while alerts require setup.\nWhat should I check before downloading the app?|Confirm the source, review permissions, and make sure the package name matches the official listing.\nDoes this site promise winnings or financial gain?|No. The content is informational and does not guarantee outcomes or profits.";

$faqs = [];
$lines = preg_split('/[\r\n]+/', $faqRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line, 2);
    $question = trim($parts[0] ?? '');
    $answer = trim($parts[1] ?? '');
    
    if (!empty($question)) {
        $faqs[] = [
            'question' => $question,
            'answer' => $answer,
        ];
    }
}

$instanceId = 'sk-faq-' . uniqid();
?>

<section class="sk-faq" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .sk-faq-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
