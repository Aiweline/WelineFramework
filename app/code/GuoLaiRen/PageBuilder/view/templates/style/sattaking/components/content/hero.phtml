/**
 * Satta King 786 - Hero Section Component
 * 
 * 首屏英雄区域，包含标题、描述、CTA按钮、特性标签和右侧大图
 * 基于 https://www.insattaking786.com/ 原网站结构
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 顶部徽章文字:text:Satta king knowledge base
 * content.title => 主标题:textarea:Satta King 786 Guide to Satta Formats and Play
 * content.description => 描述文字:textarea:A balanced, encyclopedia-style view of satta king and satta, including result formats, timing cycles, and Android access. Seedhi bhasha, clear rules.
 * 
 * group:cta => 按钮设置
 * cta.primary_text => 主按钮文字:text:Get the Android App
 * cta.primary_url => 主按钮链接:text:#download
 * cta.primary_icon => 主按钮图标:select:download|download,android,arrow
 * cta.secondary_text => 次按钮文字:text:Explore Games
 * cta.secondary_url => 次按钮链接:text:#games
 * 
 * group:features => 特性标签
 * features.items => 特性列表:textarea:Result cycles decoded|Understand single, jodi, and panna formats used in satta king 786 listings.\r\nAndroid-first access|Lightweight app guidance with clear install steps and permission clarity.\r\nCompliance-friendly tone|Facts, definitions, and responsible use notes without promises of winnings.|格式：标题|描述，一行一个
 * 
 * group:visual => 视觉设置
 * visual.show_image => 显示右侧图片:select:yes|yes,no
 * visual.image_url => 图片URL:textarea:|留空使用默认装饰效果
 * visual.image_alt => 图片Alt文字:text:Opulent satta king interface banner
 * visual.layout => 布局模式:select:split|split,full-width|split=左右分栏,full-width=全宽
 * 
 * group:style => 样式设置
 * style.padding_top => 顶部内边距:number:120|px
 * style.padding_bottom => 底部内边距:number:80|px
 * style.title_size => 标题字号:number:3.5|rem
 * style.desc_size => 描述字号:number:1.25|rem
 * 
 * @fields_end
 */

$config = $component_config ?? [];

// 确保颜色变量可用
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$heroBg = $colors['hero_bg'] ?? 'linear-gradient(135deg, #1a1a3e 0%, #0f0f2e 50%, #0a0a1a 100%)';
$textPrimary = $colors['text_primary'] ?? '#ffffff';
$textSecondary = $colors['text_secondary'] ?? '#b8b8d0';
$accentPrimary = $colors['accent_primary'] ?? '#7c3aed';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a855f7';
$accentSecondary = $colors['accent_secondary'] ?? '#3b82f6';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(255, 255, 255, 0.08)';

// 内容配置 - 使用原网站文案
$badge = $config['content.badge'] ?? 'Satta king knowledge base';
$title = $config['content.title'] ?? 'Satta King 786 Guide to Satta Formats and Play';
$description = $config['content.description'] ?? 'A balanced, encyclopedia-style view of satta king and satta, including result formats, timing cycles, and Android access. Seedhi bhasha, clear rules.';

// CTA配置
$primaryBtnText = $config['cta.primary_text'] ?? 'Get the Android App';
$primaryBtnUrl = $config['cta.primary_url'] ?? '#download';
$primaryBtnIcon = $config['cta.primary_icon'] ?? 'download';
$secondaryBtnText = $config['cta.secondary_text'] ?? 'Explore Games';
$secondaryBtnUrl = $config['cta.secondary_url'] ?? '#games';

// 特性配置 - 使用原网站文案
$featuresRaw = $config['features.items'] ?? "Result cycles decoded|Understand single, jodi, and panna formats used in satta king 786 listings.\nAndroid-first access|Lightweight app guidance with clear install steps and permission clarity.\nCompliance-friendly tone|Facts, definitions, and responsible use notes without promises of winnings.";

$features = [];
$lines = preg_split('/[\r\n]+/', $featuresRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    
    $parts = explode('|', $line, 2);
    $featureTitle = trim($parts[0] ?? '');
    $featureDesc = trim($parts[1] ?? '');
    
    if (!empty($featureTitle)) {
        $features[] = [
            'title' => $featureTitle,
            'description' => $featureDesc,
        ];
    }
}

// 视觉配置
$showImage = ($config['visual.show_image'] ?? 'yes') !== 'no';
$imageUrl = $config['visual.image_url'] ?? '';
$imageAlt = $config['visual.image_alt'] ?? 'Opulent satta king interface banner';
$layout = $config['visual.layout'] ?? 'split';

// 样式配置
$paddingTop = $config['style.padding_top'] ?? '120';
$paddingBottom = $config['style.padding_bottom'] ?? '80';
$titleSize = $config['style.title_size'] ?? '3.5';
$descSize = $config['style.desc_size'] ?? '1.25';

$instanceId = 'sk-hero-' . uniqid();
?>

