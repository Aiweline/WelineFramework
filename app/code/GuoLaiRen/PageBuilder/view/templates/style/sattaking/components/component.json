{
    "template": "sattaking",
    "name": "Satta King 786",
    "description": "深紫蓝渐变风格主题，现代信息平台设计",
    "version": "1.0.0",
    "author": "GuoLaiRen",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部导航区域",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav"
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero", "features", "app-download", "platform", "games", "benefits", "download-reminder", "faq"]
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部链接和版权区域",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links"
        }
    },
    "components": {
        "header-nav": {
            "name": "导航栏",
            "name_en": "Navigation Header",
            "description": "页面顶部导航，支持Logo、导航链接和CTA按钮",
            "region": "header",
            "category": "header",
            "type": "section",
            "icon": "bi-menu-button-wide",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["header", "navigation", "download_button", "color_scheme"],
            "file": "header/nav.phtml",
            "default_config": {
                "logo.display": "yes",
                "logo.text": "Satta King 786",
                "logo.width": 40,
                "navigation.show_cta": "yes",
                "navigation.cta_text": "Download App",
                "navigation.cta_url": "#download"
            }
        },
        "hero": {
            "name": "首屏英雄区",
            "name_en": "Hero Section",
            "description": "首屏大图区域，包含标题、描述、CTA按钮和特性标签",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-badge-hd",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "cta", "style"],
            "file": "content/hero.phtml",
            "default_config": {
                "content.badge": "Guide & Platform",
                "content.title": "Satta King 786 Guide to Satta Formats and Play",
                "cta.primary_text": "Get the Android App",
                "cta.secondary_text": "Explore Games"
            }
        },
        "features": {
            "name": "特性展示",
            "name_en": "Features Section",
            "description": "展示平台核心功能特性，支持4列布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-stars",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "content/features.phtml",
            "default_config": {
                "content.badge": "Core Features",
                "content.title": "What the platform offers"
            }
        },
        "app-download": {
            "name": "应用下载",
            "name_en": "App Download Section",
            "description": "应用下载区域，包含下载按钮和安装指南",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-download",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "download", "style"],
            "file": "content/app-download.phtml",
            "default_config": {
                "content.badge": "App Download",
                "content.title": "Android access designed for clarity",
                "download.primary_text": "Primary Download"
            }
        },
        "platform": {
            "name": "平台概述",
            "name_en": "Platform Overview",
            "description": "展示平台数据结构和特性，6格布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-grid-3x2",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "content/platform.phtml",
            "default_config": {
                "content.badge": "Platform Overview",
                "content.title": "How data is structured on the platform"
            }
        },
        "games": {
            "name": "游戏/市场展示",
            "name_en": "Games Showcase",
            "description": "展示热门游戏或市场列表，4列卡片布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-controller",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["games", "style"],
            "file": "content/games.phtml",
            "default_config": {
                "content.badge": "Popular Games",
                "content.title": "Well-known markets and formats"
            }
        },
        "benefits": {
            "name": "用户优势",
            "name_en": "Benefits Section",
            "description": "展示使用平台的好处，2列布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-check-circle",
            "sort_order": 60,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "content/benefits.phtml",
            "default_config": {
                "content.badge": "Player Benefits",
                "content.title": "Why a structured hub matters"
            }
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ Section",
            "description": "FAQ手风琴展示，支持展开收起效果",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-question-circle",
            "sort_order": 70,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["faq", "style"],
            "file": "content/faq.phtml",
            "default_config": {
                "content.badge": "FAQ Snapshot",
                "content.title": "Quick answers about the platform"
            }
        },
        "download-reminder": {
            "name": "下载提醒",
            "name_en": "Download Reminder",
            "description": "下载提醒区块，引导用户下载应用",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-phone",
            "sort_order": 80,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "buttons", "style"],
            "file": "content/download-reminder.phtml",
            "default_config": {
                "content.badge": "Download Reminder",
                "content.title": "Keep satta updates organized on Android",
                "buttons.primary_text": "Download for Android",
                "buttons.secondary_text": "Read FAQ"
            }
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer with Links",
            "description": "简洁的页脚区域，包含品牌信息和导航链接",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "icon": "bi-layout-text-window-reverse",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "config_groups": ["style", "layout", "content", "typography"],
            "file": "footer/links.phtml",
            "default_config": {
                "brand.name": "Satta King 786",
                "brand.description": "An informational guide to satta king formats, schedules, and Android access. Always check local laws and follow responsible play practices.",
                "links.items": "Download App=>#download\nGames=>#games\nFAQ=>#faq\nContact=>/contact",
                "copyright.text": "Designed for clarity, speed, and compliance-first guidance."
            }
        },
        "legal-content": {
            "name": "法律文档",
            "name_en": "Legal Content",
            "description": "隐私政策、服务条款等；无本地文件时使用共享 legal-content 组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-file-earmark-text",
            "sort_order": 90,
            "is_default": false,
            "compatible_styles": ["*"],
            "config_groups": ["content", "style"],
            "file": "legal-content.phtml",
            "default_config": []
        }
    },
    "nav_config": {
        "description": "导航可使用子页面配置",
        "use_subpages": true,
        "subpage_types": ["link", "anchor", "page"],
        "default_items": [
            {"text": "Home", "href": "#home", "type": "anchor"},
            {"text": "Games", "href": "#games", "type": "anchor"},
            {"text": "FAQ", "href": "#faq", "type": "anchor"},
            {"text": "Download", "href": "#download", "type": "anchor"}
        ]
    },
    "config_inheritance": {
        "description": "组件可以继承模板的配置项",
        "shared_configs": ["styles", "texts", "color_scheme"]
    }
}
