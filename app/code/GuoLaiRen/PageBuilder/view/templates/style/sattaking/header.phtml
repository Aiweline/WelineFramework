        color: <?= htmlspecialchars($navTextColor) ?>;
    }
    
    .sk-logo-icon {
        width: <?= intval($logoWidth) ?>px;
        height: <?= intval($logoWidth) ?>px;
        background: <?= $buttonPrimaryBg ?>;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .sk-logo-icon svg {
        width: 20px;
        height: 20px;
        fill: #ffffff;
    }
    
    .sk-logo-text {
        font-size: 1.25rem;
        font-weight: 700;
    }
    
    .sk-nav {
