<?php
/**
 * Satta King 786 模板 - Header
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:Satta King 786
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 背景颜色:color:rgba(8, 8, 26, 0.95)
 * navigation.text_color => 文字颜色:color:#ffffff
 * navigation.link_hover_color => 链接悬停颜色:color:#a855f7
 * navigation.links => 导航链接:textarea:Home=>/\r\nGames=>/games\r\nDownload=>/download\r\nFAQ=>/faq|格式：名称=>链接，一行一个
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Download App
 * navigation.cta_url => CTA按钮链接:text:#download
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'sattaking';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'sattaking';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<!DOCTYPE html>
<html lang="<?= $this->getRequest()->getLang() ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($page ? $page->getData('title') : 'Satta King 786') ?></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 辅助函数
if (!function_exists('sk_color')) {
    function sk_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('sk_getConfig')) {
    function sk_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// Logo配置
$logoDisplay = sk_getConfig($styleSettings, 'logo.display', 'yes');
$logoText = sk_getConfig($styleSettings, 'logo.text', 'Satta King 786');
$logoUrl = sk_getConfig($styleSettings, 'logo.url', '');
$logoWidth = sk_getConfig($styleSettings, 'logo.width', '40');

// 导航配置
$navDisplay = sk_getConfig($styleSettings, 'navigation.display', 'yes');
$navBgColor = sk_getConfig($styleSettings, 'navigation.bg_color', 'rgba(8, 8, 26, 0.95)');
$navTextColor = sk_getConfig($styleSettings, 'navigation.text_color', '#ffffff');
$navLinkHoverColor = sk_getConfig($styleSettings, 'navigation.link_hover_color', '#a855f7');
$navLinksRaw = sk_getConfig($styleSettings, 'navigation.links', "Home=>/\nGames=>/games\nDownload=>/download\nFAQ=>/faq");
$showCta = sk_getConfig($styleSettings, 'navigation.show_cta', 'yes');
$ctaText = sk_getConfig($styleSettings, 'navigation.cta_text', 'Download App');
$ctaUrl = sk_getConfig($styleSettings, 'navigation.cta_url', '#download');

// 颜色配置
$accentPrimary = sk_color($colors, 'accent_primary', '#7c3aed');
$buttonPrimaryBg = sk_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%)');

// 解析导航链接
$navLinks = [];
$lines = preg_split('/[\r\n]+/', $navLinksRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('=>', $line, 2);
    $name = trim($parts[0] ?? '');
    $url = trim($parts[1] ?? '#');
    if (!empty($name)) {
        $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
?>

<?php if ($navDisplay === 'yes'): ?>
<style>
    .sk-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: <?= htmlspecialchars($navBgColor) ?>;
        backdrop-filter: blur(10px);
        padding: 15px 0;
