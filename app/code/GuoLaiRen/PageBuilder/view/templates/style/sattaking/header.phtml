<?php
// === 像素统计代码 ===
// 检测预览模式
$isPreviewMode = (bool)($this->getData('is_preview') ?? false);
if (!$isPreviewMode && isset($_GET['preview']) && $_GET['preview'] === '1') {
    $isPreviewMode = true;
}

// 读取像素配置（默认启用）
$pixelEnabled = sk_getConfig($styleSettings, 'pixel.enabled', 'yes');
$pixelEnabled = (string)($pixelEnabled ?? 'yes');
$pixelName = sk_getConfig($styleSettings, 'pixel.name', '');

// 如果像素名称为空，使用页面的 handle
if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}

// 获取 website_id（页面已有此字段，无需配置）
$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;

// 输出像素标签
if ($websiteId > 0 && !empty($pixelName) && !$isPreviewMode):
    // 设置 website_id Cookie，供像素代码读取
    \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_ID', (string)$websiteId, 3600 * 24 * 365);
    
    // 获取网站信息（用于像素统计）
    $websiteUrl = '';
    $websiteCode = '';
    try {
        if (class_exists('\Weline\Websites\Model\Website')) {
            $websiteModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Websites\Model\Website::class);
            $website = clone $websiteModel;
            $website->clear()->load($websiteId);
            if ($website->getId()) {
                $websiteUrl = $website->getData('url') ?? '';
                $websiteCode = $website->getData('code') ?? '';
            }
        }
    } catch (\Exception $e) {
        // 如果获取网站信息失败，不影响像素功能
    }
    
    // 设置 website_url Cookie
    if (!empty($websiteUrl)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_URL', $websiteUrl, 3600 * 24 * 365);
    }
    
    // 设置 website_code Cookie，用于区分不同站点
    if (!empty($websiteCode)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_CODE', $websiteCode, 3600 * 24 * 365);
    }
    
    // 使用变量传递方式，避免在标签属性中使用 PHP 标签
    $this->assign('pixel_name', htmlspecialchars($pixelName));
    $this->assign('pixel_enabled', htmlspecialchars($pixelEnabled));
?>
    <!-- Weline Visitor Pixel - 通过 enabled 属性控制是否统计，遵循模板配置中的 pixel.enabled 设置 -->
    <pixel name="{{pixel_name}}" enabled="{{pixel_enabled}}" />
<?php endif; ?>
