    }
    
    @media (max-width: 768px) {
        .sk-nav-links {
            display: none;
        }
        
        .sk-cta-btn span {
            display: none;
        }
        
        .sk-cta-btn {
            padding: 10px;
        }
    }
</style>

<header class="sk-header">
    <div class="sk-header-container">
        <?php if ($logoDisplay === 'yes'): ?>
        <a href="/" class="sk-logo">
            <span class="sk-logo-icon">
                <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>" style="width: 100%; height: 100%; object-fit: contain;">
                <?php else: ?>
                    <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                <?php endif; ?>
            </span>
            <span class="sk-logo-text"><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        
        <nav class="sk-nav">
            <ul class="sk-nav-links">
                <?php foreach ($navLinks as $link): ?>
                <li><a href="<?= htmlspecialchars($link['url']) ?>" class="sk-nav-link"><?= htmlspecialchars($link['name']) ?></a></li>
                <?php endforeach; ?>
            </ul>
            
            <?php if ($showCta === 'yes'): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="sk-cta-btn">
                <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
                <span><?= htmlspecialchars($ctaText) ?></span>
            </a>
            <?php endif; ?>
        </nav>
    </div>
</header>
<?php endif; ?>
