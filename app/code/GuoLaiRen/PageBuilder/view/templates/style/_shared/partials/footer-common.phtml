<?php
declare(strict_types=1);
/**
 * PageBuilder 全 style 公用尾部区：统一下载按钮委托 + 条件性 WelinePixel.send
 *
 * 在主题 layout.phtml 的 </body> 前引入一次：
 *   <?php echo $this->fetchTemplate('GuoLaiRen_PageBuilder::templates/style/_shared/partials/footer-common.phtml'); ?>
 *
 * 推荐：
 *   PHP：register(解析后的真实下载 URL, slot) 得 code（URL 的 SHA-256 → glr_+64hex）；模板 href 写 codeHref($code)（#+code），data-glr-ref 写同一段 code。点击按 code 查表跳转。
 *   亦可保留占位 href（如 /#register）；有有效注册目标时脚本可移除占位，避免误跳锚点。#glr_ 形式不会被剥。
 *
 * 调试：window.__GLR_PB_DOWNLOAD_DEBUG = true 或 ?glr_pb_debug=1 或 localStorage glr_pb_download_debug=1
 *
 * @var \Weline\Framework\View\Template $this
 */
$glrPbDownloadJson = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::toJsonForFooter();
?>
<style id="glr-pb-download-cursor">[data-glr-ref],a[href^="#glr_"]{cursor:pointer!important}[data-glr-ref] svg,a[href^="#glr_"] svg{pointer-events:none}</style>
<script type="application/json" id="glr-pb-download-registry"><?= $glrPbDownloadJson ?></script>
<script>
(function () {
    'use strict';

    var LOG_PREFIX = '[glr-pb-download]';

    function debugEnabled() {
        try {
            if (window.__GLR_PB_DOWNLOAD_DEBUG === true) {
                return true;
            }
        } catch (e0) { /* ignore */ }
        try {
            if (typeof location !== 'undefined' && location.search && location.search.indexOf('glr_pb_debug=1') !== -1) {
                return true;
            }
        } catch (e1) { /* ignore */ }
        try {
            if (typeof localStorage !== 'undefined' && localStorage.getItem('glr_pb_download_debug') === '1') {
                return true;
            }
        } catch (e2) { /* ignore */ }
        return false;
    }

    function logDbg(msg, extra) {
        if (!debugEnabled()) {
            return;
        }
        if (extra !== undefined) {
            console.log(LOG_PREFIX, msg, extra);
        } else {
            console.log(LOG_PREFIX, msg);
        }
    }

    /**
     * 每次点击重新读 DOM（避免闭包缓存空 map；重复 id 时取最后一个 JSON 块）
     */
    function readRegistryMapFresh() {
        var nodes = document.querySelectorAll('#glr-pb-download-registry');
        var el = nodes.length ? nodes[nodes.length - 1] : null;
        if (!el || !el.textContent) {
            logDbg('registry node missing or empty', { nodeCount: nodes.length });
            return {};
        }
        try {
            var parsed = JSON.parse(el.textContent);
            return parsed && parsed.map && typeof parsed.map === 'object' ? parsed.map : {};
        } catch (err) {
            logDbg('registry JSON parse failed', { error: String(err && err.message ? err.message : err) });
            return {};
        }
    }

    var slotToEvent = {
        primary: 'download-click',
        secondary: 'download-secondary',
        android: 'download-click',
        ios: 'download-click',
        url: 'download-click'
    };

    function isPreview() {
        try {
            return !!(window.__TRACKING_CONFIG__ && window.__TRACKING_CONFIG__.isPreview);
        } catch (e) {
            return false;
        }
    }

    function sendDownloadPixel(eventName, targetHref) {
        if (isPreview()) {
            logDbg('skip WelinePixel.send (preview mode)');
            return;
        }
        if (!window.WelinePixel || typeof window.WelinePixel.send !== 'function') {
            logDbg('WelinePixel.send not available', { hasWelinePixel: !!window.WelinePixel });
            return;
        }
        try {
            var base = window.WelinePixel.init
                ? JSON.parse(JSON.stringify(window.WelinePixel.init))
                : {};
            base.eventName = eventName;
            base.url = window.location.href;
            base.elementInfo = base.elementInfo || {
                tagName: 'A',
                className: '',
                id: '',
                innerText: '',
                href: targetHref || null,
                eventType: 'click'
            };
            base.elementInfo.href = targetHref || base.elementInfo.href;
            base.elementInfo.eventType = 'click';
            window.WelinePixel.send(base);
            logDbg('WelinePixel.send called', { eventName: eventName, href: targetHref });
        } catch (err) {
            logDbg('WelinePixel.send threw', { error: String(err && err.message ? err.message : err) });
        }
    }

    function isRegistryCodeHref(href) {
        // glr_ + sha256 hex（64）；极端哈希碰撞时可能为同格式另一段 64 hex
        return /^#glr_[0-9a-f]{64}$/i.test(String(href == null ? '' : href).trim());
    }

    function shouldNavigate(href) {
        if (!href || href === '#') {
            return false;
        }
        if (href.indexOf('javascript:') === 0) {
            return false;
        }
        if (isRegistryCodeHref(href)) {
            return false;
        }
        return true;
    }

    /**
     * 占位链接：无真实下载目标，仅作 SEO/占位（如 /#register、#register、#）
     * 注册表已提供真实 href 时可安全移除，避免点击先跳站内锚点。
     */
    function isPlaceholderDownloadHref(href) {
        if (href == null) {
            return false;
        }
        var h = String(href).trim();
        if (h === '' || h === '#') {
            return true;
        }
        if (/^javascript:/i.test(h)) {
            return false;
        }
        if (/^https?:\/\//i.test(h)) {
            return false;
        }
        if (/^mailto:/i.test(h) || /^tel:/i.test(h)) {
            return false;
        }
        if (/\.(apk|ipa|dmg|exe|zip)(\?|$)/i.test(h)) {
            return false;
        }
        if (isRegistryCodeHref(h)) {
            return false;
        }
        if (h.charAt(0) === '#' && h.indexOf('//') === -1) {
            return true;
        }
        if (/^\/#[^?#]+$/i.test(h)) {
            return true;
        }
        return false;
    }

    function stripPlaceholderHrefsForRegistry() {
        var refMap = readRegistryMapFresh();
        var nodes = document.querySelectorAll('[data-glr-ref]');
        for (var i = 0; i < nodes.length; i++) {
            var el = nodes[i];
            if (!el.getAttribute) {
                continue;
            }
            var ref = el.getAttribute('data-glr-ref');
            if (!ref || !refMap[ref]) {
                continue;
            }
            var entry = refMap[ref];
            var regHref = entry && entry.href ? entry.href : '';
            if (!shouldNavigate(regHref)) {
                continue;
            }
            var nat = el.getAttribute('href');
            if (nat == null) {
                continue;
            }
            if (!isPlaceholderDownloadHref(nat)) {
                continue;
            }
            el.removeAttribute('href');
            logDbg('stripped placeholder href (registry has real target)', { ref: ref, removed: nat });
        }
    }

    function runWhenDomReady(fn) {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fn);
        } else {
            fn();
        }
    }

    function navigate(href, el, slot, registryTarget) {
        var evName = slotToEvent[slot] || 'download-click';
        var canNav = shouldNavigate(href);
        logDbg('navigate()', { slot: slot, eventName: evName, href: href, shouldNavigate: canNav, registryTarget: registryTarget });
        if (!canNav) {
            logDbg('abort: shouldNavigate(href) is false');
            return;
        }
        sendDownloadPixel(evName, href);
        var openTarget = '_self';
        if (registryTarget && String(registryTarget).toLowerCase() === '_blank') {
            openTarget = '_blank';
        } else if (el && el.getAttribute) {
            var attrT = (el.getAttribute('data-glr-target') || '').trim().toLowerCase();
            if (attrT === '_blank') {
                openTarget = '_blank';
            }
        }
        if (openTarget === '_blank') {
            var w = window.open(href, '_blank', 'noopener,noreferrer');
            logDbg('window.open result', { opened: !!w, href: href });
        } else {
            logDbg('assign location.href', href);
            window.location.href = href;
        }
    }

    function findGlrDownloadClickEl(target) {
        if (!target || !target.closest) {
            return null;
        }
        var byAttr = target.closest('[data-glr-ref]');
        if (byAttr) {
            return byAttr;
        }
        var link = target.closest('a');
        if (link && isRegistryCodeHref(link.getAttribute('href'))) {
            return link;
        }
        return null;
    }

    function onDocClick(e) {
        var el = findGlrDownloadClickEl(e.target);
        if (el) {
            var ref = (el.getAttribute('data-glr-ref') || '').trim();
            if (!ref) {
                var hrefOnly = (el.getAttribute('href') || '').trim();
                if (isRegistryCodeHref(hrefOnly)) {
                    ref = hrefOnly.substring(1);
                }
            }
            var refMap = readRegistryMapFresh();
            logDbg('click glr-download', {
                tag: el.tagName,
                ref: ref,
                mapSize: Object.keys(refMap).length,
                inMap: !!(ref && refMap[ref]),
                nativeHref: el.getAttribute && el.getAttribute('href')
            });
            if (!ref) {
                return;
            }
            var entry = refMap[ref];
            if (entry) {
                e.preventDefault();
                var regHref = entry.href || '';
                if (!shouldNavigate(regHref)) {
                    var nh = el.getAttribute ? el.getAttribute('href') : null;
                    if (shouldNavigate(nh)) {
                        logDbg('registry href empty, using <a href> fallback', { ref: ref, href: nh });
                        navigate(nh, el, entry.slot || 'url', entry.target || '_self');
                    } else {
                        logDbg('registry href empty and no valid native href', { ref: ref });
                    }
                    return;
                }
                navigate(regHref, el, entry.slot || 'url', entry.target || '_self');
                return;
            }
            var nativeHref = el.getAttribute ? el.getAttribute('href') : null;
            if (isRegistryCodeHref(nativeHref)) {
                e.preventDefault();
                console.warn(LOG_PREFIX, 'ref 不在注册表但 href 为 #glr_ code，已阻止跳转。ref=', ref);
                return;
            }
            if (shouldNavigate(nativeHref)) {
                logDbg('registry miss → native navigation (href on <a>)', { ref: ref, href: nativeHref });
                return;
            }
            console.warn(LOG_PREFIX, 'ref 不在注册表且无有效 href，点击无效。ref=', ref, '可加 ?glr_pb_debug=1 查看 registry');
            e.preventDefault();
            return;
        }

        el = e.target && e.target.closest ? e.target.closest('a[data-glr-download][data-glr-href]') : null;
        if (!el) {
            return;
        }
        logDbg('click legacy a[data-glr-download][data-glr-href]');
        var slotLegacy = el.getAttribute('data-glr-download');
        var hrefLegacy = el.getAttribute('data-glr-href');
        if (!slotLegacy) {
            return;
        }
        e.preventDefault();
        navigate(hrefLegacy, el, slotLegacy, null);
    }

    if (!window.__GlrPbDownloadDocClickBound) {
        window.__GlrPbDownloadDocClickBound = true;
        document.addEventListener('click', onDocClick, true);
    }
    if (debugEnabled()) {
        var m = readRegistryMapFresh();
        logDbg('footer-common init', { mapEntryCount: Object.keys(m).length, sampleRefs: Object.keys(m).slice(0, 8) });
    }

    runWhenDomReady(function () {
        stripPlaceholderHrefsForRegistry();
    });
})();
</script>
