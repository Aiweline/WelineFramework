<?php
/**
 * 共享 — 法律文档展示组件（隐私政策、服务条款等）
 *
 * 默认文案由布局 JSON 中 `content.body` / `toc.items` 提供；`page.content` 可为空。
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 *
 * @fields_start
 *
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Legal
 * content.title => 标题:text:|留空使用页面标题
 * content.last_updated => 最后更新:text:
 * content.body => 引言/正文:textarea:
 * content.show_toc => 显示目录:select:yes|yes,no
 * content.show_last_updated => 显示更新日期:select:yes|yes,no
 *
 * group:toc => 章节（当页面内容为空时由配置渲染）
 * toc.items => 章节:textarea:标题|段落内容，一行一节
 *
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['section_bg_1'] ?? '#0d0020';
$textPrimary = $colors['text_primary'] ?? '#f5f3ff';
$textSecondary = $colors['text_secondary'] ?? '#c4b5fd';
$textMuted = $colors['text_muted'] ?? '#7c6fad';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#a78bfa';
$accentSecondary = $colors['accent_secondary'] ?? '#ec4899';
$cardBg = $colors['card_bg'] ?? 'rgba(255, 255, 255, 0.04)';
$borderLight = $colors['border_light'] ?? 'rgba(139, 92, 246, 0.12)';

$badge = $config['content.badge'] ?? 'Legal';
$showToc = ($config['content.show_toc'] ?? 'yes') !== 'no';

$page = $this->getData('page') ?? null;
$pageTitle = $page ? ($page->getData('title') ?? 'Legal Document') : 'Legal Document';
$pageContent = $page ? ($page->getData('content') ?? '') : '';

$title = trim($config['content.title'] ?? '') ?: $pageTitle;
$lastUpdatedConfig = trim($config['content.last_updated'] ?? '');
$lastUpdated = $lastUpdatedConfig ?: ($page ? ($page->getData('updated_at') ?? '') : '');
if (!$lastUpdated) {
    $lastUpdated = date('F j, Y');
}

if ($pageContent === '') {
    $body = trim($config['content.body'] ?? '');
    $tocRaw = $config['toc.items'] ?? '';
    $sections = [];
    foreach (preg_split('/[\r\n]+/', $tocRaw) as $line) {
        $line = trim($line);
        if ($line === '') continue;
        $parts = explode('|', $line, 2);
        $sTitle = trim($parts[0] ?? '');
        $sContent = trim($parts[1] ?? '');
        if ($sTitle !== '') {
            $sections[] = ['title' => $sTitle, 'content' => $sContent];
        }
    }
    if ($body !== '' || !empty($sections)) {
        $pageContent = '';
        if ($body !== '') {
            $pageContent .= '<p>' . nl2br(htmlspecialchars($body)) . '</p>';
        }
        foreach ($sections as $s) {
            $pageContent .= '<h2>' . htmlspecialchars($s['title']) . '</h2>';
            $pageContent .= '<p>' . nl2br(htmlspecialchars($s['content'])) . '</p>';
        }
    }
}
if ($pageContent === '') {
    $pageContent = '<p>' . __('Please add content to this page via the page editor or configure the component.') . '</p>';
}

$instanceId = 'le-legal-' . uniqid();
?>

<section id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }

        #<?= $instanceId ?> .le-legal-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }

        #<?= $instanceId ?> .le-legal-header {
            margin-bottom: 48px;
        }

        #<?= $instanceId ?> .le-legal-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(139, 92, 246, 0.15);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 700;
            color: <?= $accentPrimaryLight ?>;
            margin-bottom: 20px;
        }

        #<?= $instanceId ?> .le-legal-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 12px;
        }

        #<?= $instanceId ?> .le-legal-updated {
            font-size: 0.9rem;
            color: <?= $textMuted ?>;
        }

        #<?= $instanceId ?> .le-legal-content {
            font-size: 1.05rem;
            color: <?= $textSecondary ?>;
            line-height: 1.8;
        }

        #<?= $instanceId ?> .le-legal-content h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin: 40px 0 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid <?= $borderLight ?>;
        }

        #<?= $instanceId ?> .le-legal-content h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin: 32px 0 12px;
        }

        #<?= $instanceId ?> .le-legal-content p {
            margin-bottom: 16px;
        }

        #<?= $instanceId ?> .le-legal-content ul, #<?= $instanceId ?> .le-legal-content ol {
            padding-left: 24px;
            margin-bottom: 16px;
        }

        #<?= $instanceId ?> .le-legal-content li {
            margin-bottom: 8px;
            list-style: disc;
        }

        #<?= $instanceId ?> .le-legal-content a {
            color: <?= $accentPrimaryLight ?>;
            text-decoration: underline;
        }

        #<?= $instanceId ?> .le-legal-content a:hover {
            color: <?= $accentSecondary ?>;
        }

        @media (max-width: 576px) {
            #<?= $instanceId ?> .le-legal-title {
                font-size: 1.75rem;
            }
        }
    </style>

    <div class="le-legal-container">
        <div class="le-legal-header">
            <div class="le-legal-badge"><?= htmlspecialchars($badge) ?></div>
            <h1 class="le-legal-title"><?= htmlspecialchars($title) ?></h1>
            <p class="le-legal-updated"><?= __('Last updated') ?>: <?= htmlspecialchars(strtotime($lastUpdated) ? date('F j, Y', strtotime($lastUpdated)) : $lastUpdated) ?></p>
        </div>

        <div class="le-legal-content">
            <?= $pageContent ?>
        </div>
    </div>
</section>
