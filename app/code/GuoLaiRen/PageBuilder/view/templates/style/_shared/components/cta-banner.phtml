<?php
/**
 * 共享组件 - CTA 行动号召横幅
 * 
 * 通用的行动号召横幅组件，适用于所有模板
 * 
 * @component_start
 * name => 行动号召横幅
 * name_en => CTA Banner
 * description => 通用的行动号召横幅组件，支持标题、描述、按钮和背景设置
 * category => content
 * type => section
 * sort_order => 10
 * compatible_styles => *
 * @component_end
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.title => 标题:text:立即行动
 * content.subtitle => 副标题:text:开始您的旅程
 * content.description => 描述文字:textarea:加入我们，开启全新体验
 * content.button_text => 按钮文字:text:立即开始
 * content.button_url => 按钮链接:text:#
 * content.button_target => 新窗口打开:select:_self|_self,_blank
 * 
 * group:style => 样式设置
 * style.bg_type => 背景类型:select:color|color,gradient,image
 * style.bg_color => 背景颜色:color:#3498db
 * style.bg_gradient_start => 渐变起始色:color:#3498db
 * style.bg_gradient_end => 渐变结束色:color:#2c3e50
 * style.bg_image => 背景图片:text:
 * style.text_color => 文字颜色:color:#ffffff
 * style.button_bg => 按钮背景色:color:#ffffff
 * style.button_color => 按钮文字色:color:#3498db
 * style.padding => 内边距:select:medium|small,medium,large
 * style.text_align => 文字对齐:select:center|left,center,right
 * 
 * @fields_end
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $component_config 组件配置
 */

// 获取配置
$config = $this->getData('component_config') ?? [];

// 内容配置
$title = $config['content.title'] ?? '立即行动';
$subtitle = $config['content.subtitle'] ?? '';
$description = $config['content.description'] ?? '';
$buttonText = $config['content.button_text'] ?? '立即开始';
$buttonUrl = $config['content.button_url'] ?? '#';
$buttonTarget = $config['content.button_target'] ?? '_self';

// 样式配置
$bgType = $config['style.bg_type'] ?? 'color';
$bgColor = $config['style.bg_color'] ?? '#3498db';
$bgGradientStart = $config['style.bg_gradient_start'] ?? '#3498db';
$bgGradientEnd = $config['style.bg_gradient_end'] ?? '#2c3e50';
$bgImage = $config['style.bg_image'] ?? '';
$textColor = $config['style.text_color'] ?? '#ffffff';
$buttonBg = $config['style.button_bg'] ?? '#ffffff';
$buttonColor = $config['style.button_color'] ?? '#3498db';
$padding = $config['style.padding'] ?? 'medium';
$textAlign = $config['style.text_align'] ?? 'center';

// 计算背景样式
$bgStyle = match($bgType) {
    'gradient' => "background: linear-gradient(135deg, {$bgGradientStart}, {$bgGradientEnd});",
    'image' => "background: url('{$bgImage}') center/cover no-repeat;",
    default => "background-color: {$bgColor};",
};

// 计算内边距
$paddingStyle = match($padding) {
    'small' => 'padding: 2rem 1rem;',
    'large' => 'padding: 6rem 1rem;',
    default => 'padding: 4rem 1rem;',
};

// 生成唯一ID
$componentId = 'cta_' . uniqid();
?>

<section class="shared-cta-banner" id="<?= $componentId ?>">
    <style>
        #<?= $componentId ?> {
            <?= $bgStyle ?>
            <?= $paddingStyle ?>
            color: <?= $textColor ?>;
            text-align: <?= $textAlign ?>;
        }
        
        #<?= $componentId ?> .cta-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }
        
        #<?= $componentId ?> .cta-subtitle {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 1rem;
        }
        
        #<?= $componentId ?> .cta-description {
            font-size: 1.1rem;
            opacity: 0.85;
            margin-bottom: 2rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        
        #<?= $componentId ?> .cta-button {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: <?= $buttonBg ?>;
            color: <?= $buttonColor ?>;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        
        #<?= $componentId ?> .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }
        
        @media (max-width: 768px) {
            #<?= $componentId ?> .cta-title {
                font-size: 1.75rem;
            }
            
            #<?= $componentId ?> .cta-subtitle {
                font-size: 1rem;
            }
            
            #<?= $componentId ?> .cta-description {
                font-size: 1rem;
            }
        }
    </style>
    
    <div class="container">
        <?php if ($subtitle): ?>
        <p class="cta-subtitle"><?= htmlspecialchars($subtitle) ?></p>
        <?php endif; ?>
        
        <h2 class="cta-title"><?= htmlspecialchars($title) ?></h2>
        
        <?php if ($description): ?>
        <p class="cta-description"><?= htmlspecialchars($description) ?></p>
        <?php endif; ?>
        
        <?php if ($buttonText): ?>
        <a href="<?= htmlspecialchars($buttonUrl) ?>" 
           class="cta-button" 
           target="<?= htmlspecialchars($buttonTarget) ?>">
            <?= htmlspecialchars($buttonText) ?>
        </a>
        <?php endif; ?>
    </div>
</section>
