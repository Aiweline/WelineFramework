<?php
/**
 * Callbreak Sunlit Durbar - Blog List Component
 *
 * @component_start
 * code: blog-list
 * name: 博客列表
 * name_en: Blog List
 * description: Callbreak Sunlit Durbar 博客列表页，包含首篇文章、文章流与侧栏。
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * group:blog => 博客设置
 * blog.title => 博客列表标题:text:Latest Callbreak Sunlit Durbar Updates
 * blog.subtitle => 副标题:text:Tips, releases, and play-flow updates from the Sunlit Durbar desk
 * blog.posts_per_page => 每页文章数:number:9
 * blog.show_sidebar => 显示侧边栏:select:yes|yes,no
 * blog.show_category => 显示分类:select:yes|yes,no
 * blog.show_date => 显示日期:select:yes|yes,no
 * blog.show_author => 显示作者:select:yes|yes,no
 * blog.card_style => 卡片样式:select:default|default,minimal,featured
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', 'Latest Callbreak Sunlit Durbar Updates');
$subtitle = $getConfig('blog.subtitle', 'Tips, releases, and play-flow updates from the Sunlit Durbar desk');
$postsPerPage = max(1, (int)$getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = (string)$getConfig('blog.card_style', 'default');

$primaryColor = $getConfig('color_scheme.primary', '#ff7a45');
$secondaryColor = $getConfig('color_scheme.secondary', '#00cdb6');
$bgColor = $getConfig('color_scheme.background', '#fffaf0');
$textColor = $getConfig('color_scheme.text', '#332016');
$surfaceColor = $getConfig('color_scheme.surface', 'rgba(255,255,255,0.82)');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $posts[0] ?? null;
$streamPosts = array_slice($posts, 1);
$recent = !empty($recentPosts) ? array_slice($recentPosts, 0, 5) : array_slice($posts, 0, 5);

$formatDate = static function ($value) {
    if (!$value) {
        return '';
    }
    $timestamp = strtotime((string)$value);
    return $timestamp ? date('M d, Y', $timestamp) : (string)$value;
};

$spanClasses = ['span-7', 'span-5', 'span-4', 'span-8', 'span-6'];
$componentId = $component_instance_id ?? 'blog-list-' . uniqid();
?>

<section id="<?= $componentId ?>" class="durbar-journal-list style-<?= htmlspecialchars($cardStyle) ?>">
    <div class="section-inner">
        <header class="journal-head">
            <div class="head-copy" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                <p class="section-tag"><?= __('Journal') ?></p>
                <div class="head-row">
                    <h1><?= htmlspecialchars((string)$title) ?></h1>
                    <?php if (!empty($posts)): ?>
                        <span class="post-count"><?= count($posts) ?> <?= __('Stories') ?></span>
                    <?php endif; ?>
                </div>
                <?php if ($subtitle): ?>
                    <p class="head-summary"><?= htmlspecialchars((string)$subtitle) ?></p>
                <?php endif; ?>
            </div>

            <?php if (!empty($blogCategories)): ?>
                <nav class="category-ribbon" aria-label="Blog categories" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="90ms">
                    <?php foreach ($blogCategories as $category): ?>
                        <?php if (empty($category['name'])) continue; ?>
                        <a href="<?= htmlspecialchars((string)($category['url'] ?? '#')) ?>">
                            <span><?= htmlspecialchars((string)$category['name']) ?></span>
                            <?php if (isset($category['post_count'])): ?>
                                <em><?= (int)$category['post_count'] ?></em>
                            <?php endif; ?>
                        </a>
                    <?php endforeach; ?>
                </nav>
            <?php endif; ?>
        </header>

        <?php if (empty($posts)): ?>
            <article class="empty-state" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                <h2><?= __('No posts yet') ?></h2>
                <p><?= __('Fresh strategy notes and release updates will appear here soon.') ?></p>
            </article>
        <?php else: ?>
            <div class="journal-layout<?= $showSidebar ? ' with-sidebar' : '' ?>">
                <main class="journal-main">
                    <?php if ($featuredPost): ?>
                        <?php
                        $featuredUrl = (string)($featuredPost['url'] ?? '#');
                        $featuredTitle = (string)($featuredPost['title'] ?? __('Untitled Post'));
                        $featuredSummary = (string)($featuredPost['summary'] ?? '');
                        $featuredImage = (string)($featuredPost['cover_image'] ?? '');
                        $featuredCategory = (string)($featuredPost['category_name'] ?? '');
                        $featuredDate = $formatDate($featuredPost['published_at'] ?? '');
                        $featuredAuthor = (string)($featuredPost['author'] ?? '');
                        ?>
                        <article class="lead-story<?= $featuredImage === '' ? ' no-image' : '' ?>" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                            <div class="lead-copy">
                                <div class="story-meta">
                                    <?php if ($showCategory && $featuredCategory !== ''): ?>
                                        <span class="story-chip"><?= htmlspecialchars($featuredCategory) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && $featuredDate !== ''): ?>
                                        <span class="story-date"><?= htmlspecialchars($featuredDate) ?></span>
                                    <?php endif; ?>
                                </div>

                                <h2><a href="<?= htmlspecialchars($featuredUrl) ?>"><?= htmlspecialchars($featuredTitle) ?></a></h2>

                                <?php if ($featuredSummary !== ''): ?>
                                    <p class="lead-summary"><?= htmlspecialchars(mb_substr($featuredSummary, 0, 240)) ?><?= mb_strlen($featuredSummary) > 240 ? '...' : '' ?></p>
                                <?php endif; ?>

                                <div class="lead-foot">
                                    <?php if ($showAuthor && $featuredAuthor !== ''): ?>
                                        <span class="story-author"><?= htmlspecialchars($featuredAuthor) ?></span>
                                    <?php endif; ?>
                                    <a class="story-link" href="<?= htmlspecialchars($featuredUrl) ?>"><?= __('Read Story') ?></a>
                                </div>
                            </div>

                            <?php if ($featuredImage !== ''): ?>
                                <a class="lead-media" href="<?= htmlspecialchars($featuredUrl) ?>">
                                    <img src="<?= htmlspecialchars($featuredImage) ?>" alt="<?= htmlspecialchars($featuredTitle) ?>" loading="lazy" decoding="async">
                                </a>
                            <?php endif; ?>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($streamPosts)): ?>
                        <div class="story-stack">
                            <?php foreach ($streamPosts as $index => $post): ?>
                                <?php
                                $postUrl = (string)($post['url'] ?? '#');
                                $postTitle = (string)($post['title'] ?? __('Untitled Post'));
                                $postSummary = (string)($post['summary'] ?? '');
                                $postImage = (string)($post['cover_image'] ?? '');
                                $postCategory = (string)($post['category_name'] ?? '');
                                $postDate = $formatDate($post['published_at'] ?? '');
                                $postAuthor = (string)($post['author'] ?? '');
                                $spanClass = $spanClasses[$index % count($spanClasses)];
                                $toneClass = 'tone-' . (($index % 3) + 1);
                                $isHeroTile = $cardStyle === 'featured' && $index === 0;
                                ?>
                                <article class="story-card <?= htmlspecialchars($spanClass) ?> <?= htmlspecialchars($toneClass) ?><?= $isHeroTile ? ' is-hero-tile' : '' ?><?= $postImage === '' ? ' no-image' : '' ?>" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="<?= min($index * 70, 280) ?>ms">
                                    <?php if ($postImage !== ''): ?>
                                        <a class="story-media" href="<?= htmlspecialchars($postUrl) ?>">
                                            <img src="<?= htmlspecialchars($postImage) ?>" alt="<?= htmlspecialchars($postTitle) ?>" loading="lazy" decoding="async">
                                        </a>
                                    <?php endif; ?>

                                    <div class="story-body">
                                        <div class="story-meta">
                                            <?php if ($showCategory && $postCategory !== ''): ?>
                                                <span class="story-chip"><?= htmlspecialchars($postCategory) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && $postDate !== ''): ?>
                                                <span class="story-date"><?= htmlspecialchars($postDate) ?></span>
                                            <?php endif; ?>
                                        </div>

                                        <h3><a href="<?= htmlspecialchars($postUrl) ?>"><?= htmlspecialchars($postTitle) ?></a></h3>

                                        <?php if ($postSummary !== ''): ?>
                                            <p class="story-excerpt"><?= htmlspecialchars(mb_substr($postSummary, 0, 170)) ?><?= mb_strlen($postSummary) > 170 ? '...' : '' ?></p>
                                        <?php endif; ?>

                                        <div class="story-foot">
                                            <?php if ($showAuthor && $postAuthor !== ''): ?>
                                                <span class="story-author"><?= htmlspecialchars($postAuthor) ?></span>
                                            <?php endif; ?>
                                            <a class="story-link" href="<?= htmlspecialchars($postUrl) ?>"><?= __('Read More') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </main>

                <?php if ($showSidebar): ?>
                    <aside class="journal-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                                <h2><?= __('Categories') ?></h2>
                                <div class="rail-category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php if (empty($category['name'])) continue; ?>
                                        <a href="<?= htmlspecialchars((string)($category['url'] ?? '#')) ?>">
                                            <span><?= htmlspecialchars((string)$category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <em><?= (int)$category['post_count'] ?></em>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recent)): ?>
                            <section class="rail-card" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="100ms">
                                <h2><?= __('Recent Posts') ?></h2>
                                <div class="recent-stack">
                                    <?php foreach ($recent as $post): ?>
                                        <?php
                                        $recentUrl = (string)($post['url'] ?? '#');
                                        $recentTitle = (string)($post['title'] ?? __('Untitled Post'));
                                        $recentDate = $formatDate($post['published_at'] ?? '');
                                        ?>
                                        <a href="<?= htmlspecialchars($recentUrl) ?>">
                                            <strong><?= htmlspecialchars($recentTitle) ?></strong>
                                            <?php if ($recentDate !== ''): ?>
                                                <span><?= htmlspecialchars($recentDate) ?></span>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

