$desc1 = $getConfig('texts.advantage_1_desc', $defaultCards[0]['desc']);
$title2 = $getConfig('texts.advantage_2_title', $defaultCards[1]['title']);
$desc2 = $getConfig('texts.advantage_2_desc', $defaultCards[1]['desc']);
$title3 = $getConfig('texts.advantage_3_title', $defaultCards[2]['title']);
$desc3 = $getConfig('texts.advantage_3_desc', $defaultCards[2]['desc']);

$cards = [
    ['icon' => $icon1, 'title' => $title1, 'desc' => $desc1, 'index' => '01', 'tone' => 'sun'],
    ['icon' => $icon2, 'title' => $title2, 'desc' => $desc2, 'index' => '02', 'tone' => 'mint'],
    ['icon' => $icon3, 'title' => $title3, 'desc' => $desc3, 'index' => '03', 'tone' => 'rose'],
];
$markerEffects = ['animate__fadeInLeft', 'animate__zoomIn', 'animate__fadeInRight'];
?>
<section id="<?= $componentId ?>" class="durbar-advantages" aria-labelledby="<?= $componentId ?>-title">
    <span class="adv-deco adv-deco-a" aria-hidden="true"></span>
    <span class="adv-deco adv-deco-b" aria-hidden="true"></span>
    <span class="adv-deco adv-deco-c" aria-hidden="true"></span>
    <div class="section-inner">
        <div class="adv-stage">
            <header class="adv-command"<?= $showTitle ? '' : ' aria-hidden="true"' ?>>
                <?php if ($showTitle): ?>
                    <span class="adv-head-mark" data-durbar-reveal data-durbar-effect="animate__fadeInDown" aria-hidden="true">
                        <span class="adv-mark-node adv-mark-node-a"></span>
                        <span class="adv-mark-track"></span>
                        <span class="adv-mark-node adv-mark-node-b"></span>
                    </span>
                    <h2 id="<?= $componentId ?>-title" data-durbar-reveal data-durbar-effect="animate__fadeInLeft"><?= htmlspecialchars($title) ?></h2>
                    <?php if ($summary !== ''): ?>
                        <p class="adv-summary" data-durbar-reveal data-durbar-effect="animate__fadeInLeft" data-wow-delay="60ms"><?= htmlspecialchars($summary) ?></p>
                    <?php endif; ?>
                <?php endif; ?>
                <?php if ($showButton): ?>
                    <a href="<?= htmlspecialchars($btnUrl) ?>" class="adv-cta" data-durbar-reveal data-durbar-effect="animate__zoomIn" data-wow-delay="80ms"><?= htmlspecialchars($btnText) ?></a>
                <?php endif; ?>
            </header>

            <div class="adv-route" aria-label="Core advantages">
                <span class="adv-route-line" aria-hidden="true"></span>
                <?php foreach ($cards as $index => $card): ?>
                    <?php $markerEffect = $markerEffects[$index % count($markerEffects)]; ?>
                    <article class="adv-marker adv-marker-<?= (int)($index + 1) ?> adv-tone-<?= htmlspecialchars($card['tone']) ?>" data-durbar-reveal data-durbar-effect="<?= htmlspecialchars($markerEffect) ?>" data-wow-delay="<?= htmlspecialchars((string)(120 + ($index * 100))) ?>ms">
                        <span class="adv-marker-index"><?= htmlspecialchars($card['index']) ?></span>
                        <div class="adv-marker-media">
                            <img src="<?= htmlspecialchars($card['icon']) ?>" alt="<?= htmlspecialchars($card['title']) ?>" loading="lazy" decoding="async">
                        </div>
                        <div class="adv-marker-copy">
                            <h3><?= htmlspecialchars($card['title']) ?></h3>
                            <?php if ($showDescription): ?>
                                <p><?= htmlspecialchars($card['desc']) ?></p>
                            <?php endif; ?>
                        </div>
                    </article>
                <?php endforeach; ?>
