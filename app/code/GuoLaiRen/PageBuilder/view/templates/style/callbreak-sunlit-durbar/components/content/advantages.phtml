<?php
/**
 * Callbreak Sunlit Durbar - Advantages Component
 *
 * @component_start
 * code: advantages
 * name: 优势展示
 * name_en: Advantages Section
 * description: Display core benefits with a promenade-style responsive layout.
 * category: content
 * region: content
 * thumbnail: asset/img/our-advantages/icon01.webp
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_description => 显示描述:select:yes|yes,no
 * display.show_button => 显示按钮:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#ddfff5
 * style.title_color => 标题颜色:color:#3d2217
 * style.title_font_size => 标题字号(PC端):number:36|px
 * style.title_font_size_mobile => 标题字号(移动端):number:24|px
 * style.card_title_color => 卡片标题颜色:color:#3d2217
 * style.card_title_font_size => 卡片标题字号:number:18|px
 * style.card_desc_color => 卡片描述颜色:color:#6b4e41
 * style.card_desc_font_size => 卡片描述字号:number:14|px
 * style.icon_size => 图标尺寸:number:85|px
 * style.icon_border_radius => 图标圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * style.card_gap => 卡片间距:number:30|px
 *
 * group:button => 按钮配置
 * button.text => 按钮文本:text:Join Table
 * button.url => 按钮链接:text:#download
 * button.bg_gradient_start => 按钮渐变起始色:color:#ffd661
 * button.bg_gradient_end => 按钮渐变结束色:color:#ff764d
 * button.text_color => 按钮文字颜色:color:#2b140d
 * button.border_radius => 按钮圆角:number:999|px
 * button.padding_x => 按钮水平内边距:number:32|px
 * button.padding_y => 按钮垂直内边距:number:10|px
 *
 * group:icons => 图标配置
 * icons.icon_1 => 优势1图标:textarea:|默认使用本地icon01.webp
 * icons.icon_2 => 优势2图标:textarea:|默认使用本地icon02.webp
 * icons.icon_3 => 优势3图标:textarea:|默认使用本地icon03.webp
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Why Callbreak Feels Better In Daylight
 * texts.summary => 区域说明:textarea:Play feels brighter when routes, reads, and round tempo are separated into clear table lanes.
 * texts.advantage_1_title => 优势1标题:text:Faster Table Entry
 * texts.advantage_1_desc => 优势1描述:textarea:Jump into active callbreak rooms with fewer taps, clearer route labels, and stronger mobile focus.
 * texts.advantage_2_title => 优势2标题:text:Sharper Trump Reading
 * texts.advantage_2_desc => 优势2描述:textarea:Bright contrast zones make score states, trick flow, and decision moments easier to read at a glance.
 * texts.advantage_3_title => 优势3标题:text:Four-Seat Rhythm
 * texts.advantage_3_desc => 优势3描述:textarea:The layout is tuned for partnership-table energy, keeping action visible without crowding the screen.
 *
 * @fields_end
