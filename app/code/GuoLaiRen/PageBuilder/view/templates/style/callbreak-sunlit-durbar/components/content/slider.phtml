<?php
/**
 * Callbreak Sunlit Durbar 轮播组件 - Slider Component
 * 
 * @component_start
 * code: slider
 * name: 轮播横幅
 * name_en: Banner Slider
 * description: 首屏轮播Banner，支持多图轮播和自动播放
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.webp
 * @component_end
 * 
 * @fields_start
 * 
 * group:slider => 轮播设置
 * slider.display => 显示轮播:select:yes|yes,no
 * slider.autoplay => 自动播放:select:yes|yes,no
 * slider.autoplay_interval => 播放间隔:number:5000|毫秒
 * slider.bg_color => 背景颜色:color:#fff6ea
 * slider.banner_image_mobile => 移动端图片:textarea:|默认使用本地banner-2.jpg
 * slider.banner_image_desktop => PC端图片:textarea:|默认使用本地banner-03.webp
 * slider.download_btn_image => 下载按钮图片:textarea:|默认使用download-btn-m.webp
 * slider.alt => 图片描述:text:Callbreak Sunlit Durbar launch board
 * 
 * @fields_end
 */

$componentId = 'durbar-slider-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

// 轮播配置
$sliderDisplay = $getConfig('slider.display', 'yes') !== 'no';
$sliderAutoplay = $getConfig('slider.autoplay', 'yes') !== 'no';
$sliderInterval = intval($getConfig('slider.autoplay_interval', '5000'));
$sliderBgColor = $getConfig('slider.bg_color', '#fff6ea');
$sliderBgGradientEnd = '#1d1850';

// 图片配置
$defaultBannerMobile = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/banner-2.jpg');
$defaultBannerDesktop = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/banner-03.webp');
$defaultDownloadBtn = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/download-btn-m.webp');

$bannerMobile = $getConfig('slider.banner_image_mobile', '') ?: $defaultBannerMobile;
$bannerDesktop = $getConfig('slider.banner_image_desktop', '') ?: $defaultBannerDesktop;
$downloadBtnImg = $getConfig('slider.download_btn_image', '') ?: $defaultDownloadBtn;
$bannerAlt = $getConfig('slider.alt', 'Callbreak Sunlit Durbar launch board');

if (!$sliderDisplay) return;
?>
<!-- Durbar Slider Component Start: <?= $componentId ?> -->
<style>
#<?= $componentId ?> {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, <?= htmlspecialchars($sliderBgColor) ?> 0%, <?= htmlspecialchars($sliderBgGradientEnd) ?> 100%);
}

#<?= $componentId ?> .durbar-slider-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    margin-left: -12px;
    margin-right: -12px;
}

#<?= $componentId ?> .durbar-slider-slide {
    text-align: center;
    width: 100%;
}

#<?= $componentId ?> .durbar-slider-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    margin-top: -90px;
}

#<?= $componentId ?> .durbar-slider-download {
    position: absolute;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    cursor: pointer;
    margin: 0;
}

#<?= $componentId ?> .durbar-slider-download img {
    animation: <?= $componentId ?>-zoom 2s infinite;
}

@keyframes <?= $componentId ?>-zoom {
    0% { transform: scale(1); }
    50% { transform: scale(0.9); }
    100% { transform: scale(1); }
}

@media (max-width: 991px) {
    #<?= $componentId ?> {
        margin-top: -75px;
    }
    
    #<?= $componentId ?> .durbar-slider-img {
        margin-top: 0;
        min-width: 100vw;
    }
}
</style>

<section id="<?= $componentId ?>" class="durbar-slider-component">
    <div class="durbar-slider-inner">
        <div class="durbar-slider-slide">
            <picture>
                <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerMobile) ?>">
                <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerDesktop) ?>">
                <img class="durbar-slider-img" 
                     src="<?= htmlspecialchars($bannerMobile) ?>" 
                     alt="<?= htmlspecialchars($bannerAlt) ?>" 
                     fetchpriority="high" 
                     decoding="async">
            </picture>
        </div>
        <p class="durbar-slider-download">
            <img src="<?= htmlspecialchars($downloadBtnImg) ?>" 
                 alt="Download App" 
                 width="210" 
                 height="54">
        </p>
    </div>
</section>
<!-- Durbar Slider Component End: <?= $componentId ?> -->
