<?php
/**
 * Callbreak Sunlit Durbar - Header
 *
 * @fields_start
 *
 * group:header_logo => 头部品牌
 * header.logo.display => 显示Logo:select:yes|yes,no
 * header.logo.text => Logo文本:text:Callbreak Sunlit Durbar
 * header.logo.subline => Logo副标题:text:Sunlit four-player callbreak arena
 * header.logo.url => Logo地址:textarea:|默认使用本地durbar-logo-icon.svg
 * header.logo.width => Logo宽度:responsive:70/70|px
 * header.logo.height => Logo高度:responsive:|px
 *
 * group:header_navigation => 导航设置
 * header.navigation.display => 显示导航:select:yes|yes,no
 * header.navigation.items => 导航项配置:textarea:Home=>/\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQs=>/faqs|格式：名称=>链接
 * header.navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * header.navigation.mobile_menu_label => 移动端菜单标题:text:Menu
 * group:header_navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * header.navigation.label_home_page => 首页菜单名:text:
 * header.navigation.label_about_page => 关于我们菜单名:text:
 * header.navigation.label_blog_list => 博客菜单名:text:
 * header.navigation.label_contact_page => 联系我们菜单名:text:
 * header.navigation.label_terms_of_service => 条款菜单名:text:
 * header.navigation.label_privacy_policy => 隐私政策菜单名:text:
 *
 * group:header_download_button => 下载按钮
 * header.download_button.display => 显示下载按钮:select:yes|yes,no
 * header.download_button.text => 按钮文本:text:Download App
 * header.download_button.url => 按钮链接:text:#download
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

$templateCode = $page ? $page->getData('style') : 'callbreak-sunlit-durbar';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'callbreak-sunlit-durbar';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('__csd_shell_managed', true);
$this->assign('__pagebuilder_shell_managed', true);
?>
<?= $this->fetchTemplate('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/components/header/nav.phtml') ?>
