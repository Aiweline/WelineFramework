<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var normalizeUrl = function (url) {
        if (!url) {
            return window.location.href;
        }
        if (/^https?:\/\//i.test(url)) {
            return url;
        }
        if (url.charAt(0) !== '/') {
            url = '/' + url;
        }
        return window.location.origin.replace(/\/$/, '') + url;
    };

    root.addEventListener('click', function (event) {
        var button = event.target.closest('[data-share]');
        if (!button) {
            return;
        }

        var type = button.getAttribute('data-share');
        var url = encodeURIComponent(normalizeUrl(button.getAttribute('data-url') || ''));
        var title = encodeURIComponent(button.getAttribute('data-title') || document.title || '');
        var shareUrl = '';

        if (type === 'facebook') {
            shareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + url;
        } else if (type === 'twitter') {
            shareUrl = 'https://twitter.com/intent/tweet?url=' + url + '&text=' + title;
        } else if (type === 'linkedin') {
            shareUrl = 'https://www.linkedin.com/shareArticle?mini=true&url=' + url + '&title=' + title;
        } else if (type === 'copy') {
            var plainUrl = decodeURIComponent(url);
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(plainUrl).then(function () {
                    button.textContent = 'Copied';
                    setTimeout(function () {
                        button.textContent = 'Copy';
                    }, 1600);
                });
            }
            return;
        }

        if (shareUrl !== '') {
            window.open(shareUrl, '_blank', 'noopener,noreferrer,width=640,height=720');
        }
    });
})();
</script>
