<?php
/**
 * Callbreak Sunlit Durbar - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: 首屏轮播Banner
 * name_en: Hero Slider
 * description: Bright callbreak hero stage with a center court image and detached download rail.
 * category: content
 * region: content
 * thumbnail: asset/img/banner-03.webp
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner设置
 * banner.display => 显示Banner:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|默认使用本地durbar-hero-stage.svg
 * banner.image_desktop => 桌面端Banner图片:textarea:|默认使用本地durbar-hero-stage.svg
 * banner.alt => Banner图片描述:text:Callbreak Sunlit Durbar launch board
 * banner.bg_color => Banner背景色:color:#fff4d8
 *
 * group:hero => Hero文案
 * hero.title => Hero标题:text:
 * hero.subtitle => Hero副标题:textarea:
 * hero.stage_text => Hero舞台文案:text:
 *
 * group:app_info => 应用信息
 * app_info.app_name => 应用名称:text:Callbreak Sunlit Durbar
 * app_info.app_size => 应用大小:text:82.4 MB
 * app_info.app_version => 版本:text:V6.1
 *
 * group:download_btn => 下载按钮
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.image => 下载徽章图片:textarea:|默认使用本地durbar-floating-badge.svg
 * download_btn.alt => 下载按钮文案:text:Download App
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局设置
 * layout.slider_classes => 附加类名:textarea:rs-slider slider-style2
 * layout.margin_top => 顶部偏移:number:0|px
 * layout.img_margin_top => 媒体偏移:number:0|px
 *
 * @fields_end
 */

$page = $this->getData('page') ?? null;
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$bannerDisplayRaw = $getConfig('banner.display', 'yes');
$bannerDisplay = ($bannerDisplayRaw === 'yes' || $bannerDisplayRaw === true || $bannerDisplayRaw === 'true' || $bannerDisplayRaw === 0 || $bannerDisplayRaw === '0');
if (!$bannerDisplay) {
    return;
}

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sanitizeTitle = static function ($value) {
    $value = trim((string)$value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$defaultStage = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/durbar-hero-stage.svg');
$defaultDownloadBadge = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/durbar-floating-badge.svg');

$bannerImageMobile = trim((string)$getConfig('banner.image_mobile', '')) ?: $defaultStage;
$bannerImageDesktop = trim((string)$getConfig('banner.image_desktop', '')) ?: $defaultStage;
$bannerAlt = trim((string)$getConfig('banner.alt', 'Callbreak Sunlit Durbar launch board'));
$bannerBgColor = (string)$getConfig('banner.bg_color', $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#fff4d8'));
$bannerBgGradientEnd = (string)$getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe4a8');

$downloadBtnDisplayRaw = $getConfig('download_btn.display', 'yes');
$downloadBtnDisplay = ($downloadBtnDisplayRaw === 'yes' || $downloadBtnDisplayRaw === true || $downloadBtnDisplayRaw === 'true' || $downloadBtnDisplayRaw === 0 || $downloadBtnDisplayRaw === '0');
$downloadBtnImage = trim((string)$getConfig('download_btn.image', '')) ?: $defaultDownloadBadge;
$downloadBtnLabel = trim((string)$getConfig('download_btn.alt', 'Download App'));
if ($downloadBtnLabel === '') {
    $downloadBtnLabel = 'Download App';
}
$downloadBtnUrl = (string)$getConfig('download_btn.url', '#download');
$downloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$downloadBtnUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadHref, 'url');

$sliderClasses = trim((string)$getConfig('layout.slider_classes', 'rs-slider slider-style2'));
$marginTop = (int)$getConfig('layout.margin_top', '0');
$imgMarginTop = (int)$getConfig('layout.img_margin_top', '0');

$appName = $sanitizeTitle((string)$getConfig('app_info.app_name', ''));
if ($appName === '') {
    $appName = 'Callbreak Sunlit Durbar';
}
$pageTitleFallback = $page ? $sanitizeTitle((string)($page->getData('title') ?: $page->getData('meta_title') ?: $appName)) : $appName;
$pageTitle = $sanitizeTitle((string)$getConfig('hero.title', $pageTitleFallback));
if ($pageTitle === '') {
    $pageTitle = $appName;
}

$subtitle = trim((string)$getConfig('hero.subtitle', $page ? (string)($page->getData('meta_description') ?: '') : ''));
if ($subtitle === '') {
    $subtitle = $bannerAlt !== $pageTitle ? $bannerAlt : 'Fast four-player callbreak rounds with a brighter day-table rhythm.';
}

$stageText = trim((string)$getConfig('hero.stage_text', ''));
if ($stageText === '') {
    $stageText = $bannerAlt !== '' ? $bannerAlt : $pageTitle;
}

$titleColor = (string)$getConfig('hero.title_color', $colors['heading_color'] ?? '#402217');
$subtitleColor = (string)$getConfig('hero.text_color', $colors['text_secondary'] ?? '#6b4e41');
$statLabelColor = (string)($colors['text_muted'] ?? '#9b7967');
$accentCoral = (string)($colors['accent_primary'] ?? '#ff7a45');
$accentMint = (string)($colors['accent_primary_vibrant'] ?? '#00cdb6');
$accentGold = (string)($colors['accent_secondary'] ?? '#ffd24d');

$appSize = trim((string)$getConfig('app_info.app_size', '82.4 MB'));
$appVersion = trim((string)$getConfig('app_info.app_version', 'V6.1'));

$componentId = 'csd-hero-' . uniqid();
$headingId = $componentId . '-title';
?>
<section
    id="main-content"
    class="csd-hero-section <?= htmlspecialchars($sliderClasses) ?>"
    style="--csd-hero-offset: <?= $marginTop ?>px; --csd-media-offset: <?= $imgMarginTop ?>px;"
    aria-labelledby="<?= htmlspecialchars($headingId) ?>"
>
    <div id="<?= $componentId ?>" class="csd-hero-shell">
        <span class="csd-suit csd-suit-a" aria-hidden="true">♦</span>
        <span class="csd-suit csd-suit-b" aria-hidden="true">♣</span>
        <span class="csd-suit csd-suit-c" aria-hidden="true">♥</span>
