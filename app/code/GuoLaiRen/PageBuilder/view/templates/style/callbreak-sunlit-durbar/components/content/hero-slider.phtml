                    <div class="csd-stage-ribbon-copy">
                        <span><?= htmlspecialchars($appName) ?></span>
                        <strong><?= htmlspecialchars($stageText) ?></strong>
                    </div>

                    <?php if ($downloadBtnDisplay): ?>
                        <a
                            role="button"
                            tabindex="0"
                            class="csd-download-ticket"
                            id="download"
                            href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($downloadRef)) ?>"
                            data-glr-ref="<?= htmlspecialchars($downloadRef) ?>"
                        >
                            <span class="csd-download-mark" aria-hidden="true">⇣</span>
                            <span class="csd-download-copy">
                                <strong><?= htmlspecialchars($downloadBtnLabel) ?></strong>
                                <small><?= htmlspecialchars($appVersion) ?> · <?= htmlspecialchars($appSize) ?></small>
                            </span>
                        </a>
                    <?php endif; ?>
                </div>

                <div class="csd-stage-court" data-durbar-reveal data-durbar-effect="animate__zoomIn">
                    <span class="csd-stage-burst" aria-hidden="true"></span>
                    <span class="csd-stage-path csd-stage-path-a" aria-hidden="true"></span>
                    <span class="csd-stage-path csd-stage-path-b" aria-hidden="true"></span>

                    <span class="csd-stage-hanger csd-stage-hanger-left" aria-hidden="true">
                        <i>♠</i>
                        <strong><?= htmlspecialchars($appVersion) ?></strong>
                    </span>

                    <span class="csd-stage-hanger csd-stage-hanger-right" aria-hidden="true">
                        <i>♥</i>
                        <strong><?= htmlspecialchars($appSize) ?></strong>
                    </span>

                    <figure class="csd-sun-stage">
                        <picture>
                            <source media="(max-width: 768px)" srcset="<?= htmlspecialchars($bannerImageMobile) ?>">
                            <source media="(min-width: 769px)" srcset="<?= htmlspecialchars($bannerImageDesktop) ?>">
                            <img
                                src="<?= htmlspecialchars($bannerImageDesktop ?: $bannerImageMobile) ?>"
                                alt="<?= htmlspecialchars($bannerAlt) ?>"
