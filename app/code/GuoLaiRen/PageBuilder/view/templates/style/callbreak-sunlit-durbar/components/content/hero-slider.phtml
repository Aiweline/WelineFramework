                                decoding="async"
                            >
                        </picture>
                        <figcaption>
                            <span><?= htmlspecialchars($stageText) ?></span>
                            <strong><?= htmlspecialchars($appName) ?></strong>
                        </figcaption>
                    </figure>
                </div>
            </div>
        </div>
    </div>
</section>
