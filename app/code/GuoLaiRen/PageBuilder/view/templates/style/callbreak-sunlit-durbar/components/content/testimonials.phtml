<?php
/**
 * Callbreak Sunlit Durbar - Testimonials Component
 *
 * @component_start
 * code: testimonials
 * name: 用户评价
 * name_en: Testimonials
 * description: Player feedback rendered as a responsive signal wall.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_rating => 显示评分:select:yes|yes,no
 * display.show_avatar => 显示头像:select:yes|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#ecf8ff
 * style.title_color => 标题颜色:color:#3d2217
 * style.title_font_size => 标题字号(PC端):number:36|px
 * style.title_font_size_mobile => 标题字号(移动端):number:24|px
 * style.card_bg_color => 卡片背景色:color:rgba(255,255,255,0.84)
 * style.card_border_radius => 卡片圆角:number:18|px
 * style.card_border_left_color => 卡片高亮色:color:#53e0c5
 * style.card_border_left_width => 卡片高亮宽度:number:3|px
 * style.card_padding => 卡片内边距:number:24|px
 * style.name_color => 姓名颜色:color:#3d2217
 * style.name_font_size => 姓名字号:number:16|px
 * style.rating_color => 评分颜色:color:#ffc27a
 * style.content_color => 内容颜色:color:#6b4e41
 * style.content_font_size => 内容字号:number:14|px
 * style.avatar_size => 头像尺寸:number:58|px
 * style.avatar_border_radius => 头像圆角:number:50|%
 * style.section_padding => 区域内边距(PC端):number:60|px
 * style.section_padding_mobile => 区域内边距(移动端):number:40|px
 * style.card_gap => 卡片间距:number:20|px
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:|默认使用本地头像
 * avatars.avatar_2 => 评价2头像:textarea:|默认使用本地头像
 * avatars.avatar_3 => 评价3头像:textarea:|默认使用本地头像
 *
 * group:texts => 文本内容
 * texts.title => 区域标题:text:Player Signals From The Tables
 * texts.summary => 区域说明:textarea:Real player notes are framed like table slips, so praise and friction stay easy to compare at a glance.
 * texts.testimonial_1_name => 评价1姓名:text:Rajesh Kumar (Mumbai)
 * texts.testimonial_1_rating => 评价1评分:text:4.9/5
 * texts.testimonial_1_content => 评价1内容:textarea:Tables load quickly, the banner feels lively, and the lobby is easier to scan on mobile.
 * texts.testimonial_2_name => 评价2姓名:text:Priya Sharma (Delhi)
 * texts.testimonial_2_rating => 评价2评分:text:4.8/5
 * texts.testimonial_2_content => 评价2内容:textarea:I like the color separation between sections because each route feels easier to spot.
 * texts.testimonial_3_name => 评价3姓名:text:Amit Patel (Ahmedabad)
 * texts.testimonial_3_rating => 评价3评分:text:4.8/5
 * texts.testimonial_3_content => 评价3内容:textarea:The page feels energetic without becoming hard to read, especially on a smaller screen.
 *
 * @fields_end
 */

$componentId = 'durbar-testimonials-' . uniqid();

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';

$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#ecf8ff'));
$titleColor = $getConfig('style.title_color', '#3d2217');
$titleFontSize = (int)$getConfig('style.title_font_size', '36');
$titleFontSizeMobile = (int)$getConfig('style.title_font_size_mobile', '24');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.84)');
$cardBorderRadius = (int)$getConfig('style.card_border_radius', '18');
$cardAccentColor = $getConfig('style.card_border_left_color', '#53e0c5');
$cardAccentWidth = (int)$getConfig('style.card_border_left_width', '3');
$cardPadding = (int)$getConfig('style.card_padding', '24');
$nameColor = $getConfig('style.name_color', '#3d2217');
$nameFontSize = (int)$getConfig('style.name_font_size', '16');
$ratingColor = $getConfig('style.rating_color', '#ffc27a');
$contentColor = $getConfig('style.content_color', '#6b4e41');
$contentFontSize = (int)$getConfig('style.content_font_size', '14');
$avatarSize = (int)$getConfig('style.avatar_size', '58');
$avatarRadius = (int)$getConfig('style.avatar_border_radius', '50');
$sectionPadding = (int)$getConfig('style.section_padding', '60');
$sectionPaddingMobile = (int)$getConfig('style.section_padding_mobile', '40');
$cardGap = (int)$getConfig('style.card_gap', '20');

$defaultAvatar1 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/user/Rajesh-Kumar-1.avif');
$defaultAvatar2 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/user/Priya-Sharma-2.avif');
$defaultAvatar3 = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/callbreak-sunlit-durbar/asset/img/user/Amit-Patel-3.avif');

$avatar1 = $getConfig('avatars.avatar_1', $getConfig('testimonials.avatar_1', '')) ?: $defaultAvatar1;
$avatar2 = $getConfig('avatars.avatar_2', $getConfig('testimonials.avatar_2', '')) ?: $defaultAvatar2;
$avatar3 = $getConfig('avatars.avatar_3', $getConfig('testimonials.avatar_3', '')) ?: $defaultAvatar3;

$defaultSectionTitle = 'Player Signals From The Tables';
$title = $getConfig('texts.title', $getConfig('testimonials.title', $getConfig('texts.testimonials_title', $defaultSectionTitle)));
$summary = $getConfig('texts.summary', 'Real player notes are framed like table slips, so praise and friction stay easy to compare at a glance.');
$name1 = $getConfig('texts.testimonial_1_name', 'Rajesh Kumar (Mumbai)');
$rating1 = $getConfig('texts.testimonial_1_rating', '4.9/5');
$content1 = $getConfig('texts.testimonial_1_content', 'Tables load quickly, the banner feels lively, and the lobby is easier to scan on mobile.');
$name2 = $getConfig('texts.testimonial_2_name', 'Priya Sharma (Delhi)');
$rating2 = $getConfig('texts.testimonial_2_rating', '4.8/5');
$content2 = $getConfig('texts.testimonial_2_content', 'I like the color separation between sections because each route feels easier to spot.');
$name3 = $getConfig('texts.testimonial_3_name', 'Amit Patel (Ahmedabad)');
$rating3 = $getConfig('texts.testimonial_3_rating', '4.8/5');
$content3 = $getConfig('texts.testimonial_3_content', 'The page feels energetic without becoming hard to read, especially on a smaller screen.');

$cards = [
    ['avatar' => $avatar1, 'name' => $name1, 'rating' => $rating1, 'content' => $content1, 'tone' => 'sun'],
    ['avatar' => $avatar2, 'name' => $name2, 'rating' => $rating2, 'content' => $content2, 'tone' => 'mint'],
    ['avatar' => $avatar3, 'name' => $name3, 'rating' => $rating3, 'content' => $content3, 'tone' => 'rose'],
];
$cardEffects = ['animate__fadeInLeft', 'animate__zoomIn', 'animate__fadeInRight'];

$ratingValues = [];
foreach ($cards as $card) {
    if (preg_match('/(\d+(?:\.\d+)?)/', (string)$card['rating'], $matches)) {
        $ratingValues[] = (float)$matches[1];
    }
}
$averageScore = $ratingValues ? number_format(array_sum($ratingValues) / count($ratingValues), 1) : '4.8';
?>
<section id="<?= $componentId ?>" class="durbar-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <span class="tes-deco tes-deco-a" aria-hidden="true"></span>
    <span class="tes-deco tes-deco-b" aria-hidden="true"></span>
    <span class="tes-deco tes-deco-c" aria-hidden="true"></span>
    <div class="section-inner">
        <div class="tes-top">
            <div class="tes-score" data-durbar-reveal data-durbar-effect="animate__zoomIn">
                <div class="tes-score-ring">
                    <strong><?= htmlspecialchars($averageScore) ?></strong>
                </div>
                <?php if ($showRating): ?>
                    <div class="tes-stars" aria-hidden="true">
                        <span>★</span>
                        <span>★</span>
                        <span>★</span>
                        <span>★</span>
                        <span>★</span>
                    </div>
                <?php endif; ?>
            </div>

            <?php if ($showTitle): ?>
                <header class="tes-head" data-durbar-reveal data-durbar-effect="animate__fadeInRight" data-wow-delay="70ms">
                    <span class="tes-head-mark" aria-hidden="true">
                        <span class="tes-mark-bar tes-mark-bar-a"></span>
                        <span class="tes-mark-bar tes-mark-bar-b"></span>
                        <span class="tes-mark-bar tes-mark-bar-c"></span>
                        <span class="tes-mark-dot"></span>
                    </span>
                    <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                    <?php if ($summary !== ''): ?>
                        <p class="tes-summary"><?= htmlspecialchars($summary) ?></p>
                    <?php endif; ?>
                </header>
            <?php endif; ?>
        </div>

        <div class="tes-cards">
            <?php foreach ($cards as $index => $card): ?>
                <?php $cardEffect = $cardEffects[$index % count($cardEffects)]; ?>
                <article class="tes-card tes-card-<?= (int)($index + 1) ?> tes-tone-<?= htmlspecialchars($card['tone']) ?>" data-durbar-reveal data-durbar-effect="<?= htmlspecialchars($cardEffect) ?>" data-wow-delay="<?= htmlspecialchars((string)(130 + ($index * 90))) ?>ms">
                    <div class="tes-card-head">
                        <?php if ($showAvatar): ?>
                            <img src="<?= htmlspecialchars($card['avatar']) ?>" alt="<?= htmlspecialchars($card['name']) ?>" loading="lazy" decoding="async">
                        <?php endif; ?>
                        <div class="tes-card-meta">
                            <h3><?= htmlspecialchars($card['name']) ?></h3>
                            <?php if ($showRating): ?>
                                <p><?= htmlspecialchars($card['rating']) ?></p>
                            <?php endif; ?>
                        </div>
                    </div>
                    <p class="tes-card-body"><?= htmlspecialchars($card['content']) ?></p>
                </article>
            <?php endforeach; ?>
        </div>
    </div>
</section>
