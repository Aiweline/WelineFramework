                                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($brandName) ?>" loading="lazy" decoding="async">
                                </span>
                                <div class="csd-mobile-brand-copy">
                                    <p><?= htmlspecialchars($mobileMenuLabel) ?></p>
                                    <strong><?= htmlspecialchars($brandName) ?></strong>
                                </div>
                            </div>
                            <button class="csd-mobile-close" type="button" aria-label="Close navigation">x</button>
                        </div>

                        <div class="csd-mobile-caption">
                            <span><?= htmlspecialchars($mobileMenuLabel) ?></span>
                            <i aria-hidden="true"></i>
                        </div>

                        <nav class="csd-mobile-grid" aria-label="Mobile navigation">
                            <?php foreach ($navItems as $index => $item): ?>
                                <?php
                                $mobileMark = ['✦', '●', '▲', '◌'][$index % 4];
                                ?>
                                <a class="csd-mobile-link" href="<?= htmlspecialchars($item['href']) ?>" data-mark="<?= htmlspecialchars($mobileMark) ?>">
                                    <span class="csd-mobile-link-text">
