</header>
<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var toggle = root.querySelector('.csd-toggle');
    var closeButton = root.querySelector('.csd-mobile-close');
    var backdrop = root.querySelector('.csd-mobile-backdrop');
    var sheet = root.querySelector('.csd-mobile-sheet');
    var body = document.body;
    var closeTimer = null;

    var syncScrollState = function () {
        if (window.scrollY > 20) {
            root.classList.add('is-scrolled');
        } else {
            root.classList.remove('is-scrolled');
        }
    };

    var setOpen = function (isOpen) {
        if (closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = null;
        }

        if (isOpen) {
            body.classList.add('csd-nav-lock');
            if (sheet) {
                sheet.hidden = false;
            }
            if (backdrop) {
                backdrop.hidden = false;
            }

            window.requestAnimationFrame(function () {
                window.requestAnimationFrame(function () {
                    root.classList.add('is-open');
                });
            });
        } else {
            root.classList.remove('is-open');
            body.classList.remove('csd-nav-lock');
            closeTimer = window.setTimeout(function () {
                if (sheet) {
                    sheet.hidden = true;
                }
                if (backdrop) {
                    backdrop.hidden = true;
                }
            }, 340);
        }

        if (toggle) {
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }
    };

    syncScrollState();
    window.addEventListener('scroll', syncScrollState, { passive: true });

    if (toggle) {
        toggle.addEventListener('click', function () {
            setOpen(!root.classList.contains('is-open'));
        });
    }

    if (closeButton) {
        closeButton.addEventListener('click', function () {
            setOpen(false);
        });
    }

    if (backdrop) {
        backdrop.addEventListener('click', function () {
            setOpen(false);
        });
    }

    root.querySelectorAll('.csd-mobile-link').forEach(function (link) {
        link.addEventListener('click', function () {
            setOpen(false);
        });
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 1140 && root.classList.contains('is-open')) {
            setOpen(false);
        }
    });
}());
</script>
