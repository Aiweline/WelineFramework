$downloadBtnPaddingY = (int)$getConfig('download_button.padding_y', '11');

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = [];
    if (method_exists($page, 'getHeaderNavigationPages')) {
        $navigationPages = $page->getHeaderNavigationPages(10);
    } elseif (method_exists($page, 'getNavigationPages')) {
        $navigationPages = $page->getNavigationPages([], 10);
    }
    foreach ($navigationPages as $navPage) {
        $type = trim((string)($navPage['type'] ?? ''));
        $label = $type !== '' ? trim((string)$getConfig('navigation.label_' . $type, '')) : '';
        if ($label === '' && $type !== '') {
            $label = trim((string)$getConfig('header.navigation.label_' . $type, ''));
        }
        $navItems[] = [
            'text' => $label !== '' ? $label : ($navPage['title'] ?? ''),
            'href' => $navPage['url'] ?? '#',
        ];
    }
}

if (empty($navItems)) {
    $navItemsConfig = $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>/faqs");
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }
    foreach (preg_split('/\r?\n/', $navItemsConfig) as $line) {
        $line = trim((string)$line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $text = trim((string)($parts[0] ?? ''));
        $href = trim((string)($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }
        if ($href === '') {
            $href = '/' . strtolower(trim((string)preg_replace('/[^a-zA-Z0-9]+/', '-', $text), '-'));
        }
        $navItems[] = ['text' => $text, 'href' => $href];
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'Blog', 'href' => '/blog'],
        ['text' => 'FAQs', 'href' => '/faqs'],
    ];
}

$splitIndex = (int)ceil(count($navItems) / 2);
$leftItems = array_slice($navItems, 0, $splitIndex);
$rightItems = array_slice($navItems, $splitIndex);
