$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $component_config ?? $this->getData('component_config') ?? [];
$config = array_merge(
    is_array($styleSettings) ? $styleSettings : [],
    is_array($componentConfig) ? $componentConfig : []
);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$heroBg = $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#fff6ea');
$heroGradientEnd = $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#ffe2bb');
$heroTitleColor = $getConfig('hero.title_color', $colors['heading_color'] ?? '#3d2217');

$textPrimary = $colors['text_primary'] ?? '#332016';
$textSecondary = $colors['text_secondary'] ?? '#6b4e41';
$textMuted = $colors['text_muted'] ?? '#9a7d6d';
$sectionBg1 = $colors['section_bg_1'] ?? '#fffdf8';
$sectionBg2 = $colors['section_bg_2'] ?? '#eef9ff';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.82)';
$borderLight = $colors['border_light'] ?? 'rgba(126,91,67,0.14)';
$buttonBg = $colors['button_primary_bg'] ?? 'linear-gradient(100deg, #ff9f4d 0%, #ff4d4d 100%)';
$buttonText = $colors['button_primary_text'] ?? '#2b140d';
$primaryColor = $getConfig('color_scheme.primary', '#ff7a45');
$secondaryColor = $getConfig('color_scheme.secondary', '#00cdb6');
$surfaceColor = $getConfig('color_scheme.surface', 'rgba(255,255,255,0.82)');

$page = $this->getData('page');
$pageTitle = $page ? (string)($page->getData('title') ?: 'Contact Callbreak Sunlit Durbar') : 'Contact Callbreak Sunlit Durbar';

$heroTitle = $getConfig('hero.title', $pageTitle);
$heroSubtitle = $getConfig('hero.subtitle', 'Need support or business help? Reach us through the channels below.');

$addressLabel = $getConfig('contact_info.address_label', 'Address');
$contactAddress = $getConfig('contact_info.address', 'Mumbai Operations Hub, Andheri East, Maharashtra, India');
$phoneLabel = $getConfig('contact_info.phone_label', 'Phone');
$contactPhone = $getConfig('contact_info.phone', '+91 98765 43210');
$emailLabel = $getConfig('contact_info.email_label', 'Email');
$contactEmail = $getConfig('contact_info.email', 'support@callbreaksunlitdurbar.com');
$workHoursLabel = $getConfig('contact_info.work_hours_label', 'Support Hours');
$contactWorkHours = $getConfig('contact_info.work_hours', '24/7 Player Support');
$phoneHref = preg_replace('/\s+/', '', $contactPhone);

$formTitle = $getConfig('form.title', 'Send A Support Message');
$formNameLabel = $getConfig('form.name_label', 'Name');
$formEmailLabel = $getConfig('form.email_label', 'Email');
$formSubjectLabel = $getConfig('form.subject_label', 'Topic');
$formMessageLabel = $getConfig('form.message_label', 'Message');
$formSubmitText = $getConfig('form.submit_text', 'Send Message');
$formSuccessMessage = $getConfig('form.success_message', 'Thanks. Our team will reply soon.');

$mapTitle = $getConfig('map.title', 'Visit The Support Hub');
$mapEmbedUrl = trim((string)$getConfig('map.embed_url', ''));
$mapHeight = max(260, (int)$getConfig('map.height', '400'));

$socialLinks = [
    ['name' => 'Facebook', 'url' => trim((string)$getConfig('social.facebook', '')), 'label' => 'FB'],
    ['name' => 'Twitter', 'url' => trim((string)$getConfig('social.twitter', '')), 'label' => 'X'],
    ['name' => 'LinkedIn', 'url' => trim((string)$getConfig('social.linkedin', '')), 'label' => 'IN'],
    ['name' => 'WeChat', 'url' => trim((string)$getConfig('social.wechat', '')), 'label' => 'WC'],
    ['name' => 'Weibo', 'url' => trim((string)$getConfig('social.weibo', '')), 'label' => 'WB'],
];
$socialLinks = array_values(array_filter($socialLinks, function ($item) {
    return $item['url'] !== '';
}));

$contactCards = [
    ['label' => $addressLabel, 'value' => $contactAddress, 'href' => ''],
    ['label' => $phoneLabel, 'value' => $contactPhone, 'href' => $phoneHref !== '' ? 'tel:' . $phoneHref : ''],
    ['label' => $emailLabel, 'value' => $contactEmail, 'href' => $contactEmail !== '' ? 'mailto:' . $contactEmail : ''],
    ['label' => $workHoursLabel, 'value' => $contactWorkHours, 'href' => ''],
];
$instanceId = $component_instance_id ?? 'contact-content-' . uniqid();
?>

<section id="<?= $instanceId ?>" class="durbar-contact-page">
    <div class="contact-hero">
        <span class="hero-float hero-float-left" data-durbar-parallax data-durbar-speed="0.06" aria-hidden="true"></span>
        <span class="hero-float hero-float-right" data-durbar-parallax data-durbar-speed="0.09" aria-hidden="true"></span>
        <div class="section-inner hero-layout no-panel">
            <header class="hero-copy" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                <p class="section-tag"><?= __('Contact') ?></p>
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <p class="hero-summary"><?= htmlspecialchars($heroSubtitle) ?></p>

                <?php if ($showSocial && !empty($socialLinks)): ?>
                    <div class="hero-social" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="120ms">
                        <?php foreach ($socialLinks as $link): ?>
                            <a href="<?= htmlspecialchars($link['url']) ?>" target="_blank" rel="noopener" aria-label="<?= htmlspecialchars($link['name']) ?>">
                                <?= htmlspecialchars($link['label']) ?>
                            </a>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </header>

        </div>
    </div>

    <section class="contact-stage">
        <div class="section-inner stage-layout<?= !$showInfo ? ' no-info' : '' ?><?= !$showForm ? ' no-form' : '' ?>">
            <?php if ($showInfo): ?>
                <aside class="info-column" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                    <header class="column-head">
                        <p class="section-tag"><?= __('Routes') ?></p>
                        <h2><?= __('Support Desks') ?></h2>
                    </header>

                    <div class="desk-grid">
                        <?php foreach ($contactCards as $index => $card): ?>
                            <?php if (trim((string)$card['value']) === '') continue; ?>
                            <article class="desk-card desk-card-<?= $index + 1 ?>" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="<?= min($index * 80, 260) ?>ms">
                                <span class="desk-label"><?= htmlspecialchars((string)$card['label']) ?></span>
                                <?php if ($card['href'] !== ''): ?>
                                    <a href="<?= htmlspecialchars($card['href']) ?>"><?= nl2br(htmlspecialchars((string)$card['value'])) ?></a>
                                <?php else: ?>
                                    <p><?= nl2br(htmlspecialchars((string)$card['value'])) ?></p>
                                <?php endif; ?>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </aside>
            <?php endif; ?>

            <?php if ($showForm): ?>
                <section class="form-column" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="120ms">
                    <header class="form-head">
                        <p class="section-tag"><?= __('Message') ?></p>
                        <h2><?= htmlspecialchars($formTitle) ?></h2>
                    </header>

                    <form class="contact-form" onsubmit="return false;" aria-label="contact form">
                        <div class="form-row">
                            <label>
                                <span><?= htmlspecialchars($formNameLabel) ?></span>
                                <input type="text" name="name" placeholder="<?= htmlspecialchars((string)__('Your name')) ?>" required>
                            </label>
                            <label>
                                <span><?= htmlspecialchars($formEmailLabel) ?></span>
                                <input type="email" name="email" placeholder="<?= htmlspecialchars((string)__('you@example.com')) ?>" required>
                            </label>
                        </div>

                        <label>
                            <span><?= htmlspecialchars($formSubjectLabel) ?></span>
                            <input type="text" name="topic" placeholder="<?= htmlspecialchars((string)__('How can we help?')) ?>">
                        </label>

                        <label>
                            <span><?= htmlspecialchars($formMessageLabel) ?></span>
                            <textarea name="message" rows="6" placeholder="<?= htmlspecialchars((string)__('Share your request')) ?>" required></textarea>
                        </label>

                        <div class="form-foot">
                            <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                            <p class="form-note"><?= htmlspecialchars($formSuccessMessage) ?></p>
                        </div>
                    </form>
                </section>
            <?php endif; ?>
        </div>
    </section>

    <?php if ($showMap): ?>
        <section class="map-stage" style="--map-height: <?= $mapHeight ?>px;">
            <div class="section-inner map-shell">
                <div class="map-copy" data-durbar-reveal data-durbar-effect="animate__fadeInUp">
                    <p class="section-tag"><?= __('Locate') ?></p>
                    <h2><?= htmlspecialchars($mapTitle) ?></h2>
                    <?php if ($contactAddress !== ''): ?>
                        <p><?= nl2br(htmlspecialchars($contactAddress)) ?></p>
                    <?php endif; ?>
                    <?php if ($contactWorkHours !== ''): ?>
                        <span class="map-meta"><?= htmlspecialchars($contactWorkHours) ?></span>
                    <?php endif; ?>
                </div>

                <div class="map-panel" data-durbar-reveal data-durbar-effect="animate__fadeInUp" data-wow-delay="100ms">
                    <?php if ($mapEmbedUrl !== ''): ?>
                        <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="<?= htmlspecialchars($mapTitle) ?>"></iframe>
                    <?php else: ?>
                        <div class="map-placeholder">
                            <strong><?= htmlspecialchars($mapTitle) ?></strong>
                            <p><?= nl2br(htmlspecialchars($contactAddress)) ?></p>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        </section>
    <?php endif; ?>
</section>

