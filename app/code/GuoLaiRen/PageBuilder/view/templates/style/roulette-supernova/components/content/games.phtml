$componentId = 'rsn-games-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$styleSettings = is_array($styleSettings) ? $styleSettings : [];
$componentConfig = is_array($componentConfig) ? $componentConfig : [];

$getConfigAny = function (array $keys, $default = '') use ($styleSettings, $componentConfig) {
    foreach ($keys as $key) {
        if (array_key_exists($key, $componentConfig) && $componentConfig[$key] !== '') {
            return $componentConfig[$key];
        }
    }

    foreach ($keys as $key) {
        if (array_key_exists($key, $styleSettings) && $styleSettings[$key] !== '') {
            return $styleSettings[$key];
        }
    }

    return $default;
};

$getConfig = function ($key, $default = '') use ($getConfigAny) {
    return $getConfigAny([$key], $default);
};

$normalizeLines = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $value = str_replace(["\r\n", "\r"], "\n", $value);
    return array_values(array_filter(array_map('trim', preg_split('/\n+/', $value) ?: []), static function ($item) {
        return $item !== '';
    }));
};

$parseLegacyGames = static function ($value) use ($normalizeLines) {
    $rooms = [];
    foreach ($normalizeLines((string) $value) as $line) {
        $parts = array_map('trim', explode('|', $line));
        $title = $parts[0] ?? '';
        if ($title === '') {
            continue;
        }
        $rooms[] = [
            'title' => $title,
            'description' => $parts[1] ?? '',
            'url' => $parts[2] ?? '#',
        ];
    }
    return $rooms;
};

$parseLegacyTokenList = static function ($value) {
    $tokens = preg_split('/\|/', str_replace(["\r", "\n"], '|', (string) $value)) ?: [];
    return array_values(array_filter(array_map('trim', $tokens), static function ($item) {
        return $item !== '';
    }));
};

$getLegacyIndexed = static function (array $items, $index, $default = '') {
    return isset($items[$index]) && $items[$index] !== '' ? $items[$index] : $default;
};

$display = $getConfig('display.show_section', $getConfig('games.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showSubtitle = $getConfig('display.show_subtitle', $getConfig('display.show_description', 'yes')) !== 'no';
$showTags = $getConfig('display.show_tags', 'yes') !== 'no';
$bgColor = (string) $getConfig('style.bg_color', $getConfig('games.bg_color', '#071a15'));
$accentColor = (string) $getConfig('style.accent_color', '#dfff5a');
$titleColor = (string) $getConfig('style.title_color', '#f7f1e8');
$subtitleColor = (string) $getConfig('style.subtitle_color', '#cbbcae');
$panelBgColor = (string) $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.08)');
$cardBgColor = (string) $getConfig('style.card_bg_color', 'rgba(12,15,18,0.86)');
$cardBorderColor = (string) $getConfig('style.card_border_color', 'rgba(255,255,255,0.08)');
$cardRadius = max(18, (int) $getConfig('style.card_radius', '28'));
$sectionPadding = max(48, (int) $getConfig('style.section_padding', '84'));
$sectionPaddingMobile = max(36, (int) $getConfig('style.section_padding_mobile', '48'));
$cardGap = max(12, (int) $getConfig('style.card_gap', '24'));
$kicker = trim((string) $getConfigAny(['texts.kicker', 'texts.games_kicker'], 'Table spread'));
$title = trim((string) $getConfigAny(['texts.title', 'games.title', 'texts.games_title'], 'Choose Your Supernova Table'));
$subtitle = trim((string) $getConfigAny(
    ['texts.summary', 'texts.games_summary', 'texts.subtitle'],
    'Move from fast roulette rooms to steadier tables without losing sight of the wheel, the stake zones, or the entry path.'
));
$linkText = trim((string) $getConfigAny(['texts.link_text', 'texts.games_link_text'], 'Open table'));
$legacyGames = $parseLegacyGames($getConfig('games.items', ''));
$legacyBadges = $parseLegacyTokenList($getConfigAny(['texts.badges', 'texts.games_badges'], ''));
$legacyTags = $parseLegacyTokenList($getConfigAny(['texts.tags', 'texts.games_tags'], ''));

$defaultGames = [
    ['badge' => 'Popular Table', 'title' => 'Flash Wheel', 'description' => 'High-energy roulette room with quick joins and a bright action path for short sessions.', 'tag' => 'Live Wheel', 'url' => '#download'],
    ['badge' => 'Fast Access', 'title' => 'Classic Orbit', 'description' => 'Balanced roulette pacing for players who want a steadier table rhythm.', 'tag' => 'Fast Join', 'url' => '#download'],
    ['badge' => 'Classic Pace', 'title' => 'Night Table', 'description' => 'A darker live roulette lane with stronger focus on the wheel and stake zones.', 'tag' => 'Night Table', 'url' => '#download'],
    ['badge' => 'Private Lounge', 'title' => 'Private Pit', 'description' => 'A tighter roulette route for invite groups, returning players, and focused sessions.', 'tag' => 'Invite Group', 'url' => '#download'],
    ['badge' => 'High Limit', 'title' => 'Streak Room', 'description' => 'Built for players who like faster table turns and immediate re-entry.', 'tag' => 'Fast Re-entry', 'url' => '#download'],
    ['badge' => 'Beginner Friendly', 'title' => 'Starter Wheel', 'description' => 'A cleaner roulette lane that helps new players settle in before moving faster.', 'tag' => 'Easy Start', 'url' => '#download'],
];

$games = [];
for ($i = 1; $i <= 6; $i++) {
    $index = $i - 1;
    $defaultGame = $defaultGames[$index];
    $legacyGame = $legacyGames[$index] ?? [];
    $groupPrefix = "game_{$i}.";

    $game = [
        'badge' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_badge", "texts.game_{$i}_badge"], $getLegacyIndexed($legacyBadges, $index, $defaultGame['badge']))),
        'name' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_title", "texts.game_{$i}_title"], $legacyGame['title'] ?? $defaultGame['title'])),
        'description' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_desc", "texts.game_{$i}_desc"], $legacyGame['description'] ?? $defaultGame['description'])),
        'tag' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_tag", "texts.game_{$i}_tag"], $getLegacyIndexed($legacyTags, $index, $defaultGame['tag']))),
        'link' => trim((string) $getConfigAny([$groupPrefix . "texts.game_{$i}_url", "texts.game_{$i}_url"], $legacyGame['url'] ?? $defaultGame['url'])),
    ];

    if ($game['name'] === '') {
        continue;
    }

    if ($game['link'] === '') {
        $game['link'] = '#';
    }

    $games[] = $game;
}

if (empty($games)) {
    foreach ($defaultGames as $defaultGame) {
        $games[] = [
            'badge' => $defaultGame['badge'],
            'name' => $defaultGame['title'],
            'description' => $defaultGame['description'],
            'tag' => $defaultGame['tag'],
            'link' => $defaultGame['url'],
        ];
    }
}

$tags = [];
foreach (array_slice($games, 0, 3) as $game) {
    if ($game['tag'] !== '' && !in_array($game['tag'], $tags, true)) {
        $tags[] = $game['tag'];
    }
}
if (empty($tags)) {
    $tags = array_slice($legacyTags, 0, 3);
}
if (empty($tags)) {
    $tags = ['Live Wheel', 'Fast Join', 'Night Table'];
}

$gameCount = count($games);
$topCount = (int) ceil($gameCount / 2);
$bottomCount = max(0, $gameCount - $topCount);
$desktopColumns = max(1, min(3, $topCount));
$wheelAsset = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/roulette-supernova/asset/img/roulette-hero-wheel.svg');
?>
<section id="<?= $componentId ?>" class="rsn-games" aria-labelledby="<?= $componentId ?>-title">
    <div class="games-shell">
        <header class="games-head" id="tables">
            <?php if ($kicker !== ''): ?>
                <span class="games-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle && $title !== ''): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showSubtitle && $subtitle !== ''): ?>
                <p class="games-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if ($showTags && !empty($tags)): ?>
                <div class="games-tags" aria-label="Table highlights">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="nova-stage" style="--game-gap: <?= (int) $cardGap ?>px; --game-radius: <?= (int) $cardRadius ?>px; --game-columns: <?= (int) $desktopColumns ?>;">
            <div class="nova-core" aria-hidden="true">
                <span class="nova-glow nova-glow-a"></span>
                <span class="nova-glow nova-glow-b"></span>
                <span class="nova-arc nova-arc-a"></span>
                <span class="nova-arc nova-arc-b"></span>
                <div class="nova-wheel-shell">
                    <span class="nova-wheel-ring nova-wheel-ring-a"></span>
                    <span class="nova-wheel-ring nova-wheel-ring-b"></span>
                    <div class="nova-wheel-frame">
                        <img src="<?= htmlspecialchars($wheelAsset) ?>" alt="Roulette wheel">
                    </div>
                </div>
            </div>

                <div class="nova-grid" role="list">
                    <?php foreach ($games as $index => $game): ?>
                    <?php
                    $badge = trim((string) ($game['badge'] ?? ''));
                    if ($badge === '') {
                        $badge = 'Open Table';
                    }
                    $tag = trim((string) ($game['tag'] ?? ''));
                    if ($tag === '') {
                        $tag = $tags[$index % count($tags)] ?? 'Live Wheel';
                    }
                    $toneClass = 'table-card-' . (string) (($index % 4) + 1);
                    $isTopRow = $index < $topCount;
                    $rowCount = $isTopRow ? $topCount : max(1, $bottomCount);
                    $localIndex = $isTopRow ? $index : ($index - $topCount);
                    $centerPoint = ($rowCount - 1) / 2;
                    $offset = $localIndex - $centerPoint;
                    $distance = abs($offset);
                    $desktopRise = (int) round(($distance * 28) + 12);
                    if (!$isTopRow) {
                        $desktopRise *= -1;
                    }
                    $desktopTilt = round($offset * 3.1, 2);
                    $mobileLift = $index % 2 === 0 ? -3 : 6;
                    $mobileTilt = $index % 3 === 0 ? -2.2 : ($index % 3 === 1 ? 1.4 : 2.4);
                    $style = sprintf('--card-rise:%spx;--card-tilt:%sdeg;--mobile-lift:%spx;--mobile-tilt:%sdeg;', $desktopRise, $desktopTilt, $mobileLift, $mobileTilt);
                    $bandClass = $index % 2 === 0 ? 'table-card-band-top' : 'table-card-band-bottom';
                    ?>
                    <article class="table-card <?= $isTopRow ? 'table-card-top' : 'table-card-bottom' ?> <?= htmlspecialchars($toneClass) ?> <?= htmlspecialchars($bandClass) ?>" role="listitem" style="<?= htmlspecialchars($style) ?>">
                        <span class="table-core-dot" aria-hidden="true"></span>
                        <div class="table-card-head">
                            <span class="table-badge"><?= htmlspecialchars($badge) ?></span>
                            <span class="table-tag"><?= htmlspecialchars($tag) ?></span>
                        </div>
                        <h3><?= htmlspecialchars($game['name']) ?></h3>
                        <p><?= htmlspecialchars($game['description']) ?></p>
                        <div class="table-card-foot">
                            <a class="game-link" href="<?= htmlspecialchars($game['link']) ?>"><?= htmlspecialchars($linkText !== '' ? $linkText : 'Open table') ?></a>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

