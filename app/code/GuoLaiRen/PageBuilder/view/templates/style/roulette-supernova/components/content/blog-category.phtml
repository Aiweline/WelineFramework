<?php
/**
 * Roulette Supernova - Blog Category Component
 *
 * @component_start
 * code: blog-category
 * name: 博客分类
 * name_en: Blog Category
 * description: Roulette Supernova category archive with a spotlight article, staggered stream cards, and responsive side rail.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * blog.title|分类标题|text|Category Archive
 * blog.subtitle|副标题|text|Browse roulette articles by category, event theme, or update stream.
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=Yes,no=No|yes
 * blog.show_category|显示分类|select:yes=Yes,no=No|yes
 * blog.show_date|显示日期|select:yes=Yes,no=No|yes
 * blog.show_author|显示作者|select:yes=Yes,no=No|yes
 * blog.card_style|卡片样式|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$componentId = 'rsn-blog-category-' . uniqid();
$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$currentCategory = $this->getData('current_category') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = trim((string) $getConfig('blog.title', (string) ($currentCategory['name'] ?? 'Category Archive')));
if ($title === '') {
    $title = 'Category Archive';
}
$subtitle = trim((string) $getConfig('blog.subtitle', 'Browse roulette articles by category, event theme, or update stream.'));
$postsPerPage = max(1, (int) $getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = (string) $getConfig('blog.card_style', 'default');

$visiblePosts = array_slice($blogPosts, 0, $postsPerPage);
$spotlightPost = $visiblePosts[0] ?? null;
$streamPosts = array_slice($visiblePosts, 1);
$categoryName = trim((string) ($currentCategory['name'] ?? ''));
$categoryDescription = trim((string) ($currentCategory['description'] ?? ''));
?>
<section id="<?= $componentId ?>" class="rsn-blog-category">
    <div class="category-shell">
        <header class="category-masthead">
            <?php if ($categoryName !== ''): ?>
                <span class="category-chip"><?= htmlspecialchars($categoryName) ?></span>
            <?php endif; ?>
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($subtitle !== ''): ?>
                <p class="category-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if ($categoryDescription !== ''): ?>
                <p class="category-description"><?= htmlspecialchars($categoryDescription) ?></p>
            <?php endif; ?>
        </header>

        <?php if (empty($visiblePosts)): ?>
            <section class="category-empty" aria-label="<?= htmlspecialchars((string) __('Category archive')) ?>">
                <span class="empty-chip">No posts</span>
                <h2><?= __('No posts in this category yet') ?></h2>
                <p><?= __('Fresh roulette articles will appear here when this archive receives new entries.') ?></p>
                <a href="/blog" class="back-link"><?= __('Back to Blog') ?></a>
            </section>
        <?php else: ?>
            <?php if ($spotlightPost): ?>
                <article class="spotlight-story">
                    <div class="spotlight-copy">
                        <span class="spotlight-kicker">Lead article</span>
                        <h2><a href="<?= htmlspecialchars($spotlightPost['url']) ?>"><?= htmlspecialchars($spotlightPost['title']) ?></a></h2>
                        <div class="spotlight-meta">
                            <?php if ($showCategory && !empty($spotlightPost['category_name'])): ?>
                                <span><?= htmlspecialchars($spotlightPost['category_name']) ?></span>
                            <?php endif; ?>
                            <?php if ($showDate && !empty($spotlightPost['published_at'])): ?>
                                <span><?= date('M d, Y', strtotime($spotlightPost['published_at'])) ?></span>
                            <?php endif; ?>
                            <?php if ($showAuthor && !empty($spotlightPost['author'])): ?>
                                <span><?= htmlspecialchars($spotlightPost['author']) ?></span>
                            <?php endif; ?>
                        </div>
                        <?php if (!empty($spotlightPost['summary'])): ?>
                            <p><?= htmlspecialchars(mb_strimwidth((string) $spotlightPost['summary'], 0, 240, '...')) ?></p>
                        <?php endif; ?>
                        <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="story-action"><?= __('Read Article') ?></a>
                    </div>
                    <?php if (!empty($spotlightPost['cover_image'])): ?>
                        <a href="<?= htmlspecialchars($spotlightPost['url']) ?>" class="spotlight-media">
                            <img src="<?= htmlspecialchars($spotlightPost['cover_image']) ?>" alt="<?= htmlspecialchars($spotlightPost['title']) ?>" loading="lazy">
                        </a>
                    <?php endif; ?>
                </article>
            <?php endif; ?>

            <div class="category-stage<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="stream-list <?= htmlspecialchars('style-' . preg_replace('/[^a-z0-9-]+/i', '', $cardStyle)) ?>">
                    <?php foreach ($streamPosts as $index => $post): ?>
                        <article class="stream-card<?= $index % 2 === 1 ? ' is-shifted' : '' ?>">
                            <?php if (!empty($post['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($post['url']) ?>" class="stream-media">
                                    <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>
                            <div class="stream-copy">
                                <div class="stream-meta">
                                    <?php if ($showCategory && !empty($post['category_name'])): ?>
                                        <span class="stream-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($post['published_at'])): ?>
                                        <span class="stream-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>
                                <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                    <p><?= htmlspecialchars(mb_strimwidth((string) $post['summary'], 0, 200, '...')) ?></p>
                                <?php endif; ?>
                                <div class="stream-foot">
                                    <?php if ($showAuthor && !empty($post['author'])): ?>
                                        <span class="stream-author"><?= htmlspecialchars($post['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($post['url']) ?>" class="story-action subtle"><?= __('Open Story') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="stream-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Browse</span>
                                <h2><?= __('Categories') ?></h2>
                                <div class="category-list">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <?php $active = !empty($currentCategory['id']) && isset($category['id']) && $category['id'] == $currentCategory['id']; ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-entry<?= $active ? ' is-active' : '' ?>">
                                            <span><?= htmlspecialchars($category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <small><?= (int) $category['post_count'] ?></small>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card">
                                <span class="rail-kicker">Recent</span>
                                <h2><?= __('Latest Posts') ?></h2>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 4) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

