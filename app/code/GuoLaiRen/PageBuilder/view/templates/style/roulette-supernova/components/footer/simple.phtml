<?php
/**
 * Roulette Supernova - Simple Footer Component
 *
 * @component_start
 * code: footer-simple
 * name: 简洁底部
 * name_en: Simple Footer
 * description: Minimal roulette footer bar with editable copyright text.
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 * group:content => 内容配置
 * content.copyright_text => 版权信息:text:© 2026 Roulette Supernova. All rights reserved.
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#09090d
 * style.text_color => 文字颜色:color:#bcaea4
 * style.padding => 内边距:number:20|px
 * style.text_align => 对齐方式:select:center|left,center,right
 * @fields_end
 */

$componentId = 'rsn-footer-simple-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];
$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};
$text = trim((string) $getConfig('content.copyright_text', '© 2026 Roulette Supernova. All rights reserved.'));
$bgColor = (string) $getConfig('style.bg_color', $colors['footer_bg'] ?? '#09090d');
$textColor = (string) $getConfig('style.text_color', $colors['footer_text'] ?? '#bcaea4');
$padding = max(12, (int) $getConfig('style.padding', '20'));
$textAlign = (string) $getConfig('style.text_align', 'center');
?>
<footer id="<?= $componentId ?>" class="rsn-footer-simple">
    <div class="simple-footer-shell">
        <p><?= htmlspecialchars($text, ENT_QUOTES, 'UTF-8') ?></p>
    </div>
</footer>
<style>
#<?= $componentId ?> {
    width: 100%;
    background: <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    padding: <?= (int) $padding ?>px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
}
#<?= $componentId ?> .simple-footer-shell {
    width: min(1200px, calc(100% - 1rem));
    margin: 0 auto;
    text-align: <?= htmlspecialchars($textAlign, ENT_QUOTES, 'UTF-8') ?>;
}
#<?= $componentId ?> p {
    margin: 0;
    color: <?= htmlspecialchars($textColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: 0.82rem;
    line-height: 1.7;
}
</style>
