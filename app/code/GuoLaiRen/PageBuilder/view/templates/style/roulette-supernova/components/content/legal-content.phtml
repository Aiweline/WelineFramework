<?php
/**
 * Roulette Supernova - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: 法律文档内容
 * name_en: Legal Content
 * description: Roulette Supernova legal page with dark editorial framing, inline TOC, and policy-safe defaults.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:80|px
 * layout.content_padding => 内容内边距:number:44|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.bg_color => 背景色:color:#09090f
 * header.bg_gradient_end => 渐变结束色:color:#1b0910
 * header.title_color => 标题颜色:color:#f7f1e8
 * header.text_color => 文字颜色:color:#cbbcae
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:Policy Sections
 * toc.bg_color => 目录背景色:color:rgba(255,255,255,0.06)
 * toc.border_color => 目录边框色:color:rgba(255,255,255,0.10)
 *
 * group:content => 内容设置
 * content.bg_color => 内容区背景色:color:rgba(7,7,11,0.82)
 * content.text_color => 内容文字颜色:color:#d7cbc1
 * content.heading_color => 标题颜色:color:#f7f1e8
 * content.link_color => 链接颜色:color:#4df6ff
 *
 * @fields_end
 */

$componentId = 'rsn-legal-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';
$contentWidth = (string) $getConfig('layout.content_width', 'narrow');
$headerPadding = max(48, (int) $getConfig('layout.header_padding', 80));
$contentPadding = max(26, (int) $getConfig('layout.content_padding', 44));

$pageType = $page ? (string) ($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';
$lastUpdatedRaw = $page ? (string) ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';
$lastUpdatedTs = $lastUpdatedRaw !== '' ? strtotime($lastUpdatedRaw) : false;
$lastUpdated = $lastUpdatedTs ? date('F j, Y', $lastUpdatedTs) : trim($lastUpdatedRaw);

$headerTitle = trim((string) $getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Policy Document';
}

$typeMarkers = [
    'privacy_policy' => 'PP',
    'terms_of_service' => 'TS',
    'refund_policy' => 'RF',
    'shipping_policy' => 'DP',
    'cookie_policy' => 'CK',
];
$headerIcon = trim((string) $getConfig('header.icon', $typeMarkers[$pageType] ?? 'LG'));
$tocTitle = trim((string) $getConfig('toc.title', 'Policy Sections'));

$heroBg = (string) $getConfig('header.bg_color', $colors['hero_bg'] ?? '#09090f');
$heroBgEnd = (string) $getConfig('header.bg_gradient_end', $colors['faq_bg'] ?? '#1b0910');
$heroTitleColor = (string) $getConfig('header.title_color', $colors['text_primary'] ?? '#f7f1e8');
$heroTextColor = (string) $getConfig('header.text_color', $colors['text_secondary'] ?? '#cbbcae');
$tocBg = (string) $getConfig('toc.bg_color', $colors['card_bg'] ?? 'rgba(255,255,255,0.06)');
$tocBorder = (string) $getConfig('toc.border_color', $colors['border_light'] ?? 'rgba(255,255,255,0.10)');
$contentBg = (string) $getConfig('content.bg_color', 'rgba(7,7,11,0.82)');
$contentText = (string) $getConfig('content.text_color', '#d7cbc1');
$contentHeading = (string) $getConfig('content.heading_color', $colors['text_primary'] ?? '#f7f1e8');
$contentLink = (string) $getConfig('content.link_color', $colors['link_color'] ?? '#4df6ff');

$maxWidth = match ($contentWidth) {
    'wide' => '1180px',
    'medium' => '980px',
    default => '820px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int) $matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }
        $id = $slug . '-' . (++$headingIndex);

        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}
$hasToc = $showToc && !empty($tocItems);
?>
<section
    id="<?= $componentId ?>"
    class="rsn-legal"
    style="--rsn-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --rsn-legal-header-padding: <?= (int) $headerPadding ?>px; --rsn-legal-content-padding: <?= (int) $contentPadding ?>px; --rsn-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="legal-shell">
        <header class="legal-hero">
            <div class="hero-lights" aria-hidden="true">
                <span class="light light-1"></span>
                <span class="light light-2"></span>
                <span class="light light-3"></span>
            </div>
            <div class="hero-copy">
                <?php if ($showIcon && $headerIcon !== ''): ?>
                    <span class="hero-marker"><?= htmlspecialchars($headerIcon) ?></span>
                <?php endif; ?>
                <span class="hero-kicker">Rulebook</span>
                <h1><?= htmlspecialchars($headerTitle) ?></h1>
                <?php if ($showLastUpdated && $lastUpdated !== ''): ?>
                    <p class="hero-meta"><?= __('Last Updated') ?> <strong><?= htmlspecialchars($lastUpdated) ?></strong></p>
                <?php endif; ?>
            </div>
        </header>

        <div class="legal-stage<?= $hasToc ? ' has-toc' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-toc" aria-label="<?= htmlspecialchars((string) __('Table of contents')) ?>">
                    <div class="toc-card">
                        <strong class="toc-title"><?= htmlspecialchars($tocTitle) ?></strong>
                        <nav class="toc-links">
                            <?php foreach ($tocItems as $item): ?>
                                <a href="#<?= htmlspecialchars($item['id']) ?>" class="toc-link level-<?= (int) $item['level'] ?>">
                                    <span><?= str_pad((string) array_search($item, $tocItems, true) + 1, 2, '0', STR_PAD_LEFT) ?></span>
                                    <em><?= htmlspecialchars($item['text']) ?></em>
                                </a>
                            <?php endforeach; ?>
                        </nav>
                    </div>
                </aside>
            <?php endif; ?>

            <article class="legal-article<?= !$hasToc ? ' no-toc' : '' ?>">
                <div class="article-frame">
                    <div class="article-content">
                        <?php if ($pageContent !== ''): ?>
                            <?= $pageContent ?>
                        <?php else: ?>
                            <p><?= __('Add policy content here to publish the current rules, terms, or privacy details for this roulette site.') ?></p>
                        <?php endif; ?>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

