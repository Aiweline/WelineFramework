<?php
/**
 * Roulette Supernova - Header
 *
 * @fields_start
 *
 * group:header => 头部区域设置（Header）
 * header.logo.display => 显示Logo:select:yes|yes,no
 * header.logo.text => Logo文本:text:Roulette Supernova
 * header.logo.url => Logo地址:textarea:|默认使用本地roulette-logo-icon.svg
 * header.navigation.display => 显示导航:select:yes|yes,no
 * header.navigation.bg_color => 导航背景色:color:#12121c
 * header.navigation.text_color => 导航文字颜色:color:#f7f1e8
 * header.navigation.link_color => 链接颜色:color:#f7f1e8
 * header.navigation.link_hover_color => 链接悬停颜色:color:#dfff5a
 * header.navigation.items => 导航项配置:textarea:Home=>/\r\nTables=>#tables\r\nEdge=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|配置格式：名字=>url，一行一个
 * group:header_nav_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * header.navigation.label_home_page => 首页菜单名:text:
 * header.navigation.label_about_page => 关于我们菜单名:text:
 * header.navigation.label_blog_list => 博客菜单名:text:
 * header.navigation.label_contact_page => 联系我们菜单名:text:
 * header.navigation.label_terms_of_service => 条款菜单名:text:
 * header.navigation.label_privacy_policy => 隐私政策菜单名:text:
 * header.download_button.text => 下载按钮文本:text:Spin Now
 * header.download_button.display => 显示下载按钮:select:yes|yes,no
 * header.download_button.bg_color => 按钮背景颜色:color:#ff5b45
 * header.download_button.hover_bg_color => 按钮悬停背景色:color:#ffbf47
 * header.download_button.text_color => 按钮文字颜色:color:#130d08
 * header.download_button.url => 下载链接:text:#download
 *
 * group:banner => Banner兼容字段（Hero/Banner）
 * banner.display => 显示Banner区域:select:no|yes,no【建议使用hero-slider组件代替】
 * banner.image_mobile => 移动端Banner图片:textarea:|【已迁移到hero-slider组件】
 * banner.image_desktop => PC端Banner图片:textarea:|【已迁移到hero-slider组件】
 * banner.alt => Banner图片描述:text:Roulette Supernova hero
 * banner.download_btn_image => Banner中下载按钮图片:textarea:|【已迁移到hero-slider组件】
 * banner.download_btn_alt => Banner中下载按钮描述:text:Spin Now
 * banner.bg_color => Banner背景颜色:color:#05060d
 * banner.padding_v => Banner上下内边距:responsive:0/0|px[MD]
 * banner.slider_classes => Banner轮播区域CSS类:textarea:rsn-hero-stage
 *
 * group:color_scheme => 全局色系设置
 * color_scheme.scheme => 选择色系:select:default|default,blue,purple,green,red
 *
 * group:pixel => 像素统计
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}
 *
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];

$templateCode = $page ? $page->getData('style') : 'roulette-supernova';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'roulette-supernova';
}

$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
$this->assign('component_config', is_array($componentConfig) ? $componentConfig : []);
$this->assign('__rsn_shell_managed', true);
$this->assign('__pagebuilder_shell_managed', true);
?>
<?= $this->fetchTemplate('GuoLaiRen_PageBuilder::style/roulette-supernova/components/header/nav.phtml') ?>
