$componentId = 'rsn-about-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'yes') !== 'no';
$showCta = $getConfig('display.show_cta', 'yes') !== 'no';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';
$heroTitle = trim((string) $getConfig('hero.title', $pageTitle));
if ($heroTitle === '') {
    $heroTitle = 'About Roulette Supernova';
}
$heroKicker = trim((string) $getConfig('hero.kicker', 'Brand orbit'));
$heroSubtitle = trim((string) $getConfig('hero.subtitle', 'A roulette-focused landing system built to keep wheel entry, trust cues, and mobile hierarchy sharp.'));
$heroPadding = max(52, (int) $getConfig('hero.padding', 88));
$storyKicker = trim((string) $getConfig('story.kicker', 'Brand story'));
$storyTitle = trim((string) $getConfig('story.title', 'Why Roulette Supernova Reads Faster'));
$storySubtitle = trim((string) $getConfig('story.subtitle', 'A sharper roulette presentation keeps table selection, trust cues, and support paths easy to scan.'));
$storyContent = trim((string) $getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Roulette Supernova is built for roulette brands that want a stronger first impression without losing clarity. The layout keeps table entry points, support access, and trust signals visible from the first screen while still leaving room for brand story and operator details.';
}
$storyParagraphs = preg_split('/\r?\n\s*\r?\n/', $storyContent) ?: [];
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs)));
if (empty($storyParagraphs)) {
    $storyParagraphs = [trim($storyContent)];
}

$defaultStats = [
    ['24/7', 'Support route'],
    ['1-tap', 'Wheel entry'],
    ['3-layer', 'Contrast system'],
    ['Mobile', 'Responsive flow'],
];
$stats = [];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $defaultStats[$i - 1][0]));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $defaultStats[$i - 1][1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = ['number' => $number, 'label' => $label];
}
$orbitStats = array_slice($stats, 0, 4);

$valuesTitle = trim((string) $getConfig('values.title', 'What Players Feel First'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'Three editable pillars help this section stay bold, readable, and easy to adapt across roulette sites.'));
$defaultValues = [
    ['01', 'Wheel Clarity', 'The most important roulette interactions stay closest to the eye and never get buried under decoration.'],
    ['02', 'Bold Contrast', 'Text, cards, and action states are tuned for fast scanning on bright screens and smaller devices.'],
    ['03', 'Trust Signals', 'Support routes, policy access, and action cues stay visible so players can move through the roulette journey with more confidence.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $title = trim((string) $getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $desc = trim((string) $getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($title === '' && $desc === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string) $getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
        'title' => $title,
        'description' => $desc,
    ];
}

$teamTitle = trim((string) $getConfig('team.title', 'Behind The Table Flow'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', 'Editable role cards can introduce support, trust, content, or operations teams without breaking the roulette story.'));
$defaultMembers = [
    ['SP', 'Player Support', 'Issue routing and account help'],
    ['TR', 'Fair Play Review', 'Policy, trust, and table checks'],
    ['PD', 'Table Operations', 'Room flow and access planning'],
    ['CO', 'Content Desk', 'Guides, updates, and player copy'],
];
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $name = trim((string) $getConfig("team.member_{$i}_name", $defaultMembers[$i - 1][1]));
    $role = trim((string) $getConfig("team.member_{$i}_role", $defaultMembers[$i - 1][2]));
    if ($name === '' && $role === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => trim((string) $getConfig("team.member_{$i}_icon", $defaultMembers[$i - 1][0])),
        'name' => $name,
        'role' => $role,
    ];
}

$ctaTitle = trim((string) $getConfig('cta.title', 'Need help before you join a table?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Use this area to guide players toward support, verification, or account help while keeping the roulette journey clear.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Support'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact')) ?: '/contact';
$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#07070b');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#18070f');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#f7f1e8');
$heroTextColor = (string) $getConfig('hero.text_color', $colors['text_secondary'] ?? '#cbbcae');
$storyBg = (string) $getConfig('story.bg_color', '#0f1219');
$storyTitleColor = (string) $getConfig('story.title_color', '#f7f1e8');
$valuesBg = (string) $getConfig('values.bg_color', '#f7f0e5');
$statsCardBg = (string) $getConfig('stats.card_bg', 'rgba(255,255,255,0.06)');
$statsNumberColor = (string) $getConfig('stats.number_color', '#dfff5a');
$statsLabelColor = (string) $getConfig('stats.label_color', '#b8aba1');
$ctaButtonBg = (string) $getConfig('cta.button_bg', 'linear-gradient(135deg, #ff5b45 0%, #ffbf47 44%, #dfff5a 100%)');
$ctaButtonTextColor = (string) $getConfig('cta.button_text_color', '#130d08');
?>
<section
    id="<?= $componentId ?>"
    class="rsn-about"
    style="--rsn-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-stats-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-stat-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-stat-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>; --rsn-about-hero-padding: <?= (int) $heroPadding ?>px;"
>
    <div class="about-shell">
        <header class="hero-band">
            <div class="hero-copy">
                <?php if ($heroKicker !== ''): ?>
                    <span class="hero-kicker"><?= htmlspecialchars($heroKicker) ?></span>
                <?php endif; ?>
                <h1><?= htmlspecialchars($heroTitle) ?></h1>
                <?php if ($heroSubtitle !== ''): ?>
                    <p class="hero-subtitle"><?= htmlspecialchars($heroSubtitle) ?></p>
                <?php endif; ?>
            </div>

            <div class="hero-orbit" aria-hidden="true">
                <div class="orbit-core">
                    <?php if ($storyTitle !== ''): ?>
                        <span><?= htmlspecialchars($storyTitle) ?></span>
                    <?php endif; ?>
                    <?php if ($storySubtitle !== ''): ?>
                        <strong><?= htmlspecialchars($storySubtitle) ?></strong>
                    <?php endif; ?>
                </div>
                <?php foreach ($orbitStats as $index => $stat): ?>
                    <article class="orbit-stat orbit-stat-<?= (int) ($index + 1) ?>">
                        <strong><?= htmlspecialchars($stat['number']) ?></strong>
                        <span><?= htmlspecialchars($stat['label']) ?></span>
                    </article>
                <?php endforeach; ?>
            </div>
        </header>

        <section class="story-runway">
            <div class="runway-intro">
                <?php if ($storyKicker !== ''): ?>
                    <span class="section-kicker"><?= htmlspecialchars($storyKicker) ?></span>
                <?php endif; ?>
                <?php if ($storyTitle !== ''): ?>
                    <h2><?= htmlspecialchars($storyTitle) ?></h2>
                <?php endif; ?>
                <?php if ($storySubtitle !== ''): ?>
                    <p><?= htmlspecialchars($storySubtitle) ?></p>
                <?php endif; ?>
            </div>
            <div class="runway-body">
                <?php foreach ($storyParagraphs as $paragraph): ?>
                    <p><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                <?php endforeach; ?>
            </div>
        </section>

        <?php if ($showStats && !empty($stats)): ?>
            <section class="stats-ribbon" aria-label="About highlights">
                <?php foreach ($stats as $index => $stat): ?>
                    <article class="ribbon-card ribbon-card-<?= (int) ($index + 1) ?>">
                        <strong><?= htmlspecialchars($stat['number']) ?></strong>
                        <span><?= htmlspecialchars($stat['label']) ?></span>
                    </article>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showValues && !empty($values)): ?>
            <section class="values-track">
                <div class="track-head">
                    <span class="section-kicker">Player signals</span>
                    <?php if ($valuesTitle !== ''): ?>
                        <h2><?= htmlspecialchars($valuesTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($valuesSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                    <?php endif; ?>
                </div>
                <div class="track-lane">
                    <?php foreach ($values as $index => $value): ?>
                        <article class="value-panel value-panel-<?= (int) ($index + 1) ?>">
                            <span class="value-mark"><?= htmlspecialchars($value['icon']) ?></span>
                            <h3><?= htmlspecialchars($value['title']) ?></h3>
                            <p><?= htmlspecialchars($value['description']) ?></p>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showTeam && !empty($teamMembers)): ?>
            <section class="team-board">
                <div class="board-head">
                    <span class="section-kicker">Crew deck</span>
                    <?php if ($teamTitle !== ''): ?>
                        <h2><?= htmlspecialchars($teamTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($teamSubtitle !== ''): ?>
                        <p><?= htmlspecialchars($teamSubtitle) ?></p>
                    <?php endif; ?>
                </div>
                <div class="team-deck">
                    <?php foreach ($teamMembers as $index => $member): ?>
                        <article class="team-card team-card-<?= (int) ($index + 1) ?>">
                            <span class="team-icon"><?= htmlspecialchars($member['icon']) ?></span>
                            <div>
                                <h3><?= htmlspecialchars($member['name']) ?></h3>
                                <p><?= htmlspecialchars($member['role']) ?></p>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            </section>
        <?php endif; ?>

        <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
            <section class="cta-ribbon">
                <div class="cta-copy">
                    <?php if ($ctaTitle !== ''): ?>
                        <h2><?= htmlspecialchars($ctaTitle) ?></h2>
                    <?php endif; ?>
                    <?php if ($ctaDescription !== ''): ?>
                        <p><?= htmlspecialchars($ctaDescription) ?></p>
                    <?php endif; ?>
                </div>
                <?php if ($ctaButtonText !== ''): ?>
                    <a href="<?= htmlspecialchars($ctaButtonUrl) ?>" class="cta-button"><?= htmlspecialchars($ctaButtonText) ?></a>
                <?php endif; ?>
            </section>
        <?php endif; ?>
    </div>
</section>

<style>
