                </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </header>

    <main class="rsn-region-content relative flex min-w-0 flex-col" data-region="content">
        <?php foreach ($contentComponents as $index => $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
                <div class="rsn-component-wrapper" data-component="<?= htmlspecialchars($component['code']) ?>" data-index="<?= (int) $index ?>">
                    <?= $renderComponent($component) ?>
                </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </main>

    <footer class="rsn-region-footer relative w-full" data-region="footer">
        <?php foreach ($footerComponents as $component): ?>
            <?php if ($component['enabled'] ?? true): ?>
                <div class="rsn-component-wrapper" data-component="<?= htmlspecialchars($component['code']) ?>">
                    <?= $renderComponent($component) ?>
                </div>
            <?php endif; ?>
