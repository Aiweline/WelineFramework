<?php
/**
 * Roulette Supernova - Blog List Component
 *
 * @component_start
 * code: blog-list
 * name: 博客列表
 * name_en: Blog List
 * description: Roulette Supernova journal list with a lead story deck, signal rail, and responsive post grid.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 * blog.title|博客列表标题|text|Roulette Journal
 * blog.subtitle|副标题|text|Guides, table notes, feature updates, and roulette reading for fast-scanning landing pages.
 * blog.posts_per_page|每页显示数量|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=Yes,no=No|yes
 * blog.show_category|显示分类|select:yes=Yes,no=No|yes
 * blog.show_date|显示日期|select:yes=Yes,no=No|yes
 * blog.show_author|显示作者|select:yes=Yes,no=No|yes
 * blog.card_style|卡片样式|select:default=Default,minimal=Minimal,featured=Featured|default
 * @fields_end
 */

$componentId = 'rsn-blog-list-' . uniqid();
$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = trim((string) $getConfig('blog.title', 'Roulette Journal'));
$subtitle = trim((string) $getConfig('blog.subtitle', 'Guides, table notes, feature updates, and roulette reading for fast-scanning landing pages.'));
$postsPerPage = max(1, (int) $getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = (string) $getConfig('blog.card_style', 'default');

$visiblePosts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $visiblePosts[0] ?? null;
$gridPosts = array_slice($visiblePosts, 1);
$cardClass = 'style-' . preg_replace('/[^a-z0-9-]+/i', '', $cardStyle);
$blogBackground = (string) ($colors['blog_bg'] ?? 'linear-gradient(180deg, #07070b 0%, #13070d 100%)');
?>
<section id="<?= $componentId ?>" class="rsn-blog-list">
    <div class="blog-shell">
        <header class="blog-masthead">
            <span class="masthead-kicker">Roulette journal</span>
            <h1><?= htmlspecialchars($title !== '' ? $title : 'Roulette Journal') ?></h1>
            <?php if ($subtitle !== ''): ?>
                <p><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </header>

        <?php if (empty($visiblePosts)): ?>
            <section class="blog-empty" aria-label="<?= htmlspecialchars((string) __('Blog')) ?>">
                <span class="empty-mark">00</span>
                <h2><?= __('No articles published yet') ?></h2>
                <p><?= __('New roulette guides and updates will appear here once posts are available.') ?></p>
            </section>
        <?php else: ?>
            <div class="blog-stage<?= $showSidebar ? ' has-rail' : '' ?>">
                <div class="blog-main">
                    <?php if ($featuredPost): ?>
                        <article class="lead-story">
                            <?php if (!empty($featuredPost['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="lead-media">
                                    <img src="<?= htmlspecialchars($featuredPost['cover_image']) ?>" alt="<?= htmlspecialchars($featuredPost['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>

                            <div class="lead-copy">
                                <div class="lead-meta">
                                    <?php if ($showCategory && !empty($featuredPost['category_name'])): ?>
                                        <span class="story-chip"><?= htmlspecialchars($featuredPost['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($featuredPost['published_at'])): ?>
                                        <span class="story-date"><?= date('M d, Y', strtotime($featuredPost['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>
                                <h2>
                                    <a href="<?= htmlspecialchars($featuredPost['url']) ?>"><?= htmlspecialchars($featuredPost['title']) ?></a>
                                </h2>
                                <?php if (!empty($featuredPost['summary'])): ?>
                                    <p><?= htmlspecialchars(mb_strimwidth((string) $featuredPost['summary'], 0, 260, '...')) ?></p>
                                <?php endif; ?>
                                <div class="lead-foot">
                                    <?php if ($showAuthor && !empty($featuredPost['author'])): ?>
                                        <span class="story-author"><?= htmlspecialchars($featuredPost['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="story-link"><?= __('Read Article') ?></a>
                                </div>
                            </div>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($gridPosts)): ?>
                        <section class="story-grid <?= htmlspecialchars($cardClass) ?>" aria-label="<?= htmlspecialchars((string) __('Blog posts')) ?>">
                            <?php foreach ($gridPosts as $index => $post): ?>
                                <article class="story-card<?= $cardStyle === 'featured' && $index === 0 ? ' card-wide' : '' ?>">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="story-cover">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                        </a>
                                    <?php endif; ?>
                                    <div class="story-body">
                                        <div class="story-topline">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span class="story-chip"><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span class="story-date"><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>
                                        <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                        <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                            <p><?= htmlspecialchars(mb_strimwidth((string) $post['summary'], 0, 150, '...')) ?></p>
                                        <?php endif; ?>
                                        <div class="story-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span class="story-author"><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars($post['url']) ?>" class="story-link"><?= __('Open') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </section>
                    <?php endif; ?>
                </div>

                <?php if ($showSidebar): ?>
                    <aside class="signal-rail">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-card" aria-label="<?= htmlspecialchars((string) __('Categories')) ?>">
                                <div class="rail-head">
                                    <span class="rail-kicker">Filters</span>
                                    <h2><?= __('Categories') ?></h2>
                                </div>
                                <div class="category-cloud">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="category-pill"><?= htmlspecialchars($category['name']) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPosts)): ?>
                            <section class="rail-card" aria-label="<?= htmlspecialchars((string) __('Recent posts')) ?>">
                                <div class="rail-head">
                                    <span class="rail-kicker">Signal</span>
                                    <h2><?= __('Recent Posts') ?></h2>
                                </div>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPosts, 0, 4) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

