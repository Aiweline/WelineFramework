$componentId = 'rsn-faq-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showIntro = $getConfig('display.show_intro', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';
$bgColor = $getConfig('style.bg_color', $getConfig('faq.bg_color', '#1b0910'));
$accentColor = $getConfig('style.accent_color', '#dfff5a');
$titleColor = $getConfig('style.title_color', '#f7f1e8');
$textColor = $getConfig('style.text_color', '#cbbcae');
$panelBgColor = $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.06)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,255,255,0.08)');
$cardRadius = (int) $getConfig('style.card_radius', '24');
$sectionPadding = (int) $getConfig('style.section_padding', '72');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '48');
$badgeText = trim((string) $getConfig('texts.badge', $getConfig('texts.faq_badge', 'Roulette Support')));
$title = trim((string) $getConfig('texts.title', $getConfig('faq.title', 'Frequently Asked Questions')));
$intro = trim((string) $getConfig('texts.intro', $getConfig('texts.faq_intro', 'Open any roulette question inline to compare table flow, mobile readability, and support paths without leaving the section.')));
$tags = array_values(array_filter([
    trim((string) $getConfig('texts.tag_1', 'Fast Join')),
    trim((string) $getConfig('texts.tag_2', 'Live Wheel')),
    trim((string) $getConfig('texts.tag_3', 'Mobile Ready')),
]));

$defaults = [
    ['question' => 'How do I choose the right roulette table here?', 'answer' => 'Start with the table labels and short descriptions. Faster rooms suit short sessions, while steadier rooms are better if you want more time to read the wheel and bets.'],
    ['question' => 'Does Roulette Supernova work well on mobile?', 'answer' => 'Yes. The key wheel view, table buttons, and support sections are arranged to stay readable on smaller screens without awkward overflow.'],
    ['question' => 'Can I move between live and classic roulette rooms quickly?', 'answer' => 'Yes. The homepage keeps table switching direct, so you can compare room styles and move into another roulette lane without digging through clutter.'],
    ['question' => 'Are the bet zones easy to read for new players?', 'answer' => 'Yes. Contrast is kept strong so straight bets, color bets, and common roulette actions remain easy to scan before you join.'],
    ['question' => 'Do the quick-entry buttons take me straight to the room list?', 'answer' => 'Yes. Primary actions are placed close to the table descriptions so the route from homepage to roulette room stays short and obvious.'],
    ['question' => 'Where can I find help if I get stuck on a table?', 'answer' => 'Use the support and contact areas linked across the site. They stay easy to reach from the main navigation and footer.'],
];

$faqEntries = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i - 1];
    $question = trim((string) $getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string) $getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question !== '' && $answer !== '') {
        $faqEntries[] = [
            'index' => count($faqEntries),
            'question' => $question,
            'answer' => $answer,
        ];
    }
}

if (empty($faqEntries)) {
    foreach (array_slice($defaults, 0, 4) as $index => $defaultFaq) {
        $faqEntries[] = [
            'index' => $index,
            'question' => $defaultFaq['question'],
            'answer' => $defaultFaq['answer'],
        ];
    }
}

$splitSize = max(1, (int) ceil(count($faqEntries) / 2));
$faqColumns = array_chunk($faqEntries, $splitSize);
if (count($faqColumns) === 1) {
    $faqColumns[] = [];
}
?>
<section id="<?= $componentId ?>" class="rsn-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell">
        <header class="faq-head" id="faq">
            <?php if ($badgeText !== ''): ?>
                <span class="faq-badge"><?= htmlspecialchars($badgeText) ?></span>
            <?php endif; ?>
            <?php if ($showTitle && $title !== ''): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($showIntro && $intro !== ''): ?>
                <p class="faq-intro"><?= htmlspecialchars($intro) ?></p>
            <?php endif; ?>
            <?php if (!empty($tags)): ?>
                <div class="faq-tags">
                    <?php foreach ($tags as $tag): ?>
                        <span><?= htmlspecialchars($tag) ?></span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </header>

        <div class="faq-board" aria-label="Frequently asked questions">
            <?php foreach ($faqColumns as $columnIndex => $columnItems): ?>
                <div class="faq-column faq-column-<?= (int) ($columnIndex + 1) ?>" role="list">
                    <?php foreach ($columnItems as $entry): ?>
                        <?php $toneClass = 'faq-card-' . (string) ((($entry['index']) % 4) + 1); ?>
                        <details class="faq-card <?= htmlspecialchars($toneClass) ?> <?= $entry['index'] % 2 === 0 ? 'faq-card-left' : 'faq-card-right' ?>" role="listitem"<?= $firstOpen && $entry['index'] === 0 ? ' open' : '' ?>>
                            <summary>
                                <span class="faq-index"><?= sprintf('%02d', $entry['index'] + 1) ?></span>
                                <span class="faq-summary-copy">
                                    <strong><?= htmlspecialchars($entry['question']) ?></strong>
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-answer">
                                <p><?= nl2br(htmlspecialchars($entry['answer'])) ?></p>
                            </div>
                        </details>
                    <?php endforeach; ?>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>

