<?php
/**
 * Roulette Supernova - Contact Content Component
 *
 * @component_start
 * code: contact-content
 * name: 联系我们内容
 * name_en: Contact Content
 * description: Roulette Supernova support page with route cards, message dock, and optional map.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_map => 显示地图:select:yes|yes,no
 * display.show_form => 显示联系表单:select:yes|yes,no
 * display.show_social => 显示社交链接:select:yes|yes,no
 * display.show_info => 显示联系信息:select:yes|yes,no
 *
 * group:hero => 顶部横幅
 * hero.kicker => 页面辅助标题:text:Support route
 * hero.title => 页面标题:text:Contact Roulette Supernova
 * hero.subtitle => 页面副标题:textarea:Need help with room access, account questions, or roulette support? Use the contact routes below to reach the right desk.
 * hero.bg_color => 背景色:color:#07070b
 * hero.bg_gradient_end => 渐变结束色:color:#18070f
 * hero.title_color => 标题颜色:color:#f7f1e8
 *
 * group:contact_info => 联系信息
 * contact_info.address => 地址:textarea:Mumbai, India
 * contact_info.phone => 电话:text:+91 1800-XXX-XXXX
 * contact_info.email => 邮箱:text:support@roulettesupernova.com
 * contact_info.work_hours => 工作时间:text:24/7 Roulette Support
 *
 * group:social => 社交媒体
 * social.wechat => 微信:text:
 * social.weibo => 微博:text:
 * social.facebook => Facebook:text:
 * social.twitter => Twitter:text:
 * social.linkedin => LinkedIn:text:
 *
 * group:form => 表单设置
 * form.title => 表单标题:text:Send A Support Request
 * form.submit_text => 提交按钮:text:Send Message
 * form.success_message => 成功提示:text:Share your UID, device, and issue details so the support team can route the request faster.
 *
 * group:map => 地图设置
 * map.embed_url => 地图嵌入链接:textarea:
 * map.height => 地图高度:number:360|px
 *
 * @fields_end
 */

$componentId = 'rsn-contact-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$heroKicker = trim((string) $getConfig('hero.kicker', 'Support route'));
$title = trim((string) $getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'Contact Roulette Supernova';
}
$description = trim((string) $getConfig('hero.subtitle', 'Need help with room access, account questions, or roulette support? Use the contact routes below to reach the right desk.'));
$email = trim((string) $getConfig('contact_info.email', 'support@roulettesupernova.com'));
$phone = trim((string) $getConfig('contact_info.phone', '+91 1800-XXX-XXXX'));
$address = trim((string) $getConfig('contact_info.address', 'Mumbai, India'));
$hours = trim((string) $getConfig('contact_info.work_hours', '24/7 Roulette Support'));
$formTitle = trim((string) $getConfig('form.title', 'Send A Support Request'));
$formSubmitText = trim((string) $getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string) $getConfig('form.success_message', 'Share your UID, device, and issue details so the support team can route the request faster.'));
$mapEmbedUrl = trim((string) $getConfig('map.embed_url', ''));
$mapHeight = max(240, (int) $getConfig('map.height', 360));
$contactCards = [];
if ($email !== '') {
    $contactCards[] = ['label' => __('Email'), 'value' => $email, 'icon' => 'EM', 'href' => 'mailto:' . $email];
}
if ($phone !== '') {
    $contactCards[] = ['label' => __('Phone'), 'value' => $phone, 'icon' => 'PH', 'href' => 'tel:' . preg_replace('/[^0-9+]/', '', $phone)];
}
if ($address !== '') {
    $contactCards[] = ['label' => __('Address'), 'value' => $address, 'icon' => 'AD', 'href' => ''];
}
if ($hours !== '') {
    $contactCards[] = ['label' => __('Support Hours'), 'value' => $hours, 'icon' => '24', 'href' => ''];
}
$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string) $getConfig($key, ''));
    if ($url !== '') {
        $socials[] = ['name' => $label, 'url' => $url];
    }
}
$heroBg = (string) $getConfig('hero.bg_color', $colors['hero_bg'] ?? '#07070b');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#18070f');
$heroTitleColor = (string) $getConfig('hero.title_color', $colors['text_primary'] ?? '#f7f1e8');
?>
<section
    id="<?= $componentId ?>"
    class="rsn-contact"
    style="--rsn-contact-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --rsn-contact-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --rsn-contact-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>;"
>
    <div class="contact-shell">
        <header class="contact-hero">
            <?php if ($heroKicker !== ''): ?>
                <span class="hero-kicker"><?= htmlspecialchars($heroKicker) ?></span>
            <?php endif; ?>
            <h1><?= htmlspecialchars($title) ?></h1>
            <?php if ($description !== ''): ?>
                <p><?= htmlspecialchars($description) ?></p>
            <?php endif; ?>
        </header>

        <?php if ($showInfo && !empty($contactCards)): ?>
            <section class="contact-grid" aria-label="Support channels">
                <?php foreach ($contactCards as $card): ?>
                    <?php if ($card['href'] !== ''): ?>
                        <a class="contact-card" href="<?= htmlspecialchars($card['href']) ?>">
                            <span class="contact-icon"><?= htmlspecialchars($card['icon']) ?></span>
                            <span class="contact-label"><?= htmlspecialchars($card['label']) ?></span>
                            <strong><?= htmlspecialchars($card['value']) ?></strong>
                        </a>
                    <?php else: ?>
                        <article class="contact-card">
                            <span class="contact-icon"><?= htmlspecialchars($card['icon']) ?></span>
                            <span class="contact-label"><?= htmlspecialchars($card['label']) ?></span>
                            <strong><?= htmlspecialchars($card['value']) ?></strong>
                        </article>
                    <?php endif; ?>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showSocial && !empty($socials)): ?>
            <section class="social-strip" aria-label="<?= htmlspecialchars((string) __('Social links')) ?>">
                <?php foreach ($socials as $social): ?>
                    <a href="<?= htmlspecialchars($social['url']) ?>" class="social-pill" target="_blank" rel="noopener">
                        <span><?= htmlspecialchars(mb_strtoupper(mb_substr($social['name'], 0, 2))) ?></span>
                        <small><?= htmlspecialchars($social['name']) ?></small>
                    </a>
                <?php endforeach; ?>
            </section>
        <?php endif; ?>

        <?php if ($showForm): ?>
            <div class="contact-stage">
                <section class="message-dock">
                    <div class="dock-head">
                        <?php if ($formTitle !== ''): ?>
                            <h2><?= htmlspecialchars($formTitle) ?></h2>
                        <?php endif; ?>
                        <?php if ($formSuccessMessage !== ''): ?>
                            <p><?= htmlspecialchars($formSuccessMessage) ?></p>
                        <?php endif; ?>
                    </div>
                    <form class="contact-form">
                        <div class="field-row">
                            <label class="field">
                                <span><?= __('Full Name') ?></span>
                                <input type="text" placeholder="<?= htmlspecialchars((string) __('Enter your name')) ?>">
                            </label>
                            <label class="field">
                                <span><?= __('Email Address') ?></span>
                                <input type="email" placeholder="<?= htmlspecialchars((string) __('Enter your email')) ?>">
                            </label>
                        </div>
                        <label class="field">
                            <span><?= __('Subject') ?></span>
                            <input type="text" placeholder="<?= htmlspecialchars((string) __('What is this about?')) ?>">
                        </label>
                        <label class="field">
                            <span><?= __('Message') ?></span>
                            <textarea placeholder="<?= htmlspecialchars((string) __('Tell us how we can help...')) ?>"></textarea>
                        </label>
                        <button type="submit" class="submit-btn"><?= htmlspecialchars($formSubmitText) ?></button>
                    </form>
                </section>
            </div>
        <?php endif; ?>

        <?php if ($showMap && $mapEmbedUrl !== ''): ?>
            <section class="map-stage" aria-label="<?= htmlspecialchars((string) __('Map')) ?>">
                <iframe src="<?= htmlspecialchars($mapEmbedUrl) ?>" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height: <?= (int) $mapHeight ?>px;"></iframe>
            </section>
        <?php endif; ?>
    </div>
</section>

