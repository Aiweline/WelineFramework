 * style.section_padding_mobile => 区域内边距(移动端):number:48|px
 *
 * group:texts => 文本内容
 * texts.kicker => 辅助标题:text:Player reaction
 * texts.title => 区域标题:text:What Players Notice First
 * texts.avg_label => 平均评分标题:text:Average rating
 * texts.avg_suffix => 平均评分后缀:text:player reviews
 * texts.testimonial_1_name => 评价1姓名:text:Aarav Sinha
 * texts.testimonial_1_tag => 评价1标签:text:Flash Wheel
 * texts.testimonial_1_rating => 评价1评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_1_content => 评价1内容:textarea:The wheel stays obvious, the join path is quick, and I never lose the important roulette actions on mobile.
 * texts.testimonial_2_name => 评价2姓名:text:Meera Joshi
 * texts.testimonial_2_tag => 评价2标签:text:Classic Orbit
 * texts.testimonial_2_rating => 评价2评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_2_content => 评价2内容:textarea:The contrast helps me read stake zones fast, especially when I move between slower and faster roulette rooms.
 * texts.testimonial_3_name => 评价3姓名:text:Rohan Verma
 * texts.testimonial_3_tag => 评价3标签:text:Night Table
 * texts.testimonial_3_rating => 评价3评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_3_content => 评价3内容:textarea:I like that the darker table still keeps the wheel bright, so the page feels lively without getting messy.
 * texts.testimonial_4_name => 评价4姓名:text:Ananya Pillai
 * texts.testimonial_4_tag => 评价4标签:text:Private Pit
 * texts.testimonial_4_rating => 评价4评分:text:⭐⭐⭐⭐⭐
 * texts.testimonial_4_content => 评价4内容:textarea:The layout makes private roulette rooms feel premium, and the action buttons stay easy to hit.
 * texts.testimonial_5_name => 评价5姓名:text:Kabir Rao
 * texts.testimonial_5_tag => 评价5标签:text:Starter Wheel
 * texts.testimonial_5_rating => 评价5评分:text:⭐⭐⭐⭐☆
 * texts.testimonial_5_content => 评价5内容:textarea:New players can settle in quickly because the table names, buttons, and wheel are all easy to spot.
 *
 * group:avatars => 头像配置
 * avatars.avatar_1 => 评价1头像:textarea:
 * avatars.avatar_2 => 评价2头像:textarea:
 * avatars.avatar_3 => 评价3头像:textarea:
 * avatars.avatar_4 => 评价4头像:textarea:
 * avatars.avatar_5 => 评价5头像:textarea:
 *
 * @fields_end
 */

$componentId = 'rsn-testimonials-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('testimonials.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showRating = $getConfig('display.show_rating', 'yes') !== 'no';
$showAvatar = $getConfig('display.show_avatar', 'yes') !== 'no';
$showAvg = $getConfig('display.show_avg', 'yes') !== 'no';
$bgColor = $getConfig('style.bg_color', $getConfig('testimonials.bg_color', '#0b0b12'));
$accentColor = $getConfig('style.accent_color', '#dfff5a');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.08)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(255,255,255,0.08)');
$textColor = $getConfig('style.text_color', '#f7f1e8');
$sectionPadding = (int) $getConfig('style.section_padding', '84');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '48');
$kicker = trim((string) $getConfig('texts.kicker', 'Player reaction'));
$title = trim((string) $getConfig('texts.title', $getConfig('testimonials.title', 'What Players Notice First')));
$avgLabelText = trim((string) $getConfig('texts.avg_label', 'Average rating'));
$avgSuffix = trim((string) $getConfig('texts.avg_suffix', 'player reviews'));

$parseRating = function ($raw) {
    $raw = trim((string) $raw);
    if ($raw === '') {
        return 0;
    }
    if (is_numeric($raw)) {
        return (int) $raw;
    }
    preg_match_all('/[★⭐]/u', $raw, $matches);
    return count($matches[0] ?? []);
};

$defaults = [
    ['name' => 'Aarav Sinha', 'tag' => 'Flash Wheel', 'rating' => '⭐⭐⭐⭐⭐', 'text' => 'The wheel stays obvious, the join path is quick, and I never lose the important roulette actions on mobile.'],
    ['name' => 'Meera Joshi', 'tag' => 'Classic Orbit', 'rating' => '⭐⭐⭐⭐⭐', 'text' => 'The contrast helps me read stake zones fast, especially when I move between slower and faster roulette rooms.'],
    ['name' => 'Rohan Verma', 'tag' => 'Night Table', 'rating' => '⭐⭐⭐⭐⭐', 'text' => 'I like that the darker table still keeps the wheel bright, so the page feels lively without getting messy.'],
    ['name' => 'Ananya Pillai', 'tag' => 'Private Pit', 'rating' => '⭐⭐⭐⭐⭐', 'text' => 'The layout makes private roulette rooms feel premium, and the action buttons stay easy to hit.'],
    ['name' => 'Kabir Rao', 'tag' => 'Starter Wheel', 'rating' => '⭐⭐⭐⭐☆', 'text' => 'New players can settle in quickly because the table names, buttons, and wheel are all easy to spot.'],
];

$reviews = [];
for ($i = 1; $i <= 5; $i++) {
    $default = $defaults[$i - 1];
    $name = trim((string) $getConfig("texts.testimonial_{$i}_name", $default['name']));
    $tag = trim((string) $getConfig("texts.testimonial_{$i}_tag", $default['tag']));
    $ratingText = trim((string) $getConfig("texts.testimonial_{$i}_rating", $default['rating']));
    $content = trim((string) $getConfig("texts.testimonial_{$i}_content", $default['text']));
    $avatar = trim((string) $getConfig("avatars.avatar_{$i}", ''));
    if ($name !== '' && $content !== '') {
        $ratingValue = max(0, min(5, $parseRating($ratingText)));
        $reviews[] = [
            'name' => $name,
            'tag' => $tag,
            'rating' => $ratingValue,
            'rating_text' => $ratingText !== '' ? $ratingText : str_repeat('★', max(1, $ratingValue)),
            'text' => $content,
            'avatar' => $avatar,
        ];
    }
}

if (empty($reviews)) {
    foreach ($defaults as $default) {
        $reviews[] = [
            'name' => $default['name'],
            'tag' => $default['tag'],
            'rating' => $parseRating($default['rating']),
            'rating_text' => $default['rating'],
            'text' => $default['text'],
            'avatar' => '',
        ];
    }
}

$totalRating = array_sum(array_column($reviews, 'rating'));
$avgRating = count($reviews) ? $totalRating / count($reviews) : 0;
$avgLabel = number_format($avgRating, 1);
$avgStars = str_repeat('★', max(1, min(5, (int) round($avgRating))));

$buildInitials = function ($name) {
    $parts = preg_split('/\s+/', trim((string) $name));
    $first = $parts[0] ?? '';
    $second = $parts[1] ?? $first;
    return strtoupper(substr($first, 0, 1) . substr($second, 0, 1));
};

$reviewLayouts = ['featured', 'lane-a', 'lane-b', 'lane-c', 'lane-d'];
?>
<section id="<?= $componentId ?>" class="rsn-testimonials" aria-labelledby="<?= $componentId ?>-title">
    <div class="voices-shell">
        <header class="voices-head" id="reviews">
            <?php if ($kicker !== ''): ?>
                <span class="voices-kicker"><?= htmlspecialchars($kicker) ?></span>
            <?php endif; ?>
            <?php if ($showTitle && $title !== ''): ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
        </header>

        <div class="voices-layout<?= $showAvg ? ' has-summary' : '' ?>">
            <?php if ($showAvg): ?>
                <aside class="voices-summary" aria-label="Average player rating">
                    <?php if ($avgLabelText !== ''): ?>
                        <span class="summary-label"><?= htmlspecialchars($avgLabelText) ?></span>
                    <?php endif; ?>
                    <div class="summary-score-row">
                        <strong><?= htmlspecialchars($avgLabel) ?></strong>
                        <span class="summary-stars" aria-label="<?= htmlspecialchars($avgLabel) ?> out of 5"><?= htmlspecialchars($avgStars) ?></span>
                    </div>
                    <?php if ($avgSuffix !== ''): ?>
                        <small><?= count($reviews) ?> <?= htmlspecialchars($avgSuffix) ?></small>
                    <?php endif; ?>
                </aside>
            <?php endif; ?>

            <div class="voices-grid" role="list" aria-label="Player reviews">
                <?php foreach ($reviews as $index => $review): ?>
                    <?php $layoutClass = $reviewLayouts[$index % count($reviewLayouts)]; ?>
                    <article class="review-card review-card-<?= htmlspecialchars($layoutClass) ?>" role="listitem">
                        <div class="review-card-top">
                            <?php if ($review['tag'] !== ''): ?>
                                <span class="review-tag"><?= htmlspecialchars($review['tag']) ?></span>
                            <?php endif; ?>
                            <?php if ($showRating): ?>
                                <span class="review-stars"><?= htmlspecialchars($review['rating_text']) ?></span>
                            <?php endif; ?>
                        </div>
                        <blockquote><?= htmlspecialchars($review['text']) ?></blockquote>
                        <footer class="review-foot<?= $showAvatar ? '' : ' no-avatar' ?>">
                            <?php if ($showAvatar): ?>
                                <span class="review-avatar">
                                    <?php if ($review['avatar'] !== ''): ?>
                                        <img src="<?= htmlspecialchars($review['avatar']) ?>" alt="<?= htmlspecialchars($review['name']) ?>">
                                    <?php else: ?>
                                        <?= htmlspecialchars($buildInitials($review['name'])) ?>
                                    <?php endif; ?>
                                </span>
                            <?php endif; ?>
                            <span class="review-meta">
                                <strong><?= htmlspecialchars($review['name']) ?></strong>
                                <?php if ($review['tag'] !== ''): ?>
                                    <small><?= htmlspecialchars($review['tag']) ?></small>
                                <?php endif; ?>
                            </span>
                        </footer>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</section>

