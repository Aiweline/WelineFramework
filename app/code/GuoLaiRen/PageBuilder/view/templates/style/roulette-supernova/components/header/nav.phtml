<script>
(function () {
    var nav = document.getElementById('<?= $componentId ?>');
    if (!nav) {
        return;
    }

    var toggle = nav.querySelector('.nav-toggle');
    var panel = nav.querySelector('.mobile-panel');
    var close = nav.querySelector('.mobile-close');
    var links = nav.querySelectorAll('.mobile-link, .mobile-cta');
    var originalOverflow = '';

    function setOpen(next) {
        nav.setAttribute('data-mobile-open', next ? 'true' : 'false');
        if (toggle) {
            toggle.setAttribute('aria-expanded', next ? 'true' : 'false');
        }
        if (panel) {
            panel.setAttribute('aria-hidden', next ? 'false' : 'true');
        }
        if (document.body) {
            if (!originalOverflow) {
                originalOverflow = document.body.style.overflow || '';
            }
            document.body.style.overflow = next ? 'hidden' : originalOverflow;
        }
    }

    if (toggle) {
        toggle.addEventListener('click', function () {
            setOpen(nav.getAttribute('data-mobile-open') !== 'true');
        });
    }

    if (close) {
        close.addEventListener('click', function () {
            setOpen(false);
        });
    }

    links.forEach(function (link) {
        link.addEventListener('click', function () {
            setOpen(false);
        });
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && nav.getAttribute('data-mobile-open') === 'true') {
            setOpen(false);
        }
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 992 && nav.getAttribute('data-mobile-open') === 'true') {
            setOpen(false);
        }
    });
})();
</script>

