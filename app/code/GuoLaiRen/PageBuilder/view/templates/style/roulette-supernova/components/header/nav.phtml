/**
 * Roulette Supernova - Navigation
 *
 * @component_start
 * code: header-nav
 * name: 导航栏
 * name_en: Navigation Bar
 * description: Roulette Supernova compact navigation with a lighter desktop height and a layered mobile drawer.
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:Roulette Supernova
 * logo.url => Logo图片URL:textarea:|留空使用默认图标
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#12121c
 * navigation.text_color => 导航文字颜色:color:#f7f1e8
 * navigation.link_color => 导航链接颜色:color:#f7f1e8
 * navigation.link_hover_color => 链接悬停颜色:color:#dfff5a
 * navigation.items => 导航项:textarea:Home=>/\r\nTables=>#tables\r\nEdge=>#advantages\r\nReviews=>#reviews\r\nFAQ=>#faq|格式：文本=>链接
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.use_subpages => 使用子页面作为导航:select:no|yes,no
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:Spin Now
 * download_button.bg_color => 按钮背景颜色:color:#ff5b45
 * download_button.bg_hover_color => 按钮悬停背景色:color:#ffbf47
 * download_button.text_color => 按钮文字颜色:color:#130d08
 * download_button.url => 按钮链接:text:#download
 * @fields_end
 */

$componentId = 'rsn-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];
$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$metaTitleRaw = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Roulette Supernova';
$metaTitle = $sanitizeTitle($metaTitleRaw);
if ($metaTitle === '') {
    $metaTitle = 'Roulette Supernova';
}
$metaDescription = $page ? trim((string) ($page->getData('meta_description') ?: '')) : '';

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
if (!$navDisplay) {
    return;
}

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name', 'texts.app_name'], 'Roulette Supernova'));
if ($logoText === '') {
    $logoText = 'Roulette Supernova';
}
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/roulette-supernova/asset/img/roulette-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);

$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], $colors['nav_bg'] ?? '#12121c');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], $colors['nav_text'] ?? '#f7f1e8');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], $colors['nav_link'] ?? '#f7f1e8');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], $colors['nav_link_hover'] ?? '#dfff5a');
$ctaDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Spin Now'));
$ctaUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download'));
$ctaHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaHref, 'url');
$ctaBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], $colors['accent_primary'] ?? '#ff5b45');
$ctaBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], $colors['accent_primary_dark'] ?? '#ffbf47');
$ctaTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], $colors['button_primary_text'] ?? '#130d08');

$navItemsConfig = (string) $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nTables=>#tables\nEdge=>#advantages\nReviews=>#reviews\nFAQ=>#faq");
$useCustomLinksRaw = trim((string) $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], ''));
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('navigation.use_subpages', 'no'), 'no') !== 'yes';
$navItems = [];

if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);

    foreach ($navigationPages as $navPage) {
        $title = trim((string) ($navPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }

        $type = (string) ($navPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny([
            'navigation_labels.navigation.label_' . $type,
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], ''));

        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $title,
            'href' => (string) ($navPage['url'] ?? '#'),
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\n', "\n", $navItemsConfig);
    }

    foreach (preg_split('/\r?\n/', $navItemsConfig) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }

        $parts = explode('=>', $line, 2);
        $text = trim((string) ($parts[0] ?? ''));
        $href = trim((string) ($parts[1] ?? ''));

        if ($text === '') {
            continue;
        }

        $navItems[] = [
            'text' => $text,
            'href' => $href !== '' ? $href : '#',
        ];
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'Tables', 'href' => '#tables'],
        ['text' => 'Reviews', 'href' => '#reviews'],
        ['text' => 'FAQ', 'href' => '#faq'],
    ];
}
?>

