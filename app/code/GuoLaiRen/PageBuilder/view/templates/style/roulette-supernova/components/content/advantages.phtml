                <?php endif; ?>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
            </header>
        <?php endif; ?>

        <div class="adv-orbit" style="--adv-gap: <?= (int) $cardGap ?>px;">
            <div class="adv-hub" aria-hidden="true">
                <div class="hub-ring hub-ring-a"></div>
                <div class="hub-ring hub-ring-b"></div>
                <div class="hub-core">
                    <?php if ($hubLabel !== ''): ?>
