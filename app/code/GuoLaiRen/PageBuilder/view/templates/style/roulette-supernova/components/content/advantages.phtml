$componentId = 'rsn-advantages-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('advantages.display', 'yes')) !== 'no';
if (!$display) {
    return;
}
$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$bgColor = $getConfig('style.bg_color', $getConfig('advantages.bg_color', '#f7f0e5'));
$titleColor = $getConfig('style.title_color', '#140d10');
$cardBgColor = $getConfig('style.card_bg_color', 'rgba(255,255,255,0.9)');
$cardBorderColor = $getConfig('style.card_border_color', 'rgba(20,13,16,0.08)');
$cardTitleColor = $getConfig('style.card_title_color', '#140d10');
$cardDescColor = $getConfig('style.card_desc_color', '#5c4f48');
$sectionPadding = (int) $getConfig('style.section_padding', '80');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '48');
$cardGap = (int) $getConfig('style.card_gap', '24');
$kicker = trim((string) $getConfig('texts.kicker', 'Table strengths'));
$title = trim((string) $getConfig('texts.title', $getConfig('advantages.title', 'Why Roulette Supernova Shifts The Feel')));
$hubLabel = trim((string) $getConfig('texts.hub_label', 'Roulette'));
$items = [
    [
        'icon' => $getConfig('texts.advantage_1_icon', '01'),
        'title' => $getConfig('texts.advantage_1_title', 'Wheel-First Hierarchy'),
        'desc' => $getConfig('texts.advantage_1_desc', 'Key roulette actions, bet labels, and room entry points are surfaced without burying the wheel itself.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_2_icon', '02'),
        'title' => $getConfig('texts.advantage_2_title', 'Hard Contrast, Fast Scan'),
        'desc' => $getConfig('texts.advantage_2_desc', 'Dark panels, sharp highlights, and bright state markers keep busy screens easier to read on mobile.'),
    ],
    [
        'icon' => $getConfig('texts.advantage_3_icon', '03'),
        'title' => $getConfig('texts.advantage_3_title', 'Pace Changes Stay Clear'),
        'desc' => $getConfig('texts.advantage_3_desc', 'Switching from faster tables to steadier roulette rooms still feels clean because the wheel, labels, and actions stay easy to track.'),
