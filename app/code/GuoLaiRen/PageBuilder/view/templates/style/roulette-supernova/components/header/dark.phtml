<?php
/**
 * Roulette Supernova - Dark Header Component
 *
 * @component_start
 * code: header-dark
 * name: 深色头部
 * name_en: Dark Header
 * description: Alternative dark roulette header with logo, links, and a compact CTA lane.
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url => Logo图片URL:textarea:|留空使用默认图标
 * logo.text => Logo文字:text:Roulette Supernova
 * logo.width => Logo宽度:text:48px
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.use_subpages => 使用子页面作为导航:select:no|yes,no
 * navigation.items => 导航项:textarea:Home=>/
Tables=>#tables
Reviews=>#reviews
FAQ=>#faq|格式：文本=>链接
 * group:button => 按钮设置
 * button.display => 显示按钮:select:yes|yes,no
 * button.text => 按钮文字:text:Spin Now
 * button.url => 按钮链接:text:#download
 * group:style => 样式设置
 * style.background => 背景色:color:#11131c
 * style.nav_color => 导航文字色:color:#f7f1e8
 * style.accent_color => 强调色:color:#ff5b45
 * style.height => 头部高度:text:76px
 * @fields_end
 */

$componentId = 'rsn-header-dark-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge(is_array($styleSettings) ? $styleSettings : [], is_array($componentConfig) ? $componentConfig : []);
$colors = isset($colors) && is_array($colors) ? $colors : [];
$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};
$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};
$parseNavItems = static function ($value) {
    $value = (string) $value;
    if (strpos($value, '\\n') !== false && strpos($value, "\n") === false) {
        $value = str_replace('\\n', "\n", $value);
    }
    $items = [];
    foreach (preg_split('/\r?\n/', $value) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = strpos($line, '=>') !== false ? explode('=>', $line, 2) : [$line, '#'];
        $text = trim((string) ($parts[0] ?? ''));
        $href = trim((string) ($parts[1] ?? '#'));
        if ($text === '') {
            continue;
        }
        $items[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
    }
    return $items;
};
$logoDisplay = $getConfig('logo.display', 'yes') !== 'no';
$navDisplay = $getConfig('navigation.display', 'yes') !== 'no';
$buttonDisplay = $getConfig('button.display', 'yes') !== 'no';
$logoText = trim((string) $getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name'], 'Roulette Supernova'));
if ($logoText === '') {
    $logoText = 'Roulette Supernova';
}
$defaultLogo = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/roulette-supernova/asset/img/roulette-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $defaultLogo);
$logoWidth = trim((string) $getConfig('logo.width', '48px'));
$navItems = [];
if ($page && $getConfig('navigation.use_subpages', 'no') === 'yes') {
    $pages = method_exists($page, 'getHeaderNavigationPages') ? $page->getHeaderNavigationPages(12) : $page->getNavigationPages([], 12);
    foreach ($pages as $navPage) {
        $title = trim((string) ($navPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }
        $navItems[] = ['text' => $title, 'href' => (string) ($navPage['url'] ?? '#')];
    }
}
if (empty($navItems)) {
    $navItems = $parseNavItems($getConfig('navigation.items', "Home=>/\nTables=>#tables\nReviews=>#reviews\nFAQ=>#faq"));
}
if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'Tables', 'href' => '#tables'],
        ['text' => 'Reviews', 'href' => '#reviews'],
        ['text' => 'FAQ', 'href' => '#faq'],
    ];
}
$buttonText = trim((string) $getConfig('button.text', 'Spin Now'));
$buttonUrl = trim((string) $getConfig('button.url', '#download')) ?: '#download';
$buttonHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $buttonUrl);
$buttonRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($buttonHref, 'url');
$bgColor = (string) $getConfig('style.background', $colors['nav_bg'] ?? '#11131c');
$navColor = (string) $getConfig('style.nav_color', $colors['nav_text'] ?? '#f7f1e8');
$accentColor = (string) $getConfig('style.accent_color', $colors['accent_primary'] ?? '#ff5b45');
$height = trim((string) $getConfig('style.height', '76px'));
?>
<header id="<?= $componentId ?>" class="rsn-header-dark" aria-label="Dark header">
    <div class="dark-shell">
        <?php if ($logoDisplay): ?>
            <a class="dark-brand" href="/" aria-label="<?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?> home">
                <img src="<?= htmlspecialchars($logoUrl, ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?>" loading="lazy" decoding="async">
                <span><?= htmlspecialchars($logoText, ENT_QUOTES, 'UTF-8') ?></span>
            </a>
        <?php endif; ?>
        <?php if ($navDisplay && !empty($navItems)): ?>
            <nav class="dark-nav" aria-label="Secondary navigation">
                <?php foreach ($navItems as $item): ?>
                    <a href="<?= htmlspecialchars($item['href'], ENT_QUOTES, 'UTF-8') ?>"><?= htmlspecialchars($item['text'], ENT_QUOTES, 'UTF-8') ?></a>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>
        <?php if ($buttonDisplay && $buttonText !== ''): ?>
            <a class="dark-cta" href="<?= htmlspecialchars($buttonRef, ENT_QUOTES, 'UTF-8') ?>">
                <span><?= htmlspecialchars($buttonText, ENT_QUOTES, 'UTF-8') ?></span>
            </a>
        <?php endif; ?>
    </div>
</header>
<style>
#<?= $componentId ?> {
    width: 100%;
    min-height: <?= htmlspecialchars($height, ENT_QUOTES, 'UTF-8') ?>;
    background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0) 100%), <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 14px 36px rgba(0,0,0,0.2);
}
#<?= $componentId ?>,
#<?= $componentId ?> * {
    box-sizing: border-box;
}
#<?= $componentId ?> .dark-shell {
    width: min(1280px, calc(100% - 1.2rem));
    min-height: <?= htmlspecialchars($height, ENT_QUOTES, 'UTF-8') ?>;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    flex-wrap: wrap;
}
#<?= $componentId ?> .dark-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    color: <?= htmlspecialchars($navColor, ENT_QUOTES, 'UTF-8') ?>;
    text-decoration: none;
    font-family: 'Syne', 'Manrope', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
#<?= $componentId ?> .dark-brand img {
    width: <?= htmlspecialchars($logoWidth, ENT_QUOTES, 'UTF-8') ?>;
    height: auto;
}
#<?= $componentId ?> .dark-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.55rem;
    flex-wrap: wrap;
    flex: 1 1 380px;
}
#<?= $componentId ?> .dark-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0.45rem 0.82rem;
    border-radius: 999px;
    color: <?= htmlspecialchars($navColor, ENT_QUOTES, 'UTF-8') ?>;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
}
#<?= $componentId ?> .dark-nav a:hover,
#<?= $componentId ?> .dark-nav a:focus-visible {
    color: #ffffff;
    border-color: rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.07);
}
#<?= $componentId ?> .dark-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, <?= htmlspecialchars($accentColor, ENT_QUOTES, 'UTF-8') ?> 0%, #ffbf47 100%);
    color: #120d08;
    text-decoration: none;
    font-weight: 800;
    box-shadow: 0 12px 26px rgba(0,0,0,0.2);
}
@media (max-width: 767px) {
    #<?= $componentId ?> .dark-shell {
        width: calc(100% - 1rem);
        justify-content: center;
        text-align: center;
    }
    #<?= $componentId ?> .dark-nav {
        flex-basis: 100%;
        order: 3;
    }
}
</style>
