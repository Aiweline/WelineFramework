{
    "$schema": "2.1.0",
    "template": "roulette-supernova",
    "name": "Roulette Supernova",
    "description": "High-contrast roulette landing theme with bold dark surfaces, responsive page sections, and policy-safe inner pages.",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部区域，包含导航、Logo等",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "advantages", "games-showcase", "testimonials", "faq"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部区域，包含版权、链接等",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "星焰导航",
            "name_en": "Supernova Navigation",
            "description": "Dark responsive navigation with a layered mobile drawer and bold CTA support.",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "download_button"],
            "file": "header/nav.phtml"
        },
        "header-simple": {
            "name": "简洁头部",
            "name_en": "Simple Header",
            "description": "Minimal roulette header with editable logo art and brand text.",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "style"],
            "file": "header/simple.phtml"
        },
        "header-dark": {
            "name": "深色头部",
            "name_en": "Dark Header",
            "description": "Alternative dark roulette header with logo, links, and CTA support.",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 3,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "button", "style"],
            "file": "header/dark.phtml"
        },
        "hero-slider": {
            "name": "Hero首屏",
            "name_en": "Hero Section",
            "description": "Roulette-first hero layout with motion cues, floating wheel visuals, and responsive CTA flow.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner", "hero", "download_btn", "layout"],
            "file": "content/hero-slider.phtml"
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages",
            "description": "Contrast-heavy benefit grid for roulette trust cues, speed, and table clarity.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts"],
            "file": "content/advantages.phtml"
        },
        "games-showcase": {
            "name": "游戏展示",
            "name_en": "Games Showcase",
            "description": "Roulette table selector with a custom visual deck while keeping original data reading rules intact.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts", "game_1", "game_2", "game_3", "game_4", "game_5", "game_6"],
            "file": "content/games.phtml"
        },
        "slider": {
            "name": "轮播横幅",
            "name_en": "Slider",
            "description": "Compatibility slider for original banner assets and download-button data.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 35,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["slider"],
            "file": "content/slider.phtml"
        },
        "banner": {
            "name": "静态横幅",
            "name_en": "Banner",
            "description": "Compatibility banner for original responsive images and download-button data.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 36,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["banner"],
            "file": "content/banner.phtml"
        },
        "testimonials": {
            "name": "玩家评价",
            "name_en": "Testimonials",
            "description": "Review rail with score summary, swipe support, and roulette-focused default fallback text.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts", "avatars"],
            "file": "content/testimonials.phtml"
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ",
            "description": "Interactive roulette FAQ with compact cards, inline expansion, and mobile-safe spacing.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts"],
            "file": "content/faq.phtml"
        },
        "about-content": {
            "name": "关于页内容",
            "name_en": "About Content",
            "description": "About-page layout for roulette brand story, values, and operational structure.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 60,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "hero", "stats", "story", "values", "team", "cta"],
            "file": "content/about-content.phtml"
        },
        "contact-content": {
            "name": "联系页内容",
            "name_en": "Contact Content",
            "description": "Support-focused contact page with route cards, form panel, and optional map embed.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 61,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "hero", "contact_info", "social", "form", "map"],
            "file": "content/contact-content.phtml"
        },
        "legal-content": {
            "name": "法律页内容",
            "name_en": "Legal Content",
            "description": "Dark legal page with auto-generated section navigation and safe policy rendering.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 62,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/legal-content.phtml"
        },
        "blog-list": {
            "name": "博客列表",
            "name_en": "Blog List",
            "description": "Roulette journal list page with lead story framing and responsive archive cards.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 63,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-list.phtml"
        },
        "blog-category": {
            "name": "博客分类",
            "name_en": "Blog Category",
            "description": "Category archive page with spotlight article, staggered card flow, and side navigation.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 64,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-category.phtml"
        },
        "blog-detail": {
            "name": "博客详情",
            "name_en": "Blog Detail",
            "description": "Article detail page with split hero, share tools, and related roulette reading.",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 65,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/blog-detail.phtml"
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer Links",
            "description": "Compact supernova footer with roulette crest seam and compliant navigation links.",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "config_groups": ["display", "style", "layout", "footer", "content", "typography"],
            "file": "footer/links.phtml"
        },
        "footer-simple": {
            "name": "简洁底部",
            "name_en": "Simple Footer",
            "description": "Minimal footer bar with editable copyright text.",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "config_groups": ["content", "style"],
            "file": "footer/simple.phtml"
        }
    }
}
