    <div class="hero-noise" style="background-image: url('<?= htmlspecialchars($bgImage) ?>');" aria-hidden="true"></div>
    <div class="hero-shell">
        <div class="hero-stage" aria-hidden="true">
            <span class="hero-spotlight spotlight-left"></span>
            <span class="hero-spotlight spotlight-right"></span>

            <div class="hero-drift drift-a" data-rsn-parallax="22">
                <span class="hero-halo hero-halo-a"></span>
            </div>
            <div class="hero-drift drift-b" data-rsn-parallax="-18">
                <span class="hero-halo hero-halo-b"></span>
            </div>
            <div class="hero-drift drift-c" data-rsn-parallax="14">
                <span class="hero-halo hero-halo-c"></span>
            </div>

            <article class="signal-card signal-card-a">
                <span><?= htmlspecialchars($heroSignals[0]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[0]['value']) ?></strong>
            </article>

            <article class="signal-card signal-card-b">
                <span><?= htmlspecialchars($heroSignals[1]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[1]['value']) ?></strong>
            </article>

            <div class="hero-core">
                <div class="core-ring core-ring-outer"></div>
                <div class="core-ring core-ring-inner"></div>
                <div class="core-wave"></div>
                <div class="core-grid"></div>

                <?php foreach ($wheelNumbers as $index => $number): ?>
                    <span class="wheel-number wheel-number-<?= (int) ($index + 1) ?>"><?= htmlspecialchars($number) ?></span>
                <?php endforeach; ?>

                <?php foreach ($heroTokens as $token): ?>
                    <span class="hero-token <?= htmlspecialchars($token['class']) ?>"><?= htmlspecialchars($token['label']) ?></span>
                <?php endforeach; ?>

                <span class="hero-ball"></span>
                <div class="hero-wheel-card">
                    <div class="wheel-glow"></div>
                    <div class="wheel-frame">
                        <img src="<?= htmlspecialchars($heroImage) ?>" alt="<?= htmlspecialchars($title) ?>">
                    </div>
                    <span class="wheel-overlay wheel-overlay-a" aria-hidden="true"></span>
                    <span class="wheel-overlay wheel-overlay-b" aria-hidden="true"></span>
                    <span class="wheel-overlay wheel-overlay-c" aria-hidden="true"></span>
                </div>
            </div>

            <article class="signal-card signal-card-c">
                <span><?= htmlspecialchars($heroSignals[2]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[2]['value']) ?></strong>
            </article>
        </div>

        <header class="hero-head">
            <span class="hero-kicker"><?= htmlspecialchars($brandName) ?></span>
            <div class="hero-pill-row" aria-label="Hero highlights">
                <?php foreach ($heroPills as $pill): ?>
                    <span><?= htmlspecialchars($pill) ?></span>
                <?php endforeach; ?>
            </div>
            <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h1>
            <?php if ($subtitle !== ''): ?>
                <p class="hero-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <div class="hero-actions">
                <?php if ($showPrimaryCta && $ctaText !== ''): ?>
                    <a class="hero-primary" href="<?= htmlspecialchars($ctaRef) ?>">
                        <span class="btn-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 4V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                <path d="M8 10L12 14L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M5 18H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </span>
                        <span><?= htmlspecialchars($ctaText) ?></span>
                    </a>
                <?php endif; ?>

                <?php if ($ctaSecondaryText !== ''): ?>
                    <a class="hero-secondary" href="<?= htmlspecialchars($ctaSecondaryUrl) ?>">
                        <span><?= htmlspecialchars($ctaSecondaryText) ?></span>
                    </a>
                <?php endif; ?>
            </div>
        </header>

        <div class="hero-signals-mobile" aria-label="Hero signals">
            <article class="signal-card signal-card-mobile">
                <span><?= htmlspecialchars($heroSignals[0]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[0]['value']) ?></strong>
            </article>
            <article class="signal-card signal-card-mobile">
                <span><?= htmlspecialchars($heroSignals[1]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[1]['value']) ?></strong>
            </article>
            <article class="signal-card signal-card-mobile">
                <span><?= htmlspecialchars($heroSignals[2]['label']) ?></span>
                <strong><?= htmlspecialchars($heroSignals[2]['value']) ?></strong>
            </article>
        </div>
    </div>
</section>

