<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        return;
    }

    var layers = root.querySelectorAll('[data-rsn-parallax]');
    if (!layers.length) {
        return;
    }

    var ticking = false;

    function update() {
        ticking = false;
        if (window.innerWidth <= 860) {
            layers.forEach(function (layer) {
                layer.style.setProperty('--rsn-parallax-shift', '0px');
            });
            return;
        }
        var rect = root.getBoundingClientRect();
        var progress = ((window.innerHeight * 0.55) - rect.top) / (window.innerHeight + rect.height);
        layers.forEach(function (layer) {
            var depth = parseFloat(layer.getAttribute('data-rsn-parallax')) || 0;
            layer.style.setProperty('--rsn-parallax-shift', (progress * depth).toFixed(2) + 'px');
        });
    }

    function requestTick() {
        if (!ticking) {
            ticking = true;
            window.requestAnimationFrame(update);
        }
    }

    window.addEventListener('scroll', requestTick, { passive: true });
    window.addEventListener('resize', requestTick);
    update();
})();
</script>
