 * Roulette Supernova - Hero Slider Component
 *
 * @component_start
 * code: hero-slider
 * name: Hero首屏
 * name_en: Hero Slider
 * description: Roulette-first hero with a centered stage, replaceable wheel art, and lightweight decorative parallax.
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:banner => Banner兼容字段
 * banner.display => 显示Banner区域:select:yes|yes,no
 * banner.image_mobile => 移动端Banner图片:textarea:|留空使用默认图
 * banner.image_desktop => PC端Banner图片:textarea:|留空使用默认图
 * banner.alt => Banner图片描述:text:Roulette Supernova hero
 * banner.bg_color => Banner背景颜色:color:#05060d
 * banner.download_btn_alt => Banner下载按钮描述:text:Download
 *
 * group:hero => Hero设置
 * hero.display => 显示Hero:select:yes|yes,no
 * hero.title => 主标题:text:Own the Wheel at Roulette Supernova
 * hero.subtitle => 副标题:textarea:A bold roulette landing system built for quick table scans, stronger contrast, and faster mobile entry.
 * hero.signal_card_a_value => 信号卡片A主值:text:Own the Wheel at Roulette Supernova
 * hero.signal_card_b_value => 信号卡片B主值:textarea:A bold roulette landing system built for quick table scans, stronger contrast, and faster mobile entry.
 * hero.cta_text => CTA按钮文字:text:Download Now
 * hero.cta_url => CTA按钮链接:text:#download
 * hero.secondary_cta_text => 次按钮文字:text:Browse Tables
 * hero.secondary_cta_url => 次按钮链接:text:#tables
 * hero.image => 左侧图片:textarea:|留空使用默认图
 * hero.bg_image => 背景图片:textarea:|留空使用默认图
 * hero.bg_color => Hero背景颜色:color:#05060d
 *
 * group:download_btn => 下载按钮兼容字段
 * download_btn.display => 显示下载按钮:select:yes|yes,no
 * download_btn.alt => 下载按钮描述:text:Download
 * download_btn.url => 下载链接:text:#download
 *
 * group:layout => 布局兼容字段
 * layout.slider_classes => 区域附加类名:textarea:rsn-hero-stage
 *
 * @fields_end
 */

$componentId = 'rsn-hero-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$colors = isset($colors) && is_array($colors) ? $colors : [];

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$sanitizeTitle = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^样式模板预览\s*[-–—]*\s*/u', '', $value);
    $value = str_replace('样式模板预览', '', $value);
    return trim($value);
};

$shorten = static function ($value, $limit = 90) {
    $value = trim((string) $value);
    if ($value === '') {
        return '';
    }
    if (function_exists('mb_strimwidth')) {
        return mb_strimwidth($value, 0, $limit, '...');
    }
    return strlen($value) > $limit ? substr($value, 0, $limit - 3) . '...' : $value;
};

$appendUnique = static function (array &$items, $value, $limit = 3) {
    $value = trim((string) $value);
    if ($value === '' || in_array($value, $items, true)) {
        return;
    }
    if (count($items) >= $limit) {
        return;
    }
    $items[] = $value;
};

$heroDisplay = $normalizeToggle($getConfig('hero.display', $getConfig('banner.display', 'yes')));
if ($heroDisplay !== 'yes') {
    return;
}

$brandName = $sanitizeTitle($getConfigAny(['app_info.app_name', 'logo.text', 'header.logo.text'], ''));
if ($brandName === '' && $page) {
    $brandName = $sanitizeTitle((string) ($page->getData('title') ?: ''));
}
if ($brandName === '') {
    $brandName = 'Roulette Supernova';
}

$pageTitle = $page ? $sanitizeTitle((string) ($page->getData('meta_title') ?: $page->getData('title') ?: '')) : '';
$title = $sanitizeTitle((string) $getConfig('hero.title', ''));
if ($title === '') {
    $title = $pageTitle !== '' ? $pageTitle : $brandName;
}

$subtitle = trim((string) $getConfig('hero.subtitle', ''));
if ($subtitle === '' && $page) {
    $subtitle = trim((string) ($page->getData('meta_description') ?: ''));
}
if ($subtitle === '') {
    $subtitle = 'A bold roulette landing system built for quick table scans, stronger contrast, and faster mobile entry.';
}

$ctaText = trim((string) $getConfig('hero.cta_text', $getConfigAny(['download_btn.alt', 'banner.download_btn_alt'], 'Download')));
if ($ctaText === '') {
    $ctaText = 'Download';
}
$showPrimaryCta = $normalizeToggle($getConfig('download_btn.display', 'yes')) === 'yes';
$ctaUrl = trim((string) $getConfig('hero.cta_url', $getConfigAny(['download_btn.url'], '#download'))) ?: '#download';
$ctaHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $ctaUrl);
$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaHref, 'url');
$ctaSecondaryText = trim((string) $getConfig('hero.secondary_cta_text', 'Browse Tables'));
$ctaSecondaryUrl = trim((string) $getConfig('hero.secondary_cta_url', '#tables')) ?: '#tables';
$heroImage = trim((string) $getConfigAny(['hero.image', 'hero.image_desktop', 'banner.image_desktop', 'slider.banner_image_desktop'], ''));
$heroImage = $heroImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/roulette-supernova/asset/img/roulette-hero-wheel.svg');
$bgImage = trim((string) $getConfigAny(['hero.bg_image', 'banner.image_mobile', 'slider.banner_image_mobile'], ''));
$bgImage = $bgImage ?: $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/roulette-supernova/asset/img/poker-header-bg.svg');
$heroBg = (string) $getConfigAny(['hero.bg_color', 'banner.bg_color', 'slider.bg_color'], $colors['hero_bg'] ?? '#05060d');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', $colors['hero_bg_gradient_end'] ?? '#14070f');

$heroPills = [];
$appendUnique($heroPills, $ctaText);
$appendUnique($heroPills, $ctaSecondaryText);
$navSeedConfig = (string) $getConfigAny(['header.navigation.items', 'navigation.items'], '');
if ($navSeedConfig !== '') {
    if (strpos($navSeedConfig, '\n') !== false && strpos($navSeedConfig, "\n") === false) {
        $navSeedConfig = str_replace('\n', "\n", $navSeedConfig);
    }
    foreach (preg_split('/\r?\n/', $navSeedConfig) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }
        $parts = explode('=>', $line, 2);
        $navText = trim((string) ($parts[0] ?? ''));
        if ($navText !== '') {
            $appendUnique($heroPills, $navText);
        }
    }
}
if (count($heroPills) < 3) {
    foreach (preg_split('/\s+/', $brandName) ?: [] as $word) {
        $appendUnique($heroPills, $word);
    }
}
if (empty($heroPills)) {
    $heroPills = [$brandName];
}
$heroPills = array_slice($heroPills, 0, 3);
$signalCardAValue = trim((string) $getConfig('hero.signal_card_a_value', ''));
if ($signalCardAValue === '') {
    $signalCardAValue = $shorten($title, 72);
}
$signalCardBValue = trim((string) $getConfig('hero.signal_card_b_value', ''));
if ($signalCardBValue === '') {
    $signalCardBValue = $shorten($subtitle, 92);
}

$heroSignals = [
    ['label' => $heroPills[0] ?? $brandName, 'value' => $signalCardAValue],
    ['label' => $heroPills[1] ?? $brandName, 'value' => $signalCardBValue],
    ['label' => $heroPills[2] ?? $brandName, 'value' => $shorten($ctaSecondaryText !== '' ? $ctaSecondaryText : $ctaText, 72)],
];
$wheelNumbers = ['0', '12', '26', '32', '17'];
$tokenLabels = [];
foreach ($heroPills as $pill) {
    $token = strtoupper(preg_replace('/[^A-Za-z0-9]+/', ' ', (string) $pill));
    $token = trim($token);
    if ($token === '') {
        continue;
    }
    if (function_exists('mb_substr')) {
        $token = mb_substr($token, 0, 8);
    } else {
        $token = substr($token, 0, 8);
    }
    $appendUnique($tokenLabels, $token);
}
while (count($tokenLabels) < 3) {
    $appendUnique($tokenLabels, 'ROULETTE');
    $appendUnique($tokenLabels, 'TABLE');
    $appendUnique($tokenLabels, 'LIVE');
}
$heroTokens = [
    ['label' => $tokenLabels[0] ?? 'ROULETTE', 'class' => 'token-a'],
    ['label' => $tokenLabels[1] ?? 'TABLE', 'class' => 'token-b'],
    ['label' => $tokenLabels[2] ?? 'LIVE', 'class' => 'token-c'],
];
?>
