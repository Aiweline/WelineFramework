 * team.title => 团队标题:text:Behind The Tables
 * team.subtitle => 团队副标题:text:
 * team.member_1_icon => 成员1图标:text:G1
 * team.member_1_name => 成员1姓名:text:Room Analyst
 * team.member_1_role => 成员1职位:text:Table flow and lobby readability
 * team.member_2_icon => 成员2图标:text:G2
 * team.member_2_name => 成员2姓名:text:Support Lead
 * team.member_2_role => 成员2职位:text:Player routing and response systems
 * team.member_3_icon => 成员3图标:text:G3
 * team.member_3_name => 成员3姓名:text:Mobile Designer
 * team.member_3_role => 成员3职位:text:Responsive journeys for quick visits
 * team.member_4_icon => 成员4图标:text:G4
 * team.member_4_name => 成员4姓名:text:Trust Editor
 * team.member_4_role => 成员4职位:text:Clear policy and table communication
 *
 * group:cta => CTA模块
 * cta.kicker => CTA提示语:text:Support Route
 * cta.title => CTA标题:text:Need a direct route?
 * cta.description => CTA描述:textarea:Use the contact page to reach the right desk for account, gameplay, or support questions.
 * cta.button_text => CTA按钮文本:text:Contact Us
 * cta.button_url => CTA按钮链接:text:/contact
 * cta.button_bg => CTA按钮背景:color:#1eb980
 * cta.button_text_color => CTA按钮文字颜色:color:#0b1525
 *
 * @fields_end
 */

$page = $this->getData('page');
$componentId = 'grc-about-' . uniqid();

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

if ($getConfig('display.show_section', $getConfig('about.display', 'yes')) === 'no') {
    return;
}

$showStats = $getConfig('display.show_stats', 'yes') !== 'no';
$showValues = $getConfig('display.show_values', 'yes') !== 'no';
$showTeam = $getConfig('display.show_team', 'no') !== 'no';
$showCta = $getConfig('display.show_cta', 'no') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$heroKicker = trim((string) $getConfig('hero.kicker', 'Brand Dossier'));
$title = trim((string) $getConfig('hero.title', $pageTitle));
if ($title === '') {
    $title = 'About Gin Rummy Carnival';
}
$subtitle = trim((string) $getConfig('hero.subtitle', 'Gin Rummy Carnival refines the classic trick-taking experience with clearer room reading, faster support access, and dependable mobile play.'));
$heroBg = (string) $getConfig('hero.bg_color', '#0b1525');
$heroBgEnd = (string) $getConfig('hero.bg_gradient_end', '#0f2538');
$heroTitleColor = (string) $getConfig('hero.title_color', '#f8fafc');
$heroTextColor = (string) $getConfig('hero.text_color', '#cbd5e1');
$heroPadding = max(40, (int) $getConfig('hero.padding', 72));
$statsLeadLabel = trim((string) $getConfig('stats.lead_label', 'Signature Signal'));
$statsNumberColor = (string) $getConfig('stats.number_color', '#f2a93b');
$statsLabelColor = (string) $getConfig('stats.label_color', '#cbd5e1');
$statsCardBg = (string) $getConfig('stats.card_bg', '#102b3d');

$stats = [];
$defaultNumbers = ['5+', '1M+', '24/7', '20+'];
$defaultLabels = [
    'Years refining table flow',
    'Gin Rummy sessions served',
    'Support desk coverage',
    'Regions reached',
];
for ($i = 1; $i <= 4; $i++) {
    $number = trim((string) $getConfig("stats.stat_{$i}_number", $defaultNumbers[$i - 1]));
    $label = trim((string) $getConfig("stats.stat_{$i}_label", $defaultLabels[$i - 1]));
    if ($number === '' && $label === '') {
        continue;
    }
    $stats[] = [
        'value' => $number,
        'label' => $label,
    ];
}

if (empty($stats)) {
    $statsRaw = (string) $getConfig('stats.items', "5+|Years refining table flow\n1M+|Gin Rummy sessions served\n24/7|Support desk coverage\n20+|Regions reached");
    if (strpos($statsRaw, '\\n') !== false && strpos($statsRaw, "\n") === false) {
        $statsRaw = str_replace('\\n', "\n", $statsRaw);
    }
    foreach (preg_split('/[\r\n]+/', $statsRaw) ?: [] as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim((string) ($parts[0] ?? '')) === '') {
            continue;
        }
        $stats[] = [
            'value' => trim((string) ($parts[0] ?? '')),
            'label' => trim((string) ($parts[1] ?? '')),
        ];
    }
}

$storyKicker = trim((string) $getConfig('story.kicker', 'House Note'));
$storyTitle = trim((string) $getConfig('story.title', 'Our Story'));
$storySubtitle = trim((string) $getConfig('story.subtitle', ''));
$storyContent = trim((string) $getConfig('story.content', $pageContent));
if ($storyContent === '') {
    $storyContent = 'Gin Rummy Carnival keeps the familiar card rhythm of Gin Rummy while improving how players discover tables, read feature cues, and reach support across desktop and mobile.';
}
$storyBg = (string) $getConfig('story.bg_color', '#0f2538');
$storyTitleColor = (string) $getConfig('story.title_color', '#f2a93b');
$storyParagraphs = preg_split('/[\r\n]+/', $storyContent) ?: [];
$storyParagraphs = array_values(array_filter(array_map('trim', $storyParagraphs), static function ($item) {
    return $item !== '';
}));
if (empty($storyParagraphs)) {
    $storyParagraphs = [$storyContent];
}

$storyBlocks = $storyParagraphs;
$storyLead = $storyBlocks[0] ?? '';
$storyTrail = array_slice($storyBlocks, 1);

$valuesKicker = trim((string) $getConfig('values.kicker', 'Playbook'));
$valuesTitle = trim((string) $getConfig('values.title', 'Our Core Values'));
$valuesSubtitle = trim((string) $getConfig('values.subtitle', 'Three editable pillars keep the page useful when creating new Gin Rummy sites.'));
$valuesBg = (string) $getConfig('values.bg_color', '#0b1525');
$defaultValues = [
    ['⚖️', 'Fair Play', 'Table signals, rule expectations, and outcome cues should stay transparent from the first tap.'],
    ['📱', 'Mobile Clarity', 'Layouts, routes, and controls should remain readable during quick Gin Rummy browsing on smaller screens.'],
    ['💬', 'Fast Support', 'Account, payout, and gameplay questions should reach the right desk without extra friction.'],
];
$values = [];
for ($i = 1; $i <= 3; $i++) {
    $itemTitle = trim((string) $getConfig("values.value_{$i}_title", $defaultValues[$i - 1][1]));
    $itemDesc = trim((string) $getConfig("values.value_{$i}_desc", $defaultValues[$i - 1][2]));
    if ($itemTitle === '' && $itemDesc === '') {
        continue;
    }
    $values[] = [
        'icon' => trim((string) $getConfig("values.value_{$i}_icon", $defaultValues[$i - 1][0])),
        'title' => $itemTitle,
        'description' => $itemDesc,
    ];
}

if (empty($values)) {
    $valuesRaw = (string) $getConfig('values.items', "Fair Play|Table signals, rule expectations, and outcome cues should stay transparent from the first tap.|⚖️\nMobile Clarity|Layouts, routes, and controls should remain readable during quick Gin Rummy browsing on smaller screens.|📱\nFast Support|Account, payout, and gameplay questions should reach the right desk without extra friction.|💬");
    if (strpos($valuesRaw, '\\n') !== false && strpos($valuesRaw, "\n") === false) {
        $valuesRaw = str_replace('\\n', "\n", $valuesRaw);
    }
    foreach (preg_split('/[\r\n]+/', $valuesRaw) ?: [] as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line);
        if (trim((string) ($parts[0] ?? '')) === '') {
            continue;
        }
        $values[] = [
            'title' => trim((string) ($parts[0] ?? '')),
            'description' => trim((string) ($parts[1] ?? '')),
            'icon' => trim((string) ($parts[2] ?? '⭐')),
        ];
    }
}

$leadStat = $stats[0] ?? null;
$trailStats = array_slice($stats, 1);
$teamKicker = trim((string) $getConfig('team.kicker', 'Table Crew'));
$teamTitle = trim((string) $getConfig('team.title', 'Behind The Tables'));
$teamSubtitle = trim((string) $getConfig('team.subtitle', ''));
$teamMembers = [];
for ($i = 1; $i <= 4; $i++) {
    $memberName = trim((string) $getConfig("team.member_{$i}_name", ''));
    $memberRole = trim((string) $getConfig("team.member_{$i}_role", ''));
    $memberIcon = trim((string) $getConfig("team.member_{$i}_icon", ''));
    if ($memberName === '' && $memberRole === '' && $memberIcon === '') {
        continue;
    }
    $teamMembers[] = [
        'icon' => $memberIcon !== '' ? $memberIcon : 'G' . $i,
        'name' => $memberName,
        'role' => $memberRole,
    ];
}

$ctaKicker = trim((string) $getConfig('cta.kicker', 'Support Route'));
$ctaTitle = trim((string) $getConfig('cta.title', 'Need a direct route?'));
$ctaDescription = trim((string) $getConfig('cta.description', 'Use the contact page to reach the right desk for account, gameplay, or support questions.'));
$ctaButtonText = trim((string) $getConfig('cta.button_text', 'Contact Us'));
$ctaButtonUrl = trim((string) $getConfig('cta.button_url', '/contact'));
$ctaButtonBg = (string) $getConfig('cta.button_bg', '#1eb980');
$ctaButtonTextColor = (string) $getConfig('cta.button_text_color', '#0b1525');
?>

<section id="<?= $componentId ?>" class="grc-about-page" aria-labelledby="<?= $componentId ?>-title" style="--grc-about-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --grc-about-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --grc-about-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --grc-about-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --grc-about-hero-padding: <?= (int) $heroPadding ?>px; --grc-about-stats-number: <?= htmlspecialchars($statsNumberColor, ENT_QUOTES, 'UTF-8') ?>; --grc-about-stats-label: <?= htmlspecialchars($statsLabelColor, ENT_QUOTES, 'UTF-8') ?>; --grc-about-stats-card-bg: <?= htmlspecialchars($statsCardBg, ENT_QUOTES, 'UTF-8') ?>; --grc-about-story-bg: <?= htmlspecialchars($storyBg, ENT_QUOTES, 'UTF-8') ?>; --grc-about-story-title: <?= htmlspecialchars($storyTitleColor, ENT_QUOTES, 'UTF-8') ?>; --grc-about-values-bg: <?= htmlspecialchars($valuesBg, ENT_QUOTES, 'UTF-8') ?>; --grc-about-cta-bg: <?= htmlspecialchars($ctaButtonBg, ENT_QUOTES, 'UTF-8') ?>; --grc-about-cta-text: <?= htmlspecialchars($ctaButtonTextColor, ENT_QUOTES, 'UTF-8') ?>;">
    <div class="about-suits" aria-hidden="true">
        <span class="about-suit about-suit-spade">&spades;</span>
        <span class="about-suit about-suit-heart">&hearts;</span>
        <span class="about-suit about-suit-diamond">&diams;</span>
    </div>

    <div class="about-shell">
        <header class="about-banner wow animate__fadeInUp" data-wow-duration="0.82s">
            <div class="banner-copy">
                <?php if ($heroKicker !== ''): ?>
                    <span class="banner-kicker"><?= htmlspecialchars($heroKicker) ?></span>
                <?php endif; ?>
                <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h1>
                <?php if ($subtitle !== ''): ?>
                    <p class="banner-subtitle"><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
            </div>

            <?php if ($showStats && !empty($stats)): ?>
                <div class="banner-pulse" aria-label="About statistics">
                    <?php if ($leadStat): ?>
                        <article class="pulse-card pulse-card-lead">
                            <?php if ($statsLeadLabel !== ''): ?>
                                <span class="pulse-label"><?= htmlspecialchars($statsLeadLabel) ?></span>
                            <?php endif; ?>
                            <strong><?= htmlspecialchars($leadStat['value']) ?></strong>
                            <p><?= htmlspecialchars($leadStat['label']) ?></p>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($trailStats)): ?>
                        <div class="pulse-strip">
                            <?php foreach ($trailStats as $stat): ?>
                                <article class="pulse-card">
                                    <strong><?= htmlspecialchars($stat['value']) ?></strong>
                                    <p><?= htmlspecialchars($stat['label']) ?></p>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endif; ?>
        </header>

        <main class="about-route">
            <article class="story-stage wow animate__fadeInUp" data-wow-delay="0.08s" data-wow-duration="0.86s">
                <div class="story-head">
                    <?php if ($storyKicker !== ''): ?>
                        <span class="story-kicker"><?= htmlspecialchars($storyKicker) ?></span>
                    <?php endif; ?>
                    <h2><?= htmlspecialchars($storyTitle) ?></h2>
                    <?php if ($storySubtitle !== ''): ?>
                        <p class="story-subtitle"><?= htmlspecialchars($storySubtitle) ?></p>
                    <?php endif; ?>
                </div>

                <div class="story-sheet">
                    <?php if ($storyLead !== ''): ?>
                        <p class="story-lead"><?= nl2br(htmlspecialchars($storyLead)) ?></p>
                    <?php endif; ?>

                    <?php if (!empty($storyTrail)): ?>
                        <div class="story-flow<?= count($storyTrail) > 1 ? ' has-grid' : '' ?>">
                            <?php foreach ($storyTrail as $paragraph): ?>
                                <p class="story-paragraph"><?= nl2br(htmlspecialchars($paragraph)) ?></p>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </div>
            </article>

            <?php if ($showValues && !empty($values)): ?>
                <section class="values-stage wow animate__fadeInUp" data-wow-delay="0.14s" data-wow-duration="0.9s" aria-labelledby="<?= $componentId ?>-values-title">
                    <header class="values-head">
                        <?php if ($valuesKicker !== ''): ?>
                            <span class="values-kicker"><?= htmlspecialchars($valuesKicker) ?></span>
                        <?php endif; ?>
                        <h2 id="<?= $componentId ?>-values-title"><?= htmlspecialchars($valuesTitle) ?></h2>
                        <?php if ($valuesSubtitle !== ''): ?>
                            <p><?= htmlspecialchars($valuesSubtitle) ?></p>
                        <?php endif; ?>
                    </header>

                    <div class="values-mosaic">
                        <?php foreach ($values as $index => $value): ?>
                            <article class="value-card value-card-<?= (int) ($index + 1) ?>">
                                <span class="value-stamp" aria-hidden="true"><?= htmlspecialchars($value['icon']) ?></span>
                                <div class="value-copy">
                                    <h3><?= htmlspecialchars($value['title']) ?></h3>
                                    <?php if ($value['description'] !== ''): ?>
                                        <p><?= htmlspecialchars($value['description']) ?></p>
                                    <?php endif; ?>
                                </div>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </section>
            <?php endif; ?>

            <?php if ($showTeam && !empty($teamMembers)): ?>
                <section class="team-stage wow animate__fadeInUp" data-wow-delay="0.18s" data-wow-duration="0.92s" aria-labelledby="<?= $componentId ?>-team-title">
                    <header class="team-head">
                        <?php if ($teamKicker !== ''): ?>
                            <span class="team-kicker"><?= htmlspecialchars($teamKicker) ?></span>
                        <?php endif; ?>
                        <h2 id="<?= $componentId ?>-team-title"><?= htmlspecialchars($teamTitle) ?></h2>
                        <?php if ($teamSubtitle !== ''): ?>
                            <p><?= htmlspecialchars($teamSubtitle) ?></p>
                        <?php endif; ?>
                    </header>

                    <div class="team-grid">
                        <?php foreach ($teamMembers as $index => $member): ?>
                            <article class="team-card team-card-<?= (int) ($index + 1) ?>">
                                <span class="team-mark" aria-hidden="true"><?= htmlspecialchars($member['icon']) ?></span>
                                <div class="team-copy">
                                    <?php if ($member['name'] !== ''): ?>
                                        <h3><?= htmlspecialchars($member['name']) ?></h3>
                                    <?php endif; ?>
                                    <?php if ($member['role'] !== ''): ?>
                                        <p><?= htmlspecialchars($member['role']) ?></p>
                                    <?php endif; ?>
                                </div>
                            </article>
                        <?php endforeach; ?>
                    </div>
                </section>
            <?php endif; ?>

            <?php if ($showCta && ($ctaTitle !== '' || $ctaDescription !== '' || $ctaButtonText !== '')): ?>
                <section class="cta-stage wow animate__fadeInUp" data-wow-delay="0.22s" data-wow-duration="0.94s" aria-labelledby="<?= $componentId ?>-cta-title">
                    <div class="cta-copy">
                        <?php if ($ctaKicker !== ''): ?>
                            <span class="cta-kicker"><?= htmlspecialchars($ctaKicker) ?></span>
                        <?php endif; ?>
                        <?php if ($ctaTitle !== ''): ?>
                            <h2 id="<?= $componentId ?>-cta-title"><?= htmlspecialchars($ctaTitle) ?></h2>
                        <?php endif; ?>
                        <?php if ($ctaDescription !== ''): ?>
                            <p><?= htmlspecialchars($ctaDescription) ?></p>
                        <?php endif; ?>
                    </div>

                    <?php if ($ctaButtonText !== ''): ?>
                        <a class="cta-link" href="<?= htmlspecialchars($ctaButtonUrl !== '' ? $ctaButtonUrl : '/contact') ?>">
                            <span><?= htmlspecialchars($ctaButtonText) ?></span>
                        </a>
                    <?php endif; ?>
                </section>
            <?php endif; ?>
        </main>
    </div>
</section>

<style>
