        scroll-snap-align: start;
        transform: none;
        border-radius: 24px;
    }

    #<?= $componentId ?> .voices-head h2 span {
        font-size: clamp(1.8rem, 9vw, 2.8rem);
    }
}
</style>

<script>
(function () {
    var root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    var tiles = root.querySelectorAll('[data-review-index]');
    var payload = <?= json_encode($jsPayload, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    var nameEl = root.querySelector('[data-console-name]');
    var tagEl = root.querySelector('[data-console-tag]');
    var ratingEl = root.querySelector('[data-console-rating]');
    var textEl = root.querySelector('[data-console-text]');
    var avatarEl = root.querySelector('[data-console-avatar]');
    var showAvatar = <?= $showAvatar ? 'true' : 'false' ?>;
    var showRating = <?= $showRating ? 'true' : 'false' ?>;

    var renderAvatar = function (item) {
        if (!showAvatar || !avatarEl) {
            return;
        }

        if (item.avatar) {
            avatarEl.innerHTML = '<img src="' + item.avatar.replace(/"/g, '&quot;') + '" alt="' + item.name.replace(/"/g, '&quot;') + '">';
        } else {
            avatarEl.textContent = item.initials || '';
        }
    };

    var setActive = function (index) {
        var item = payload[index];
        if (!item) {
            return;
        }

        tiles.forEach(function (tile) {
            tile.classList.toggle('is-active', tile.getAttribute('data-review-index') === String(index));
        });

        if (nameEl) {
            nameEl.textContent = item.name || '';
        }
        if (tagEl) {
            tagEl.textContent = item.tag || '';
            tagEl.hidden = !item.tag;
        }
        if (ratingEl) {
            ratingEl.textContent = item.rating_text || '';
            ratingEl.hidden = !showRating || !item.rating_text;
        }
        if (textEl) {
            textEl.textContent = item.text || '';
        }

        renderAvatar(item);
    };

    tiles.forEach(function (tile) {
        var index = parseInt(tile.getAttribute('data-review-index') || '0', 10);
        ['mouseenter', 'focus', 'click'].forEach(function (eventName) {
            tile.addEventListener(eventName, function () {
                setActive(index);
            });
        });
    });
})();
</script>
