$componentId = 'grc-footer-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string) $value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string) ($parts[0] ?? '')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function ($parsed) {
    $mobile = (float) $parsed['mobile'];
    $desktop = (float) $parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$showLinks = $normalizeToggle($getConfig('display.show_links', 'yes')) !== 'no';
$showDisclaimer = $normalizeToggle($getConfig('display.show_disclaimer', 'yes')) !== 'no';
$showCopyright = $normalizeToggle($getConfig('display.show_copyright', 'yes')) !== 'no';

$bgColor = (string) $getConfig('style.background_color', '#0b1525');
$textColor = (string) $getConfig('style.text_color', '#94a3b8');
$linkColor = (string) $getConfig('style.link_color', '#cbd5e1');
$linkHoverColor = (string) $getConfig('style.link_hover_color', '#f2a93b');
$linkFontSize = (int) $getConfig('style.link_font_size', '15');
$linkFontWeight = (int) $getConfig('style.link_font_weight', '700');
$linkGap = (int) $getConfig('style.link_gap', '10');
$borderTop = $normalizeToggle($getConfig('style.border_top', 'no'), 'no') === 'yes';
$borderColor = (string) $getConfig('style.border_color', '#234055');
$borderWidth = (int) $getConfig('style.border_width', '1');
$sectionPadding = (int) $getConfig('style.section_padding', '48');
$sectionPaddingMobile = (int) $getConfig('style.section_padding_mobile', '35');
$separatorDisplay = $normalizeToggle($getConfig('style.separator_display', 'no'), 'no') === 'yes';
$separatorChar = trim((string) $getConfig('style.separator_char', '/'));
if ($separatorChar === '') {
    $separatorChar = '/';
}
$separatorColor = (string) $getConfig('style.separator_color', '#4a6478');
$maxWidth = (int) $getConfig('layout.max_width', '1240');
$paddingHorizontal = $genResponsiveCSS($parseResponsive($getConfig('layout.padding_horizontal', '16/16') . 'px'));
$paddingVerticalConfig = trim((string) $getConfig('layout.padding_vertical', ''));
$paddingVertical = $paddingVerticalConfig !== ''
    ? $genResponsiveCSS($parseResponsive($paddingVerticalConfig . 'px'))
    : $genResponsiveCSS($parseResponsive($sectionPaddingMobile . '/' . $sectionPadding . 'px'));
$fontSize = $genResponsiveCSS($parseResponsive($getConfig('typography.font_size', '12/14') . 'px'));
$lineHeight = (float) $getConfig('typography.line_height', '1.65');
$disclaimerBgColor = (string) $getConfig('disclaimer.bg_color', 'transparent');
$disclaimerBorderRadius = (int) $getConfig('disclaimer.border_radius', '0');
$disclaimerPadding = (int) $getConfig('disclaimer.padding', '0');
$disclaimerFontSize = (int) $getConfig('disclaimer.font_size', '14');
$disclaimerTextColor = (string) $getConfig('disclaimer.text_color', $textColor);
$copyrightFontSize = (int) $getConfig('copyright.font_size', '14');
$copyrightTextColor = (string) $getConfig('copyright.text_color', $textColor);
$copyrightMarginTop = (int) $getConfig('copyright.margin_top', '7');

$logoText = (string) $getConfigAny(['footer.logo_text', 'footer.logo.text', 'logo.text'], 'Gin Rummy Carnival');
$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/carnival-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['footer.logo_url', 'footer.logo.url', 'logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);
$copyright = (string) $getConfigAny(['content.copyright_text', 'footer.copyright'], '© 2026 Gin Rummy Carnival. All rights reserved.');
$disclaimerText = (string) $getConfigAny(['content.disclaimer_text', 'footer.disclaimer_text'], '18+ Only. Real-money gameplay involves risk. Please play responsibly and stay within your limits.');
$downloadText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Install App'));
$downloadUrl = trim((string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download'));
$downloadHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $downloadUrl);
$downloadRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($downloadHref, 'url');
$floatingDownloadIcon = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/floating-download-badge.svg');
$showFloatingDownload = $downloadText !== '' && $downloadUrl !== '';

$links = [];
$useCustomLinksRaw = (string) $getConfig('content.use_custom_links', '');
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
    : $normalizeToggle($getConfig('content.use_subpages', 'no'), 'no') !== 'yes';

if (!$useCustomLinks && $page) {
    $footerPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(30)
        : $page->getNavigationPages([], 30);
    foreach ($footerPages as $footerPage) {
        $text = trim((string) ($footerPage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $type = (string) ($footerPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny([
            'content_footer_labels.content.footer_label_' . $type,
            'content.footer_label_' . $type,
        ], ''));
        $links[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $text,
            'href' => (string) ($footerPage['url'] ?? '#'),
        ];
    }
}

if (empty($links)) {
    $linksConfig = (string) $getConfigAny(
        ['content.footer_links', 'footer.links'],
        "Home=>/\nAbout=>/about\nBlog=>/blog\nFAQs=>#faq"
    );

    if (strpos($linksConfig, '\\n') !== false && strpos($linksConfig, "\n") === false) {
        $linksConfig = str_replace('\\n', "\n", $linksConfig);
    }

    $items = preg_split('/\r?\n/', $linksConfig);
    if (!is_array($items) || count(array_filter(array_map('trim', $items))) === 0) {
        $items = explode(',', $linksConfig);
    }

    foreach ($items as $item) {
        $item = trim((string) $item);
        if ($item === '') {
            continue;
        }

        if (strpos($item, '|') !== false) {
            $parts = array_map('trim', explode('|', $item, 2));
        } elseif (strpos($item, '=>') !== false) {
            $parts = array_map('trim', explode('=>', $item, 2));
        } else {
            $parts = [$item, '#'];
        }

        if (count($parts) < 1 || $parts[0] === '') {
            continue;
        }

        $links[] = [
            'text' => $parts[0],
            'href' => $parts[1] !== '' ? $parts[1] : '#',
        ];
    }
}

if (empty($links)) {
    $links = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'Games', 'href' => '#games'],
        ['text' => 'FAQ', 'href' => '#faq'],
        ['text' => 'Support', 'href' => '/contact'],
    ];
}
