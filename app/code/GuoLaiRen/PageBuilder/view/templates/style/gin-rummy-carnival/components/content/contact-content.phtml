$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$componentId = 'grc-contact-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showMap = $getConfig('display.show_map', 'yes') !== 'no';
$showForm = $getConfig('display.show_form', 'yes') !== 'no';
$showSocial = $getConfig('display.show_social', 'yes') !== 'no';
$showInfo = $getConfig('display.show_info', 'yes') !== 'no';

$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContent = $page ? trim((string) ($page->getData('content') ?? '')) : '';

$flattenText = static function ($value) {
    $value = trim(strip_tags((string) $value));
    if ($value === '') {
        return '';
    }
    return preg_replace('/\s+/u', ' ', $value) ?: $value;
};

$pageContentText = $flattenText($pageContent);

$heroKicker = trim((string) $getConfig('hero.kicker', 'Support Switchboard'));
$title = trim((string) $getConfig('hero.title', $getConfig('content.title', $pageTitle)));
if ($title === '') {
    $title = 'Get in Touch';
}
$description = trim((string) $getConfig('hero.subtitle', $getConfig('content.description', $pageContentText !== '' ? $pageContentText : 'Need help with Gin Rummy tables, account access, or payout questions? Use the contact routes below to reach the right desk quickly.')));

$addressLabel = trim((string) $getConfig('contact_info.address_label', 'Address'));
$email = trim((string) $getConfig('contact_info.email', $getConfig('contact.email', 'support@ginrummycarnival.com')));
$emailLabel = trim((string) $getConfig('contact_info.email_label', 'Email'));
$phone = trim((string) $getConfig('contact_info.phone', $getConfig('contact.phone', '+91 1800-XXX-XXXX')));
$phoneLabel = trim((string) $getConfig('contact_info.phone_label', 'Phone'));
$address = trim((string) $getConfig('contact_info.address', $getConfig('contact.address', 'Mumbai, India')));
$hoursLabel = trim((string) $getConfig('contact_info.work_hours_label', 'Support Hours'));
$hours = trim((string) $getConfig('contact_info.work_hours', $getConfig('contact.hours', '24/7 Customer Support')));

$routesKicker = trim((string) $getConfig('contact.routes_kicker', 'Contact Routes'));
$routesTitle = trim((string) $getConfig('contact.routes_title', 'Reach the right Gin Rummy desk without extra steps'));
$summaryLabel = trim((string) $getConfig('contact.summary_label', 'Support Desk'));
$summaryText = trim((string) $getConfig('contact.summary_text', 'Use the channels configured for this page to route account, game, or payout questions quickly.'));
$socialTitle = trim((string) $getConfig('contact.social_title', 'Follow the desk'));
$formKicker = trim((string) $getConfig('form.kicker', 'Message Desk'));
$formTitle = trim((string) $getConfig('form.title', $getConfig('content.form_title', 'Send us a Message')));
$formNameLabel = trim((string) $getConfig('form.name_label', 'Full Name'));
$formEmailLabel = trim((string) $getConfig('form.email_label', 'Email Address'));
$formSubjectLabel = trim((string) $getConfig('form.subject_label', 'Subject'));
$formMessageLabel = trim((string) $getConfig('form.message_label', 'Message'));
$formNamePlaceholder = trim((string) $getConfig('form.name_placeholder', 'Your name'));
$formEmailPlaceholder = trim((string) $getConfig('form.email_placeholder', 'name@example.com'));
$formSubjectPlaceholder = trim((string) $getConfig('form.subject_placeholder', 'Account, gameplay, or payout issue'));
$formMessagePlaceholder = trim((string) $getConfig('form.message_placeholder', 'Share your table, UID, device, or payment details so the support desk can route the request quickly.'));
$formSubmitText = trim((string) $getConfig('form.submit_text', 'Send Message'));
$formSuccessMessage = trim((string) $getConfig('form.success_message', $getConfig('content.form_intro', 'Share the table, account, or payout context so the support team can route your request faster.')));
$mapTitle = trim((string) $getConfig('map.title', 'Desk Location'));
$mapEmbedUrl = trim((string) $getConfig('map.embed_url', ''));
$mapHeight = max(240, (int) $getConfig('map.height', 360));

$socialMap = [
    'social.wechat' => 'WeChat',
    'social.weibo' => 'Weibo',
    'social.facebook' => 'Facebook',
    'social.twitter' => 'Twitter',
    'social.linkedin' => 'LinkedIn',
];
$socials = [];
foreach ($socialMap as $key => $label) {
    $url = trim((string) $getConfig($key, ''));
    if ($url === '') {
        continue;
    }
    $socials[] = [
        'name' => $label,
        'url' => $url,
    ];
}

if (empty($socials)) {
    $socialRaw = (string) $getConfig('social.items', "Facebook|#\nTwitter|#\nInstagram|#\nYouTube|#");
    if (strpos($socialRaw, '\\n') !== false && strpos($socialRaw, "\n") === false) {
        $socialRaw = str_replace('\\n', "\n", $socialRaw);
    }
    foreach (preg_split('/[\r\n]+/', $socialRaw) ?: [] as $line) {
        if (trim($line) === '') {
            continue;
        }
        $parts = explode('|', $line, 2);
        if (trim((string) ($parts[0] ?? '')) === '') {
            continue;
        }
        $socials[] = [
            'name' => trim((string) ($parts[0] ?? '')),
            'url' => trim((string) ($parts[1] ?? '#')),
        ];
    }
}

$channels = [];
if ($email !== '') {
    $channels[] = ['icon' => 'EM', 'label' => $emailLabel !== '' ? $emailLabel : 'Email', 'value' => $email, 'href' => 'mailto:' . $email];
}
if ($phone !== '') {
    $channels[] = ['icon' => 'PH', 'label' => $phoneLabel !== '' ? $phoneLabel : 'Phone', 'value' => $phone, 'href' => 'tel:' . preg_replace('/[^0-9+]/', '', $phone)];
}
if ($address !== '') {
    $channels[] = ['icon' => 'AD', 'label' => $addressLabel !== '' ? $addressLabel : 'Address', 'value' => $address, 'href' => ''];
}
if ($hours !== '') {
    $channels[] = ['icon' => '24', 'label' => $hoursLabel !== '' ? $hoursLabel : 'Support Hours', 'value' => $hours, 'href' => ''];
}

$showSupportSummary = empty($channels);
$channelLead = $channels[0] ?? null;
$channelTrail = array_slice($channels, 1);

$getInitials = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return 'NA';
    }

    $parts = preg_split('/\s+/', $value) ?: [];
    $initials = '';
    foreach ($parts as $part) {
        if ($part === '') {
            continue;
        }
        if (function_exists('mb_substr')) {
            $initials .= mb_strtoupper(mb_substr($part, 0, 1));
        } else {
            $initials .= strtoupper(substr($part, 0, 1));
        }
        if (strlen($initials) >= 2) {
            break;
        }
    }

    if ($initials === '') {
        $initials = function_exists('mb_substr') ? mb_strtoupper(mb_substr($value, 0, 2)) : strtoupper(substr($value, 0, 2));
    }

    return $initials;
};
?>

