<?php
/**
 * Gin Rummy Carnival Blog List Component
 *
 * @fields_start
 * blog.title|博客列表标题|text|Latest Blog Posts
 * blog.subtitle|副标题|text|Stay updated with our latest news and articles
 * blog.posts_per_page|每页文章数|number|9
 * blog.show_sidebar|显示侧边栏|select:yes=是,no=否|yes
 * blog.show_category|显示分类|select:yes=是,no=否|yes
 * blog.show_date|显示日期|select:yes=是,no=否|yes
 * blog.show_author|显示作者|select:yes=是,no=否|yes
 * blog.card_style|卡片样式|select:default=默认,minimal=简约,featured=重点|default
 * blog.kicker|顶部提示文案|text|Editorial Table
 * blog.feature_kicker|首篇提示文案|text|Lead Story
 * blog.empty_text|空状态文案|text|There are no blog posts yet. Please check back later.
 * blog.read_article_text|首篇按钮文案|text|Read Story
 * blog.read_more_text|列表按钮文案|text|Open Story
 * blog.categories_title|分类标题|text|Categories
 * blog.recent_posts_title|最近文章标题|text|Recent Posts
 * @fields_end
 */

$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$blogPosts = $this->getData('blog_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$componentId = 'grc-blog-list-' . uniqid();

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$title = $getConfig('blog.title', 'Latest Blog Posts');
$subtitle = $getConfig('blog.subtitle', 'Stay updated with our latest news and articles');
$postsPerPage = max(1, (int) $getConfig('blog.posts_per_page', 9));
$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCategory = $getConfig('blog.show_category', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$cardStyle = $getConfig('blog.card_style', 'default');
$mastKicker = trim((string) $getConfig('blog.kicker', 'Editorial Table'));
$featureKicker = trim((string) $getConfig('blog.feature_kicker', 'Lead Story'));
$emptyText = trim((string) $getConfig('blog.empty_text', 'There are no blog posts yet. Please check back later.'));
$readArticleText = trim((string) $getConfig('blog.read_article_text', 'Read Story'));
$readMoreText = trim((string) $getConfig('blog.read_more_text', 'Open Story'));
$categoriesTitle = trim((string) $getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string) $getConfig('blog.recent_posts_title', 'Recent Posts'));

$primaryColor = $getConfig('color_scheme.primary', '#1eb980');
$secondaryColor = $getConfig('color_scheme.secondary', '#f2a93b');
$bgColor = $getConfig('color_scheme.background', '#0b1525');
$textColor = $getConfig('color_scheme.text', '#f8fafc');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/poker-header-bg.svg');

$posts = array_slice($blogPosts, 0, $postsPerPage);
$featuredPost = $posts[0] ?? null;
$sidePosts = array_slice($posts, 1, 2);
$archivePosts = array_slice($posts, 3);
if (!$featuredPost) {
    $archivePosts = [];
}

$featureSideStack = $featuredPost ? $sidePosts : array_slice($posts, 0, 2);
$archiveDeck = $featuredPost ? $archivePosts : array_slice($posts, 2);
$recentPool = !empty($recentPosts) ? $recentPosts : $posts;

$excerpt = static function ($value, $limit) {
    $value = trim((string) $value);
    if ($value === '') {
        return '';
    }

    if (function_exists('mb_strlen') && function_exists('mb_substr')) {
        return mb_strlen($value) > $limit ? mb_substr($value, 0, $limit) . '...' : $value;
    }

    return strlen($value) > $limit ? substr($value, 0, $limit) . '...' : $value;
};
?>

<section id="<?= $componentId ?>" class="grc-blog-list" aria-labelledby="<?= $componentId ?>-title">
    <div class="list-suits" aria-hidden="true">
        <span class="list-suit list-suit-spade">&spades;</span>
        <span class="list-suit list-suit-club">&clubs;</span>
    </div>

    <div class="blog-shell">
        <header class="news-mast wow animate__fadeInUp" data-wow-duration="0.84s">
            <div class="mast-copy">
                <span class="mast-kicker"><?= htmlspecialchars($mastKicker !== '' ? $mastKicker : 'Editorial Table') ?></span>
                <h2 id="<?= $componentId ?>-title"><?= htmlspecialchars($title) ?></h2>
                <?php if ($subtitle): ?>
                    <p><?= htmlspecialchars($subtitle) ?></p>
                <?php endif; ?>
            </div>

            <?php if (!empty($blogCategories)): ?>
                <nav class="mast-categories" aria-label="Blog categories">
                    <?php foreach (array_slice($blogCategories, 0, 4) as $category): ?>
                        <a href="<?= htmlspecialchars($category['url'] ?? '#') ?>"><?= htmlspecialchars($category['name'] ?? '') ?></a>
                    <?php endforeach; ?>
                </nav>
            <?php endif; ?>
        </header>

        <?php if (empty($posts)): ?>
            <div class="blog-empty">
                <div class="empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <p><?= htmlspecialchars($emptyText !== '' ? $emptyText : 'There are no blog posts yet. Please check back later.') ?></p>
            </div>
        <?php else: ?>
            <div class="news-layout<?= $showSidebar ? ' has-rail' : '' ?>">
                <main class="news-stage">
                    <?php if ($featuredPost): ?>
                        <article class="headline-feature wow animate__fadeInUp" data-wow-delay="0.06s" data-wow-duration="0.88s">
                            <div class="feature-copy">
                                <span class="feature-kicker"><?= htmlspecialchars($featureKicker !== '' ? $featureKicker : 'Lead Story') ?></span>
                                <div class="feature-meta">
                                    <?php if ($showCategory && !empty($featuredPost['category_name'])): ?>
                                        <span><?= htmlspecialchars($featuredPost['category_name']) ?></span>
                                    <?php endif; ?>
                                    <?php if ($showDate && !empty($featuredPost['published_at'])): ?>
                                        <span><?= date('M d, Y', strtotime($featuredPost['published_at'])) ?></span>
                                    <?php endif; ?>
                                </div>
                                <h3><a href="<?= htmlspecialchars($featuredPost['url']) ?>"><?= htmlspecialchars($featuredPost['title']) ?></a></h3>
                                <?php if (!empty($featuredPost['summary'])): ?>
                                    <p><?= htmlspecialchars($excerpt($featuredPost['summary'], 220)) ?></p>
                                <?php endif; ?>
                                <div class="feature-foot">
                                    <?php if ($showAuthor && !empty($featuredPost['author'])): ?>
                                        <span><?= htmlspecialchars($featuredPost['author']) ?></span>
                                    <?php endif; ?>
                                    <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="feature-link"><?= htmlspecialchars($readArticleText !== '' ? $readArticleText : 'Read Story') ?></a>
                                </div>
                            </div>

                            <?php if (!empty($featuredPost['cover_image'])): ?>
                                <a href="<?= htmlspecialchars($featuredPost['url']) ?>" class="feature-media">
                                    <img src="<?= htmlspecialchars($featuredPost['cover_image']) ?>" alt="<?= htmlspecialchars($featuredPost['title']) ?>" loading="lazy">
                                </a>
                            <?php endif; ?>
                        </article>
                    <?php endif; ?>

                    <?php if (!empty($featureSideStack)): ?>
                        <div class="bulletin-stack wow animate__fadeInUp" data-wow-delay="0.1s" data-wow-duration="0.9s">
                            <?php foreach ($featureSideStack as $post): ?>
                                <article class="bulletin-card">
                                    <div class="bulletin-meta">
                                        <?php if ($showCategory && !empty($post['category_name'])): ?>
                                            <span><?= htmlspecialchars($post['category_name']) ?></span>
                                        <?php endif; ?>
                                        <?php if ($showDate && !empty($post['published_at'])): ?>
                                            <span><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                        <?php endif; ?>
                                    </div>
                                    <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                    <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                        <p><?= htmlspecialchars($excerpt($post['summary'], 110)) ?></p>
                                    <?php endif; ?>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>

                    <?php if (!empty($archiveDeck)): ?>
                        <div class="archive-grid style-<?= htmlspecialchars(preg_replace('/[^a-z0-9-]+/i', '', (string) $cardStyle)) ?> wow animate__fadeInUp" data-wow-delay="0.14s" data-wow-duration="0.92s">
                            <?php foreach ($archiveDeck as $index => $post): ?>
                                <article class="archive-card<?= $cardStyle === 'featured' && $index === 0 ? ' is-wide' : '' ?><?= $index % 5 === 2 ? ' is-lifted' : '' ?>">
                                    <?php if (!empty($post['cover_image'])): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="archive-media">
                                            <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                        </a>
                                    <?php endif; ?>
                                    <div class="archive-copy">
                                        <div class="archive-meta">
                                            <?php if ($showCategory && !empty($post['category_name'])): ?>
                                                <span><?= htmlspecialchars($post['category_name']) ?></span>
                                            <?php endif; ?>
                                            <?php if ($showDate && !empty($post['published_at'])): ?>
                                                <span><?= date('M d, Y', strtotime($post['published_at'])) ?></span>
                                            <?php endif; ?>
                                        </div>
                                        <h3><a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($post['title']) ?></a></h3>
                                        <?php if ($cardStyle !== 'minimal' && !empty($post['summary'])): ?>
                                            <p><?= htmlspecialchars($excerpt($post['summary'], 150)) ?></p>
                                        <?php endif; ?>
                                        <div class="archive-foot">
                                            <?php if ($showAuthor && !empty($post['author'])): ?>
                                                <span><?= htmlspecialchars($post['author']) ?></span>
                                            <?php endif; ?>
                                            <a href="<?= htmlspecialchars($post['url']) ?>"><?= htmlspecialchars($readMoreText !== '' ? $readMoreText : 'Open Story') ?></a>
                                        </div>
                                    </div>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                </main>

                <?php if ($showSidebar): ?>
                    <aside class="news-rail wow animate__fadeInUp" data-wow-delay="0.18s" data-wow-duration="0.94s">
                        <?php if (!empty($blogCategories)): ?>
                            <section class="rail-panel">
                                <span class="rail-kicker"><?= htmlspecialchars($categoriesTitle !== '' ? $categoriesTitle : 'Categories') ?></span>
                                <div class="rail-links">
                                    <?php foreach ($blogCategories as $category): ?>
                                        <a href="<?= htmlspecialchars($category['url']) ?>" class="rail-link">
                                            <span><?= htmlspecialchars($category['name']) ?></span>
                                            <?php if (isset($category['post_count'])): ?>
                                                <small><?= (int) $category['post_count'] ?></small>
                                            <?php endif; ?>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if (!empty($recentPool)): ?>
                            <section class="rail-panel">
                                <span class="rail-kicker"><?= htmlspecialchars($recentPostsTitle !== '' ? $recentPostsTitle : 'Recent Posts') ?></span>
                                <div class="recent-stack">
                                    <?php foreach (array_slice($recentPool, 0, 5) as $post): ?>
                                        <a href="<?= htmlspecialchars($post['url']) ?>" class="recent-link">
                                            <?php if (!empty($post['cover_image'])): ?>
                                                <img src="<?= htmlspecialchars($post['cover_image']) ?>" alt="<?= htmlspecialchars($post['title']) ?>" loading="lazy">
                                            <?php endif; ?>
                                            <span>
                                                <strong><?= htmlspecialchars($post['title']) ?></strong>
                                                <?php if (!empty($post['published_at'])): ?>
                                                    <small><?= date('M d, Y', strtotime($post['published_at'])) ?></small>
                                                <?php endif; ?>
                                            </span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</section>

