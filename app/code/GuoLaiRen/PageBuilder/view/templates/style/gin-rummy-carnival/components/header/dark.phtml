<?php
/**
 * Gin Rummy Carnival - Dark Header
 *
 * @component_start
 * code: header-dark
 * name: Dark Header
 * name_en: Dark Header
 * description: Alternative sticky header with navigation and CTA
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文本:text:Gin Rummy Carnival
 * logo.url => Logo地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:text:150px
 *
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * navigation.items => 导航项:textarea:Home=>/\r\nGames=>#games\r\nFAQ=>#faq\r\nSupport=>/contact
 *
 * group:button => 按钮设置
 * button.display => 显示按钮:select:yes|yes,no
 * button.text => 按钮文本:text:Install App
 * button.url => 按钮链接:text:#download
 *
 * group:style => 样式设置
 * style.background => 背景颜色:color:#08131d
 * style.nav_color => 导航文字颜色:color:#f8fafc
 * style.accent_color => 强调色:color:#1eb980
 * style.height => 头部高度:text:72px
 * @fields_end
 */

$componentId = 'grc-header-dark-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoText = trim((string) $getConfig('logo.text', 'Gin Rummy Carnival'));
$defaultLogo = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/carnival-logo-icon.svg');
$logoUrl = trim((string) $getConfig('logo.url', ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $defaultLogo);
$logoWidth = trim((string) $getConfig('logo.width', '150px'));
$showNav = $getConfig('navigation.display', 'yes') !== 'no';
$useCustomLinksRaw = trim((string) $getConfig('navigation.use_custom_links', ''));
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $useCustomLinksRaw === 'yes'
    : $getConfig('navigation.use_subpages', 'no') !== 'yes';
$navItems = [];
if (!$useCustomLinks && $page) {
    $pages = method_exists($page, 'getHeaderNavigationPages') ? $page->getHeaderNavigationPages(10) : $page->getNavigationPages([], 10);
    foreach ($pages as $navPage) {
        $text = trim((string) ($navPage['title'] ?? ''));
        if ($text === '') {
            continue;
        }
        $navItems[] = ['text' => $text, 'href' => (string) ($navPage['url'] ?? '#')];
    }
}
if (empty($navItems)) {
    $rawItems = (string) $getConfig('navigation.items', "Home=>/\nGames=>#games\nFAQ=>#faq\nSupport=>/contact");
    if (strpos($rawItems, '\\n') !== false && strpos($rawItems, "\n") === false) {
        $rawItems = str_replace('\\n', "\n", $rawItems);
    }
    foreach (preg_split('/[\r\n]+/', $rawItems) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '') {
            continue;
        }
        $parts = strpos($line, '|') !== false ? explode('|', $line, 2) : explode('=>', $line, 2);
        $text = trim((string) ($parts[0] ?? ''));
        $href = trim((string) ($parts[1] ?? '#'));
        if ($text === '') {
            continue;
        }
        $navItems[] = ['text' => $text, 'href' => $href !== '' ? $href : '#'];
    }
}
$showButton = $getConfig('button.display', 'yes') !== 'no';
$buttonText = trim((string) $getConfig('button.text', 'Install App'));
$buttonUrl = trim((string) $getConfig('button.url', '#download'));
$buttonHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string) $buttonUrl);
$buttonRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($buttonHref, 'url');
$bgColor = (string) $getConfig('style.background', '#08131d');
$navColor = (string) $getConfig('style.nav_color', '#f8fafc');
$accentColor = (string) $getConfig('style.accent_color', '#1eb980');
$headerHeight = trim((string) $getConfig('style.height', '72px'));
?>
<header id="<?= $componentId ?>" class="grc-header-dark">
    <div class="dark-inner">
        <?php if ($showLogo && $logoUrl !== ''): ?>
            <a href="/" class="dark-brand" aria-label="<?= htmlspecialchars($logoText !== '' ? $logoText : 'Gin Rummy Carnival') ?> home">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText !== '' ? $logoText : 'Gin Rummy Carnival') ?>" style="width: <?= htmlspecialchars($logoWidth, ENT_QUOTES, 'UTF-8') ?>;">
                <?php if ($logoText !== ''): ?>
                    <span><?= htmlspecialchars($logoText) ?></span>
                <?php endif; ?>
            </a>
        <?php endif; ?>

        <?php if ($showNav && !empty($navItems)): ?>
            <nav class="dark-nav" aria-label="Primary navigation">
                <?php foreach ($navItems as $item): ?>
                    <a href="<?= htmlspecialchars($item['href']) ?>"><?= htmlspecialchars($item['text']) ?></a>
                <?php endforeach; ?>
            </nav>
        <?php endif; ?>

        <?php if ($showButton && $buttonText !== ''): ?>
            <a class="dark-cta" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($buttonRef)) ?>" data-glr-ref="<?= htmlspecialchars($buttonRef) ?>">
                <?= htmlspecialchars($buttonText) ?>
            </a>
        <?php endif; ?>
    </div>
</header>
<style>
#<?= $componentId ?> {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 19, 29, 0.92);
    border-bottom: 1px solid rgba(255,255,255,0.08);
}
#<?= $componentId ?> .dark-inner {
    width: min(1240px, calc(100% - 32px));
    min-height: <?= htmlspecialchars($headerHeight, ENT_QUOTES, 'UTF-8') ?>;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
}
#<?= $componentId ?> .dark-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: <?= htmlspecialchars($navColor, ENT_QUOTES, 'UTF-8') ?>;
    font-family: 'Space Grotesk', 'Manrope', sans-serif;
    font-weight: 700;
}
#<?= $componentId ?> .dark-brand img {
    height: auto;
    display: block;
}
#<?= $componentId ?> .dark-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
}
#<?= $componentId ?> .dark-nav a {
    color: <?= htmlspecialchars($navColor, ENT_QUOTES, 'UTF-8') ?>;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 700;
}
#<?= $componentId ?> .dark-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.82rem 1.15rem;
    border-radius: 999px;
    background: <?= htmlspecialchars($accentColor, ENT_QUOTES, 'UTF-8') ?>;
    color: #08131d;
    text-decoration: none;
    font-weight: 800;
}
@media (max-width: 980px) {
    #<?= $componentId ?> .dark-inner {
        grid-template-columns: 1fr;
        justify-items: center;
        padding: 0.9rem 0;
    }
}
@media (max-width: 767px) {
    #<?= $componentId ?> .dark-inner {
        width: min(100%, calc(100% - 24px));
    }
    #<?= $componentId ?> .dark-nav {
        gap: 0.75rem;
    }
}
</style>
