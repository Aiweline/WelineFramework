$ctaRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($ctaHref, 'url');
$ctaBgColor = (string) $getConfigAny(['download_button.bg_color', 'header.download_button.bg_color'], $colors['accent_primary'] ?? '#1eb980');
$ctaBgHoverColor = (string) $getConfigAny(['download_button.bg_hover_color', 'header.download_button.hover_bg_color'], $colors['accent_primary_dark'] ?? '#0f7f61');
$ctaTextColor = (string) $getConfigAny(['download_button.text_color', 'header.download_button.text_color'], $colors['button_primary_text'] ?? '#0b1525');
$ctaFontSize = (int) $getConfig('download_button.font_size', '12');
$ctaFontWeight = (int) $getConfig('download_button.font_weight', '800');
$ctaRadius = (int) $getConfigAny(['download_button.border_radius', 'header.download_button.border_radius'], '16');
$ctaPaddingX = (int) $getConfig('download_button.padding_x', '16');
$ctaPaddingY = (int) $getConfig('download_button.padding_y', '10');

$navItems = [];
if (!$useCustomLinks && $page) {
    $navigationPages = method_exists($page, 'getHeaderNavigationPages')
        ? $page->getHeaderNavigationPages(10)
        : $page->getNavigationPages([], 10);
    foreach ($navigationPages as $navPage) {
        $title = trim((string) ($navPage['title'] ?? ''));
        if ($title === '') {
            continue;
        }
        $type = (string) ($navPage['type'] ?? '');
        $configuredLabel = trim((string) $getConfigAny([
            'navigation_labels.navigation.label_' . $type,
            'navigation.label_' . $type,
            'header.navigation.label_' . $type,
        ], ''));
        $navItems[] = [
            'text' => $configuredLabel !== '' ? $configuredLabel : $title,
            'href' => (string) ($navPage['url'] ?? '#'),
        ];
    }
}

if (empty($navItems)) {
    if (strpos($navItemsConfig, '\\n') !== false && strpos($navItemsConfig, "\n") === false) {
        $navItemsConfig = str_replace('\\n', "\n", $navItemsConfig);
    }

    foreach (preg_split('/\r?\n/', $navItemsConfig) ?: [] as $line) {
        $line = trim((string) $line);
        if ($line === '' || strpos($line, '=>') === false) {
            continue;
        }

        $parts = explode('=>', $line, 2);
        $text = trim((string) ($parts[0] ?? ''));
        $href = trim((string) ($parts[1] ?? ''));
        if ($text === '') {
            continue;
        }

        if ($href === '') {
            $href = '/' . strtolower(trim(preg_replace('/[^a-zA-Z0-9]+/', '-', $text), '-'));
        }

        $navItems[] = ['text' => $text, 'href' => $href];
    }
}

if (empty($navItems)) {
    $navItems = [
        ['text' => 'Home', 'href' => '/'],
        ['text' => 'Games', 'href' => '#games'],
        ['text' => 'About', 'href' => '/about'],
        ['text' => 'FAQ', 'href' => '/faq'],
    ];
}

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}
