$navBackdropBlur = (int) $getConfig('navigation.backdrop_blur', '10');

$navItemsConfig = (string) $getConfigAny(['navigation.items', 'header.navigation.items'], "Home=>/\nGames=>#games\nHow to Play=>#howto\nWinners=>#winners\nFAQ=>#faq");
$useCustomLinksRaw = trim((string) $getConfigAny(['navigation.use_custom_links', 'header.navigation.use_custom_links'], ''));
$useCustomLinks = $useCustomLinksRaw !== ''
    ? $normalizeToggle($useCustomLinksRaw, 'yes') === 'yes'
