$ctaDisplay = $normalizeToggle($getConfigAny(['download_button.display', 'header.download_button.display'], 'yes')) !== 'no';
$ctaText = trim((string) $getConfigAny(['download_button.text', 'header.download_button.text', 'navigation.cta_text'], 'Install App'));
$ctaUrl = (string) $getConfigAny(['download_button.url', 'header.download_button.url', 'navigation.cta_url'], '#download');
