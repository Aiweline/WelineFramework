<script>
(() => {
    const root = document.getElementById('<?= $componentId ?>');
    if (!root) {
        return;
    }

    const toggle = root.querySelector('.nav-toggle');
    const stage = document.getElementById('<?= $componentId ?>-mobile');
    const closeBtn = stage ? stage.querySelector('.mobile-close') : null;
    const desktopMq = window.matchMedia('(min-width: 961px)');
    const syncScrolled = () => {
        root.dataset.scrolled = window.scrollY > 10 ? 'true' : 'false';
    };

    const setOpen = (open) => {
        if (!toggle || !stage) {
            return;
        }

        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        stage.style.display = open ? 'flex' : 'none';
        stage.setAttribute('aria-hidden', open ? 'false' : 'true');
        root.dataset.mobileOpen = open ? 'true' : 'false';
        document.body.classList.toggle('grc-mobile-lock', open);
    };

    if (toggle && stage) {
        toggle.addEventListener('click', () => {
            const isOpen = toggle.getAttribute('aria-expanded') === 'true';
            setOpen(!isOpen);
        });

        stage.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => setOpen(false));
        });

        if (closeBtn) {
            closeBtn.addEventListener('click', () => setOpen(false));
        }

        stage.addEventListener('click', (event) => {
            if (event.target === stage) {
                setOpen(false);
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                setOpen(false);
            }
        });

        const syncDesktop = (event) => {
            if (event.matches) {
                setOpen(false);
            }
        };

        if (desktopMq.addEventListener) {
            desktopMq.addEventListener('change', syncDesktop);
        } else if (desktopMq.addListener) {
            desktopMq.addListener(syncDesktop);
        }
    }

    syncScrolled();
    window.addEventListener('scroll', syncScrolled, { passive: true });
})();
</script>
