/**
 * Gin Rummy Carnival - Navigation
 *
 * @component_start
 * code: header-nav
 * name: Navigation
 * name_en: Navigation Bar
 * description: Carnival ribbon navigation with animated light sweep and mobile panel
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文本:text:Gin Rummy Carnival
 * logo.subline => Logo副标题:text:Deal sharp. Read faster.
 * logo.url => Logo图片地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:responsive:60/64|px
 * logo.height => Logo高度:responsive:|px[可选，默认跟随宽度]
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 导航背景色:color:#0b1c2a
 * navigation.bg_color_scrolled => 滚动后导航背景色:color:#08131d
 * navigation.text_color => 导航文字颜色:color:#f8fafc
 * navigation.link_color => 链接颜色:color:#cbd5e1
 * navigation.link_hover_color => 链接悬停颜色:color:#f2a93b
 * navigation.link_font_size => 链接字号:number:12|px
 * navigation.link_font_weight => 链接字重:number:800
 * navigation.link_gap => 链接间距:number:4|px
 * navigation.padding_x => 水平内边距:number:16|px
 * navigation.padding_y => 垂直内边距:number:10|px
 * navigation.min_height => 最小高度:number:62|px
 * navigation.box_shadow => 阴影:text:0 18px 42px rgba(1, 8, 19, 0.24)
 * navigation.backdrop_blur => 背景模糊:number:10|px
 * navigation.items => 导航项:textarea:Home=>/\r\nGames=>#games\r\nHow to Play=>#howto\r\nWinners=>#winners\r\nFAQ=>#faq|格式：名称=>链接
 * navigation.use_custom_links => 使用自定义导航链接:select:yes|yes,no
 * group:navigation_labels => 导航菜单显示名称（有对应页面时显示，留空使用页面标题）
 * navigation.label_home_page => 首页菜单名:text:
 * navigation.label_about_page => 关于我们菜单名:text:
 * navigation.label_blog_list => 博客菜单名:text:
 * navigation.label_contact_page => 联系我们菜单名:text:
 * navigation.label_terms_of_service => 条款菜单名:text:
 * navigation.label_privacy_policy => 隐私政策菜单名:text:
 * group:download_button => 下载按钮
 * download_button.display => 显示下载按钮:select:yes|yes,no
 * download_button.text => 按钮文本:text:Install App
 * download_button.url => 按钮链接:text:#download
 * download_button.bg_color => 按钮背景色:color:#1eb980
 * download_button.bg_hover_color => 按钮悬停背景色:color:#0f7f61
 * download_button.text_color => 按钮文字颜色:color:#0b1525
 * download_button.font_size => 按钮字号:number:12|px
 * download_button.font_weight => 按钮字重:number:800
 * download_button.border_radius => 按钮圆角:number:16|px
 * download_button.padding_x => 按钮水平内边距:number:16|px
 * download_button.padding_y => 按钮垂直内边距:number:10|px
 * @fields_end
 */

$componentId = 'grc-nav-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);
$standaloneShell = !($this->getData('__grc_shell_managed') || $this->getData('__pagebuilder_shell_managed'));

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$getConfigAny = function (array $keys, $default = '') use ($config) {
    foreach ($keys as $key) {
        if (isset($config[$key]) && $config[$key] !== '') {
            return $config[$key];
        }
    }
    return $default;
};

$normalizeToggle = static function ($value, $default = 'yes') {
    if ($value === '' || $value === null) {
        return $default;
    }
    if ($value === 0 || $value === '0') {
        return 'yes';
    }
    if ($value === 1 || $value === '1') {
        return 'no';
    }
    return ($value === 'no' || $value === false || $value === 'false') ? 'no' : 'yes';
};

$parseResponsive = static function ($value) {
    if (empty($value)) {
        return ['mobile' => '', 'desktop' => '', 'unit' => 'px'];
    }
    $value = trim((string) $value);
    $unit = 'px';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    return [
        'mobile' => trim((string) ($parts[0] ?? '')),
        'desktop' => trim((string) ($parts[1] ?? ($parts[0] ?? ''))),
        'unit' => $unit,
    ];
};

$genResponsiveCSS = static function ($parsed) {
    $mobile = (float) $parsed['mobile'];
    $desktop = (float) $parsed['desktop'];
    $unit = $parsed['unit'];
    if ($mobile === $desktop) {
        return $mobile . $unit;
    }
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
};

$sanitizeTitle = function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return $value;
    }
    $value = preg_replace('/^\\x{6837}\\x{5F0F}\\x{6A21}\\x{677F}\\x{9884}\\x{89C8}\\s*[-–—]*\\s*/u', '', $value);
    return trim($value);
};

$metaTitleRaw = $page ? ($page->getData('meta_title') ?: $page->getData('title')) : 'Gin Rummy Carnival';
$metaTitle = $sanitizeTitle($metaTitleRaw);
if ($metaTitle === '') {
    $metaTitle = 'Gin Rummy Carnival';
}
$metaDescription = $page ? (string) $page->getData('meta_description') : '';
$metaKeywords = $page ? (string) $page->getData('meta_keywords') : '';

$this->assign('template_code', 'gin-rummy-carnival');
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);

$logoDisplay = $normalizeToggle($getConfigAny(['logo.display', 'header.logo.display'], 'yes')) !== 'no';
$logoText = $sanitizeTitle($getConfigAny(['logo.text', 'header.logo.text', 'app_info.app_name', 'texts.app_name'], 'Gin Rummy Carnival'));
if ($logoText === '') {
    $logoText = 'Gin Rummy Carnival';
}
$logoSubline = trim((string) $getConfigAny(['logo.subline', 'header.logo.subline'], 'Deal sharp. Read faster.'));

$logoIconUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/carnival-logo-icon.svg');
$logoUrl = trim((string) $getConfigAny(['logo.url', 'header.logo.url'], ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $logoIconUrl);
$logoWidth = $genResponsiveCSS($parseResponsive($getConfigAny(['logo.width', 'header.logo.width'], '60/64') . 'px'));
$logoHeightConfig = trim((string) $getConfigAny(['logo.height', 'header.logo.height'], ''));
$logoHeight = $logoHeightConfig === '' ? $logoWidth : $genResponsiveCSS($parseResponsive($logoHeightConfig . 'px'));

$navDisplay = $normalizeToggle($getConfigAny(['navigation.display', 'header.navigation.display'], 'yes')) !== 'no';
if (!$navDisplay) {
    return;
}

$navBgColor = (string) $getConfigAny(['navigation.bg_color', 'header.navigation.bg_color'], $colors['nav_bg'] ?? '#0b1c2a');
$navBgColorScrolled = (string) $getConfigAny(['navigation.bg_color_scrolled', 'header.navigation.bg_color_scrolled'], $colors['nav_bg_scrolled'] ?? '#08131d');
$navTextColor = (string) $getConfigAny(['navigation.text_color', 'header.navigation.text_color'], $colors['nav_text'] ?? '#f8fafc');
$navLinkColor = (string) $getConfigAny(['navigation.link_color', 'header.navigation.link_color'], $colors['nav_link'] ?? '#cbd5e1');
$navLinkHoverColor = (string) $getConfigAny(['navigation.link_hover_color', 'header.navigation.link_hover_color'], $colors['nav_link_hover'] ?? '#f2a93b');
$navLinkFontSize = (int) $getConfig('navigation.link_font_size', '12');
$navLinkFontWeight = (int) $getConfig('navigation.link_font_weight', '800');
$navLinkGap = (int) $getConfig('navigation.link_gap', '4');
$navPaddingX = (int) $getConfig('navigation.padding_x', '16');
$navPaddingY = (int) $getConfig('navigation.padding_y', '10');
