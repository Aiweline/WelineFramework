<?php
/**
 * Gin Rummy Carnival - Simple Header
 *
 * @component_start
 * code: header-simple
 * name: Simple Header
 * name_en: Simple Header
 * description: Compact header with brand mark and optional text
 * category: header
 * region: header
 * @component_end
 *
 * @fields_start
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文本:text:Gin Rummy Carnival
 * logo.url => Logo地址:textarea:|留空使用默认图标
 * logo.width => Logo宽度:number:56|px
 * logo.position => Logo位置:select:left|left,center,right
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#08131d
 * style.text_color => 文字颜色:color:#f8fafc
 * style.padding => 内边距:number:18|px
 * @fields_end
 */

$componentId = 'grc-header-simple-' . uniqid();
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showLogo = $getConfig('logo.display', 'yes') !== 'no';
$logoText = trim((string) $getConfig('logo.text', 'Gin Rummy Carnival'));
$defaultLogo = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/carnival-logo-icon.svg');
$logoUrl = trim((string) $getConfig('logo.url', ''));
$logoUrl = $logoUrl !== '' ? $logoUrl : ($page && $page->getData('logo') ? (string) $page->getData('logo') : $defaultLogo);
$logoWidth = max(32, (int) $getConfig('logo.width', 56));
$position = (string) $getConfig('logo.position', 'left');
$bgColor = (string) $getConfig('style.bg_color', '#08131d');
$textColor = (string) $getConfig('style.text_color', '#f8fafc');
$padding = max(12, (int) $getConfig('style.padding', 18));
$justifyMap = ['left' => 'flex-start', 'center' => 'center', 'right' => 'flex-end'];
$justify = $justifyMap[$position] ?? 'flex-start';
?>
<header id="<?= $componentId ?>" class="grc-header-simple">
    <div class="simple-inner">
        <?php if ($showLogo && $logoUrl !== ''): ?>
            <a href="/" class="simple-brand" aria-label="<?= htmlspecialchars($logoText !== '' ? $logoText : 'Gin Rummy Carnival') ?> home">
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText !== '' ? $logoText : 'Gin Rummy Carnival') ?>" loading="eager">
                <?php if ($logoText !== ''): ?>
                    <span><?= htmlspecialchars($logoText) ?></span>
                <?php endif; ?>
            </a>
        <?php endif; ?>
    </div>
</header>
<style>
#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    padding: <?= (int) $padding ?>px 0;
}
#<?= $componentId ?> .simple-inner {
    width: min(1240px, calc(100% - 32px));
    margin: 0 auto;
    display: flex;
    justify-content: <?= $justify ?>;
    align-items: center;
}
#<?= $componentId ?> .simple-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: <?= htmlspecialchars($textColor, ENT_QUOTES, 'UTF-8') ?>;
    font-family: 'Space Grotesk', 'Manrope', sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
}
#<?= $componentId ?> .simple-brand img {
    width: <?= (int) $logoWidth ?>px;
    height: auto;
    display: block;
}
@media (max-width: 767px) {
    #<?= $componentId ?> .simple-inner {
        width: min(100%, calc(100% - 24px));
    }
}
</style>
