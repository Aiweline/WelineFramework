<?php
/**
 * Gin Rummy Carnival - Simple Footer
 *
 * @component_start
 * code: footer-simple
 * name: Simple Footer
 * name_en: Simple Footer
 * description: Minimal footer bar with copyright text
 * category: footer
 * region: footer
 * @component_end
 *
 * @fields_start
 * group:content => 内容配置
 * content.copyright_text => 版权信息:text:© 2026 Gin Rummy Carnival. All rights reserved.
 *
 * group:style => 样式设置
 * style.bg_color => 背景颜色:color:#08131d
 * style.text_color => 文字颜色:color:#94a3b8
 * style.padding => 内边距:number:20|px
 * style.text_align => 对齐方式:select:center|left,center,right
 * @fields_end
 */

$componentId = 'grc-footer-simple-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$copyrightText = (string) $getConfig('content.copyright_text', '© 2026 Gin Rummy Carnival. All rights reserved.');
$bgColor = (string) $getConfig('style.bg_color', '#08131d');
$textColor = (string) $getConfig('style.text_color', '#94a3b8');
$padding = max(12, (int) $getConfig('style.padding', 20));
$textAlign = (string) $getConfig('style.text_align', 'center');
?>
<footer id="<?= $componentId ?>" class="grc-footer-simple">
    <div class="simple-footer-inner">
        <p><?= htmlspecialchars($copyrightText) ?></p>
    </div>
</footer>
<style>
#<?= $componentId ?> {
    background: <?= htmlspecialchars($bgColor, ENT_QUOTES, 'UTF-8') ?>;
    padding: <?= (int) $padding ?>px 0;
}
#<?= $componentId ?> .simple-footer-inner {
    width: min(1240px, calc(100% - 32px));
    margin: 0 auto;
    text-align: <?= htmlspecialchars($textAlign, ENT_QUOTES, 'UTF-8') ?>;
}
#<?= $componentId ?> p {
    margin: 0;
    color: <?= htmlspecialchars($textColor, ENT_QUOTES, 'UTF-8') ?>;
    font-size: 0.875rem;
    line-height: 1.7;
}
@media (max-width: 767px) {
    #<?= $componentId ?> .simple-footer-inner {
        width: min(100%, calc(100% - 24px));
    }
}
</style>
