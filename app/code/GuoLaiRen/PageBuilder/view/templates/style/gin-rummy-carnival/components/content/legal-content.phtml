<?php
/**
 * Gin Rummy Carnival - Legal Content Component
 *
 * @component_start
 * code: legal-content
 * name: Legal Content
 * name_en: Legal Content
 * description: Legal document content module with optional TOC and updated date
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_toc => 显示目录:select:yes|yes,no
 * display.show_last_updated => 显示更新时间:select:yes|yes,no
 * display.show_icon => 显示图标:select:yes|yes,no
 *
 * group:layout => 布局设置
 * layout.content_width => 内容宽度:select:medium|narrow,medium,wide
 * layout.header_padding => 头部内边距:number:72|px
 * layout.content_padding => 内容内边距:number:32|px
 *
 * group:header => 头部设置
 * header.title => 页面标题:text:
 * header.icon => 自定义图标:text:
 * header.summary_with_count_singular => 有章节时摘要(单数):text:section arranged for quick review
 * header.summary_with_count_plural => 有章节时摘要(复数):text:sections arranged for quick review
 * header.summary_without_count => 无章节时摘要:text:Structured for readable desktop and mobile policy review.
 * header.sections_label => 章节统计标签:text:Sections
 * header.updated_label => 更新时间标签:text:Updated
 * header.layout_label => 布局标签:text:Layout
 * header.bg_color => 背景颜色:color:#0b1525
 * header.bg_gradient_end => 渐变结束色:color:#0f2538
 * header.title_color => 标题颜色:color:#f8fafc
 * header.text_color => 文字颜色:color:#cbd5e1
 *
 * group:toc => 目录设置
 * toc.title => 目录标题:text:On This Page
 * toc.items => 章节内容:textarea:|当页面正文为空时可按“标题|内容”一行一节配置
 * toc.bg_color => 目录背景色:color:rgba(11,21,37,0.9)
 * toc.border_color => 目录边框色:color:rgba(122,161,192,0.22)
 *
 * group:content => 内容设置
 * content.body => 引言正文:textarea:|当页面正文为空时显示
 * content.empty_text => 空状态文案:text:Please add policy content in the page editor or configure this component.
 * content.bg_color => 内容背景色:color:rgba(11,21,37,0.9)
 * content.text_color => 内容文字颜色:color:#e9f5f2
 * content.heading_color => 内容标题颜色:color:#f2a93b
 * content.link_color => 内容链接颜色:color:#1eb980
 *
 * @fields_end
 */

$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: ($component_config ?? []);
$config = array_merge($styleSettings, $componentConfig);
$page = $this->getData('page');
$componentId = 'grc-legal-' . uniqid();

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$showToc = $getConfig('display.show_toc', 'yes') !== 'no';
$showLastUpdated = $getConfig('display.show_last_updated', 'yes') !== 'no';
$showIcon = $getConfig('display.show_icon', 'yes') !== 'no';

$contentWidth = (string) $getConfig('layout.content_width', 'medium');
$headerPadding = max(40, (int) $getConfig('layout.header_padding', 72));
$contentPadding = max(24, (int) $getConfig('layout.content_padding', 32));

$pageType = $page ? (string) ($page->getData('type') ?? '') : '';
$pageTitle = $page ? trim((string) ($page->getData('title') ?? '')) : '';
$pageContentRaw = $page ? (string) ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? (string) ($page->getData('updated_at') ?? $page->getData('created_at') ?? '') : '';
$summarySingular = trim((string) $getConfig('header.summary_with_count_singular', 'section arranged for quick review'));
$summaryPlural = trim((string) $getConfig('header.summary_with_count_plural', 'sections arranged for quick review'));
$summaryWithoutCount = trim((string) $getConfig('header.summary_without_count', 'Structured for readable desktop and mobile policy review.'));
$sectionsLabel = trim((string) $getConfig('header.sections_label', 'Sections'));
$updatedLabel = trim((string) $getConfig('header.updated_label', 'Updated'));
$layoutLabel = trim((string) $getConfig('header.layout_label', 'Layout'));
$tocRaw = trim((string) $getConfig('toc.items', ''));
$contentBody = trim((string) $getConfig('content.body', ''));
$emptyText = trim((string) $getConfig('content.empty_text', 'Please add policy content in the page editor or configure this component.'));

$headerTitle = trim((string) $getConfig('header.title', $pageTitle));
if ($headerTitle === '') {
    $headerTitle = 'Legal Document';
}

$typeIcons = [
    'privacy_policy' => '🔒',
    'terms_of_service' => '📜',
    'refund_policy' => '💰',
    'shipping_policy' => '🚚',
    'cookie_policy' => '🍪',
];
$headerIcon = trim((string) $getConfig('header.icon', $typeIcons[$pageType] ?? '📄'));
$tocTitle = trim((string) $getConfig('toc.title', 'On This Page'));

$heroBg = (string) $getConfig('header.bg_color', '#0b1525');
$heroBgEnd = (string) $getConfig('header.bg_gradient_end', '#0f2538');
$heroTitleColor = (string) $getConfig('header.title_color', '#f8fafc');
$heroTextColor = (string) $getConfig('header.text_color', '#cbd5e1');
$tocBg = (string) $getConfig('toc.bg_color', 'rgba(11,21,37,0.9)');
$tocBorder = (string) $getConfig('toc.border_color', 'rgba(122,161,192,0.22)');
$contentBg = (string) $getConfig('content.bg_color', 'rgba(11,21,37,0.9)');
$contentText = (string) $getConfig('content.text_color', '#e9f5f2');
$contentHeading = (string) $getConfig('content.heading_color', '#f2a93b');
$contentLink = (string) $getConfig('content.link_color', '#1eb980');

$maxWidth = match ($contentWidth) {
    'wide' => '1220px',
    'narrow' => '860px',
    default => '1040px',
};

$tocItems = [];
$pageContent = $pageContentRaw;
if ($showToc && $pageContentRaw !== '') {
    $headingIndex = 0;
    $pageContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$tocItems, &$headingIndex) {
        $level = (int) $matches[1];
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $tocItems[] = [
            'id' => $id,
            'text' => $text,
            'level' => $level,
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $pageContentRaw);
}

$hasToc = $showToc && !empty($tocItems);
$formattedUpdated = '';
if ($showLastUpdated && $lastUpdated !== '') {
    $timestamp = strtotime($lastUpdated);
    if ($timestamp) {
        $formattedUpdated = date('F j, Y', $timestamp);
    }
}

$documentLabel = $pageType !== '' ? ucwords(str_replace('_', ' ', $pageType)) : 'Policy File';
$fallbackSections = [];
if ($pageContentRaw === '') {
    if ($tocRaw !== '') {
        if (strpos($tocRaw, '\\n') !== false && strpos($tocRaw, "\n") === false) {
            $tocRaw = str_replace('\\n', "\n", $tocRaw);
        }
        foreach (preg_split('/[\r\n]+/', $tocRaw) ?: [] as $line) {
            $line = trim((string) $line);
            if ($line === '') {
                continue;
            }
            $parts = explode('|', $line, 2);
            $sectionTitle = trim((string) ($parts[0] ?? ''));
            $sectionContent = trim((string) ($parts[1] ?? ''));
            if ($sectionTitle === '') {
                continue;
            }
            $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $sectionTitle));
            $slug = trim($slug, '-');
            if ($slug === '') {
                $slug = 'section';
            }
            $fallbackSections[] = [
                'id' => $slug . '-' . (count($fallbackSections) + 1),
                'title' => $sectionTitle,
                'content' => $sectionContent,
            ];
        }
    }

    if ($contentBody !== '' || !empty($fallbackSections)) {
        $builtContent = '';
        if ($contentBody !== '') {
            $builtContent .= '<p>' . nl2br(htmlspecialchars($contentBody, ENT_QUOTES, 'UTF-8')) . '</p>';
        }
        foreach ($fallbackSections as $section) {
            $builtContent .= '<h2 id="' . htmlspecialchars($section['id'], ENT_QUOTES, 'UTF-8') . '">' . htmlspecialchars($section['title'], ENT_QUOTES, 'UTF-8') . '</h2>';
            $builtContent .= '<p>' . nl2br(htmlspecialchars($section['content'], ENT_QUOTES, 'UTF-8')) . '</p>';
            $tocItems[] = [
                'id' => $section['id'],
                'text' => $section['title'],
                'level' => 2,
            ];
        }
        $pageContent = $builtContent;
    } else {
        $pageContent = '<p>' . htmlspecialchars($emptyText, ENT_QUOTES, 'UTF-8') . '</p>';
    }
}

$sectionCount = count($tocItems);
$summaryText = $sectionCount > 0
    ? (($sectionCount === 1 ? $summarySingular : $summaryPlural) ?: 'sections arranged for quick review')
    : ($summaryWithoutCount !== '' ? $summaryWithoutCount : 'Structured for readable desktop and mobile policy review.');
?>

<section id="<?= $componentId ?>" class="grc-legal-page" style="--grc-legal-hero-bg: <?= htmlspecialchars($heroBg, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-hero-end: <?= htmlspecialchars($heroBgEnd, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-hero-title: <?= htmlspecialchars($heroTitleColor, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-hero-text: <?= htmlspecialchars($heroTextColor, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-toc-bg: <?= htmlspecialchars($tocBg, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-toc-border: <?= htmlspecialchars($tocBorder, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-content-bg: <?= htmlspecialchars($contentBg, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-content-text: <?= htmlspecialchars($contentText, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-heading: <?= htmlspecialchars($contentHeading, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-link: <?= htmlspecialchars($contentLink, ENT_QUOTES, 'UTF-8') ?>; --grc-legal-header-padding: <?= (int) $headerPadding ?>px; --grc-legal-content-padding: <?= (int) $contentPadding ?>px; --grc-legal-max-width: <?= htmlspecialchars($maxWidth, ENT_QUOTES, 'UTF-8') ?>;">
    <div class="legal-suits" aria-hidden="true">
        <span class="legal-suit legal-suit-spade">&spades;</span>
        <span class="legal-suit legal-suit-diamond">&diams;</span>
    </div>

    <div class="legal-shell">
        <header class="legal-mast wow animate__fadeInUp" data-wow-duration="0.84s">
            <div class="mast-copy">
                <div class="mast-line">
                    <?php if ($showIcon && $headerIcon !== ''): ?>
                        <span class="mast-icon"><?= htmlspecialchars($headerIcon) ?></span>
                    <?php endif; ?>
                    <span class="mast-type"><?= htmlspecialchars($documentLabel) ?></span>
                </div>
                <h1><?= htmlspecialchars($headerTitle) ?></h1>
                <p>
                    <?php if ($sectionCount > 0): ?>
                        <?= htmlspecialchars((string) $sectionCount) ?> <?= htmlspecialchars($summaryText) ?>
                    <?php else: ?>
                        <?= htmlspecialchars($summaryText) ?>
                    <?php endif; ?>
                </p>
            </div>

            <div class="mast-cards" aria-label="Document summary">
                <article class="summary-card summary-card-strong">
                    <span><?= htmlspecialchars($sectionsLabel !== '' ? $sectionsLabel : 'Sections') ?></span>
                    <strong><?= (int) $sectionCount ?></strong>
                </article>
                <?php if ($formattedUpdated !== ''): ?>
                    <article class="summary-card">
                        <span><?= htmlspecialchars($updatedLabel !== '' ? $updatedLabel : 'Updated') ?></span>
                        <strong><?= htmlspecialchars($formattedUpdated) ?></strong>
                    </article>
                <?php endif; ?>
                <article class="summary-card">
                    <span><?= htmlspecialchars($layoutLabel !== '' ? $layoutLabel : 'Layout') ?></span>
                    <strong><?= htmlspecialchars(ucfirst($contentWidth)) ?></strong>
                </article>
            </div>
        </header>

        <div class="legal-layout<?= $hasToc ? ' has-index' : '' ?>">
            <?php if ($hasToc): ?>
                <aside class="legal-index wow animate__fadeInUp" data-wow-delay="0.08s" data-wow-duration="0.88s" aria-label="<?= htmlspecialchars($tocTitle) ?>">
                    <span class="index-kicker"><?= htmlspecialchars($tocTitle) ?></span>
                    <nav class="index-list">
                        <?php foreach ($tocItems as $index => $item): ?>
                            <a href="#<?= htmlspecialchars($item['id']) ?>" class="index-link level-<?= (int) $item['level'] ?>">
                                <small><?= sprintf('%02d', $index + 1) ?></small>
                                <span><?= htmlspecialchars($item['text']) ?></span>
                            </a>
                        <?php endforeach; ?>
                    </nav>
                </aside>
            <?php endif; ?>

            <article class="legal-sheet wow animate__fadeInUp" data-wow-delay="0.12s" data-wow-duration="0.9s">
                <header class="sheet-head">
                    <span class="sheet-kicker"><?= htmlspecialchars($documentLabel) ?></span>
                    <?php if ($formattedUpdated !== ''): ?>
                        <span class="sheet-updated"><?= htmlspecialchars($updatedLabel !== '' ? $updatedLabel : 'Updated') ?>: <?= htmlspecialchars($formattedUpdated) ?></span>
                    <?php endif; ?>
                </header>

                <div class="sheet-content prose">
                    <?= $pageContent ?>
                </div>
            </article>
        </div>
    </div>
</section>

