{
    "$schema": "2.1.0",
    "template": "gin-rummy-carnival",
    "name": "Gin Rummy Carnival",
    "description": "High-contrast responsive Gin Rummy Game theme with modern motion accents and full tpmst-compatible data logic.",
    "version": "1.0.0",
    "regions": {
        "header": {
            "name": "Header Region",
            "name_en": "Header",
            "description": "Top area including logo and navigation",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "Content Region",
            "name_en": "Content",
            "description": "Main page content area",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "advantages", "games", "testimonials", "faq"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "Footer Region",
            "name_en": "Footer",
            "description": "Bottom area including links and legal notes",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "Header Navigation",
            "name_en": "Header Navigation",
            "description": "Sticky responsive navigation with animated light sweep effects",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "download_button"],
            "file": "header/nav.phtml"
        },
        "header-simple": {
            "name": "Simple Header",
            "name_en": "Simple Header",
            "description": "Compact header with editable logo content and gin palette styling",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 2,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "style"],
            "file": "header/simple.phtml"
        },
        "header-dark": {
            "name": "Dark Header",
            "name_en": "Dark Header",
            "description": "Alternative sticky header with navigation and CTA support",
            "region": "header",
            "category": "header",
            "type": "section",
            "sort_order": 3,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "config_groups": ["logo", "navigation", "button", "style"],
            "file": "header/dark.phtml"
        },
        "hero-slider": {
            "name": "Hero Section",
            "name_en": "Hero Section",
            "description": "Main hero area with tactical messaging and dual CTA",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["hero", "banner", "download_btn", "layout"],
            "file": "content/hero-slider.phtml"
        },
        "advantages": {
            "name": "Advantages",
            "name_en": "Advantages",
            "description": "Feature highlights with editable cards and icon support",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts"],
            "file": "content/advantages.phtml"
        },
        "games": {
            "name": "Games Showcase",
            "name_en": "Games Showcase",
            "description": "Dynamic game mode showcase with configurable cards",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts", "games"],
            "file": "content/games.phtml"
        },
        "slider": {
            "name": "Slider",
            "name_en": "Slider",
            "description": "Hero slider block compatible with existing slider config keys",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 35,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["slider"],
            "file": "content/slider.phtml"
        },
        "banner": {
            "name": "Banner",
            "name_en": "Banner",
            "description": "Static hero banner compatible with existing banner config keys",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 36,
            "compatible_styles": ["*"],
