            "description": "Expandable frequently asked questions block",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["display", "style", "texts"],
            "file": "content/faq.phtml"
        },
        "about-content": {
            "name": "About Content",
            "name_en": "About Content",
            "description": "About page narrative and brand positioning content",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 60,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/about-content.phtml"
        },
        "contact-content": {
            "name": "Contact Content",
