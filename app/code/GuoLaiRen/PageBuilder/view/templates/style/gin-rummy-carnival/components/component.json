            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 62,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "file": "content/legal-content.phtml"
        },
        "blog-list": {
            "name": "Blog List",
            "name_en": "Blog List",
            "description": "Blog listing page with feature story and side rail",
            "region": "content",
            "category": "content",
            "type": "section",
            "sort_order": 63,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
