    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

#<?= $componentId ?> .faq-badge {
    color: #071322;
    background: linear-gradient(130deg, rgba(101,255,191,0.96) 0%, rgba(255,205,114,0.92) 100%);
}

