    position: relative;
    overflow: hidden;
    padding: <?= (int) $sectionPadding ?>px 0;
    background:
        radial-gradient(860px 320px at 6% 0%, rgba(101, 255, 191, 0.16), transparent 66%),
        radial-gradient(840px 320px at 94% 12%, rgba(255, 111, 151, 0.18), transparent 64%),
        linear-gradient(142deg, #06101d 0%, <?= htmlspecialchars($bgColor) ?> 44%, #1b243d 100%);
}

