    background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, <?= htmlspecialchars($panelBgColor) ?> 100%);
    border: 1px solid <?= htmlspecialchars($cardBorderColor) ?>;
    box-shadow: 0 20px 42px rgba(3, 10, 22, 0.14);
    overflow: hidden;
