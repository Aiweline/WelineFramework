<?php
/**
 * @component_start
 * code: faq
 * name: FAQ
 * name_en: FAQ
 * description: Two-column internal accordion board
 * category: content
 * region: content
 * @component_end
 *
 * @fields_start
 *
 * group:display => 显示控制
 * display.show_section => 显示此区域:select:yes|yes,no
 * display.show_title => 显示标题:select:yes|yes,no
 * display.show_intro => 显示引导文案:select:yes|yes,no
 * display.first_open => 默认展开第一项:select:no|yes,no
 *
 * group:style => 样式配置
 * style.bg_color => 背景颜色:color:#0c1728
 * style.accent_color => 强调色:color:#ff6b2c
 * style.title_color => 标题颜色:color:#f5fbff
 * style.text_color => 正文颜色:color:#c1d1e0
 * style.panel_bg_color => 面板背景色:color:rgba(255,255,255,0.95)
 * style.card_border_color => 卡片边框色:color:rgba(41,208,255,0.18)
 * style.card_radius => 卡片圆角:number:24|px
 * style.section_padding => 区域内边距(PC端):number:80|px
 * style.section_padding_mobile => 区域内边距(移动端):number:52|px
 *
 * group:texts => 文本内容
 * texts.badge => 徽章文本:text:Quick Answers
 * texts.title => 区域标题:text:Frequently Asked Questions
 * texts.intro => 引导文案:textarea:Players usually want the same core answers first: how room flow changes, what can be edited later, and how the layout behaves on mobile.
 * texts.tag_1 => 标签1:text:Room Access
 * texts.tag_2 => 标签2:text:Gameplay Rhythm
 * texts.tag_3 => 标签3:text:Mobile UX
 * texts.faq_1_question => 问题1:text:What changes from one Gin Rummy room to another?
 * texts.faq_1_answer => 答案1:textarea:Core rules stay consistent, but room tempo, visual density, and queue speed can vary. That helps players choose a format matching their reaction style.
 * texts.faq_2_question => 问题2:text:Can these titles and descriptions be edited later?
 * texts.faq_2_answer => 答案2:textarea:Yes. Section title, intro, tags, room list, and every question-answer pair all follow component configuration values.
 * texts.faq_3_question => 问题3:text:Is the homepage still responsive on small screens?
 * texts.faq_3_answer => 答案3:textarea:Yes. The layout reorders for touch-first reading. Controls scale up, and room selectors remain horizontally scrollable where needed.
 * texts.faq_4_question => 问题4:text:Why are module backgrounds more contrasted in this theme?
 * texts.faq_4_answer => 答案4:textarea:Contrast improves scan speed. It makes each section feel intentional and prevents the page from becoming one long surface.
 * texts.faq_5_question => 问题5:text:
 * texts.faq_5_answer => 答案5:textarea:
 * texts.faq_6_question => 问题6:text:
 * texts.faq_6_answer => 答案6:textarea:
 *
 * @fields_end
 */

$componentId = 'grc-faq-' . uniqid();
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$config = array_merge($styleSettings, $componentConfig);

$getConfig = function ($key, $default = '') use ($config) {
    return isset($config[$key]) && $config[$key] !== '' ? $config[$key] : $default;
};

$display = $getConfig('display.show_section', $getConfig('faq.display', 'yes')) !== 'no';
if (!$display) {
    return;
}

$showTitle = $getConfig('display.show_title', 'yes') !== 'no';
$showIntro = $getConfig('display.show_intro', 'yes') !== 'no';
$firstOpen = $getConfig('display.first_open', 'no') === 'yes';

$bgColor = (string) $getConfig('style.bg_color', '#0c1728');
$accentColor = (string) $getConfig('style.accent_color', '#ff6b2c');
$titleColor = (string) $getConfig('style.title_color', '#f5fbff');
$textColor = (string) $getConfig('style.text_color', '#c1d1e0');
$panelBgColor = (string) $getConfig('style.panel_bg_color', 'rgba(255,255,255,0.95)');
$cardBorderColor = (string) $getConfig('style.card_border_color', 'rgba(41,208,255,0.18)');
$cardRadius = max(18, (int) $getConfig('style.card_radius', '24'));
$sectionPadding = max(48, (int) $getConfig('style.section_padding', '80'));
$sectionPaddingMobile = max(36, (int) $getConfig('style.section_padding_mobile', '52'));

$badgeText = (string) $getConfig('texts.badge', 'Quick Answers');
$defaultSectionTitle = 'Frequently Asked Questions';
$title = (string) $getConfig('texts.title', $getConfig('faq.title', $getConfig('texts.faq_title', $defaultSectionTitle)));
$intro = (string) $getConfig('texts.intro', 'Players usually want the same core answers first: how room flow changes, what can be edited later, and how the layout behaves on mobile.');

$tags = [];
for ($i = 1; $i <= 3; $i++) {
    $tag = trim((string) $getConfig("texts.tag_{$i}", ''));
    if ($tag !== '') {
        $tags[] = $tag;
    }
}

$defaults = [
    1 => ['question' => 'What changes from one Gin Rummy room to another?', 'answer' => 'Core rules stay consistent, but room tempo, visual density, and queue speed can vary. That helps players choose a format matching their reaction style.'],
    2 => ['question' => 'Can these titles and descriptions be edited later?', 'answer' => 'Yes. Section title, intro, tags, room list, and every question-answer pair all follow component configuration values.'],
    3 => ['question' => 'Is the homepage still responsive on small screens?', 'answer' => 'Yes. The layout reorders for touch-first reading. Controls scale up, and room selectors remain horizontally scrollable where needed.'],
    4 => ['question' => 'Why are module backgrounds more contrasted in this theme?', 'answer' => 'Contrast improves scan speed. It makes each section feel intentional and prevents the page from becoming one long surface.'],
    5 => ['question' => '', 'answer' => ''],
    6 => ['question' => '', 'answer' => ''],
];

$faqs = [];
for ($i = 1; $i <= 6; $i++) {
    $default = $defaults[$i];
    $question = trim((string) $getConfig("texts.faq_{$i}_question", $default['question']));
    $answer = trim((string) $getConfig("texts.faq_{$i}_answer", $default['answer']));
    if ($question === '' || $answer === '') {
        continue;
    }

    $faqs[] = [
        'order' => count($faqs),
        'no' => sprintf('%02d', count($faqs) + 1),
        'question' => $question,
        'answer' => $answer,
    ];
}

if (empty($faqs)) {
    return;
}

$splitIndex = (int) ceil(count($faqs) / 2);
$faqColumns = [
    array_slice($faqs, 0, $splitIndex),
    array_slice($faqs, $splitIndex),
];
$activeIndex = $firstOpen ? 0 : -1;
?>

<section id="<?= $componentId ?>" class="grc-faq" aria-labelledby="<?= $componentId ?>-title">
    <div class="faq-shell" id="faq">
        <div class="faq-grid">
            <header class="faq-intro-card wow animate__fadeInLeft" data-wow-duration="0.84s">
                <span class="faq-badge"><?= htmlspecialchars($badgeText) ?></span>
                <?php if ($showTitle): ?>
                    <h2 id="<?= $componentId ?>-title"><span><?= htmlspecialchars($title) ?></span></h2>
                <?php endif; ?>
                <?php if ($showIntro && $intro !== ''): ?>
                    <p><?= htmlspecialchars($intro) ?></p>
                <?php endif; ?>

                <?php if (!empty($tags)): ?>
                    <div class="faq-tags" aria-label="FAQ topics">
                        <?php foreach ($tags as $index => $tag): ?>
                            <span class="wow animate__zoomIn" data-wow-delay="<?= htmlspecialchars(number_format(0.1 + ($index * 0.05), 2)) ?>s" data-wow-duration="0.72s"><?= htmlspecialchars($tag) ?></span>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </header>

            <?php foreach ($faqColumns as $columnIndex => $column): ?>
                <div class="faq-stack faq-stack-<?= (int) ($columnIndex + 1) ?>" role="list">
                    <?php foreach ($column as $faq): ?>
                        <?php $isOpen = $faq['order'] === $activeIndex; ?>
                        <article class="faq-card wow <?= $columnIndex % 2 === 0 ? 'animate__fadeInUp' : 'animate__fadeInRight' ?><?= $isOpen ? ' is-open' : '' ?>" role="listitem" data-wow-delay="<?= htmlspecialchars(number_format(0.14 + ($faq['order'] * 0.06), 2)) ?>s" data-wow-duration="<?= htmlspecialchars(number_format(0.8 + (($faq['order'] % 3) * 0.05), 2)) ?>s">
                            <button type="button" class="faq-trigger" data-faq-trigger="<?= (int) $faq['order'] ?>" aria-expanded="<?= $isOpen ? 'true' : 'false' ?>" aria-controls="<?= $componentId ?>-answer-<?= (int) $faq['order'] ?>" id="<?= $componentId ?>-trigger-<?= (int) $faq['order'] ?>">
                                <span class="faq-topline">
                                    <span class="faq-no"><?= htmlspecialchars($faq['no']) ?></span>
                                    <span class="faq-icon" aria-hidden="true">+</span>
                                </span>
                                <span class="faq-question"><?= htmlspecialchars($faq['question']) ?></span>
                            </button>

                            <div class="faq-answer" id="<?= $componentId ?>-answer-<?= (int) $faq['order'] ?>" role="region" aria-labelledby="<?= $componentId ?>-trigger-<?= (int) $faq['order'] ?>" <?= $isOpen ? '' : 'hidden' ?>>
                                <p><?= nl2br(htmlspecialchars($faq['answer'])) ?></p>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>

<style>
