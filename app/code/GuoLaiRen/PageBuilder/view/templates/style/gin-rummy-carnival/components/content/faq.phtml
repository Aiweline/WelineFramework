        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 0.18rem;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
    }

    #<?= $componentId ?> .faq-tags::-webkit-scrollbar {
        display: none;
    }

    #<?= $componentId ?> .faq-tags span {
        scroll-snap-align: start;
