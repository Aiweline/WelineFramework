                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>
                    </aside>
                <?php endif; ?>

                <article class="reading-sheet wow animate__fadeInUp" data-wow-delay="0.12s" data-wow-duration="0.9s">
                    <div class="sheet-body prose">
                        <?= $articleContent ?>
                    </div>

                    <footer class="sheet-foot">
                        <a href="/blog" class="back-home"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
