                    </svg>
                </div>
                <h2><?= htmlspecialchars($notFoundTitle !== '' ? $notFoundTitle : 'Article Not Found') ?></h2>
                <p><?= htmlspecialchars($notFoundDesc !== '' ? $notFoundDesc : 'The article you are looking for does not exist or has been removed.') ?></p>
                <a href="/blog" class="back-home"><?= htmlspecialchars($backToBlogText !== '' ? $backToBlogText : 'Back to Blog') ?></a>
            </div>
        </div>
    </section>
<?php else: ?>
    <section id="<?= $componentId ?>" class="grc-blog-detail" aria-labelledby="<?= $componentId ?>-title">
        <div class="detail-suits" aria-hidden="true">
            <span class="detail-suit detail-suit-spade">&spades;</span>
            <span class="detail-suit detail-suit-club">&clubs;</span>
        </div>

        <div class="detail-shell">
            <nav class="detail-breadcrumb" aria-label="Breadcrumb">
                <a href="/"><?= htmlspecialchars($breadcrumbHomeText !== '' ? $breadcrumbHomeText : 'Home') ?></a>
                <span>/</span>
                <a href="/blog"><?= htmlspecialchars($breadcrumbBlogText !== '' ? $breadcrumbBlogText : 'Blog') ?></a>
                <span>/</span>
                <strong><?= htmlspecialchars(function_exists('mb_substr') ? mb_substr($currentPost['title'], 0, 42) : substr($currentPost['title'], 0, 42)) ?><?= (function_exists('mb_strlen') ? mb_strlen($currentPost['title']) : strlen($currentPost['title'])) > 42 ? '...' : '' ?></strong>
            </nav>

            <header class="article-mast<?= $showCover && !empty($currentPost['cover_image']) ? ' has-cover' : '' ?> wow animate__fadeInUp" data-wow-duration="0.84s">
                <div class="mast-copy">
                    <?php if (!empty($currentPost['category_name'])): ?>
                        <span class="mast-chip"><?= htmlspecialchars($currentPost['category_name']) ?></span>
                    <?php endif; ?>

                    <h1 id="<?= $componentId ?>-title"><?= htmlspecialchars($currentPost['title']) ?></h1>

                    <div class="mast-meta">
                        <?php if ($showDate && !empty($currentPost['published_at'])): ?>
                            <span><?= date('F d, Y', strtotime($currentPost['published_at'])) ?></span>
                        <?php endif; ?>
                        <?php if ($showAuthor && !empty($currentPost['author'])): ?>
