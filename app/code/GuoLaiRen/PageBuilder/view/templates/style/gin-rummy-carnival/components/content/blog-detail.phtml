                                        <a href="#<?= htmlspecialchars($item['id']) ?>" class="jump-link level-<?= (int) $item['level'] ?>">
                                            <small><?= sprintf('%02d', $index + 1) ?></small>
                                            <span><?= htmlspecialchars($item['label']) ?></span>
                                        </a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showTags && !empty($tags)): ?>
