                                <span class="tool-kicker"><?= htmlspecialchars($tagsTitle !== '' ? $tagsTitle : 'Tags') ?></span>
                                <div class="tag-list">
                                    <?php foreach ($tags as $tag): ?>
                                        <a href="/blog/tag/<?= urlencode($tag) ?>" class="tag-chip">#<?= htmlspecialchars($tag) ?></a>
                                    <?php endforeach; ?>
                                </div>
                            </section>
                        <?php endif; ?>

                        <?php if ($showShare): ?>
                            <section class="tool-card">
                                <span class="tool-kicker"><?= htmlspecialchars($shareTitle !== '' ? $shareTitle : 'Share') ?></span>
                                <div class="share-row">
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=<?= $shareUrl ?>" target="_blank" rel="noopener" class="share-btn" title="<?= htmlspecialchars($shareFacebookTitle !== '' ? $shareFacebookTitle : 'Share on Facebook') ?>"><?= htmlspecialchars($shareFacebookText !== '' ? $shareFacebookText : 'FB') ?></a>
                                    <a href="https://twitter.com/intent/tweet?url=<?= $shareUrl ?>&text=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="<?= htmlspecialchars($shareTwitterTitle !== '' ? $shareTwitterTitle : 'Share on X') ?>"><?= htmlspecialchars($shareTwitterText !== '' ? $shareTwitterText : 'X') ?></a>
                                    <a href="https://www.linkedin.com/shareArticle?mini=true&url=<?= $shareUrl ?>&title=<?= $shareTitle ?>" target="_blank" rel="noopener" class="share-btn" title="<?= htmlspecialchars($shareLinkedinTitle !== '' ? $shareLinkedinTitle : 'Share on LinkedIn') ?>"><?= htmlspecialchars($shareLinkedinText !== '' ? $shareLinkedinText : 'IN') ?></a>
