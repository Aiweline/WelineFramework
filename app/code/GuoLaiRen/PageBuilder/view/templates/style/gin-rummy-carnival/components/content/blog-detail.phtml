$style = $this->getData('style') ?: $this->getData('style_settings') ?: [];
$componentConfig = $this->getData('component_config') ?: [];
$currentPost = $this->getData('current_post') ?: [];
$relatedPosts = $this->getData('related_posts') ?: [];
$blogCategories = $this->getData('blog_categories') ?: [];
$recentPosts = $this->getData('recent_posts') ?: [];
$componentId = 'grc-blog-detail-' . uniqid();

$getConfig = function ($key, $default = '') use ($style, $componentConfig) {
    if (isset($componentConfig[$key]) && $componentConfig[$key] !== '') {
        return $componentConfig[$key];
    }
    return $style[$key] ?? $default;
};

$showSidebar = $getConfig('blog.show_sidebar', 'yes') === 'yes';
$showCover = $getConfig('blog.show_cover', 'yes') === 'yes';
$showAuthor = $getConfig('blog.show_author', 'yes') === 'yes';
$showDate = $getConfig('blog.show_date', 'yes') === 'yes';
$showTags = $getConfig('blog.show_tags', 'yes') === 'yes';
$showShare = $getConfig('blog.show_share', 'yes') === 'yes';
$showRelated = $getConfig('blog.show_related', 'yes') === 'yes';
$relatedCount = (int) $getConfig('blog.related_count', 3);
if ($relatedCount <= 0) {
    $relatedCount = 3;
}
$notFoundTitle = trim((string) $getConfig('blog.not_found_title', 'Article Not Found'));
$notFoundDesc = trim((string) $getConfig('blog.not_found_desc', 'The article you are looking for does not exist or has been removed.'));
$backToBlogText = trim((string) $getConfig('blog.back_to_blog_text', 'Back to Blog'));
$breadcrumbHomeText = trim((string) $getConfig('blog.breadcrumb_home_text', 'Home'));
$breadcrumbBlogText = trim((string) $getConfig('blog.breadcrumb_blog_text', 'Blog'));
$viewsSuffix = trim((string) $getConfig('blog.views_suffix', 'views'));
$jumpTitle = trim((string) $getConfig('blog.jump_title', 'Jump Within'));
$tagsTitle = trim((string) $getConfig('blog.tags_title', 'Tags'));
$shareTitle = trim((string) $getConfig('blog.share_title', 'Share'));
$shareFacebookTitle = trim((string) $getConfig('blog.share_facebook_title', 'Share on Facebook'));
$shareTwitterTitle = trim((string) $getConfig('blog.share_twitter_title', 'Share on X'));
$shareLinkedinTitle = trim((string) $getConfig('blog.share_linkedin_title', 'Share on LinkedIn'));
$shareCopyTitle = trim((string) $getConfig('blog.share_copy_title', 'Copy Link'));
$shareFacebookText = trim((string) $getConfig('blog.share_facebook_text', 'FB'));
$shareTwitterText = trim((string) $getConfig('blog.share_twitter_text', 'X'));
$shareLinkedinText = trim((string) $getConfig('blog.share_linkedin_text', 'IN'));
$shareCopyText = trim((string) $getConfig('blog.share_copy_text', 'CP'));
$copySuccessText = trim((string) $getConfig('blog.copy_success_text', 'Link copied to clipboard!'));
$categoriesTitle = trim((string) $getConfig('blog.categories_title', 'Categories'));
$recentPostsTitle = trim((string) $getConfig('blog.recent_posts_title', 'Recent Posts'));
$relatedTitle = trim((string) $getConfig('blog.related_title', 'Related Articles'));
$relatedKicker = trim((string) $getConfig('blog.related_kicker', 'Continue Reading'));

$primaryColor = $getConfig('color_scheme.primary', '#1eb980');
$secondaryColor = $getConfig('color_scheme.secondary', '#f2a93b');
$bgColor = $getConfig('color_scheme.background', '#0b1525');
$textColor = $getConfig('color_scheme.text', '#f8fafc');
$pokerBg = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/gin-rummy-carnival/asset/img/poker-header-bg.svg');

$tags = [];
if (!empty($currentPost['tags'])) {
    $tags = is_array($currentPost['tags']) ? $currentPost['tags'] : explode(',', $currentPost['tags']);
    $tags = array_values(array_filter(array_map('trim', $tags), static function ($item) {
        return $item !== '';
    }));
}

$articleContent = (string) ($currentPost['content'] ?? '');
$jumpLinks = [];
if ($articleContent !== '') {
    $headingIndex = 0;
    $articleContent = preg_replace_callback('/<h([23])([^>]*)>(.*?)<\/h\1>/is', static function ($matches) use (&$jumpLinks, &$headingIndex) {
        $text = trim(strip_tags($matches[3]));
        if ($text === '') {
            return $matches[0];
        }

        $slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $text));
        $slug = trim($slug, '-');
        if ($slug === '') {
            $slug = 'article-section';
        }

        $id = $slug . '-' . (++$headingIndex);
        $jumpLinks[] = [
            'id' => $id,
            'label' => $text,
            'level' => (int) $matches[1],
        ];

        return '<h' . $matches[1] . $matches[2] . ' id="' . htmlspecialchars($id, ENT_QUOTES, 'UTF-8') . '">' . $matches[3] . '</h' . $matches[1] . '>';
    }, $articleContent);
}

$hasRail = $showSidebar || ($showShare && !empty($currentPost)) || ($showTags && !empty($tags)) || !empty($jumpLinks);
$shareUrl = urlencode((string) ($_SERVER['REQUEST_URI'] ?? ''));
$shareTitle = urlencode((string) ($currentPost['title'] ?? ''));
?>

