$marginTop = (int) $getConfig('layout.margin_top', '-72');
$imgMarginTop = (int) $getConfig('layout.img_margin_top', '0');

$wordTrim = static function ($value, $limit = 3) {
    $value = trim((string) $value);
    if ($value === '') {
        return '';
    }

    $words = preg_split('/\s+/', preg_replace('/[^\p{L}\p{N}]+/u', ' ', $value)) ?: [];
    $words = array_values(array_filter($words, static function ($item) {
        return $item !== '';
    }));

    return trim(implode(' ', array_slice($words, 0, max(1, (int) $limit))));
};

$splitHeadline = static function ($value) {
    $value = trim((string) $value);
    if ($value === '') {
        return [];
    }

    $words = preg_split('/\s+/', $value) ?: [];
    $words = array_values(array_filter($words, static function ($item) {
        return $item !== '';
    }));

    $count = count($words);
    if ($count <= 3) {
        return [$value];
    }

    $pivot = (int) ceil($count / 2);
    if ($count >= 6) {
        $pivot = min(4, max(2, $pivot));
    }

    $first = implode(' ', array_slice($words, 0, $pivot));
    $second = implode(' ', array_slice($words, $pivot));

    return array_values(array_filter([$first, $second]));
};

$headlineCards = $splitHeadline($title);
if (empty($headlineCards)) {
    $headlineCards = ['Gin Rummy Carnival'];
}

$heroTags = [];
foreach ([$wordTrim($title, 3), $wordTrim($subtitle, 4), $wordTrim($subtitle, 8)] as $item) {
    $item = trim((string) $item);
    if ($item !== '') {
        $heroTags[] = $item;
    }
}
$heroTags = array_values(array_unique($heroTags));
$heroTags = array_slice($heroTags, 0, 4);
