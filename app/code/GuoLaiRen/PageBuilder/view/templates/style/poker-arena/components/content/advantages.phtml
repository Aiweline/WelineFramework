<?php
/**
 * PokerArena - Advantages Section Component
 * 
 * 6 advantages grid with icons
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Why PokerArena
 * content.title => 标题:text:The PokerArena Advantage
 * content.description => 描述:textarea:Industry-leading security, instant payouts, and a platform built by poker players, for poker players.
 * 
 * group:advantages => 优势列表
 * advantages.items => 优势列表:textarea:🔒|Certified Random Shuffles|Our RNG is independently certified by GLI and eCOGRA, ensuring every hand is truly random and fair.\r\n💰|Instant Cashouts|Withdraw your winnings instantly to your preferred payment method. No delays, no hassle.\r\n🏆|Live Tournaments|Compete in daily, weekly, and seasonal tournaments with massive guaranteed prize pools.\r\n🖥️|Multi-Table Support|Play up to 24 tables simultaneously with our optimized multi-tabling interface.\r\n📊|Advanced Statistics|Track your performance with detailed hand histories, win rates, and session analytics.\r\n💎|VIP Rewards Program|Earn points on every hand and unlock exclusive rewards, bonuses, and tournament entries.|格式：图标|标题|描述
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['advantages_bg'] ?? '#0a1f10';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimary = $colors['accent_primary'] ?? '#047857';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$accentSecondaryLight = $colors['accent_secondary_light'] ?? '#fbbf24';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(4, 120, 87, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(4, 120, 87, 0.3)';
$badgeText = $colors['badge_text'] ?? '#10b981';

$badge = $config['content.badge'] ?? 'Why PokerArena';
$title = $config['content.title'] ?? 'The PokerArena Advantage';
$description = $config['content.description'] ?? 'Industry-leading security, instant payouts, and a platform built by poker players, for poker players.';

$advRaw = $config['advantages.items'] ?? "🔒|Certified Random Shuffles|Our RNG is independently certified by GLI and eCOGRA, ensuring every hand is truly random and fair.\n💰|Instant Cashouts|Withdraw your winnings instantly to your preferred payment method. No delays, no hassle.\n🏆|Live Tournaments|Compete in daily, weekly, and seasonal tournaments with massive guaranteed prize pools.\n🖥️|Multi-Table Support|Play up to 24 tables simultaneously with our optimized multi-tabling interface.\n📊|Advanced Statistics|Track your performance with detailed hand histories, win rates, and session analytics.\n💎|VIP Rewards Program|Earn points on every hand and unlock exclusive rewards, bonuses, and tournament entries.";

$advantages = [];
foreach (preg_split('/[\r\n]+/', $advRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 3);
    if (count($parts) >= 2) {
        $advantages[] = [
            'icon' => trim($parts[0] ?? ''),
            'title' => trim($parts[1] ?? ''),
            'desc' => trim($parts[2] ?? ''),
        ];
    }
}

$instanceId = 'pa-adv-' . uniqid();
?>

<section class="pa-advantages" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .pa-adv-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
        #<?= $instanceId ?> .pa-adv-header { text-align: center; margin-bottom: 60px; }
        
        #<?= $instanceId ?> .pa-adv-badge {
            display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px;
            background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>;
            border-radius: 50px; font-size: 0.85rem; font-weight: 600;
            color: <?= $badgeText ?>; margin-bottom: 20px;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        
        #<?= $instanceId ?> .pa-adv-title {
            font-size: 2.75rem; font-weight: 800; color: <?= $textPrimary ?>; margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .pa-adv-subtitle {
            font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; line-height: 1.7;
        }
        
        #<?= $instanceId ?> .pa-adv-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
        }
        
        #<?= $instanceId ?> .pa-adv-card {
            background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>;
            border-radius: 16px; padding: 32px; transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .pa-adv-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(4, 120, 87, 0.3);
            transform: translateY(-4px);
        }
        
        #<?= $instanceId ?> .pa-adv-icon {
            font-size: 2.5rem; margin-bottom: 16px; line-height: 1;
        }
        
        #<?= $instanceId ?> .pa-adv-card-title {
            font-size: 1.15rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 10px;
        }
        
        #<?= $instanceId ?> .pa-adv-card-desc {
            font-size: 0.9rem; color: <?= $textMuted ?>; line-height: 1.7;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .pa-adv-grid { grid-template-columns: repeat(2, 1fr); }
            #<?= $instanceId ?> .pa-adv-title { font-size: 2rem; }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> .pa-adv-grid { grid-template-columns: 1fr; }
            #<?= $instanceId ?> { padding: 60px 0; }
            #<?= $instanceId ?> .pa-adv-title { font-size: 1.75rem; }
        }
    </style>
    
    <div class="pa-adv-container">
        <div class="pa-adv-header">
            <div class="pa-adv-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="pa-adv-title"><?= htmlspecialchars($title) ?></h2>
            <p class="pa-adv-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="pa-adv-grid">
            <?php foreach ($advantages as $adv): ?>
            <div class="pa-adv-card">
                <div class="pa-adv-icon"><?= htmlspecialchars($adv['icon']) ?></div>
                <h3 class="pa-adv-card-title"><?= htmlspecialchars($adv['title']) ?></h3>
                <p class="pa-adv-card-desc"><?= htmlspecialchars($adv['desc']) ?></p>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
