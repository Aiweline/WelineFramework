        </div>
        
        <div class="pa-download-visual">
            <div class="pa-download-phone">
                <div class="pa-download-phone-notch"></div>
                <div class="pa-download-phone-logo">
                    <svg viewBox="0 0 24 24"><path d="M12 2C9.24 2 7 4.24 7 7c0 1.77.94 3.41 2.47 4.3L12 24l2.53-12.7C16.06 10.41 17 8.77 17 7c0-2.76-2.24-5-5-5z"/></svg>
                </div>
                <div class="pa-download-phone-text">PokerArena</div>
                <div class="pa-download-phone-sub">Play Anywhere</div>
            </div>
        </div>
    </div>
