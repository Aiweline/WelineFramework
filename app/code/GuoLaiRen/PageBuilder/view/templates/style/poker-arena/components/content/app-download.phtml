<?php
/**
 * PokerArena - App Download Section Component
 * 
 * Download section with phone mockup decoration and features
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Mobile App
 * content.title => 标题:text:Play Anywhere, Anytime
 * content.description => 描述:textarea:Download the PokerArena app for the ultimate mobile poker experience. Lightning-fast gameplay, instant notifications, and seamless multi-tabling on the go.
 * 
 * group:features => 功能亮点
 * features.items => 功能列表:textarea:Low Latency|Sub-100ms response for real-time gameplay\r\nHand History|Complete hand replay and analysis tools\r\nQuick Sit|Join cash games instantly with one tap\r\nPush Alerts|Tournament start and blind level notifications|格式：标题|描述
 * 
 * group:download => 下载按钮
 * download.android_text => Android按钮文字:text:Download for Android
 * download.android_url => Android下载链接:text:#android
 * download.ios_text => iOS按钮文字:text:Download for iOS
 * download.ios_url => iOS下载链接:text:#ios
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['download_bg'] ?? 'linear-gradient(135deg, #0d2914 0%, #103318 100%)';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimary = $colors['accent_primary'] ?? '#047857';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$accentSecondaryLight = $colors['accent_secondary_light'] ?? '#fbbf24';
$buttonGoldBg = $colors['button_gold_bg'] ?? 'linear-gradient(135deg, #d97706 0%, #f59e0b 100%)';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #047857 0%, #d97706 100%)';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';

$badge = $config['content.badge'] ?? 'Mobile App';
$title = $config['content.title'] ?? 'Play Anywhere, Anytime';
$description = $config['content.description'] ?? 'Download the PokerArena app for the ultimate mobile poker experience. Lightning-fast gameplay, instant notifications, and seamless multi-tabling on the go.';

$featuresRaw = $config['features.items'] ?? "Low Latency|Sub-100ms response for real-time gameplay\nHand History|Complete hand replay and analysis tools\nQuick Sit|Join cash games instantly with one tap\nPush Alerts|Tournament start and blind level notifications";
$features = [];
foreach (preg_split('/[\r\n]+/', $featuresRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 2);
    if (!empty(trim($parts[0] ?? ''))) {
        $features[] = ['title' => trim($parts[0]), 'desc' => trim($parts[1] ?? '')];
    }
}

$androidText = $config['download.android_text'] ?? 'Download for Android';
$androidUrl = $config['download.android_url'] ?? '#android';
$iosText = $config['download.ios_text'] ?? 'Download for iOS';
$iosUrl = $config['download.ios_url'] ?? '#ios';

$androidHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$androidUrl);
$iosHref = \GuoLaiRen\PageBuilder\Helper\PageHelper::resolveAppDownloadUrl((string)$iosUrl);
$androidRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($androidHref, 'android');
$iosRef = \GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::register($iosHref, 'ios');

$instanceId = 'pa-download-' . uniqid();
?>

<section class="pa-download" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?> .pa-download-container {
            max-width: 1200px; margin: 0 auto; padding: 0 20px;
            display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
        }
        
        #<?= $instanceId ?> .pa-download-badge {
            display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px;
            background: rgba(217, 119, 6, 0.15); border: 1px solid rgba(217, 119, 6, 0.3);
            border-radius: 50px; font-size: 0.85rem; font-weight: 600;
            color: <?= $accentSecondaryLight ?>; margin-bottom: 20px;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        
        #<?= $instanceId ?> .pa-download-title {
            font-size: 2.75rem; font-weight: 800; color: <?= $textPrimary ?>;
            margin-bottom: 20px; line-height: 1.15;
        }
        
        #<?= $instanceId ?> .pa-download-desc {
            font-size: 1.1rem; color: <?= $textSecondary ?>; line-height: 1.7; margin-bottom: 32px;
        }
        
        #<?= $instanceId ?> .pa-download-features {
            display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 40px;
        }
        
        #<?= $instanceId ?> .pa-download-feature {
            padding: 16px; background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>;
            border-radius: 12px; transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .pa-download-feature:hover {
            border-color: rgba(4, 120, 87, 0.3);
        }
        
        #<?= $instanceId ?> .pa-download-feature-title {
            font-size: 0.95rem; font-weight: 700; color: <?= $accentSecondaryLight ?>; margin-bottom: 4px;
        }
        
        #<?= $instanceId ?> .pa-download-feature-desc {
            font-size: 0.8rem; color: <?= $textMuted ?>; line-height: 1.5;
        }
        
        #<?= $instanceId ?> .pa-download-buttons { display: flex; gap: 16px; flex-wrap: wrap; }
        
        #<?= $instanceId ?> .pa-download-btn-android {
            display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px;
            background: <?= $buttonGoldBg ?>; color: #422006; font-size: 1rem; font-weight: 700;
            border-radius: 12px; transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(217, 119, 6, 0.3); text-transform: uppercase; letter-spacing: 0.03em;
        }
        
        #<?= $instanceId ?> .pa-download-btn-android:hover {
            transform: translateY(-3px); box-shadow: 0 8px 30px rgba(217, 119, 6, 0.5);
        }
        
        #<?= $instanceId ?> .pa-download-btn-ios {
            display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px;
            background: transparent; color: <?= $accentPrimaryLight ?>; font-size: 1rem; font-weight: 700;
            border: 2px solid <?= $accentPrimary ?>; border-radius: 12px; transition: all 0.3s ease;
            text-transform: uppercase; letter-spacing: 0.03em;
        }
        
        #<?= $instanceId ?> .pa-download-btn-ios:hover {
            background: rgba(4, 120, 87, 0.15); border-color: <?= $accentPrimaryLight ?>;
        }
        
        /* Phone mockup */
        #<?= $instanceId ?> .pa-download-visual {
            display: flex; justify-content: center; align-items: center; position: relative;
        }
        
        #<?= $instanceId ?> .pa-download-phone {
            width: 280px; height: 560px;
            background: linear-gradient(180deg, #0d2914 0%, #060d08 100%);
            border-radius: 36px; border: 3px solid rgba(134, 239, 172, 0.15);
            position: relative; overflow: hidden;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5), 0 0 60px rgba(4, 120, 87, 0.15);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
        }
        
        #<?= $instanceId ?> .pa-download-phone-notch {
            position: absolute; top: 8px; width: 120px; height: 28px;
            background: #040a06; border-radius: 0 0 16px 16px;
        }
        
        #<?= $instanceId ?> .pa-download-phone-logo {
            width: 80px; height: 80px;
            background: <?= $buttonPrimaryBg ?>;
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center; margin-bottom: 16px;
            box-shadow: 0 8px 30px rgba(4, 120, 87, 0.4);
        }
        
        #<?= $instanceId ?> .pa-download-phone-logo svg { width: 40px; height: 40px; fill: #ffffff; }
        
        #<?= $instanceId ?> .pa-download-phone-text {
            font-size: 1.3rem; font-weight: 800; color: <?= $textPrimary ?>; letter-spacing: -0.02em;
        }
        
        #<?= $instanceId ?> .pa-download-phone-sub {
            font-size: 0.8rem; color: <?= $textMuted ?>; margin-top: 4px;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .pa-download-container { grid-template-columns: 1fr; }
            #<?= $instanceId ?> .pa-download-visual { order: -1; }
            #<?= $instanceId ?> .pa-download-title { font-size: 2rem; }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> { padding: 60px 0; }
            #<?= $instanceId ?> .pa-download-features { grid-template-columns: 1fr; }
            #<?= $instanceId ?> .pa-download-buttons { flex-direction: column; }
            #<?= $instanceId ?> .pa-download-btn-android,
            #<?= $instanceId ?> .pa-download-btn-ios { width: 100%; justify-content: center; }
            #<?= $instanceId ?> .pa-download-phone { width: 220px; height: 440px; }
        }
    </style>
    <div class="pa-download-container">
        <div class="pa-download-content">
            <div class="pa-download-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="pa-download-title"><?= htmlspecialchars($title) ?></h2>
            <p class="pa-download-desc"><?= htmlspecialchars($description) ?></p>
            
            <div class="pa-download-features">
                <?php foreach ($features as $feat): ?>
                <div class="pa-download-feature">
                    <div class="pa-download-feature-title"><?= htmlspecialchars($feat['title']) ?></div>
                    <div class="pa-download-feature-desc"><?= htmlspecialchars($feat['desc']) ?></div>
                </div>
                <?php endforeach; ?>
            </div>
            
            <div class="pa-download-buttons">
                <a role="button" tabindex="0" class="pa-download-btn-android" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($androidRef)) ?>" data-glr-ref="<?= htmlspecialchars($androidRef) ?>">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
                    <?= htmlspecialchars($androidText) ?>
                </a>
                <a role="button" tabindex="0" class="pa-download-btn-ios" href="<?= htmlspecialchars(\GuoLaiRen\PageBuilder\Helper\GlrDownloadRegistry::codeHref($iosRef)) ?>" data-glr-ref="<?= htmlspecialchars($iosRef) ?>">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83"/></svg>
                    <?= htmlspecialchars($iosText) ?>
                </a>
