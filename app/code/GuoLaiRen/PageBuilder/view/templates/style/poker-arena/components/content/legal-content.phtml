<?php
/**
 * PokerArena - Legal Content Component
 * 
 * Generic legal document display for privacy, terms, cookies, refund, etc.
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:layout => 布局设置
 * layout.show_toc => 显示目录:select:yes|yes,no
 * layout.show_last_updated => 显示更新时间:select:yes|yes,no
 * layout.content_width => 内容宽度:select:narrow|narrow,medium,wide
 * 
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['section_bg_1'] ?? '#071209';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';

$showToc = ($config['layout.show_toc'] ?? 'yes') !== 'no';
$showLastUpdated = ($config['layout.show_last_updated'] ?? 'yes') !== 'no';
$contentWidth = $config['layout.content_width'] ?? 'narrow';
$maxWidth = $contentWidth === 'wide' ? '1000px' : ($contentWidth === 'medium' ? '800px' : '700px');

$page = $this->getData('page');
$pageTitle = $page ? ($page->getData('title') ?? 'Legal Document') : 'Legal Document';
$pageContent = $page ? ($page->getData('content') ?? '') : '';
$lastUpdated = $page ? ($page->getData('updated_at') ?? '') : '';

$instanceId = 'pa-legal-' . uniqid();
?>

<section class="pa-legal" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 60px 0 100px; }
        #<?= $instanceId ?> .pa-legal-container { max-width: <?= $maxWidth ?>; margin: 0 auto; padding: 0 20px; }
        
        #<?= $instanceId ?> .pa-legal-header { margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid <?= $borderLight ?>; }
        #<?= $instanceId ?> .pa-legal-title { font-size: 2.5rem; font-weight: 800; color: <?= $textPrimary ?>; margin-bottom: 8px; }
        #<?= $instanceId ?> .pa-legal-updated { font-size: 0.9rem; color: <?= $textMuted ?>; }
        
        #<?= $instanceId ?> .pa-legal-content { font-size: 1rem; color: <?= $textSecondary ?>; line-height: 1.8; }
        #<?= $instanceId ?> .pa-legal-content h2 { font-size: 1.5rem; font-weight: 700; color: <?= $textPrimary ?>; margin: 40px 0 16px; }
        #<?= $instanceId ?> .pa-legal-content h3 { font-size: 1.25rem; font-weight: 700; color: <?= $textPrimary ?>; margin: 32px 0 12px; }
        #<?= $instanceId ?> .pa-legal-content p { margin-bottom: 16px; }
        #<?= $instanceId ?> .pa-legal-content a { color: <?= $accentPrimaryLight ?>; text-decoration: underline; }
        #<?= $instanceId ?> .pa-legal-content ul { margin: 16px 0; padding-left: 24px; }
        #<?= $instanceId ?> .pa-legal-content li { margin-bottom: 8px; list-style: disc; }
        
        @media (max-width: 768px) { #<?= $instanceId ?> .pa-legal-title { font-size: 1.75rem; } }
    </style>
    
    <div class="pa-legal-container">
        <div class="pa-legal-header">
            <h1 class="pa-legal-title"><?= htmlspecialchars($pageTitle) ?></h1>
            <?php if ($showLastUpdated && $lastUpdated): ?>
            <div class="pa-legal-updated">Last updated: <?= htmlspecialchars($lastUpdated) ?></div>
            <?php endif; ?>
        </div>
        
        <div class="pa-legal-content">
            <?= $pageContent ?>
        </div>
    </div>
</section>
