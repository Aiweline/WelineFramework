<?php
/**
 * PokerArena - Contact Content Component
 * 
 * Contact form + support info
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Get in Touch
 * content.title => 标题:text:Contact Us
 * content.description => 描述:textarea:Have questions? Our support team is available 24/7 to help with anything you need.
 * 
 * group:contact => 联系方式
 * contact.email => 支持邮箱:text:support@pokerarena.com
 * contact.live_chat => 在线客服:text:Available 24/7
 * contact.response_time => 响应时间:text:Under 2 hours
 * 
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$sectionBg = $colors['contact_bg'] ?? '#0a1f10';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimary = $colors['accent_primary'] ?? '#047857';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$accentSecondaryLight = $colors['accent_secondary_light'] ?? '#fbbf24';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';
$formBg = $colors['form_bg'] ?? 'rgba(255, 255, 255, 0.05)';
$formBorder = $colors['form_border'] ?? 'rgba(134, 239, 172, 0.15)';
$formBorderFocus = $colors['form_border_focus'] ?? '#047857';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #047857 0%, #d97706 100%)';

$badge = $config['content.badge'] ?? 'Get in Touch';
$title = $config['content.title'] ?? 'Contact Us';
$description = $config['content.description'] ?? 'Have questions? Our support team is available 24/7 to help with anything you need.';
$email = $config['contact.email'] ?? 'support@pokerarena.com';
$liveChat = $config['contact.live_chat'] ?? 'Available 24/7';
$responseTime = $config['contact.response_time'] ?? 'Under 2 hours';

$instanceId = 'pa-contact-' . uniqid();
?>

<section class="pa-contact" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> { background: <?= $sectionBg ?>; padding: 80px 0 100px; }
        #<?= $instanceId ?> .pa-contact-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .pa-contact-header { text-align: center; margin-bottom: 60px; }
        
        #<?= $instanceId ?> .pa-contact-badge {
            display: inline-flex; padding: 8px 18px;
            background: rgba(4, 120, 87, 0.15); border: 1px solid rgba(4, 120, 87, 0.3);
            border-radius: 50px; font-size: 0.85rem; font-weight: 600;
            color: <?= $accentPrimaryLight ?>; margin-bottom: 20px; text-transform: uppercase;
        }
        
        #<?= $instanceId ?> .pa-contact-title { font-size: 2.75rem; font-weight: 800; color: <?= $textPrimary ?>; margin-bottom: 16px; }
        #<?= $instanceId ?> .pa-contact-desc { font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; }
        
        #<?= $instanceId ?> .pa-contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        
        #<?= $instanceId ?> .pa-contact-form-card {
            background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>;
            border-radius: 20px; padding: 36px;
        }
        
        #<?= $instanceId ?> .pa-contact-form-title { font-size: 1.3rem; font-weight: 700; color: <?= $textPrimary ?>; margin-bottom: 24px; }
        
        #<?= $instanceId ?> .pa-contact-field { margin-bottom: 20px; }
        #<?= $instanceId ?> .pa-contact-label { display: block; font-size: 0.85rem; font-weight: 600; color: <?= $textSecondary ?>; margin-bottom: 8px; }
        
        #<?= $instanceId ?> .pa-contact-input,
        #<?= $instanceId ?> .pa-contact-textarea {
            width: 100%; padding: 14px 16px; background: <?= $formBg ?>;
            border: 1px solid <?= $formBorder ?>; border-radius: 10px;
            color: <?= $textPrimary ?>; font-size: 0.95rem;
            font-family: inherit; transition: border-color 0.3s ease;
        }
        
        #<?= $instanceId ?> .pa-contact-input:focus,
        #<?= $instanceId ?> .pa-contact-textarea:focus {
            outline: none; border-color: <?= $formBorderFocus ?>;
        }
        
        #<?= $instanceId ?> .pa-contact-textarea { min-height: 120px; resize: vertical; }
        
        #<?= $instanceId ?> .pa-contact-submit {
            display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px;
            background: <?= $buttonPrimaryBg ?>; color: #ffffff;
            font-size: 1rem; font-weight: 700; border-radius: 12px;
            transition: all 0.3s ease; cursor: pointer; border: none;
            text-transform: uppercase; letter-spacing: 0.03em; width: 100%;
            justify-content: center;
        }
        
        #<?= $instanceId ?> .pa-contact-submit:hover {
            transform: translateY(-2px); box-shadow: 0 6px 20px rgba(4, 120, 87, 0.4);
        }
        
        #<?= $instanceId ?> .pa-contact-info { display: flex; flex-direction: column; gap: 24px; }
        
        #<?= $instanceId ?> .pa-contact-info-card {
            background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>;
            border-radius: 16px; padding: 28px; transition: all 0.3s ease;
        }
        #<?= $instanceId ?> .pa-contact-info-card:hover { border-color: rgba(4, 120, 87, 0.3); }
        #<?= $instanceId ?> .pa-contact-info-label { font-size: 0.85rem; color: <?= $textMuted ?>; margin-bottom: 8px; text-transform: uppercase; font-weight: 600; }
        #<?= $instanceId ?> .pa-contact-info-value { font-size: 1.1rem; font-weight: 700; color: <?= $textPrimary ?>; }
        #<?= $instanceId ?> .pa-contact-info-value a { color: <?= $accentSecondaryLight ?>; }
        
        @media (max-width: 992px) { #<?= $instanceId ?> .pa-contact-grid { grid-template-columns: 1fr; } }
        @media (max-width: 576px) { #<?= $instanceId ?> .pa-contact-title { font-size: 2rem; } }
    </style>
    
    <div class="pa-contact-container">
        <div class="pa-contact-header">
            <div class="pa-contact-badge"><?= htmlspecialchars($badge) ?></div>
            <h1 class="pa-contact-title"><?= htmlspecialchars($title) ?></h1>
            <p class="pa-contact-desc"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="pa-contact-grid">
            <div class="pa-contact-form-card">
                <h3 class="pa-contact-form-title">Send us a Message</h3>
                <form>
                    <div class="pa-contact-field">
                        <label class="pa-contact-label">Your Name</label>
                        <input type="text" class="pa-contact-input" placeholder="John Doe">
                    </div>
                    <div class="pa-contact-field">
                        <label class="pa-contact-label">Email Address</label>
                        <input type="email" class="pa-contact-input" placeholder="john@example.com">
                    </div>
                    <div class="pa-contact-field">
                        <label class="pa-contact-label">Subject</label>
                        <input type="text" class="pa-contact-input" placeholder="How can we help?">
                    </div>
                    <div class="pa-contact-field">
                        <label class="pa-contact-label">Message</label>
                        <textarea class="pa-contact-textarea" placeholder="Tell us more..."></textarea>
                    </div>
                    <button type="submit" class="pa-contact-submit">Send Message</button>
                </form>
            </div>
            
            <div class="pa-contact-info">
                <div class="pa-contact-info-card">
                    <div class="pa-contact-info-label">Email Support</div>
                    <div class="pa-contact-info-value"><a href="mailto:<?= htmlspecialchars($email) ?>"><?= htmlspecialchars($email) ?></a></div>
                </div>
                <div class="pa-contact-info-card">
                    <div class="pa-contact-info-label">Live Chat</div>
                    <div class="pa-contact-info-value"><?= htmlspecialchars($liveChat) ?></div>
                </div>
                <div class="pa-contact-info-card">
                    <div class="pa-contact-info-label">Average Response Time</div>
                    <div class="pa-contact-info-value"><?= htmlspecialchars($responseTime) ?></div>
                </div>
                <div class="pa-contact-info-card">
                    <div class="pa-contact-info-label">Responsible Gaming</div>
                    <div class="pa-contact-info-value">Players must be 18+ to play. If you or someone you know has a gambling problem, please seek help.</div>
                </div>
            </div>
        </div>
    </div>
</section>
