<?php
/**
 * PokerArena - Testimonials Component
 * 
 * 3 player reviews with star ratings, poker alias, tournament wins
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:Player Stories
 * content.title => 标题:text:What Our Players Say
 * content.description => 描述:textarea:Join thousands of satisfied players who trust PokerArena for their online poker experience.
 * 
 * group:testimonials => 评价列表
 * testimonials.items => 评价列表:textarea:AceKing_Pro|5|The software is incredibly smooth. I've been playing poker online for 15 years and PokerArena has the best user experience by far. Multi-tabling is a dream.|MTT Champion 2024 • $250K+ Winnings\r\nRiverQueen88|5|Fast cashouts and amazing tournament structures. Won my first major tournament here and the payout was in my account within minutes!|Sit & Go Specialist • 10K+ Games Played\r\nBluffMaster_X|4|Great selection of games and stakes. The VIP program is genuinely rewarding. Only wish they had more Omaha Hi-Lo tables during off-peak hours.|High Stakes Regular • Diamond VIP|格式：昵称|星级|评语|标签
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['testimonials_bg'] ?? '#071209';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$accentSecondaryLight = $colors['accent_secondary_light'] ?? '#fbbf24';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';
$starFilled = $colors['star_filled'] ?? '#fbbf24';
$starEmpty = $colors['star_empty'] ?? 'rgba(251, 191, 36, 0.2)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(4, 120, 87, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(4, 120, 87, 0.3)';
$badgeText = $colors['badge_text'] ?? '#10b981';

$badge = $config['content.badge'] ?? 'Player Stories';
$title = $config['content.title'] ?? 'What Our Players Say';
$description = $config['content.description'] ?? 'Join thousands of satisfied players who trust PokerArena for their online poker experience.';

$testRaw = $config['testimonials.items'] ?? "AceKing_Pro|5|The software is incredibly smooth. I've been playing poker online for 15 years and PokerArena has the best user experience by far. Multi-tabling is a dream.|MTT Champion 2024 • \$250K+ Winnings\nRiverQueen88|5|Fast cashouts and amazing tournament structures. Won my first major tournament here and the payout was in my account within minutes!|Sit & Go Specialist • 10K+ Games Played\nBluffMaster_X|4|Great selection of games and stakes. The VIP program is genuinely rewarding. Only wish they had more Omaha Hi-Lo tables during off-peak hours.|High Stakes Regular • Diamond VIP";

$testimonials = [];
foreach (preg_split('/[\r\n]+/', $testRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line, 4);
    if (count($parts) >= 3) {
        $testimonials[] = [
            'name' => trim($parts[0] ?? ''),
            'stars' => intval(trim($parts[1] ?? '5')),
            'text' => trim($parts[2] ?? ''),
            'tag' => trim($parts[3] ?? ''),
        ];
    }
}

$instanceId = 'pa-test-' . uniqid();
?>

<section class="pa-testimonials" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .pa-test-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        #<?= $instanceId ?> .pa-test-header { text-align: center; margin-bottom: 60px; }
        
        #<?= $instanceId ?> .pa-test-badge {
            display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px;
            background: <?= $badgeBg ?>; border: 1px solid <?= $badgeBorder ?>;
            border-radius: 50px; font-size: 0.85rem; font-weight: 600;
            color: <?= $badgeText ?>; margin-bottom: 20px;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        
        #<?= $instanceId ?> .pa-test-title {
            font-size: 2.75rem; font-weight: 800; color: <?= $textPrimary ?>; margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .pa-test-subtitle {
            font-size: 1.125rem; color: <?= $textSecondary ?>; max-width: 600px; margin: 0 auto; line-height: 1.7;
        }
        
        #<?= $instanceId ?> .pa-test-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
        }
        
        #<?= $instanceId ?> .pa-test-card {
            background: <?= $cardBg ?>; border: 1px solid <?= $borderLight ?>;
            border-radius: 16px; padding: 32px; transition: all 0.3s ease;
        }
        
        #<?= $instanceId ?> .pa-test-card:hover {
            border-color: rgba(4, 120, 87, 0.3); transform: translateY(-4px);
        }
        
        #<?= $instanceId ?> .pa-test-stars { margin-bottom: 16px; display: flex; gap: 4px; }
        
        #<?= $instanceId ?> .pa-test-star {
            width: 18px; height: 18px;
        }
        
        #<?= $instanceId ?> .pa-test-text {
            font-size: 0.95rem; color: <?= $textSecondary ?>; line-height: 1.7; margin-bottom: 24px;
            font-style: italic;
        }
        
        #<?= $instanceId ?> .pa-test-author {
            display: flex; align-items: center; gap: 12px;
        }
        
        #<?= $instanceId ?> .pa-test-avatar {
            width: 48px; height: 48px;
            background: linear-gradient(135deg, #047857, #d97706);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; font-weight: 700; color: #ffffff;
        }
        
        #<?= $instanceId ?> .pa-test-name {
            font-size: 1rem; font-weight: 700; color: <?= $textPrimary ?>;
        }
        
        #<?= $instanceId ?> .pa-test-tag {
            font-size: 0.8rem; color: <?= $accentSecondaryLight ?>; margin-top: 2px;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .pa-test-grid { grid-template-columns: 1fr; max-width: 600px; margin: 0 auto; }
            #<?= $instanceId ?> .pa-test-title { font-size: 2rem; }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> { padding: 60px 0; }
            #<?= $instanceId ?> .pa-test-title { font-size: 1.75rem; }
        }
    </style>
    
    <div class="pa-test-container">
        <div class="pa-test-header">
            <div class="pa-test-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="pa-test-title"><?= htmlspecialchars($title) ?></h2>
            <p class="pa-test-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="pa-test-grid">
            <?php foreach ($testimonials as $test): ?>
            <div class="pa-test-card">
                <div class="pa-test-stars">
                    <?php for ($i = 1; $i <= 5; $i++): ?>
                    <svg class="pa-test-star" viewBox="0 0 24 24" fill="<?= $i <= $test['stars'] ? $starFilled : $starEmpty ?>">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    <?php endfor; ?>
                </div>
                
                <p class="pa-test-text">&ldquo;<?= htmlspecialchars($test['text']) ?>&rdquo;</p>
                
                <div class="pa-test-author">
                    <div class="pa-test-avatar"><?= htmlspecialchars(mb_substr($test['name'], 0, 1)) ?></div>
                    <div>
                        <div class="pa-test-name"><?= htmlspecialchars($test['name']) ?></div>
                        <?php if ($test['tag']): ?>
                        <div class="pa-test-tag"><?= htmlspecialchars($test['tag']) ?></div>
                        <?php endif; ?>
                    </div>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
