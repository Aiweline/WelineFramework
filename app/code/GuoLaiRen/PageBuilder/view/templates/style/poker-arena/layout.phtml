// 颜色辅助函数
if (!function_exists('pa_color')) {
    function pa_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

// 配置辅助函数
if (!function_exists('pa_getConfig')) {
    function pa_getConfig($settings, $key, $default = '') {
        $value = $settings[$key] ?? $default;
        if ($value === '' && $default !== '') {
            return $default;
        }
        return $value;
    }
}

