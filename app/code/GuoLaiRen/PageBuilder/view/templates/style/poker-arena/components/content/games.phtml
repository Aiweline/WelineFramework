<?php
/**
 * PokerArena - Games Showcase Component
 * 
 * 4 poker variants: Texas Hold'em, Omaha, Sit & Go, MTT
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.badge => 徽章文字:text:♠ Our Games
 * content.title => 标题:text:Choose Your Game
 * content.description => 描述:textarea:From casual cash games to high-stakes tournaments, find the perfect table for your skill level.
 * 
 * group:games => 游戏列表
 * games.items => 游戏列表:textarea:♠|Texas Hold'em|The world's most popular poker variant. Master the art of reading opponents and playing your position.|$0.01/$0.02 - $500/$1000|2-9 Players|#holdem\r\n♥|Omaha Poker|Four hole cards, five community cards — more action, bigger pots. Perfect for players who love multi-way action.|$0.05/$0.10 - $200/$400|2-9 Players|#omaha\r\n♦|Sit & Go Tournaments|Quick tournaments that start as soon as seats fill. Fast-paced action with escalating blinds.|$1 - $500 Buy-in|6-9 Players|#sitandgo\r\n♣|Multi-Table Tournaments|Compete against hundreds of players for massive prize pools. Deep-stacked, slow-structured events.|$0.50 - $10K Buy-in|100-10000 Players|#mtt|格式：花色|名称|描述|筹码范围|玩家数|链接
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

$sectionBg = $colors['games_bg'] ?? '#071209';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';
$textSecondary = $colors['text_secondary'] ?? '#86efac';
$textMuted = $colors['text_muted'] ?? '#6b8f7a';
$accentPrimary = $colors['accent_primary'] ?? '#047857';
$accentPrimaryLight = $colors['accent_primary_light'] ?? '#10b981';
$accentSecondary = $colors['accent_secondary'] ?? '#d97706';
$accentSecondaryLight = $colors['accent_secondary_light'] ?? '#fbbf24';
$cardBg = $colors['card_bg'] ?? 'rgba(255,255,255,0.03)';
$borderLight = $colors['border_light'] ?? 'rgba(134, 239, 172, 0.1)';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #047857 0%, #d97706 100%)';
$badgeBg = $colors['badge_bg'] ?? 'rgba(4, 120, 87, 0.15)';
$badgeBorder = $colors['badge_border'] ?? 'rgba(4, 120, 87, 0.3)';
$badgeText = $colors['badge_text'] ?? '#10b981';

$badge = $config['content.badge'] ?? '♠ Our Games';
$title = $config['content.title'] ?? 'Choose Your Game';
$description = $config['content.description'] ?? 'From casual cash games to high-stakes tournaments, find the perfect table for your skill level.';

$gamesRaw = $config['games.items'] ?? "♠|Texas Hold'em|The world's most popular poker variant. Master the art of reading opponents and playing your position.|\$0.01/\$0.02 - \$500/\$1000|2-9 Players|#holdem\n♥|Omaha Poker|Four hole cards, five community cards — more action, bigger pots. Perfect for players who love multi-way action.|\$0.05/\$0.10 - \$200/\$400|2-9 Players|#omaha\n♦|Sit & Go Tournaments|Quick tournaments that start as soon as seats fill. Fast-paced action with escalating blinds.|\$1 - \$500 Buy-in|6-9 Players|#sitandgo\n♣|Multi-Table Tournaments|Compete against hundreds of players for massive prize pools. Deep-stacked, slow-structured events.|\$0.50 - \$10K Buy-in|100-10000 Players|#mtt";

$games = [];
foreach (preg_split('/[\r\n]+/', $gamesRaw) as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('|', $line);
    if (count($parts) >= 3) {
        $games[] = [
            'suit' => trim($parts[0] ?? '♠'),
            'name' => trim($parts[1] ?? ''),
            'desc' => trim($parts[2] ?? ''),
            'stakes' => trim($parts[3] ?? ''),
            'players' => trim($parts[4] ?? ''),
            'url' => trim($parts[5] ?? '#'),
        ];
    }
}

$suitColors = ['♠' => '#ecfdf5', '♥' => '#ef4444', '♦' => '#f59e0b', '♣' => '#10b981'];

$instanceId = 'pa-games-' . uniqid();
?>

<section class="pa-games" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $sectionBg ?>;
            padding: 100px 0;
        }
        
        #<?= $instanceId ?> .pa-games-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        #<?= $instanceId ?> .pa-games-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        #<?= $instanceId ?> .pa-games-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: <?= $badgeBg ?>;
            border: 1px solid <?= $badgeBorder ?>;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            color: <?= $badgeText ?>;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        #<?= $instanceId ?> .pa-games-title {
            font-size: 2.75rem;
            font-weight: 800;
            color: <?= $textPrimary ?>;
            margin-bottom: 16px;
        }
        
        #<?= $instanceId ?> .pa-games-subtitle {
            font-size: 1.125rem;
            color: <?= $textSecondary ?>;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.7;
        }
        
        #<?= $instanceId ?> .pa-games-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
        
        #<?= $instanceId ?> .pa-game-card {
            background: <?= $cardBg ?>;
            border: 1px solid <?= $borderLight ?>;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?> .pa-game-card:hover {
            border-color: rgba(4, 120, 87, 0.4);
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(4, 120, 87, 0.2);
        }
        
        #<?= $instanceId ?> .pa-game-suit {
            font-size: 3rem;
            line-height: 1;
            margin-bottom: 16px;
            filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3));
        }
        
        #<?= $instanceId ?> .pa-game-name {
            font-size: 1.4rem;
            font-weight: 700;
            color: <?= $textPrimary ?>;
            margin-bottom: 12px;
        }
        
        #<?= $instanceId ?> .pa-game-desc {
            font-size: 0.95rem;
            color: <?= $textMuted ?>;
            line-height: 1.7;
            margin-bottom: 20px;
        }
        
        #<?= $instanceId ?> .pa-game-meta {
            display: flex;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        #<?= $instanceId ?> .pa-game-meta-item {
            padding: 6px 14px;
            background: rgba(4, 120, 87, 0.1);
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            color: <?= $accentPrimaryLight ?>;
        }
        
        #<?= $instanceId ?> .pa-game-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: <?= $buttonPrimaryBg ?>;
            color: #ffffff;
            font-size: 0.9rem;
            font-weight: 700;
            border-radius: 10px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        
        #<?= $instanceId ?> .pa-game-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(4, 120, 87, 0.4);
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .pa-games-title { font-size: 2rem; }
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .pa-games-grid { grid-template-columns: 1fr; }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> { padding: 60px 0; }
            #<?= $instanceId ?> .pa-games-title { font-size: 1.75rem; }
        }
    </style>
    
    <div class="pa-games-container">
        <div class="pa-games-header">
            <div class="pa-games-badge"><?= htmlspecialchars($badge) ?></div>
            <h2 class="pa-games-title"><?= htmlspecialchars($title) ?></h2>
            <p class="pa-games-subtitle"><?= htmlspecialchars($description) ?></p>
        </div>
        
        <div class="pa-games-grid">
            <?php foreach ($games as $game): ?>
            <div class="pa-game-card">
                <div class="pa-game-suit" style="color: <?= $suitColors[$game['suit']] ?? '#ecfdf5' ?>"><?= htmlspecialchars($game['suit']) ?></div>
                <h3 class="pa-game-name"><?= htmlspecialchars($game['name']) ?></h3>
                <p class="pa-game-desc"><?= htmlspecialchars($game['desc']) ?></p>
                <div class="pa-game-meta">
                    <?php if ($game['stakes']): ?>
                    <span class="pa-game-meta-item"><?= htmlspecialchars($game['stakes']) ?></span>
                    <?php endif; ?>
                    <?php if ($game['players']): ?>
                    <span class="pa-game-meta-item"><?= htmlspecialchars($game['players']) ?></span>
                    <?php endif; ?>
                </div>
                <a href="<?= htmlspecialchars($game['url']) ?>" class="pa-game-btn">Join Table</a>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
</section>
