<?php
/**
 * PokerArena - Header Navigation Component
 * 
 * 导航组件，支持从子页面动态获取导航项
 * Logo with spade/chip icon SVG, gold-green gradient "Join Table" CTA
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.image => Logo图片URL:textarea:|留空使用默认文字Logo
 * logo.text => Logo文字:text:PokerArena
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.use_custom_links => 使用自定义导航链接:select:no|no,yes
 * navigation.items => 导航项配置:textarea:Home=>#hero\r\nGames=>#games\r\nAdvantages=>#advantages\r\nDownload=>#download\r\nFAQ=>#faq|格式：名称=>链接，一行一个（仅当开启自定义链接时生效）
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Join Table
 * navigation.cta_url => CTA按钮链接:text:#register
 * 
 * @fields_end
 */

$config = $component_config ?? [];

if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 颜色配置
$navBg = $colors['nav_bg'] ?? 'rgba(6, 13, 8, 0.95)';
$navText = $colors['nav_text'] ?? '#ecfdf5';
$navLink = $colors['nav_link'] ?? '#86efac';
$navLinkHover = $colors['nav_link_hover'] ?? '#fbbf24';
$accentPrimary = $colors['accent_primary'] ?? '#047857';
$accentSecondary = $colors['accent_secondary'] ?? '#d97706';
$buttonPrimaryBg = $colors['button_primary_bg'] ?? 'linear-gradient(135deg, #047857 0%, #d97706 100%)';

// Logo配置
$showLogo = ($config['logo.display'] ?? 'yes') !== 'no';
$logoImage = $config['logo.image'] ?? '';
$logoText = $config['logo.text'] ?? 'PokerArena';
$logoWidth = $config['logo.width'] ?? 40;

// 导航配置
$useCustomLinks = ($config['navigation.use_custom_links'] ?? 'no') === 'yes';
$navItemsRaw = $config['navigation.items'] ?? "Home=>#hero\nGames=>#games\nAdvantages=>#advantages\nDownload=>#download\nFAQ=>#faq";
$showCta = ($config['navigation.show_cta'] ?? 'yes') !== 'no';
$ctaText = $config['navigation.cta_text'] ?? 'Join Table';
$ctaUrl = $config['navigation.cta_url'] ?? '#register';

// 导航项：默认按网站页面类型自动生成；开启「使用自定义导航链接」时用 navigation.items
$navItems = [];
$page = $this->getData('page');
if (!$useCustomLinks && $page && method_exists($page, 'getHeaderNavigationPages')) {
    $headerPages = $page->getHeaderNavigationPages(10);
    foreach ($headerPages as $navPage) {
        $type = $navPage['type'] ?? '';
        $labelKey = 'navigation.label_' . $type;
        $configuredLabel = trim((string)($config[$labelKey] ?? ''));
        $title = $navPage['title'] ?? '';
        $url = $navPage['url'] ?? '/';
        if (isset($navPage['type']) && $navPage['type'] === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME) {
            $title = __('Home');
            $url = '/';
        }
        $navItems[] = ['name' => $configuredLabel !== '' ? $configuredLabel : $title, 'url' => $url];
    }
}
if ($useCustomLinks || empty($navItems)) {
    $navItems = [];
    $lines = preg_split('/[\r\n]+/', $navItemsRaw);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        $parts = explode('=>', $line, 2);
        $name = trim($parts[0] ?? '');
        $url = trim($parts[1] ?? '#');
        if (!empty($name)) {
            $navItems[] = ['name' => $name, 'url' => $url ?: '#'];
        }
    }
}
if (empty($navItems)) {
    $navItems = [
        ['name' => 'Home', 'url' => '#hero'],
        ['name' => 'Games', 'url' => '#games'],
        ['name' => 'Advantages', 'url' => '#advantages'],
        ['name' => 'Download', 'url' => '#download'],
        ['name' => 'FAQ', 'url' => '#faq'],
    ];
}

$instanceId = 'pa-nav-' . uniqid();
?>

<nav class="pa-nav" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= htmlspecialchars($navBg) ?>;
            backdrop-filter: blur(10px);
            padding: 0 20px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        #<?= $instanceId ?> .pa-nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.3rem;
            font-weight: 800;
            color: <?= $navText ?>;
            letter-spacing: -0.02em;
        }
        
        #<?= $instanceId ?> .pa-nav-logo img {
            height: <?= intval($logoWidth) ?>px;
            width: auto;
        }
        
        #<?= $instanceId ?> .pa-nav-logo-icon {
            width: <?= intval($logoWidth) ?>px;
            height: <?= intval($logoWidth) ?>px;
            background: <?= $buttonPrimaryBg ?>;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 12px rgba(4, 120, 87, 0.3);
        }
        
        #<?= $instanceId ?> .pa-nav-logo-icon svg {
            width: 22px;
            height: 22px;
            fill: #ffffff;
        }
        
        #<?= $instanceId ?> .pa-nav-menu {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        #<?= $instanceId ?> .pa-nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        
        #<?= $instanceId ?> .pa-nav-link {
            color: <?= $navLink ?>;
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.3s ease;
            position: relative;
        }
        
        #<?= $instanceId ?> .pa-nav-link:hover {
            color: <?= $navLinkHover ?>;
        }
        
        #<?= $instanceId ?> .pa-nav-link::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: <?= $accentSecondary ?>;
            transition: width 0.3s ease;
        }
        
        #<?= $instanceId ?> .pa-nav-link:hover::after {
            width: 100%;
        }
        
        #<?= $instanceId ?> .pa-nav-cta {
            padding: 10px 24px;
            background: <?= $buttonPrimaryBg ?>;
            color: #ffffff;
            font-size: 0.9rem;
            font-weight: 700;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            box-shadow: 0 4px 15px rgba(4, 120, 87, 0.3);
        }
        
        #<?= $instanceId ?> .pa-nav-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(4, 120, 87, 0.5);
        }
        
        #<?= $instanceId ?> .pa-nav-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            padding: 8px;
            cursor: pointer;
        }
        
        #<?= $instanceId ?> .pa-nav-toggle span {
            width: 24px;
            height: 2px;
            background: <?= $navText ?>;
            transition: all 0.3s ease;
        }
        
        @media (max-width: 992px) {
            #<?= $instanceId ?> .pa-nav-menu {
                position: fixed;
                top: 80px;
                left: 0;
                right: 0;
                bottom: 0;
                background: <?= $navBg ?>;
                flex-direction: column;
                justify-content: flex-start;
                padding: 40px 20px;
                gap: 0;
                transform: translateX(100%);
                transition: transform 0.3s ease;
                backdrop-filter: blur(12px);
            }
            
            #<?= $instanceId ?> .pa-nav-menu.active {
                transform: translateX(0);
            }
            
            #<?= $instanceId ?> .pa-nav-links {
                flex-direction: column;
                width: 100%;
                gap: 0;
            }
            
            #<?= $instanceId ?> .pa-nav-link {
                display: block;
                padding: 16px 0;
                font-size: 1.1rem;
                border-bottom: 1px solid rgba(134, 239, 172, 0.08);
                width: 100%;
            }
            
            #<?= $instanceId ?> .pa-nav-link::after { display: none; }
            
            #<?= $instanceId ?> .pa-nav-cta {
                margin-top: 24px;
                width: 100%;
                text-align: center;
                padding: 16px;
            }
            
            #<?= $instanceId ?> .pa-nav-toggle { display: flex; }
            
            #<?= $instanceId ?> .pa-nav-toggle.active span:nth-child(1) {
                transform: rotate(45deg) translate(5px, 5px);
            }
            #<?= $instanceId ?> .pa-nav-toggle.active span:nth-child(2) { opacity: 0; }
            #<?= $instanceId ?> .pa-nav-toggle.active span:nth-child(3) {
                transform: rotate(-45deg) translate(5px, -5px);
            }
        }
    </style>
    
    <!-- Logo -->
    <?php if ($showLogo): ?>
    <a href="/" class="pa-nav-logo">
        <?php if ($logoImage): ?>
            <img src="<?= htmlspecialchars($logoImage) ?>" alt="<?= htmlspecialchars($logoText) ?>">
        <?php else: ?>
            <span class="pa-nav-logo-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2C9.24 2 7 4.24 7 7c0 1.77.94 3.41 2.47 4.3L12 24l2.53-12.7C16.06 10.41 17 8.77 17 7c0-2.76-2.24-5-5-5zm0 7.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 4.5 12 4.5s2.5 1.12 2.5 2.5S13.38 9.5 12 9.5z"/></svg>
            </span>
        <?php endif; ?>
        <span><?= htmlspecialchars($logoText) ?></span>
    </a>
    <?php endif; ?>
    
    <!-- Mobile Toggle -->
    <button class="pa-nav-toggle" onclick="this.classList.toggle('active'); document.querySelector('#<?= $instanceId ?> .pa-nav-menu').classList.toggle('active');">
        <span></span>
        <span></span>
        <span></span>
    </button>
    
    <!-- Navigation Menu -->
    <div class="pa-nav-menu">
        <div class="pa-nav-links">
            <?php foreach ($navItems as $item): ?>
            <a href="<?= htmlspecialchars($item['url']) ?>" class="pa-nav-link"><?= htmlspecialchars($item['name']) ?></a>
            <?php endforeach; ?>
        </div>
        
        <?php if ($showCta): ?>
        <a href="<?= htmlspecialchars($ctaUrl) ?>" class="pa-nav-cta"><?= htmlspecialchars($ctaText) ?></a>
        <?php endif; ?>
    </div>
</nav>
