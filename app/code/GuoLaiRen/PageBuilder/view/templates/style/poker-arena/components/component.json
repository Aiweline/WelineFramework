{
    "$schema": "2.1.0",
    "template": "poker-arena",
    "name": "PokerArena",
    "description": "Premium emerald green + gold poker/casino card game website template",
    "version": "1.0.0",
    "author": "GuoLaiRen",
    "regions": {
        "header": {
            "name": "头部区域",
            "name_en": "Header",
            "description": "页面顶部导航区域",
            "multiple": false,
            "required": true,
            "accepts": ["header"],
            "default_component": "header-nav",
            "supports_slot_nesting": true
        },
        "content": {
            "name": "内容区域",
            "name_en": "Content",
            "description": "页面主要内容区域，可包含多个组件",
            "multiple": true,
            "required": false,
            "accepts": ["content", "widget"],
            "default_components": ["hero-slider", "games", "advantages", "app-download", "testimonials", "faq", "cta-banner"],
            "supports_slot_nesting": true
        },
        "footer": {
            "name": "底部区域",
            "name_en": "Footer",
            "description": "页面底部链接和版权区域",
            "multiple": false,
            "required": true,
            "accepts": ["footer"],
            "default_component": "footer-links",
            "supports_slot_nesting": true
        }
    },
    "components": {
        "header-nav": {
            "name": "导航栏",
            "name_en": "Navigation Header",
            "description": "PokerArena顶部导航，支持Logo、导航链接和CTA按钮",
            "region": "header",
            "category": "header",
            "type": "section",
            "icon": "bi-menu-button-wide",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["header"],
            "slots": {
                "logo": {
                    "name": "Logo 区域",
                    "accepts": ["header"],
                    "slot_type": "header-logo",
                    "max": 1
                },
                "nav-links": {
                    "name": "导航链接",
                    "accepts": ["header"],
                    "slot_type": "header-nav-link",
                    "max": 10
                },
                "actions": {
                    "name": "操作按钮",
                    "accepts": ["header"],
                    "slot_type": "header-action",
                    "max": 3
                }
            },
            "config_groups": ["header", "navigation", "download_button", "color_scheme", "pixel"],
            "file": "header/nav.phtml",
            "default_config": {
                "logo.display": "yes",
                "logo.text": "PokerArena",
                "logo.width": 40,
                "navigation.show_cta": "yes",
                "navigation.cta_text": "Join Table",
                "navigation.cta_url": "#register"
            }
        },
        "hero-slider": {
            "name": "首屏轮播Banner",
            "name_en": "Hero Slider",
            "description": "首屏大图区域，包含标题、描述、CTA按钮和统计数据",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-badge-hd",
            "sort_order": 10,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "slides": {
                    "name": "幻灯片",
                    "accepts": ["content", "widget"],
                    "slot_type": "hero-slide",
                    "max": 10
                },
                "cta": {
                    "name": "CTA 按钮",
                    "accepts": ["content", "widget"],
                    "slot_type": "hero-cta",
                    "max": 2
                }
            },
            "config_groups": ["content", "cta", "stats", "style"],
            "file": "content/hero-slider.phtml"
        },
        "games": {
            "name": "游戏展示",
            "name_en": "Games Showcase",
            "description": "展示扑克游戏变种，4列卡片布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-controller",
            "sort_order": 20,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "items": {
                    "name": "游戏项目",
                    "accepts": ["content", "widget"],
                    "slot_type": "game-item",
                    "max": 20
                }
            },
            "config_groups": ["games", "texts", "style"],
            "file": "content/games.phtml"
        },
        "advantages": {
            "name": "优势展示",
            "name_en": "Advantages Section",
            "description": "展示平台核心优势，6列卡片布局",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-stars",
            "sort_order": 30,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "items": {
                    "name": "优势项目",
                    "accepts": ["content", "widget"],
                    "slot_type": "advantage-item",
                    "max": 12
                }
            },
            "config_groups": ["advantages", "texts", "style"],
            "file": "content/advantages.phtml"
        },
        "app-download": {
            "name": "应用下载",
            "name_en": "App Download Section",
            "description": "应用下载区域，包含下载按钮和功能亮点",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-download",
            "sort_order": 40,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["content", "download", "style"],
            "file": "content/app-download.phtml"
        },
        "testimonials": {
            "name": "用户评价",
            "name_en": "Testimonials",
            "description": "用户评价展示，支持头像、评分和内容",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-chat-quote",
            "sort_order": 50,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "items": {
                    "name": "评价项目",
                    "accepts": ["content", "widget"],
                    "slot_type": "testimonial-item",
                    "max": 20
                }
            },
            "config_groups": ["testimonials", "texts", "style"],
            "file": "content/testimonials.phtml"
        },
        "faq": {
            "name": "常见问题",
            "name_en": "FAQ Section",
            "description": "FAQ手风琴展示，支持展开收起效果",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-question-circle",
            "sort_order": 60,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "items": {
                    "name": "FAQ 项目",
                    "accepts": ["content", "widget"],
                    "slot_type": "faq-item",
                    "max": 30
                }
            },
            "config_groups": ["faq", "texts", "style"],
            "file": "content/faq.phtml"
        },
        "cta-banner": {
            "name": "CTA横幅",
            "name_en": "CTA Banner",
            "description": "行动号召横幅，引导用户注册或下载",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-megaphone",
            "sort_order": 65,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["content", "buttons", "style"],
            "file": "content/cta-banner.phtml"
        },
        "blog-list": {
            "name": "博客文章列表",
            "name_en": "Blog Posts List",
            "description": "展示博客文章列表，支持分类筛选",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-newspaper",
            "sort_order": 70,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "sidebar": {
                    "name": "侧边栏",
                    "accepts": ["content", "widget"],
                    "slot_type": "blog-sidebar",
                    "max": 5
                }
            },
            "config_groups": ["blog"],
            "file": "content/blog-list.phtml"
        },
        "blog-detail": {
            "name": "博客文章详情",
            "name_en": "Blog Post Detail",
            "description": "展示单篇博客文章详情",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-file-text",
            "sort_order": 71,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "sidebar": {
                    "name": "侧边栏",
                    "accepts": ["content", "widget"],
                    "slot_type": "blog-sidebar",
                    "max": 5
                },
                "related": {
                    "name": "相关文章",
                    "accepts": ["content", "widget"],
                    "slot_type": "blog-related",
                    "max": 6
                }
            },
            "config_groups": ["blog"],
            "file": "content/blog-detail.phtml"
        },
        "blog-category": {
            "name": "博客分类",
            "name_en": "Blog Category",
            "description": "展示特定分类下的博客文章列表",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-folder",
            "sort_order": 72,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "config_groups": ["blog"],
            "file": "content/blog-category.phtml"
        },
        "legal-content": {
            "name": "法律文档内容",
            "name_en": "Legal Content",
            "description": "通用法律文档内容组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-file-earmark-text",
            "sort_order": 80,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "applicable_page_types": ["privacy_policy", "terms_of_service", "refund_policy", "shipping_policy", "cookie_policy"],
            "config_groups": ["legal"],
            "file": "content/legal-content.phtml",
            "config_schema": {
                "show_toc": {"type": "boolean", "default": true, "label": "显示目录"},
                "show_last_updated": {"type": "boolean", "default": true, "label": "显示更新时间"},
                "content_width": {"type": "select", "options": ["narrow", "medium", "wide"], "default": "narrow", "label": "内容宽度"}
            }
        },
        "about-content": {
            "name": "关于我们内容",
            "name_en": "About Content",
            "description": "关于我们页面内容组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-info-circle",
            "sort_order": 81,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "team": {
                    "name": "团队成员",
                    "accepts": ["content", "widget"],
                    "slot_type": "about-team",
                    "max": 12
                },
                "values": {
                    "name": "价值观",
                    "accepts": ["content", "widget"],
                    "slot_type": "about-value",
                    "max": 6
                }
            },
            "applicable_page_types": ["about_page"],
            "config_groups": ["about"],
            "file": "content/about-content.phtml",
            "config_schema": {
                "layout": {"type": "select", "options": ["standard", "split", "timeline"], "default": "standard", "label": "布局模式"},
                "show_team": {"type": "boolean", "default": true, "label": "显示团队"},
                "show_values": {"type": "boolean", "default": true, "label": "显示价值观"},
                "show_stats": {"type": "boolean", "default": true, "label": "显示数据统计"}
            }
        },
        "contact-content": {
            "name": "联系我们内容",
            "name_en": "Contact Content",
            "description": "联系我们页面内容组件",
            "region": "content",
            "category": "content",
            "type": "section",
            "icon": "bi-envelope",
            "sort_order": 82,
            "is_default": false,
            "compatible_styles": ["*"],
            "placeable_in": ["content"],
            "slots": {
                "form": {
                    "name": "联系表单",
                    "accepts": ["content", "widget"],
                    "slot_type": "contact-form",
                    "max": 1
                },
                "info": {
                    "name": "联系信息",
                    "accepts": ["content", "widget"],
                    "slot_type": "contact-info",
                    "max": 5
                }
            },
            "applicable_page_types": ["contact_page"],
            "config_groups": ["contact"],
            "file": "content/contact-content.phtml",
            "config_schema": {
                "layout": {"type": "select", "options": ["split", "centered", "full"], "default": "split", "label": "布局模式"},
                "show_map": {"type": "boolean", "default": false, "label": "显示地图"},
                "show_form": {"type": "boolean", "default": true, "label": "显示表单"},
                "show_social": {"type": "boolean", "default": true, "label": "显示社交链接"}
            }
        },
        "footer-links": {
            "name": "页脚链接",
            "name_en": "Footer with Links",
            "description": "页脚区域，包含品牌、多列链接和版权信息",
            "region": "footer",
            "category": "footer",
            "type": "section",
            "icon": "bi-layout-text-window-reverse",
            "sort_order": 1,
            "is_default": true,
            "compatible_styles": ["*"],
            "placeable_in": ["footer"],
            "slots": {
                "links": {
                    "name": "链接组",
                    "accepts": ["footer"],
                    "slot_type": "footer-link-group",
                    "max": 5
                },
                "social": {
                    "name": "社交链接",
                    "accepts": ["footer"],
                    "slot_type": "footer-social",
                    "max": 1
                },
                "copyright": {
                    "name": "版权信息",
                    "accepts": ["footer"],
                    "slot_type": "footer-copyright",
                    "max": 1
                }
            },
            "config_groups": ["style", "layout", "content", "typography"],
            "file": "footer/links.phtml"
        }
    },
    "nav_config": {
        "description": "导航可使用子页面配置",
        "use_subpages": true,
        "subpage_types": ["link", "anchor", "page"],
        "default_items": [
            {"text": "Home", "href": "#home", "type": "anchor"},
            {"text": "Games", "href": "#games", "type": "anchor"},
            {"text": "About", "href": "#about", "type": "anchor"},
            {"text": "Blog", "href": "#blog", "type": "anchor"},
            {"text": "FAQ", "href": "#faq", "type": "anchor"}
        ]
    },
    "config_inheritance": {
        "description": "组件可以继承模板的配置项",
        "shared_configs": ["styles", "texts", "color_scheme"]
    }
}
