<?php
/**
 * PokerArena 模板 - Header
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.text => Logo文字:text:PokerArena
 * logo.url => Logo图片URL:text:
 * logo.width => Logo宽度:number:40|px
 * 
 * group:navigation => 导航设置
 * navigation.display => 显示导航:select:yes|yes,no
 * navigation.bg_color => 背景颜色:color:rgba(6, 13, 8, 0.95)
 * navigation.text_color => 文字颜色:color:#ecfdf5
 * navigation.link_hover_color => 链接悬停颜色:color:#fbbf24
 * navigation.links => 导航链接:textarea:Home=>/\r\nGames=>/games\r\nAbout=>/about\r\nBlog=>/blog\r\nFAQ=>/faq|格式：名称=>链接，一行一个
 * navigation.show_cta => 显示CTA按钮:select:yes|yes,no
 * navigation.cta_text => CTA按钮文字:text:Join Table
 * navigation.cta_url => CTA按钮链接:text:#register
 * 
 * group:pixel => 像素统计:📊访客像素统计配置
 * pixel.enabled => 启用像素统计:select:yes|yes,no
 * pixel.name => 像素名称:text:{handle}
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'poker-arena';
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'poker-arena';
}
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
// 确保 $colors 已定义
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

// 辅助函数
if (!function_exists('pa_header_color')) {
    function pa_header_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('pa_header_getConfig')) {
    function pa_header_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

// Logo配置
$logoDisplay = pa_header_getConfig($styleSettings, 'logo.display', 'yes');
$logoText = pa_header_getConfig($styleSettings, 'logo.text', 'PokerArena');
$logoUrl = pa_header_getConfig($styleSettings, 'logo.url', '');
$logoWidth = pa_header_getConfig($styleSettings, 'logo.width', '40');

// 导航配置
$navDisplay = pa_header_getConfig($styleSettings, 'navigation.display', 'yes');
$navBgColor = pa_header_getConfig($styleSettings, 'navigation.bg_color', pa_header_color($colors, 'nav_bg', 'rgba(6, 13, 8, 0.95)'));
$navTextColor = pa_header_getConfig($styleSettings, 'navigation.text_color', '#ecfdf5');
$navLinkHoverColor = pa_header_getConfig($styleSettings, 'navigation.link_hover_color', '#fbbf24');
$navLinksRaw = pa_header_getConfig($styleSettings, 'navigation.links', "Home=>/\nGames=>/games\nAbout=>/about\nBlog=>/blog\nFAQ=>/faq");
$showCta = pa_header_getConfig($styleSettings, 'navigation.show_cta', 'yes');
$ctaText = pa_header_getConfig($styleSettings, 'navigation.cta_text', 'Join Table');
$ctaUrl = pa_header_getConfig($styleSettings, 'navigation.cta_url', '#register');

// 颜色配置
$accentPrimary = pa_header_color($colors, 'accent_primary', '#047857');
$buttonPrimaryBg = pa_header_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #047857 0%, #d97706 100%)');

// 解析导航链接
$navLinks = [];
$lines = preg_split('/[\r\n]+/', $navLinksRaw);
foreach ($lines as $line) {
    $line = trim($line);
    if (empty($line)) continue;
    $parts = explode('=>', $line, 2);
    $name = trim($parts[0] ?? '');
    $url = trim($parts[1] ?? '#');
    if (!empty($name)) {
        $navLinks[] = ['name' => $name, 'url' => $url];
    }
}
?>

<?php if ($navDisplay === 'yes'): ?>
<style>
    .pa-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: <?= htmlspecialchars($navBgColor) ?>;
