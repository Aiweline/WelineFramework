        .pa-header-cta-btn { padding: 10px; }
    }
</style>

<header class="pa-header">
    <div class="pa-header-container">
        <?php if ($logoDisplay === 'yes'): ?>
        <a href="/" class="pa-logo">
            <span class="pa-logo-icon">
                <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= htmlspecialchars($logoText) ?>" style="width: 100%; height: 100%; object-fit: contain;">
                <?php else: ?>
                    <svg viewBox="0 0 24 24"><path d="M12 2C9.24 2 7 4.24 7 7c0 1.77.94 3.41 2.47 4.3L12 24l2.53-12.7C16.06 10.41 17 8.77 17 7c0-2.76-2.24-5-5-5zm0 7.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 4.5 12 4.5s2.5 1.12 2.5 2.5S13.38 9.5 12 9.5z"/></svg>
                <?php endif; ?>
            </span>
            <span class="pa-logo-text"><?= htmlspecialchars($logoText) ?></span>
        </a>
        <?php endif; ?>
        
        <nav class="pa-header-nav">
            <ul class="pa-header-nav-links">
                <?php foreach ($navLinks as $link): ?>
                <li><a href="<?= htmlspecialchars($link['url']) ?>" class="pa-header-nav-link"><?= htmlspecialchars($link['name']) ?></a></li>
                <?php endforeach; ?>
            </ul>
            
            <?php if ($showCta === 'yes'): ?>
            <a href="<?= htmlspecialchars($ctaUrl) ?>" class="pa-header-cta-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C9.24 2 7 4.24 7 7c0 1.77.94 3.41 2.47 4.3L12 24l2.53-12.7C16.06 10.41 17 8.77 17 7c0-2.76-2.24-5-5-5z"/></svg>
                <span><?= htmlspecialchars($ctaText) ?></span>
            </a>
            <?php endif; ?>
        </nav>
    </div>
</header>
<?php endif; ?>

<?php
// === 像素统计代码 ===
$isPreviewMode = (bool)($this->getData('is_preview') ?? false);
if (!$isPreviewMode && isset($_GET['preview']) && $_GET['preview'] === '1') {
    $isPreviewMode = true;
}

$pixelEnabled = pa_header_getConfig($styleSettings, 'pixel.enabled', 'yes');
$pixelEnabled = (string)($pixelEnabled ?? 'yes');
$pixelName = pa_header_getConfig($styleSettings, 'pixel.name', '');

if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}

$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;

if ($websiteId > 0 && !empty($pixelName) && !$isPreviewMode):
    \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_ID', (string)$websiteId, 3600 * 24 * 365);
    
    $websiteUrl = '';
    $websiteCode = '';
    try {
        if (class_exists('\Weline\Websites\Model\Website')) {
            $websiteModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Websites\Model\Website::class);
            $website = clone $websiteModel;
            $website->clear()->load($websiteId);
            if ($website->getId()) {
                $websiteUrl = $website->getData('url') ?? '';
                $websiteCode = $website->getData('code') ?? '';
            }
        }
    } catch (\Exception $e) {
        // 如果获取网站信息失败，不影响像素功能
    }
    
    if (!empty($websiteUrl)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_URL', $websiteUrl, 3600 * 24 * 365);
    }
    if (!empty($websiteCode)) {
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_CODE', $websiteCode, 3600 * 24 * 365);
    }
    
    $this->assign('pixel_name', htmlspecialchars($pixelName));
    $this->assign('pixel_enabled', htmlspecialchars($pixelEnabled));
?>
    <pixel name="{{pixel_name}}" enabled="{{pixel_enabled}}" />
<?php endif; ?>
