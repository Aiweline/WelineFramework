    .pa-footer {
        background: <?= htmlspecialchars($footerBg) ?>;
        padding: 80px 0 0;
    }
    
    .pa-footer-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    
    .pa-footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
