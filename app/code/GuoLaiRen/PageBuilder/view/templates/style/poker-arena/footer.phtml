<?php
/**
 * PokerArena 模板 - Footer
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:brand => 品牌设置
 * brand.name => 品牌名称:text:PokerArena
 * brand.description => 品牌描述:textarea:The ultimate online poker experience. Join millions of players worldwide.
 * 
 * group:links => 链接设置
 * links.column1_title => 栏目1标题:text:Games
 * links.column1_items => 栏目1链接:textarea:Texas Hold'em=>/games/holdem\r\nOmaha Poker=>/games/omaha\r\nSit & Go=>/games/sit-and-go\r\nTournaments=>/games/tournaments|格式：名称=>链接
 * links.column2_title => 栏目2标题:text:About
 * links.column2_items => 栏目2链接:textarea:About Us=>/about\r\nResponsible Gaming=>/responsible-gaming\r\nFair Play=>/fair-play\r\nCareers=>/careers|格式：名称=>链接
 * links.column3_title => 栏目3标题:text:Support
 * links.column3_items => 栏目3链接:textarea:Help Center=>/help\r\nContact Us=>/contact\r\nFAQ=>/faq\r\nLive Chat=>/chat|格式：名称=>链接
 * links.column4_title => 栏目4标题:text:Legal
 * links.column4_items => 栏目4链接:textarea:Privacy Policy=>/privacy\r\nTerms of Service=>/terms\r\nCookie Policy=>/cookies\r\nRefund Policy=>/refund|格式：名称=>链接
 * 
 * group:contact => 联系信息
 * contact.email => 邮箱:text:support@pokerarena.com
 * 
 * group:copyright => 版权设置
 * copyright.text => 版权文字:text:All rights reserved. Play responsibly.
 * copyright.disclaimer => 免责声明:textarea:PokerArena promotes responsible gaming. Players must be 18+ to participate.
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

$templateCode = $page ? $page->getData('style') : 'poker-arena';
if (empty($templateCode)) {
    $templateCode = 'poker-arena';
}
$this->assign('template_code', $templateCode);
?>
<div style="display:none;">
    <w:template>GuoLaiRen_PageBuilder::base/colors.phtml</w:template>
</div>
<?php
if (!isset($colors) || !is_array($colors)) {
    $colors = [];
}

if (!function_exists('pa_footer_color')) {
    function pa_footer_color($colors, $key, $default = '') {
        return $colors[$key] ?? $default;
    }
}

if (!function_exists('pa_footer_getConfig')) {
    function pa_footer_getConfig($settings, $key, $default = '') {
        return $settings[$key] ?? $default;
    }
}

$brandName = pa_footer_getConfig($styleSettings, 'brand.name', 'PokerArena');
$brandDesc = pa_footer_getConfig($styleSettings, 'brand.description', 'The ultimate online poker experience. Join millions of players worldwide.');

$columns = [];
for ($i = 1; $i <= 4; $i++) {
    $title = pa_footer_getConfig($styleSettings, "links.column{$i}_title", '');
    $raw = pa_footer_getConfig($styleSettings, "links.column{$i}_items", '');
    $links = [];
    if ($raw) {
        foreach (preg_split('/[\r\n]+/', $raw) as $line) {
            $line = trim($line);
            if (empty($line)) continue;
            $parts = explode('=>', $line, 2);
            $name = trim($parts[0] ?? '');
            $url = trim($parts[1] ?? '#');
            if (!empty($name)) {
                $links[] = ['name' => $name, 'url' => $url];
            }
        }
    }
    if ($title || !empty($links)) {
        $columns[] = ['title' => $title, 'links' => $links];
    }
}

if (empty($columns)) {
    $columns = [
        ['title' => 'Games', 'links' => [['name' => 'Texas Hold\'em', 'url' => '#'], ['name' => 'Omaha', 'url' => '#'], ['name' => 'Tournaments', 'url' => '#']]],
        ['title' => 'About', 'links' => [['name' => 'About Us', 'url' => '/about'], ['name' => 'Responsible Gaming', 'url' => '#']]],
        ['title' => 'Support', 'links' => [['name' => 'Help Center', 'url' => '#'], ['name' => 'Contact', 'url' => '/contact'], ['name' => 'FAQ', 'url' => '/faq']]],
        ['title' => 'Legal', 'links' => [['name' => 'Privacy Policy', 'url' => '/privacy'], ['name' => 'Terms of Service', 'url' => '/terms']]],
    ];
}

$contactEmail = pa_footer_getConfig($styleSettings, 'contact.email', 'support@pokerarena.com');
$copyrightText = pa_footer_getConfig($styleSettings, 'copyright.text', 'All rights reserved. Play responsibly.');
$disclaimer = pa_footer_getConfig($styleSettings, 'copyright.disclaimer', 'PokerArena promotes responsible gaming. Players must be 18+ to participate.');

$footerBg = pa_footer_color($colors, 'footer_bg', '#040a06');
$footerText = pa_footer_color($colors, 'footer_text', '#6b8f7a');
$footerLink = pa_footer_color($colors, 'footer_link', '#86efac');
$footerLinkHover = pa_footer_color($colors, 'footer_link_hover', '#fbbf24');
$footerBorder = pa_footer_color($colors, 'footer_border', 'rgba(134, 239, 172, 0.06)');
$textPrimary = pa_footer_color($colors, 'text_primary', '#ecfdf5');
$buttonPrimaryBg = pa_footer_color($colors, 'button_primary_bg', 'linear-gradient(135deg, #047857 0%, #d97706 100%)');

$currentYear = date('Y');
?>

