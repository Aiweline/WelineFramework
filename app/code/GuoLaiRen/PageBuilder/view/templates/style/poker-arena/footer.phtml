</style>

<footer class="pa-footer">
    <div class="pa-footer-container">
        <div class="pa-footer-grid">
            <div class="pa-footer-brand">
                <div class="pa-footer-logo">
                    <span class="pa-footer-logo-icon">
                        <svg viewBox="0 0 24 24"><path d="M12 2C9.24 2 7 4.24 7 7c0 1.77.94 3.41 2.47 4.3L12 24l2.53-12.7C16.06 10.41 17 8.77 17 7c0-2.76-2.24-5-5-5z"/></svg>
                    </span>
                    <span><?= htmlspecialchars($brandName) ?></span>
                </div>
                <p class="pa-footer-brand-desc"><?= htmlspecialchars($brandDesc) ?></p>
            </div>
            
            <?php foreach ($columns as $column): ?>
            <div class="pa-footer-column">
                <h4><?= htmlspecialchars($column['title']) ?></h4>
                <div class="pa-footer-links">
                    <?php foreach ($column['links'] as $link): ?>
                    <a href="<?= htmlspecialchars($link['url']) ?>" class="pa-footer-link"><?= htmlspecialchars($link['name']) ?></a>
                    <?php endforeach; ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
        
        <div class="pa-footer-bottom">
            <div class="pa-footer-copyright">
                &copy; <?= $currentYear ?> <?= htmlspecialchars($brandName) ?>. <?= htmlspecialchars($copyrightText) ?>
            </div>
            <div class="pa-footer-disclaimer"><?= htmlspecialchars($disclaimer) ?></div>
        </div>
    </div>
</footer>
