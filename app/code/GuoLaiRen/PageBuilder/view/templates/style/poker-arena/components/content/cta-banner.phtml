<?php
/**
 * PokerArena - CTA Banner Component
 * 
 * "Ready to Show Your Hand?" call-to-action with emerald-gold gradient
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $colors 颜色配置
 * @var array $component_config 组件配置
 * 
 * @fields_start
 * 
 * group:content => 内容设置
 * content.title => 标题:text:Ready to Show Your Hand?
 * content.description => 描述:textarea:Join millions of players worldwide. Create your free account today and get a welcome bonus on your first deposit.
 * 
 * group:buttons => 按钮设置
 * buttons.primary_text => 主按钮文字:text:Create Account
 * buttons.primary_url => 主按钮链接:text:#register
 * buttons.secondary_text => 次按钮文字:text:Download App
 * buttons.secondary_url => 次按钮链接:text:#download
 * 
 * @fields_end
 */

$config = $component_config ?? [];
if (!isset($colors) || !is_array($colors)) { $colors = []; }

$ctaBg = $colors['cta_bg'] ?? 'linear-gradient(135deg, #047857 0%, #065f46 50%, #d97706 100%)';
$textPrimary = $colors['text_primary'] ?? '#ecfdf5';

$title = $config['content.title'] ?? 'Ready to Show Your Hand?';
$description = $config['content.description'] ?? 'Join millions of players worldwide. Create your free account today and get a welcome bonus on your first deposit.';
$primaryText = $config['buttons.primary_text'] ?? 'Create Account';
$primaryUrl = $config['buttons.primary_url'] ?? '#register';
$secondaryText = $config['buttons.secondary_text'] ?? 'Download App';
$secondaryUrl = $config['buttons.secondary_url'] ?? '#download';

$instanceId = 'pa-cta-' . uniqid();
?>

<section class="pa-cta" id="<?= $instanceId ?>">
    <style>
        #<?= $instanceId ?> {
            background: <?= $ctaBg ?>;
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }
        
        #<?= $instanceId ?>::before {
            content: '♠ ♥ ♦ ♣';
            position: absolute;
            font-size: 12rem;
            color: rgba(255,255,255,0.03);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            white-space: nowrap;
            pointer-events: none;
            letter-spacing: 2rem;
        }
        
        #<?= $instanceId ?> .pa-cta-container {
            max-width: 800px; margin: 0 auto; padding: 0 20px;
            text-align: center; position: relative; z-index: 1;
        }
        
        #<?= $instanceId ?> .pa-cta-title {
            font-size: 3rem; font-weight: 900; color: #ffffff;
            margin-bottom: 20px; line-height: 1.1;
        }
        
        #<?= $instanceId ?> .pa-cta-desc {
            font-size: 1.15rem; color: rgba(255,255,255,0.85);
            line-height: 1.7; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;
        }
        
        #<?= $instanceId ?> .pa-cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        
        #<?= $instanceId ?> .pa-cta-btn-primary {
            padding: 18px 40px;
            background: #ffffff; color: #047857;
            font-size: 1.1rem; font-weight: 700;
            border-radius: 12px; transition: all 0.3s ease;
            text-transform: uppercase; letter-spacing: 0.03em;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        
        #<?= $instanceId ?> .pa-cta-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.3);
        }
        
        #<?= $instanceId ?> .pa-cta-btn-secondary {
            padding: 18px 40px;
            background: transparent; color: #ffffff;
            font-size: 1.1rem; font-weight: 700;
            border: 2px solid rgba(255,255,255,0.4);
            border-radius: 12px; transition: all 0.3s ease;
            text-transform: uppercase; letter-spacing: 0.03em;
        }
        
        #<?= $instanceId ?> .pa-cta-btn-secondary:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.7);
        }
        
        @media (max-width: 768px) {
            #<?= $instanceId ?> .pa-cta-title { font-size: 2rem; }
        }
        
        @media (max-width: 576px) {
            #<?= $instanceId ?> { padding: 60px 0; }
            #<?= $instanceId ?> .pa-cta-buttons { flex-direction: column; align-items: center; }
            #<?= $instanceId ?> .pa-cta-btn-primary,
            #<?= $instanceId ?> .pa-cta-btn-secondary { width: 100%; text-align: center; }
        }
    </style>
    
    <div class="pa-cta-container">
        <h2 class="pa-cta-title"><?= htmlspecialchars($title) ?></h2>
        <p class="pa-cta-desc"><?= htmlspecialchars($description) ?></p>
        <div class="pa-cta-buttons">
            <?php if ($primaryText): ?>
            <a href="<?= htmlspecialchars($primaryUrl) ?>" class="pa-cta-btn-primary"><?= htmlspecialchars($primaryText) ?></a>
            <?php endif; ?>
            <?php if ($secondaryText): ?>
            <a href="<?= htmlspecialchars($secondaryUrl) ?>" class="pa-cta-btn-secondary"><?= htmlspecialchars($secondaryText) ?></a>
            <?php endif; ?>
        </div>
    </div>
</section>
