<?php
/**
 * 统计代码模板 - Tracking Code Template
 * 包含所有统计代码的加载和通用事件跟踪函数
 * 
 * 使用说明：
 * 在元素上添加 data-track-event="事件名称" 属性，点击时会自动触发事件追踪
 * 系统会自动提取元素上的所有 data-* 属性（除了 data-track-event 和 data-handle）作为事件参数
 * 向后兼容：也支持 data-handle 属性（等同于 data-track-event）
 * 
 * 示例：
 * <a href="#" data-track-event="button_click">点击按钮</a>
 * <button data-track-event="submit_form" data-form-id="contact" data-value="1">提交</button>
 * <a href="#" data-track-event="cta_click" data-button-type="primary" data-page="home">CTA</a>
 * 
 * 注意：
 * - 所有 data-* 属性值会自动解析（如果是 JSON 格式会自动解析为对象/数组）
 * - 属性名会自动移除 data- 前缀后作为参数名
 * - 不再提供 trackCTA, trackFormSubmit, trackPageView 等 JS 函数，统一使用属性方式
 * 
 * @var \Weline\Framework\View\Template $this
 */

use Weline\Framework\App\Debug;

$page = $this->getData('page');
$isPreview = (bool)($this->getData('is_preview') ?? false);

// 获取样式配置（用于读取像素配置）
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 获取统计代码配置
$gtmId = $page ? $page->getData('gtm_id') : '';
$gaId = $page ? ($page->getData('ga4_id') ?: $page->getData('ga_id')) : '';
$fbId = $page ? ($page->getData('fb_pixel_id') ?: $page->getData('fb_id')) : '';

// 读取像素统计配置（遵循模板配置规则）
// 确保 $pixelEnabled 始终有值，避免未定义变量错误
$pixelEnabled = 'yes'; // 默认启用
$pixelName = '';
if (!empty($styleSettings)) {
    // 从样式配置中读取像素配置
    $pixelEnabled = $styleSettings['pixel.enabled'] ?? 'yes';
    $pixelName = $styleSettings['pixel.name'] ?? '';
}
// 确保 $pixelEnabled 始终是字符串类型，避免类型错误
$pixelEnabled = (string)($pixelEnabled ?? 'yes');

// 如果像素名称为空，使用页面的 handle
if (empty($pixelName) && $page) {
    $pixelName = $page->getData('handle') ?? '';
}

// 直接从页面对象获取 website_id（页面已有此字段，无需配置）
$websiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;
?>

<!-- 头部统计代码（Head Section） -->
<?php if (!$isPreview): ?>
    <!-- Google Tag Manager -->
    <?php if (!empty($gtmId)): ?>
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','<?= htmlspecialchars($gtmId ?? '') ?>');</script>
    <?php endif; ?>
    
    <!-- Google Analytics (GA4) -->
    <?php if (!empty($gaId)): ?>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<?= htmlspecialchars($gaId ?? '') ?>"></script>
    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);} 
    gtag('js', new Date());
    gtag('config', '<?= htmlspecialchars($gaId ?? '') ?>');
    </script>
    <?php endif; ?>

    <!-- Meta Pixel (Facebook) -->
    <?php if (!empty($fbId)): ?>
    <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '<?= htmlspecialchars($fbId ?? '') ?>');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt=""
    src="https://www.facebook.com/tr?id=<?= htmlspecialchars($fbId ?? '') ?>&ev=PageView&noscript=1"/></noscript>
    <?php endif; ?>
    
    <!-- Weline Visitor Pixel（遵循模板配置规则） -->
    <?php
    // 如果页面绑定了网站且有像素名称，输出像素标签（通过 enabled 属性控制是否统计）
    if ($websiteId > 0 && !empty($pixelName)):
        // 设置 website_id Cookie，供像素代码读取
        \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_ID', (string)$websiteId, 3600 * 24 * 365);
        
        // 获取网站信息（用于像素统计）
        $websiteUrl = '';
        $websiteCode = '';
        try {
            if (class_exists('\Weline\Websites\Model\Website')) {
                $websiteModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Websites\Model\Website::class);
                $website = clone $websiteModel;
                $website->clear()->load($websiteId);
                if ($website->getId()) {
                    $websiteUrl = $website->getData('url') ?? '';
                    $websiteCode = $website->getData('code') ?? '';
                }
            }
        } catch (\Exception $e) {
            // 如果获取网站信息失败，不影响像素功能
        }
        
        // 设置 website_url Cookie
        if (!empty($websiteUrl)) {
            \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_URL', $websiteUrl, 3600 * 24 * 365);
        }
        
        // 设置 website_code Cookie，用于区分不同站点
        if (!empty($websiteCode)) {
            \Weline\Framework\Http\Cookie::set('WELINE_WEBSITE_CODE', $websiteCode, 3600 * 24 * 365);
        }
        
        // 使用变量传递方式，避免在标签属性中使用 PHP 标签
        $this->assign('pixel_name', htmlspecialchars($pixelName));
        $this->assign('pixel_enabled', htmlspecialchars($pixelEnabled));
        Debug::env('pixel_name', true);
    ?>
        <!-- 通过 enabled 属性控制是否统计，遵循模板配置中的 pixel.enabled 设置 -->
        <pixel name="{{pixel_name}}" enabled="{{pixel_enabled}}" />
    <?php endif; ?>
<?php endif; ?>

<!-- 通用事件跟踪函数（Window Level） -->
<script>
(function() {
    'use strict';
    
    // 预览模式检测函数
    function detectPreviewMode() {
        try {
            var qs = window.location ? window.location.search : '';
            return (
                /[?&](preview|is_preview|pb_preview|builder)=1/i.test(qs) ||
                !!window.__PAGEBUILDER_PREVIEW__ ||
                !!window.__IS_PREVIEW__ ||
                (document && (
                    document.documentElement.hasAttribute('data-preview') ||
                    (document.body && (
                        document.body.classList.contains('preview') ||
                        document.body.classList.contains('is-preview')
                    ))
                ))
            );
        } catch(e) {
            return false;
        }
    }
    
    // 检查统计代码是否可用
    var trackingConfig = {
        hasGTM: <?php echo (!empty($gtmId)) ? 'true' : 'false'; ?>,
        hasGA: <?php echo (!empty($gaId)) ? 'true' : 'false'; ?>,
        hasFB: <?php echo (!empty($fbId)) ? 'true' : 'false'; ?>
    };
    
    var isPreview = detectPreviewMode();
    
    // 通用事件跟踪函数
    window.trackEvent = function(eventName, eventParams) {
        if (!eventName) {
            console.warn('[Tracking] Event name is required');
            return;
        }
        
        eventParams = eventParams || {};
        
        if (isPreview) {
            // 预览模式：只打印日志
            try {
                console.info('%c[Preview][Tracking] Event:', 'color: #00ff00; font-weight: bold;', eventName);
                if (Object.keys(eventParams).length > 0) {
                    console.info('%c[Preview][Tracking] Params:', 'color: #00ff00;', eventParams);
                }
                if (trackingConfig.hasGTM) console.info('%c[Preview][GTM]', 'color: #4285f4;', eventName);
                if (trackingConfig.hasGA) console.info('%c[Preview][GA]', 'color: #4285f4;', eventName);
                if (trackingConfig.hasFB) console.info('%c[Preview][Meta]', 'color: #4285f4;', eventName);
            } catch(e) {}
            return;
        }
        
        // 正常模式：发送真实统计数据
        try {
            // Google Tag Manager
            if (trackingConfig.hasGTM && window.dataLayer && typeof window.dataLayer.push === 'function') {
                var gtmEvent = { event: eventName };
                if (Object.keys(eventParams).length > 0) {
                    Object.assign(gtmEvent, eventParams);
                }
                window.dataLayer.push(gtmEvent);
            }
            
            // Google Analytics 4
            if (trackingConfig.hasGA && typeof window.gtag === 'function') {
                if (Object.keys(eventParams).length > 0) {
                    window.gtag('event', eventName, eventParams);
                } else {
                    window.gtag('event', eventName);
                }
            }
            
            // Legacy Google Analytics
            if (trackingConfig.hasGA && typeof window.ga === 'function') {
                window.ga('send', 'event', 'cta', eventName, { nonInteraction: false });
            }
            
            // Facebook Pixel
            if (trackingConfig.hasFB && typeof window.fbq === 'function') {
                // 发送自定义事件
                window.fbq('trackCustom', eventName, eventParams);
                
                // 如果是 Lead 相关事件，也发送标准 Lead 事件
                if (eventName.toLowerCase().indexOf('lead') !== -1 || eventName.toLowerCase().indexOf('submit') !== -1) {
                    window.fbq('track', 'Lead', {
                        content_name: eventName,
                        status: 'completed'
                    });
                }
            }
        } catch (error) {
            console.error('[Tracking] Event tracking failed:', error);
        }
    };
    
    // 注意：所有事件追踪都通过元素属性触发，不再提供 JS 便捷函数
    // 使用方式：在元素上添加 data-track-event="事件名称" 和 data-* 属性传递参数
    
    // 暴露预览模式状态（供外部检查）
    window.__TRACKING_CONFIG__ = {
        isPreview: isPreview,
        hasGTM: trackingConfig.hasGTM,
        hasGA: trackingConfig.hasGA,
        hasFB: trackingConfig.hasFB
    };
    
    // 预览模式提示（json_encode 避免页面 charset 误判时控制台乱码）
    if (isPreview) {
        console.log(<?= json_encode('%c━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━') ?>, 'color: #00ff00; font-weight: bold;');
        console.log(<?= json_encode('%c🔍 预览模式 - 统计代码已禁用') ?>, 'color: #00ff00; font-size: 14px; font-weight: bold;');
        console.log(<?= json_encode('%c📊 跟踪配置:') ?>, 'color: #ffcc00; font-weight: bold;', window.__TRACKING_CONFIG__);
        console.log(<?= json_encode('%c💡 提示: 所有 trackEvent() 调用将只打印日志，不会发送真实数据') ?>, 'color: #999999; font-style: italic;');
        console.log(<?= json_encode('%c━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━') ?>, 'color: #00ff00; font-weight: bold;');
    }
    
    // 统一事件处理：自动为所有带有 data-track-event 或 data-handle 属性的元素绑定点击事件
    function initAutoTracking() {
        // 使用事件委托，支持动态添加的元素
        document.addEventListener('click', function(event) {
            var target = event.target;
            // 向上查找带有事件追踪属性的元素
            while (target && target !== document) {
                if (target.hasAttribute) {
                    // 优先使用 data-track-event，如果没有则使用 data-handle（向后兼容）
                    var eventName = target.getAttribute('data-track-event') || target.getAttribute('data-handle');
                    if (eventName) {
                        // 提取元素的所有 data-* 属性作为事件参数
                        var eventParams = {};
                        if (target.attributes && target.attributes.length > 0) {
                            for (var i = 0; i < target.attributes.length; i++) {
                                var attr = target.attributes[i];
                                var attrName = attr.name;
                                // 提取所有 data-* 属性（除了 data-track-event 和 data-handle，这些是事件名）
                                if (attrName.startsWith('data-') && 
                                    attrName !== 'data-track-event' && 
                                    attrName !== 'data-handle') {
                                    // 移除 data- 前缀，并将属性名转换为驼峰命名
                                    var paramKey = attrName.substring(5); // 移除 'data-'
                                    var paramValue = attr.value;
                                    // 尝试解析 JSON 值
                                    try {
                                        if ((paramValue.startsWith('{') && paramValue.endsWith('}')) ||
                                            (paramValue.startsWith('[') && paramValue.endsWith(']'))) {
                                            eventParams[paramKey] = JSON.parse(paramValue);
                                        } else {
                                            eventParams[paramKey] = paramValue;
                                        }
                                    } catch(e) {
                                        // 如果解析失败，使用原始字符串值
                                        eventParams[paramKey] = paramValue;
                                    }
                                }
                            }
                        }
                        // 触发事件
                        window.trackEvent(eventName, eventParams);
                        break;
                    }
                }
                target = target.parentElement;
            }
        }, true); // 使用捕获阶段，确保优先处理
    }
    
    // 页面加载完成后初始化
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAutoTracking);
    } else {
        initAutoTracking();
    }
})();
</script>

