<?php
/**
 * PageBuilder AI 虚拟编辑入口
 *
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */
$page = $this->getData('page');
$pageType = (string)($this->getData('visual_page_type') ?? '');
$virtualPagesByType = $this->getData('virtual_pages_by_type') ?? [];
$virtualPage = \is_array($virtualPagesByType[$pageType] ?? null) ? $virtualPagesByType[$pageType] : [];
$styleCode = (string)($this->getData('visual_style_code') ?? ($virtualPage['style_code'] ?? 'default'));
$publicId = (string)($this->getData('visual_public_id') ?? '');
$workspaceUrl = $publicId !== '' ? $this->getBackendUrl('pagebuilder/backend/ai-site-agent/workspace', ['public_id' => $publicId]) : $this->getBackendUrl('pagebuilder/backend/ai-site-agent/index');
$pageTypeNames = \GuoLaiRen\PageBuilder\Model\Page::getPageTypes();
$pageTypeLabel = (string)($pageTypeNames[$pageType] ?? $pageType);
$title = (string)($virtualPage['title'] ?? ($page ? $page->getData('title') : ''));
$handle = (string)($virtualPage['handle'] ?? ($page ? $page->getData('handle') : ''));
$defaultLocale = (string)($virtualPage['locale'] ?? ($page ? $page->getData('default_locale') : 'en_US'));
$metaTitle = (string)($virtualPage['meta_title'] ?? ($page ? $page->getData('meta_title') : ''));
$metaDescription = (string)($virtualPage['meta_description'] ?? ($page ? $page->getData('meta_description') : ''));
$metaKeywords = (string)($virtualPage['meta_keywords'] ?? ($page ? $page->getData('meta_keywords') : ''));
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= __('AI 虚拟主题编辑') ?></h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<?= $workspaceUrl ?>"><?= __('AI建站工作台') ?></a></li>
                    <li class="breadcrumb-item active"><?= __('虚拟编辑') ?></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                        <span class="badge bg-primary-subtle text-primary"><?= __('虚拟主题') ?></span>
                        <?php if ($pageTypeLabel !== ''): ?>
                        <span class="badge bg-light text-body border"><?= htmlspecialchars($pageTypeLabel) ?></span>
                        <?php endif; ?>
                        <?php if ($styleCode !== ''): ?>
                        <span class="badge bg-light text-body border"><?= htmlspecialchars($styleCode) ?></span>
                        <?php endif; ?>
                    </div>
                    <h5 class="mb-1"><?= htmlspecialchars($title !== '' ? $title : __('未命名页面')) ?></h5>
                    <p class="text-muted mb-0">
                        <?= __('当前页面还处于虚拟工作区阶段，所有改动都会先保存到工作区，点击发布后才会物化正式页面。') ?>
                    </p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="btn btn-primary" onclick="openVisualConfig()">
                        <i class="mdi mdi-monitor-edit"></i> <?= __('进入编辑') ?>
                    </button>
                    <a class="btn btn-outline-secondary" href="<?= $workspaceUrl ?>">
                        <i class="mdi mdi-arrow-left"></i> <?= __('返回工作台') ?>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="handle" value="<?= htmlspecialchars($handle) ?>">
<input type="hidden" id="style" value="<?= htmlspecialchars($styleCode) ?>">
<input type="hidden" id="meta_title" value="<?= htmlspecialchars($metaTitle) ?>">
<input type="hidden" id="meta_description" value="<?= htmlspecialchars($metaDescription) ?>">
<input type="hidden" id="meta_keywords" value="<?= htmlspecialchars($metaKeywords) ?>">

<?= $this->fetch('GuoLaiRen_PageBuilder::templates/Backend/Page/form_component/visual_config.phtml') ?>

<script>
window.currentStyle = <?= json_encode($styleCode, JSON_UNESCAPED_UNICODE) ?>;
window.visualConfigHandle = <?= json_encode($handle, JSON_UNESCAPED_UNICODE) ?>;
window.defaultLanguage = <?= json_encode($defaultLocale, JSON_UNESCAPED_UNICODE) ?>;
window.currentVisualLanguage = <?= json_encode($defaultLocale, JSON_UNESCAPED_UNICODE) ?>;

document.addEventListener('DOMContentLoaded', function () {
    setTimeout(function () {
        if (typeof window.openVisualConfig === 'function') {
            window.openVisualConfig();
        }
    }, 60);
});
</script>
