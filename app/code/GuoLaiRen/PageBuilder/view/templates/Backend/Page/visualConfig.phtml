<script>
// 页面ID（如果 form.phtml 中已定义则跳过）
if (typeof pageId === 'undefined') {
    var pageId = <?= $pageId ?>;
}

// 自动保存防抖定时器
let autoSaveTimer = null;
const AUTO_SAVE_DELAY = 1000; // 1秒

// 打开可视化配置
function openVisualConfig() {
    document.getElementById('visualConfigWrapper').classList.add('active');
    document.body.style.overflow = 'hidden';
}

// 关闭可视化配置
function closeVisualConfig() {
    document.getElementById('visualConfigWrapper').classList.remove('active');
    document.body.style.overflow = '';
}

// 切换配置区域
function toggleSection(sectionId) {
    const section = document.getElementById(sectionId);
    section.classList.toggle('collapsed');
}

// 切换设备视图
function switchDevice(device) {
    // 更新按钮状态
    document.querySelectorAll('.device-btn').forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-device') === device);
    });
    
    // 更新预览容器
    const container = document.getElementById('previewContainer');
    container.className = 'preview-container device-' + device;
}

// 更新保存状态
function updateSaveStatus(status, text) {
    const statusEl = document.getElementById('saveStatus');
    const textEl = document.getElementById('saveStatusText');
    
    statusEl.className = 'save-status ' + status;
    textEl.textContent = text;
}

// 自动保存配置
function autoSaveConfig() {
    // 清除之前的定时器
    if (autoSaveTimer) {
        clearTimeout(autoSaveTimer);
    }
    
    // 设置新的定时器
    autoSaveTimer = setTimeout(async () => {
        updateSaveStatus('saving', '<?= __('保存中...') ?>');
        
        try {
            // 收集所有配置
            const config = {};
            document.querySelectorAll('.auto-save-field').forEach(field => {
                const key = field.getAttribute('data-config-key');
                config[key] = field.value;
            });
            
            // 发送保存请求
            const response = await fetch('<?= $this->getBackendUrl('*/backend/preview/autoSave') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    page_id: pageId,
                    style_config: config
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                updateSaveStatus('saved', '<?= __('已保存') ?>');
                
                // 自动刷新预览
                refreshPreview();
            } else {
                updateSaveStatus('error', '<?= __('保存失败') ?>');
                console.error('保存失败:', result.message);
            }
        } catch (error) {
            updateSaveStatus('error', '<?= __('保存失败') ?>');
            console.error('保存异常:', error);
        }
    }, AUTO_SAVE_DELAY);
}

// 刷新预览
function refreshPreview() {
    const loading = document.getElementById('previewLoading');
    const iframe = document.getElementById('previewIframe');
    
    loading.classList.add('active');
    
    // 重新加载iframe
    iframe.src = iframe.src.split('?')[0] + '?page_id=' + pageId + '&t=' + Date.now();
    
    // 监听加载完成
    iframe.onload = function() {
        loading.classList.remove('active');
    };
}

// 监听所有自动保存字段
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.auto-save-field').forEach(field => {
        field.addEventListener('input', function() {
            updateSaveStatus('', '<?= __('未保存') ?>');
            autoSaveConfig();
        });
        
        field.addEventListener('change', function() {
            updateSaveStatus('', '<?= __('未保存') ?>');
            autoSaveConfig();
        });
    });
});

// 键盘快捷键
document.addEventListener('keydown', function(e) {
    // ESC 退出全屏
    if (e.key === 'Escape') {
        closeVisualConfig();
    }
    
    // Ctrl+S 保存
    if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        autoSaveConfig();
    }
});
</script>

