<script>
(function() {
    var pageTreeApiUrl = <?= json_encode($pageTreeApiUrl, JSON_UNESCAPED_SLASHES) ?>;
    function loadPageTree(pageId) {
        var container = document.getElementById('pageTreeContainer');
        if (!container) return;
        container.innerHTML = '<div class="text-muted small"><?= __("加载中...") ?></div>';
        if (!pageId) {
            container.innerHTML = '<div class="text-muted small"><?= __("请先打开页面") ?></div>';
            return;
        }
        fetch(pageTreeApiUrl + '?page_id=' + encodeURIComponent(String(pageId)), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.success || !data.list || !data.list.length) {
                    container.innerHTML = '<div class="text-muted small"><?= __("暂无子页面") ?></div>';
                    return;
                }
                var html = '';
                for (var i = 0; i < data.list.length; i++) {
                    var p = data.list[i];
                    var title = (p.title || p.handle || ('#' + p.page_id)).replace(/</g, '&lt;');
                    var currentId = (window.visualPageId || window.pageId || 0);
                    var activeClass = (currentId && parseInt(p.page_id, 10) === parseInt(currentId, 10)) ? ' active' : '';
                    html += '<a href="#" class="ve-page-tree-item' + activeClass + '" data-page-id="' + parseInt(p.page_id, 10) + '">' + title + '</a>';
                }
                container.innerHTML = html;
                container.querySelectorAll('.ve-page-tree-item').forEach(function(el) {
                    el.addEventListener('click', function(e) {
                        e.preventDefault();
                        var id = parseInt(this.getAttribute('data-page-id'), 10);
                        if (!id) return;
                        window.visualPageId = id;
                        if (typeof window.pageId !== 'undefined') window.pageId = id;
                        if (typeof window.refreshPreview === 'function') window.refreshPreview();
                        container.querySelectorAll('.ve-page-tree-item').forEach(function(x) { x.classList.remove('active'); });
                        this.classList.add('active');
                    });
                });
            })
            .catch(function() {
                container.innerHTML = '<div class="text-danger small"><?= __("加载失败") ?></div>';
            });
    }
    window.visualEditorLoadPageTree = function(pageId) {
        loadPageTree(pageId || window.visualPageId || window.pageId || 0);
    };
    window.visualEditorSelectPageInTree = function(pageId) {
        var container = document.getElementById('pageTreeContainer');
        if (!container) return;
        container.querySelectorAll('.ve-page-tree-item').forEach(function(el) {
            var id = parseInt(el.getAttribute('data-page-id'), 10);
            if (id === parseInt(pageId, 10)) el.classList.add('active');
            else el.classList.remove('active');
        });
    };
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            var pid = window.visualPageId || window.pageId || 0;
            if (pid) loadPageTree(pid);
        });
    } else {
        var pid = window.visualPageId || window.pageId || 0;
        if (pid) loadPageTree(pid);
    }
})();
</script>
