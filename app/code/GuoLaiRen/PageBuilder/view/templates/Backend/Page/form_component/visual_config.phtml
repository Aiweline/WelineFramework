            icon.className = originalClass;
        });
}

// HTML转义辅助函数（模板配置模式使用）
function escapeHtmlForTemplate(text) {
    if (typeof text === 'undefined' || text === null) return '';
    const div = document.createElement('div');
    div.textContent = String(text);
    return div.innerHTML;
}

// ========== 普通页面模式：加载指定样式的配置 ==========
async function loadVisualStyleConfig() {
    try {
        const currentPageId = typeof pageId !== 'undefined' ? pageId : (window.pageId || window.visualPageId || 0);
        const externalStyleSelect = document.getElementById('style');
        const styleCode = externalStyleSelect ? externalStyleSelect.value : (typeof window.currentStyle !== 'undefined' ? window.currentStyle : '');
        const locale = window.currentVisualLanguage || '';

        if (!styleCode) {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-info m-3"><?= __('请先选择样式模板（方案）') ?></div>';
            }
            return;
        }

        // 显示加载中
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('正在加载配置...') ?></div></div>';
        }

        // 复用模板配置的获取接口
        let url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
            '?style_code=' + encodeURIComponent(styleCode) +
            '&page_id=' + encodeURIComponent(currentPageId);
        if (locale) {
            url += '&locale=' + encodeURIComponent(locale);
        }

        const response = await fetch(url);
        const result = await response.json();
        if (result.success && result.data) {
            // 显示模板信息（名称 + 代码）
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            // 直接复用渲染逻辑
            renderTemplateConfig(result.data);
        } else {
            if (configPanel) {
                configPanel.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('加载配置失败') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('加载配置失败:', error);
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?></div>';
        }
    }
}

// ========== 刷新样式配置按钮（普通页面模式） ==========
window.refreshVisualStyleConfig = async function(event) {
    try {
        // 处理按钮 loading 状态（可选）
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = true;
            if (icon) { icon.className = 'mdi mdi-loading mdi-spin'; }
        }

        // 重新加载样式配置
        await loadVisualStyleConfig();

        // 刷新预览（如果对应函数存在则调用）
        if (typeof refreshVisualPreview === 'function') {
            refreshVisualPreview();
        } else if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    } catch (error) {
        console.error('刷新样式配置失败:', error);
        alert('刷新失败：' + (error && error.message ? error.message : 'Unknown error'));
    } finally {
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = false;
            if (icon) { icon.className = 'mdi mdi-refresh'; }
        }
    }
};

// ========== 全屏模式功能 ==========
window.toggleFullscreen = function() {
    const wrapper = document.getElementById('visualConfigWrapper');
    const btn = document.getElementById('fullscreenBtn');
    const icon = btn ? btn.querySelector('i') : null;
    const panel = document.getElementById('configPanel');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    
    if (!wrapper || !btn) return;
    
    wrapper.classList.toggle('fullscreen-mode');
    btn.classList.toggle('active');
    
    // 切换图标
    if (icon) {
        if (wrapper.classList.contains('fullscreen-mode')) {
            icon.className = 'mdi mdi-fullscreen-exit';
            btn.title = '<?= __('退出全屏') ?>';
            // 进入全屏时立即收起配置面板
            if (panel) panel.classList.add('collapsed');
            // 显示悬浮展开按钮
            if (floatingBtn) floatingBtn.style.display = 'block';
        } else {
            icon.className = 'mdi mdi-fullscreen';
            btn.title = '<?= __('全屏模式') ?>';
            // 退出全屏时展开配置面板
            if (panel) panel.classList.remove('collapsed');
            // 隐藏悬浮展开按钮
            if (floatingBtn) floatingBtn.style.display = 'none';
        }
    }
};

// ========== 配置面板收起/展开功能 ==========
window.toggleConfigPanel = function() {
    const panel = document.getElementById('configPanel');
    const btn = document.getElementById('configPanelToggle');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    const wrapper = document.getElementById('visualConfigWrapper');
    
