<!-- 早期挂载一个全局入口，确保表单可调用，即使主脚本延迟/异常 -->
<script>
if (typeof window.openVisualConfig === 'undefined') {
    window.openVisualConfig = function(passedHandle) {
        try {
            if (passedHandle && typeof passedHandle === 'string') {
                window.visualConfigHandle = passedHandle.trim();
            }
            var wrapper = document.getElementById('visualConfigWrapper');
            if (wrapper) {
                wrapper.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            if (typeof window.visualConfigLazyInit === 'function') {
                window.visualConfigLazyInit();
            } else if (typeof window.openVisualConfigCore === 'function') {
                // 兼容：如果核心函数已定义
                window.openVisualConfigCore(passedHandle);
            } else {
                console.warn('[VisualConfig] 组件未完全就绪，稍后将继续初始化');
                setTimeout(function(){
                    if (typeof window.visualConfigLazyInit === 'function') {
                        window.visualConfigLazyInit();
                    }
                }, 100);
            }
        } catch (e) {
            console.error('[VisualConfig] 打开入口出错:', e);
        }
    };
}
</script>

<script>
// ========== 组件初始化：支持通过 handle 或 page_id 初始化 ==========
// 使用唯一的初始化标识，避免在 iframe 环境中重复初始化导致内存耗尽
(function() {
    try { console.log('[VisualConfig] 组件脚本运行'); } catch (_){ }
    // 检查是否已经在当前 window 中初始化过（防止重复执行）
    const initKey = 'visualConfigInit_' + (window.location.href || 'default');
    if (window[initKey]) {
        console.log('⚠️ 可视化配置组件已初始化，跳过重复初始化');
        return;
    }
    window[initKey] = true;
    
    // 初始化全局变量（只在未定义时设置，避免覆盖已有值）
    window.visualConfigInitialized = window.visualConfigInitialized || false;
    window.visualPageId = window.visualPageId || null;
    window.visualConfigHandle = window.visualConfigHandle || null;
    window.currentVisualLanguage = window.currentVisualLanguage || '';
    window.defaultLanguage = window.defaultLanguage || '';
    
    // 延迟初始化，等待 DOM 完全加载后再执行（避免在 iframe 中立即执行导致内存问题）
    const initVisualConfig = function() {
        // 如果已经初始化过，直接返回
        if (window.visualConfigInitialized) {
            return;
        }
        
        // 只有在可视化配置容器存在时才初始化
        if (!document.getElementById('visualConfigWrapper')) {
            // 容器不存在，可能是在 iframe 中动态加载，延迟重试
            setTimeout(initVisualConfig, 100);
            return;
        }
        
        // 尝试从多个来源获取 handle 和 page_id（优先使用外部传入的全局值）
        let handle = (typeof window.visualConfigHandle !== 'undefined' && window.visualConfigHandle) ? window.visualConfigHandle : '<?= htmlspecialchars($handle ?? '') ?>';
        let pageId = <?= $pageId ?: 'null' ?>;
        
        // 如果 handle 为空，尝试从 DOM 获取
        if (!handle) {
            const handleInput = document.getElementById('handle');
            if (handleInput) {
                handle = handleInput.value.trim();
            }
        }
        
        // 如果 pageId 为空，尝试从全局变量获取
        if (!pageId && typeof window.visualPageId !== 'undefined' && window.visualPageId) {
            pageId = window.visualPageId;
        }
        
        // 如果只有 handle 没有 pageId，需要通过 API 获取
        if (handle && !pageId) {
            console.log('📡 通过 handle 获取页面信息:', handle);
            fetch('<?= $this->getBackendUrl('pagebuilder/backend/page/getPageByHandle') ?>?handle=' + encodeURIComponent(handle))
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.data) {
                        pageId = result.data.page_id || null;
                        window.visualPageId = pageId;
                        window.visualConfigHandle = handle;
                        if (result.data.default_locale) {
                            window.defaultLanguage = result.data.default_locale;
                            window.currentVisualLanguage = result.data.default_locale;
                        }
                        console.log('✅ 页面信息获取成功:', { pageId, handle, defaultLocale: window.defaultLanguage });
                        window.visualConfigInitialized = true;
                    } else {
                        console.error('❌ 获取页面信息失败:', result.message || '未知错误');
                    }
                })
                .catch(error => {
                    console.error('❌ API 调用失败:', error);
                    if (typeof pageId !== 'undefined' && pageId) {
                        window.visualPageId = pageId;
                        window.visualConfigInitialized = true;
                    }
                });
        } else {
            window.visualPageId = pageId;
            window.visualConfigHandle = handle;
            window.visualConfigInitialized = true;
        }
        
        if (!window.defaultLanguage && <?= $page && $page->getData('default_locale') ? json_encode($page->getData('default_locale')) : 'null' ?>) {
            window.defaultLanguage = <?= $page && $page->getData('default_locale') ? json_encode($page->getData('default_locale')) : 'null' ?>;
            window.currentVisualLanguage = window.defaultLanguage;
        }
        
        console.log('✅ 可视化配置组件初始化完成', {
            pageId: window.visualPageId,
            handle: window.visualConfigHandle,
            defaultLanguage: window.defaultLanguage
        });
    };
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVisualConfig);
    } else {
        setTimeout(initVisualConfig, 50);
    }
    
    // 提供延迟初始化函数（供外部调用）
    window.visualConfigLazyInit = initVisualConfig;
    // 在外部渲染完成后，组件内部也能重新初始化
    window.addEventListener('VisualEditor:rendered', function(){
        try { console.log('[VisualConfig] 组件捕获 VisualEditor:rendered，重新初始化'); } catch(_){ }
        setTimeout(initVisualConfig, 0);
    });
})();

// 页面ID（兼容性：如果全局未定义，使用组件内部的值）
// 取消在全局公开 pageId，避免与外部冲突（统一由组件内部管理）

// 自动保存防抖定时器
let autoSaveTimer = null;

// 提前定义 autoSaveVisualConfig 占位符（避免在函数定义前调用导致错误）
// 这个占位符会在 autoSaveConfig 定义后被替换
if (typeof window.autoSaveVisualConfig === 'undefined') {
    window.autoSaveVisualConfig = function() {
        // 如果 autoSaveConfig 已定义，则调用它；否则等待
        if (typeof window.autoSaveConfig === 'function') {
            return window.autoSaveConfig.apply(window, arguments);
        } else {
            console.warn('⚠️ autoSaveConfig 尚未定义，请稍后重试');
            return Promise.reject(new Error('autoSaveConfig not yet defined'));
        }
    };
}
const AUTO_SAVE_DELAY = 1000; // 1秒

// 打开可视化配置
function openVisualConfig(passedHandle) {
    document.getElementById('visualConfigWrapper').classList.add('active');
    document.body.style.overflow = 'hidden';
    // 如果外部传入了 handle，则以它为准，由组件自行通过接口解析 pageId
    if (typeof passedHandle === 'string' && passedHandle.trim()) {
        window.visualConfigHandle = passedHandle.trim();
        // 重置，以便触发通过 handle 获取 page 信息
        window.visualPageId = null;
        window.visualConfigInitialized = false;
        if (typeof window.visualConfigLazyInit === 'function') {
            window.visualConfigLazyInit();
        }
    }
    
    // 检测是否为模板配置模式，如果是则加载模板配置
    const isTemplateMode = window.isTemplateConfigMode || false;
    if (isTemplateMode) {
        const styleCode = window.currentTemplateStyleCode || '';
        const templatePageId = window.currentTemplatePageId || 0;
        
        if (styleCode) {
            // 清空静态配置内容，准备加载动态配置
            const configPanel = document.querySelector('.config-panel-body');
            if (configPanel) {
                configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('正在加载配置...') ?></div></div>';
            }
            
            // 加载模板配置
            loadTemplateStyleConfig();
            
            // 加载预览
            refreshTemplatePreview();
        }
    }
    // 非模板模式：根据外部样式选择加载配置并刷新预览
    if (!isTemplateMode) {
        if (typeof loadVisualStyleConfig === 'function') {
            loadVisualStyleConfig().then(() => {
                if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
            });
        }
    }
}

// 关闭可视化配置
function closeVisualConfig() {
    document.getElementById('visualConfigWrapper').classList.remove('active');
    document.body.style.overflow = '';
}

// 向外部抛出全局函数供表单调用
try {
    if (!window.openVisualConfig) {
        window.openVisualConfig = openVisualConfig;
        console.log('[VisualConfig] 已挂载 window.openVisualConfig(handle)');
    }
    if (!window.closeVisualConfig) {
        window.closeVisualConfig = closeVisualConfig;
    }
} catch (_) {}

// 切换配置区域
function toggleSection(sectionId) {
    const section = document.getElementById(sectionId);
    section.classList.toggle('collapsed');
}

// 切换设备视图
function switchDevice(device) {
    // 更新按钮状态
    document.querySelectorAll('.device-btn').forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-device') === device);
    });
    
    // 更新预览容器
    const container = document.getElementById('previewContainer');
    container.className = 'preview-container device-' + device;
}

// 更新保存状态（全局函数）
window.updateSaveStatus = function(status, text) {
    const statusEl = document.getElementById('saveStatus');
    const textEl = document.getElementById('saveStatusText');
    
    if (statusEl) {
        statusEl.className = 'save-status ' + status;
    }
    if (textEl) {
        textEl.textContent = text;
    }
}

 // 自动保存配置（全局函数，确保可以被 selectColorScheme 调用）
 window.autoSaveConfig = function(immediate = false) {
    // 清除之前的定时器
    if (autoSaveTimer) {
        clearTimeout(autoSaveTimer);
        autoSaveTimer = null;
    }
    
    // 保存函数
    const saveFunction = async () => {
        if (typeof window.updateSaveStatus === 'function') {
            window.updateSaveStatus('saving', '<?= __('保存中...') ?>');
        }
        
        try {
            // 收集所有配置
            const config = {};
            document.querySelectorAll('.auto-save-field').forEach(field => {
                const key = field.getAttribute('data-config-key');
                // 处理 radio 类型
                if (field.type === 'radio') {
                    if (field.checked) {
                        config[key] = field.value;
                    }
                } else {
                    config[key] = field.value;
                }
            });
            
            // 检测是否为模板配置模式
            const isTemplateMode = window.isTemplateConfigMode || false;
            const styleCode = window.currentTemplateStyleCode || '';
            const templatePageId = window.currentTemplatePageId || 0;
            
            // 构建请求体（使用全局 pageId 或从 window 获取）
            const currentPageId = typeof pageId !== 'undefined' ? pageId : (window.pageId || window.visualPageId || 0);
            // 尝试从外部下拉框读取当前样式代码
            let currentStyleCode = '';
            const externalStyleSelect = document.getElementById('style');
            if (externalStyleSelect && externalStyleSelect.value) {
                currentStyleCode = externalStyleSelect.value;
            } else if (typeof window.currentStyle !== 'undefined' && window.currentStyle) {
                currentStyleCode = window.currentStyle;
            }

            let requestBody = {
                page_id: currentPageId,
                style_config: config
            };
            
            // 如果是模板配置模式，使用模板接口
            let saveUrl = '<?= $this->getBackendUrl('*/backend/preview/autoSave') ?>';
            if (isTemplateMode && styleCode) {
                saveUrl = '<?= $this->getBackendUrl('*/backend/template/autoSave') ?>';
                requestBody.page_id = templatePageId || pageId;
                requestBody.style_code = styleCode;
            } else {
                // 普通页面配置模式：附带样式代码，支持语言（如有）
                if (currentStyleCode) {
                    requestBody.style_code = currentStyleCode;
                }
                if (window.currentVisualLanguage) {
                    requestBody.locale = window.currentVisualLanguage;
                }
            }
            
            // 发送保存请求
            const response = await fetch(saveUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(requestBody)
            });
            
            const result = await response.json();
            
            if (result.success) {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('saved', '<?= __('已保存') ?>');
                }
                
                // 如果不是立即保存模式，自动刷新预览（立即保存模式下由调用者决定是否刷新）
                if (!immediate) {
                    if (typeof window.refreshPreview === 'function') {
                        window.refreshPreview();
                    }
                }
                
                return Promise.resolve();
            } else {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('保存失败') ?>');
                }
                console.error('保存失败:', result.message);
                return Promise.reject(new Error(result.message || '保存失败'));
            }
        } catch (error) {
            if (typeof window.updateSaveStatus === 'function') {
                window.updateSaveStatus('error', '<?= __('保存失败') ?>');
            }
            console.error('保存异常:', error);
            return Promise.reject(error);
        }
    };
    
    if (immediate) {
        // 立即保存，返回 Promise
        return saveFunction();
    } else {
        // 延迟保存，返回 Promise
        return new Promise((resolve, reject) => {
            autoSaveTimer = setTimeout(async () => {
                try {
                    await saveFunction();
                    resolve();
                } catch (error) {
                    reject(error);
                }
            }, AUTO_SAVE_DELAY);
        });
    }
}

// 更新 autoSaveVisualConfig 为完整实现（替换之前的占位符，确保直接调用 autoSaveConfig）
window.autoSaveVisualConfig = function() {
    return window.autoSaveConfig.apply(window, arguments);
