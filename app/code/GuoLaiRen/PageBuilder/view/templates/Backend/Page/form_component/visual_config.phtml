// 模板配置模式：加载模板样式配置
async function loadTemplateStyleConfig(forceScan = false) {
    const styleCode = window.currentTemplateStyleCode || '';
    const templatePageId = window.currentTemplatePageId || 0;
    
    if (!styleCode) {
        console.error('模板代码不能为空');
        return;
    }
    
    try {
        let url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
            '?style_code=' + encodeURIComponent(styleCode) +
            '&page_id=' + templatePageId;
        
        if (forceScan) {
            url += '&force_scan=1&t=' + Date.now();
        }
        
        const response = await fetch(url);
        const result = await response.json();
        try { console.log('[VisualConfig] 页面模式配置载入'); console.log('请求URL:', url); console.log('返回结构:', result); } catch (_) {}
        try { console.log('[VisualConfig] 模板模式配置载入'); console.log('请求URL:', url); console.log('返回结构:', result); } catch (_) {}
        
        if (result.success && result.data) {
            // 显示模板信息（名称 + 代码）
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            renderTemplateConfig(result.data);
        } else {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('加载配置失败') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('加载配置失败:', error);
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?></div>';
        }
    }
}

// 模板配置模式：渲染模板配置
function renderTemplateConfig(configGroups) {
    try { console.log('[VisualConfig] 渲染配置分组'); console.log('分组keys:', Object.keys(configGroups || {})); } catch (_) {}
    // 辅助函数：渲染单个配置字段
    function renderConfigField(configKey, config) {
        const rawValue = config.value !== undefined ? config.value : (config.default || '');
        const fieldId = 'config_' + configKey.replace(/\./g, '_');
        try { console.log('[VisualConfig] 渲染字段:', { configKey, type: config.type || 'text', default: config.default || '', value: rawValue }); } catch (_) {}
        
        let fieldHtml = `<div class="mb-3 config-field-item" data-config-key="${escapeHtmlForTemplate(configKey)}" data-config-label="${escapeHtmlForTemplate(config.label || '')}" data-config-description="${escapeHtmlForTemplate(config.description || config.note || '')}">`;
        // 添加恢复默认值按钮到标签中
        const escapedDefault = escapeHtmlForTemplate(config.default || '');
        fieldHtml += `<label for="${fieldId}" class="form-label">`;
        fieldHtml += `${escapeHtmlForTemplate(config.label)}`;
        fieldHtml += ` <a href="javascript:void(0)" 
                         class="link-warning ms-1 visual-config-reset-btn" 
                         data-field-id="${fieldId}"
                         data-config-key="${escapeHtmlForTemplate(configKey)}"
                         data-config-type="${config.type || 'text'}"
                         data-default-value="${escapedDefault}"
                         onclick="resetVisualConfigField(this)"
                         title="<?= __('恢复默认值') ?>">
                        <i class="mdi mdi-restore"></i> <span class="reset-text"><?= __('恢复') ?></span>
                     </a>`;
        fieldHtml += `</label>`;
        
        // 特殊处理：色系选择（带预览图）
        if (config.type === 'color_scheme' && config.color_schemes) {
            fieldHtml += `<div class="color-scheme-selector" id="${fieldId}_container">`;
            fieldHtml += `<input type="hidden" id="${fieldId}" class="auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
            
            const colorSchemes = config.color_schemes;
            fieldHtml += `<div class="color-scheme-grid">`;
            
            for (const schemeKey in colorSchemes) {
                const scheme = colorSchemes[schemeKey];
                const isSelected = rawValue == schemeKey;
                // 预览图片路径：使用后端静态资源接口
                let previewUrl = '';
                if (scheme.preview_image) {
                    const pv = String(scheme.preview_image || '');
                    if (/^(https?:)?\/\//.test(pv) || pv.startsWith('/')) {
                        // 已是绝对URL或以/开头
                        previewUrl = pv;
                    } else {
                        // 相对路径，拼接模板静态基准URL
                        previewUrl = '<?= $this->fetchTemplateStatic("GuoLaiRen_PageBuilder::") ?>' + pv.replace(/^style\//, 'templates/style/');
                    }
                }
                
                fieldHtml += `<div class="color-scheme-item ${isSelected ? 'selected' : ''}" 
                        data-scheme-key="${escapeHtmlForTemplate(schemeKey)}" 
                        onclick="selectColorScheme('${fieldId}', '${escapeHtmlForTemplate(schemeKey)}')">`;
                
                // 预览图或渐变色背景
                if (previewUrl) {
                    fieldHtml += `<div class="color-scheme-preview">`;
                    fieldHtml += `<img src="${previewUrl}" alt="${escapeHtmlForTemplate(scheme.display_name)}" 
                            onerror="this.style.display='none'">`;
                    fieldHtml += `</div>`;
                } else if (scheme.gradient_colors && scheme.gradient_colors.length >= 2) {
                    // 使用渐变色作为背景
                    const gradientColors = scheme.gradient_colors;
                    const gradientStr = gradientColors.join(', ');
                    fieldHtml += `<div class="color-scheme-preview gradient-preview" 
                            style="background: linear-gradient(135deg, ${gradientStr});">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                } else {
                    // 无预览图也无渐变色时显示默认占位符
                    fieldHtml += `<div class="color-scheme-preview no-image">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                }
                
                // 选中标记
                fieldHtml += `<div class="color-scheme-check ${isSelected ? 'active' : ''}">`;
                fieldHtml += `<i class="mdi mdi-check-circle"></i>`;
                fieldHtml += `</div>`;
                
                // 名称和描述
                fieldHtml += `<div class="color-scheme-info">`;
                fieldHtml += `<div class="color-scheme-name">${escapeHtmlForTemplate(scheme.display_name)}</div>`;
                if (scheme.description) {
                    fieldHtml += `<div class="color-scheme-desc">${escapeHtmlForTemplate(scheme.description)}</div>`;
                }
                fieldHtml += `</div>`;
                
                fieldHtml += `</div>`;
            }
            
            fieldHtml += `</div>`;
            fieldHtml += `</div>`;
        } else if (config.type === 'color') {
            fieldHtml += `<input type="color" id="${fieldId}" class="form-control form-control-color auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
        } else if (config.type === 'textarea') {
            fieldHtml += `<textarea id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" rows="3">${escapeHtmlForTemplate(rawValue)}</textarea>`;
        } else if (config.type === 'select' && config.options) {
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}">`;
            for (const optValue in config.options) {
                fieldHtml += `<option value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'selected' : ''}>${escapeHtmlForTemplate(config.options[optValue])}</option>`;
            }
            fieldHtml += `</select>`;
        } else if (config.type === 'radio' && config.options) {
            // Radio 类型
            for (const optValue in config.options) {
                const optLabel = config.options[optValue];
                fieldHtml += `<div class="form-check">`;
                fieldHtml += `<input type="radio" id="${fieldId}_${optValue}" class="form-check-input auto-save-field" 
                        name="${fieldId}" data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'checked' : ''}>`;
                fieldHtml += `<label class="form-check-label" for="${fieldId}_${optValue}">${escapeHtmlForTemplate(optLabel)}</label>`;
                fieldHtml += `</div>`;
            }
        } else {
            fieldHtml += `<input type="${config.type || 'text'}" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || '')}">`;
        }
        
        fieldHtml += `</div>`;
        return fieldHtml;
    }
    
    // 辅助函数：渲染单个配置分组
    function renderConfigGroup(fileKey, groupKey, group, isColorScheme = false) {
        const sectionId = 'config_' + fileKey + '_' + groupKey;
        let groupHtml = `<div class="config-section ${isColorScheme ? 'color-scheme-section' : ''}" id="${sectionId}">`;
        try { console.log('[VisualConfig] 渲染分组:', { fileKey, groupKey, isColorScheme, configsCount: group && group.configs ? Object.keys(group.configs).length : 0 }); } catch (_) {}
        
        // 配色方案分组：不可折叠，不显示折叠图标
        if (isColorScheme) {
            groupHtml += `<div class="config-section-header" style="cursor: default;">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'palette'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `</div>`;
        } else {
            groupHtml += `<div class="config-section-header" onclick="toggleSection('${sectionId}')">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'cog'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `<i class="mdi mdi-chevron-down"></i>`;
            groupHtml += `</div>`;
        }
        
        groupHtml += `<div class="config-section-body" ${isColorScheme ? 'style="display: block !important;"' : ''}>`;
        
        if (group.configs && typeof group.configs === 'object') {
            for (const configKey in group.configs) {
                const config = group.configs[configKey];
                groupHtml += renderConfigField(configKey, config);
            }
        }
        
        groupHtml += `</div></div>`;
        return groupHtml;
    }
    
    // 收集所有配置分组，确保色系配置（fileKey === 'color_scheme'）渲染在最顶部
    let html = '';
    const orderedFileKeys = Object.keys(configGroups || {});
    // 将 color_scheme 提前
    const idx = orderedFileKeys.indexOf('color_scheme');
    if (idx > 0) {
        orderedFileKeys.splice(idx, 1);
        orderedFileKeys.unshift('color_scheme');
    }
    
    for (const fileKey of orderedFileKeys) {
        const fileGroup = configGroups[fileKey];
        if (!fileGroup) continue;
        const isColorSchemeFile = fileKey === 'color_scheme';
        if (fileGroup.groups && typeof fileGroup.groups === 'object' && Object.keys(fileGroup.groups).length > 0) {
            for (const groupKey in fileGroup.groups) {
                const group = fileGroup.groups[groupKey];
                html += renderConfigGroup(fileKey, groupKey, group, isColorSchemeFile);
            }
        }
    }
    
    const configFields = document.querySelector('.config-panel-body');
    if (configFields) {
        configFields.innerHTML = html || '<div class="alert alert-info m-3"><?= __('暂无配置项') ?></div>';
        
        // 绑定自动保存事件（就地绑定，确保动态渲染后立即生效）
        document.querySelectorAll('.auto-save-field').forEach(field => {
            const handler = function() {
                if (typeof updateSaveStatus === 'function') {
                    updateSaveStatus('', '<?= __('未保存') ?>');
                }
                if (typeof autoSaveConfig === 'function') {
                    autoSaveConfig();
                }
            };
            field.removeEventListener('input', handler);
            field.removeEventListener('change', handler);
            field.addEventListener('input', handler, { passive: true });
            field.addEventListener('change', handler, { passive: true });
        });
        
        // 为每个配置分组添加恢复默认值按钮（在分组标题旁边）
        document.querySelectorAll('.config-section').forEach(section => {
            const header = section.querySelector('.config-section-header span');
            const resetButtons = section.querySelectorAll('.visual-config-reset-btn');
            
            if (header && resetButtons.length > 0) {
                // 检查是否已经有批量恢复按钮
                if (!section.querySelector('.reset-all-fields-btn')) {
                    const resetAllBtn = document.createElement('a');
                    resetAllBtn.href = 'javascript:void(0)';
                    resetAllBtn.className = 'link-danger ms-2 reset-all-fields-btn';
                    resetAllBtn.innerHTML = '<i class="mdi mdi-restore"></i> <?= __('恢复全部') ?>';
                    resetAllBtn.title = '<?= __('恢复此分组所有字段为默认值') ?>';
                    resetAllBtn.onclick = function(e) {
                        e.stopPropagation();
                        resetVisualConfigGroup(section);
                    };
                    header.appendChild(resetAllBtn);
                }
            }
        });
    }
}

// 模板配置模式：刷新模板预览（别名，保持兼容）
function refreshTemplatePreview() {
    refreshPreview();
}

// 模板配置模式：刷新配置（重新扫描模板字段）
function refreshTemplateConfig(event) {
    const btn = event ? event.target.closest('button') : document.querySelector('button[onclick*="refreshTemplateConfig"]');
    if (!btn) return;
    
    const icon = btn.querySelector('i');
    const originalClass = icon.className;
    
    btn.disabled = true;
    icon.className = 'mdi mdi-loading mdi-spin';
    
    const configPanel = document.querySelector('.config-panel-body');
    if (configPanel) {
        configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('正在刷新配置...') ?></div></div>';
    }
    
    loadTemplateStyleConfig(true)
        .then(() => {
            console.log('✅ 配置刷新成功');
            refreshTemplatePreview();
        })
        .catch(error => {
