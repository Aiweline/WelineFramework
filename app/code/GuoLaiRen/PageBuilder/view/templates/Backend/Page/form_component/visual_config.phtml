async function handleConfigImport(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    try {
        const formData = new FormData();
        formData.append('config_file', file);
        
        let pageId = window.pageId || 0;
        let styleCode = '';
        let url = '';
        
        if (window.isTemplateConfigMode) {
            pageId = window.currentTemplatePageId || 0;
            styleCode = window.currentTemplateStyleCode || '';
            url = '<?= $this->getBackendUrl("*/backend/template/importConfig") ?>';
            formData.append('style_code', styleCode);
            formData.append('page_id', pageId);
        } else {
            pageId = window.visualPageId || pageId;
            const styleSelect = document.getElementById('style');
            styleCode = styleSelect ? styleSelect.value : '';
            url = '<?= $this->getBackendUrl("pagebuilder/backend/page/importConfig") ?>';
            formData.append('page_id', pageId);
            formData.append('style_code', styleCode);
        }
        
        // 显示加载状态
        const importBtn = document.getElementById('importConfigBtn');
        const originalHtml = importBtn ? importBtn.innerHTML : '';
        if (importBtn) {
            importBtn.disabled = true;
            importBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("导入中...") ?>';
        }
        
        const response = await fetch(url, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin'
        });
        
        const result = await response.json();
        
        if (result.success) {
            if (typeof showToast === 'function') {
                showToast('success', '<?= __("导入成功") ?>', result.message || '<?= __("配置已导入") ?>');
            } else {
                alert('<?= __("导入成功") ?>: ' + (result.message || '<?= __("配置已导入") ?>'));
            }
            
            // 重新加载配置
            if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                loadTemplateStyleConfig().then(() => {
                    refreshPreview();
                });
            } else if (typeof loadVisualStyleConfig === 'function') {
                loadVisualStyleConfig().then(() => {
                    if (typeof refreshVisualPreview === 'function') {
                        refreshVisualPreview();
                    } else {
                        refreshPreview();
                    }
                });
            }
        } else {
            throw new Error(result.message || '<?= __("导入失败") ?>');
        }
        
        // 恢复按钮状态
        if (importBtn) {
            importBtn.innerHTML = originalHtml;
            importBtn.disabled = false;
        }
        
        // 清空文件输入
        event.target.value = '';
    } catch (error) {
        console.error('导入配置失败:', error);
        if (typeof showToast === 'function') {
            showToast('error', '<?= __("导入失败") ?>', error.message || '<?= __("未知错误") ?>');
        } else {
            alert('<?= __("导入失败") ?>: ' + (error.message || '<?= __("未知错误") ?>'));
        }
        
        // 恢复按钮状态
        const importBtn = document.getElementById('importConfigBtn');
        if (importBtn) {
            importBtn.disabled = false;
            importBtn.innerHTML = '<i class="mdi mdi-upload"></i> <?= __("导入配置") ?>';
        }
        
        // 清空文件输入
        event.target.value = '';
    }
}

// ========== 恢复默认值功能 ==========
/**
 * 恢复单个配置字段为默认值
 */
window.resetVisualConfigField = function(button) {
    const fieldId = button.getAttribute('data-field-id');
    const fieldType = button.getAttribute('data-config-type');
    const defaultValue = button.getAttribute('data-default-value');
    const configKey = button.getAttribute('data-config-key');
    
    console.log('🔄 恢复默认值:', { fieldId, fieldType, defaultValue, configKey });
    
    const field = document.getElementById(fieldId);
    if (!field) {
        console.error('❌ 找不到字段:', fieldId);
        return;
    }
    
    // 根据字段类型进行不同的处理
    switch (fieldType) {
        case 'text':
        case 'number':
        case 'responsive':
        case 'textarea':
            // 文本类型：设置为默认值（如果为空则清空）
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'select':
            // 下拉框：设置为默认值或第一个选项
            if (defaultValue) {
                // 尝试找到并选择默认值
                for (let i = 0; i < field.options.length; i++) {
                    if (field.options[i].value === defaultValue) {
                        field.selectedIndex = i;
                        break;
                    }
                }
            } else {
                field.selectedIndex = 0;
            }
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'radio':
            // Radio 类型：选择默认值对应的 radio
            if (defaultValue) {
                const radioField = document.querySelector(`input[name="${fieldId}"][value="${defaultValue}"]`);
                if (radioField) {
                    radioField.checked = true;
                    radioField.dispatchEvent(new Event('change', { bubbles: true }));
                }
            } else {
                // 如果没有默认值，选择第一个
                const firstRadio = document.querySelector(`input[name="${fieldId}"]`);
                if (firstRadio) {
                    firstRadio.checked = true;
                    firstRadio.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
            break;
            
        case 'color':
            // 颜色选择器：直接设置值
            field.value = defaultValue || '#ffffff';
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
        
        case 'color_scheme':
            // 色系选择：调用选择函数以更新隐藏输入与UI
            if (typeof window.selectColorScheme === 'function') {
                const schemeKey = defaultValue || 'default';
                window.selectColorScheme(fieldId, schemeKey);
            } else {
                // 后备：直接写值并触发保存
                field.value = defaultValue || 'default';
                field.dispatchEvent(new Event('change', { bubbles: true }));
                if (typeof window.autoSaveConfig === 'function') {
                    window.autoSaveConfig(true);
                }
            }
            break;
            
        default:
            // 其他类型：设置为默认值
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
    }
    
    // 显示提示信息
    if (typeof showToast === 'function') {
        showToast('success', '<?= __('成功') ?>', '<?= __('已恢复为默认值') ?>');
    } else {
        console.log('✅ 字段已恢复默认值');
    }
};

/**
 * 显示恢复默认值确认模态框
 */
function showResetConfigConfirmModal(title, message, details, onConfirm) {
    // 检查 bootstrap 是否可用
    if (typeof bootstrap === 'undefined') {
        console.error('❌ Bootstrap 未加载！');
        if (confirm(message)) {
            onConfirm();
        }
        return;
    }
    
    const modalElement = document.getElementById('resetConfigConfirmModal');
    if (!modalElement) {
        console.error('❌ 找不到确认模态框');
        if (confirm(message)) {
            onConfirm();
        }
        return;
    }
    
    // 设置模态框内容
    document.getElementById('resetConfigMessage').textContent = message;
    const detailsEl = document.getElementById('resetConfigDetails');
    if (details) {
        detailsEl.innerHTML = details;
        detailsEl.style.display = 'block';
    } else {
        detailsEl.style.display = 'none';
    }
    
    // 移除旧的确认按钮事件监听器
    const confirmBtn = document.getElementById('confirmResetConfigBtn');
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
    
    // 绑定新的确认事件
    newConfirmBtn.onclick = function() {
        const modal = bootstrap.Modal.getInstance(modalElement);
        if (modal) {
            modal.hide();
        }
        onConfirm();
    };
    
    // 显示模态框
    const modal = new bootstrap.Modal(modalElement);
    modal.show();
}

/**
 * 恢复整个配置分组的所有字段为默认值
 */
window.resetVisualConfigGroup = function(section) {
    if (!section) return;
    
    const resetButtons = section.querySelectorAll('.visual-config-reset-btn');
    if (resetButtons.length === 0) {
        if (typeof showToast === 'function') {
            showToast('info', '<?= __('提示') ?>', '<?= __('此分组没有可恢复的字段') ?>');
        }
        return;
    }
    
    const header = section.querySelector('.config-section-header span');
    const groupLabel = header ? header.textContent.replace(/恢复全部.*/g, '').trim() : '此分组';
    
    // 显示确认模态框
    showResetConfigConfirmModal(
        '<?= __('确认恢复分组') ?>',
        `<?= __('确定要恢复') ?> "${groupLabel}" <?= __('下所有字段为默认值吗？') ?>`,
        `<i class="mdi mdi-alert"></i> <?= __('这将影响') ?> <strong>${resetButtons.length}</strong> <?= __('个字段！修改将自动保存。') ?>`,
        async function() {
            try {
                // 收集需要重置的字段的 configKey
                const configKeys = [];
                
                resetButtons.forEach(button => {
                    const configKey = button.getAttribute('data-config-key');
                    if (configKey) {
                        configKeys.push(configKey);
                    }
                });
                
                console.log(`✅ 已收集 ${configKeys.length} 个配置键:`, configKeys);
                
                // 更新保存状态
                updateSaveStatus('saving', '<?= __('重置中...') ?>');
                
                let url = '';
                let requestData = {};
                
                if (window.isTemplateConfigMode) {
                    // 模板配置模式
                    url = '<?= $this->getBackendUrl('*/backend/template/resetFieldsToDefault') ?>';
                    requestData = {
                        style_code: window.currentTemplateStyleCode || '',
                        page_id: window.currentTemplatePageId || 0,
                        config_keys: configKeys
                    };
                } else {
                    // 正常页面配置模式
                    url = '<?= $this->getBackendUrl('pagebuilder/backend/preview/resetFieldsToDefault') ?>';
                    const styleSelect = document.getElementById('style');
                    let styleCode = styleSelect ? styleSelect.value : '';
                    requestData = {
                        page_id: window.visualPageId || window.pageId || 0,
                        style_code: styleCode,
                        config_keys: configKeys,
                        locale: window.currentVisualLanguage || ''
                    };
                }
                
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(requestData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    console.log('✅ 重置成功，重新加载配置...');
                    
                    // 重新加载配置
                    if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                        await loadTemplateStyleConfig();
                    } else if (typeof loadVisualStyleConfig === 'function') {
                        await loadVisualStyleConfig();
                    }
                    
                    // 刷新预览
                    refreshPreview();
                    
                    updateSaveStatus('saved', '<?= __('已重置') ?>');
                    if (typeof showToast === 'function') {
                        showToast('success', '<?= __('成功') ?>', `<?= __('已恢复') ?> ${result.reset_count || configKeys.length} <?= __('个字段为默认值') ?>`);
                    }
                } else {
                    updateSaveStatus('error', '<?= __('重置失败') ?>: ' + (result.message || ''));
                    console.error('❌ 重置失败:', result);
                    if (typeof showToast === 'function') {
                        showToast('error', '<?= __('失败') ?>', result.message || '<?= __('重置失败') ?>');
                    }
                }
            } catch (error) {
                console.error('❌ 重置失败:', error);
                updateSaveStatus('error', '<?= __('重置失败') ?>');
                if (typeof showToast === 'function') {
                    showToast('error', '<?= __('失败') ?>', error.message || '<?= __('重置失败') ?>');
                }
            }
        }
    );
};

// ========== 配置项搜索功能 ==========
/**
 * 搜索配置字段
 * @param {string} searchTerm - 搜索关键词
 */
window.searchConfigFields = function(searchTerm) {
    const searchBox = document.querySelector('.config-search-box');
    const searchInput = document.getElementById('configSearchInput');
    
    if (!searchTerm || searchTerm.trim() === '') {
        // 清空搜索
        clearConfigSearch();
        return;
    }
    
    // 更新搜索框状态
    if (searchBox) {
        searchBox.classList.add('has-value');
    }
    
    const term = searchTerm.trim().toLowerCase();
    const allFields = document.querySelectorAll('.config-field-item');
    const allSections = document.querySelectorAll('.config-section');
    const sectionVisibility = new Map(); // 记录每个section是否有可见字段
    
    // 遍历所有配置字段
    allFields.forEach(function(field) {
        const configKey = (field.getAttribute('data-config-key') || '').toLowerCase();
        const configLabel = (field.getAttribute('data-config-label') || '').toLowerCase();
        const configDescription = (field.getAttribute('data-config-description') || '').toLowerCase();
        
        // 模糊匹配：检查 key、label 或 description 是否包含搜索词
        const matches = configKey.includes(term) || 
                       configLabel.includes(term) || 
                       configDescription.includes(term);
        
        if (matches) {
            // 显示字段
            field.classList.remove('config-field-hidden');
            
            // 高亮匹配的文本（在 label 中）
            const label = field.querySelector('label');
            if (label) {
                // 保存原始 HTML（如果还没有保存）
                if (!label.hasAttribute('data-original-html')) {
                    label.setAttribute('data-original-html', label.innerHTML);
                }
                
                // 先移除之前的高亮
                let labelHTML = label.getAttribute('data-original-html') || label.innerHTML || '';
                labelHTML = labelHTML.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
                
                // 提取文本部分（不包括恢复按钮）
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = labelHTML;
                const restoreBtn = tempDiv.querySelector('.visual-config-reset-btn');
                const restoreBtnHTML = restoreBtn ? restoreBtn.outerHTML : '';
                tempDiv.querySelectorAll('.visual-config-reset-btn').forEach(btn => btn.remove());
                const textOnly = tempDiv.textContent || '';
                
                // 高亮文本
                const highlightedText = highlightSearchTerm(textOnly, term);
                if (highlightedText !== textOnly) {
                    label.innerHTML = highlightedText + (restoreBtnHTML ? ' ' + restoreBtnHTML : '');
                } else {
                    label.innerHTML = labelHTML; // 恢复原始 HTML
                }
            }
            
            // 记录该字段所属的 section 有可见字段
            const section = field.closest('.config-section');
            if (section) {
                const sectionId = section.id;
                sectionVisibility.set(sectionId, true);
            }
        } else {
            // 隐藏字段
            field.classList.add('config-field-hidden');
        }
    });
    
    // 更新 section 的可见性
    allSections.forEach(function(section) {
        const sectionId = section.id;
        const hasVisibleFields = sectionVisibility.get(sectionId) || false;
        
        if (hasVisibleFields) {
            section.classList.remove('config-section-empty');
            // 自动展开匹配的 section
            const sectionBody = section.querySelector('.config-section-body');
            if (sectionBody && sectionBody.style.display === 'none') {
                sectionBody.style.display = '';
                const chevron = section.querySelector('.config-section-header i.mdi-chevron-down, .config-section-header i.mdi-chevron-right');
                if (chevron) {
                    chevron.classList.remove('mdi-chevron-right');
                    chevron.classList.add('mdi-chevron-down');
                }
            }
        } else {
            section.classList.add('config-section-empty');
        }
    });
};

/**
 * 高亮搜索关键词
 * @param {string} text - 原始文本
 * @param {string} term - 搜索关键词
 * @returns {string} 高亮后的文本
 */
function highlightSearchTerm(text, term) {
    if (!term || !text) return text;
    
    // 移除已有的高亮
    text = text.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
    
    // 创建正则表达式进行不区分大小写的匹配
    const regex = new RegExp('(' + escapeRegExp(term) + ')', 'gi');
    return text.replace(regex, '<span class="config-search-highlight">$1</span>');
}

/**
 * 转义正则表达式特殊字符
 * @param {string} str - 要转义的字符串
 * @returns {string} 转义后的字符串
 */
function escapeRegExp(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

/**
 * 清空搜索
 */
window.clearConfigSearch = function() {
    const searchInput = document.getElementById('configSearchInput');
    const searchBox = document.querySelector('.config-search-box');
    
    if (searchInput) {
        searchInput.value = '';
    }
    
    if (searchBox) {
        searchBox.classList.remove('has-value');
    }
    
    // 显示所有字段
    const allFields = document.querySelectorAll('.config-field-item');
    allFields.forEach(function(field) {
        field.classList.remove('config-field-hidden');
        
        // 恢复原始 HTML（移除高亮）
        const label = field.querySelector('label');
        if (label) {
            // 如果有保存的原始 HTML，使用它；否则移除高亮标签
            const originalHTML = label.getAttribute('data-original-html');
            if (originalHTML) {
                label.innerHTML = originalHTML;
                label.removeAttribute('data-original-html');
            } else {
                // 移除高亮标签，保留其他 HTML
                let labelHTML = label.innerHTML || '';
                labelHTML = labelHTML.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
                label.innerHTML = labelHTML;
            }
        }
    });
    
    // 恢复所有 section 的可见性
    const allSections = document.querySelectorAll('.config-section');
    allSections.forEach(function(section) {
        section.classList.remove('config-section-empty');
    });
};
</script>

