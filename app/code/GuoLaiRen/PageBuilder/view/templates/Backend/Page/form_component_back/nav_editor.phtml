       value="<?= htmlspecialchars($navItemsConfig) ?>">

<script>
(function() {
    const navList = document.getElementById('navItemsList');
    const navHidden = document.getElementById('navItemsHidden');
    
    // 序列化导航项
    function serializeNavItems() {
        const items = [];
        navList.querySelectorAll('.nav-item-row').forEach(row => {
            const text = row.querySelector('.nav-item-text').value.trim();
            const href = row.querySelector('.nav-item-href').value.trim();
            if (text) {
                items.push(text + '=>' + (href || '#'));
            }
        });
        return items.join('\n');
    }
    
    // 更新隐藏字段
    function updateHiddenField() {
        navHidden.value = serializeNavItems();
        // 触发 change 事件以便自动保存
        navHidden.dispatchEvent(new Event('change', { bubbles: true }));
    }
    
    // 添加导航项
    window.addNavItem = function() {
        const row = document.createElement('li');
        row.className = 'nav-item-row';
        row.draggable = true;
        row.innerHTML = `
            <span class="nav-item-drag"><i class="mdi mdi-drag"></i></span>
            <input type="text" class="nav-item-text" value="" placeholder="<?= __('名称') ?>">
            <input type="text" class="nav-item-href" value="#" placeholder="<?= __('链接') ?>">
            <select class="nav-item-type">
                <option value="anchor" selected><?= __('锚点') ?></option>
                <option value="page"><?= __('页面') ?></option>
                <option value="external"><?= __('外部') ?></option>
            </select>
            <div class="nav-item-actions">
                <button type="button" class="btn-danger" onclick="removeNavItem(this)" title="<?= __('删除') ?>">
                    <i class="mdi mdi-delete"></i>
                </button>
            </div>
        `;
        
        navList.appendChild(row);
        setupRowEvents(row);
        row.querySelector('.nav-item-text').focus();
    };
    
    // 删除导航项
    window.removeNavItem = function(btn) {
        const row = btn.closest('.nav-item-row');
        row.remove();
        updateHiddenField();
    };
    
    // 设置行事件
    function setupRowEvents(row) {
        // 输入事件
        row.querySelectorAll('input, select').forEach(input => {
            input.addEventListener('input', updateHiddenField);
            input.addEventListener('change', updateHiddenField);
        });
        
        // 拖拽事件
        row.addEventListener('dragstart', handleDragStart);
        row.addEventListener('dragend', handleDragEnd);
        row.addEventListener('dragover', handleDragOver);
        row.addEventListener('drop', handleDrop);
    }
    
    // 拖拽处理
    let draggedRow = null;
    
    function handleDragStart(e) {
        draggedRow = this;
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
    }
    
    function handleDragEnd(e) {
        this.classList.remove('dragging');
        navList.querySelectorAll('.nav-item-row').forEach(row => {
            row.classList.remove('drag-over');
        });
        draggedRow = null;
        updateHiddenField();
    }
    
    function handleDragOver(e) {
        e.preventDefault();
        if (this !== draggedRow) {
            this.classList.add('drag-over');
        }
    }
    
    function handleDrop(e) {
        e.preventDefault();
        this.classList.remove('drag-over');
        
        if (draggedRow && this !== draggedRow) {
            const allRows = [...navList.querySelectorAll('.nav-item-row')];
            const draggedIndex = allRows.indexOf(draggedRow);
            const droppedIndex = allRows.indexOf(this);
            
            if (draggedIndex < droppedIndex) {
                this.parentNode.insertBefore(draggedRow, this.nextSibling);
            } else {
                this.parentNode.insertBefore(draggedRow, this);
            }
        }
    }
    
    // 初始化现有行的事件
    navList.querySelectorAll('.nav-item-row').forEach(setupRowEvents);
})();
</script>
