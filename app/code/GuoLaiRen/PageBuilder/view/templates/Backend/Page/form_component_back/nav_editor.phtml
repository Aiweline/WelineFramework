/**
 * 导航编辑器组件 - Navigation Editor
 * 
 * 支持：
 * 1. 可视化编辑导航项
 * 2. 拖拽排序
 * 3. 添加/编辑/删除导航项
 * 4. 支持链接类型：锚点、页面、外部链接
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 */

$page = $this->getData('page');
$pageId = $page && $page->getId() ? $page->getId() : 0;
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 获取当前导航配置
$navItemsConfig = $styleSettings['header.navigation.items'] ?? $styleSettings['navigation.items'] ?? '';
if (empty($navItemsConfig)) {
    $navItemsConfig = "Home=>#home\nAbout=>#about\nBlog=>#blog\nFAQs=>#faqs";
}

// 解析导航项
$navItems = [];
if (!empty($navItemsConfig)) {
    $lines = preg_split('/\r?\n/', str_replace('\\n', "\n", $navItemsConfig));
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line)) continue;
        if (strpos($line, '=>') !== false) {
            $parts = explode('=>', $line, 2);
            $text = trim($parts[0]);
            $href = \GuoLaiRen\PageBuilder\Helper\PageHelper::normalizeAnchorUrl(trim($parts[1] ?? '') ?: '#');
            if (!empty($text)) {
                $navItems[] = [
                    'text' => $text,
                    'href' => $href,
                    'type' => $this->getNavItemType($href)
                ];
            }
        }
    }
}

// 辅助函数：判断链接类型
if (!function_exists('getNavItemType')) {
    function getNavItemType($href) {
        if (empty($href) || $href === '#') return 'anchor';
        if (strpos($href, '#') === 0) return 'anchor';
        if (preg_match('/^https?:\/\//', $href)) return 'external';
        return 'page';
    }
}
?>

