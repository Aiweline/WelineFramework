</style>

<div class="asset-manager-modal" id="assetManagerModal">
    <div class="asset-manager-content">
        <div class="asset-manager-header">
            <strong><i class="mdi mdi-folder"></i> <?= __('文件管理器') ?></strong>
            <div>
                <button type="button" class="btn btn-sm btn-light" onclick="closeAssetManager()"><i class="mdi mdi-close"></i> <?= __('关闭') ?></button>
            </div>
        </div>
        <div class="asset-manager-toolbar" id="assetManagerToolbar">
            <span class="small text-muted"><?= __('目录') ?>: <span class="asset-path" id="assetPathText"></span></span>
        </div>
        <div class="asset-manager-body" id="assetListBody">
            <div class="p-4 text-center text-muted"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></div>
        </div>
    </div>
</div>

<!-- 图片预览弹窗 -->
<div class="image-preview-modal" id="imagePreviewModal" onclick="closeImagePreview()">
    <div class="image-preview-content" onclick="event.stopPropagation()">
        <button type="button" class="image-preview-close" onclick="closeImagePreview()" title="<?= __('关闭') ?>">×</button>
        <img id="imagePreviewImg" src="" alt="">
        <div class="image-preview-info" id="imagePreviewInfo"></div>
    </div>
</div>

<script>
(function(){
    var WELINE_MEDIA_DIR_PREFIX = '<?= $weline_media_dir_prefix ?>';
    var MEDIA_IFRAME_BASE = '<?= $media_iframe_base_url ?>';

    function getCurrentHandle(){
        var hEl = document.getElementById('handle');
        var val = hEl ? (hEl.value || '').trim() : '';
        if (!val && <?= ($this->getData('page') && $this->getData('page')->getId()) ? 'true' : 'false' ?>) {
            return '<?= $this->getData('page') ? htmlspecialchars((($this->getData('page') ?? '')->getData('handle')) ?? '') : '' ?>';
        }
        return val;
    }

    window.openAssetManager = function() {
        var modal = document.getElementById('assetManagerModal');
        var body = document.getElementById('assetListBody');
        var pathText = document.getElementById('assetPathText');
        if (!modal || !body) return;

        var handle = getCurrentHandle();
        if (!handle) {
            body.innerHTML = '<div class="alert alert-warning m-3"><?= __('请先填写页面句柄 handle') ?></div>';
            if (pathText) pathText.textContent = '';
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
            return;
        }

        var startPath = WELINE_MEDIA_DIR_PREFIX + '/' + handle;
        var url = MEDIA_IFRAME_BASE + (MEDIA_IFRAME_BASE.indexOf('?') >= 0 ? '&' : '?') +
            'startPath=' + encodeURIComponent(startPath) + '&lockPath=1';
        body.innerHTML = '<iframe id="assetManagerIframe" src="' + (url.replace(/"/g, '&quot;')) + '" style="width:100%;height:70vh;min-height:400px;border:0" title="<?= __('媒体管理器') ?>"></iframe>';
        if (pathText) pathText.textContent = '/pub/media/' + startPath;
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
    };

    window.closeAssetManager = function() {
        var modal = document.getElementById('assetManagerModal');
        var body = document.getElementById('assetListBody');
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        }
        if (body) {
            body.innerHTML = '<div class="p-4 text-center text-muted"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></div>';
        }
    };

    window.copyAssetUrl = function(url){
        if (navigator.clipboard && navigator.clipboard.writeText){
            navigator.clipboard.writeText(url).then(function(){
                if (typeof BackendToast !== 'undefined') BackendToast.success('<?= __('已复制') ?>');
                else if (typeof showToast === 'function') showToast('success', '<?= __('已复制') ?>', url);
            });
        } else {
            var ta = document.createElement('textarea');
            ta.value = url; document.body.appendChild(ta); ta.select();
            try{ document.execCommand('copy'); if (typeof BackendToast !== 'undefined') BackendToast.success('<?= __('已复制') ?>'); }catch(_){}
            document.body.removeChild(ta);
        }
    };

    // 图片预览功能（供其他选择器回调等使用）
    window.previewImage = function(url, name) {
        const modal = document.getElementById('imagePreviewModal');
        const img = document.getElementById('imagePreviewImg');
        const info = document.getElementById('imagePreviewInfo');
        if (modal && img) {
            img.src = url;
            img.alt = name || '';
            if (info) {
                info.textContent = name || '';
            }
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    };
    
    window.closeImagePreview = function() {
        const modal = document.getElementById('imagePreviewModal');
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
            // 清空图片源，释放内存
            const img = document.getElementById('imagePreviewImg');
            if (img) {
                img.src = '';
            }
        }
    };
    
    // ESC 键关闭预览
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            const modal = document.getElementById('imagePreviewModal');
            if (modal && modal.classList.contains('active')) {
                closeImagePreview();
            }
        }
    });
})();
</script>


