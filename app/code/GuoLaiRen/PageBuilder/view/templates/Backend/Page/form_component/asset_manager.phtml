<?php
/**
 * 可视化文件管理器 - 接入 weline_media (MediaManager)
 *
 * dir 约定（用于 MediaManager startPath，根为 pub/media）：
 *   pagebuilder/pages/{handle}
 * - 按页面 handle 隔离，便于按页面导出/备份
 * - handle 为空时使用 pagebuilder/common 或提示先填写
 */
$weline_media_dir_prefix = 'pagebuilder/pages';
$media_iframe_base_url = $this->getBackendUrl('media/backend/manager', ['iframe' => '1'], true);
?>
<!-- 文件管理器样式与弹窗 -->
