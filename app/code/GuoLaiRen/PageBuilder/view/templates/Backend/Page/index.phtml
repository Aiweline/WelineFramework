    // 执行删除站点（错误信息用 BackendToast 展示，支持 HTML）
    function deleteSite(pageId, pageName, button) {
        const originalHtml = button.innerHTML;
        const originalDisabled = button.disabled;
        
        button.disabled = true;
        button.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __("删除中...") ?>';
        
        var url = '<?= $this->getBackendUrl("*/backend/page/deleteSite") ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ id: pageId }) };
        var req = window.Weline.Api.request(url, opts);
        req.then(function(res) {
            var data = (res && res.data) || res;
            if (data.success) {
                showToast('success', '<?= __("删除成功") ?>', data.message || ('<?= __("站点") ?> "' + pageName + '" <?= __("已删除") ?>'));
                setTimeout(() => { window.location.reload(); }, 1500);
            } else {
                button.disabled = originalDisabled;
                button.innerHTML = originalHtml;
                if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("删除失败") ?>: ' + (data.message || '<?= __("未知错误") ?>'), { html: true });
                else showToast('error', '<?= __("删除失败") ?>', data.message || '<?= __("未知错误") ?>');
            }
        })
        .catch(error => {
            console.error('删除站点失败:', error);
            button.disabled = originalDisabled;
            button.innerHTML = originalHtml;
            var errMsg = '<?= __("网络错误，请重试") ?>';
            if (error && error.response) {
                if (error.response.data && typeof error.response.data.message === 'string') errMsg = error.response.data.message;
                else if (typeof error.response.data === 'string') errMsg = error.response.data;
                else if (error.responseText) errMsg = error.responseText;
            } else if (error && error.message) errMsg = error.message;
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("删除失败") ?>: ' + errMsg, { html: true });
            else showToast('error', '<?= __("删除失败") ?>', errMsg);
        });
    }
    
    // ============ 单页发布 ============
    function publishPage(pageId, button) {
        if (!pageId) {
            if (typeof BackendToast !== 'undefined') BackendToast.warning('<?= __("页面ID不存在") ?>');
            return;
        }
        var originalHtml = button.innerHTML;
        var originalDisabled = button.disabled;
        button.disabled = true;
        button.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("发布中...") ?>';
        var url = '<?= $this->getBackendUrl("*/backend/page/publish") ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ id: pageId }) };
        window.Weline.Api.request(url, opts).then(function(res) {
            var data = (res && res.data) || res;
            if (data.success) {
                if (typeof BackendToast !== 'undefined') BackendToast.success(data.message || '<?= __("页面已发布") ?>');
                else showToast('success', '<?= __("发布成功") ?>', data.message || '');
                setTimeout(function() { window.location.reload(); }, 800);
            } else {
                button.disabled = originalDisabled;
                button.innerHTML = originalHtml;
                if (typeof BackendToast !== 'undefined') BackendToast.error(data.message || '<?= __("发布失败") ?>');
                else showToast('error', '<?= __("发布失败") ?>', data.message || '');
            }
        }).catch(function(error) {
            button.disabled = originalDisabled;
            button.innerHTML = originalHtml;
            var errMsg = (error && error.message) ? error.message : '<?= __("网络错误，请重试") ?>';
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("发布失败") ?>: ' + errMsg);
            else showToast('error', '<?= __("发布失败") ?>', errMsg);
        });
    }
    document.querySelectorAll('.publish-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var pageId = this.getAttribute('data-page-id');
            publishPage(pageId, this);
        });
    });
    
    // ============ 一键发布本站 ============
    var publishSiteConfirmBtn = document.getElementById('publishSiteConfirmBtn');
    var publishSiteModalEl = document.getElementById('publishSiteModal');
    if (publishSiteConfirmBtn && publishSiteModalEl) {
        publishSiteConfirmBtn.addEventListener('click', function() {
            var sel = document.getElementById('publishSiteWebsiteId');
            var websiteId = sel ? parseInt(sel.value, 10) : 0;
            if (!websiteId) {
                if (typeof BackendToast !== 'undefined') BackendToast.warning('<?= __("请选择要发布的站点") ?>');
                return;
            }
            BackendConfirm.show('<?= __("确定要发布该站点下所有页面吗？") ?>', {
                title: '<?= __("一键发布本站") ?>',
                confirmText: '<?= __("发布") ?>',
                cancelText: '<?= __("取消") ?>',
                type: 'info'
            }).then(function(confirmed) {
                if (!confirmed) return;
                var originalHtml = publishSiteConfirmBtn.innerHTML;
                var originalDisabled = publishSiteConfirmBtn.disabled;
                publishSiteConfirmBtn.disabled = true;
                publishSiteConfirmBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("发布中...") ?>';
                var url = '<?= $this->getBackendUrl("*/backend/page/publishSite") ?>';
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ website_id: websiteId }) };
                window.Weline.Api.request(url, opts).then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success) {
                        if (typeof BackendToast !== 'undefined') BackendToast.success(data.message || '<?= __("本站已发布") ?>');
                        else showToast('success', '<?= __("发布成功") ?>', data.message || '');
                        if (typeof bootstrap !== 'undefined' && publishSiteModalEl) {
                            var modal = bootstrap.Modal.getInstance(publishSiteModalEl);
                            if (modal) modal.hide();
                        }
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        publishSiteConfirmBtn.disabled = originalDisabled;
                        publishSiteConfirmBtn.innerHTML = originalHtml;
                        if (typeof BackendToast !== 'undefined') BackendToast.error(data.message || '<?= __("发布失败") ?>');
                        else showToast('error', '<?= __("发布失败") ?>', data.message || '');
                    }
                }).catch(function(error) {
                    publishSiteConfirmBtn.disabled = originalDisabled;
                    publishSiteConfirmBtn.innerHTML = originalHtml;
                    var errMsg = (error && error.message) ? error.message : '<?= __("网络错误，请重试") ?>';
                    if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("发布失败") ?>: ' + errMsg);
                    else showToast('error', '<?= __("发布失败") ?>', errMsg);
                });
            });
        });
    }
    
    // 导出页面功能（带loading）
    const exportButtons = document.querySelectorAll('.export-page-btn');
    exportButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const pageId = this.getAttribute('data-page-id');
            if (!pageId) {
                showToast('error', '<?= __("导出失败") ?>', '<?= __("页面ID不存在") ?>');
                return;
            }
            
            const originalHtml = this.innerHTML;
            const originalDisabled = this.disabled;
            
            // 显示loading状态
            this.disabled = true;
            this.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("导出中...") ?>';
            
            // 使用直接链接点击方式触发下载（最可靠的方式）
            const exportUrl = '<?= $this->getBackendUrl("*/backend/page/export") ?>?id=' + encodeURIComponent(pageId);
            
            // 创建一个临时的链接元素并点击
            const link = document.createElement('a');
            link.href = exportUrl;
            link.download = ''; // 让浏览器处理下载
            link.style.display = 'none';
            document.body.appendChild(link);
            
            // 立即点击触发下载
            link.click();
            
            // 由于导出过程可能需要较长时间（生成HTML、下载资源、创建ZIP），
            // 我们保持loading状态更长时间，让用户知道正在处理
            // 延迟恢复按钮状态（给用户看到loading反馈，同时给后端足够时间生成文件）
            setTimeout(function() {
                button.disabled = originalDisabled;
                button.innerHTML = originalHtml;
                
                // 清理链接
                if (link.parentNode) {
                    link.parentNode.removeChild(link);
                }
                
                showToast('success', '<?= __("导出成功") ?>', '<?= __("文件已开始下载，请查看浏览器下载列表") ?>');
            }, 3000); // 3秒后恢复，给后端足够时间开始输出文件
            
            // 设置超时保护，防止按钮永远处于loading状态
            setTimeout(function() {
                if (button.disabled && button.innerHTML.includes('<?= __("导出中...") ?>')) {
                    button.disabled = originalDisabled;
                    button.innerHTML = originalHtml;
                    
                    if (link.parentNode) {
                        link.parentNode.removeChild(link);
                    }
                    
                    showToast('info', '<?= __("导出处理中") ?>', '<?= __("文件可能较大，正在生成中，请稍候...") ?>');
                }
            }, 30000); // 30秒超时保护
        });
    });
    
    // ============ 一键建站功能 ============
    const quickSiteModal = document.getElementById('quickSiteModal');
    const btnNext = document.getElementById('btnNext');
    const btnPrev = document.getElementById('btnPrev');
    const btnCreate = document.getElementById('btnCreate');
    const btnCancel = document.getElementById('btnCancel');
    let currentStep = 1;
    let selectedWebsiteName = '';
    let selectedTemplateName = '';
    
    // 预览图生成队列
    let previewGenerationQueue = [];
    let isGeneratingPreviews = false;
    let globalUploadUrl = '';
    
    // 加载模板列表
    function loadTemplates() {
        const container = document.getElementById('templateSelector');
        var url = '<?= $this->getBackendUrl("*/backend/page/getStyles") ?>';
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function(res) {
            var data = (res && res.data) || res;
                if (data.success && data.data && data.data.length > 0) {
                    globalUploadUrl = data.upload_url || '';
                    let html = '';
                    previewGenerationQueue = []; // 清空队列
                    
                    data.data.forEach(style => {
                        const thumbnail = style.preview_image || '';
                        const needsPreview = style.needs_preview || false;
                        
                        let thumbnailHtml;
                        if (thumbnail) {
                            thumbnailHtml = `<img src="${thumbnail}" alt="${style.name}" onerror="this.parentNode.innerHTML='<i class=\\'mdi mdi-palette-outline pagebuilder-page-palette-icon\\'></i>'">`; 
                        } else if (needsPreview) {
                            thumbnailHtml = `<div class="preview-generating" data-style-code="${style.code}">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <small class="d-block mt-1" style="font-size:10px;"><?= __('生成中...') ?></small>
                            </div>`;
                            previewGenerationQueue.push({
                                code: style.code,
                                name: style.name,
                                preview_page_url: style.preview_page_url
                            });
                        } else {
                            thumbnailHtml = '<i class="mdi mdi-palette-outline pagebuilder-page-palette-icon"></i>';
                        }
                        
                        html += `
                            <div class="col-6 col-lg-4">
                                <div class="template-card" data-style-code="${style.code}" data-style-name="${style.name}" onclick="selectTemplate(this)">
                                    <div class="template-preview" id="preview-${style.code}">${thumbnailHtml}</div>
                                    <div class="template-info">
                                        <div class="template-name">${style.name}</div>
                                        <div class="template-desc text-truncate">${style.description || '<?= __("暂无描述") ?>'}</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    container.innerHTML = html;
                    
                    // 开始自动生成预览图
                    if (previewGenerationQueue.length > 0) {
                        processPreviewQueue();
                    }
                } else {
                    container.innerHTML = `
                        <div class="col-12 text-center py-4">
                            <i class="mdi mdi-alert-circle-outline text-warning" style="font-size:48px;"></i>
                            <p class="mt-2 text-muted"><?= __('暂无可用模板，请先创建模板') ?></p>
                        </div>
                    `;
                }
            })
            .catch(error => {
                console.error('加载模板失败:', error);
                container.innerHTML = `
                    <div class="col-12 text-center py-4">
                        <i class="mdi mdi-alert-circle-outline text-danger" style="font-size:48px;"></i>
                        <p class="mt-2 text-danger"><?= __('加载模板失败，请刷新页面重试') ?></p>
                    </div>
                `;
            });
    }
    
    // 处理预览图生成队列
    async function processPreviewQueue() {
        if (isGeneratingPreviews || previewGenerationQueue.length === 0) return;
        
        isGeneratingPreviews = true;
        
        // 动态加载 html2canvas
        if (typeof html2canvas === 'undefined') {
            await loadHtml2Canvas();
        }
        
        while (previewGenerationQueue.length > 0) {
            const task = previewGenerationQueue.shift();
            try {
                await generateSinglePreview(task);
            } catch (error) {
                console.error(`生成预览图失败 (${task.code}):`, error);
                // 更新UI显示失败状态
                const previewContainer = document.getElementById('preview-' + task.code);
                if (previewContainer) {
                    previewContainer.innerHTML = '<i class="mdi mdi-image-off text-muted" style="font-size:32px;"></i>';
                }
            }
            // 添加延迟避免过快请求
            await new Promise(resolve => setTimeout(resolve, 500));
        }
        
        isGeneratingPreviews = false;
    }
    
    // 动态加载 html2canvas
    function loadHtml2Canvas() {
        return new Promise((resolve, reject) => {
            if (typeof html2canvas !== 'undefined') {
                resolve();
                return;
            }
            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
        });
    }
    
    // 生成单个模板预览图
    async function generateSinglePreview(task) {
        return new Promise((resolve, reject) => {
            // 创建隐藏的 iframe 来加载预览页面
            const iframe = document.createElement('iframe');
            iframe.style.cssText = 'position:fixed;top:-10000px;left:-10000px;width:1200px;height:800px;border:none;';
            document.body.appendChild(iframe);
            
            iframe.onload = async function() {
                try {
                    // 等待页面完全渲染
                    await new Promise(r => setTimeout(r, 2000));
                    
                    // 截图
                    const canvas = await html2canvas(iframe.contentDocument.body, {
                        width: 1200,
                        height: 800,
                        scale: 0.5,
                        useCORS: true,
                        allowTaint: true,
                        logging: false
                    });
                    
                    // 转换为 Base64
                    const imageData = canvas.toDataURL('image/png');
                    
                    // 上传到服务器
                    const formData = new FormData();
                    formData.append('style_code', task.code);
                    formData.append('image_data', imageData);
                    
                    var opts = { method: 'POST', body: formData };
                    var res = await window.Weline.Api.request(globalUploadUrl, opts);
                    const result = (res && res.data) || res;
                    
                    if (result.success && result.preview_url) {
                        // 更新预览图显示
                        const previewContainer = document.getElementById('preview-' + task.code);
                        if (previewContainer) {
                            previewContainer.innerHTML = `<img src="${result.preview_url}" alt="${task.name}" style="max-width:100%;max-height:100%;object-fit:cover;">`;
                        }
                    }
                    
                    resolve();
                } catch (error) {
                    reject(error);
                } finally {
                    // 清理 iframe
                    document.body.removeChild(iframe);
                }
            };
            
            iframe.onerror = function() {
                document.body.removeChild(iframe);
                reject(new Error('Failed to load preview page'));
            };
            
            iframe.src = task.preview_page_url;
        });
    }
    
    // 选择站点
    window.selectWebsite = function(item) {
        document.querySelectorAll('.website-item').forEach(i => {
            i.classList.remove('selected');
            i.querySelector('.website-check').className = 'mdi mdi-checkbox-blank-circle-outline me-2 website-check';
        });
        item.classList.add('selected');
        item.querySelector('.website-check').className = 'mdi mdi-checkbox-marked-circle me-2 website-check text-success';
        document.getElementById('selectedWebsiteId').value = item.dataset.websiteId;
        selectedWebsiteName = item.querySelector('.fw-bold').textContent;
        // 页面名称前缀默认用网站名，可改
        var siteNameEl = document.getElementById('siteName');
        if (siteNameEl) siteNameEl.value = selectedWebsiteName || '';
    };
    
    // 选择模板
    window.selectTemplate = function(card) {
        document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        document.getElementById('selectedStyleCode').value = card.dataset.styleCode;
        selectedTemplateName = card.dataset.styleName;
    };
    
    // 显示快速新建站点表单
    window.showQuickWebsiteForm = function() {
        document.getElementById('quickWebsiteForm').classList.remove('d-none');
    };
    
    // 隐藏快速新建站点区域（内部使用 websites:website:build 标签，表单在 offcanvas 中）
    window.hideQuickWebsiteForm = function() {
        var el = document.getElementById('quickWebsiteForm');
        if (el) el.classList.add('d-none');
    };
    
    // 更新步骤指示器
    function updateStepIndicator(step) {
        document.querySelectorAll('.step-indicator .step').forEach((el, idx) => {
            el.classList.remove('active', 'completed');
            if (idx + 1 < step) el.classList.add('completed');
            if (idx + 1 === step) el.classList.add('active');
        });
    }
    
    // 显示指定步骤内容
    function showStep(step) {
        currentStep = step;
        updateStepIndicator(step);
        
        document.querySelectorAll('.step-content').forEach(el => el.classList.add('d-none'));
        document.getElementById(`step${step}Content`).classList.remove('d-none');
        
        // 按钮显示逻辑
        btnPrev.classList.toggle('d-none', step === 1);
        btnNext.classList.toggle('d-none', step >= 2);
        btnCreate.classList.toggle('d-none', step !== 2);
        btnCancel.classList.toggle('d-none', step === 3);
        
        if (step === 3) {
            btnPrev.classList.add('d-none');
            btnCreate.classList.add('d-none');
        }
        
        // 第2步时更新显示信息，页面名称前缀默认用网站名（可改）
        if (step === 2) {
            document.getElementById('selectedWebsiteDisplay').textContent = selectedWebsiteName || '-';
            document.getElementById('selectedTemplateDisplay').textContent = selectedTemplateName || '-';
            var siteNameEl = document.getElementById('siteName');
            if (siteNameEl && selectedWebsiteName) siteNameEl.value = selectedWebsiteName;
        }
    }
    
    // Modal 打开时加载模板
    quickSiteModal.addEventListener('show.bs.modal', function() {
        currentStep = 1;
        showStep(1);
        loadTemplates();
        // 重置表单和选择状态
        document.getElementById('quickSiteForm').reset();
        document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
        document.querySelectorAll('.website-item').forEach(i => {
            i.classList.remove('selected');
            const check = i.querySelector('.website-check');
            if (check) check.className = 'mdi mdi-checkbox-blank-circle-outline me-2 website-check';
        });
        document.getElementById('selectedWebsiteId').value = '';
        document.getElementById('selectedStyleCode').value = '';
        selectedWebsiteName = '';
        selectedTemplateName = '';
        hideQuickWebsiteForm();
    });
    
    // 下一步
    btnNext.addEventListener('click', function() {
        if (currentStep === 1) {
            const websiteId = document.getElementById('selectedWebsiteId').value;
            const styleCode = document.getElementById('selectedStyleCode').value;
            
            if (!websiteId) {
                BackendToast.warning('<?= __("请选择一个站点") ?>');
                return;
            }
            
            if (!styleCode) {
                BackendToast.warning('<?= __("请选择一个模板") ?>');
                return;
            }
            showStep(2);
        }
    });
    
    // 上一步
    btnPrev.addEventListener('click', function() {
        if (currentStep > 1) {
            showStep(currentStep - 1);
        }
    });
    
    // 开始创建
    btnCreate.addEventListener('click', function() {
        const form = document.getElementById('quickSiteForm');
        const siteName = document.getElementById('siteName').value.trim();
        const siteHandle = document.getElementById('siteHandle').value.trim();
        const websiteId = document.getElementById('selectedWebsiteId').value;
        const styleCode = document.getElementById('selectedStyleCode').value;
        
        if (!siteName) {
            BackendToast.warning('<?= __("请填写页面名称前缀") ?>');
            return;
        }
        if (siteHandle !== '' && !/^[a-z0-9-]+$/.test(siteHandle)) {
            BackendToast.warning('<?= __("URL前缀只能包含小写字母、数字和连字符") ?>');
            return;
        }
        
        showStep(3);
        
        // 收集选中的页面类型
        const pageTypes = [];
        document.querySelectorAll('input[name="page_types[]"]:checked').forEach(cb => {
            pageTypes.push(cb.value);
        });
        // 确保首页在列表中
        if (!pageTypes.includes('home_page')) {
            pageTypes.unshift('home_page');
        }
        
        // 发送创建请求
        const formData = new FormData();
        formData.append('style_code', styleCode);
        formData.append('site_name', siteName);
        formData.append('site_handle', siteHandle);
        formData.append('website_id', websiteId);
        formData.append('default_locale', document.getElementById('siteDefaultLocale').value);
        formData.append('page_types', JSON.stringify(pageTypes));
        // SEO 账户绑定
        const seoAccountId = document.getElementById('seo_account_quick_value')?.value || '';
        if (seoAccountId) {
            formData.append('seo_account_id', seoAccountId);
        }
        
        const progressBar = document.getElementById('createProgressBar');
        const creationLog = document.getElementById('creationLog');
        const creationProgress = document.getElementById('creationProgress');
        const creationResult = document.getElementById('creationResult');
        
        creationLog.innerHTML = '<div class="text-muted"><?= __("开始创建...") ?></div>';
        
        var url = '<?= $this->getBackendUrl("*/backend/page/quickSite") ?>';
        var req = window.Weline.Api.request(url, { method: 'POST', body: formData });
        req.then(function(res) {
            var data = (res && res.data) || res;
            if (data.success) {
                progressBar.style.width = '100%';
                progressBar.textContent = '100%';
                
                // 显示成功结果
                creationProgress.classList.add('d-none');
                creationResult.classList.remove('d-none');
                
                let pagesHtml = '';
                if (data.pages && data.pages.length > 0) {
                    pagesHtml = '<ul class="list-group list-group-flush mb-3">';
                    data.pages.forEach(page => {
                        pagesHtml += `
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="mdi mdi-file-document text-primary me-2"></i>${page.name}</span>
                                <span class="badge bg-success">${page.handle}</span>
                            </li>
                        `;
                    });
                    pagesHtml += '</ul>';
                }
                
                creationResult.innerHTML = `
                    <div class="text-center py-3">
                        <i class="mdi mdi-check-circle text-success" style="font-size:64px;"></i>
                        <h4 class="mt-3 text-success"><?= __("站点创建成功！") ?></h4>
                        <p class="text-muted"><?= __("已成功创建以下页面：") ?></p>
                    </div>
                    ${pagesHtml}
                    <div class="text-center">
                        <button type="button" class="btn btn-primary" onclick="window.location.reload()">
                            <i class="mdi mdi-refresh"></i> <?= __("刷新页面列表") ?>
                        </button>
                        <a href="<?= $this->getBackendUrl('*/backend/page/edit') ?>?id=${data.home_page_id}" class="btn btn-success ms-2">
                            <i class="mdi mdi-pencil"></i> <?= __("编辑首页") ?>
                        </a>
                    </div>
                `;
            } else {
                creationProgress.classList.add('d-none');
                creationResult.classList.remove('d-none');
                var msg = data.message || '<?= __("未知错误") ?>';
                creationResult.innerHTML = `
                    <div class="text-center py-3">
                        <i class="mdi mdi-alert-circle text-danger" style="font-size:64px;"></i>
                        <h4 class="mt-3 text-danger"><?= __("创建失败") ?></h4>
                        <div class="quick-site-error-body text-muted text-start overflow-auto mt-2" style="max-height:280px;"></div>
                    </div>
                    <div class="text-center">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="mdi mdi-close"></i> <?= __("关闭") ?>
                        </button>
                    </div>
                `;
                var errBody = creationResult.querySelector('.quick-site-error-body');
                if (errBody) errBody.innerHTML = msg;
                if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("创建失败") ?>: ' + msg, { html: true });
            }
        })
        .catch(error => {
            console.error('创建失败:', error);
            creationProgress.classList.add('d-none');
            creationResult.classList.remove('d-none');
            var errMsg = '<?= __("网络错误，请稍后重试") ?>';
            if (error && error.response) {
                if (error.response.data && typeof error.response.data.message === 'string') errMsg = error.response.data.message;
                else if (typeof error.response.data === 'string') errMsg = error.response.data;
                else if (error.responseText) errMsg = error.responseText;
            } else if (error && error.message) errMsg = error.message;
            creationResult.innerHTML = `
                <div class="text-center py-3">
                    <i class="mdi mdi-alert-circle text-danger" style="font-size:64px;"></i>
                    <h4 class="mt-3 text-danger"><?= __("创建失败") ?></h4>
                    <div class="quick-site-error-body text-muted text-start overflow-auto mt-2" style="max-height:280px;"></div>
                </div>
                <div class="text-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="mdi mdi-close"></i> <?= __("关闭") ?>
                    </button>
                </div>
            `;
            var errBody = creationResult.querySelector('.quick-site-error-body');
            if (errBody) errBody.innerHTML = errMsg;
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("创建失败") ?>: ' + errMsg, { html: true });
        });
    });
});

// 处理删除确认表单 - 使用 BackendConfirm
document.querySelectorAll('.delete-confirm-form').forEach(form => {
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        const message = this.dataset.confirmMessage || '<?= __('确定要执行此操作吗？') ?>';
        const formElement = this;
        
        BackendConfirm.show(message, {
            title: '<?= __('确认删除') ?>',
            confirmText: '<?= __('确认删除') ?>',
            cancelText: '<?= __('取消') ?>',
            type: 'danger'
        }).then((confirmed) => {
            if (confirmed) {
                formElement.submit();
            }
        });
    });
});
</script>
