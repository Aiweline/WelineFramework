    // 更新步骤指示器
    function updateStepIndicator(step) {
        document.querySelectorAll('.step-indicator .step').forEach((el, idx) => {
            el.classList.remove('active', 'completed');
            if (idx + 1 < step) el.classList.add('completed');
            if (idx + 1 === step) el.classList.add('active');
        });
    }
    
    // 显示指定步骤内容
    function showStep(step) {
        currentStep = step;
        updateStepIndicator(step);
        
        document.querySelectorAll('.step-content').forEach(el => el.classList.add('d-none'));
        document.getElementById(`step${step}Content`).classList.remove('d-none');
        
        // 按钮显示逻辑
        btnPrev.classList.toggle('d-none', step === 1);
        btnNext.classList.toggle('d-none', step >= 2);
        btnCreate.classList.toggle('d-none', step !== 2);
        btnCancel.classList.toggle('d-none', step === 3);
        
        if (step === 3) {
            btnPrev.classList.add('d-none');
            btnCreate.classList.add('d-none');
        }
        
        // 第2步时更新显示信息
        if (step === 2) {
            document.getElementById('selectedWebsiteDisplay').textContent = selectedWebsiteName || '-';
            document.getElementById('selectedTemplateDisplay').textContent = selectedTemplateName || '-';
        }
    }
    
