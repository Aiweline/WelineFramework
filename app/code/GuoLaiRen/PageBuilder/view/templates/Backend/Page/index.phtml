    // 执行删除站点
    function deleteSite(pageId, pageName, button) {
        const originalHtml = button.innerHTML;
        const originalDisabled = button.disabled;
        
        // 显示loading状态
        button.disabled = true;
        button.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i> <?= __("删除中...") ?>';
        
        fetch('<?= $this->getBackendUrl("*/backend/page/deleteSite") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ id: pageId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('success', '<?= __("删除成功") ?>', data.message || ('<?= __("站点") ?> "' + pageName + '" <?= __("已删除") ?>'));
                // 刷新页面
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } else {
                button.disabled = originalDisabled;
                button.innerHTML = originalHtml;
                showToast('error', '<?= __("删除失败") ?>', data.message || '<?= __("未知错误") ?>');
            }
        })
        .catch(error => {
            console.error('删除站点失败:', error);
            button.disabled = originalDisabled;
            button.innerHTML = originalHtml;
            showToast('error', '<?= __("删除失败") ?>', '<?= __("网络错误，请重试") ?>');
        });
    }
    
    // 导出页面功能（带loading）
