                                                                                    if ($port && !isset($urlParts['port'])) {
                                                                                        $scheme = isset($urlParts['scheme']) ? $urlParts['scheme'] . '://' : '';
                                                                                        $host = $urlParts['host'] ?? '';
                                                                                        $path = isset($urlParts['path']) ? $urlParts['path'] : '';
                                                                                        $newUrl = $scheme . $host . ':' . $port . $path;
                                                                                        $childWebsiteUrls[] = $newUrl;
                                                                                    } else {
                                                                                        $childWebsiteUrls[] = $trimmedUrl;
                                                                                    }
                                                                                }
                                                                            }
                                                                            // 兼容后续代码，用第一个作为默认
                                                                            $childWebsiteUrl = isset($childWebsiteUrls[0]) ? $childWebsiteUrls[0] : '';
                                                                        }
                                                                    } catch (\Exception $e) {
