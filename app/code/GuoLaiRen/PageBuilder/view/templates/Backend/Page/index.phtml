    // 加载模板列表
    function loadTemplates() {
        const container = document.getElementById('templateSelector');
        fetch('<?= $this->getBackendUrl("*/backend/page/getStyles") ?>')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.data && data.data.length > 0) {
                    globalUploadUrl = data.upload_url || '';
                    let html = '';
                    previewGenerationQueue = []; // 清空队列
                    
                    data.data.forEach(style => {
                        const thumbnail = style.preview_image || '';
                        const needsPreview = style.needs_preview || false;
                        
                        let thumbnailHtml;
                        if (thumbnail) {
                            thumbnailHtml = `<img src="${thumbnail}" alt="${style.name}" onerror="this.parentNode.innerHTML='<i class=\\'mdi mdi-palette-outline\\' style=\\'font-size:32px;color:#6c757d;\\'></i>'">`; 
                        } else if (needsPreview) {
                            // 需要生成预览图 - 显示加载中状态
                            thumbnailHtml = `<div class="preview-generating" data-style-code="${style.code}">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <small class="d-block mt-1" style="font-size:10px;"><?= __('生成中...') ?></small>
                            </div>`;
                            // 加入队列
                            previewGenerationQueue.push({
                                code: style.code,
                                name: style.name,
                                preview_page_url: style.preview_page_url
                            });
                        } else {
                            thumbnailHtml = '<i class="mdi mdi-palette-outline" style="font-size:32px;color:#6c757d;"></i>';
                        }
                        
                        html += `
                            <div class="col-6 col-lg-4">
                                <div class="template-card" data-style-code="${style.code}" data-style-name="${style.name}" onclick="selectTemplate(this)">
                                    <div class="template-preview" id="preview-${style.code}">${thumbnailHtml}</div>
                                    <div class="template-info">
                                        <div class="template-name">${style.name}</div>
                                        <div class="template-desc text-truncate">${style.description || '<?= __("暂无描述") ?>'}</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    container.innerHTML = html;
                    
                    // 开始自动生成预览图
                    if (previewGenerationQueue.length > 0) {
                        processPreviewQueue();
                    }
                } else {
                    container.innerHTML = `
                        <div class="col-12 text-center py-4">
                            <i class="mdi mdi-alert-circle-outline text-warning" style="font-size:48px;"></i>
                            <p class="mt-2 text-muted"><?= __('暂无可用模板，请先创建模板') ?></p>
                        </div>
                    `;
                }
            })
            .catch(error => {
                console.error('加载模板失败:', error);
                container.innerHTML = `
                    <div class="col-12 text-center py-4">
                        <i class="mdi mdi-alert-circle-outline text-danger" style="font-size:48px;"></i>
                        <p class="mt-2 text-danger"><?= __('加载模板失败，请刷新页面重试') ?></p>
                    </div>
                `;
            });
    }
    
    // 处理预览图生成队列
    async function processPreviewQueue() {
        if (isGeneratingPreviews || previewGenerationQueue.length === 0) return;
        
        isGeneratingPreviews = true;
        
        // 动态加载 html2canvas
        if (typeof html2canvas === 'undefined') {
            await loadHtml2Canvas();
        }
        
        while (previewGenerationQueue.length > 0) {
            const task = previewGenerationQueue.shift();
            try {
                await generateSinglePreview(task);
            } catch (error) {
                console.error(`生成预览图失败 (${task.code}):`, error);
                // 更新UI显示失败状态
                const previewContainer = document.getElementById('preview-' + task.code);
                if (previewContainer) {
                    previewContainer.innerHTML = '<i class="mdi mdi-image-off text-muted" style="font-size:32px;"></i>';
                }
            }
            // 添加延迟避免过快请求
            await new Promise(resolve => setTimeout(resolve, 500));
        }
        
        isGeneratingPreviews = false;
    }
    
    // 动态加载 html2canvas
    function loadHtml2Canvas() {
        return new Promise((resolve, reject) => {
            if (typeof html2canvas !== 'undefined') {
                resolve();
                return;
            }
            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
        });
    }
    
    // 生成单个模板预览图
    async function generateSinglePreview(task) {
        return new Promise((resolve, reject) => {
            // 创建隐藏的 iframe 来加载预览页面
            const iframe = document.createElement('iframe');
            iframe.style.cssText = 'position:fixed;top:-10000px;left:-10000px;width:1200px;height:800px;border:none;';
            document.body.appendChild(iframe);
            
            iframe.onload = async function() {
                try {
                    // 等待页面完全渲染
                    await new Promise(r => setTimeout(r, 2000));
                    
                    // 截图
                    const canvas = await html2canvas(iframe.contentDocument.body, {
                        width: 1200,
                        height: 800,
                        scale: 0.5,
                        useCORS: true,
                        allowTaint: true,
                        logging: false
                    });
                    
                    // 转换为 Base64
                    const imageData = canvas.toDataURL('image/png');
                    
                    // 上传到服务器
                    const formData = new FormData();
                    formData.append('style_code', task.code);
                    formData.append('image_data', imageData);
                    
                    const response = await fetch(globalUploadUrl, {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success && result.preview_url) {
                        // 更新预览图显示
                        const previewContainer = document.getElementById('preview-' + task.code);
                        if (previewContainer) {
                            previewContainer.innerHTML = `<img src="${result.preview_url}" alt="${task.name}" style="max-width:100%;max-height:100%;object-fit:cover;">`;
                        }
                    }
                    
                    resolve();
                } catch (error) {
                    reject(error);
                } finally {
                    // 清理 iframe
                    document.body.removeChild(iframe);
                }
            };
            
            iframe.onerror = function() {
                document.body.removeChild(iframe);
                reject(new Error('Failed to load preview page'));
            };
            
            iframe.src = task.preview_page_url;
        });
    }
    
