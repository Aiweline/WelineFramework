        const form = document.getElementById('quickSiteForm');
        const siteName = document.getElementById('siteName').value.trim();
        const siteHandle = document.getElementById('siteHandle').value.trim();
        const websiteId = document.getElementById('selectedWebsiteId').value;
        const styleCode = document.getElementById('selectedStyleCode').value;
        
        if (!siteName || !siteHandle) {
            Swal.fire({
                icon: 'warning',
                title: '<?= __("提示") ?>',
                text: '<?= __("请填写完整信息") ?>',
                confirmButtonText: '<?= __("确定") ?>'
            });
            return;
        }
        
        // 验证handle格式
        if (!/^[a-z0-9-]+$/.test(siteHandle)) {
            Swal.fire({
                icon: 'warning',
                title: '<?= __("提示") ?>',
                text: '<?= __("URL前缀只能包含小写字母、数字和连字符") ?>',
                confirmButtonText: '<?= __("确定") ?>'
            });
            return;
        }
        
        showStep(3);
        
        // 收集选中的页面类型
        const pageTypes = [];
        document.querySelectorAll('input[name="page_types[]"]:checked').forEach(cb => {
            pageTypes.push(cb.value);
        });
        // 确保首页在列表中
        if (!pageTypes.includes('home_page')) {
            pageTypes.unshift('home_page');
        }
        
        // 发送创建请求
        const formData = new FormData();
        formData.append('style_code', styleCode);
        formData.append('site_name', siteName);
        formData.append('site_handle', siteHandle);
        formData.append('website_id', websiteId);
        formData.append('default_locale', document.getElementById('siteDefaultLocale').value);
        formData.append('page_types', JSON.stringify(pageTypes));
        
        const progressBar = document.getElementById('createProgressBar');
        const creationLog = document.getElementById('creationLog');
        const creationProgress = document.getElementById('creationProgress');
        const creationResult = document.getElementById('creationResult');
        
        creationLog.innerHTML = '<div class="text-muted"><?= __("开始创建...") ?></div>';
        
        fetch('<?= $this->getBackendUrl("*/backend/page/quickSite") ?>', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                progressBar.style.width = '100%';
                progressBar.textContent = '100%';
                
                // 显示成功结果
                creationProgress.classList.add('d-none');
                creationResult.classList.remove('d-none');
                
                let pagesHtml = '';
                if (data.pages && data.pages.length > 0) {
                    pagesHtml = '<ul class="list-group list-group-flush mb-3">';
                    data.pages.forEach(page => {
                        pagesHtml += `
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="mdi mdi-file-document text-primary me-2"></i>${page.name}</span>
                                <span class="badge bg-success">${page.handle}</span>
                            </li>
                        `;
                    });
                    pagesHtml += '</ul>';
                }
                
                creationResult.innerHTML = `
                    <div class="text-center py-3">
                        <i class="mdi mdi-check-circle text-success" style="font-size:64px;"></i>
                        <h4 class="mt-3 text-success"><?= __("站点创建成功！") ?></h4>
                        <p class="text-muted"><?= __("已成功创建以下页面：") ?></p>
                    </div>
                    ${pagesHtml}
                    <div class="text-center">
                        <button type="button" class="btn btn-primary" onclick="window.location.reload()">
                            <i class="mdi mdi-refresh"></i> <?= __("刷新页面列表") ?>
                        </button>
                        <a href="<?= $this->getBackendUrl('*/backend/page/edit') ?>?id=${data.home_page_id}" class="btn btn-success ms-2">
                            <i class="mdi mdi-pencil"></i> <?= __("编辑首页") ?>
                        </a>
                    </div>
                `;
            } else {
                creationProgress.classList.add('d-none');
                creationResult.classList.remove('d-none');
                creationResult.innerHTML = `
                    <div class="text-center py-3">
                        <i class="mdi mdi-alert-circle text-danger" style="font-size:64px;"></i>
                        <h4 class="mt-3 text-danger"><?= __("创建失败") ?></h4>
                        <p class="text-muted">${data.message || '<?= __("未知错误") ?>'}</p>
                    </div>
                    <div class="text-center">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="mdi mdi-close"></i> <?= __("关闭") ?>
                        </button>
                    </div>
                `;
            }
        })
        .catch(error => {
            console.error('创建失败:', error);
            creationProgress.classList.add('d-none');
            creationResult.classList.remove('d-none');
            creationResult.innerHTML = `
                <div class="text-center py-3">
                    <i class="mdi mdi-alert-circle text-danger" style="font-size:64px;"></i>
                    <h4 class="mt-3 text-danger"><?= __("创建失败") ?></h4>
                    <p class="text-muted"><?= __("网络错误，请稍后重试") ?></p>
                </div>
                <div class="text-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="mdi mdi-close"></i> <?= __("关闭") ?>
                    </button>
                </div>
            `;
        });
    });
});
</script>

