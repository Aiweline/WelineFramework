                                                                        <i class="mdi mdi-publish me-1"></i><?= __('发布') ?>
                                                                    </button>
                                                                </acl>
                                                                <acl source="GuoLaiRen_PageBuilder::page_builder_delete">
                                                                    <form action="<?= $this->getBackendUrl('*/backend/page/delete') ?>"
                                                                          method='post' 
                                                                          style="display:inline;"
                                                                          onsubmit="return confirm('<?= __('确定要删除此子页面吗？') ?>');">
                                                                        <input type='hidden' name='id' value='<?= $childPage->getId() ?>'>
                                                                        <button type='submit' class='btn btn-sm btn-danger d-inline-flex align-items-center' style="min-width: 70px; white-space: nowrap;">
                                                                            <i class="mdi mdi-delete me-1"></i><?= __('删除') ?>
