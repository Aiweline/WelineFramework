                        // 2秒后恢复原状
                        setTimeout(() => {
                            this.innerHTML = originalHtml;
                            this.className = originalClass;
                        }, 2000);
                    })
                    .catch(err => {
                        console.error('<?= __("复制失败") ?>:', err);
                        showToast('error', '<?= __("复制失败") ?>', '<?= __("请手动复制链接") ?>');
                    });
            } else {
                // 降级方案
                const textArea = document.createElement('textarea');
                textArea.value = url;
                textArea.style.position = 'fixed';
                textArea.style.left = '-999999px';
                textArea.style.top = '-999999px';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                
                try {
                    const successful = document.execCommand('copy');
                    if (successful) {
                        this.innerHTML = '<i class="mdi mdi-check"></i> <?= __("已复制") ?>';
                        this.classList.add('text-success');
                        
                        showToast('success', '<?= __("Sitemap 链接已复制") ?>', url);
                        
                        setTimeout(() => {
                            this.innerHTML = originalHtml;
                            this.className = originalClass;
                        }, 2000);
                    } else {
                        throw new Error('execCommand failed');
                    }
                } catch (err) {
                    console.error('<?= __("复制失败") ?>:', err);
                    const escapedUrl = String(url)
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#39;');
                    
                    if (typeof BackendConfirm !== 'undefined') {
                        const confirmHtml = `
                            <div class="mb-2"><?= __("请手动复制以下链接") ?></div>
                            <textarea class="form-control" readonly style="height: 90px; font-family: monospace;">${escapedUrl}</textarea>
                        `;
                        BackendConfirm.show(confirmHtml, {
                            title: '<?= __("复制失败") ?>',
                            confirmText: '<?= __("关闭") ?>',
                            cancelText: '<?= __("关闭") ?>',
                            type: 'warning'
                        });
                    } else {
                        showToast('error', '<?= __("复制失败") ?>', '<?= __("请手动复制以下链接") ?>: ' + url);
                    }
                } finally {
                    document.body.removeChild(textArea);
                }
            }
        });
    });
    
    // ============ 一键删除站点功能 ============
    const deleteSiteButtons = document.querySelectorAll('.delete-site-btn');
    deleteSiteButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const pageId = this.getAttribute('data-page-id');
            const pageName = this.getAttribute('data-page-name');
            const childCount = parseInt(this.getAttribute('data-child-count') || '0');
            
            if (!pageId) {
                showToast('error', '<?= __("删除失败") ?>', '<?= __("页面ID不存在") ?>');
                return;
            }
            
            // 构建确认消息
            let confirmMessage = '<?= __("确定要删除站点") ?> "' + pageName + '" <?= __("吗？") ?>';
            if (childCount > 0) {
                confirmMessage += '\n\n<?= __("此操作将同时删除") ?> ' + childCount + ' <?= __("个子页面！") ?>';
            }
            confirmMessage += '\n\n<?= __("此操作不可恢复！") ?>';
            
            // 使用 BackendConfirm 确认删除
            const confirmHtml = childCount > 0 
                ? `<?= __("站点名称") ?>: ${pageName}\n<?= __("子页面数量") ?>: ${childCount} <?= __("个") ?>\n<?= __("警告") ?>: <?= __("此操作将删除该站点及其所有子页面，且不可恢复！") ?>`
                : `<?= __("站点名称") ?>: ${pageName}\n<?= __("警告") ?>: <?= __("此操作不可恢复！") ?>`;
            
            BackendConfirm.show(confirmHtml, {
                title: '<?= __("确认删除站点") ?>',
                confirmText: '<?= __("确认删除") ?>',
