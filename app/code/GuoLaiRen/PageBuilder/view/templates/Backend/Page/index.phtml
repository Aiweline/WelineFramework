                                                            <!-- 子页面操作 -->
                                                            <div class="d-flex gap-1 ms-3 flex-nowrap">
                                                                <?php
                                                                // 生成子页面前端访问链接：默认根域名并带当前请求端口（getDisplayBaseUrl）
