            this.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("导出中...") ?>';
            
            // 使用直接链接点击方式触发下载（最可靠的方式）
            const exportUrl = '<?= $this->getBackendUrl("*/backend/page/export") ?>?id=' + encodeURIComponent(pageId);
            
            // 创建一个临时的链接元素并点击
            const link = document.createElement('a');
            link.href = exportUrl;
            link.download = ''; // 让浏览器处理下载
            link.style.display = 'none';
            document.body.appendChild(link);
            
            // 立即点击触发下载
            link.click();
            
            // 由于导出过程可能需要较长时间（生成HTML、下载资源、创建ZIP），
            // 我们保持loading状态更长时间，让用户知道正在处理
            // 延迟恢复按钮状态（给用户看到loading反馈，同时给后端足够时间生成文件）
            setTimeout(function() {
                button.disabled = originalDisabled;
                button.innerHTML = originalHtml;
                
                // 清理链接
                if (link.parentNode) {
                    link.parentNode.removeChild(link);
                }
                
                showToast('success', '<?= __("导出成功") ?>', '<?= __("文件已开始下载，请查看浏览器下载列表") ?>');
            }, 3000); // 3秒后恢复，给后端足够时间开始输出文件
            
            // 设置超时保护，防止按钮永远处于loading状态
            setTimeout(function() {
                if (button.disabled && button.innerHTML.includes('<?= __("导出中...") ?>')) {
                    button.disabled = originalDisabled;
                    button.innerHTML = originalHtml;
                    
                    if (link.parentNode) {
                        link.parentNode.removeChild(link);
                    }
                    
                    showToast('info', '<?= __("导出处理中") ?>', '<?= __("文件可能较大，正在生成中，请稍候...") ?>');
                }
            }, 30000); // 30秒超时保护
        });
    });
    
