<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 从快速建站向导跳转：自动打开一键建站弹窗并可选预选站点
    (function() {
        var params = new URLSearchParams(window.location.search);
        var openQuickSite = params.get('open_quick_site') === '1';
        var websiteId = params.get('website_id') || '';
        if (!openQuickSite) return;
        var modalEl = document.getElementById('quickSiteModal');
        if (!modalEl || typeof bootstrap === 'undefined') return;
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
        modalEl.addEventListener('shown.bs.modal', function onShown() {
            modalEl.removeEventListener('shown.bs.modal', onShown);
            if (websiteId) {
                var item = document.querySelector('.website-item[data-website-id="' + websiteId + '"]');
                if (item && typeof window.selectWebsite === 'function') {
                    window.selectWebsite(item);
                }
            }
        }, { once: true });
        var cleanUrl = window.location.pathname + (websiteId ? '?website_id=' + websiteId : '') + (window.location.hash || '');
        if (history.replaceState) {
            history.replaceState(null, '', cleanUrl);
        }
    })();

    // 拷贝链接功能
    const copyButtons = document.querySelectorAll('.copy-link-btn');
    
    copyButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const url = this.getAttribute('data-url');
            const pageName = this.getAttribute('data-page-name');
            const originalHtml = this.innerHTML;
            const originalClass = this.className;
            
            // 使用现代 Clipboard API
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(url)
                    .then(() => {
                        // 成功提示
                        this.innerHTML = '<i class="mdi mdi-check"></i> <?= __("已复制") ?>';
                        this.className = 'btn btn-success btn-sm copy-link-btn';
                        
                        // Toast 通知
                        showToast('success', '<?= __("链接已复制") ?>', 
                                  '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
                        
                        // 2秒后恢复原状
                        setTimeout(() => {
                            this.innerHTML = originalHtml;
                            this.className = originalClass;
                        }, 2000);
                    })
                    .catch(err => {
                        console.error('<?= __("复制失败") ?>:', err);
                        showToast('error', '<?= __("复制失败") ?>', '<?= __("请手动复制链接") ?>');
                    });
            } else {
                // 降级方案：使用传统的 execCommand 方法
                const textArea = document.createElement('textarea');
                textArea.value = url;
                textArea.style.position = 'fixed';
                textArea.style.left = '-999999px';
                textArea.style.top = '-999999px';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                
                try {
                    const successful = document.execCommand('copy');
                    if (successful) {
                        // 成功提示
                        this.innerHTML = '<i class="mdi mdi-check"></i> <?= __("已复制") ?>';
                        this.className = 'btn btn-success btn-sm copy-link-btn';
                        
                        showToast('success', '<?= __("链接已复制") ?>', 
                                  '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
                        
                        setTimeout(() => {
                            this.innerHTML = originalHtml;
                            this.className = originalClass;
                        }, 2000);
                    } else {
                        throw new Error('execCommand failed');
                    }
                } catch (err) {
                    console.error('<?= __("复制失败") ?>:', err);
                    // 最后降级方案：提示用户手动复制
                    const escapedUrl = String(url)
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#39;');
                    
                    if (typeof BackendConfirm !== 'undefined') {
                        const confirmHtml = `
                            <div class="mb-2"><?= __("请手动复制以下链接") ?></div>
                            <textarea class="form-control" readonly style="height: 90px; font-family: monospace;">${escapedUrl}</textarea>
                        `;
                        BackendConfirm.show(confirmHtml, {
                            title: '<?= __("复制失败") ?>',
                            confirmText: '<?= __("关闭") ?>',
                            cancelText: '<?= __("关闭") ?>',
                            type: 'warning'
                        });
                    } else {
                        showToast('error', '<?= __("复制失败") ?>', '<?= __("请手动复制以下链接") ?>: ' + url);
                    }
                } finally {
                    document.body.removeChild(textArea);
                }
            }
        });
    });
    
    // Toast 通知函数
    function showToast(type, title, message) {
        // 检查是否有全局的 Toast 方法（如 Bootstrap Toast）
        if (typeof BackendToast !== 'undefined') {
            if (type === 'success') {
                BackendToast.success(title + (message ? ': ' + message : ''));
            } else if (type === 'error') {
                BackendToast.error(title + (message ? ': ' + message : ''));
            } else {
                BackendToast.info(title + (message ? ': ' + message : ''));
            }
        } else if (typeof Toastify !== 'undefined') {
            const bgColor = getComputedStyle(document.documentElement).getPropertyValue(
                type === 'success' ? '--backend-color-success' : '--backend-color-danger'
            ).trim() || (type === 'success' ? '#34c38f' : '#f46a6a');
            Toastify({
                text: title + (message ? '<br>' + message : ''),
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: bgColor,
                escapeMarkup: false
            }).showToast();
        } else if (typeof toastr !== 'undefined') {
            toastr[type](message || '', title);
        } else {
            console.log('[' + type.toUpperCase() + '] ' + title + (message ? ': ' + message : ''));
        }
    }
    
    // ============ 复制 Sitemap 链接功能 ============
    const copySitemapButtons = document.querySelectorAll('.copy-sitemap-link-btn');
    
