                    var url = '<?= $this->getUrl("weline/eav/api/options/attributes") ?>?entity_code=' + encodeURIComponent(escapeHtmlForTemplate(entityCode));
                    var req = window.Weline.Api.get(url, { silent: true });
                    req.then(function(res) {
                        var data = (res && res.data) || res;
                            if (data.success && data.data.attributes) {
                                select.innerHTML = '<option value=""><?= __('-- 请选择属性 --') ?></option>';
