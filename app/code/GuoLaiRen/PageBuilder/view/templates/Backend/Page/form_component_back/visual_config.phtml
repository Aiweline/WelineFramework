// ========== 配置项搜索功能 ==========
/**
 * 搜索配置字段
 * @param {string} searchTerm - 搜索关键词
 */
window.searchConfigFields = function(searchTerm) {
    const searchBox = document.querySelector('.config-search-box');
    const searchInput = document.getElementById('configSearchInput');
    
    if (!searchTerm || searchTerm.trim() === '') {
        // 清空搜索
        clearConfigSearch();
        return;
    }
    
    // 更新搜索框状态
    if (searchBox) {
        searchBox.classList.add('has-value');
    }
    
    const term = searchTerm.trim().toLowerCase();
    const allFields = document.querySelectorAll('.config-field-item');
    const allSections = document.querySelectorAll('.config-section');
    const sectionVisibility = new Map(); // 记录每个section是否有可见字段
    
    // 遍历所有配置字段
    allFields.forEach(function(field) {
        const configKey = (field.getAttribute('data-config-key') || '').toLowerCase();
        const configLabel = (field.getAttribute('data-config-label') || '').toLowerCase();
        const configDescription = (field.getAttribute('data-config-description') || '').toLowerCase();
        
        // 模糊匹配：检查 key、label 或 description 是否包含搜索词
        const matches = configKey.includes(term) || 
                       configLabel.includes(term) || 
                       configDescription.includes(term);
        
        if (matches) {
            // 显示字段
            field.classList.remove('config-field-hidden');
            
            // 高亮匹配的文本（在 label 中）
            const label = field.querySelector('label');
            if (label) {
                // 保存原始 HTML（如果还没有保存）
                if (!label.hasAttribute('data-original-html')) {
                    label.setAttribute('data-original-html', label.innerHTML);
                }
                
                // 先移除之前的高亮
                let labelHTML = label.getAttribute('data-original-html') || label.innerHTML || '';
                labelHTML = labelHTML.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
                
                // 提取文本部分（不包括恢复按钮）
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = labelHTML;
                const restoreBtn = tempDiv.querySelector('.visual-config-reset-btn');
                const restoreBtnHTML = restoreBtn ? restoreBtn.outerHTML : '';
                tempDiv.querySelectorAll('.visual-config-reset-btn').forEach(btn => btn.remove());
                const textOnly = tempDiv.textContent || '';
                
                // 高亮文本
                const highlightedText = highlightSearchTerm(textOnly, term);
                if (highlightedText !== textOnly) {
                    label.innerHTML = highlightedText + (restoreBtnHTML ? ' ' + restoreBtnHTML : '');
                } else {
                    label.innerHTML = labelHTML; // 恢复原始 HTML
                }
            }
            
            // 记录该字段所属的 section 有可见字段
            const section = field.closest('.config-section');
            if (section) {
                const sectionId = section.id;
                sectionVisibility.set(sectionId, true);
            }
        } else {
            // 隐藏字段
            field.classList.add('config-field-hidden');
        }
    });
    
    // 更新 section 的可见性
    allSections.forEach(function(section) {
        const sectionId = section.id;
        const hasVisibleFields = sectionVisibility.get(sectionId) || false;
        
        if (hasVisibleFields) {
            section.classList.remove('config-section-empty');
            // 自动展开匹配的 section
            const sectionBody = section.querySelector('.config-section-body');
            if (sectionBody && sectionBody.style.display === 'none') {
                sectionBody.style.display = '';
                const chevron = section.querySelector('.config-section-header i.mdi-chevron-down, .config-section-header i.mdi-chevron-right');
                if (chevron) {
                    chevron.classList.remove('mdi-chevron-right');
                    chevron.classList.add('mdi-chevron-down');
                }
            }
        } else {
            section.classList.add('config-section-empty');
        }
    });
};

/**
 * 高亮搜索关键词
 * @param {string} text - 原始文本
 * @param {string} term - 搜索关键词
 * @returns {string} 高亮后的文本
 */
function highlightSearchTerm(text, term) {
    if (!term || !text) return text;
    
    // 移除已有的高亮
    text = text.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
    
    // 创建正则表达式进行不区分大小写的匹配
    const regex = new RegExp('(' + escapeRegExp(term) + ')', 'gi');
    return text.replace(regex, '<span class="config-search-highlight">$1</span>');
}

/**
 * 转义正则表达式特殊字符
 * @param {string} str - 要转义的字符串
 * @returns {string} 转义后的字符串
 */
function escapeRegExp(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

/**
 * HTML转义辅助函数
 */
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

/**
 * 执行配置回填并添加蓝色边框标记
 */
window.performConfigFill = function(configItems, filledInputs) {
    let filledCount = 0;
    
    // 执行回填
    configItems.forEach(function(item) {
        const input = item.input;
        if (input) {
            input.value = item.value;
            // 触发change和input事件，确保自动保存和UI更新
            input.dispatchEvent(new Event('change', { bubbles: true }));
            input.dispatchEvent(new Event('input', { bubbles: true }));
            
            // 添加蓝色边框标记（永久保留）
            input.classList.add('ai-filled-field');
            input.style.borderColor = '#0d6efd';
            input.style.borderWidth = '2px';
            input.style.borderStyle = 'solid';
            
            filledCount++;
        }
    });
    
    // 显示成功消息
    BackendToast.success(`<?= __('生成成功：已生成并填充') ?> ${filledCount} <?= __('个配置项') ?>`);
    
    // 自动保存
    if (typeof window.autoSaveConfig === 'function') {
        window.autoSaveConfig(true); // 立即保存
    }
}

