                    (group.label || groupKey) + '</h6>';
                
                for (const [fieldKey, field] of Object.entries(group.fields || {})) {
                    // 修复：如果 fieldKey 已经包含组前缀，则直接使用，避免重复前缀
                    // 例如：fieldKey='button.text', groupKey='button' → fullKey='button.text'
                    // 而不是：'button.button.text'
                    const fullKey = fieldKey.startsWith(groupKey + '.') ? fieldKey : (groupKey + '.' + fieldKey);
                    const currentValue = currentConfig[fullKey] !== undefined ? currentConfig[fullKey] : (field.default || '');
                    
                    formHtml += '<div class="config-field" style="margin-bottom: 14px;">';
                    formHtml += '<label style="display: block; margin-bottom: 4px; font-size: 13px; opacity: 0.7;">' + 
                        (field.label || fieldKey) + '</label>';
                    
                    const fieldType = field.type || 'text';
                    const inputId = 'comp_config_' + fullKey.replace(/\./g, '_');
                    
                    if (fieldType === 'select' && field.options) {
                        formHtml += '<select id="' + inputId + '" data-field="' + fullKey + '" class="form-select form-select-sm" style="width: 100%;">';
                        // 修复：如果 options 是数组，使用值本身作为 option value；如果是对象，使用键作为 value
                        if (Array.isArray(field.options)) {
                            for (const optValue of field.options) {
                                const selected = currentValue === optValue ? 'selected' : '';
                                formHtml += '<option value="' + escapeHtml(optValue) + '" ' + selected + '>' + escapeHtml(optValue) + '</option>';
                            }
                        } else {
                            for (const [optKey, optLabel] of Object.entries(field.options)) {
                                const selected = currentValue === optKey ? 'selected' : '';
                                formHtml += '<option value="' + escapeHtml(optKey) + '" ' + selected + '>' + escapeHtml(optLabel) + '</option>';
                            }
                        }
                        formHtml += '</select>';
                    } else if (fieldType === 'textarea') {
                        formHtml += '<textarea id="' + inputId + '" data-field="' + fullKey + '" class="form-control form-control-sm" rows="3" style="width: 100%;">' + 
                            escapeHtml(currentValue) + '</textarea>';
                    } else if (fieldType === 'color') {
                        formHtml += '<input type="text" id="' + inputId + '" data-field="' + fullKey + '" value="' + escapeHtml(currentValue) + '" class="form-control form-control-sm visual-color-input" data-coloris style="width: 100%;" placeholder="#000000 / rgba(...) / transparent">';
                    } else if (fieldType === 'image') {
                        formHtml += '<div style="display: flex; gap: 8px; align-items: center;">';
                        formHtml += '<input type="text" id="' + inputId + '" data-field="' + fullKey + '" value="' + escapeHtml(currentValue) + '" class="form-control form-control-sm" style="flex: 1;" placeholder="<?= __('图片URL') ?>">';
                        formHtml += '</div>';
                    } else {
                        formHtml += '<input type="text" id="' + inputId + '" data-field="' + fullKey + '" value="' + escapeHtml(currentValue) + '" class="form-control form-control-sm" style="width: 100%;">';
                    }
                    
                    formHtml += '</div>';
                }
                
                formHtml += '</div>';
            }
        }
        
        formHtml += '</div>';
        
        // 显示配置弹窗（使用自定义 Bootstrap Modal）
        const result = await showComponentConfigModal({
            title: '<?= __('组件配置') ?> - ' + (metadata.name || componentCode),
            html: formHtml,
            confirmText: '<?= __('保存') ?>',
            cancelText: '<?= __('取消') ?>',
            onOpen: (modalElement) => {
                initVisualColorInputs(modalElement);
                
                // AI 生成按钮点击事件（SSE 流式，在「生成过程」终端中展示）
                const aiBtn = document.getElementById('aiGenerateComponentConfigBtn');
                if (aiBtn) {
                    aiBtn.addEventListener('click', async () => {
                        const originalHtml = aiBtn.innerHTML;
                        aiBtn.disabled = true;
                        aiBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> <?= __('生成中...') ?>';
                        const aiPromptEl = document.querySelector('.weline-component-config-modal [data-field="_ai_prompt"]');
                        const aiPromptValue = (aiPromptEl && aiPromptEl.value) ? aiPromptEl.value.trim() : '';
                        const formData = new FormData();
                        formData.append('page_id', pageId);
                        formData.append('style_code', styleCode);
                        formData.append('component_code', componentCode);
                        formData.append('region', region);
                        formData.append('index', index);
                        formData.append('ai_prompt', aiPromptValue);
                        // 点击生成时更新并保存组件 AI 提示词到页面数据（与组件配置一起存放）
                        const collectModalConfig = () => {
                            const cfg = {};
                            document.querySelectorAll('.weline-component-config-modal [data-field]').forEach(input => {
                                const key = input.getAttribute('data-field');
                                if (!key) return;
                                let val = input.value;
                                if (input.type === 'color' && input.id) {
                                    const textEl = document.getElementById(input.id + '_text');
                                    if (textEl) val = textEl.value;
                                }
                                cfg[key] = val;
                            });
                            return cfg;
                        };
                        try {
                            const configToSave = collectModalConfig();
                            configToSave._ai_prompt = aiPromptValue;
                            const saveUrl = '<?= $this->getBackendUrl('*/backend/visual/api/component/updateConfig') ?>';
                            await window.Weline.Api.request(saveUrl, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ page_id: pageId, component_code: componentCode, region: region, index: index, config: configToSave }) });
                        } catch (e) { /* 保存提示词失败不影响本次生成 */ }
                        const streamUrl = '<?= $this->getBackendUrl("*/backend/ai-generate/component-config-stream") ?>';
                        const sseContent = document.querySelector('.weline-component-config-modal #aiComponentConfigSseTerminal_content');
                        const sseStatus = document.querySelector('.weline-component-config-modal #aiComponentConfigSseTerminal_status');
                        const sseContainer = document.querySelector('.weline-component-config-modal #aiComponentConfigSseTerminal');
                        function sseLog(t, type) {
                            type = type || 'info';
                            if (!sseContent) return;
                            const line = document.createElement('div');
                            line.className = 'weline-sse-terminal-line ' + type;
                            line.innerHTML = '<span class="weline-sse-terminal-time">[' + new Date().toLocaleTimeString('zh-CN', { hour12: false }) + ']</span><span class="weline-sse-terminal-text">' + (t || '').replace(/</g, '&lt;') + '</span>';
                            sseContent.appendChild(line);
                            if (sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                        }
                        function sseSetStatus(t) {
                            if (sseStatus) sseStatus.textContent = t || '';
                            if (sseContainer) sseContainer.classList.toggle('connected', t === '<?= __("已连接") ?>');
                        }
                        function applyConfigData(data) {
                            function toDisplayValue(val) {
                                if (Array.isArray(val)) {
                                    return val.map(function(item) {
                                        if (item && typeof item === 'object') return Object.values(item).map(function(v) { return v != null ? String(v) : ''; }).join('|');
                                        return String(item);
                                    }).join('\n');
                                }
                                return val != null ? String(val) : '';
                            }
                            let filledCount = 0;
                            for (const [key, value] of Object.entries(data)) {
                                const inputId = 'comp_config_' + key.replace(/\./g, '_');
                                const input = document.getElementById(inputId);
                                if (input) {
                                    input.value = toDisplayValue(value);
                                    input.style.borderColor = '#667eea';
                                    input.style.boxShadow = '0 0 0 2px rgba(102,126,234,0.2)';
                                    input.dispatchEvent(new Event('change', { bubbles: true }));
                                    input.dispatchEvent(new Event('input', { bubbles: true }));
                                    filledCount++;
                                    setTimeout(() => { input.style.borderColor = ''; input.style.boxShadow = ''; }, 2000);
                                }
                            }
                            if (filledCount > 0) BackendToast.success('<?= __('已生成') ?> ' + filledCount + ' <?= __('个配置项') ?>');
                        }
                        function restoreBtn() {
                            aiBtn.disabled = false;
                            aiBtn.innerHTML = originalHtml;
                            if (sseStatus) sseStatus.textContent = '<?= __("已断开") ?>';
                            if (sseContainer) sseContainer.classList.remove('connected');
                        }
                        if (sseContent) sseContent.innerHTML = '';
                        document.querySelectorAll('.weline-component-config-modal .weline-sse-unpublished-warning').forEach(function(el) { el.remove(); });
                        sseLog('<?= __("连接中...") ?>', 'info');
                        sseSetStatus('<?= __("连接中...") ?>');
                        let streamingLineEl = null;
                        let streamingTextEl = null;
                        try {
                            const res = await fetch(streamUrl, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                            if (!res.ok) throw new Error(res.statusText || '<?= __("请求失败") ?>');
                            if (!res.body) throw new Error('<?= __("不支持流式响应") ?>');
                            const reader = res.body.getReader();
                            const decoder = new TextDecoder();
                            let buffer = '';
                            let currentEvent = '', currentData = '';
                            function finishEvent() {
                                try {
                                    const payload = currentData ? JSON.parse(currentData) : {};
                                    if (currentEvent === 'start' || currentEvent === 'progress') {
                                        if (payload.message) { sseLog(payload.message, currentEvent === 'start' ? 'start' : 'progress'); sseSetStatus('<?= __("已连接") ?>'); }
                                    } else if (currentEvent === 'context') {
                                        if (payload.display_text && sseContent) {
                                            sseLog('【<?= __("操作上下文") ?>】', 'info');
                                            const pre = document.createElement('pre');
                                            pre.className = 'weline-sse-terminal-context';
                                            pre.textContent = payload.display_text;
                                            sseContent.appendChild(pre);
                                            if (sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                                        }
                                    } else if (currentEvent === 'unpublished_warning') {
                                        const msg = (payload.message || '<?= __("以下页面未发布，请发布后再使用或注意核对导航链接。") ?>');
                                        const items = payload.items || [];
                                        let existing = document.querySelector('.weline-component-config-modal .weline-sse-unpublished-warning');
                                        if (existing) existing.remove();
                                        if (sseContainer && items.length > 0) {
                                            const wrap = document.createElement('div');
                                            wrap.className = 'weline-sse-unpublished-warning';
                                            wrap.style.cssText = 'margin-top:10px; padding:12px; background:#dc3545; color:#fff; border-radius:6px; border:1px solid #c82333;';
                                            let html = '<div style="font-weight:700; margin-bottom:8px;">⚠️ ' + (msg.replace(/</g, '&lt;')) + '</div>';
                                            html += '<ul style="margin:0 0 10px 0; padding-left:20px; font-size:12px;">';
                                            items.forEach(function(it) {
                                                const t = (it.title || '') + (it.handle ? ' (' + it.handle + ')' : '');
                                                html += '<li>' + (t.replace(/</g, '&lt;')) + '</li>';
                                            });
                                            html += '</ul>';
                                            html += '<button type="button" class="btn btn-sm btn-light weline-sse-unpublished-confirm"><?= __("知道了") ?></button>';
                                            wrap.innerHTML = html;
                                            wrap.querySelector('.weline-sse-unpublished-confirm').addEventListener('click', function() { wrap.remove(); });
                                            sseContainer.parentNode.insertBefore(wrap, sseContainer.nextSibling);
                                            if (sseContent && sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                                        }
                                    } else if (currentEvent === 'trace') {
                                        if (payload.display_text && sseContent) {
                                            let traceEl = document.querySelector('.weline-sse-terminal-trace');
                                            if (!traceEl) {
                                                sseLog('【<?= __("链路追踪") ?>】', 'info');
                                                traceEl = document.createElement('pre');
                                                traceEl.className = 'weline-sse-terminal-trace';
                                                sseContent.appendChild(traceEl);
                                            }
                                            traceEl.textContent = payload.display_text;
                                            if (sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                                        }
                                    } else if (currentEvent === 'prompt') {
                                        if (payload.prompt && sseContent) {
                                            sseLog('【<?= __("本次提示词") ?>】', 'info');
                                            const pre = document.createElement('pre');
                                            pre.className = 'weline-sse-terminal-prompt';
                                            pre.textContent = payload.prompt;
                                            sseContent.appendChild(pre);
                                            if (sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                                        }
                                    } else if (currentEvent === 'chunk') {
                                        const txt = (payload.content && typeof payload.content === 'string') ? payload.content : '';
                                        if (!txt) return;
                                        if (!streamingTextEl && sseContent) {
                                            const line = document.createElement('div');
                                            line.className = 'weline-sse-terminal-line progress weline-sse-terminal-streaming';
                                            line.innerHTML = '<span class="weline-sse-terminal-time">[' + new Date().toLocaleTimeString('zh-CN', { hour12: false }) + ']</span><span class="weline-sse-terminal-text"></span>';
                                            sseContent.appendChild(line);
                                            streamingLineEl = line;
                                            streamingTextEl = line.querySelector('.weline-sse-terminal-text');
                                        }
                                        if (streamingTextEl) {
                                            streamingTextEl.textContent += txt;
                                            if (sseContent && sseContent.parentElement) sseContent.parentElement.scrollTop = sseContent.parentElement.scrollHeight;
                                        }
                                    } else if (currentEvent === 'done') {
                                        if (streamingLineEl) streamingLineEl.classList.remove('weline-sse-terminal-streaming');
                                        streamingLineEl = null; streamingTextEl = null;
                                        const d = payload.data || payload;
                                        restoreBtn();
                                        applyConfigData(d);
                                        sseLog('<?= __("生成完成") ?>', 'done');
                                    } else if (currentEvent === 'error') {
                                        if (streamingLineEl) streamingLineEl.classList.remove('weline-sse-terminal-streaming');
                                        streamingLineEl = null; streamingTextEl = null;
                                        if (payload.message) sseLog(payload.message, 'error');
                                        restoreBtn();
                                        BackendToast.error((payload && payload.message) || '<?= __("生成失败") ?>');
                                    }
                                } catch (e) {}
                                currentEvent = '';
                                currentData = '';
                            }
                            function processChunk(chunk) {
                                if (chunk && chunk.value) buffer += decoder.decode(chunk.value, { stream: true });
                                const SEP_DBL = '\n\n', SEP_SGL = '\n';
                                const parts = buffer.split(SEP_DBL);
                                buffer = parts.pop() || '';
                                for (let i = 0; i < parts.length; i++) {
                                    const lines = parts[i].split(SEP_SGL);
                                    currentEvent = '';
                                    currentData = '';
                                    for (let j = 0; j < lines.length; j++) {
                                        const ln = lines[j];
                                        if (ln.indexOf('event:') === 0) currentEvent = ln.replace(/^event:\s*/, '').trim();
                                        else if (ln.indexOf('data:') === 0) currentData = ln.replace(/^data:\s*/, '');
                                    }
                                    finishEvent();
                                }
                            }
                            while (true) {
                                const val = await reader.read();
                                processChunk(val);
                                if (val && val.done) break;
                            }
                        } catch (err) {
                            console.error('AI生成组件配置错误:', err);
                            restoreBtn();
                            BackendToast.error(err && err.message ? err.message : '<?= __("生成请求失败，请稍后重试") ?>');
                            if (sseContent) sseLog((err && err.message) || '<?= __("请求失败") ?>', 'error');
                        }
                    });
                }
            }
        });
        
        if (result.isConfirmed) {
            // 收集配置数据
            const newConfig = { ...currentConfig };
            document.querySelectorAll('.weline-component-config-modal [data-field]').forEach(input => {
                const fieldKey = input.getAttribute('data-field');
                newConfig[fieldKey] = input.value;
            });
            
            
            // 显示保存中
            BackendToast.info('<?= __('保存中...') ?>', 2000);
            
            // 调用API保存配置
            var saveUrl = '<?= $this->getBackendUrl('*/backend/visual/api/component/updateConfig') ?>';
            var saveOpts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ page_id: pageId, component_code: componentCode, region: region, index: index, config: newConfig }) };
            var saveRes = await window.Weline.Api.request(saveUrl, saveOpts);
            const saveResult = (saveRes && saveRes.data) || saveRes;
            
            if (saveResult.success) {
                BackendToast.success('<?= __('保存成功') ?>');
                
                // 刷新预览，传入编辑前保存的滚动位置
                if (typeof refreshPreview === 'function') {
                    refreshPreview({ scrollX: savedScrollX, scrollY: savedScrollY });
                }
            } else {
                throw new Error(saveResult.message || '<?= __('保存失败') ?>');
            }
        }
        
    } catch (error) {
        console.error('❌ 编辑组件失败:', error);
        BackendToast.error('<?= __('编辑失败') ?>：' + (error.message || '<?= __('未知错误') ?>'));
    }
};

// 组件配置 Modal 函数（替代 Swal.fire 表单弹窗）
function showComponentConfigModal(options) {
    return new Promise((resolve) => {
        const modalId = 'componentConfigModal_' + Date.now();
        
        // 创建 modal HTML
        const modalHtml = `
            <div class="modal fade weline-component-config-modal" id="${modalId}" tabindex="-1" aria-hidden="true" style="z-index: 100520;">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width: 520px;">
                    <div class="modal-content" style="background: var(--backend-color-card-bg); border: 1px solid var(--backend-color-border); border-radius: 8px;">
                        <div class="modal-header" style="border-bottom: 1px solid var(--backend-color-border); padding: 12px 16px;">
                            <h5 class="modal-title" style="color: var(--backend-color-text-primary); font-size: 16px; font-weight: 600;">${options.title || '<?= __('配置') ?>'}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: var(--backend-btn-close-filter, none);"></button>
                        </div>
                        <div class="modal-body" style="padding: 16px; max-height: 60vh; overflow-y: auto;">
                            ${options.html || ''}
                        </div>
                        <div class="modal-footer" style="border-top: 1px solid var(--backend-color-border); padding: 12px 16px; gap: 8px;">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">${options.cancelText || '<?= __('取消') ?>'}</button>
                            <button type="button" class="btn btn-primary btn-sm" id="${modalId}_confirmBtn">${options.confirmText || '<?= __('确定') ?>'}</button>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        // 插入到 body
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        const modalElement = document.getElementById(modalId);
        const modal = new bootstrap.Modal(modalElement, { backdrop: 'static', keyboard: false });
        
        // 确认按钮事件
        const confirmBtn = document.getElementById(modalId + '_confirmBtn');
        confirmBtn.addEventListener('click', () => {
            modal.hide();
            resolve({ isConfirmed: true });
        });
        
        // 关闭/取消事件
        modalElement.addEventListener('hidden.bs.modal', () => {
            // 如果还没有确认过，说明是取消
            modalElement.remove();
        });
        
        // 显示 modal
        modal.show();
        
        // 触发 onOpen 回调
        if (typeof options.onOpen === 'function') {
            modalElement.addEventListener('shown.bs.modal', () => {
                options.onOpen(modalElement);
            }, { once: true });
        }
    });
}

// HTML 转义函数
function escapeHtml(text) {
    if (text === null || text === undefined) return '';
    const div = document.createElement('div');
    div.textContent = String(text);
    return div.innerHTML;
}

// 删除预览中的组件
window.removeComponentInPreview = async function(wrapper) {
    const componentCode = wrapper.getAttribute('data-component');
    const region = wrapper.getAttribute('data-region');
    const index = wrapper.getAttribute('data-index');
    const pageId = window.visualPageId || 0;
    
    
    // 在弹窗显示前保存滚动位置
    const iframe = document.getElementById('previewIframe');
    let savedScrollX = 0;
    let savedScrollY = 0;
    try {
        if (iframe && iframe.contentWindow && iframe.contentDocument) {
            savedScrollX = iframe.contentWindow.scrollX || iframe.contentDocument.documentElement.scrollLeft || 0;
            savedScrollY = iframe.contentWindow.scrollY || iframe.contentDocument.documentElement.scrollTop || 0;
        }
    } catch (e) {
        console.warn('无法获取滚动位置:', e);
    }
    
    const confirmed = await BackendConfirm.show('<?= __('确定要删除此组件吗？') ?>', {
        title: '<?= __('删除组件？') ?>',
        confirmText: '<?= __('确认删除') ?>',
        cancelText: '<?= __('取消') ?>',
        type: 'danger'
    });
    
    if (!confirmed) return;
    
    try {
        // 显示加载提示
        BackendToast.info('<?= __('删除中...') ?>', 2000);
        
        const requestData = {
            page_id: pageId,
            component_code: componentCode,
            region: region
        };
        
        // 如果有索引，添加到请求中（用于精确删除）
        if (index !== null && index !== undefined) {
            requestData.index = parseInt(index, 10);
        }
        
        
        var url = '<?= $this->getBackendUrl('*/backend/visual/api/component/remove') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestData) };
        var res = await window.Weline.Api.request(url, opts);
        const data = (res && res.data) || res;
        
        
        if (data.success) {
            // 刷新预览，传入删除前保存的滚动位置
            if (typeof refreshPreview === 'function') {
                refreshPreview({ scrollX: savedScrollX, scrollY: savedScrollY });
            }
            
            BackendToast.success(data.is_global ? '<?= __('全局组件已删除') ?>' : '<?= __('已删除') ?>');
        } else {
            BackendToast.error('<?= __('删除失败') ?>：' + (data.message || '<?= __('未知错误') ?>'));
        }
    } catch (error) {
        console.error('❌ 删除组件失败:', error);
        BackendToast.error('<?= __('删除失败') ?>：' + (error.message || '<?= __('网络错误') ?>'));
    }
};

// 预览iframe加载完成后设置放置区域
document.addEventListener('DOMContentLoaded', function() {
    const previewFrame = document.getElementById('previewIframe');
    if (previewFrame) {
        previewFrame.addEventListener('load', function() {
            setTimeout(setupPreviewDropZones, 500);
        });
    }
});

</script>

