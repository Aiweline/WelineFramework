// 刷新预览（全局函数，确保可以被 selectColorScheme 调用）
// 支持保持滚动位置，可传入预先保存的位置 { scrollX, scrollY }
window.refreshPreview = function(savedPosition) {
    const loading = document.getElementById('previewLoading');
    const iframe = document.getElementById('previewIframe');
    
    if (!loading || !iframe) {
        return;
    }
    
    // 保存当前滚动位置（如果没有传入预保存的位置）
    let savedScrollX = 0;
    let savedScrollY = 0;
    
    if (savedPosition && (savedPosition.scrollX || savedPosition.scrollY)) {
        // 使用传入的预保存位置
        savedScrollX = savedPosition.scrollX || 0;
        savedScrollY = savedPosition.scrollY || 0;
    } else {
        // 尝试获取当前滚动位置
        try {
            if (iframe.contentWindow && iframe.contentDocument) {
                savedScrollX = iframe.contentWindow.scrollX || iframe.contentDocument.documentElement.scrollLeft || 0;
                savedScrollY = iframe.contentWindow.scrollY || iframe.contentDocument.documentElement.scrollTop || 0;
            }
        } catch (e) {
            // 忽略
        }
    }
    
    loading.classList.add('active');
    
    // 检测是否为模板配置模式
    const isTemplateMode = window.isTemplateConfigMode || false;
    const styleCode = window.currentTemplateStyleCode || '';
    const templatePageId = window.currentTemplatePageId || 0;
    
    // 构建预览 URL（page_id 模式 或 虚拟主题 public_id + page_type）
    const currentPageId = typeof pageId !== 'undefined' ? pageId : (window.pageId || window.visualPageId || 0);
    const useVirtualPreview = typeof window.visualPublicId === 'string' && window.visualPublicId.trim() !== ''
        && typeof window.visualPageType === 'string' && window.visualPageType.trim() !== '';
    let previewUrl;
    if (useVirtualPreview) {
        previewUrl = '<?= $this->getBackendUrl('*/backend/preview/full') ?>?public_id=' + encodeURIComponent(window.visualPublicId)
            + '&page_type=' + encodeURIComponent(window.visualPageType) + '&visual_editor=1';
    } else {
        previewUrl = '<?= $this->getBackendUrl('*/backend/preview/full') ?>?page_id=' + currentPageId + '&visual_editor=1';
    }
    
    if (!useVirtualPreview && isTemplateMode && styleCode) {
        previewUrl += '&style_code=' + encodeURIComponent(styleCode);
        if (templatePageId) {
            previewUrl = '<?= $this->getBackendUrl('*/backend/preview/full') ?>?page_id=' + templatePageId + '&style_code=' + encodeURIComponent(styleCode) + '&visual_editor=1';
        }
    } else {
        const externalStyleSelect = document.getElementById('style');
        const externalStyleCode = externalStyleSelect ? externalStyleSelect.value : (typeof window.currentStyle !== 'undefined' ? window.currentStyle : '');
        if (externalStyleCode) {
            previewUrl += '&style_code=' + encodeURIComponent(externalStyleCode);
        }
        if (window.currentVisualLanguage) {
            previewUrl += '&locale=' + encodeURIComponent(window.currentVisualLanguage);
        }
    }
    
    if (typeof window.visualVirtualThemeId === 'number' && window.visualVirtualThemeId > 0) {
        previewUrl += '&virtual_theme_id=' + encodeURIComponent(String(window.visualVirtualThemeId));
    }
    
    previewUrl += '&t=' + Date.now();
    
    // 重新加载iframe
    iframe.src = previewUrl;
    
    // 监听加载完成
    iframe.onload = function() {
        loading.classList.remove('active');
        
        // 恢复滚动位置
        if (savedScrollY > 0 || savedScrollX > 0) {
            // 延迟恢复，确保内容已渲染
            setTimeout(() => {
                try {
                    if (iframe.contentWindow) {
                        iframe.contentWindow.scrollTo(savedScrollX, savedScrollY);
                    }
                } catch (e) {
                    // 忽略
                }
            }, 100);
        }
        
        // 重新设置拖放区域
        setTimeout(() => {
            if (typeof setupPreviewDropZones === 'function') {
                setupPreviewDropZones();
            }
        }, 200);
    };
}

// 可视化编辑内 iframe 点击 header/footer 链接时通过 postMessage 通知跳转，在此统一处理
window.addEventListener('message', function(e) {
