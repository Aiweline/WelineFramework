// 获取分组展开状态的 localStorage key
function getVisualConfigStateKey() {
    const pageId = document.querySelector('[data-page-id]')?.getAttribute('data-page-id') || 
                   window.location.pathname.match(/\/page\/(\d+)/)?.[1] || 
                   'default';
    return `visual_config_sections_${pageId}`;
}

// 保存分组展开状态到 localStorage
function saveSectionState(sectionId, isExpanded) {
    try {
        const stateKey = getVisualConfigStateKey();
        const states = JSON.parse(localStorage.getItem(stateKey) || '{}');
        states[sectionId] = isExpanded;
        localStorage.setItem(stateKey, JSON.stringify(states));
    } catch (e) {
        console.warn('保存分组状态失败:', e);
    }
}

// 从 localStorage 恢复分组展开状态
function restoreSectionState(sectionId) {
    try {
        const stateKey = getVisualConfigStateKey();
        const states = JSON.parse(localStorage.getItem(stateKey) || '{}');
        return states[sectionId] !== false; // 默认展开（true），除非明确设置为 false
    } catch (e) {
        console.warn('恢复分组状态失败:', e);
        return true; // 默认展开
    }
}

// 切换配置区域
function toggleSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const isCollapsed = section.classList.contains('collapsed');
    section.classList.toggle('collapsed');
    const isExpanded = !section.classList.contains('collapsed');
    
    // 保存状态到 localStorage
    saveSectionState(sectionId, isExpanded);
}

const VISUAL_COLORIS_CSS_URLS = [
    'https://cdn.jsdelivr.net/gh/mdbassit/Coloris@latest/dist/coloris.min.css',
    'https://cdn.jsdelivr.net/npm/@melloware/coloris@latest/dist/coloris.min.css'
];

const VISUAL_COLORIS_JS_URLS = [
    'https://cdn.jsdelivr.net/gh/mdbassit/Coloris@latest/dist/coloris.min.js',
    'https://cdn.jsdelivr.net/npm/@melloware/coloris@latest/dist/umd/coloris.min.js'
];

function ensureVisualColorisCss() {
    if (document.querySelector('link[data-visual-coloris="1"]')) {
        return;
    }
    
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = VISUAL_COLORIS_CSS_URLS[0];
    link.setAttribute('data-visual-coloris', '1');
    link.onerror = function() {
        if (link.href !== VISUAL_COLORIS_CSS_URLS[1]) {
            link.href = VISUAL_COLORIS_CSS_URLS[1];
        }
    };
    document.head.appendChild(link);
}

function ensureVisualColorisJs() {
    if (typeof window.Coloris === 'function') {
        return Promise.resolve(window.Coloris);
    }
    
    if (window.__visualColorisLoadPromise) {
        return window.__visualColorisLoadPromise;
    }
    
    window.__visualColorisLoadPromise = new Promise(function(resolve, reject) {
        let index = 0;
        
        const loadScript = function() {
            if (typeof window.Coloris === 'function') {
                resolve(window.Coloris);
                return;
            }
            
            if (index >= VISUAL_COLORIS_JS_URLS.length) {
                reject(new Error('Coloris script failed to load from all CDN sources'));
                return;
            }
            
            const url = VISUAL_COLORIS_JS_URLS[index++];
            const existing = document.querySelector(`script[data-visual-coloris-src="${url}"]`);
            if (existing) {
                existing.addEventListener('load', function() {
                    if (typeof window.Coloris === 'function') {
                        resolve(window.Coloris);
                    } else {
                        loadScript();
                    }
                }, { once: true });
                existing.addEventListener('error', function() {
                    loadScript();
                }, { once: true });
                return;
            }
            
            const script = document.createElement('script');
            script.src = url;
            script.async = true;
            script.setAttribute('data-visual-coloris-src', url);
            script.onload = function() {
                if (typeof window.Coloris === 'function') {
                    resolve(window.Coloris);
                } else {
                    loadScript();
                }
            };
            script.onerror = function() {
                script.remove();
                loadScript();
            };
            document.head.appendChild(script);
        };
        
        loadScript();
    }).catch(function(error) {
        console.error('[VisualConfig] Coloris 加载失败:', error);
        window.__visualColorisLoadPromise = null;
        throw error;
    });
    
    return window.__visualColorisLoadPromise;
}

function ensureVisualColorisPortal() {
    let portal = document.getElementById('visual-coloris-portal');
    if (portal) {
        return portal;
    }
    
    portal = document.createElement('div');
    portal.id = 'visual-coloris-portal';
    
    const toastContainer = document.querySelector('.backend-toast-container');
    const host = (toastContainer && toastContainer.parentElement) ? toastContainer.parentElement : document.body;
    host.appendChild(portal);
    
    return portal;
}

function updateVisualColorPreview(input) {
    if (!(input instanceof HTMLElement)) {
        return;
    }
    const value = String(input.value || '').trim();
    const isEmpty = value === '';
    input.style.setProperty('--preview-color', isEmpty ? 'transparent' : value);
    input.classList.toggle('visual-color-input-empty', isEmpty);
    input.title = isEmpty ? '<?= __('点击选择颜色') ?>' : value;
}

function initVisualColorInputs(scope) {
    const root = scope instanceof Element ? scope : document;
    const colorInputs = root.querySelectorAll('.visual-color-input[data-coloris]');
    if (!colorInputs.length) {
        return;
    }
    
    ensureVisualColorisCss();
    colorInputs.forEach(function(input) {
        input.setAttribute('autocomplete', 'off');
        if (!input.placeholder) {
            input.placeholder = '#000000 / rgba(...) / transparent';
        }
        
        if (!input.dataset.visualColorPreviewBound) {
            const syncPreview = function() {
                updateVisualColorPreview(input);
            };
            input.addEventListener('input', syncPreview, { passive: true });
            input.addEventListener('change', syncPreview, { passive: true });
            input.dataset.visualColorPreviewBound = '1';
        }
        
        updateVisualColorPreview(input);
    });
    
    ensureVisualColorisJs().then(function() {
        const portal = ensureVisualColorisPortal();
        if (!window.__visualColorisConfigured) {
            window.Coloris({
                el: '.visual-color-input[data-coloris]',
                alpha: true,
                format: 'mixed',
                formatToggle: true,
                clearButton: true,
                theme: 'default',
                themeMode: 'auto',
                parent: portal,
                swatches: [
                    '#ffffff',
                    '#000000',
                    '#0066cc',
                    '#1f7a5b',
                    '#e74c3c',
                    'rgba(0,0,0,0.35)'
                ],
                onChange: function(color, input) {
                    if (!input) {
                        return;
                    }
                    if (input.value !== color) {
                        input.value = color;
                    }
                    input.dispatchEvent(new Event('input', { bubbles: true }));
                }
            });
            window.__visualColorisConfigured = true;
        }
    }).catch(function() {
        // CDN 都失败时保留普通文本输入，不阻断页面其他功能
    });
}

