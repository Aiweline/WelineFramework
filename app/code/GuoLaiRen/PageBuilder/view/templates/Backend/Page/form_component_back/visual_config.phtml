                                    var opt = document.createElement('option');
                                    opt.value = attr.code;
                                    opt.textContent = attr.name + ' (' + attr.code + ')';
                                    if ('${escapeHtmlForTemplate(rawValue)}' === attr.code) opt.selected = true;
                                    select.appendChild(opt);
                                });
                            }
                        })
                        .catch(function(err) {
                            select.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
                        });
                })();
            <\/script>`;
        } else if (config.type === 'eav_options') {
            // EAV 属性选项选择器
            const entityCode = config.entity_code || 'product';
            const attributeCode = config.attribute_code || '';
            const multiple = config.multiple || false;
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field eav-options-select" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" 
                    data-entity-code="${escapeHtmlForTemplate(entityCode)}" 
                    data-attribute-code="${escapeHtmlForTemplate(attributeCode)}" 
                    ${multiple ? 'multiple style="min-height: 120px;"' : ''}>
                <option value=""><?= __('-- 加载中... --') ?></option>
            </select>`;
            if (attributeCode) {
                const selectedValues = multiple ? (Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : [])) : [rawValue];
                fieldHtml += `<script>
                    (function() {
                        var select = document.getElementById('${fieldId}');
                        if (!select) return;
                        var currentValues = ${JSON.stringify(selectedValues)};
                        var url = '<?= $this->getUrl("weline/eav/api/options") ?>?entity_code=' + encodeURIComponent(escapeHtmlForTemplate(entityCode)) + '&attribute_code=' + encodeURIComponent(escapeHtmlForTemplate(attributeCode));
                        var req = window.Weline.Api.get(url, { silent: true });
                        req.then(function(res) {
                            var data = (res && res.data) || res;
                                if (data.success && data.data.options) {
                                    select.innerHTML = '<option value=""><?= __('-- 请选择 --') ?></option>';
                                    data.data.options.forEach(function(opt) {
                                        var option = document.createElement('option');
                                        option.value = opt.id;
                                        option.textContent = opt.value;
                                        if (currentValues.includes(String(opt.id))) option.selected = true;
                                        select.appendChild(option);
                                    });
                                }
                            })
                            .catch(function(err) {
                                select.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
                            });
                    })();
                <\/script>`;
            }
        } else {
            fieldHtml += `<input type="${config.type || 'text'}" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || '')}">`;
        }
        
        fieldHtml += `</div>`;
        return fieldHtml;
    }
    
    // 辅助函数：渲染单个配置分组
    function renderConfigGroup(fileKey, groupKey, group, isColorScheme = false) {
        const sectionId = 'config_' + fileKey + '_' + groupKey;
        let groupHtml = `<div class="config-section ${isColorScheme ? 'color-scheme-section' : ''}" id="${sectionId}">`;
        
        // 配色方案分组：不可折叠，不显示折叠图标
        if (isColorScheme) {
            groupHtml += `<div class="config-section-header" style="cursor: default;">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'palette'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `</div>`;
        } else {
            groupHtml += `<div class="config-section-header" onclick="toggleSection('${sectionId}')">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'cog'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `<i class="mdi mdi-chevron-down"></i>`;
            groupHtml += `</div>`;
        }
        
        groupHtml += `<div class="config-section-body" ${isColorScheme ? 'style="display: block !important;"' : ''}>`;
        
        if (group.configs && typeof group.configs === 'object') {
            for (const configKey in group.configs) {
                const config = group.configs[configKey];
                groupHtml += renderConfigField(configKey, config);
            }
        }
        
        groupHtml += `</div></div>`;
        return groupHtml;
    }
    
    // 收集所有配置分组，确保色系配置（fileKey === 'color_scheme'）渲染在最顶部
    let html = '';

    // 在样式分组之前渲染一个独立的 SEO / TDK 配置块（仅普通页面模式）
    if (!window.isTemplateConfigMode) {
        html += `<div class="config-section seo-section" id="seo_section">
            <div class="config-section-header">
                <span><i class="mdi mdi-google"></i> <?= __('SEO / TDK 设置') ?></span>
            </div>
            <div class="config-section-body">
                <div class="mb-3">
                    <label for="seo_meta_title" class="form-label"><?= __('页面标题（Meta Title）') ?></label>
                    <input type="text"
                           id="seo_meta_title"
                           class="form-control"
                           placeholder="<?= __('用于浏览器标题和搜索结果的主标题') ?>">
                    <div class="form-text">
                        <?= __('建议控制在 30-60 个字符内，包含核心关键词。') ?>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="seo_meta_description" class="form-label"><?= __('页面描述（Meta Description）') ?></label>
                    <textarea id="seo_meta_description"
                              class="form-control"
                              rows="3"
                              placeholder="<?= __('用于搜索结果摘要的描述性文案') ?>"></textarea>
                    <div class="form-text">
                        <?= __('建议控制在 70-150 个字符内，清晰说明页面价值和核心卖点。') ?>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="seo_meta_keywords" class="form-label"><?= __('关键词（Meta Keywords，可选）') ?></label>
                    <input type="text"
                           id="seo_meta_keywords"
                           class="form-control"
                           placeholder="<?= __('以英文逗号分隔的关键词，例如：landing page,seo,marketing') ?>">
                    <div class="form-text">
                        <?= __('现代搜索引擎已弱化该字段，仅做补充参考使用。') ?>
                    </div>
                </div>

                <div class="alert alert-info mb-0">
                    <i class="mdi mdi-information-outline"></i>
                    <?= __('此处修改会直接覆盖当前页面对象记录中的 SEO 字段，而不会写入样式配置。支持按当前预览语言分别维护多语言 TDK。') ?>
                </div>
            </div>
        </div>`;
    }
    const orderedFileKeys = Object.keys(configGroups || {});
    // 将 color_scheme 提前
    const idx = orderedFileKeys.indexOf('color_scheme');
    if (idx > 0) {
        orderedFileKeys.splice(idx, 1);
        orderedFileKeys.unshift('color_scheme');
    }
    
    for (const fileKey of orderedFileKeys) {
        const fileGroup = configGroups[fileKey];
        if (!fileGroup) continue;
        const isColorSchemeFile = fileKey === 'color_scheme';
        if (fileGroup.groups && typeof fileGroup.groups === 'object' && Object.keys(fileGroup.groups).length > 0) {
            for (const groupKey in fileGroup.groups) {
                const group = fileGroup.groups[groupKey];
                html += renderConfigGroup(fileKey, groupKey, group, isColorSchemeFile);
            }
        }
    }
    
    const configFields = document.querySelector('.config-panel-body');
    if (configFields) {
        configFields.innerHTML = html || '<div class="alert alert-info m-3"><?= __('暂无配置项') ?></div>';

        // 普通页面模式下，初始化 SEO / TDK 配置块，自动从页面表单 TDK 字段回填
        if (!window.isTemplateConfigMode) {
            try {
                initSeoSection();
            } catch (e) {
                console.error('[VisualConfig] 初始化 SEO / TDK 区域失败:', e);
            }
        }
        
        // 恢复分组展开状态（SEO/TDK 与配色分组始终展开，其他根据模板类型决定）
        const allSections = Array.from(document.querySelectorAll('.config-section:not(.color-scheme-section):not(.seo-section)'));
        let firstSectionFound = false;
        
        // 获取当前样式代码，判断是否为新版模板
        const externalStyleSelect = document.getElementById('style');
        const currentStyleCode = externalStyleSelect ? externalStyleSelect.value : (window.currentStyle || window.currentTemplateStyleCode || '');
        
        // 新版模板列表（这些模板默认收起所有非 SEO/TDK 分组）
        const newStyleTemplates = ['tpmst', 'marketing-landing', 'modern-shop'];
        const isNewStyleTemplate = newStyleTemplates.some(t => currentStyleCode.toLowerCase().includes(t.toLowerCase()));
        
        // 获取所有保存的状态
        let savedStates = {};
        try {
            const stateKey = getVisualConfigStateKey();
            savedStates = JSON.parse(localStorage.getItem(stateKey) || '{}');
        } catch (e) {
            console.warn('读取分组状态失败:', e);
        }
        
        // 检查是否有任何保存的状态（用于判断是否是首次加载）
        const hasAnySavedState = Object.keys(savedStates).length > 0;
        
        allSections.forEach((section, index) => {
            const sectionId = section.id;
            if (!sectionId) return;
            
            // 检查是否有保存的状态
            const hasSavedState = sectionId in savedStates;
            
            if (hasSavedState) {
                // 有保存的状态，恢复它
                const isExpanded = savedStates[sectionId] !== false;
                if (!isExpanded) {
                    section.classList.add('collapsed');
                } else {
                    section.classList.remove('collapsed');
                }
            } else {
                // 没有保存的状态，根据模板类型决定默认行为
                if (isNewStyleTemplate) {
                    // 新版模板：默认全部收起
                    section.classList.add('collapsed');
                    saveSectionState(sectionId, false);
                } else if (!hasAnySavedState && !firstSectionFound && index === 0) {
                    // 旧模板：首次加载且是第一个组，默认展开
                    firstSectionFound = true;
                    section.classList.remove('collapsed');
                    saveSectionState(sectionId, true);
                } else {
                    // 其他情况默认折叠
                    section.classList.add('collapsed');
                    saveSectionState(sectionId, false);
                }
            }
        });
        
        // 绑定自动保存事件（就地绑定，确保动态渲染后立即生效）
        document.querySelectorAll('.auto-save-field').forEach(field => {
            const handler = function() {
                if (typeof updateSaveStatus === 'function') {
                    updateSaveStatus('', '<?= __('未保存') ?>');
                }
                if (typeof autoSaveConfig === 'function') {
                    autoSaveConfig();
                }
            };
            field.removeEventListener('input', handler);
            field.removeEventListener('change', handler);
            field.addEventListener('input', handler, { passive: true });
            field.addEventListener('change', handler, { passive: true });
        });
        
        initVisualColorInputs(configFields);
        
        // 为每个配置分组添加恢复默认值按钮（在分组标题旁边）
        document.querySelectorAll('.config-section').forEach(section => {
            const header = section.querySelector('.config-section-header span');
            const resetButtons = section.querySelectorAll('.visual-config-reset-btn');
            
            if (header && resetButtons.length > 0) {
                // 检查是否已经有批量恢复按钮
                if (!section.querySelector('.reset-all-fields-btn')) {
                    const resetAllBtn = document.createElement('a');
                    resetAllBtn.href = 'javascript:void(0)';
                    resetAllBtn.className = 'link-danger ms-2 reset-all-fields-btn';
                    resetAllBtn.innerHTML = '<i class="mdi mdi-restore"></i> <?= __('恢复全部') ?>';
                    resetAllBtn.title = '<?= __('恢复此分组所有字段为默认值') ?>';
                    resetAllBtn.onclick = function(e) {
                        e.stopPropagation();
                        resetVisualConfigGroup(section);
                    };
                    header.appendChild(resetAllBtn);
                }
            }
        });
    }
}

// 模板配置模式：刷新模板预览（别名，保持兼容）
function refreshTemplatePreview() {
    refreshPreview();
}

// 模板配置模式：刷新配置（重新扫描模板字段）
function refreshTemplateConfig(event) {
    const btn = event ? event.target.closest('button') : document.querySelector('button[onclick*="refreshTemplateConfig"]');
    if (!btn) return;
    
    const icon = btn.querySelector('i');
    const originalClass = icon.className;
    
    btn.disabled = true;
    icon.className = 'mdi mdi-loading mdi-spin';
    
    const configPanel = document.querySelector('.config-panel-body');
    if (configPanel) {
        configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('正在刷新配置...') ?></div></div>';
    }
    
    loadTemplateStyleConfig(true)
        .then(() => {
            refreshTemplatePreview();
        })
        .catch(error => {
            console.error('❌ 刷新失败:', error);
            if (configPanel) {
                configPanel.innerHTML = '<div class="alert alert-danger m-3"><?= __('刷新配置失败') ?></div>';
            }
        })
        .finally(() => {
            btn.disabled = false;
            icon.className = originalClass;
        });
}

// HTML转义辅助函数（模板配置模式使用）
function escapeHtmlForTemplate(text) {
    if (typeof text === 'undefined' || text === null) return '';
    const div = document.createElement('div');
    div.textContent = String(text);
    return div.innerHTML;
}

// ========== 普通页面模式：加载指定样式的配置 ==========
async function loadVisualStyleConfig() {
    try {
        const currentPageId = typeof pageId !== 'undefined' ? pageId : (window.pageId || window.visualPageId || 0);
        const externalStyleSelect = document.getElementById('style');
        const styleCode = externalStyleSelect ? externalStyleSelect.value : (typeof window.currentStyle !== 'undefined' ? window.currentStyle : '');
        const locale = window.currentVisualLanguage || '';

        if (!styleCode) {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-info m-3"><?= __('请先选择样式模板（方案）') ?></div>';
            }
            return;
        }

        // 显示加载中
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('正在加载配置...') ?></div></div>';
        }

        // 复用模板配置的获取接口
        let url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
            '?style_code=' + encodeURIComponent(styleCode) +
            '&page_id=' + encodeURIComponent(currentPageId);
        if (locale) {
            url += '&locale=' + encodeURIComponent(locale);
        }

        var res = await window.Weline.Api.get(url, { silent: true });
        const result = (res && res.data) || res;
        if (result.success && result.data) {
            // 显示模板信息（名称 + 代码）
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            // 直接复用渲染逻辑
            renderTemplateConfig(result.data);
        } else {
            if (configPanel) {
                configPanel.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('加载配置失败') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('加载配置失败:', error);
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?></div>';
        }
    }
}

// ========== 刷新样式配置按钮（普通页面模式） ==========
window.refreshVisualStyleConfig = async function(event) {
    try {
        // 处理按钮 loading 状态（可选）
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = true;
            if (icon) { icon.className = 'mdi mdi-loading mdi-spin'; }
        }

        // 重新加载样式配置
        await loadVisualStyleConfig();

        // 刷新预览（如果对应函数存在则调用）
        if (typeof refreshVisualPreview === 'function') {
            refreshVisualPreview();
        } else if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    } catch (error) {
        console.error('刷新样式配置失败:', error);
        BackendToast.error('<?= __('刷新失败') ?>：' + (error && error.message ? error.message : 'Unknown error'));
    } finally {
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = false;
            if (icon) { icon.className = 'mdi mdi-refresh'; }
        }
    }
};

// ========== 全屏模式功能 ==========
window.toggleFullscreen = function() {
    const wrapper = document.getElementById('visualConfigWrapper');
    const btn = document.getElementById('fullscreenBtn');
    const icon = btn ? btn.querySelector('i') : null;
    const panel = document.getElementById('configPanel');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    
    if (!wrapper || !btn) return;
    
    wrapper.classList.toggle('fullscreen-mode');
    btn.classList.toggle('active');
    
    // 切换图标
    if (icon) {
        if (wrapper.classList.contains('fullscreen-mode')) {
            icon.className = 'mdi mdi-fullscreen-exit';
            btn.title = '<?= __('退出全屏') ?>';
            // 进入全屏时立即收起配置面板
            if (panel) panel.classList.add('collapsed');
            // 显示悬浮展开按钮
            if (floatingBtn) floatingBtn.style.display = 'block';
        } else {
            icon.className = 'mdi mdi-fullscreen';
            btn.title = '<?= __('全屏模式') ?>';
            // 退出全屏时展开配置面板
            if (panel) panel.classList.remove('collapsed');
            // 隐藏悬浮展开按钮
            if (floatingBtn) floatingBtn.style.display = 'none';
        }
    }
};

// ========== 配置面板收起/展开功能 ==========
window.toggleConfigPanel = function() {
    const panel = document.getElementById('configPanel');
    const btn = document.getElementById('configPanelToggle');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    const wrapper = document.getElementById('visualConfigWrapper');
    
    if (!panel) return;
    
    panel.classList.toggle('collapsed');
    
    // 更新面板内的收起按钮图标
    if (btn) {
        const icon = btn.querySelector('i');
        if (icon) {
            if (panel.classList.contains('collapsed')) {
                icon.className = 'mdi mdi-chevron-right';
                btn.title = '<?= __('展开面板') ?>';
            } else {
                icon.className = 'mdi mdi-chevron-left';
                btn.title = '<?= __('收起面板') ?>';
            }
        }
    }
    
    // 控制悬浮展开按钮的显示（仅全屏模式下）
    if (wrapper && wrapper.classList.contains('fullscreen-mode') && floatingBtn) {
        if (panel.classList.contains('collapsed')) {
            floatingBtn.style.display = 'block';
        } else {
            floatingBtn.style.display = 'none';
        }
    }
};

// ========== 语言切换功能 ==========
window.switchVisualLanguage = function(language) {
    
    // 更新当前语言（如果是在模板配置模式，需要特殊处理）
    if (window.isTemplateConfigMode) {
        // 模板配置模式下的语言切换逻辑
        window.currentVisualLanguage = language;
        
        // 显示加载提示
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-info m-3"><i class="mdi mdi-loading mdi-spin"></i> 正在加载 ' + language + ' 语言配置...</div>';
        }
        
        // 重新加载配置（模板配置模式）
        if (typeof loadTemplateStyleConfig === 'function') {
            loadTemplateStyleConfig().then(() => {
                refreshPreview();
            });
        }
    } else {
        // 正常页面配置模式下的语言切换逻辑
        window.currentVisualLanguage = language;
        
        // 显示加载提示
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-info m-3"><i class="mdi mdi-loading mdi-spin"></i> 正在加载 ' + language + ' 语言配置...</div>';
        }
        
        // 重新加载配置（页面配置模式）
        if (typeof loadVisualStyleConfig === 'function') {
            loadVisualStyleConfig().then(() => {
                if (typeof refreshVisualPreview === 'function') {
                    refreshVisualPreview();
                } else {
                    refreshPreview();
                }
            });
        }
    }
};

// ========== PageSpeed Insights 功能 ==========
window.openPageSpeedMobile = function(){
    // 检查页面是否已发布
    const btn = document.getElementById('psiMobileBtn');
    if (btn) {
        const isPublished = btn.getAttribute('data-is-published') === '1';
        if (!isPublished) {
            BackendToast.warning('<?= __('无法测试：页面未发布，无法进行 PageSpeed 测试。原因：PageSpeed Insights 需要访问已发布的公开页面才能进行分析。解决方法：请先在页面编辑表单中将页面状态设置为"已发布"，然后再进行测试。') ?>');
            return;
        }
    }
    
    // 获取页面句柄
    let handle = '';
    if (window.isTemplateConfigMode) {
        // 模板配置模式：使用测试页面句柄
        const page = <?= ($page && $page->getId()) ? json_encode($page->getData('handle'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) : 'null' ?>;
        handle = page || '';
    } else {
        // 正常模式：从表单获取
        const handleInput = document.getElementById('handle');
        handle = handleInput ? handleInput.value.trim() : '';
    }
    
    if (!handle){
        BackendToast.warning('<?= __('页面句柄不能为空，无法测试 PageSpeed') ?>');
        return;
    }
    
    const baseUrl = '<?= rtrim(rtrim($this->request->getBaseHost(), '/'), ':') ?>';
    // 本地环境不启用
    try {
        const u = new URL(baseUrl);
        const h = u.hostname || '';
        const isPrivate = (
            h === 'localhost' || h === '127.0.0.1' || h === '::1' ||
            /\.local$/i.test(h) || /^10\./.test(h) || /^192\.168\./.test(h) || /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(h)
        );
        if (isPrivate) {
            const btn = document.getElementById('psiMobileBtn');
            if (btn) {
                btn.disabled = true;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-secondary');
                btn.title = '<?= __('本地或内网地址无法使用 PageSpeed，请部署到公网或提供可访问 URL') ?>';
            }
            return;
        }
    } catch(_) {}
    
    const previewUrl = baseUrl + '/' + handle + '?preview=1';
    // 使用官方 analysis 接口并传入 url 参数，默认手机端
    const psiUrl = 'https://pagespeed.web.dev/analysis?url=' + encodeURIComponent(previewUrl) + '&form_factor=mobile';
    window.open(psiUrl, '_blank', 'noopener');
};

