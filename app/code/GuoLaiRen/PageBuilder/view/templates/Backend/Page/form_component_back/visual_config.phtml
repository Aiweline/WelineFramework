// ========== 配置导入导出功能 ==========
window.exportPageConfig = async function() {
    try {
        let pageId = window.pageId || 0;
        let styleCode = '';
        
        if (window.isTemplateConfigMode) {
            // 模板配置模式
            pageId = window.currentTemplatePageId || 0;
            styleCode = window.currentTemplateStyleCode || '';
        } else {
            // 正常页面配置模式
            pageId = window.visualPageId || pageId;
            const styleSelect = document.getElementById('style');
            styleCode = styleSelect ? styleSelect.value : '';
            if (!styleCode && typeof currentStyle !== 'undefined' && currentStyle) {
                styleCode = currentStyle;
            }
        }
        
        if (!pageId || !styleCode) {
            BackendToast.error('<?= __("导出失败：请先选择样式模板") ?>');
            return;
        }
        
        // 显示加载状态
        const exportBtn = document.getElementById('exportConfigBtn');
        const originalHtml = exportBtn ? exportBtn.innerHTML : '';
        if (exportBtn) {
            exportBtn.disabled = true;
            exportBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("导出中...") ?>';
        }
        
        // 调用导出接口
        let url = '';
        if (window.isTemplateConfigMode) {
            url = '<?= $this->getBackendUrl("*/backend/template/exportConfig") ?>' + 
                '?style_code=' + encodeURIComponent(styleCode) + 
                '&page_id=' + encodeURIComponent(pageId);
        } else {
            url = '<?= $this->getBackendUrl("*/backend/page/exportConfig") ?>' + 
                '?page_id=' + encodeURIComponent(pageId) + 
                '&style_code=' + encodeURIComponent(styleCode);
        }
        
        const response = await fetch(url, {
            method: 'GET',
            credentials: 'same-origin'
        });
        
        if (!response.ok) {
            throw new Error('HTTP ' + response.status);
        }
        
        // 获取文件名
        const contentDisposition = response.headers.get('Content-Disposition');
        let filename = 'config-' + pageId + '-' + styleCode + '.xlsx';
        if (contentDisposition) {
            const filenameMatch = contentDisposition.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
            if (filenameMatch && filenameMatch[1]) {
                filename = filenameMatch[1].replace(/['"]/g, '');
            }
        }
        
        // 下载文件
        const blob = await response.blob();
        const downloadUrl = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = downloadUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(downloadUrl);
        
        if (typeof showToast === 'function') {
            showToast('success', '<?= __("导出成功") ?>', '<?= __("配置已导出到Excel文件") ?>');
        }
        
        // 恢复按钮状态
        if (exportBtn) {
            exportBtn.innerHTML = originalHtml;
            exportBtn.disabled = false;
        }
    } catch (error) {
        console.error('导出配置失败:', error);
        BackendToast.error('<?= __("导出失败") ?>：' + (error.message || '<?= __("未知错误") ?>'));
        
        // 恢复按钮状态
        const exportBtn = document.getElementById('exportConfigBtn');
        if (exportBtn) {
            exportBtn.disabled = false;
            exportBtn.innerHTML = '<i class="mdi mdi-download"></i> <?= __("导出配置") ?>';
        }
    }
};

