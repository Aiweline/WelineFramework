async function handleConfigImport(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    try {
        const formData = new FormData();
        formData.append('config_file', file);
        
        let pageId = window.pageId || 0;
        let styleCode = '';
        let url = '';
        
        if (window.isTemplateConfigMode) {
            pageId = window.currentTemplatePageId || 0;
            styleCode = window.currentTemplateStyleCode || '';
            url = '<?= $this->getBackendUrl("*/backend/template/importConfig") ?>';
            formData.append('style_code', styleCode);
            formData.append('page_id', pageId);
        } else {
            pageId = window.visualPageId || pageId;
            const styleSelect = document.getElementById('style');
            styleCode = styleSelect ? styleSelect.value : '';
            url = '<?= $this->getBackendUrl("*/backend/page/importConfig") ?>';
            formData.append('page_id', pageId);
            formData.append('style_code', styleCode);
        }
        
        // 显示加载状态
        const importBtn = document.getElementById('importConfigBtn');
        const originalHtml = importBtn ? importBtn.innerHTML : '';
        if (importBtn) {
            importBtn.disabled = true;
            importBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("导入中...") ?>';
        }
        
        var opts = { method: 'POST', body: formData, credentials: 'same-origin' };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (result.success) {
            BackendToast.success('<?= __("导入成功") ?>：' + (result.message || '<?= __("配置已导入") ?>'));
            
            // 重新加载配置
            if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                loadTemplateStyleConfig().then(() => {
                    refreshPreview();
                });
            } else if (typeof loadVisualStyleConfig === 'function') {
                loadVisualStyleConfig().then(() => {
                    if (typeof refreshVisualPreview === 'function') {
                        refreshVisualPreview();
                    } else {
                        refreshPreview();
                    }
                });
            }
        } else {
            throw new Error(result.message || '<?= __("导入失败") ?>');
        }
        
        // 恢复按钮状态
        if (importBtn) {
            importBtn.innerHTML = originalHtml;
            importBtn.disabled = false;
        }
        
        // 清空文件输入
        event.target.value = '';
    } catch (error) {
        console.error('导入配置失败:', error);
        BackendToast.error('<?= __("导入失败") ?>：' + (error.message || '<?= __("未知错误") ?>'));
        
        // 恢复按钮状态
        const importBtn = document.getElementById('importConfigBtn');
        if (importBtn) {
            importBtn.disabled = false;
            importBtn.innerHTML = '<i class="mdi mdi-upload"></i> <?= __("导入配置") ?>';
        }
        
        // 清空文件输入
        event.target.value = '';
    }
}

// ========== 恢复默认值功能 ==========
/**
 * 恢复单个配置字段为默认值
 */
window.resetVisualConfigField = function(button) {
    const fieldId = button.getAttribute('data-field-id');
    const fieldType = button.getAttribute('data-config-type');
    const defaultValue = button.getAttribute('data-default-value');
    const configKey = button.getAttribute('data-config-key');
    
    
    const field = document.getElementById(fieldId);
    if (!field) {
        console.error('❌ 找不到字段:', fieldId);
        return;
    }
    
    // 根据字段类型进行不同的处理
    switch (fieldType) {
        case 'text':
        case 'number':
        case 'responsive':
        case 'textarea':
            // 文本类型：设置为默认值（如果为空则清空）
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'select':
            // 下拉框：设置为默认值或第一个选项
            if (defaultValue) {
                // 尝试找到并选择默认值
                for (let i = 0; i < field.options.length; i++) {
                    if (field.options[i].value === defaultValue) {
                        field.selectedIndex = i;
                        break;
                    }
                }
            } else {
                field.selectedIndex = 0;
            }
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'radio':
            // Radio 类型：选择默认值对应的 radio
            if (defaultValue) {
                const radioField = document.querySelector(`input[name="${fieldId}"][value="${defaultValue}"]`);
                if (radioField) {
                    radioField.checked = true;
                    radioField.dispatchEvent(new Event('change', { bubbles: true }));
                }
            } else {
                // 如果没有默认值，选择第一个
                const firstRadio = document.querySelector(`input[name="${fieldId}"]`);
                if (firstRadio) {
                    firstRadio.checked = true;
                    firstRadio.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
            break;
            
        case 'color':
            // Coloris 使用文本输入，保留 hex/rgb/rgba/transparent 原始值
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('input', { bubbles: true }));
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
        
        case 'color_scheme':
            // 色系选择：调用选择函数以更新隐藏输入与UI
            if (typeof window.selectColorScheme === 'function') {
                const schemeKey = defaultValue || 'default';
                window.selectColorScheme(fieldId, schemeKey);
            } else {
                // 后备：直接写值并触发保存
                field.value = defaultValue || 'default';
                field.dispatchEvent(new Event('change', { bubbles: true }));
                if (typeof window.autoSaveConfig === 'function') {
                    window.autoSaveConfig(true);
                }
            }
            break;
            
        default:
            // 其他类型：设置为默认值
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
    }
    
    // 显示提示信息
    if (typeof showToast === 'function') {
        showToast('success', '<?= __('成功') ?>', '<?= __('已恢复为默认值') ?>');
    } else {
    }
};

/**
 * 显示恢复默认值确认模态框
 */
function showResetConfigConfirmModal(title, message, details, onConfirm) {
    // 检查 bootstrap 是否可用
    if (typeof bootstrap === 'undefined') {
        console.error('❌ Bootstrap 未加载！');
        BackendConfirm.show(message, { title: title }).then((confirmed) => {
            if (confirmed) onConfirm();
        });
        return;
    }
    
    const modalElement = document.getElementById('resetConfigConfirmModal');
    if (!modalElement) {
        console.error('❌ 找不到确认模态框');
        BackendConfirm.show(message, { title: title }).then((confirmed) => {
            if (confirmed) onConfirm();
        });
        return;
    }
    
    // 设置模态框内容
    document.getElementById('resetConfigMessage').textContent = message;
    const detailsEl = document.getElementById('resetConfigDetails');
    if (details) {
        detailsEl.innerHTML = details;
        detailsEl.style.display = 'block';
    } else {
        detailsEl.style.display = 'none';
    }
    
    // 移除旧的确认按钮事件监听器
    const confirmBtn = document.getElementById('confirmResetConfigBtn');
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
    
    // 绑定新的确认事件
    newConfirmBtn.onclick = function() {
        const modal = bootstrap.Modal.getInstance(modalElement);
        if (modal) {
            modal.hide();
        }
        onConfirm();
    };
    
    // 显示模态框
    const modal = new bootstrap.Modal(modalElement);
    modal.show();
}

