<?php
/**
 * 可视化配置界面（左配置右预览）
 * 支持通过 handle 或 page_id 初始化
 * 
 * 使用方式：
 * 1. 通过 handle 初始化（推荐）：
 *    GuoLaiRen_PageBuilder::Backend/Page/form_component/visual_config.phtml
 *    需要确保页面中有 <input id="handle"> 元素，或者通过 JS 设置 window.visualConfigHandle
 * 
 * 2. 通过 page_id 初始化：
 *    $this->assign('visual_config_page_id', $pageId);
 *    GuoLaiRen_PageBuilder::Backend/Page/form_component/visual_config.phtml
 * 
 * @var \Weline\Framework\View\Template $this
 */
// 尝试从多种方式获取 page_id 和 handle
$page = $this->getData('page');
$pageId = $this->getData('visual_config_page_id') ?: ($page && $page->getId() ? $page->getId() : 0);
$handle = $this->getData('visual_config_handle') ?: ($page ? $page->getData('handle') : '');
$styleSettings = $page ? $page->getStyleSettings() : [];
$isTemplateConfigMode = $this->getData('is_template_config_mode') ?: false;

// 虚拟主题 / 会话预览：由 virtual-edit 等入口 assign，普通编辑页为 0 / 空串
$virtualThemeIdForVisual = (int)($this->getData('visual_config_virtual_theme_id') ?: 0);
$visualPublicId = (string)($this->getData('visual_public_id') ?? '');
$visualPageTypeForPreview = (string)($this->getData('visual_page_type') ?? '');
$visualPreviewUrlBootstrap = (string)($this->getData('visual_preview_url') ?? '');
$isVisualVirtualMode = (bool)($this->getData('visual_is_virtual_mode') ?? false);
$previewIframeSrc = ($isVisualVirtualMode && $visualPreviewUrlBootstrap !== '')
    ? $visualPreviewUrlBootstrap
    : $this->getBackendUrl('*/backend/preview/full', ['page_id' => (int)$pageId, 'visual_editor' => '1']);

// AI 组件配置生成所需：页面类型、页面描述、各类型提示词（供前端手风琴展示）
$pageType = $page ? (string)($page->getData('type') ?? 'custom_page') : 'custom_page';
$aiDescription = $page ? (string)($page->getData('ai_description') ?? '') : '';
$pageTypePromptMap = \GuoLaiRen\PageBuilder\Model\Page::getPageTypePromptInstructionsMap();
$pageTypeNames = \GuoLaiRen\PageBuilder\Model\Page::getPageTypes();
$currentPageTypePrompt = $pageTypePromptMap[$pageType] ?? $pageTypePromptMap['custom_page'] ?? '';
$currentPageTypeName = $pageTypeNames[$pageType] ?? $pageType;

// 渲染 SseTerminal 组件 HTML（用于组件配置弹窗内的 AI 生成过程展示）
ob_start();
?>
<w:theme:sse-terminal id="aiComponentConfigSseTerminal" title="@lang{生成过程}" height="180px" events="start,progress,chunk,done,error" show-toolbar="true" />
