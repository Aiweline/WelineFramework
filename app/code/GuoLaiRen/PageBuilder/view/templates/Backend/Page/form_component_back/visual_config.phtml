// 色系选择函数（全局函数）
window.selectColorScheme = function(fieldId, schemeKey) {
    const hiddenInput = document.getElementById(fieldId);
    if (!hiddenInput) return;
    
    // 更新隐藏输入框的值
    hiddenInput.value = schemeKey;
    
    // 更新UI：移除所有选中状态
    const container = document.getElementById(fieldId + '_container');
    if (container) {
        container.querySelectorAll('.color-scheme-item').forEach(item => {
            item.classList.remove('selected');
            const check = item.querySelector('.color-scheme-check');
            if (check) {
                check.classList.remove('active');
            }
        });
        
        // 添加新的选中状态
        const selectedItem = container.querySelector(`[data-scheme-key="${schemeKey}"]`);
        if (selectedItem) {
            selectedItem.classList.add('selected');
            const check = selectedItem.querySelector('.color-scheme-check');
            if (check) {
                check.classList.add('active');
            }
        }
    }
    
    // 触发自动保存
    if (typeof window.updateSaveStatus === 'function') {
        window.updateSaveStatus('', '<?= __('未保存') ?>');
    }
    
    // 检测是否为模板配置模式
    const isTemplateMode = window.isTemplateConfigMode || false;
    
    // 立即触发保存（不延迟，色系切换需要立即生效）
    if (isTemplateMode) {
        // 模板配置模式：立即保存并刷新预览
        if (typeof window.autoSaveConfig === 'function') {
            window.autoSaveConfig(true).then(() => {
                // 保存成功后刷新预览
                if (typeof refreshTemplatePreview === 'function') {
                    refreshTemplatePreview();
                } else if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
            }).catch(error => {
                console.error('❌ 保存失败:', error);
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('保存失败') ?>');
                }
            });
        } else {
            console.error('❌ autoSaveConfig 函数未定义');
        }
    } else {
        // 正常模式：立即保存并刷新预览
        if (typeof window.autoSaveConfig === 'function') {
            window.autoSaveConfig(true).then(() => {
                // 保存成功后刷新预览
                if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
            }).catch(error => {
                console.error('❌ 保存失败:', error);
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('保存失败') ?>');
                }
            });
        } else {
            console.error('❌ autoSaveConfig 函数未定义');
        }
    }
}

// 监听所有自动保存字段
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.auto-save-field').forEach(field => {
        field.addEventListener('input', function() {
            updateSaveStatus('', '<?= __('未保存') ?>');
            autoSaveConfig();
        });
        
        field.addEventListener('change', function() {
            updateSaveStatus('', '<?= __('未保存') ?>');
            autoSaveConfig();
        });
    });
    // 全局事件委托：保证动态渲染的字段也能触发自动保存
    const delegatedAutoSaveHandler = function(e) {
        const target = e.target;
        if (target && target.classList && target.classList.contains('auto-save-field')) {
            if (typeof updateSaveStatus === 'function') {
                updateSaveStatus('', '<?= __('未保存') ?>');
            }
            if (typeof autoSaveConfig === 'function') {
                autoSaveConfig();
            }
        }
    };
    document.addEventListener('input', delegatedAutoSaveHandler, true);
    document.addEventListener('change', delegatedAutoSaveHandler, true);
    // 监听外部样式选择器变化，联动加载配置和预览
    const externalStyleSelect = document.getElementById('style');
    if (externalStyleSelect) {
        externalStyleSelect.addEventListener('change', function() {
            // 普通页面模式下，根据选中样式动态加载配置
            if (!window.isTemplateConfigMode && typeof loadVisualStyleConfig === 'function') {
                loadVisualStyleConfig().then(() => {
                    if (typeof window.refreshPreview === 'function') {
                        window.refreshPreview();
                    }
                });
            }
        });
    }
});

// 键盘快捷键
document.addEventListener('keydown', function(e) {
    // ESC 退出全屏（如果不在AI生成中）
    if (e.key === 'Escape') {
        closeVisualConfig();
    }
    
    // Ctrl+S 保存
    if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        autoSaveConfig();
    }
});

// ========== 模板配置模式专用函数 ==========

// 模板配置模式：加载模板样式配置
async function loadTemplateStyleConfig(forceScan = false) {
    const styleCode = window.currentTemplateStyleCode || '';
    const templatePageId = window.currentTemplatePageId || 0;
    
    if (!styleCode) {
        console.error('模板代码不能为空');
        return;
    }
    
    try {
        let url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
            '?style_code=' + encodeURIComponent(styleCode) +
            '&page_id=' + templatePageId;
        
        if (forceScan) {
            url += '&force_scan=1&t=' + Date.now();
        }
        
        var res = await window.Weline.Api.get(url, { silent: true });
        const result = (res && res.data) || res;
        
        if (result.success && result.data) {
            // 显示模板信息（名称 + 代码）
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            renderTemplateConfig(result.data);
        } else {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('加载配置失败') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('加载配置失败:', error);
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?></div>';
        }
    }
}

// 模板配置模式：渲染模板配置
function renderTemplateConfig(configGroups) {

    // 初始化 SEO / TDK 配置块：同步当前语言下的 TDK 值，并绑定自动保存
    function initSeoSection() {
        const metaTitleInput = document.getElementById('seo_meta_title');
        const metaDescInput = document.getElementById('seo_meta_description');
        const metaKeywordsInput = document.getElementById('seo_meta_keywords');

        if (!metaTitleInput || !metaDescInput || !metaKeywordsInput) {
            return;
        }

        const getCurrentLocale = function () {
            return window.currentVisualLanguage || window.defaultLanguage || '';
        };

        const isDefaultLocale = function (locale) {
            const def = window.defaultLanguage || '';
            if (!locale || !def) {
                return true;
            }
            return locale === def;
        };

        const syncFromBaseFields = function () {
            const locale = getCurrentLocale();
            const useDefault = isDefaultLocale(locale);

            const titleId = useDefault ? 'meta_title' : 'meta_title_' + locale;
            const descId = useDefault ? 'meta_description' : 'meta_description_' + locale;
            const keywordsId = useDefault ? 'meta_keywords' : 'meta_keywords_' + locale;

            const baseTitle = document.getElementById(titleId);
            const baseDesc = document.getElementById(descId);
            const baseKeywords = document.getElementById(keywordsId);

            metaTitleInput.value = baseTitle ? (baseTitle.value || '') : '';
            metaDescInput.value = baseDesc ? (baseDesc.value || '') : '';
            metaKeywordsInput.value = baseKeywords ? (baseKeywords.value || '') : '';
        };

        const syncToBaseFields = function () {
            const locale = getCurrentLocale();
            const useDefault = isDefaultLocale(locale);

            const titleId = useDefault ? 'meta_title' : 'meta_title_' + locale;
            const descId = useDefault ? 'meta_description' : 'meta_description_' + locale;
            const keywordsId = useDefault ? 'meta_keywords' : 'meta_keywords_' + locale;

            const baseTitle = document.getElementById(titleId);
            const baseDesc = document.getElementById(descId);
            const baseKeywords = document.getElementById(keywordsId);

            if (baseTitle) {
                baseTitle.value = metaTitleInput.value;
            }
            if (baseDesc) {
                baseDesc.value = metaDescInput.value;
            }
            if (baseKeywords) {
                baseKeywords.value = metaKeywordsInput.value;
            }
        };

        let seoSaveTimer = null;

        const scheduleSeoSave = function () {
            if (seoSaveTimer) {
                clearTimeout(seoSaveTimer);
                seoSaveTimer = null;
            }
            seoSaveTimer = setTimeout(function () {
                window.saveSeoConfig && window.saveSeoConfig();
            }, 800);
        };

        const bindSeoField = function (input) {
            input.addEventListener('input', function () {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('', '<?= __('未保存') ?>');
                }
                syncToBaseFields();
                scheduleSeoSave();
            });
            input.addEventListener('change', function () {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('', '<?= __('未保存') ?>');
                }
                syncToBaseFields();
                scheduleSeoSave();
            });
        };

        // 首次同步当前语言的 TDK 值
        syncFromBaseFields();

        // 绑定输入事件
        bindSeoField(metaTitleInput);
        bindSeoField(metaDescInput);
        bindSeoField(metaKeywordsInput);

        // 当预览语言切换时，外部会更新 window.currentVisualLanguage，这里提供一个简易的重新同步接口
        window.refreshSeoSection && window.refreshSeoSection();
        window.refreshSeoSection = function () {
            syncFromBaseFields();
        };
    }
    // 辅助函数：渲染单个配置字段
    function renderConfigField(configKey, config) {
        const rawValue = config.value !== undefined ? config.value : (config.default || '');
        const fieldId = 'config_' + configKey.replace(/\./g, '_');
        
        let fieldHtml = `<div class="mb-3 config-field-item" data-config-key="${escapeHtmlForTemplate(configKey)}" data-config-label="${escapeHtmlForTemplate(config.label || '')}" data-config-description="${escapeHtmlForTemplate(config.description || config.note || '')}">`;
        // 添加恢复默认值按钮到标签中
        const escapedDefault = escapeHtmlForTemplate(config.default || '');
        fieldHtml += `<label for="${fieldId}" class="form-label">`;
        fieldHtml += `${escapeHtmlForTemplate(config.label)}`;
        fieldHtml += ` <a href="javascript:void(0)" 
                         class="link-warning ms-1 visual-config-reset-btn" 
                         data-field-id="${fieldId}"
                         data-config-key="${escapeHtmlForTemplate(configKey)}"
                         data-config-type="${config.type || 'text'}"
                         data-default-value="${escapedDefault}"
                         onclick="resetVisualConfigField(this)"
                         title="<?= __('恢复默认值') ?>">
                        <i class="mdi mdi-restore"></i> <span class="reset-text"><?= __('恢复') ?></span>
                     </a>`;
        fieldHtml += `</label>`;
        
        // 显示描述信息（如果有）
        if (config.description && config.description.trim()) {
            // 将 \n 转换为 <br>，同时转义其他HTML字符
            let descriptionHtml = String(config.description || '')
                .replace(/\\n/g, '\n')  // 先转换字面量 \n 为实际换行
                .replace(/\r\n/g, '\n')  // 统一处理 \r\n
                .replace(/\n/g, '<br>'); // 将换行符转换为 <br>
            descriptionHtml = escapeHtmlForTemplate(descriptionHtml.replace(/<br>/g, '__BR__'))
                .replace(/__BR__/g, '<br>'); // 保留 <br> 标签
            
            fieldHtml += `<div class="form-text text-muted mb-2" style="font-size: 0.875rem; line-height: 1.4;">`;
            fieldHtml += `<i class="mdi mdi-information-outline me-1" style="font-size: 14px;"></i>`;
            fieldHtml += descriptionHtml;
            fieldHtml += `</div>`;
        }
        
        // 特殊处理：色系选择（带预览图）
        if (config.type === 'color_scheme' && config.color_schemes) {
            fieldHtml += `<div class="color-scheme-selector" id="${fieldId}_container">`;
            fieldHtml += `<input type="hidden" id="${fieldId}" class="auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
            
            const colorSchemes = config.color_schemes;
            fieldHtml += `<div class="color-scheme-grid">`;
            
            for (const schemeKey in colorSchemes) {
                const scheme = colorSchemes[schemeKey];
                const isSelected = rawValue == schemeKey;
                // 预览图片路径：使用后端静态资源接口
                let previewUrl = '';
                if (scheme.preview_image) {
                    const pv = String(scheme.preview_image || '');
                    if (/^(https?:)?\/\//.test(pv) || pv.startsWith('/')) {
                        // 已是绝对URL或以/开头
                        previewUrl = pv;
                    } else {
                        // 相对路径，拼接模板静态基准URL
                        previewUrl = '<?= $this->fetchTemplateStatic("GuoLaiRen_PageBuilder::") ?>' + pv.replace(/^style\//, 'templates/style/');
                    }
                }
                
                fieldHtml += `<div class="color-scheme-item ${isSelected ? 'selected' : ''}" 
                        data-scheme-key="${escapeHtmlForTemplate(schemeKey)}" 
                        onclick="selectColorScheme('${fieldId}', '${escapeHtmlForTemplate(schemeKey)}')">`;
                
                // 预览图或渐变色背景
                if (previewUrl) {
                    fieldHtml += `<div class="color-scheme-preview">`;
                    fieldHtml += `<img src="${previewUrl}" alt="${escapeHtmlForTemplate(scheme.display_name)}" 
                            onerror="this.style.display='none'">`;
                    fieldHtml += `</div>`;
                } else if (scheme.gradient_colors && scheme.gradient_colors.length >= 2) {
                    // 使用渐变色作为背景
                    const gradientColors = scheme.gradient_colors;
                    const gradientStr = gradientColors.join(', ');
                    fieldHtml += `<div class="color-scheme-preview gradient-preview" 
                            style="background: linear-gradient(135deg, ${gradientStr});">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                } else {
                    // 无预览图也无渐变色时显示默认占位符
                    fieldHtml += `<div class="color-scheme-preview no-image">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                }
                
                // 选中标记
                fieldHtml += `<div class="color-scheme-check ${isSelected ? 'active' : ''}">`;
                fieldHtml += `<i class="mdi mdi-check-circle"></i>`;
                fieldHtml += `</div>`;
                
                // 名称和描述
                fieldHtml += `<div class="color-scheme-info">`;
                fieldHtml += `<div class="color-scheme-name">${escapeHtmlForTemplate(scheme.display_name)}</div>`;
                if (scheme.description) {
                    fieldHtml += `<div class="color-scheme-desc">${escapeHtmlForTemplate(scheme.description)}</div>`;
                }
                fieldHtml += `</div>`;
                
                fieldHtml += `</div>`;
            }
            
            fieldHtml += `</div>`;
            fieldHtml += `</div>`;
        } else if (config.type === 'color') {
            fieldHtml += `<input type="text" id="${fieldId}" class="form-control auto-save-field visual-color-input" 
                    data-coloris
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(String(rawValue || ''))}"
                    placeholder="#000000 / rgba(...) / transparent">`;
        } else if (config.type === 'textarea') {
            // 处理 textarea 的值：将字面量 \n 和 \r\n 转换为实际换行符
            // 注意：textarea 内容中的换行符不需要 HTML 转义，但需要转义其他 HTML 特殊字符
            let textareaValue = String(rawValue || '');
            // 将字符串字面量 \n 转换为实际换行符（处理从 JSON 传递过来的转义字符）
            textareaValue = textareaValue
                .replace(/\\r\\n/g, '\n')  // 先处理 \r\n
                .replace(/\\n/g, '\n')     // 再处理 \n
                .replace(/\\r/g, '\n');    // 最后处理单独的 \r
            
            // 转义 HTML 特殊字符，但保留换行符（textarea 中换行符是有效的）
            // 将换行符临时替换，转义后再恢复
            const escaped = textareaValue
                .replace(/\n/g, '__NEWLINE__')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;')
                .replace(/__NEWLINE__/g, '\n');
            
            fieldHtml += `<textarea id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" rows="3">${escaped}</textarea>`;
        } else if (config.type === 'select' && config.options) {
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}">`;
            for (const optValue in config.options) {
                fieldHtml += `<option value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'selected' : ''}>${escapeHtmlForTemplate(config.options[optValue])}</option>`;
            }
            fieldHtml += `</select>`;
        } else if (config.type === 'multiselect' && config.options) {
            // 多选下拉
            const selectedValues = Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : []);
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field" multiple style="min-height: 120px;"
                    data-config-key="${escapeHtmlForTemplate(configKey)}">`;
            for (const optValue in config.options) {
                const isSelected = selectedValues.includes(String(optValue));
                fieldHtml += `<option value="${escapeHtmlForTemplate(optValue)}" ${isSelected ? 'selected' : ''}>${escapeHtmlForTemplate(config.options[optValue])}</option>`;
            }
            fieldHtml += `</select>`;
            fieldHtml += `<small class="form-text text-muted"><?= __('按住 Ctrl/Cmd 可多选') ?></small>`;
        } else if (config.type === 'radio' && config.options) {
            // Radio 类型
            for (const optValue in config.options) {
                const optLabel = config.options[optValue];
                fieldHtml += `<div class="form-check">`;
                fieldHtml += `<input type="radio" id="${fieldId}_${optValue}" class="form-check-input auto-save-field" 
                        name="${fieldId}" data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'checked' : ''}>`;
                fieldHtml += `<label class="form-check-label" for="${fieldId}_${optValue}">${escapeHtmlForTemplate(optLabel)}</label>`;
                fieldHtml += `</div>`;
            }
        } else if (config.type === 'checkbox_group' && config.options) {
            // 复选框组
            const selectedValues = Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : []);
            fieldHtml += `<div class="checkbox-group" id="${fieldId}_group">`;
            for (const optValue in config.options) {
                const isChecked = selectedValues.includes(String(optValue));
                fieldHtml += `<div class="form-check">`;
                fieldHtml += `<input type="checkbox" id="${fieldId}_${optValue}" class="form-check-input auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" data-checkbox-group="${fieldId}" value="${escapeHtmlForTemplate(optValue)}" ${isChecked ? 'checked' : ''}>`;
                fieldHtml += `<label class="form-check-label" for="${fieldId}_${optValue}">${escapeHtmlForTemplate(config.options[optValue])}</label>`;
                fieldHtml += `</div>`;
            }
            fieldHtml += `</div>`;
        } else if (config.type === 'number') {
            // 数字输入（支持 min/max/step）
            const minAttr = config.min !== undefined ? `min="${config.min}"` : '';
            const maxAttr = config.max !== undefined ? `max="${config.max}"` : '';
            const stepAttr = config.step !== undefined ? `step="${config.step}"` : '';
            fieldHtml += `<input type="number" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || '')}" ${minAttr} ${maxAttr} ${stepAttr}>`;
        } else if (config.type === 'url') {
            // URL 输入
            fieldHtml += `<input type="url" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || 'https://')}">`;
        } else if (config.type === 'image' || config.type === 'image_picker') {
            // 图片选择器
            fieldHtml += `<div class="input-group">
                <input type="text" id="${fieldId}" class="form-control auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                        placeholder="<?= __('图片URL') ?>">
                <button type="button" class="btn btn-outline-secondary btn-select-image" data-target="${fieldId}">
