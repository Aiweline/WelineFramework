            fieldHtml += `<div class="input-group">
                <input type="text" id="${fieldId}" class="form-control auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                        placeholder="<?= __('文件路径') ?>">
                <button type="button" class="btn btn-outline-secondary btn-select-file" data-target="${fieldId}" data-accept="${escapeHtmlForTemplate(config.accept || '*')}">
                    <i class="mdi mdi-folder-open"></i> <?= __('浏览') ?>
