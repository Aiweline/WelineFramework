/**
 * 组件拖拽面板 - 可视化构建器的组件选择器
 * 
 * 支持：
 * 1. 按区域（header/content/footer）分组显示
 * 2. 本模板组件标星推荐
 * 3. 组件拖拽到对应区域
 * 4. header/footer 区域唯一，content 区域可多个
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var string $styleCode 当前模板代码
 */

$page = $this->getData('page');
$pageId = $page && $page->getId() ? $page->getId() : 0;
$styleCode = $this->getData('style_code') ?: ($page ? $page->getData('style') : 'default');
$layoutCode = $this->getData('layout_code') ?: 'default';

// 获取组件数据的URL
$componentsApiUrl = $this->getBackendUrl('pagebuilder/backend/visual/api/component/list', [
    'style_code' => $styleCode,
    'layout_code' => $layoutCode,
    'group_by_region' => 'true',
]);
