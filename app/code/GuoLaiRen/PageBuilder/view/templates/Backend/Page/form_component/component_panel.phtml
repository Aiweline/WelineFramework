// 构建可导出的 JSON 对象
function buildExportableJson() {
    if (!window.currentGeneratedComponent) {
        return { error: '<?= __('无组件数据') ?>' };
    }
    
    const comp = window.currentGeneratedComponent;
    return {
        version: '1.0',
        exported_at: new Date().toISOString(),
        component: {
            code: comp.component?.code || '',
            name: comp.component?.name || '',
            name_en: comp.component?.name_en || '',
            description: comp.component?.description || '',
            region: comp.component?.region || comp.component?.category || 'content',
            category: comp.component?.category || comp.component?.region || 'content',
            style_code: comp.component?.style_code || '',
            phtml_code: comp.templateContent || comp.component?.phtml_code || '',
            config_schema: comp.component?.config_schema || {},
            ai_data: comp.component?.ai_data || {}
        },
        validation: comp.validation || { valid: true },
        final_prompt: comp.finalPrompt || ''
    };
}

// 复制 JSON 内容
function copyJsonContent() {
    const textarea = document.getElementById('json-edit-content');
    if (!textarea) return;
    
    navigator.clipboard.writeText(textarea.value).then(() => {
        // 显示成功提示
        const btn = event.target.closest('button');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-check"></i>';
        btn.classList.remove('btn-light');
        btn.classList.add('btn-success');
        setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-success');
            btn.classList.add('btn-light');
        }, 1500);
    }).catch(err => {
        console.error('复制失败:', err);
        textarea.select();
    });
}

// 应用 JSON 更改并预览
async function applyJsonChanges() {
    const textarea = document.getElementById('json-edit-content');
    if (!textarea) return;
    
    const jsonContent = textarea.value.trim();
    if (!jsonContent) {
        BackendToast.warning('<?= __('JSON 内容为空') ?>');
        return;
    }
    
    let jsonData;
    try {
        jsonData = JSON.parse(jsonContent);
    } catch (e) {
        BackendToast.error('<?= __('JSON 格式错误') ?>：' + e.message);
        return;
    }
    
    // 导入并预览
    importAndPreviewJson(jsonData);
}

