    }).then((result) => {
        if (result.isConfirmed && result.value) {
            generateComponentWithAi(result.value);
        }
    });
}

// 使用AI生成组件
async function generateComponentWithAi(params) {
    // 显示生成中状态
    Swal.fire({
        title: '<?= __('AI 正在生成组件...') ?>',
        html: `
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <p class="mb-1"><?= __('正在分析需求并生成代码...') ?></p>
                <p class="text-muted small"><?= __('这可能需要 10-30 秒') ?></p>
            </div>
        `,
        allowOutsideClick: false,
        showConfirmButton: false,
        customClass: { container: 'swal2-dark-theme' }
    });
    
    try {
        const response = await fetch('<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/component') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                style_code: currentStyleCode,
                region: params.region,
                name: params.name,
                description: params.description,
                style: params.style,
                fields: params.fields
            })
        });
        
        const result = await response.json();
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('生成失败') ?>');
        }
        
        // 显示生成结果
        showGeneratedComponent(result);
        
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: '<?= __('生成失败') ?>',
            text: error.message || '<?= __('未知错误') ?>',
            customClass: { container: 'swal2-dark-theme' }
        });
    }
}

// 显示生成的组件结果
function showGeneratedComponent(result) {
    const component = result.component || {};
    const validation = result.validation || {};
    const preview = result.preview || '';
    
    let validationHtml = '';
    if (validation.valid) {
        validationHtml = '<div class="alert alert-success mb-3"><i class="mdi mdi-check-circle"></i> <?= __('组件验证通过') ?></div>';
    } else {
        const errors = (validation.errors || []).map(e => `<li>${e}</li>`).join('');
        validationHtml = `<div class="alert alert-danger mb-3"><i class="mdi mdi-alert-circle"></i> <?= __('验证失败') ?>:<ul class="mb-0 mt-2">${errors}</ul></div>`;
    }
    
    Swal.fire({
        title: '<i class="mdi mdi-check-circle text-success"></i> <?= __('组件生成完成') ?>',
        html: `
            <div style="text-align: left; max-height: 60vh; overflow-y: auto;">
                ${validationHtml}
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><strong>${component.name || '<?= __('新组件') ?>'}</strong></span>
                        <span class="badge bg-primary">${component.region || 'content'}</span>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-2">${component.description || ''}</p>
                        <p class="mb-1"><strong><?= __('组件代码') ?>:</strong> <code>${component.code || ''}</code></p>
                        <p class="mb-1"><strong><?= __('文件路径') ?>:</strong> <code>${component.file || ''}</code></p>
                    </div>
                </div>
                ${preview ? `
                <div class="card">
                    <div class="card-header"><?= __('预览') ?></div>
                    <div class="card-body p-0">
                        <iframe srcdoc="${preview.replace(/"/g, '&quot;')}" style="width: 100%; height: 200px; border: none;"></iframe>
                    </div>
                </div>
                ` : ''}
            </div>
        `,
        width: '700px',
        showCancelButton: true,
        confirmButtonText: validation.valid ? '<i class="mdi mdi-content-save"></i> <?= __('保存组件') ?>' : '<?= __('修复问题') ?>',
        cancelButtonText: '<?= __('取消') ?>',
        confirmButtonColor: validation.valid ? '#28a745' : '#ffc107',
        customClass: { container: 'swal2-dark-theme' }
    }).then((confirmResult) => {
        if (confirmResult.isConfirmed) {
            if (validation.valid) {
                saveGeneratedComponent(component);
            } else {
                // 重新打开生成弹窗
                openAiGenerateComponent();
            }
        }
    });
}

// 保存生成的组件
async function saveGeneratedComponent(component) {
    Swal.fire({
        title: '<?= __('保存中...') ?>',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); },
        customClass: { container: 'swal2-dark-theme' }
    });
    
    try {
        const response = await fetch('<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/saveComponent') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                style_code: currentStyleCode,
                component: component
            })
        });
        
        const result = await response.json();
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('保存失败') ?>');
        }
        
        Swal.fire({
            icon: 'success',
            title: '<?= __('保存成功') ?>',
            text: '<?= __('组件已保存，正在刷新组件库...') ?>',
            timer: 1500,
            showConfirmButton: false,
            customClass: { container: 'swal2-dark-theme' }
        }).then(() => {
            // 刷新组件面板
            initComponentPanel();
        });
        
    } catch (error) {
        Swal.fire({
            icon: 'error',
            title: '<?= __('保存失败') ?>',
            text: error.message || '<?= __('未知错误') ?>',
            customClass: { container: 'swal2-dark-theme' }
        });
    }
}

