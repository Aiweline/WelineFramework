// 加载 AI 服务信息并渲染到信息条
async function _loadAiServiceInfo() {
    const bar = document.getElementById('ai-ws-info-bar');
    if (!bar) return;
    try {
        var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'include', silent: true };
        var resp = await window.Weline.Api.request('<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/ai_info') ?>', opts);
        if (!resp || (resp.ok === false)) throw new Error('<?= __('AI 服务不可用') ?>');
        var json;
        if (resp.data && typeof resp.data === 'object' && 'success' in resp.data) {
            json = resp.data;
        } else {
            var responseText = (resp && resp.data) !== undefined ? (typeof resp.data === 'string' ? resp.data : JSON.stringify(resp.data)) : '';
            try { json = responseText ? (JSON.parse(responseText) || safeJsonParse(responseText)) : null; } catch (e) { throw new Error('<?= __('AI 信息返回格式不正确') ?>'); }
            if (!json) throw new Error('<?= __('AI 信息返回格式不正确') ?>');
        }
        if (!json.success) {
            bar.classList.remove('ai-info-loading');
            bar.classList.add('ai-info-error');
            bar.innerHTML = '<span class="ai-info-status err"></span>'
                + '<span style="color:#f87171;font-size:11px;">' + (json.message || '<?= __('AI 服务不可用') ?>') + '</span>';
            return;
        }
        const d = json.data;
        // 连接状态图标
        const statusMap = { 'success': 'ok', 'connected': 'ok', 'passed': 'ok', 'ok': 'ok', 'failed': 'err', 'error': 'err', 'unknown': 'warn' };
        const statusCls = statusMap[d.connection_status] || 'warn';
        const statusLabel = { 'ok': '<?= __('已连接') ?>', 'warn': '<?= __('未知') ?>', 'err': '<?= __('连接失败') ?>' };
        // 供应商图标映射
        const vendorIcons = {
            'openai': 'mdi-creation', 'anthropic': 'mdi-robot-outline', 'deepseek': 'mdi-magnify-scan',
            'google': 'mdi-google', 'baidu': 'mdi-cloud', 'alibaba': 'mdi-cloud-outline'
        };
        const vIcon = vendorIcons[d.vendor] || 'mdi-chip';
        bar.classList.remove('ai-info-loading');
        bar.innerHTML = ''
            + '<span class="ai-info-status ' + statusCls + '" title="' + (statusLabel[statusCls] || '') + '"></span>'
            + '<span class="ai-info-tag"><i class="mdi ' + vIcon + '"></i> <?= __('供应商') ?>: <span class="ai-info-val">' + _escHtml(d.vendor_label) + '</span></span>'
            + '<span class="ai-info-tag"><i class="mdi mdi-brain"></i> <?= __('模型') ?>: <span class="ai-info-val">' + _escHtml(d.actual_model || d.model_code) + '</span></span>'
            + '<span class="ai-info-tag"><i class="mdi mdi-cog-outline"></i> <?= __('适配器') ?>: <span class="ai-info-val">' + _escHtml(d.provider) + '</span></span>'
            + (d.max_tokens > 0 ? '<span class="ai-info-tag"><i class="mdi mdi-counter"></i> Max: <span class="ai-info-val">' + d.max_tokens.toLocaleString() + '</span></span>' : '')
            + (d.model_source === 'local' ? '<span class="ai-info-tag" style="background:rgba(16,185,129,.12);color:#6ee7b7;"><i class="mdi mdi-server"></i> <?= __('本地') ?></span>' : '');
    } catch (e) {
        bar.classList.remove('ai-info-loading');
        bar.classList.add('ai-info-error');
        bar.innerHTML = '<span class="ai-info-status err"></span>'
            + '<span style="color:#f87171;font-size:11px;"><?= __('获取 AI 信息失败') ?>: ' + _escHtml(e.message || String(e)) + '</span>';
    }
}
function _escHtml(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

// 步骤切换
function _workshopGoToStep(step) {
    _aiWorkshop.step = step;
    document.querySelectorAll('.ai-ws-step').forEach(el => {
        const s = parseInt(el.dataset.step);
        el.classList.toggle('active', s === step);
        el.classList.toggle('done', s < step);
    });
    document.querySelectorAll('.ai-ws-panel').forEach((el, i) => {
        el.classList.toggle('active', i + 1 === step);
    });
    // 切换到微调步骤时自动同步预览
    if (step === 4) {
        _syncRefinePreview();
    }
    // 切换到预览步骤时同步「代码」与「草稿内容」（含微调后的最新 phtml），保证未保存前反复预览/微调都看到最新
    if (step === 3 && _aiWorkshop.result) {
        const code = _aiWorkshop.result.component?.phtml_code || '';
        const codeEl = document.getElementById('ai-ws-code-content');
        const templateFileEl = document.getElementById('ai-ws-template-file-content');
        if (codeEl) codeEl.textContent = code;
        if (templateFileEl) templateFileEl.textContent = code;
    }
}

function _workshopNotify(level, message) {
    const toast = window.BackendToast || window.BackendToast || null;
    if (toast && typeof toast[level] === 'function') {
        toast[level](message);
        return;
    }
    if (level === 'error') {
        console.error(message);
    } else {
        console.warn(message);
    }
}

function _workshopAskConfirm(message, onConfirmed) {
    const confirmer = window.BackendConfirm || window.AdminConfirm || null;
    if (confirmer && typeof confirmer.show === 'function') {
        confirmer.show(message, {
            title: '<?= __('确认操作') ?>',
            confirmText: '<?= __('确定') ?>',
            cancelText: '<?= __('取消') ?>',
            type: 'warning'
        }).then(function(confirmed) {
            if (confirmed && typeof onConfirmed === 'function') onConfirmed();
        });
        return;
    }
    _workshopNotify('warning', message);
}

function _workshopSetStartButtonLoading(isLoading) {
    const btn = document.getElementById('ai-ws-start-generate');
    if (!btn) return;
    if (isLoading) {
        btn.disabled = true;
        btn.dataset.originalHtml = btn.dataset.originalHtml || btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('生成中...') ?>';
    } else {
        btn.disabled = false;
        if (btn.dataset.originalHtml) {
            btn.innerHTML = btn.dataset.originalHtml;
        }
    }
}

function _workshopClearFieldValidation() {
    const step1 = document.getElementById('ai-ws-step1');
    if (!step1) return;
    step1.querySelectorAll('.is-invalid').forEach(function(el) {
        el.classList.remove('is-invalid');
    });
}

function _workshopMarkFieldInvalid(field) {
    if (!field) return;
    field.classList.add('is-invalid');
}

function _workshopCollectStep1Params() {
    const step1 = document.getElementById('ai-ws-step1');
    const getField = function(selector) {
        if (step1) return step1.querySelector(selector);
        return document.querySelector(selector);
    };

    const nameEl = getField('#aiComponentName');
    const descEl = getField('#aiComponentDesc');
    const regionEl = getField('#aiComponentRegion');
    const styleEl = getField('#aiComponentStyle');
    const refEl = getField('#aiReferenceComponent');
    const fieldsEl = getField('#aiComponentFields');

    if (!nameEl || !descEl || !regionEl || !styleEl || !refEl || !fieldsEl) {
        return {
            ok: false,
            message: '<?= __('组件工坊界面未初始化完成，请关闭后重试') ?>',
            firstInvalid: null
        };
    }

    _workshopClearFieldValidation();

    const name = (nameEl.value || '').trim();
    const description = (descEl.value || '').trim();
    let firstInvalid = null;

    if (!name) {
        _workshopMarkFieldInvalid(nameEl);
        firstInvalid = firstInvalid || nameEl;
    }
    if (!description) {
        _workshopMarkFieldInvalid(descEl);
        firstInvalid = firstInvalid || descEl;
    }

    if (firstInvalid) {
        return {
            ok: false,
            message: '<?= __('请先完善必填项：组件名称与功能描述') ?>',
            firstInvalid: firstInvalid
        };
    }

    return {
        ok: true,
        params: {
            region: regionEl.value || 'content',
            referenceComponent: refEl.value || '',
            name: name,
            description: description,
            style: styleEl.value || 'modern',
            fields: fieldsEl.value || ''
        }
    };
}

// 用户点击步骤指示器
function _wsStepClick(step) {
    const continueSwitch = function() {
        // 预览和微调步骤需要有数据才能看
        if ((step === 3 || step === 4) && !_aiWorkshop.result) {
            _workshopNotify('warning', '<?= __('请先生成组件') ?>');
            return;
        }
        // 切换到微调时同步预览
        if (step === 4 && _aiWorkshop.result) {
            _syncRefinePreview();
        }
        _workshopGoToStep(step);
    };

    // 正在生成中时，点击其他步骤会中断生成
    if (_aiWorkshop.eventSource && step !== 2) {
        _workshopAskConfirm('<?= __('正在生成中，切换步骤将中断生成，确定吗？') ?>', function() {
            _workshopAbort();
            continueSwitch();
        });
        return;
    }
    continueSwitch();
}

