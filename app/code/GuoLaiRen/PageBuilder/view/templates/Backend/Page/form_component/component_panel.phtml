/**
 * 追加 AI 思考/回复内容到日志
 * @param {string} content  内容文本
 * @param {number} iteration 迭代轮次
 * @param {string} type 'thinking' | 'response'
 * @param {boolean} streaming 是否为流式追加
 */
function _appendAiContent(content, iteration, type, streaming) {
    const container = document.getElementById('ai-gen-output');
    if (!container) return;

    const blockId = 'ai-log-' + type + '-' + (iteration || 0);
    const color = type === 'thinking' ? '#a78bfa' : '#67e8f9';

    // 流式模式：追加到同一迭代 + 同类型的 span
    if (streaming) {
        const existing = document.getElementById(blockId);
        if (existing) {
            existing.textContent += content;
            _scrollLogToBottom();
            return;
        }
    }

    // 创建新块：标签头 + 内容 span
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'margin:2px 0;';

    const label = type === 'thinking' ? '💭 <?= __('思考') ?>' : '🤖 <?= __('AI') ?>';
    const tag = document.createElement('span');
    tag.style.cssText = 'color:' + color + ';font-weight:600;font-size:10px;letter-spacing:.3px;';
    tag.textContent = label + (iteration ? ' #' + iteration : '') + '\n';
    wrapper.appendChild(tag);

    const span = document.createElement('span');
    span.id = blockId;
    span.style.cssText = 'color:#d4d4d4;white-space:pre-wrap;';
    span.textContent = content;
    wrapper.appendChild(span);

    container.appendChild(wrapper);
    _scrollLogToBottom();
}

