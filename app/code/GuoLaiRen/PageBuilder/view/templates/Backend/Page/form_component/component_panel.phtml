                </div>
            </div>
        `;
    }
    
    // 构建默认的微调提示词（如果有错误，自动包含完整的错误修复提示词）
    let defaultRefinePrompt = '';
    let lastError = '';
    if (previewFailed) {
        lastError = previewError || '预览渲染失败（未返回错误信息）';
        // 构建完整的错误修复提示词
        defaultRefinePrompt = '【错误信息】' + lastError + '\n\n' +
            '【修复要求】请修复上述PHP渲染错误。常见问题包括：\n' +
            '- PHP语法错误（括号、引号、分号不匹配）\n' +
            '- js_content中混入了PHP代码（禁止在JS中使用PHP标签）\n' +
            '- 双美元符号变量（应改为单美元符号）\n' +
            '- 未定义的变量\n' +
            '- 不平衡的控制结构（if/endif等）\n\n' +
            '请仔细检查并修复代码，确保能正常渲染。';
    } else if (!validation.valid && validation.errors && validation.errors.length > 0) {
        lastError = validation.errors.join('; ');
        defaultRefinePrompt = '【验证错误】' + lastError + '\n\n' +
            '【修复要求】请修复上述验证问题，确保组件代码符合规范。';
    }
    
    // 保存错误信息到全局变量，供微调时使用
    window.currentGeneratedComponent.lastError = lastError;
    
    // 计算输入框行数
    const textareaRows = (previewFailed || !validation.valid) ? 6 : 2;
    const hasError = previewFailed || !validation.valid;
    const errorHint = hasError ? '<small class="text-warning"><i class="mdi mdi-lightbulb"></i> 已自动填入错误修复提示词，点击微调让AI修复</small>' : '';
    
    // 构建可复制的提示词和代码区域HTML
    const copyableSectionHtml = buildCopyableSectionsHtml(templateContent, window.currentGeneratedComponent.finalPrompt);
    
    // 构建内联微调面板HTML
    const refinePanelHtml = `
        <div class="card border-primary">
            <div class="card-header bg-primary text-white py-2">
                <i class="mdi mdi-tune"></i> 微调组件
                <small class="ms-2 opacity-75">调整后实时更新预览</small>
            </div>
            <div class="card-body py-2">
                ${historyHtml}
                <div class="mb-2">
                    <textarea id="inlineRefinePrompt" class="form-control" rows="${textareaRows}" placeholder="描述需要调整的内容，如：修改背景颜色、调整字体大小、添加按钮等">${defaultRefinePrompt}</textarea>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>${errorHint}</div>
                    <button type="button" class="btn btn-primary" onclick="executeInlineRefine()" id="inlineRefineBtn">
                        <i class="mdi mdi-auto-fix"></i> 微调修复
                    </button>
                </div>
            </div>
        </div>
    `;
    
    Swal.fire({
        title: `<span class="d-flex align-items-center justify-content-center gap-2">
            ${previewFailed ? '<i class="mdi mdi-alert-circle text-warning"></i>' : '<i class="mdi mdi-check-circle text-success"></i>'}
            <span>${finalComponent.name || component.name || '<?= __('AI组件') ?>'}</span>
            <span class="badge bg-secondary fs-6">${finalComponent.region || finalComponent.category || 'content'}</span>
        </span>`,
        html: `
            <div style="text-align: left; max-height: 70vh; overflow-y: auto;">
                ${validationHtml}
                ${previewSectionHtml}
                ${copyableSectionHtml}
                ${refinePanelHtml}
            </div>
        `,
        width: '900px',
        showCancelButton: true,
        showDenyButton: false,
        confirmButtonText: '<i class="mdi mdi-content-save"></i> <?= __('确认保存') ?>',
        cancelButtonText: '<i class="mdi mdi-close"></i> <?= __('取消') ?>',
        confirmButtonColor: '#28a745',
        customClass: { 
            container: 'swal2-dark-theme',
            popup: 'swal2-component-preview-popup'
        },
        didOpen: () => {
            // 如果有错误，自动聚焦到微调输入框
            if (previewFailed || !validation.valid) {
                setTimeout(() => {
                    const textarea = document.getElementById('inlineRefinePrompt');
                    if (textarea) {
                        textarea.focus();
                        textarea.setSelectionRange(textarea.value.length, textarea.value.length);
                    }
                }, 300);
            }
        }
    }).then((confirmResult) => {
        if (confirmResult.isConfirmed) {
            // 保存组件
            saveGeneratedComponent(window.currentGeneratedComponent.component || component);
        }
    });
}

// 填充内联微调提示词
function fillInlineRefinePrompt(prompt) {
    const textarea = document.getElementById('inlineRefinePrompt');
    if (textarea) {
        textarea.value = prompt;
        textarea.focus();
    }
}

// 执行内联微调
async function executeInlineRefine() {
    const textarea = document.getElementById('inlineRefinePrompt');
    const btn = document.getElementById('inlineRefineBtn');
    const prompt = textarea?.value?.trim();
    
    if (!prompt) {
        textarea?.focus();
        return;
    }
    
    if (!window.currentGeneratedComponent) {
        Swal.showValidationMessage('<?= __('找不到组件数据') ?>');
        return;
    }
    
    const currentComponent = window.currentGeneratedComponent;
    const refineToken = _aiWorkshop.result?.refine_token || '';
    const templateContent = currentComponent.templateContent || currentComponent.component?.phtml_code || '';
    
    if (!refineToken && !templateContent) {
        Swal.showValidationMessage('<?= __('找不到组件代码') ?>');
        return;
    }
    
    // 禁用按钮，显示加载状态
    const originalBtnHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> <?= __('微调中...') ?>';
    textarea.disabled = true;
    
    // 获取错误信息（如果有）
    const lastError = currentComponent.lastError || '';
    
    // 构建完整的调整提示词（包含错误信息）
    let fullPrompt = prompt;
    if (lastError && !prompt.includes(lastError)) {
        // 如果提示词中没有包含错误信息，自动添加
        fullPrompt = `【渲染错误】${lastError}\n\n【用户要求】${prompt}`;
    }
    
    const refineBody = {
        adjustment_prompt: fullPrompt,
        category: currentComponent.component?.region || currentComponent.component?.category || 'content',
        code: currentComponent.component?.code || '',
        last_error: lastError
    };
    if (refineToken) refineBody.refine_token = refineToken; else refineBody.template_content = templateContent;
    const draftIdForRefine = (typeof _aiWorkshop !== 'undefined' && _aiWorkshop?.result?.draft_id) ? _aiWorkshop.result.draft_id : 0;
    if (draftIdForRefine) refineBody.draft_id = draftIdForRefine;
    
    try {
        var refineUrl = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/refine') ?>';
        var refineOpts = { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(refineBody) };
        var response = await window.Weline.Api.request(refineUrl, refineOpts);
        if (!response || response.ok === false) {
            throw new Error('<?= __('服务器错误') ?>');
        }
        const responseText = (response && response.data) !== undefined ? (typeof response.data === 'object' ? response.data : String(response.data)) : '';
        const responseStr = typeof responseText === 'string' ? responseText : JSON.stringify(responseText);
        let result;
        try {
            result = safeJsonParse(responseText);
        } catch (parseError) {
            console.error('<?= __('响应解析失败') ?>:', responseStr.substring(0, 500));
            throw new Error('<?= __('服务器返回了无效的响应') ?>');
        }
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('微调失败') ?>');
        }
        
        // 保存微调历史
        saveRefineHistory(prompt);
        
        // 更新当前组件数据；微调后 token 已消费
        if (result.result) {
            const refinedComponent = {
                ...window.currentGeneratedComponent.component,
                ...result.result,
                phtml_code: result.result.template_content || templateContent
            };
            
            window.currentGeneratedComponent.component = refinedComponent;
            window.currentGeneratedComponent.templateContent = result.result.template_content || templateContent;
            window.currentGeneratedComponent.preview = result.preview?.html || '';
            window.currentGeneratedComponent.validation = result.validation || { valid: true };
            if (_aiWorkshop.result) _aiWorkshop.result.refine_token = '';
        }
        
        // 关闭当前弹窗并重新显示（更新后的预览）
        Swal.close();
        
        // 重新显示生成结果（保留原始的最终提示词）
        showGeneratedComponent({
            component: window.currentGeneratedComponent.component,
            validation: window.currentGeneratedComponent.validation || { valid: true },
            preview: result.preview || window.currentGeneratedComponent.preview,
            result: result.result,
            final_prompt: window.currentGeneratedComponent.finalPrompt || ''
        });
        
    } catch (error) {
        console.error('<?= __('微调失败') ?>:', error);
        
        // 恢复按钮状态
        btn.disabled = false;
        btn.innerHTML = originalBtnHtml;
        textarea.disabled = false;
        
        // 保存错误信息到全局变量，下次微调时自动包含
        window.currentGeneratedComponent.lastError = error.message;
        
        // 显示错误信息并保留在当前页面
        const errorAlert = document.createElement('div');
        errorAlert.className = 'alert alert-danger py-2 mt-2 small';
        errorAlert.innerHTML = `<i class="mdi mdi-alert-circle"></i> ${error.message}`;
        
        const cardBody = textarea.closest('.card-body');
        const existingAlert = cardBody.querySelector('.alert-danger');
        if (existingAlert) {
            existingAlert.remove();
        }
        cardBody.appendChild(errorAlert);
        
        // 更新提示词，包含完整的错误修复提示词
        textarea.value = '【微调错误】' + error.message + '\n\n' +
            '【修复要求】请根据错误信息修复代码问题。如果是服务器错误，可能是生成的代码有语法问题，请检查：\n' +
            '- PHP语法是否正确\n' +
            '- js_content是否为纯JavaScript（不含PHP标签）\n' +
            '- 变量是否正确定义\n' +
            '- 括号和引号是否匹配';
        textarea.focus();
    }
}

// 保存生成的组件
async function saveGeneratedComponent(component) {
    // 标记 AI 生成标识
    component.ai_generated = true;
    component.ai_generated_at = new Date().toISOString();
    
    // 确保 CSS 类名有唯一前缀（避免跨模块冲突）
    const uniquePrefix = 'ai-' + (component.code || '').replace(/[^a-zA-Z0-9-]/g, '-');
    component.css_prefix = uniquePrefix;
    
    BackendToast.info('<?= __('保存中...') ?>', 3000);
    
    try {
        var url = '<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/save-component') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ style_code: currentStyleCode, component: component }) };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('保存失败') ?>');
        }
        
        // 清除localStorage中的临时组件数据
        clearGeneratedComponentFromLocal();
        
        BackendToast.success('<?= __('AI 组件已保存到组件库') ?>');
        initComponentPanel();
        
    } catch (error) {
        BackendToast.error('<?= __('保存失败') ?>：' + (error.message || '<?= __('未知错误') ?>'));
    }
}

// 显示生成的代码（用于调试）
function showGeneratedCode() {
    if (!window.currentGeneratedComponent) {
        BackendToast.warning('<?= __('无代码可显示：请先生成组件') ?>');
        return;
    }
    
    const code = window.currentGeneratedComponent.templateContent || 
                 window.currentGeneratedComponent.component?.phtml_code || 
                 '';
    
    if (!code) {
        BackendToast.warning('<?= __('代码为空：未找到组件代码') ?>');
        return;
    }
    
    // 转义HTML用于显示
    const escapedCode = code
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    
    Swal.fire({
        title: '<i class="mdi mdi-code-tags"></i> <?= __('组件源代码') ?>',
        html: `
            <div style="text-align: left;">
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <span class="text-muted small"><?= __('代码长度') ?>: ${code.length} <?= __('字符') ?></span>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyGeneratedCode()">
                        <i class="mdi mdi-content-copy"></i> <?= __('复制代码') ?>
                    </button>
                </div>
                <div style="background: #1e1e1e; border-radius: 8px; padding: 15px; max-height: 60vh; overflow: auto;">
                    <pre style="margin: 0; color: #d4d4d4; font-family: 'Consolas', 'Monaco', monospace; font-size: 12px; white-space: pre-wrap; word-break: break-all;"><code id="generated-code-content">${escapedCode}</code></pre>
                </div>
            </div>
        `,
        width: '900px',
        showCancelButton: true,
        showConfirmButton: true,
        confirmButtonText: '<i class="mdi mdi-arrow-left"></i> <?= __('返回') ?>',
        cancelButtonText: '<?= __('关闭') ?>',
        confirmButtonColor: '#667eea',
        customClass: { container: 'swal2-dark-theme' }
    }).then((result) => {
        if (result.isConfirmed) {
            // 返回显示组件
            if (window.currentGeneratedComponent) {
                showGeneratedComponent({
                    component: window.currentGeneratedComponent.component,
                    validation: window.currentGeneratedComponent.validation || { valid: true },
                    preview: window.currentGeneratedComponent.preview || '',
                    result: null
                });
            }
        }
    });
}

// 复制生成的代码到剪贴板
function copyGeneratedCode() {
    const code = window.currentGeneratedComponent?.templateContent || 
                 window.currentGeneratedComponent?.component?.phtml_code || 
                 '';
    
    if (!code) {
        BackendToast.warning('<?= __('没有代码可复制') ?>');
        return;
    }
    
    navigator.clipboard.writeText(code).then(() => {
        // 显示复制成功提示
        const btn = event.target.closest('button');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已复制') ?>';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-success');
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.remove('btn-success');
            btn.classList.add('btn-outline-primary');
        }, 2000);
    }).catch(err => {
        console.error('复制失败:', err);
        // 回退方案：选中代码
        const codeElement = document.getElementById('generated-code-content');
        if (codeElement) {
            const range = document.createRange();
            range.selectNodeContents(codeElement);
            const selection = window.getSelection();
            selection.removeAllRanges();
            selection.addRange(range);
        }
    });
}

