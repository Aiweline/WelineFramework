        // 先获取响应文本
        const responseText = await response.text();
        
        // 尝试解析JSON
        let result;
        try {
            result = safeJsonParse(responseText);
        } catch (parseError) {
            // JSON解析失败，可能是PHP错误输出
            console.error('<?= __('响应解析失败') ?>:', responseText.substring(0, 500));
            throw new Error('<?= __('服务器返回了无效的响应，可能是代码执行错误。请尝试重新微调。') ?>');
        }
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('微调失败') ?>');
        }
        
        // 保存微调历史
        saveRefineHistory(adjustmentPrompt);
        
        // 更新当前组件数据
        if (result.result) {
            const refinedComponent = {
                ...window.currentGeneratedComponent.component,
                ...result.result,
                phtml_code: result.result.template_content || templateContent
            };
            
            window.currentGeneratedComponent.component = refinedComponent;
            window.currentGeneratedComponent.templateContent = result.result.template_content || templateContent;
            window.currentGeneratedComponent.preview = result.preview?.html || '';
            
            // 重新显示生成结果（带微调后的内容）
            showGeneratedComponent({
                component: refinedComponent,
                validation: window.currentGeneratedComponent.validation || { valid: true },
                preview: result.preview?.html || window.currentGeneratedComponent.preview,
                result: result.result
            });
        } else {
            // 如果没有result，只更新预览
            if (result.preview?.html) {
                window.currentGeneratedComponent.preview = result.preview.html;
                showGeneratedComponent({
                    component: window.currentGeneratedComponent.component,
                    validation: window.currentGeneratedComponent.validation || { valid: true },
                    preview: result.preview.html,
                    result: result.result
                });
            }
        }
        
    } catch (error) {
        console.error('<?= __('微调失败') ?>:', error);
        
        // 微调失败，回到预览页面并显示错误
        // 更新预览信息以显示错误
        window.currentGeneratedComponent.preview = {
            success: false,
            error: error.message || '<?= __('微调失败') ?>',
            html: ''
        };
        
        // 重新显示带错误信息的预览页面，用户可以继续微调
        showGeneratedComponent({
            component: window.currentGeneratedComponent.component,
            validation: window.currentGeneratedComponent.validation || { valid: true },
            preview: window.currentGeneratedComponent.preview,
            result: null
        });
    }
}

// 页面加载时初始化
document.addEventListener('DOMContentLoaded', function() {
    initComponentPanel();
    
    // 延迟检查是否有未保存的AI组件（等待页面完全加载）
    setTimeout(() => {
        checkUnsavedAiComponent();
    }, 1500);
});
</script>
