// 使用AI流式生成组件（在工坊面板步骤2中运行）
async function generateComponentWithAi(params) {
    try {
        // 如果选择了参考组件，先获取其代码
        let referenceCode = '';
        if (params.referenceComponent) {
            updateStreamStatus('<?= __('获取参考组件...') ?>', 10);
            try {
                var refUrl = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/component/code') ?>?component_code=' + encodeURIComponent(params.referenceComponent) + '&style_code=' + encodeURIComponent(currentStyleCode);
                var refOpts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' }, silent: true };
                var refResponse = await window.Weline.Api.request(refUrl, refOpts);
                if (refResponse && (refResponse.ok !== false)) {
                    const refResult = (refResponse && refResponse.data) || refResponse;
                    if (refResult.success && refResult.code) {
                        referenceCode = refResult.code;
                    }
                }
            } catch (refError) {
                console.warn('获取参考组件代码失败:', refError);
            }
        }
        
        updateStreamStatus('<?= __('连接 AI 服务...') ?>', 15);
        
        // 优先从工坊步骤 1 面板内取表单值（避免多处同名 id 取到空）
        let name = params.name || '';
        let description = params.description || '';
        const step1 = document.getElementById('ai-ws-step1');
        const nameEl = step1 ? step1.querySelector('#aiComponentName') : document.getElementById('aiComponentName');
        const descEl = step1 ? step1.querySelector('#aiComponentDesc') : document.getElementById('aiComponentDesc');
        if (nameEl && (nameEl.value || '').trim()) name = nameEl.value.trim();
        if (descEl && (descEl.value || '').trim()) description = descEl.value.trim();
        if (!name || !description) {
            updateStreamStatus('<?= __('请输入组件名称和描述') ?>', 0);
            throw new Error('<?= __('组件名称和描述不能为空') ?>');
        }
        const streamParams = {
            style_code: currentStyleCode,
            region: params.region,
            name: name,
            description: description,
            style: params.style,
            fields: params.fields,
            reference_component: params.referenceComponent,
            reference_code: referenceCode,
            language: document.documentElement.lang || '<?= $this->request->getUserLanguage() ?>'
        };
        const paramsBase64 = btoa(unescape(encodeURIComponent(JSON.stringify(streamParams))));
        
        // 使用 EventSource 进行流式请求（GET）；name/description 单独传参兜底，避免 base64 解码或 URL 截断导致后端收不到
        const baseUrl = '<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/component-stream') ?>';
        const streamUrl = baseUrl + '?params=' + encodeURIComponent(paramsBase64)
            + '&name=' + encodeURIComponent(name)
            + '&description=' + encodeURIComponent(description);
        
        let result = null;
        let totalChars = 0;
        
        await new Promise((resolve, reject) => {
            const eventSource = new EventSource(streamUrl);
            _aiWorkshop.eventSource = eventSource;
            let lastErrorMessage = '';
            const guard = createStreamFinishGuard();
            function finish(isSuccess, error) {
                const r = guard.finish(isSuccess, error);
                if (r) {
                    try { eventSource.close(); } catch(e) {}
                    r.ok ? resolve() : reject(r.err);
                }
            }

            eventSource.onopen = function() { updateStreamStatus('<?= __('AI 正在生成...') ?>', 20); };
            
            eventSource.addEventListener('start', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    result = handleStreamEvent(data, result, totalChars);
                    _logLine('▶ ' + (data.message || '<?= __('开始生成组件...') ?>'), '#4ade80');
                }
            });
            
            eventSource.addEventListener('prompt', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    result = handleStreamEvent(data, result, totalChars);
                    if (data.prompt_content) {
                        const promptEl = document.getElementById('ai-gen-prompt-content');
                        if (promptEl) { promptEl.textContent = data.prompt_content; promptEl.style.opacity = '1'; }
                    }
                    if (data.prompt_length) {
                        const lenEl = document.getElementById('ai-gen-prompt-len');
                        if (lenEl) lenEl.textContent = '(' + data.prompt_length + ' <?= __('字符') ?>)';
                        _logLine('▶ <?= __('提示词已构建') ?> (' + data.prompt_length + ' <?= __('字符') ?>)', '#94a3b8');
                    }
                }
            });
            
            eventSource.addEventListener('generating', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    result = handleStreamEvent(data, result, totalChars);
                    _logLine('▶ <?= __('AI 正在生成代码...') ?>', '#94a3b8');
                }
            });

            // AI 思考/推理过程事件（普通模式，流式 reasoning_content 小块追加）
            eventSource.addEventListener('thinking', function(e) {
                const data = safeParseJson(e.data);
                if (data?.content) {
                    updateStreamStatus('<?= __('AI 思考中...') ?>', 25);
                    _appendAiContent(data.content, 0, 'thinking', true);
                }
            });
            
            eventSource.addEventListener('chunk', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    if (data.total_length) totalChars = data.total_length;
                    result = handleStreamEvent(data, result, totalChars);
                    // 只更新字符计数，不逐块刷日志
                    if (data.content) {
                        const charsEl = document.getElementById('ai-gen-chars');
                        if (charsEl) charsEl.textContent = (data.total_length || totalChars) + ' <?= __('字符') ?>';
                        updateStreamStatus('<?= __('正在接收代码...') ?> ' + (data.total_length || totalChars) + ' <?= __('字符') ?>', 60);
                    }
                }
            });
            
            eventSource.addEventListener('parsing', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    result = handleStreamEvent(data, result, totalChars);
                    _logLine('▶ <?= __('解析 AI 响应...') ?>', '#94a3b8');
                }
            });
            
            eventSource.addEventListener('stream_error', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    _logHtml('<span style="color:#ffa500">[WARN] ' + _escHtml(data.message) + '</span>');
                    updateStreamStatus('<?= __('生成出错') ?>', 50);
                }
            });

            // 质量关卡事件（语法检测 + 缺陷检测 + 自动修复）
            eventSource.addEventListener('quality_gate', function(e) {
                const data = safeParseJson(e.data);
                if (!data) return;
                const phase = data.phase || '';
                const msg = data.message || ('[quality_gate] ' + phase);
                const color = data.valid === false ? '#f87171' : '#94a3b8';
                _logLine('🛡 ' + msg, color);
                if (Array.isArray(data.errors) && data.errors.length) {
                    data.errors.slice(0, 3).forEach(err => _logLine('    ✖ ' + err, '#fca5a5'));
                }
                if (Array.isArray(data.auto_fixes) && data.auto_fixes.length) {
                    _logLine('    🔧 <?= __('自动修复') ?>: ' + data.auto_fixes.length, '#67e8f9');
                }
                if (msg) {
                    updateStreamStatus(msg, 70);
                }
            });
            
            eventSource.addEventListener('complete', function(e) {
                const data = safeParseJson(e.data);
                if (data) {
                    result = data;
                    try { fetch('http://127.0.0.1:7243/ingest/c0ecf822-3bcf-4f3d-a88a-8940482b2d3a', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ location: 'component_panel:nonAgent complete', message: 'received', data: { draft_id: data.draft_id ?? null, keys: Object.keys(data || {}) }, timestamp: Date.now(), hypothesisId: 'H1' }) }).catch(() => {}); } catch (err) {}
                    _logLine('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', '#667eea');
                    if (data.success) {
                        _logLine('✅ ' + (data.message || '<?= __('生成完成') ?>'), '#4ade80');
                    } else {
                        _logLine('[WARN] ' + (data.message || '<?= __('生成失败') ?>'), '#fbbf24');
                    }
                }
                finish(true);
            });
            
            eventSource.addEventListener('error', function(e) {
                const data = safeParseJson(e.data);
                if (data && data.message) {
                    lastErrorMessage = data.message;
                    updateStreamStatus('<?= __('错误') ?>: ' + data.message, 0);
                    _logHtml('<span style="color:#ff6b6b">[ERROR] ' + _escHtml(data.message) + '</span>');
                    finish(false, new Error(data.message));
                }
            });
            
            eventSource.addEventListener('done', function(e) { finish(true); });
            
            eventSource.onerror = function(e) {
                if (result && result.success) { finish(true); return; }
                if (lastErrorMessage) { finish(false, new Error(lastErrorMessage)); return; }
                _logLine('[FAILED] <?= __('连接中断或服务器错误') ?>', '#ff6b6b');
                finish(false, new Error('<?= __('连接中断或服务器错误') ?>'));
            };
        });
        
        // 生成完成 — 若有 draft_id 则请求预览 API 再展示，否则用 complete 内嵌 preview
        if (result && result.success) {
            updateStreamStatus('<?= __('生成完成！') ?>', 100);
            const spinnerEl = document.getElementById('ai-gen-spinner');
            if (spinnerEl) { spinnerEl.className = 'me-2'; spinnerEl.innerHTML = '<i class="mdi mdi-check-circle text-success"></i>'; }
            if (result.draft_id) {
                const previewHtml = await _fetchPreviewById({ draft_id: result.draft_id });
                if (previewHtml) result.preview = previewHtml;
            }
            // 立即同步写入 localStorage，不依赖 500ms 后的 _workshopShowResult
            if (result.component) {
                try {
                    saveGeneratedComponentToLocal({
                        component: result.component,
                        preview: result.preview?.html || result.preview || '',
                        validation: result.validation || {},
                        templateContent: result.component.phtml_code || '',
                        finalPrompt: result.final_prompt || ''
                    });
                } catch (e) { console.warn('同步保存组件到本地失败:', e); }
            }
            setTimeout(() => { _workshopShowResult(result); }, 500);
        } else if (result && result.message) {
            throw new Error(result.message);
        }
        
    } catch (error) {
        console.error('流式生成失败:', error);
        _workshopSetStartButtonLoading(false);
        let errorMessage = error.message || '<?= __('未知错误') ?>';
        let errorTip = '<?= __('您可以重新尝试生成组件。') ?>';
        
        if (errorMessage.includes('JSON') || errorMessage.includes('格式不正确')) {
            errorTip = '<?= __('AI 返回的内容解析失败，可能是网络不稳定导致数据截断。') ?>';
        } else if (errorMessage.includes('连接') || errorMessage.includes('中断')) {
            errorTip = '<?= __('网络连接不稳定，请检查网络后重试。') ?>';
        } else if (errorMessage.includes('超时') || errorMessage.includes('timeout')) {
            errorTip = '<?= __('AI 响应超时，请稍后重试。') ?>';
        } else if (errorMessage.includes('未返回任何内容')) {
            errorTip = '<?= __('AI 服务可能暂时不可用，请稍后重试。') ?>';
        }
        
        showStreamError(errorMessage, errorTip, params);
    }
}

// 在工坊步骤2中显示错误并提供重试按钮
function showStreamError(errorMessage, errorTip, params) {
    _workshopSetStartButtonLoading(false);
    const statusEl = document.getElementById('ai-gen-status');
    const progressEl = document.getElementById('ai-gen-progress');
    const spinnerEl = document.getElementById('ai-gen-spinner');
    const outputEl = document.getElementById('ai-gen-output');
    
    if (statusEl) statusEl.innerHTML = '<span style="color:#ff6b6b"><i class="mdi mdi-alert-circle"></i> <?= __('生成失败') ?></span>';
    if (progressEl) { progressEl.classList.remove('progress-bar-animated', 'progress-bar-striped'); progressEl.style.backgroundColor = '#dc3545'; }
    if (spinnerEl) { spinnerEl.className = 'me-2'; spinnerEl.innerHTML = '<i class="mdi mdi-alert-circle text-danger"></i>'; }
    if (outputEl) {
        outputEl.innerHTML += `\n<span style="color:#ff6b6b">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</span>`;
        outputEl.innerHTML += `\n<span style="color:#ff6b6b">[ERROR] ${errorMessage}</span>`;
        outputEl.innerHTML += `\n<span style="color:#888">${errorTip}</span>`;
    }
    
    // 更新步骤2底部按钮为重试/返回
    const step2 = document.getElementById('ai-ws-step2');
    if (step2) {
        const footer = step2.querySelector('.ai-ws-footer');
        if (footer) {
            footer.innerHTML = `
                <button class="ai-ws-btn-secondary" onclick="_workshopGoToStep(1)"><i class="mdi mdi-arrow-left"></i> <?= __('返回修改') ?></button>
                <button class="ai-ws-btn-primary" onclick="_workshopRegenerate()"><i class="mdi mdi-refresh"></i> <?= __('重新生成') ?></button>
            `;
        }
    }
}

// 更新流式生成状态
function updateStreamStatus(message, progress) {
    const statusEl = document.getElementById('ai-gen-status');
    const progressEl = document.getElementById('ai-gen-progress');
    if (statusEl) statusEl.innerHTML = message;
    if (progressEl) progressEl.style.width = progress + '%';
}

// 处理流式事件
function handleStreamEvent(data, currentResult, totalChars) {
    const outputEl = document.getElementById('ai-gen-output');
    const charsEl = document.getElementById('ai-gen-chars');
    
    // 根据事件类型处理
    if (data.message && !data.content && !data.success) {
        // 状态消息
        updateStreamStatus(data.message, Math.min(90, 20 + (totalChars / 100)));
        if (outputEl) {
            outputEl.textContent += '▶ ' + data.message + '\n';
            _scrollLogToBottom();
        }
    }
    
    if (data.content) {
        // AI 生成的内容块
        if (outputEl) {
            // 显示内容摘要（避免显示太长的代码）
            const preview = data.content.length > 100 ? data.content.substring(0, 100) + '...' : data.content;
            outputEl.textContent += preview;
            _scrollLogToBottom();
        }
        if (charsEl && data.total_length) {
            charsEl.textContent = data.total_length + ' <?= __('字符') ?>';
        }
        updateStreamStatus('<?= __('AI 正在生成...') ?> (' + (data.total_length || 0) + ' <?= __('字符') ?>)', Math.min(85, 20 + (data.total_length / 50)));
    }
    
    if (data.success !== undefined) {
        // 完成事件
        return data;
    }
    
    return currentResult;
}

