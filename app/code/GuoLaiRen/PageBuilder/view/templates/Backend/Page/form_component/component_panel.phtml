                <div class="mb-3">
                    <label class="form-label fw-bold"><?= __('配置字段') ?> <small class="text-muted">(<?= __('可选，每行一个') ?>)</small></label>
                    <textarea id="aiComponentFields" class="form-control" rows="3" placeholder="<?= __('标题:text:默认标题\\n描述:textarea:默认描述\\n按钮文字:text:立即下载') ?>"></textarea>
