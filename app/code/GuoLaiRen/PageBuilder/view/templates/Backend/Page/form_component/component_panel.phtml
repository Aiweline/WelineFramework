// 使用AI生成组件
async function generateComponentWithAi(params) {
    // 显示生成中状态
    Swal.fire({
        title: '<?= __('AI 正在生成组件...') ?>',
        html: `
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <p class="mb-1"><?= __('正在分析需求并生成代码...') ?></p>
                <p class="text-muted small"><?= __('这可能需要 10-30 秒') ?></p>
                ${params.referenceComponent ? `<p class="text-info small"><i class="mdi mdi-information"></i> <?= __('使用参考组件') ?>: ${params.referenceComponent}</p>` : ''}
            </div>
        `,
        allowOutsideClick: false,
        showConfirmButton: false,
        customClass: { container: 'swal2-dark-theme' }
    });
    
    try {
        // 如果选择了参考组件，先获取其代码
        let referenceCode = '';
        if (params.referenceComponent) {
            try {
                const refResponse = await fetch('<?= $this->getBackendUrl('pagebuilder/backend/visual/api/component/code') ?>?component_code=' + encodeURIComponent(params.referenceComponent) + '&style_code=' + encodeURIComponent(currentStyleCode), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (refResponse.ok) {
                    const refResult = await refResponse.json();
                    if (refResult.success && refResult.code) {
                        referenceCode = refResult.code;
                    }
                }
            } catch (refError) {
                console.warn('获取参考组件代码失败:', refError);
            }
        }
        
        const response = await fetch('<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/component') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                style_code: currentStyleCode,
                region: params.region,
                name: params.name,
                description: params.description,
                style: params.style,
                fields: params.fields,
                reference_component: params.referenceComponent,
                reference_code: referenceCode
            })
        });
        
        // 检查响应状态
        if (!response.ok) {
            throw new Error(`<?= __('服务器错误') ?>: ${response.status} ${response.statusText}`);
        }
        
        // 先获取响应文本
        const responseText = await response.text();
        
        // 尝试解析JSON
        let result;
        try {
            result = safeJsonParse(responseText);
        } catch (parseError) {
            console.error('<?= __('响应解析失败') ?>:', responseText.substring(0, 500));
            throw new Error('<?= __('服务器返回了无效的响应，可能是AI服务出错。请重试。') ?>');
        }
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('生成失败') ?>');
        }
        
        // 显示生成结果
        showGeneratedComponent(result);
        
    } catch (error) {
        Swal.fire({
            icon: 'error',
