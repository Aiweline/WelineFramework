            <button type="button" class="component-panel-toggle" onclick="toggleComponentPanel()" title="<?= __('收起/展开') ?>">
                <i class="mdi mdi-chevron-right"></i>
            </button>
        </div>
    </div>
    
    <div class="component-search">
        <input type="text" id="componentSearch" placeholder="<?= __('搜索组件...') ?>" oninput="filterComponents(this.value)">
    </div>
    
    <div class="component-panel-body" id="componentPanelBody">
        <div class="component-loading">
            <div class="spinner-border spinner-border-sm me-2"></div>
            <?= __('加载组件中...') ?>
        </div>
    </div>
</div>

<!-- 组件配置弹窗 -->
<div class="component-config-modal" id="componentConfigModal">
    <div class="component-config-dialog">
        <div class="component-config-header">
            <h5 id="componentConfigTitle"><?= __('组件配置') ?></h5>
            <button type="button" class="btn-close" onclick="closeComponentConfig()"></button>
        </div>
        <div class="component-config-body" id="componentConfigBody">
            <!-- 配置表单将动态生成 -->
        </div>
        <div class="component-config-footer">
            <button type="button" class="btn btn-secondary" onclick="closeComponentConfig()"><?= __('取消') ?></button>
            <button type="button" class="btn btn-primary" onclick="saveComponentConfig()"><?= __('保存') ?></button>
        </div>
    </div>
</div>

<script>
// 组件数据缓存
let componentData = null;
let currentStyleCode = '<?= htmlspecialchars($styleCode) ?>';
let currentEditingComponent = null;

// 区域配置（默认配置，可被 API 返回的数据覆盖）
const defaultRegionConfig = {
    header: {
        label: '<?= __('头部组件 (Header)') ?>',
        icon: 'mdi-page-layout-header',
        multiple: false,
        hint: '<?= __('Header 区域只能放置一个组件') ?>'
    },
    sidebar: {
        label: '<?= __('侧边栏组件 (Sidebar)') ?>',
        icon: 'mdi-page-layout-sidebar-left',
        multiple: true,
        hint: '<?= __('Sidebar 区域可放置多个组件') ?>'
    },
    content: {
        label: '<?= __('内容组件 (Content)') ?>',
        icon: 'mdi-text-box-multiple',
        multiple: true,
        hint: '<?= __('Content 区域可放置多个组件，按顺序排列') ?>'
    },
    hero: {
        label: '<?= __('Hero 区域 (Hero)') ?>',
        icon: 'mdi-image-area',
        multiple: false,
        hint: '<?= __('Hero 区域通常只放置一个大型横幅组件') ?>'
    },
    cta: {
        label: '<?= __('行动号召区域 (CTA)') ?>',
        icon: 'mdi-call-made',
        multiple: true,
        hint: '<?= __('CTA 区域用于放置号召行动的组件') ?>'
    },
    footer: {
        label: '<?= __('底部组件 (Footer)') ?>',
        icon: 'mdi-page-layout-footer',
        multiple: false,
        hint: '<?= __('Footer 区域只能放置一个组件') ?>'
    }
};

// 当前布局的区域配置（初始化后由 API 返回的数据更新）
let regionConfig = { ...defaultRegionConfig };
// 当前布局的区域顺序（初始化后由 API 返回的数据更新）
let regionOrder = ['header', 'content', 'footer'];

// 安全解析 JSON（处理 BOM、夹杂日志等情况）
function safeJsonParse(responseText) {
    if (!responseText) return null;
    // 去除 BOM
    const text = responseText.replace(/^\uFEFF/, '');
    try {
        return JSON.parse(text);
    } catch (err) {
        // 尝试从文本中提取 JSON 块
        const firstBrace = text.indexOf('{');
        const lastBrace = text.lastIndexOf('}');
        if (firstBrace !== -1 && lastBrace !== -1 && lastBrace > firstBrace) {
            const jsonSlice = text.slice(firstBrace, lastBrace + 1);
            return JSON.parse(jsonSlice);
        }
        throw err;
    }
}

// 初始化组件面板
async function initComponentPanel() {
    const apiUrl = '<?= $componentsApiUrl ?>';
    console.log('[组件面板] 开始加载组件，API URL:', apiUrl);
    
    try {
        const response = await fetch(apiUrl, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        console.log('[组件面板] HTTP 响应状态:', response.status, response.statusText);
        
        if (!response.ok) {
            const errorText = await response.text();
            console.error('[组件面板] HTTP 错误响应:', errorText.substring(0, 500));
            showComponentError('HTTP错误: ' + response.status + ' ' + response.statusText);
            return;
        }
        
        const responseText = await response.text();
        console.log('[组件面板] 响应长度:', responseText.length, '字符');
        
        let result;
        try {
            result = safeJsonParse(responseText);
        } catch (parseError) {
            console.error('[组件面板] JSON解析失败:', parseError);
            console.error('[组件面板] 响应内容前500字符:', responseText.substring(0, 500));
            showComponentError('JSON解析失败: ' + parseError.message);
            return;
        }
        
        console.log('[组件面板] 解析结果 success:', result.success);
        
        if (result.success) {
            componentData = result.data;
            console.log('[组件面板] 组件数据已加载');
            
            // 从 API 返回的 by_region 数据更新区域配置
            if (componentData.by_region) {
                // 获取区域顺序（API 返回的区域数据的键）
                regionOrder = Object.keys(componentData.by_region);
                console.log('[组件面板] 区域顺序:', regionOrder);
                
                // 更新区域配置
                Object.entries(componentData.by_region).forEach(([regionCode, regionData]) => {
                    if (!regionConfig[regionCode]) {
                        // 如果是未知区域，使用默认配置
                        regionConfig[regionCode] = {
                            label: regionData.label || regionCode,
                            icon: 'mdi-puzzle',
                            multiple: true,
                            hint: '<?= __('可放置组件') ?>'
                        };
                    } else if (regionData.label) {
                        // 更新已知区域的标签
                        regionConfig[regionCode].label = regionData.label;
                    }
                });
            }
            
            renderComponentPanelByRegion();
            console.log('[组件面板] 组件面板渲染完成');
        } else {
            console.error('[组件面板] API 返回失败:', result.message);
            showComponentError(result.message || '<?= __('加载组件失败') ?>');
        }
    } catch (error) {
        console.error('[组件面板] 加载组件异常:', error);
        console.error('[组件面板] 错误堆栈:', error.stack);
        showComponentError('<?= __('加载组件失败') ?>: ' + error.message);
    }
}

// 按区域渲染组件面板
function renderComponentPanelByRegion() {
    const container = document.getElementById('componentPanelBody');
    let html = '';
    
    // 使用动态区域列表（如果 API 返回了 by_region 数据，则使用 regionOrder）
    const regionsToRender = componentData.by_region ? regionOrder : ['header', 'content', 'footer'];
    
    regionsToRender.forEach(region => {
        const config = regionConfig[region] || defaultRegionConfig[region] || {
            label: region,
            icon: 'mdi-puzzle',
            multiple: true,
            hint: '<?= __('可放置组件') ?>'
        };
        const components = getComponentsForRegion(region);
        
        if (components.length === 0) return;
        
        html += `
            <div class="component-region" id="region_${region}" data-region="${region}">
                <div class="component-region-header" onclick="toggleRegion('${region}')">
                    <span>
                        <i class="mdi ${config.icon} region-icon"></i>
                        ${config.label}
                    </span>
                    <span class="region-info">
                        <span class="badge ${config.multiple ? 'badge-info' : 'badge-warning'}">
                            ${config.multiple ? '<?= __('可多个') ?>' : '<?= __('唯一') ?>'}
                        </span>
                        <span class="badge bg-secondary">${components.length}</span>
                        <i class="mdi mdi-chevron-down chevron"></i>
                    </span>
                </div>
                <div class="component-region-body">
                    ${renderComponentsByTemplate(components, region)}
                    <div class="drop-zone-hint">
                        <i class="mdi mdi-information-outline"></i> ${config.hint}
                    </div>
                </div>
            </div>
        `;
    });
    
    if (!html) {
        html = `
            <div class="component-empty">
                <i class="mdi mdi-puzzle-outline"></i>
                <p><?= __('暂无可用组件') ?></p>
            </div>
        `;
    }
    
    container.innerHTML = html;
    initDragAndDrop();
}

// 获取指定区域的组件
function getComponentsForRegion(region) {
    if (!componentData) return [];
    
    // 如果 API 返回了 by_region 数据，优先使用它
    if (componentData.by_region && componentData.by_region[region]) {
        const regionData = componentData.by_region[region];
        if (regionData.components && regionData.components.length > 0) {
            return regionData.components.map(comp => ({
                ...comp,
                isOwn: comp.isOwn || false,
                isShared: comp.isShared || false,
                templateCode: comp.templateCode || currentStyleCode,
                templateName: comp.templateName || currentStyleCode
            }));
        }
    }
    
    // 回退到传统方式
    const components = [];
    const categoryMap = {
        header: ['header'],
        sidebar: ['sidebar', 'widget'],
        content: ['content', 'widget'],
        hero: ['hero', 'banner', 'content'],
        cta: ['cta', 'content'],
        footer: ['footer']
    };
    const allowedCategories = categoryMap[region] || [region];
    
    // 收集推荐组件（当前模板）
    if (componentData.recommended && componentData.recommended.components) {
        componentData.recommended.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isOwn: true,
                    templateCode: currentStyleCode,
                    templateName: componentData.recommended.label || currentStyleCode
                });
            }
        });
    }
    
    // 收集共享组件
    if (componentData.shared && componentData.shared.components) {
        componentData.shared.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isShared: true,
                    templateCode: '_shared',
                    templateName: '<?= __('通用组件') ?>'
                });
            }
        });
    }
    
    // 收集其他模板的组件
    if (componentData.other_templates) {
        Object.entries(componentData.other_templates).forEach(([templateCode, templateData]) => {
            if (templateData.components) {
                templateData.components.forEach(comp => {
                    if (allowedCategories.includes(comp.category) || comp.region === region) {
                        components.push({
                            ...comp,
                            isOther: true,
                            templateCode: templateCode,
                            templateName: templateData.label || templateCode
                        });
                    }
                });
            }
        });
    }
    
    return components;
}

// 按模板分组渲染组件
function renderComponentsByTemplate(components, region) {
    // 按模板分组
    const groups = {};
    components.forEach(comp => {
        const key = comp.isOwn ? 'own' : (comp.isShared ? 'shared' : comp.templateCode);
        if (!groups[key]) {
            groups[key] = {
                label: comp.isOwn ? '<?= __('本模板（推荐）') ?>' : (comp.isShared ? '<?= __('通用组件') ?>' : comp.templateName),
                isOwn: comp.isOwn,
                isShared: comp.isShared,
                components: []
            };
        }
        groups[key].components.push(comp);
    });
    
    let html = '';
    
    // 优先显示本模板组件
    if (groups.own) {
        html += renderTemplateGroup(groups.own, region);
        delete groups.own;
    }
    
    // 然后显示共享组件
    if (groups.shared) {
        html += renderTemplateGroup(groups.shared, region);
        delete groups.shared;
    }
    
    // 最后显示其他模板组件
    Object.values(groups).forEach(group => {
        html += renderTemplateGroup(group, region);
    });
    
    return html;
}

// 渲染模板分组
function renderTemplateGroup(group, region) {
    const starHtml = group.isOwn ? '<span class="star">★</span>' : '';
    
    return `
        <div class="component-template-group">
            <div class="component-template-group-header">
                ${starHtml} ${group.label}
            </div>
            <div class="component-template-group-cards">
                ${group.components.map(comp => renderComponentCard(comp, region)).join('')}
            </div>
        </div>
    `;
}

// 解码 Base64 编码的预览HTML
function decodePreviewHtml(component) {
    if (!component.preview_html || !component.preview_html.trim()) {
        return '';
    }
    
    // 如果标记为已编码，则进行Base64解码
    if (component.preview_html_encoded) {
        try {
            return atob(component.preview_html);
        } catch (e) {
            console.error('[组件面板] Base64解码失败:', e, component.code);
            return '';
        }
    }
    
    // 未编码则直接返回
    return component.preview_html;
}

// 渲染组件卡片
function renderComponentCard(component, region) {
    // 优先使用预览HTML，其次使用缩略图，然后使用组件自定义图标，最后使用区域默认图标
    let thumbHtml = '';
    
    // 解码预览HTML（如果已编码）
    const decodedPreviewHtml = decodePreviewHtml(component);
    
    if (decodedPreviewHtml && decodedPreviewHtml.trim()) {
        // 直接渲染预览 HTML（带样式隔离的容器）
        // 使用 iframe 来完全隔离样式
        const previewHtml = decodedPreviewHtml.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        thumbHtml = `<div class="component-preview-container">
            <iframe 
                srcdoc="<!DOCTYPE html><html><head><meta charset='utf-8'><style>*{box-sizing:border-box;}body{margin:0;padding:0;overflow:hidden;background:#fff;min-height:100vh;}</style></head><body>${previewHtml}</body></html>"
                frameborder="0"
                scrolling="no">
            </iframe>
        </div>`;
    } else if (component.thumbnail_url) {
        thumbHtml = `<img src="${component.thumbnail_url}" alt="${component.name}" onerror="this.parentNode.innerHTML='<i class=\\'mdi mdi-puzzle\\'></i>'">`;
    } else if (component.icon) {
        // 支持 Bootstrap Icons (bi-*) 和 MDI (mdi-*)
        const iconClass = component.icon.startsWith('bi-') ? `bi ${component.icon}` : 
                         component.icon.startsWith('mdi-') ? `mdi ${component.icon}` : 
                         `mdi mdi-${component.icon}`;
        thumbHtml = `<i class="${iconClass}"></i>`;
    } else {
        thumbHtml = `<i class="mdi mdi-${getRegionIcon(region)}"></i>`;
    }
    
    const recommendedClass = component.isOwn ? 'recommended' : '';
    const tagHtml = component.isOwn 
        ? '<span class="component-tag own"><?= __('推荐') ?></span>'
        : (component.isShared 
            ? '<span class="component-tag shared"><?= __('通用') ?></span>'
            : '<span class="component-tag other"><?= __('兼容') ?></span>');
    
    // 来源标识
    const sourceLabel = component.isOwn ? '' : (component.isShared ? '<?= __('通用') ?>' : component.templateName);
    
    return `
        <div class="component-card ${recommendedClass}" 
             draggable="true"
             data-component-code="${component.code}"
             data-component-name="${component.name}"
             data-component-region="${region}"
             data-component-template="${component.style_code || component.templateCode}"
             data-component-is-own="${component.isOwn ? 'true' : 'false'}"
             ondragstart="handleDragStart(event)"
             ondragend="handleDragEnd(event)"
             ondblclick="previewComponent('${component.code}')">
            <div class="component-card-thumb">
                ${thumbHtml}
            </div>
            <div class="component-card-name" title="${component.name}">${component.name}</div>
            ${sourceLabel ? `<div class="component-card-template">${sourceLabel}</div>` : ''}
            ${tagHtml}
        </div>
    `;
}

// 获取区域图标
function getRegionIcon(region) {
    const icons = {
        header: 'page-layout-header',
        content: 'text-box',
        footer: 'page-layout-footer'
    };
    return icons[region] || 'puzzle';
}

// 显示错误
function showComponentError(message) {
    const container = document.getElementById('componentPanelBody');
    container.innerHTML = `
        <div class="component-empty">
            <i class="mdi mdi-alert-circle-outline text-danger"></i>
            <p>${message}</p>
            <button class="btn btn-sm btn-outline-primary" onclick="initComponentPanel()">
                <?= __('重试') ?>
            </button>
        </div>
    `;
}

// 切换组件面板
function toggleComponentPanel() {
    const panel = document.getElementById('componentPanel');
    const isCollapsed = panel.classList.toggle('collapsed');
    
    // 更新按钮提示文本
    const toggleBtn = panel.querySelector('.component-panel-toggle');
    if (toggleBtn) {
        toggleBtn.title = isCollapsed ? '<?= __('展开组件库') ?>' : '<?= __('收起组件库') ?>';
    }
}

// 切换区域
function toggleRegion(regionId) {
    const region = document.getElementById('region_' + regionId);
    region.classList.toggle('collapsed');
}

// 搜索组件
function filterComponents(keyword) {
    keyword = keyword.toLowerCase().trim();
    
    document.querySelectorAll('.component-card').forEach(card => {
        const name = card.getAttribute('data-component-name').toLowerCase();
        const code = card.getAttribute('data-component-code').toLowerCase();
        
        if (!keyword || name.includes(keyword) || code.includes(keyword)) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });
    
    // 显示/隐藏空的分组
    document.querySelectorAll('.component-template-group').forEach(group => {
        const visibleCards = group.querySelectorAll('.component-card:not([style*="display: none"])');
        group.style.display = visibleCards.length > 0 ? '' : 'none';
    });
}

// 拖拽相关
function initDragAndDrop() {
    // 在预览区域设置放置监听
    const previewFrame = document.getElementById('previewFrame');
    if (previewFrame && previewFrame.contentWindow) {
        setupDropZones(previewFrame.contentWindow.document);
    }
}

function handleDragStart(event) {
    const card = event.target.closest('.component-card');
    card.classList.add('dragging');
    
    const componentData = {
        code: card.getAttribute('data-component-code'),
        name: card.getAttribute('data-component-name'),
        region: card.getAttribute('data-component-region'),
        template: card.getAttribute('data-component-template'),
        isOwn: card.getAttribute('data-component-is-own') === 'true'
    };
    
    event.dataTransfer.setData('text/plain', JSON.stringify(componentData));
    event.dataTransfer.effectAllowed = 'copy';
    
    // 高亮对应的放置区域
    highlightDropZones(componentData.region);
}

function handleDragEnd(event) {
    const card = event.target.closest('.component-card');
    card.classList.remove('dragging');
    unhighlightDropZones();
}

function highlightDropZones(region) {
    // 在预览iframe中高亮 - 使用新的 pbSlots 接口
    const previewFrame = document.getElementById('previewIframe');
    if (previewFrame && previewFrame.contentWindow) {
        try {
            // 优先使用 pbSlots 接口
            if (previewFrame.contentWindow.pbSlots && previewFrame.contentWindow.pbSlots.highlight) {
                previewFrame.contentWindow.pbSlots.highlight(region);
            } else {
                // 回退到直接操作 DOM
                const doc = previewFrame.contentWindow.document;
                doc.querySelectorAll('.pb-slot[data-region="' + region + '"]').forEach(zone => {
                    zone.classList.add('drag-over');
                });
            }
        } catch (e) {
            console.warn('无法高亮预览区域:', e);
        }
    }
    
    // 通知父页面
    if (typeof window.parent.highlightPreviewRegion === 'function') {
        window.parent.highlightPreviewRegion(region);
    }
}

function unhighlightDropZones() {
    const previewFrame = document.getElementById('previewIframe');
    if (previewFrame && previewFrame.contentWindow) {
        try {
            // 优先使用 pbSlots 接口
            if (previewFrame.contentWindow.pbSlots && previewFrame.contentWindow.pbSlots.unhighlight) {
                previewFrame.contentWindow.pbSlots.unhighlight();
            } else {
                // 回退到直接操作 DOM
                const doc = previewFrame.contentWindow.document;
                doc.querySelectorAll('.pb-slot.drag-over').forEach(zone => {
                    zone.classList.remove('drag-over');
                });
            }
        } catch (e) {
            console.warn('无法取消高亮预览区域:', e);
        }
    }
    
    if (typeof window.parent.unhighlightPreviewRegion === 'function') {
        window.parent.unhighlightPreviewRegion();
    }
}

function setupDropZones(doc) {
    if (!doc) return;
    
    doc.querySelectorAll('[data-region]').forEach(zone => {
        zone.addEventListener('dragover', (e) => {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        
        zone.addEventListener('dragleave', () => {
            zone.classList.remove('drag-over');
        });
        
        zone.addEventListener('drop', (e) => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            
            try {
                const data = JSON.parse(e.dataTransfer.getData('text/plain'));
                const targetRegion = zone.getAttribute('data-region');
                
                // 检查区域匹配
                if (data.region !== targetRegion) {
                    alert('<?= __('此组件只能放置在') ?> ' + regionConfig[data.region].label);
                    return;
                }
                
                // 检查唯一性
                const isMultiple = zone.getAttribute('data-multiple') === 'true';
                if (!isMultiple && zone.querySelectorAll('.tpmst-component-wrapper').length > 0) {
                    if (!confirm('<?= __('此区域只能放置一个组件，是否替换现有组件？') ?>')) {
                        return;
                    }
                }
                
                // 添加组件
                addComponentToRegion(data, targetRegion, zone);
            } catch (err) {
                console.error('Drop error:', err);
            }
        });
    });
}

// 添加组件到区域
function addComponentToRegion(componentData, region, targetZone) {
    // 这里需要调用后端API保存组件配置
    
    // TODO: 调用API保存
    // TODO: 刷新预览
    
    if (typeof window.parent.refreshPreview === 'function') {
        window.parent.refreshPreview();
    }
}

// 预览组件
async function previewComponent(componentCode) {
    
    // 显示加载中
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('加载预览...') ?>',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });
    }
    
    try {
        // 获取当前样式代码
        const styleSelect = document.getElementById('style');
        const styleCode = styleSelect ? styleSelect.value : (window.currentStyle || 'tpmst');
        
        // 调用预览 API（不传config，使用默认配置）
        const response = await fetch('<?= $this->getBackendUrl('pagebuilder/backend/visual/api/component/preview') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'component_code=' + encodeURIComponent(componentCode) + '&style_code=' + encodeURIComponent(styleCode)
        });
        
        const result = await response.json();
        
        if (!result.success) {
