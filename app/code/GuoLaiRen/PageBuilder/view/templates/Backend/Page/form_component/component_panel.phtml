                            <br><small class="text-muted">${savedComponent.component.description || ''}</small>
                            <br><small class="text-muted"><?= __('保存时间') ?>: ${new Date(savedComponent.savedAt).toLocaleString()}</small>
                        </div>
                    </div>
                    <p class="text-muted small"><?= __('您可以恢复继续编辑，或者丢弃重新开始。') ?></p>
                </div>
            `,
            width: '500px',
            showCancelButton: true,
            showDenyButton: true,
            confirmButtonText: '<i class="mdi mdi-restore"></i> <?= __('恢复') ?>',
            denyButtonText: '<i class="mdi mdi-delete"></i> <?= __('丢弃') ?>',
            cancelButtonText: '<?= __('稍后') ?>',
            confirmButtonColor: '#667eea',
            denyButtonColor: '#dc3545',
            customClass: { container: 'swal2-dark-theme' }
        }).then((result) => {
            if (result.isConfirmed) {
                // 恢复组件
                window.currentGeneratedComponent = {
                    component: savedComponent.component,
                    templateContent: savedComponent.templateContent,
                    validation: savedComponent.validation || { valid: true },
                    preview: savedComponent.preview || ''
                };
                showGeneratedComponent({
                    component: savedComponent.component,
                    validation: savedComponent.validation || { valid: true },
                    preview: savedComponent.preview || '',
                    result: savedComponent.result
                });
            } else if (result.isDenied) {
                // 丢弃
                clearGeneratedComponentFromLocal();
            }
            // 取消则什么都不做
        });
    }
}

