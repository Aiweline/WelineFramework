// 设置预览设备尺寸（挂到 window 供全屏遮罩内按钮调用）
window.setPreviewDevice = function setPreviewDevice(device) {
    const doc = window.__aiFullscreenPreviewDoc || document;
    const container = doc.getElementById('fullscreen-preview-container');
    if (!container) return;
    
    // 移除所有设备按钮的激活状态
    doc.querySelectorAll('.ai-preview-device-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    
    // 激活当前设备按钮
    const activeBtn = doc.querySelector(`.ai-preview-device-btn[data-device="${device}"]`);
    if (activeBtn) {
        activeBtn.classList.add('active');
    }
    
    // 移除所有设备 class 并添加当前设备 class
    container.classList.remove('ai-preview-device-mobile', 'ai-preview-device-tablet', 'ai-preview-device-desktop');
    container.classList.add(`ai-preview-device-${device}`);
}

// 切换 JSON 导出区域显示/隐藏
function toggleJsonExport() {
    const body = document.getElementById('json-export-body');
    const chevron = document.getElementById('json-export-chevron');
    if (body && chevron) {
        if (body.style.display === 'none') {
            body.style.display = 'block';
            chevron.classList.remove('mdi-chevron-down');
            chevron.classList.add('mdi-chevron-up');
        } else {
            body.style.display = 'none';
            chevron.classList.remove('mdi-chevron-up');
            chevron.classList.add('mdi-chevron-down');
        }
    }
}

// 复制内容到剪贴板的通用函数
function copyToClipboard(elementId, buttonElement) {
    const element = document.getElementById(elementId);
    if (!element) {
        console.error('Element not found:', elementId);
        return;
    }
    
    const text = element.textContent || element.innerText;
    
    navigator.clipboard.writeText(text).then(() => {
        // 显示复制成功提示
        const originalText = buttonElement.innerHTML;
        buttonElement.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已复制') ?>';
        buttonElement.classList.remove('btn-light');
        buttonElement.classList.add('btn-success');
        setTimeout(() => {
            buttonElement.innerHTML = originalText;
            buttonElement.classList.remove('btn-success');
            buttonElement.classList.add('btn-light');
        }, 2000);
    }).catch(err => {
        console.error('复制失败:', err);
        // 回退方案：选中文本
        const range = document.createRange();
        range.selectNodeContents(element);
        const selection = window.getSelection();
        selection.removeAllRanges();
        selection.addRange(range);
        
        // 提示用户手动复制
        buttonElement.innerHTML = '<i class="mdi mdi-cursor-text"></i> <?= __('请Ctrl+C') ?>';
        setTimeout(() => {
            buttonElement.innerHTML = '<i class="mdi mdi-content-copy"></i> <?= __('复制') ?>';
        }, 3000);
    });
}

// 显示生成的组件结果
function showGeneratedComponent(result) {
    const component = result.component || {};
    const validation = result.validation || {};
    // 优先使用 result.preview.html，然后是 result.preview，最后是 preview
    const preview = result.preview?.html || result.preview || '';
    // 优先使用 result.result.template_content，然后是 component.phtml_code
    const templateContent = result.result?.template_content || component.phtml_code || '';
    
    // 获取最终提示词（优先使用参数传递的，其次使用已保存的）
    const finalPrompt = result.final_prompt || (window.currentGeneratedComponent?.finalPrompt) || '';
    
    // 保存当前组件数据到全局变量，供微调使用
    window.currentGeneratedComponent = {
        component: component,
        templateContent: templateContent,
        validation: validation,
        preview: preview,
        finalPrompt: finalPrompt
    };
    
    // 如果result.result存在，合并到component中
    if (result.result) {
        window.currentGeneratedComponent.component = {
            ...component,
            ...result.result,
            phtml_code: result.result.template_content || templateContent
        };
        window.currentGeneratedComponent.templateContent = result.result.template_content || templateContent;
    }
    
    // 保存到localStorage，用于页面刷新后恢复
    saveGeneratedComponentToLocal(window.currentGeneratedComponent);
    
    // 获取最终组件数据（合并result.result）
    const finalComponent = window.currentGeneratedComponent.component || component;
    
    // 判断是否预览失败
    const previewError = result.preview?.error || result.error || result.message || '';
    const previewFailed = !preview || (result.preview?.success === false) || !!previewError;
    
    // 构建预览HTML（优先使用result.preview.html）
    const previewHtml = result.preview?.html || result.preview || preview;
    
    // 加载微调历史
    const refineHistory = loadRefineHistory();
    let historyHtml = '';
    if (refineHistory.length > 0) {
        const historyItems = refineHistory.slice(0, 5).map((item) => 
            `<button type="button" class="btn btn-sm btn-outline-secondary me-1 mb-1" onclick="fillInlineRefinePrompt('${item.prompt.replace(/'/g, "\\'").replace(/"/g, '&quot;')}')">${item.prompt.length > 15 ? item.prompt.substring(0, 15) + '...' : item.prompt}</button>`
        ).join('');
        historyHtml = `
            <div class="mb-2">
                <small class="text-muted"><i class="mdi mdi-history"></i> <?= __('最近') ?>: ${historyItems}</small>
            </div>
        `;
    }
    
    // 构建验证信息HTML
    let validationHtml = '';
    if (validation.valid) {
        validationHtml = '<div class="alert alert-success py-2 mb-3"><i class="mdi mdi-check-circle"></i> <?= __('组件验证通过') ?></div>';
    } else {
        const errors = (validation.errors || []).map(e => `<li>${e}</li>`).join('');
        validationHtml = `<div class="alert alert-danger py-2 mb-3"><i class="mdi mdi-alert-circle"></i> <?= __('验证问题') ?>:<ul class="mb-0 mt-1 small">${errors}</ul></div>`;
    }
    
    // 构建预览区域HTML
    let previewSectionHtml = '';
    if (previewFailed) {
        previewSectionHtml = `
            <div class="card mb-3 border-warning">
                <div class="card-header bg-warning text-dark py-2 d-flex justify-content-between align-items-center">
                    <span><i class="mdi mdi-alert"></i> <?= __('预览渲染失败') ?></span>
                    <button type="button" class="btn btn-sm btn-outline-dark" onclick="showGeneratedCode()">
                        <i class="mdi mdi-code-tags"></i> <?= __('查看代码') ?>
                    </button>
                </div>
                <div class="card-body py-2">
                    ${previewError ? `<p class="text-danger small mb-0"><strong><?= __('错误') ?>:</strong> ${previewError}</p>` : '<p class="text-muted small mb-0"><?= __('预览生成失败，请使用下方微调功能修复问题') ?></p>'}
                </div>
            </div>
        `;
    } else if (previewHtml) {
        previewSectionHtml = `
            <div class="card mb-3">
                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                    <span><i class="mdi mdi-eye"></i> <?= __('预览') ?></span>
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-primary me-1" onclick="window.openFullscreenPreview()" title="<?= __('全屏预览') ?>">
                            <i class="mdi mdi-fullscreen"></i>
