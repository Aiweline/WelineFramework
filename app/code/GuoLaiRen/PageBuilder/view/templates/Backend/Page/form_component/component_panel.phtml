        `,
        width: '600px',
        showCancelButton: true,
        confirmButtonText: '<i class="mdi mdi-robot"></i> <?= __('生成组件') ?>',
        cancelButtonText: '<?= __('取消') ?>',
        confirmButtonColor: '#667eea',
        customClass: { container: 'swal2-dark-theme' },
        preConfirm: () => {
            const name = document.getElementById('aiComponentName').value.trim();
            const desc = document.getElementById('aiComponentDesc').value.trim();
            
            if (!name) {
                Swal.showValidationMessage('<?= __('请输入组件名称') ?>');
                return false;
            }
            if (!desc) {
                Swal.showValidationMessage('<?= __('请输入组件描述') ?>');
                return false;
            }
            
            return {
                region: document.getElementById('aiComponentRegion').value,
                name: name,
                description: desc,
                style: document.getElementById('aiComponentStyle').value,
                fields: document.getElementById('aiComponentFields').value
            };
