}

// 确保预览 iframe 内脚本可用的 component 变量（避免 "component is not defined"）
function _ensureComponentInPreviewHtml(html) {
    if (!html || typeof html !== 'string') return html;
    var script = '<script>var component=document.body.querySelector("[id]")||document.body;<\/script>';
    if (html.indexOf('<body>') !== -1) return html.replace('<body>', '<body>' + script);
    if (html.indexOf('<body ') !== -1) return html.replace(/\<body\s[^>]*\>/, function(m) { return m + script; });
    return html;
}

// 从 AI 生成的组件数据构建预览 HTML
function _buildComponentPreviewHtml(comp) {
    const css = (comp.css_content || '') + '\n' + (comp.css_responsive || '');
    const html = comp.html_content || '';
    const js = comp.js_content || '';
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><style>
:root{--pb-primary:#667eea;--pb-accent:#7c3aed;--pb-bg:#fff;--pb-text:#333;--pb-heading:#1a1a1a;--pb-link:#667eea;--pb-link-hover:#5a6fd6;--pb-text-muted:#888;--pb-border:#e5e7eb;}
body{margin:0;padding:16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:var(--pb-text);background:var(--pb-bg);}
${css}
</style></head><body>
<div id="componentId">${html}</div>
${js ? '<script>var component=document.getElementById("componentId");' + js + '<\/script>' : ''}
</body></html>`;
}

