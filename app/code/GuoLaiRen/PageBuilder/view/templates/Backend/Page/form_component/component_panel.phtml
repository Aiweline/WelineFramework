<?php
/**
 * 组件拖拽面板 - 可视化构建器的组件选择器
 * 
 * 支持：
 * 1. 按区域（header/content/footer）分组显示
 * 2. 本模板组件标星推荐
 * 3. 组件拖拽到对应区域
 * 4. header/footer 区域唯一，content 区域可多个
 * 
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\PageBuilder\Model\Page $page
 * @var string $styleCode 当前模板代码
 */

$page = $this->getData('page');
$pageId = $page && $page->getId() ? $page->getId() : 0;
$styleCode = $this->getData('style_code') ?: ($page ? $page->getData('style') : 'default');

// 获取页面类型（用于加载对应的默认布局配置）
$pageType = $page ? $page->getData('type') : '';

// 根据页面类型自动选择布局类型：博客类型页面使用blog布局
$layoutCode = $this->getData('layout_code');
if (empty($layoutCode) && $page) {
    // 博客类型页面使用blog布局
    if (in_array($pageType, [
        \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG,
        \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG_CATEGORY,
        \GuoLaiRen\PageBuilder\Model\Page::TYPE_BLOG_LIST
    ])) {
        $layoutCode = 'blog';
    } else {
        $layoutCode = 'default';
    }
}
$layoutCode = $layoutCode ?: 'default';

// 获取组件数据的URL（传递页面类型以加载对应的默认布局配置）
// include_preview=1 启用组件预览HTML生成
$componentsApiUrl = $this->getBackendUrl('pagebuilder/backend/visual/api/component/list', [
    'style_code' => $styleCode,
    'layout_code' => $layoutCode,
    'page_type' => $pageType, // 传递页面类型
    'group_by_region' => 'true',
    'include_preview' => '1', // 启用组件预览
    'include_compatible' => '1', // 包含兼容组件（跨模板）
]);

// 获取模板CSS的基础URL（用于组件预览）
$templateCssBaseUrl = $this->fetchTemplateStatic('GuoLaiRen_PageBuilder::style/' . $styleCode . '/asset/css/home.css');
?>

