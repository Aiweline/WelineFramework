            let heightHandler = null;
            
            Swal.fire({
                title: (componentInfo.name || componentCode) + ' - <?= __('预览') ?>',
                html: `
                    <div style="display: flex; flex-direction: column; height: 70vh;">
                        <div style="text-align: left; margin-bottom: 12px; flex-shrink: 0;">
                            <span class="badge bg-primary">${componentInfo.region || 'content'}</span>
                            ${componentInfo.category ? `<span class="badge bg-secondary">${componentInfo.category}</span>` : ''}
                        </div>
                        <iframe id="componentPreviewFrame" style="width: 100%; flex: 1; border: none; border-radius: 8px; background: #f5f5f5; display: block;"></iframe>
                        <p style="margin-top: 12px; font-size: 12px; color: #666; text-align: center; flex-shrink: 0;">
                            <?= __('双击组件卡片预览，拖拽到预览区域添加') ?>
                        </p>
                    </div>
                `,
                width: '90%',
                maxWidth: '1200px',
                showConfirmButton: true,
                confirmButtonText: '<?= __('关闭') ?>',
                didOpen: () => {
                    const iframe = document.getElementById('componentPreviewFrame');
                    if (iframe) {
                        // 使用flex布局，iframe自动填充容器，不需要设置固定高度
                        
                        // 监听高度变化（可选，用于内容自适应）
                        heightHandler = (event) => {
                            if (event.data && event.data.type === 'previewHeight') {
                                // flex布局下不需要手动设置高度，iframe会自动填满容器
                            }
                        };
                        window.addEventListener('message', heightHandler);
                        
                        // 写入 iframe 内容
                        try {
                            const doc = iframe.contentDocument || iframe.contentWindow.document;
                            doc.open();
                            doc.write(iframeContent);
                            doc.close();
                        } catch (e) {
                            console.error('写入 iframe 内容失败:', e);
                            iframe.srcdoc = iframeContent;
                        }
                    }
                },
                didClose: () => {
                    // 移除监听器
                    if (heightHandler) {
                        window.removeEventListener('message', heightHandler);
                        heightHandler = null;
                    }
                }
            });
        }
        
    } catch (error) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('预览失败') ?>',
                text: error.message || '<?= __('未知错误') ?>'
            });
        }
    }
}

