// 微调功能
async function _workshopRefine() {
    const input = document.getElementById('ai-refine-input')?.value.trim();
    if (!input) {
        if (typeof BackendToast !== 'undefined') BackendToast.warning('<?= __('请输入微调描述') ?>');
        return;
    }

    const btn = document.getElementById('ai-refine-btn');
    const status = document.getElementById('ai-refine-status');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('微调中...') ?>'; }
    if (status) status.textContent = '<?= __('正在调用 AI 微调...') ?>';
    _clearRefineLog();
    _refineLogLine('▶ <?= __('开始微调') ?>', '#94a3b8');
    _refineLogLine('• <?= __('微调描述') ?>: ' + input, '#a3a3a3');

    try {
        // 获取当前组件数据
        const component = _aiWorkshop.result?.component;
        if (!component) throw new Error('<?= __('无组件数据') ?>');

        const region = component.region || _aiWorkshop.params?.region || 'content';
        
        // 简化微调参数：优先使用组件 ID，后端自动获取模板内容
        // 添加语言参数，让 AI 生成对应语言的内容
        const refineParams = {
            adjustment_prompt: input,
            category: region,
            language: document.documentElement.lang || '<?= $this->request->getUserLanguage() ?>'
        };
        
        // 优先传 component_id（最简洁），其次是 code，最后是 template_content
        const componentId = _aiWorkshop.result?.component_id || component.id || 0;
        if (componentId) {
            refineParams.component_id = componentId;
        } else if (component.code) {
            refineParams.code = component.code;
            refineParams.style_code = component.style_code || component.templateCode || currentStyleCode;
        } else if (component.phtml_code) {
            // 最后备选：直接传模板内容
            refineParams.template_content = component.phtml_code;
        }
        
        const draftId = _aiWorkshop.result?.draft_id || 0;
        if (draftId) refineParams.draft_id = draftId;

        const paramsBase64 = btoa(unescape(encodeURIComponent(JSON.stringify(refineParams))));
        const streamUrl = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/refine-stream') ?>?params=' + encodeURIComponent(paramsBase64);

        _refineLogLine('⚙ <?= __('正在发送微调请求...') ?>', '#94a3b8');

        let streamResult = null;
        await new Promise((resolve, reject) => {
            const eventSource = new EventSource(streamUrl);
            _aiWorkshop.eventSource = eventSource;
            const guard = createStreamFinishGuard();
            function finish(ok, err) {
                const r = guard.finish(ok, err);
                if (r) {
                    try { eventSource.close(); } catch (e) {}
                    r.ok ? resolve() : reject(r.err);
                }
            }

            eventSource.onopen = () => {
                _refineLogLine('▶ <?= __('开始微调') ?>', '#94a3b8');
            };

            eventSource.addEventListener('agent_status', e => {
                const d = safeParseJson(e.data);
                if (d?.message) _refineLogLine('⚙ ' + d.message, '#94a3b8');
            });

            eventSource.addEventListener('iteration', e => {
                const d = safeParseJson(e.data);
                if (d) _refineLogLine('━━━ <?= __('第') ?> ' + d.iteration + ' <?= __('轮') ?> ━━━', '#667eea');
            });

            eventSource.addEventListener('thinking', e => {
                const d = safeParseJson(e.data);
                if (d?.content) _refineLogLine('🤖 ' + d.content, '#cbd5f5');
            });

            eventSource.addEventListener('tool_call', e => {
                const d = safeParseJson(e.data);
                if (d) _refineLogLine('🔧 ' + d.name, '#fbbf24');
            });

            eventSource.addEventListener('tool_result', e => {
                const d = safeParseJson(e.data);
                if (d) _refineLogLine('  ✓ ' + d.name + ' (' + (d.result_size || 0) + 'B)', '#a3a3a3');
            });

            eventSource.addEventListener('complete', e => {
                const d = safeParseJson(e.data);
                streamResult = d;
                finish(true);
            });

            // 处理服务端发送的 error 事件（正常的 SSE 错误事件）
            eventSource.addEventListener('error', e => {
                const d = safeParseJson(e.data);
                finish(false, new Error(d?.message || '<?= __('微调失败') ?>'));
            });
            
            // 处理网络错误（HTTP 404/500 等）或连接断开
            eventSource.onerror = (e) => {
                // 如果 readyState 是 CLOSED 且没有收到任何数据，可能是 404
                if (eventSource.readyState === EventSource.CLOSED) {
                    const errorMsg = '<?= __('微调请求失败：无法连接服务端（可能是 404 或网络问题）。请检查服务器是否正常运行。') ?>';
                    _refineLogLine('✗ ' + errorMsg, '#ef4444');
                    finish(false, new Error(errorMsg));
                } else if (eventSource.readyState === EventSource.CONNECTING) {
                    _refineLogLine('↻ <?= __('连接断开，正在重连...') ?>', '#fbbf24');
                }
            };
        });

        if (!streamResult?.success) throw new Error(streamResult?.message || '<?= __('微调失败') ?>');
        _refineLogLine('✓ <?= __('微调完成，正在应用预览...') ?>', '#10b981');
        if (streamResult.agent) {
            const toolCalls = streamResult.agent.tool_calls || [];
            if (streamResult.agent.iterations) {
                _refineLogLine('↻ <?= __('智能体迭代') ?>: ' + streamResult.agent.iterations, '#a3a3a3');
            }
            if (toolCalls.length > 0) {
                _refineLogLine('⚙ <?= __('工具调用记录') ?>:', '#94a3b8');
                toolCalls.forEach((tc, idx) => {
                    _refineLogLine(`- ${idx + 1}. ${tc.name}`, '#a3a3a3');
                });
            }
        }

        const json = streamResult;

        // 更新结果；微调后 token 已消费，后续微调改传 template_content
        if (json.result) {
            const r = json.result;
            if (r.template_content) {
                _aiWorkshop.result.component.phtml_code = r.template_content;
            }
            if (r.component) {
                _aiWorkshop.result.component = { ..._aiWorkshop.result.component, ...r.component };
            }
            if (_aiWorkshop.result) _aiWorkshop.result.refine_token = '';
            if (json.draft_id !== undefined && _aiWorkshop.result) _aiWorkshop.result.draft_id = json.draft_id;
            window.currentGeneratedComponent = _aiWorkshop.result.component;
        }
        if (json.preview?.html) {
            // 包裹成完整 HTML 文档供 iframe 预览（和初始生成一致）
            const renderedHtml = json.preview.html;
            const fullPreviewHtml = `<!DOCTYPE html><html><head><meta charset="utf-8"><style>
:root{--pb-primary:#667eea;--pb-accent:#7c3aed;--pb-bg:#fff;--pb-text:#333;--pb-heading:#1a1a1a;--pb-link:#667eea;--pb-link-hover:#5a6fd6;--pb-text-muted:#888;--pb-border:#e5e7eb;}
body{margin:0;padding:16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:var(--pb-text);background:var(--pb-bg);}
</style></head><body><script>var component=document.body.querySelector("[id]")||document.body;<\/script>${renderedHtml}</body></html>`;
            const dstIframe = document.getElementById('ai-ws-refine-preview');
            if (dstIframe) dstIframe.srcdoc = fullPreviewHtml;
            // 也更新步骤3的预览
            const srcIframe = document.getElementById('ai-ws-preview-iframe');
            if (srcIframe) srcIframe.srcdoc = fullPreviewHtml;
            // 更新 result 中的预览
            _aiWorkshop.result.preview = fullPreviewHtml;
        }

        // 添加到微调历史
        const historyEl = document.getElementById('ai-refine-history');
        if (historyEl) {
            historyEl.innerHTML = '<div style="padding:3px 0;border-bottom:1px solid #333;">'
                + '<span style="color:#667eea;">• </span>' + _escHtml(input)
                + '<span style="color:#10b981;margin-left:6px;">✓</span></div>'
                + historyEl.innerHTML;
        }

        // 保存本地
        saveGeneratedComponentToLocal();

        if (status) status.innerHTML = '<span style="color:#10b981;">✓ <?= __('微调完成') ?></span>';
        document.getElementById('ai-refine-input').value = '';

    } catch (e) {
        if (status) status.innerHTML = '<span style="color:#ef4444;"><?= __('微调失败') ?>: ' + e.message + '</span>';
        _refineLogLine('[FAILED] ' + e.message, '#ef4444');
    } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="mdi mdi-auto-fix"></i> <?= __('微调') ?>'; }
    }
}

