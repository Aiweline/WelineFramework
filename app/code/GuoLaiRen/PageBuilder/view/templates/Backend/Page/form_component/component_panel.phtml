// 当前面板状态
let _aiWorkshop = { step: 1, params: null, result: null, eventSource: null };

/**
 * 删除 AI 组件
 * - 无引用时直接删除
 * - 有引用时显示引用的页面列表，提示用户先移除引用
 */
async function deleteAiComponent(componentId, componentName) {
    if (!componentId) {
        BackendToast.warning('<?= __('组件 ID 无效') ?>');
        return;
    }
    
    const confirmed = await BackendConfirm.show(
        '<?= __('确定要删除 AI 组件') ?> "' + _escHtml(componentName) + '" <?= __('吗？此操作不可恢复。') ?>',
        {
            title: '<?= __('删除确认') ?>',
            confirmText: '<?= __('删除') ?>',
            cancelText: '<?= __('取消') ?>',
            type: 'danger'
        }
    );
    
    if (!confirmed) return;
    
    try {
        const url = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/delete') ?>';
        var opts = { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ id: componentId }) };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (result.success) {
            BackendToast.success(result.message || '<?= __('AI 组件已删除') ?>');
            // 刷新组件面板
            if (typeof initComponentPanel === 'function') {
                initComponentPanel();
            }
        } else {
            // 有引用时显示引用的页面列表
            if (result.references && result.references.length > 0) {
                let refHtml = '<div style="text-align:left;max-height:200px;overflow-y:auto;">';
                refHtml += '<p style="margin-bottom:10px;">' + result.message + '</p>';
                refHtml += '<ul style="margin:0;padding-left:20px;">';
                result.references.forEach(function(ref) {
                    const usedInText = ref.used_in.map(function(area) {
                        const areaNames = { header: '<?= __('页头') ?>', footer: '<?= __('页脚') ?>', content: '<?= __('内容') ?>' };
                        return areaNames[area] || area;
                    }).join('、');
                    refHtml += '<li><strong>' + _escHtml(ref.page_name) + '</strong>';
                    refHtml += ' <span style="color:var(--backend-color-text-muted);">(' + usedInText + ')</span>';
                    if (ref.page_handle) {
                        refHtml += ' <a href="<?= $this->getBackendUrl('pagebuilder/backend/page/edit') ?>?id=' + ref.page_id + '" target="_blank" style="margin-left:5px;font-size:12px;"><?= __('编辑') ?></a>';
                    }
                    refHtml += '</li>';
                });
                refHtml += '</ul></div>';
                
                BackendToast.warning(refHtml, { duration: 0, html: true });
            } else {
                BackendToast.error(result.message || '<?= __('删除失败') ?>');
            }
        }
    } catch (e) {
        console.error('deleteAiComponent error:', e);
        BackendToast.error('<?= __('删除失败：') ?>' + (e.message || '<?= __('网络错误') ?>'));
    }
}

// 创建 AI 工坊模态框
function _createWorkshopModal() {
    const modalId = 'aiWorkshopModal';
    let modal = document.getElementById(modalId);
    if (!modal) {
        modal = document.createElement('div');
        modal.id = modalId;
        modal.className = 'modal fade ai-workshop-modal';
        modal.tabIndex = -1;
        modal.setAttribute('data-bs-backdrop', 'static');
        modal.innerHTML = `
            <div class="modal-dialog modal-lg modal-dialog-centered" style="max-width: 820px;">
                <div class="modal-content" style="background: var(--backend-color-card-bg, #1e1e1e); color: var(--backend-color-text-primary, #fff);">
                    <div class="modal-header border-0">
                        <h5 class="modal-title"><i class="mdi mdi-auto-fix"></i> <?= __('AI 组件工坊') ?></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body workshop-content"></div>
                </div>
            </div>
        `;
        document.body.appendChild(modal);
    }
    return modal;
}

function _showWorkshopModal(html, onOpen) {
    const modal = _createWorkshopModal();
    modal.querySelector('.workshop-content').innerHTML = html;
    const bsModal = new bootstrap.Modal(modal);
    if (onOpen) {
        modal.addEventListener('shown.bs.modal', function onShown() {
            modal.removeEventListener('shown.bs.modal', onShown);
            onOpen();
        }, { once: true });
    }
    bsModal.show();
    return bsModal;
}

function _closeWorkshopModal() {
    const modal = document.getElementById('aiWorkshopModal');
    if (modal) {
        const bsModal = bootstrap.Modal.getInstance(modal);
        if (bsModal) bsModal.hide();
    }
}

// 对已保存的 AI 组件随时微调：从组件栏点击「微调」打开工坊并进入微调步骤
async function openRefineForSavedComponent(code, styleCode) {
    code = (code || '').trim();
    styleCode = (styleCode || '_ai_generated').trim();
    if (!code) {
        BackendToast.warning('<?= __('组件代码为空') ?>');
        return;
    }
    const url = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/info') ?>?code=' + encodeURIComponent(code) + '&include_preview=1';
    try {
        var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'include', silent: true };
        var resp = await window.Weline.Api.request(url, opts);
        const json = (resp && resp.data) || resp;
        if (!json.success) throw new Error(json.message || '<?= __('加载组件失败') ?>');
        const comp = json.component || {};
        const templateContent = json.template_content || '';
        let previewHtml = '';
        if (comp.preview_html_encoded && comp.preview_html) {
            try { previewHtml = atob(comp.preview_html); } catch (e) { previewHtml = ''; }
        }
        const recoverable = {
            component: {
                code: comp.code || code,
                name: comp.name,
                description: comp.description,
                region: comp.region || comp.category || 'content',
                category: comp.category || comp.region || 'content',
                style_code: comp.style_code || styleCode,
                templateCode: comp.templateCode || styleCode,
                phtml_code: templateContent
            },
            preview: previewHtml,
            validation: { valid: true },
            savedAt: new Date().toISOString()
        };
        _aiWorkshop = { step: 1, params: null, result: null, eventSource: null };
        _showWorkshopModal(_buildWorkshopHtml({}), function() {
            _workshopGoToStep(1);
            loadReferenceComponents(recoverable.component.region || 'content', '');
            _loadAiServiceInfo();
            _loadAgentList();
            _recoverToWorkshop(recoverable);
            setTimeout(function() { _bindWorkshopPreviewButtons(); }, 50);
        });
    } catch (e) {
        BackendToast.error('<?= __('加载失败') ?>: ' + (e.message || String(e)));
    }
}

// 打开AI组件工坊
function openAiGenerateComponent() {
    _aiWorkshop = { step: 1, params: null, result: null, eventSource: null };
    const saved = loadAiGenerationParams();
    const s = saved || {};
    
    // 检查是否有本地保存的未提交组件（可直接恢复到预览阶段）
    const recoverable = loadGeneratedComponentFromLocal();
    
    _showWorkshopModal(_buildWorkshopHtml(s), function() {
        loadReferenceComponents(s.region || 'content', s.referenceComponent || '');
        _loadAiServiceInfo();
        _loadAgentList();
        if (recoverable && recoverable.component) {
            _recoverToWorkshop(recoverable);
            BackendToast.success('<?= __('已恢复未保存的组件到预览') ?>');
        } else {
            _workshopGoToStep(1);
        }
        setTimeout(function() { _bindWorkshopPreviewButtons(); }, 50);
    });
}

// 工坊弹窗内「刷新预览」「全屏预览」事件委托
function _bindWorkshopPreviewButtons() {
    let popup = document.getElementById('aiWorkshopModal') || document.querySelector('.ai-workshop-popup');
    if (!popup || popup._aiWorkshopPreviewBound) return;
    popup._aiWorkshopPreviewBound = true;
    popup.addEventListener('click', function(e) {
        const refreshBtn = e.target.closest('[data-ai-action="refresh-preview"]');
        if (refreshBtn) {
            e.preventDefault();
            e.stopPropagation();
            var fn = window._refreshPreviewFromDraft || (typeof _refreshPreviewFromDraft !== 'undefined' ? _refreshPreviewFromDraft : null);
            if (typeof fn === 'function') fn();
            return;
        }
        const fullscreenBtn = e.target.closest('[data-ai-action="fullscreen-preview"]');
        if (fullscreenBtn) {
            e.preventDefault();
            e.stopPropagation();
            var fn = window.openFullscreenPreview || (typeof openFullscreenPreview !== 'undefined' ? openFullscreenPreview : null);
            if (typeof fn === 'function') fn();
            return;
        }
    });
}

// 在工坊内显示恢复横幅（步骤1顶部）
function _showRecoveryBanner(recoverable) {
    const bar = document.getElementById('ai-ws-recovery-bar');
    if (!bar) return;
    const comp = recoverable.component || {};
    const timeStr = recoverable.savedAt ? new Date(recoverable.savedAt).toLocaleString() : '';
    bar.style.display = '';
    bar.querySelector('.ai-recovery-name').textContent = comp.name || comp.component_code || '<?= __('未命名组件') ?>';
    bar.querySelector('.ai-recovery-desc').textContent = comp.description || '';
    bar.querySelector('.ai-recovery-time').textContent = timeStr;
    bar.querySelector('.ai-recovery-btn').onclick = function() {
        _recoverToWorkshop(recoverable);
    };
    bar.querySelector('.ai-recovery-dismiss').onclick = function() {
        bar.style.display = 'none';
        clearGeneratedComponentFromLocal();
    };
}

// 恢复组件数据到工坊，并停留在步骤 3（预览）
function _recoverToWorkshop(recoverable) {
    const comp = recoverable.component || {};
    const validation = recoverable.validation || { valid: true };
    const preview = recoverable.preview || '';
    const code = comp.phtml_code || recoverable.templateContent || '';
    
    // 构建 workshop result 对象（与 _workshopShowResult 期望的格式一致）
    const wsResult = {
        component: comp,
        validation: validation,
        preview: { html: preview },
    };
    _aiWorkshop.result = wsResult;
    
    // 同步到全局变量供微调/保存使用
    window.currentGeneratedComponent = {
        component: comp,
        templateContent: code,
        validation: validation,
        preview: preview,
        finalPrompt: recoverable.finalPrompt || ''
    };
    
    // 恢复参数（如果有）
    if (recoverable.params) {
        _aiWorkshop.params = recoverable.params;
    }
    
    // 隐藏恢复横幅
    const bar = document.getElementById('ai-ws-recovery-bar');
    if (bar) bar.style.display = 'none';
    
    // 调用 _workshopShowResult 填充步骤3的UI（其内部已 _workshopGoToStep(3)，不再切到步骤4）
    _workshopShowResult(wsResult);
}

