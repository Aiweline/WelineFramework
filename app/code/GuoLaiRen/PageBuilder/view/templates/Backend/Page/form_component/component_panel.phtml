<script>
// 组件数据缓存
let componentData = null;
let currentStyleCode = '<?= htmlspecialchars($styleCode) ?>';
let currentEditingComponent = null;

// 区域配置（默认配置，可被 API 返回的数据覆盖）
const defaultRegionConfig = {
    header: {
        label: '<?= __('头部组件 (Header)') ?>',
        icon: 'mdi-page-layout-header',
        multiple: false,
        hint: '<?= __('Header 区域只能放置一个组件') ?>'
    },
    sidebar: {
        label: '<?= __('侧边栏组件 (Sidebar)') ?>',
        icon: 'mdi-page-layout-sidebar-left',
        multiple: true,
        hint: '<?= __('Sidebar 区域可放置多个组件') ?>'
    },
    content: {
        label: '<?= __('内容组件 (Content)') ?>',
        icon: 'mdi-text-box-multiple',
        multiple: true,
        hint: '<?= __('Content 区域可放置多个组件，按顺序排列') ?>'
    },
    hero: {
        label: '<?= __('Hero 区域 (Hero)') ?>',
        icon: 'mdi-image-area',
        multiple: false,
        hint: '<?= __('Hero 区域通常只放置一个大型横幅组件') ?>'
    },
    cta: {
        label: '<?= __('行动号召区域 (CTA)') ?>',
        icon: 'mdi-call-made',
        multiple: true,
        hint: '<?= __('CTA 区域用于放置号召行动的组件') ?>'
    },
    footer: {
        label: '<?= __('底部组件 (Footer)') ?>',
        icon: 'mdi-page-layout-footer',
        multiple: false,
        hint: '<?= __('Footer 区域只能放置一个组件') ?>'
    }
};

// 当前布局的区域配置（初始化后由 API 返回的数据更新）
let regionConfig = { ...defaultRegionConfig };
// 当前布局的区域顺序（初始化后由 API 返回的数据更新）
let regionOrder = ['header', 'content', 'footer'];

// 安全解析 JSON（处理 BOM、JSON 后有多余输出如 PHP 警告等；支持 API 已解析的对象）
function safeJsonParse(responseText) {
    if (responseText == null) return null;
    if (typeof responseText === 'object') return responseText;
    const text = String(responseText).replace(/^\uFEFF/, '');
    try {
        return JSON.parse(text);
    } catch (err) {
        // 若错误提示 "after JSON at position N"，只取前 N 个字符再解析（去掉尾部多余输出，如 PHP Notice）
        const posMatch = /(?:at position|position) (\d+)/i.exec(err && err.message ? err.message : '');
        if (posMatch) {
            const pos = parseInt(posMatch[1], 10);
            if (pos > 0) {
                for (let offset = 0; offset <= 3; offset++) {
                    const cut = Math.max(0, pos - offset);
                    const slice = text.substring(0, cut).trimEnd();
                    if (!slice) continue;
                    try {
                        const out = JSON.parse(slice);
                        if (typeof console !== 'undefined' && console.warn) {
                            console.warn('[组件面板] JSON 尾部有多余内容，已截取前 ' + cut + ' 字符解析成功');
                        }
                        return out;
                    } catch (_) {}
                }
            }
        }
        // 否则用括号匹配提取第一个完整 JSON 对象（同时跟踪 {} 与 []，避免尾部垃圾干扰）
        const firstBrace = text.indexOf('{');
        if (firstBrace === -1) throw err;
        let depth = 0;
        let inString = false;
        let escape = false;
        let end = -1;
        for (let i = firstBrace; i < text.length; i++) {
            const c = text[i];
            if (escape) { escape = false; continue; }
            if (inString) {
                if (c === '\\') escape = true;
                else if (c === '"') inString = false;
                continue;
            }
            if (c === '"') { inString = true; continue; }
            if (c === '{' || c === '[') depth++;
            else if (c === '}' || c === ']') {
                depth--;
                if (depth === 0) { end = i; break; }
            }
        }
        if (end !== -1) {
            try {
                return JSON.parse(text.slice(firstBrace, end + 1));
            } catch (_) {}
        }
        throw err;
    }
}

// 全局：安全解析 SSE 返回的 JSON（Agent/微调/非 Agent 流共用）
function safeParseJson(str) {
    if (!str) return null;
    try { return JSON.parse(str); } catch (e) { return null; }
}

// 全局：流结束守卫，统一「结束标记 + eventSource 置空」，避免重复结束与重复关闭
function createStreamFinishGuard() {
    let isFinished = false;
    return {
        finish(ok, err) {
            if (isFinished) return null;
            isFinished = true;
            _aiWorkshop.eventSource = null;
            return { ok, err };
        },
        isFinished() { return isFinished; }
    };
}

// 初始化组件面板
async function initComponentPanel() {
    const apiUrl = '<?= $componentsApiUrl ?>';
    console.log('[组件面板] 开始加载组件，API URL:', apiUrl);
    
    try {
        var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' }, silent: true };
        var res = await window.Weline.Api.request(apiUrl, opts);
        var responseText = (res && res.data) !== undefined ? res.data : (typeof res === 'string' ? res : '');
        var responseStr = typeof responseText === 'string' ? responseText : JSON.stringify(responseText);
        console.log('[组件面板] 响应长度:', responseStr.length, '字符');
        
        let result;
        try {
            result = safeJsonParse(responseText);
        } catch (parseError) {
            console.error('[组件面板] JSON解析失败:', parseError);
            console.error('[组件面板] 响应内容前500字符:', responseStr.substring(0, 500));
            showComponentError('JSON解析失败: ' + parseError.message);
            return;
        }
        
        console.log('[组件面板] 解析结果 success:', result.success);
        
        if (result.success) {
            componentData = result.data;
            console.log('[组件面板] 组件数据已加载');
            
            // 从 API 返回的 by_region 数据更新区域配置
            if (componentData.by_region) {
                // 获取区域顺序（API 返回的区域数据的键）
                regionOrder = Object.keys(componentData.by_region);
                console.log('[组件面板] 区域顺序:', regionOrder);
                
                // 更新区域配置
                Object.entries(componentData.by_region).forEach(([regionCode, regionData]) => {
                    if (!regionConfig[regionCode]) {
                        // 如果是未知区域，使用默认配置
                        regionConfig[regionCode] = {
                            label: regionData.label || regionCode,
                            icon: 'mdi-puzzle',
                            multiple: true,
                            hint: '<?= __('可放置组件') ?>'
                        };
                    } else if (regionData.label) {
                        // 更新已知区域的标签
                        regionConfig[regionCode].label = regionData.label;
                    }
                });
            }
            
            renderComponentPanelByRegion();
            console.log('[组件面板] 组件面板渲染完成');
        } else {
            console.error('[组件面板] API 返回失败:', result.message);
            showComponentError(result.message || '<?= __('加载组件失败') ?>');
        }
    } catch (error) {
        console.error('[组件面板] 加载组件异常:', error);
        console.error('[组件面板] 错误堆栈:', error.stack);
        showComponentError('<?= __('加载组件失败') ?>: ' + error.message);
    }
}

// 按区域渲染组件面板
function renderComponentPanelByRegion() {
    const container = document.getElementById('componentPanelBody');
    let html = '';
    
    // 使用动态区域列表（如果 API 返回了 by_region 数据，则使用 regionOrder）
    const regionsToRender = componentData.by_region ? regionOrder : ['header', 'content', 'footer'];
    
    regionsToRender.forEach(region => {
        const config = regionConfig[region] || defaultRegionConfig[region] || {
            label: region,
            icon: 'mdi-puzzle',
            multiple: true,
            hint: '<?= __('可放置组件') ?>'
        };
        const components = getComponentsForRegion(region);
        
        if (components.length === 0) return;
        
        html += `
            <div class="component-region" id="region_${region}" data-region="${region}">
                <div class="component-region-header" onclick="toggleRegion('${region}')">
                    <span>
                        <i class="mdi ${config.icon} region-icon"></i>
                        ${config.label}
                    </span>
                    <span class="region-info">
                        <span class="badge ${config.multiple ? 'badge-info' : 'badge-warning'}">
                            ${config.multiple ? '<?= __('可多个') ?>' : '<?= __('唯一') ?>'}
                        </span>
                        <span class="badge bg-secondary">${components.length}</span>
                        <i class="mdi mdi-chevron-down chevron"></i>
                    </span>
                </div>
                <div class="component-region-body">
                    ${renderComponentsByTemplate(components, region)}
                    <div class="drop-zone-hint">
                        <i class="mdi mdi-information-outline"></i> ${config.hint}
                    </div>
                </div>
            </div>
        `;
    });
    
    if (!html) {
        html = `
            <div class="component-empty">
                <i class="mdi mdi-puzzle-outline"></i>
                <p><?= __('暂无可用组件') ?></p>
            </div>
        `;
    }
    
    container.innerHTML = html;
    initDragAndDrop();
}

// 获取指定区域的组件
function getComponentsForRegion(region) {
    if (!componentData) return [];
    
    // 如果 API 返回了 by_region 数据，优先使用它
    if (componentData.by_region && componentData.by_region[region]) {
        const regionData = componentData.by_region[region];
        if (regionData.components && regionData.components.length > 0) {
            return regionData.components.map(comp => ({
                ...comp,
                isOwn: comp.isOwn || false,
                isShared: comp.isShared || false,
                templateCode: comp.templateCode || currentStyleCode,
                templateName: comp.templateName || currentStyleCode
            }));
        }
    }
    
    // 回退到传统方式
    const components = [];
    const categoryMap = {
        header: ['header'],
        sidebar: ['sidebar', 'widget'],
        content: ['content', 'widget'],
        hero: ['hero', 'banner', 'content'],
        cta: ['cta', 'content'],
        footer: ['footer']
    };
    const allowedCategories = categoryMap[region] || [region];
    
    // 收集推荐组件（当前模板）
    if (componentData.recommended && componentData.recommended.components) {
        componentData.recommended.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isOwn: true,
                    templateCode: currentStyleCode,
                    templateName: componentData.recommended.label || currentStyleCode
                });
            }
        });
    }
    
    // 收集共享组件
    if (componentData.shared && componentData.shared.components) {
        componentData.shared.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isShared: true,
                    templateCode: '_shared',
                    templateName: '<?= __('通用组件') ?>'
                });
            }
        });
    }
    
    // 收集其他模板的组件
    if (componentData.other_templates) {
        Object.entries(componentData.other_templates).forEach(([templateCode, templateData]) => {
            if (templateData.components) {
                templateData.components.forEach(comp => {
                    if (allowedCategories.includes(comp.category) || comp.region === region) {
                        components.push({
                            ...comp,
                            isOther: true,
                            templateCode: templateCode,
                            templateName: templateData.label || templateCode
                        });
                    }
                });
            }
        });
    }
    
    return components;
}

// 按模板分组渲染组件
function renderComponentsByTemplate(components, region) {
    // 按模板分组
    const groups = {};
    components.forEach(comp => {
        const key = comp.isOwn ? 'own' : (comp.isShared ? 'shared' : comp.templateCode);
        if (!groups[key]) {
            groups[key] = {
                label: comp.isOwn ? '<?= __('本模板（推荐）') ?>' : (comp.isShared ? '<?= __('通用组件') ?>' : comp.templateName),
                isOwn: comp.isOwn,
                isShared: comp.isShared,
                components: []
            };
        }
        groups[key].components.push(comp);
    });
    
    let html = '';
    
    // 优先显示本模板组件
    if (groups.own) {
        html += renderTemplateGroup(groups.own, region);
        delete groups.own;
    }
    
    // 然后显示共享组件
    if (groups.shared) {
        html += renderTemplateGroup(groups.shared, region);
        delete groups.shared;
    }
    
    // 最后显示其他模板组件
    Object.values(groups).forEach(group => {
        html += renderTemplateGroup(group, region);
    });
    
    return html;
}

// 渲染模板分组
function renderTemplateGroup(group, region) {
    const starHtml = group.isOwn ? '<span class="star">★</span>' : '';
    
    return `
        <div class="component-template-group">
            <div class="component-template-group-header">
                ${starHtml} ${group.label}
            </div>
            <div class="component-template-group-cards">
                ${group.components.map(comp => renderComponentCard(comp, region)).join('')}
            </div>
        </div>
    `;
}

// 解码 Base64 编码的预览HTML
function decodePreviewHtml(component) {
    if (!component.preview_html || !component.preview_html.trim()) {
        return '';
    }
    
    // 如果标记为已编码，则进行Base64解码
    if (component.preview_html_encoded) {
        try {
            return atob(component.preview_html);
        } catch (e) {
            console.error('[组件面板] Base64解码失败:', e, component.code);
            return '';
        }
    }
    
    // 未编码则直接返回
    return component.preview_html;
}

// 渲染组件卡片
function renderComponentCard(component, region) {
    // 优先使用预览HTML，其次使用缩略图，然后使用组件自定义图标，最后使用区域默认图标
    let thumbHtml = '';
    
    // 解码预览HTML（如果已编码）
    const decodedPreviewHtml = decodePreviewHtml(component);
    
    if (decodedPreviewHtml && decodedPreviewHtml.trim()) {
        // 直接渲染预览 HTML（带样式隔离的容器）
        // 使用 iframe 来完全隔离样式
        const previewHtml = decodedPreviewHtml.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        thumbHtml = `<div class="component-preview-container">
            <iframe 
                srcdoc="<!DOCTYPE html><html><head><meta charset='utf-8'><style>*{box-sizing:border-box;}body{margin:0;padding:0;overflow:hidden;background:#fff;min-height:100vh;}</style></head><body><script>var component=document.body.querySelector(&quot;[id]&quot;)||document.body;<\/script>${previewHtml}</body></html>"
                frameborder="0"
                scrolling="no">
            </iframe>
        </div>`;
    } else if (component.thumbnail_url) {
        thumbHtml = `<img src="${component.thumbnail_url}" alt="${component.name}" onerror="this.parentNode.innerHTML='<i class=\\'mdi mdi-puzzle\\'></i>'">`;
    } else if (component.icon) {
        // 支持 Bootstrap Icons (bi-*) 和 MDI (mdi-*)
        const iconClass = component.icon.startsWith('bi-') ? `bi ${component.icon}` : 
                         component.icon.startsWith('mdi-') ? `mdi ${component.icon}` : 
                         `mdi mdi-${component.icon}`;
        thumbHtml = `<i class="${iconClass}"></i>`;
    } else {
        thumbHtml = `<i class="mdi mdi-${getRegionIcon(region)}"></i>`;
    }
    
    const recommendedClass = component.isOwn ? 'recommended' : '';
    const baseTagHtml = component.isOwn 
        ? '<span class="component-tag own"><?= __('推荐') ?></span>'
        : (component.isShared 
            ? '<span class="component-tag shared"><?= __('通用') ?></span>'
            : '<span class="component-tag other"><?= __('兼容') ?></span>');
    const tagHtml = baseTagHtml + ((!component.isOwn && !component.isShared && component.is_ai_generated)
        ? '<span class="component-tag ai-cyan">AI</span>'
        : '');
    const aiBadgeHtml = component.is_ai_generated
        ? '<div class="component-ai-badge"><span class="component-tag ai">AI</span><span class="component-tag ai-secondary"><?= __('生成') ?></span></div>'
        : '';
    const codeEsc = _escHtml(component.code || '');
    const styleEsc = _escHtml(component.style_code || component.templateCode || '_ai_generated');
    const nameEsc = _escHtml(component.name || '');
    const componentId = component.id || component.component_id || 0;
    const refineBtnHtml = component.is_ai_generated
        ? `<button type="button" class="component-refine-btn" onclick="event.stopPropagation();event.preventDefault();openRefineForSavedComponent('${codeEsc}','${styleEsc}')" title="<?= __('微调') ?>"><i class="mdi mdi-tune"></i></button>`
        : '';
    const deleteBtnHtml = component.is_ai_generated
        ? `<button type="button" class="component-delete-btn" onclick="event.stopPropagation();event.preventDefault();deleteAiComponent(${componentId},'${nameEsc}')" title="<?= __('删除') ?>"><i class="mdi mdi-delete"></i></button>`
        : '';

    // 来源标识
    const sourceLabel = component.isOwn ? '' : (component.isShared ? '<?= __('通用') ?>' : component.templateName);

    return `
        <div class="component-card ${recommendedClass}"
             draggable="true"
             data-component-code="${codeEsc}"
             data-component-name="${nameEsc}"
             data-component-region="${region}"
             data-component-template="${styleEsc}"
             data-component-is-own="${component.isOwn ? 'true' : 'false'}"
             data-component-id="${componentId}"
             ondragstart="handleDragStart(event)"
             ondragend="handleDragEnd(event)"
