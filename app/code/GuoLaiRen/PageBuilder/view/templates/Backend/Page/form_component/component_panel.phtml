// LocalStorage 键名
const AI_COMPONENT_PARAMS_KEY = 'pb_ai_component_params';
const AI_REFINE_HISTORY_KEY = 'pb_ai_refine_history';
const AI_GENERATED_COMPONENT_KEY = 'pb_ai_generated_component';

// 保存AI生成参数到localStorage
function saveAiGenerationParams(params) {
    try {
        const data = {
            ...params,
            savedAt: new Date().toISOString(),
            styleCode: currentStyleCode
        };
        localStorage.setItem(AI_COMPONENT_PARAMS_KEY, JSON.stringify(data));
    } catch (e) {
        console.warn('无法保存AI参数到localStorage:', e);
    }
}

// 从localStorage加载AI生成参数
function loadAiGenerationParams() {
    try {
        const saved = localStorage.getItem(AI_COMPONENT_PARAMS_KEY);
        if (saved) {
            return JSON.parse(saved);
        }
    } catch (e) {
        console.warn('无法从localStorage加载AI参数:', e);
    }
    return null;
}

// 保存微调历史到localStorage
function saveRefineHistory(adjustmentPrompt) {
    try {
        let history = [];
        const saved = localStorage.getItem(AI_REFINE_HISTORY_KEY);
        if (saved) {
            history = JSON.parse(saved);
        }
        // 添加到历史开头，最多保留10条
        history.unshift({
            prompt: adjustmentPrompt,
            savedAt: new Date().toISOString()
        });
        history = history.slice(0, 10);
        localStorage.setItem(AI_REFINE_HISTORY_KEY, JSON.stringify(history));
    } catch (e) {
        console.warn('无法保存微调历史:', e);
    }
}

// 加载微调历史
function loadRefineHistory() {
    try {
        const saved = localStorage.getItem(AI_REFINE_HISTORY_KEY);
        if (saved) {
            return JSON.parse(saved);
        }
    } catch (e) {
        console.warn('无法加载微调历史:', e);
    }
    return [];
}

// 保存生成的组件到localStorage（用于页面刷新后恢复）
function saveGeneratedComponentToLocal(componentData) {
    try {
        const data = {
            ...componentData,
            params: _aiWorkshop?.params || null,
            savedAt: new Date().toISOString(),
            styleCode: currentStyleCode
        };
        localStorage.setItem(AI_GENERATED_COMPONENT_KEY, JSON.stringify(data));
    } catch (e) {
        console.warn('无法保存生成组件到localStorage:', e);
    }
}

// 从localStorage加载生成的组件
function loadGeneratedComponentFromLocal() {
    try {
        const saved = localStorage.getItem(AI_GENERATED_COMPONENT_KEY);
        if (saved) {
            const data = JSON.parse(saved);
            // 检查是否在24小时内
            const savedTime = new Date(data.savedAt);
            const now = new Date();
            if ((now - savedTime) < 24 * 60 * 60 * 1000) {
                return data;
            }
            // 超过24小时，清除
            localStorage.removeItem(AI_GENERATED_COMPONENT_KEY);
        }
    } catch (e) {
        console.warn('无法从localStorage加载生成组件:', e);
    }
    return null;
}

// 清除保存的生成组件
function clearGeneratedComponentFromLocal() {
    try {
        localStorage.removeItem(AI_GENERATED_COMPONENT_KEY);
    } catch (e) {
        console.warn('无法清除生成组件:', e);
    }
}

// 检查是否有未保存的AI组件，直接打开工坊并恢复到微调阶段
function checkUnsavedAiComponent() {
    const savedComponent = loadGeneratedComponentFromLocal();
    if (savedComponent && savedComponent.component) {
        // 直接打开 AI 工坊，恢复逻辑在 openAiGenerateComponent 的 didOpen 中处理
        openAiGenerateComponent();
    }
}

