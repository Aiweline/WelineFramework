<script>
// 组件数据缓存
let componentData = null;
let currentStyleCode = '<?= htmlspecialchars($styleCode) ?>';
let currentEditingComponent = null;

// 区域配置
const regionConfig = {
    header: {
        label: '<?= __('头部组件 (Header)') ?>',
        icon: 'mdi-page-layout-header',
        multiple: false,
        hint: '<?= __('Header 区域只能放置一个组件') ?>'
    },
    content: {
        label: '<?= __('内容组件 (Content)') ?>',
        icon: 'mdi-text-box-multiple',
        multiple: true,
        hint: '<?= __('Content 区域可放置多个组件，按顺序排列') ?>'
    },
    footer: {
        label: '<?= __('底部组件 (Footer)') ?>',
        icon: 'mdi-page-layout-footer',
        multiple: false,
        hint: '<?= __('Footer 区域只能放置一个组件') ?>'
    }
};

// 初始化组件面板
async function initComponentPanel() {
    try {
        const response = await fetch('<?= $componentsApiUrl ?>', {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        const result = await response.json();
        
        if (result.success) {
            componentData = result.data;
            renderComponentPanelByRegion();
        } else {
            showComponentError(result.message || '<?= __('加载组件失败') ?>');
        }
    } catch (error) {
        console.error('加载组件失败:', error);
        showComponentError('<?= __('加载组件失败') ?>');
    }
}

// 按区域渲染组件面板
function renderComponentPanelByRegion() {
    const container = document.getElementById('componentPanelBody');
    let html = '';
    
    // 遍历三个区域
    ['header', 'content', 'footer'].forEach(region => {
        const config = regionConfig[region];
        const components = getComponentsForRegion(region);
        
        if (components.length === 0) return;
        
        html += `
            <div class="component-region" id="region_${region}" data-region="${region}">
                <div class="component-region-header" onclick="toggleRegion('${region}')">
                    <span>
                        <i class="mdi ${config.icon} region-icon"></i>
                        ${config.label}
                    </span>
                    <span class="region-info">
                        <span class="badge ${config.multiple ? 'badge-info' : 'badge-warning'}">
                            ${config.multiple ? '<?= __('可多个') ?>' : '<?= __('唯一') ?>'}
                        </span>
                        <span class="badge bg-secondary">${components.length}</span>
                        <i class="mdi mdi-chevron-down chevron"></i>
                    </span>
                </div>
                <div class="component-region-body">
                    ${renderComponentsByTemplate(components, region)}
                    <div class="drop-zone-hint">
                        <i class="mdi mdi-information-outline"></i> ${config.hint}
                    </div>
                </div>
            </div>
        `;
    });
    
    if (!html) {
        html = `
            <div class="component-empty">
                <i class="mdi mdi-puzzle-outline"></i>
                <p><?= __('暂无可用组件') ?></p>
            </div>
        `;
    }
    
    container.innerHTML = html;
    initDragAndDrop();
}

// 获取指定区域的组件
function getComponentsForRegion(region) {
    if (!componentData) return [];
    
    const components = [];
    const categoryMap = {
        header: ['header'],
        content: ['content', 'widget'],
        footer: ['footer']
    };
    const allowedCategories = categoryMap[region] || [];
    
    // 收集推荐组件（当前模板）
    if (componentData.recommended && componentData.recommended.components) {
        componentData.recommended.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isOwn: true,
                    templateCode: currentStyleCode,
                    templateName: componentData.recommended.label || currentStyleCode
                });
            }
        });
    }
    
    // 收集共享组件
    if (componentData.shared && componentData.shared.components) {
        componentData.shared.components.forEach(comp => {
            if (allowedCategories.includes(comp.category) || comp.region === region) {
                components.push({
                    ...comp,
                    isShared: true,
                    templateCode: '_shared',
                    templateName: '<?= __('通用组件') ?>'
                });
            }
        });
    }
    
    // 收集其他模板的组件
    if (componentData.other_templates) {
        Object.entries(componentData.other_templates).forEach(([templateCode, templateData]) => {
            if (templateData.components) {
                templateData.components.forEach(comp => {
                    if (allowedCategories.includes(comp.category) || comp.region === region) {
                        components.push({
                            ...comp,
                            isOther: true,
                            templateCode: templateCode,
                            templateName: templateData.label || templateCode
                        });
                    }
                });
            }
        });
    }
    
    return components;
}

// 按模板分组渲染组件
function renderComponentsByTemplate(components, region) {
    // 按模板分组
    const groups = {};
    components.forEach(comp => {
        const key = comp.isOwn ? 'own' : (comp.isShared ? 'shared' : comp.templateCode);
        if (!groups[key]) {
            groups[key] = {
                label: comp.isOwn ? '<?= __('本模板（推荐）') ?>' : (comp.isShared ? '<?= __('通用组件') ?>' : comp.templateName),
                isOwn: comp.isOwn,
                isShared: comp.isShared,
                components: []
            };
        }
        groups[key].components.push(comp);
    });
    
    let html = '';
    
    // 优先显示本模板组件
    if (groups.own) {
        html += renderTemplateGroup(groups.own, region);
        delete groups.own;
    }
    
    // 然后显示共享组件
    if (groups.shared) {
        html += renderTemplateGroup(groups.shared, region);
        delete groups.shared;
    }
    
    // 最后显示其他模板组件
    Object.values(groups).forEach(group => {
        html += renderTemplateGroup(group, region);
    });
    
    return html;
}

// 渲染模板分组
function renderTemplateGroup(group, region) {
    const starHtml = group.isOwn ? '<span class="star">★</span>' : '';
    
    return `
        <div class="component-template-group">
            <div class="component-template-group-header">
                ${starHtml} ${group.label}
            </div>
            <div class="component-template-group-cards">
                ${group.components.map(comp => renderComponentCard(comp, region)).join('')}
            </div>
        </div>
    `;
}

// 渲染组件卡片
function renderComponentCard(component, region) {
    const thumbHtml = component.thumbnail_url 
        ? `<img src="${component.thumbnail_url}" alt="${component.name}" onerror="this.parentNode.innerHTML='<i class=\\'mdi mdi-puzzle\\'></i>'">`
        : `<i class="mdi mdi-${getRegionIcon(region)}"></i>`;
    
    const recommendedClass = component.isOwn ? 'recommended' : '';
    const tagHtml = component.isOwn 
        ? '<span class="component-tag own"><?= __('推荐') ?></span>'
        : (component.isShared 
            ? '<span class="component-tag shared"><?= __('通用') ?></span>'
            : '<span class="component-tag other"><?= __('兼容') ?></span>');
    
    return `
        <div class="component-card ${recommendedClass}" 
             draggable="true"
             data-component-code="${component.code}"
             data-component-name="${component.name}"
             data-component-region="${region}"
             data-component-template="${component.templateCode}"
             data-component-is-own="${component.isOwn ? 'true' : 'false'}"
             ondragstart="handleDragStart(event)"
             ondragend="handleDragEnd(event)"
             ondblclick="previewComponent('${component.code}')">
            <div class="component-card-thumb">
                ${thumbHtml}
            </div>
            <div class="component-card-name" title="${component.name}">${component.name}</div>
            ${!component.isOwn ? `<div class="component-card-template">${component.templateName}</div>` : ''}
            ${tagHtml}
        </div>
    `;
}

// 获取区域图标
function getRegionIcon(region) {
    const icons = {
        header: 'page-layout-header',
        content: 'text-box',
        footer: 'page-layout-footer'
    };
    return icons[region] || 'puzzle';
}

// 显示错误
function showComponentError(message) {
    const container = document.getElementById('componentPanelBody');
    container.innerHTML = `
        <div class="component-empty">
            <i class="mdi mdi-alert-circle-outline text-danger"></i>
            <p>${message}</p>
            <button class="btn btn-sm btn-outline-primary" onclick="initComponentPanel()">
                <?= __('重试') ?>
            </button>
        </div>
    `;
}

// 切换组件面板
function toggleComponentPanel() {
    const panel = document.getElementById('componentPanel');
    panel.classList.toggle('collapsed');
}

// 切换区域
function toggleRegion(regionId) {
    const region = document.getElementById('region_' + regionId);
    region.classList.toggle('collapsed');
}

// 搜索组件
function filterComponents(keyword) {
    keyword = keyword.toLowerCase().trim();
    
    document.querySelectorAll('.component-card').forEach(card => {
        const name = card.getAttribute('data-component-name').toLowerCase();
        const code = card.getAttribute('data-component-code').toLowerCase();
        
        if (!keyword || name.includes(keyword) || code.includes(keyword)) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });
    
    // 显示/隐藏空的分组
    document.querySelectorAll('.component-template-group').forEach(group => {
        const visibleCards = group.querySelectorAll('.component-card:not([style*="display: none"])');
        group.style.display = visibleCards.length > 0 ? '' : 'none';
    });
}

// 拖拽相关
function initDragAndDrop() {
    // 在预览区域设置放置监听
    const previewFrame = document.getElementById('previewFrame');
    if (previewFrame && previewFrame.contentWindow) {
        setupDropZones(previewFrame.contentWindow.document);
    }
}

function handleDragStart(event) {
    const card = event.target.closest('.component-card');
    card.classList.add('dragging');
    
    const componentData = {
        code: card.getAttribute('data-component-code'),
        name: card.getAttribute('data-component-name'),
        region: card.getAttribute('data-component-region'),
        template: card.getAttribute('data-component-template'),
        isOwn: card.getAttribute('data-component-is-own') === 'true'
    };
    
    event.dataTransfer.setData('text/plain', JSON.stringify(componentData));
    event.dataTransfer.effectAllowed = 'copy';
    
    // 高亮对应的放置区域
    highlightDropZones(componentData.region);
}

function handleDragEnd(event) {
    const card = event.target.closest('.component-card');
    card.classList.remove('dragging');
    unhighlightDropZones();
}

function highlightDropZones(region) {
    // 在预览iframe中高亮 - 使用新的 pbSlots 接口
    const previewFrame = document.getElementById('previewIframe');
    if (previewFrame && previewFrame.contentWindow) {
        try {
            // 优先使用 pbSlots 接口
            if (previewFrame.contentWindow.pbSlots && previewFrame.contentWindow.pbSlots.highlight) {
                previewFrame.contentWindow.pbSlots.highlight(region);
            } else {
                // 回退到直接操作 DOM
                const doc = previewFrame.contentWindow.document;
                doc.querySelectorAll('.pb-slot[data-region="' + region + '"]').forEach(zone => {
                    zone.classList.add('drag-over');
                });
            }
        } catch (e) {
            console.warn('无法高亮预览区域:', e);
        }
    }
    
    // 通知父页面
    if (typeof window.parent.highlightPreviewRegion === 'function') {
        window.parent.highlightPreviewRegion(region);
    }
}

function unhighlightDropZones() {
    const previewFrame = document.getElementById('previewIframe');
    if (previewFrame && previewFrame.contentWindow) {
        try {
            // 优先使用 pbSlots 接口
            if (previewFrame.contentWindow.pbSlots && previewFrame.contentWindow.pbSlots.unhighlight) {
                previewFrame.contentWindow.pbSlots.unhighlight();
            } else {
                // 回退到直接操作 DOM
                const doc = previewFrame.contentWindow.document;
                doc.querySelectorAll('.pb-slot.drag-over').forEach(zone => {
                    zone.classList.remove('drag-over');
                });
            }
        } catch (e) {
            console.warn('无法取消高亮预览区域:', e);
        }
    }
    
    if (typeof window.parent.unhighlightPreviewRegion === 'function') {
        window.parent.unhighlightPreviewRegion();
    }
}

function setupDropZones(doc) {
    if (!doc) return;
    
    doc.querySelectorAll('[data-region]').forEach(zone => {
        zone.addEventListener('dragover', (e) => {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        
        zone.addEventListener('dragleave', () => {
            zone.classList.remove('drag-over');
        });
        
        zone.addEventListener('drop', (e) => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            
            try {
                const data = JSON.parse(e.dataTransfer.getData('text/plain'));
                const targetRegion = zone.getAttribute('data-region');
                
                // 检查区域匹配
                if (data.region !== targetRegion) {
                    alert('<?= __('此组件只能放置在') ?> ' + regionConfig[data.region].label);
                    return;
                }
                
                // 检查唯一性
                const isMultiple = zone.getAttribute('data-multiple') === 'true';
                if (!isMultiple && zone.querySelectorAll('.tpmst-component-wrapper').length > 0) {
                    if (!confirm('<?= __('此区域只能放置一个组件，是否替换现有组件？') ?>')) {
                        return;
                    }
                }
                
                // 添加组件
                addComponentToRegion(data, targetRegion, zone);
            } catch (err) {
                console.error('Drop error:', err);
            }
        });
    });
}

