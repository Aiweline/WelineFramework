                    .preview-container * {
                        visibility: visible;
                    }
                </style>
            </head>
            <body>
                <div class="preview-container">
                    ${previewHtml || '<div style="padding: 40px; text-align: center; color: #999;">预览内容为空</div>'}
                </div>
                <scr` + `ipt>
                    // 通知父窗口内容高度
                    function reportHeight() {
                        try {
                            const height = Math.max(
                                document.body.scrollHeight,
                                document.documentElement.scrollHeight,
                                document.querySelector('.preview-container')?.scrollHeight || 0
                            );
                            parent.postMessage({ type: 'previewHeight', height: height }, '*');
                        } catch (e) {
                            console.warn('报告高度失败:', e);
                        }
                    }
                    // 多种方式触发高度报告
                    if (document.readyState === 'complete') {
                        reportHeight();
                    } else {
                        window.onload = reportHeight;
                    }
                    setTimeout(reportHeight, 100);
                    setTimeout(reportHeight, 300);
                    setTimeout(reportHeight, 500);
                    setTimeout(reportHeight, 1000);
                    
                    // 监听图片加载完成
                    const images = document.querySelectorAll('img');
                    let loadedCount = 0;
                    images.forEach(img => {
                        if (img.complete) {
                            loadedCount++;
                        } else {
                            img.onload = () => {
                                loadedCount++;
                                if (loadedCount === images.length) {
                                    reportHeight();
                                }
                            };
                            img.onerror = () => {
                                loadedCount++;
                                if (loadedCount === images.length) {
                                    reportHeight();
                                }
                            };
                        }
                    });
                    if (images.length === 0 || loadedCount === images.length) {
                        setTimeout(reportHeight, 200);
                    }
                </scr` + `ipt>
            </body>
            </html>
        `;
        
        // 显示预览弹窗
        if (typeof Swal !== 'undefined') {
            // 监听 iframe 内容高度变化
            let heightHandler = null;
            
            Swal.fire({
                title: (componentInfo.name || componentCode) + ' - <?= __('预览') ?>',
                html: `
                    <div style="display: flex; flex-direction: column; height: 70vh;">
                        <div style="text-align: left; margin-bottom: 12px; flex-shrink: 0;">
                            <span class="badge bg-primary">${componentInfo.region || 'content'}</span>
                            ${componentInfo.category ? `<span class="badge bg-secondary">${componentInfo.category}</span>` : ''}
                        </div>
                        <iframe id="componentPreviewFrame" style="width: 100%; flex: 1; border: none; border-radius: 8px; background: #f5f5f5; display: block;"></iframe>
                        <p style="margin-top: 12px; font-size: 12px; color: #666; text-align: center; flex-shrink: 0;">
                            <?= __('双击组件卡片预览，拖拽到预览区域添加') ?>
                        </p>
                    </div>
                `,
                width: '90%',
                maxWidth: '1200px',
                showConfirmButton: true,
                confirmButtonText: '<?= __('关闭') ?>',
                didOpen: () => {
                    const iframe = document.getElementById('componentPreviewFrame');
                    if (iframe) {
                        // 使用flex布局，iframe自动填充容器，不需要设置固定高度
                        
                        // 监听高度变化（可选，用于内容自适应）
                        heightHandler = (event) => {
                            if (event.data && event.data.type === 'previewHeight') {
                                // flex布局下不需要手动设置高度，iframe会自动填满容器
                            }
                        };
                        window.addEventListener('message', heightHandler);
                        
                        // 写入 iframe 内容
                        try {
                            const doc = iframe.contentDocument || iframe.contentWindow.document;
                            doc.open();
                            doc.write(iframeContent);
                            doc.close();
                        } catch (e) {
                            console.error('写入 iframe 内容失败:', e);
                            iframe.srcdoc = iframeContent;
                        }
                    }
                },
                didClose: () => {
                    // 移除监听器
                    if (heightHandler) {
                        window.removeEventListener('message', heightHandler);
                        heightHandler = null;
                    }
                }
            });
        }
        
    } catch (error) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('预览失败') ?>',
                text: error.message || '<?= __('未知错误') ?>'
