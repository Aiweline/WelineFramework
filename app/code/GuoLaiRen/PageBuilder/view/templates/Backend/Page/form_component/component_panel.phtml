// 预览组件
async function previewComponent(componentCode) {
    
    // 显示加载中
    BackendToast.info('<?= __('加载预览...') ?>');
    
    try {
        // 获取当前样式代码
        const styleSelect = document.getElementById('style');
        const styleCode = styleSelect ? styleSelect.value : (window.currentStyle || 'tpmst');
        
        var url = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/component/preview') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' }, body: 'component_code=' + encodeURIComponent(componentCode) + '&style_code=' + encodeURIComponent(styleCode) };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (!result.success) {
            throw new Error(result.message || '<?= __('预览失败') ?>');
        }
        
        const componentInfo = result.component || {};
        const previewHtml = result.html || '';
        
        // 构建预览弹窗内容（使用 iframe 隔离样式）
        const templateCssUrl = '<?= htmlspecialchars($templateCssBaseUrl) ?>';
        const iframeContent = `
            <!DOCTYPE html>
            <html>
            <head>
                <meta charset="UTF-8">
                <meta name="viewport" content="width=device-width, initial-scale=1.0">
                <title>组件预览</title>
                ${templateCssUrl ? `<link rel="stylesheet" href="${templateCssUrl}" onerror="console.warn('CSS加载失败:', this.href)">` : ''}
                <style>
                    * { margin: 0; padding: 0; box-sizing: border-box; }
                    html, body { 
                        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
                        background: #f5f5f5;
                        min-height: 100%;
                        line-height: 1.5;
                    }
                    body {
                        padding: 0;
                    }
                    .preview-container {
                        background: #fff;
                        overflow: hidden;
                        width: 100%;
                        min-height: 100px;
                    }
                    /* 确保组件内容可见 */
                    .preview-container * {
                        visibility: visible;
                    }
                </style>
            </head>
            <body>
                <div class="preview-container">
                    ${previewHtml || '<div style="padding: 40px; text-align: center; color: #999;">预览内容为空</div>'}
                </div>
                <scr` + `ipt>
                    // 通知父窗口内容高度
                    function reportHeight() {
                        try {
                            const height = Math.max(
                                document.body.scrollHeight,
                                document.documentElement.scrollHeight,
                                document.querySelector('.preview-container')?.scrollHeight || 0
                            );
                            parent.postMessage({ type: 'previewHeight', height: height }, '*');
                        } catch (e) {
                            console.warn('报告高度失败:', e);
                        }
                    }
                    // 多种方式触发高度报告
                    if (document.readyState === 'complete') {
                        reportHeight();
                    } else {
                        window.onload = reportHeight;
                    }
                    setTimeout(reportHeight, 100);
                    setTimeout(reportHeight, 300);
                    setTimeout(reportHeight, 500);
                    setTimeout(reportHeight, 1000);
                    
                    // 监听图片加载完成
                    const images = document.querySelectorAll('img');
                    let loadedCount = 0;
                    images.forEach(img => {
                        if (img.complete) {
                            loadedCount++;
                        } else {
                            img.onload = () => {
                                loadedCount++;
                                if (loadedCount === images.length) {
                                    reportHeight();
                                }
                            };
                            img.onerror = () => {
                                loadedCount++;
                                if (loadedCount === images.length) {
                                    reportHeight();
                                }
                            };
                        }
                    });
                    if (images.length === 0 || loadedCount === images.length) {
                        setTimeout(reportHeight, 200);
                    }
                </scr` + `ipt>
            </body>
            </html>
        `;
        
        // 显示预览弹窗（使用 Bootstrap Modal）
        let heightHandler = null;
        const modalId = 'componentPreviewModal';
        let modal = document.getElementById(modalId);
        
        if (!modal) {
            modal = document.createElement('div');
            modal.id = modalId;
            modal.className = 'modal fade';
            modal.tabIndex = -1;
            modal.innerHTML = `
                <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width: 90%;">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body" style="padding: 0;">
                            <div style="display: flex; flex-direction: column; height: 70vh; padding: 1rem;">
                                <div class="preview-badges" style="text-align: left; margin-bottom: 12px; flex-shrink: 0;"></div>
                                <iframe class="preview-iframe" style="width: 100%; flex: 1; border: none; border-radius: 8px; background: var(--backend-color-bg-secondary, #f5f5f5); display: block;"></iframe>
                                <p style="margin-top: 12px; font-size: 12px; color: var(--backend-color-text-muted, #666); text-align: center; flex-shrink: 0;">
                                    <?= __('双击组件卡片预览，拖拽到预览区域添加') ?>
                                </p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('关闭') ?></button>
                        </div>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
        }
        
        modal.querySelector('.modal-title').textContent = (componentInfo.name || componentCode) + ' - <?= __('预览') ?>';
        modal.querySelector('.preview-badges').innerHTML = `
            <span class="badge bg-primary">${componentInfo.region || 'content'}</span>
            ${componentInfo.category ? `<span class="badge bg-secondary">${componentInfo.category}</span>` : ''}
        `;
        
        const iframe = modal.querySelector('.preview-iframe');
        
        heightHandler = (event) => {
            if (event.data && event.data.type === 'previewHeight') {
                // flex布局下不需要手动设置高度
            }
        };
        window.addEventListener('message', heightHandler);
        
        try {
            const doc = iframe.contentDocument || iframe.contentWindow.document;
            doc.open();
            doc.write(iframeContent);
            doc.close();
        } catch (e) {
            console.error('写入 iframe 内容失败:', e);
            iframe.srcdoc = iframeContent;
        }
        
        const bsModal = new bootstrap.Modal(modal);
        modal.addEventListener('hidden.bs.modal', function onHidden() {
            if (heightHandler) {
                window.removeEventListener('message', heightHandler);
                heightHandler = null;
            }
            modal.removeEventListener('hidden.bs.modal', onHidden);
        }, { once: true });
        bsModal.show();
        
    } catch (error) {
        BackendToast.error('<?= __('预览失败') ?>: ' + (error.message || '<?= __('未知错误') ?>'));
    }
}

