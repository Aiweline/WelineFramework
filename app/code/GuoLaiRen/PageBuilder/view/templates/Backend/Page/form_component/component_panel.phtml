    btn.classList.add('active');
    ['preview','code','colors'].forEach(t => {
        const el = document.getElementById('ai-ws-tab-' + t);
        if (el) el.style.display = t === tab ? '' : 'none';
    });
}

// 开始生成
function _workshopStartGenerate() {
    if (_aiWorkshop.eventSource) {
        _workshopNotify('info', '<?= __('正在生成中，请稍候...') ?>');
        return;
    }
    const collected = _workshopCollectStep1Params();
    if (!collected.ok) {
        _workshopNotify('warning', collected.message || '<?= __('请先完善参数') ?>');
        if (collected.firstInvalid) collected.firstInvalid.focus();
        return;
    }
    _workshopSetStartButtonLoading(true);
    
    // 根据模式确定智能体代码
    let agentCode = '';
    if (_aiGenerateMode === 'agent') {
        const selectedAgent = document.querySelector('.ai-agent-chip.selected');
        agentCode = selectedAgent ? selectedAgent.dataset.agentCode : 'pagebuilder_component';
    }
    
    _aiWorkshop.params = {
        ...collected.params,
        agent_code: agentCode
    };
    saveAiGenerationParams(_aiWorkshop.params);
    
    // 切换到生成步骤
    _workshopGoToStep(2);
    // 重置生成 UI
    const outputEl = document.getElementById('ai-gen-output');
    if (outputEl) outputEl.innerHTML = '';
    const toolsOutputEl = document.getElementById('ai-gen-tools-output');
    if (toolsOutputEl) { toolsOutputEl.textContent = ''; toolsOutputEl.style.opacity = '1'; }
    const toolsCountEl = document.getElementById('ai-gen-tools-count');
    if (toolsCountEl) toolsCountEl.textContent = '';
    // 重置思考过程 tab
    _aiWorkshop._toolCallCount = 0;
    updateStreamStatus('<?= __('准备中...') ?>', 5);
    const spinnerEl = document.getElementById('ai-gen-spinner');
    if (spinnerEl) { spinnerEl.className = 'spinner-grow spinner-grow-sm text-primary me-2'; spinnerEl.innerHTML = ''; }
    const progressEl = document.getElementById('ai-gen-progress');
    if (progressEl) { progressEl.className = 'progress-bar progress-bar-striped progress-bar-animated'; progressEl.style.backgroundColor = ''; }
    
    // 根据模式选择流式接口
    if (_aiGenerateMode === 'agent' && agentCode) {
        generateComponentWithAgent(_aiWorkshop.params);
    } else {
        generateComponentWithAi(_aiWorkshop.params);
    }
}

// 取消生成
function _workshopAbort() {
    if (_aiWorkshop.eventSource) {
        try { _aiWorkshop.eventSource.close(); } catch(e) {}
        _aiWorkshop.eventSource = null;
    }
    _workshopSetStartButtonLoading(false);
    _workshopGoToStep(1);
}

// 重新生成（视为新流程，清除旧未保存数据）
function _workshopRegenerate() {
    clearGeneratedComponentFromLocal();
    if (_aiWorkshop.params) {
        _workshopGoToStep(2);
        const outputEl = document.getElementById('ai-gen-output');
        if (outputEl) outputEl.innerHTML = '';
        updateStreamStatus('<?= __('重新生成中...') ?>', 5);
        generateComponentWithAi(_aiWorkshop.params);
    } else {
        _workshopGoToStep(1);
    }
}

// 保存组件
function _workshopSave() {
    if (_aiWorkshop.result && _aiWorkshop.result.component) {
        saveGeneratedComponent(_aiWorkshop.result.component);
    }
}

// 生成完成后切换到预览步骤
function _workshopShowResult(result) {
    // #region agent log
    try {
        fetch('http://127.0.0.1:7243/ingest/c0ecf822-3bcf-4f3d-a88a-8940482b2d3a', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ location: 'component_panel:_workshopShowResult', message: 'entry', data: { draft_id: result.draft_id ?? null, component_id: result.component_id ?? null, keys: result ? Object.keys(result) : [] }, timestamp: Date.now(), hypothesisId: 'H1' }) }).catch(() => {});
    } catch (e) {}
    // #endregion
    _workshopSetStartButtonLoading(false);
    _aiWorkshop.result = result;
    const component = result.component || {};
    const validation = result.validation || {};
    const preview = result.preview?.html || result.preview || '';
    const code = component.phtml_code || '';
    
    // 验证信息
    const valEl = document.getElementById('ai-ws-validation');
    if (valEl) {
        if (validation.valid !== false) {
            valEl.innerHTML = '<div class="alert alert-success py-1 px-2 small mb-2"><i class="mdi mdi-check-circle"></i> <?= __('校验通过') ?>' +
                (validation.warnings?.length ? ' <span class="text-warning">(' + validation.warnings.length + ' <?= __('警告') ?>)</span>' : '') + '</div>';
        } else {
            valEl.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-2"><i class="mdi mdi-alert"></i> <?= __('校验发现问题') ?>: ' +
                (validation.errors || []).map(e => '<div>• ' + e + '</div>').join('') + '</div>';
        }
    }
    
    // 预览
    const iframe = document.getElementById('ai-ws-preview-iframe');
    if (iframe && preview) {
        iframe.srcdoc = _ensureComponentInPreviewHtml(preview);
    }
    
    // 代码与草稿内容（可复制，便于调试）
    const codeEl = document.getElementById('ai-ws-code-content');
    const templateFileEl = document.getElementById('ai-ws-template-file-content');
    if (codeEl) codeEl.textContent = code;
    if (templateFileEl) templateFileEl.textContent = code || '';
    // 若有 draft_id 或 component_id，从后端拉取草稿内容并填入，避免每次重新生成才能复制
    const draftId = result.draft_id || 0;
    const componentId = result.component_id || 0;
    if ((draftId || componentId) && (codeEl || templateFileEl)) {
        const payload = draftId ? { draft_id: draftId } : { component_id: componentId };
        _fetchDraftContentById(payload).then(function(content) {
            if (!content) return;
            if (codeEl) codeEl.textContent = content;
            if (templateFileEl) templateFileEl.textContent = content;
        });
    }
    
    // 颜色字段
    _buildColorFields(component);
    
    // 切换到预览步骤
    _workshopGoToStep(3);
    
    // 生成完成即写入 localStorage，便于关闭后再打开能恢复到预览（仅当有 component 时写入）
    if (result && result.component) {
        try {
            saveGeneratedComponentToLocal({
                component: result.component,
                preview: result.preview?.html || result.preview || '',
                validation: result.validation || {},
                templateContent: code,
                finalPrompt: result.final_prompt || ''
            });
        } catch (e) {
            console.warn('保存生成组件到本地失败:', e);
        }
    }
}

// 构建颜色微调字段
function _buildColorFields(component) {
    const container = document.getElementById('ai-ws-color-fields');
    if (!container) return;
    
    // 主题色变量映射（配置 key → CSS 变量名）
    const colorMap = [
        { key: 'style.bg_color',     cssVar: '--pb-bg',      label: '<?= __('背景色') ?>',  value: '#ffffff' },
        { key: 'style.text_color',   cssVar: '--pb-text',    label: '<?= __('文字色') ?>',  value: '#333333' },
        { key: 'style.title_color',  cssVar: '--pb-heading', label: '<?= __('标题色') ?>',  value: '#1a1a1a' },
        { key: 'style.accent_color', cssVar: '--pb-accent',  label: '<?= __('强调色') ?>',  value: '#7c3aed' },
    ];
    
    // 从组件 ai_data 或 config_schema 提取实际颜色值
    const aiData = component.ai_data || {};
    colorMap.forEach(c => {
        const val = aiData[c.key] || component[c.key];
        if (val && /^#[0-9a-fA-F]{3,8}$/.test(val)) c.value = val;
    });
    
    container.innerHTML = colorMap.map(c => `
        <div class="ai-ws-color-item">
            <input type="color" value="${c.value}" data-key="${c.key}" data-css-var="${c.cssVar}" onchange="_wsColorChange(this)" oninput="_wsColorChange(this)">
            <span style="color:#ccc;">${c.label}</span>
        </div>
    `).join('') + `
        <div class="ai-ws-color-item mt-2" style="flex-basis:100%;">
            <button class="ai-ws-btn-secondary" onclick="_wsColorReset()" style="padding:4px 12px;font-size:11px;">
                <i class="mdi mdi-restore"></i> <?= __('重置为主题默认') ?>
            </button>
        </div>
    `;
}

// 颜色变更时实时更新预览
function _wsColorChange(input) {
    const cssVar = input.dataset.cssVar;
    const value = input.value;
    const iframe = document.getElementById('ai-ws-preview-iframe');
    if (!iframe || !iframe.contentDocument) return;
    
    // 在 iframe 的 :root 和所有 ai-component 元素上设置变量
    try {
        const doc = iframe.contentDocument;
        doc.documentElement.style.setProperty(cssVar, value);
        // 同时更新所有 ai-component 容器
        doc.querySelectorAll('[id^="ai-"]').forEach(el => {
            el.style.setProperty(cssVar, value);
        });
    } catch(e) { console.warn('无法更新预览颜色:', e); }
}

// 重置所有颜色
function _wsColorReset() {
    const container = document.getElementById('ai-ws-color-fields');
    if (!container) return;
    container.querySelectorAll('input[type=color]').forEach(input => {
        const iframe = document.getElementById('ai-ws-preview-iframe');
        if (iframe && iframe.contentDocument) {
            try {
                iframe.contentDocument.documentElement.style.removeProperty(input.dataset.cssVar);
                iframe.contentDocument.querySelectorAll('[id^="ai-"]').forEach(el => {
                    el.style.removeProperty(input.dataset.cssVar);
                });
            } catch(e) {}
        }
    });
}

// ============================================================
// 智能体（Agent）相关前端逻辑
// ============================================================

// 当前生成模式（'normal' | 'agent'）
let _aiGenerateMode = 'agent';

// 切换生成模式
function _switchAiMode(mode) {
    _aiGenerateMode = mode;
    document.querySelectorAll('.ai-mode-btn').forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
    const agentSel = document.getElementById('ai-agent-selection');
    const modeDesc = document.getElementById('ai-mode-desc');
    if (mode === 'agent') {
        if (agentSel) agentSel.style.display = '';
        if (modeDesc) modeDesc.textContent = '<?= __('智能体会自动调用工具查询参考组件、校验代码规范，生成质量更高') ?>';
    } else {
        if (agentSel) agentSel.style.display = 'none';
        if (modeDesc) modeDesc.textContent = '<?= __('直接调用 AI 模型生成代码，速度更快') ?>';
    }
}

// 加载可用智能体列表
async function _loadAgentList() {
    const container = document.getElementById('ai-agent-list');
    const agentSel = document.getElementById('ai-agent-selection');
    if (!container) return;

    try {
        var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'include', silent: true };
        var resp = await window.Weline.Api.request('<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/agents') ?>', opts);
        const json = (resp && resp.data) || resp;
        if (!json.success || !json.data?.agents?.length) {
            // 没有智能体可用时，自动切换到普通模式
            _switchAiMode('normal');
            // 禁用智能体模式按钮
            const agentBtn = document.querySelector('.ai-mode-btn[data-mode="agent"]');
            if (agentBtn) { agentBtn.disabled = true; agentBtn.style.opacity = '0.4'; agentBtn.style.cursor = 'not-allowed'; agentBtn.title = '<?= __('暂无可用智能体') ?>'; }
            return;
        }

        const agents = json.data.agents;
        container.innerHTML = agents.map(a => `
            <div class="ai-agent-chip${a.code === 'pagebuilder_component' ? ' selected' : ''}"
                 data-agent-code="${_escHtml(a.code)}"
                 onclick="_toggleAgent(this)"
                 title="${_escHtml(a.description)}">
                <i class="mdi mdi-robot-outline agent-icon"></i>
                <span>${_escHtml(a.name)}</span>
                <span class="agent-tools">${a.tools_count || 0} <?= __('工具') ?></span>
            </div>
        `).join('');
        // 默认智能体模式
        _switchAiMode('agent');
    } catch (e) {
        _switchAiMode('normal');
        const agentBtn = document.querySelector('.ai-mode-btn[data-mode="agent"]');
        if (agentBtn) { agentBtn.disabled = true; agentBtn.style.opacity = '0.4'; agentBtn.style.cursor = 'not-allowed'; }
    }
}

// 切换智能体选中状态（单选）
function _toggleAgent(el) {
    const wasSelected = el.classList.contains('selected');
    document.querySelectorAll('.ai-agent-chip').forEach(c => c.classList.remove('selected'));
    if (!wasSelected) el.classList.add('selected');
}

// 智能体模式的流式生成
async function generateComponentWithAgent(params) {
    try {
        updateStreamStatus('<?= __('智能体模式：连接 AI 服务...') ?>', 15);

        // 优先从工坊步骤 1 面板内取表单值（避免多处同名 id 取到空）
        let name = params.name || '';
        let description = params.description || '';
        const step1 = document.getElementById('ai-ws-step1');
        const nameEl = step1 ? step1.querySelector('#aiComponentName') : document.getElementById('aiComponentName');
        const descEl = step1 ? step1.querySelector('#aiComponentDesc') : document.getElementById('aiComponentDesc');
        if (nameEl && (nameEl.value || '').trim()) name = nameEl.value.trim();
        if (descEl && (descEl.value || '').trim()) description = descEl.value.trim();
        if (!name || !description) {
            updateStreamStatus('<?= __('请输入组件名称和描述') ?>', 0);
            throw new Error('<?= __('组件名称和描述不能为空') ?>');
        }
        const streamParams = {
            agent_code: params.agent_code || 'pagebuilder_component',
            style_code: currentStyleCode,
            region: params.region,
            name: name,
            description: description,
            style: params.style,
            fields: params.fields,
            reference_component: params.referenceComponent,
            reference_code: '',
            language: document.documentElement.lang || '<?= $this->request->getUserLanguage() ?>'
        };
        const paramsBase64 = btoa(unescape(encodeURIComponent(JSON.stringify(streamParams))));

        const baseUrl = '<?= $this->getBackendUrl('pagebuilder/backend/ai-generate/agent-component-stream') ?>';
        const streamUrl = baseUrl + '?params=' + encodeURIComponent(paramsBase64)
            + '&name=' + encodeURIComponent(name)
            + '&description=' + encodeURIComponent(description);

        let result = null;

        await new Promise((resolve, reject) => {
            const eventSource = new EventSource(streamUrl);
            _aiWorkshop.eventSource = eventSource;
            const guard = createStreamFinishGuard();
            function finish(ok, err) {
                const r = guard.finish(ok, err);
                if (r) {
                    try { eventSource.close(); } catch(e) {}
                    r.ok ? resolve() : reject(r.err);
                }
            }

            eventSource.onopen = () => updateStreamStatus('<?= __('智能体正在工作...') ?>', 20);

            eventSource.addEventListener('start', e => {
                const d = safeParseJson(e.data);
                if (d) _logLine('▶ ' + (d.message || ''), '#4ade80');
            });

            eventSource.addEventListener('prompt', e => {
                const d = safeParseJson(e.data);
                if (d?.prompt_length) {
                    const lenEl = document.getElementById('ai-gen-prompt-len');
                    if (lenEl) lenEl.textContent = '(' + d.prompt_length + ' <?= __('字符') ?>)';
                    _logLine('▶ <?= __('提示词已构建') ?> (' + d.prompt_length + ' <?= __('字符') ?>)', '#94a3b8');
                }
                // 填充提示词 tab 内容
                if (d?.prompt_content) {
                    const promptEl = document.getElementById('ai-gen-prompt-content');
                    if (promptEl) { promptEl.textContent = d.prompt_content; promptEl.style.opacity = '1'; }
                }
            });

            eventSource.addEventListener('generating', e => {
                updateStreamStatus('<?= __('智能体正在工作...') ?>', 25);
                _logLine('▶ <?= __('智能体正在工作...') ?>', '#94a3b8');
            });

            // 智能体迭代事件
            eventSource.addEventListener('iteration', e => {
                const d = safeParseJson(e.data);
                if (d) {
                    const pct = 25 + Math.min((d.iteration / d.max) * 60, 60);
                    updateStreamStatus('<?= __('第') ?> ' + d.iteration + ' <?= __('轮') ?>', pct);
                    _logLine('━━━ <?= __('第') ?> ' + d.iteration + ' <?= __('轮') ?> ━━━', '#667eea');
                }
            });

            eventSource.addEventListener('tool_call', e => {
                const d = safeParseJson(e.data);
                if (d) {
                    _aiWorkshop._toolCallCount = (_aiWorkshop._toolCallCount || 0) + 1;
                    const countEl = document.getElementById('ai-gen-tools-count');
                    if (countEl) countEl.textContent = '(' + _aiWorkshop._toolCallCount + ')';
                    const toolsEl = document.getElementById('ai-gen-tools-output');
                    if (toolsEl) {
                        toolsEl.innerHTML += '<div class="ai-tool-entry">'
                            + '<span class="tool-name">[Tool] ' + _escHtml(d.name) + '</span>'
                            + '<span class="tool-status pending"> ⏳ <?= __('执行中') ?>...</span>'
                            + '</div>';
                        const toolsTab = document.getElementById('ai-gen-tab-tools');
                        if (toolsTab) toolsTab.scrollTop = toolsTab.scrollHeight;
                    }
                    const argsStr = JSON.stringify(d.arguments || {});
                    _logLine('🔧 ' + d.name + '(' + (argsStr.length > 200 ? argsStr.substring(0, 200) + '...' : argsStr) + ')', '#fbbf24');
                }
            });

            eventSource.addEventListener('tool_result', e => {
                const d = safeParseJson(e.data);
                if (d) {
                    const toolsEl = document.getElementById('ai-gen-tools-output');
                    if (toolsEl) {
                        const pending = toolsEl.querySelector('.tool-status.pending:last-of-type');
                        if (pending) {
                            pending.className = 'tool-status done';
                            pending.textContent = ' ✓ ' + (d.result_size ? (d.result_size + 'B') : '<?= __('完成') ?>');
                        }
                        if (d.result) {
                            toolsEl.innerHTML += '<div class="ai-tool-entry tool-result">' + _escHtml(d.result.substring(0, 300)) + '</div>';
                        }
                        const toolsTab2 = document.getElementById('ai-gen-tab-tools');
                        if (toolsTab2) toolsTab2.scrollTop = toolsTab2.scrollHeight;
                    }
                    _logLine('  ✓ ' + d.name + ' (' + (d.result_size || 0) + 'B)', '#4ade80');
                    // 将工具返回内容也输出到日志（截断显示）
                    if (d.result) {
                        const preview = d.result.length > 300 ? d.result.substring(0, 300) + '...' : d.result;
                        _logLine('    ↳ ' + preview, '#6b7280');
                    }
                }
            });

            // AI 思考/推理过程事件（流式小块，如 DeepSeek reasoning_content）
            eventSource.addEventListener('thinking', e => {
                const d = safeParseJson(e.data);
                if (d?.content) {
                    // AI 已开始返回数据，清除等待状态
                    const w = document.getElementById('ai-wait-status'); if (w) w.remove();
                    updateStreamStatus('<?= __('AI 思考中...') ?>', 35);
                    _appendAiContent(d.content, d.iteration, 'thinking', !!d.streaming);
                }
            });

            // AI 回复内容事件（流式小块，每轮迭代的 content）
            eventSource.addEventListener('ai_response', e => {
                const d = safeParseJson(e.data);
                if (d?.content) {
                    // AI 已开始返回数据，清除等待状态
                    const w = document.getElementById('ai-wait-status'); if (w) w.remove();
                    updateStreamStatus('<?= __('AI 回复中...') ?>', 50);
                    _appendAiContent(d.content, d.iteration, 'response', !!d.streaming);
                }
            });

            // 智能体状态事件（调用 AI、执行工具、准备下一轮等过程通知）
            eventSource.addEventListener('agent_status', e => {
                const d = safeParseJson(e.data);
                if (d?.message) {
                    if (d.status === 'waiting_ai') {
                        // 等待状态：原地更新同一行，避免日志刷屏
                        const el = document.getElementById('ai-gen-output');
                        if (el) {
                            let waitLine = document.getElementById('ai-wait-status');
                            if (!waitLine) {
                                waitLine = document.createElement('div');
                                waitLine.id = 'ai-wait-status';
                                waitLine.style.cssText = 'margin:1px 0;white-space:pre-wrap;color:#fbbf24;';
                                el.appendChild(waitLine);
                            }
                            waitLine.textContent = '⏳ ' + d.message;
                            _scrollLogToBottom();
                        }
                        updateStreamStatus(d.message, 30);
                    } else {
                        // 其他状态事件：移除等待行（AI 已开始响应），追加新日志行
                        const waitLine = document.getElementById('ai-wait-status');
                        if (waitLine) waitLine.remove();
                        _logLine('⚙ ' + d.message, '#94a3b8');
                    }
                }
            });

            // 心跳事件（保持 SSE 连接活跃，无需处理）
            eventSource.addEventListener('heartbeat', e => {});

            // 质量关卡事件（语法检测 + 缺陷检测 + 自动修复）
            eventSource.addEventListener('quality_gate', e => {
                const d = safeParseJson(e.data);
                if (!d) return;
                const phase = d.phase || '';
                const msg = d.message || ('[quality_gate] ' + phase);
                const color = d.valid === false ? '#f87171' : '#94a3b8';
                _logLine('🛡 ' + msg, color);
                if (Array.isArray(d.errors) && d.errors.length) {
                    d.errors.slice(0, 3).forEach(err => _logLine('    ✖ ' + err, '#fca5a5'));
                }
                if (Array.isArray(d.auto_fixes) && d.auto_fixes.length) {
                    _logLine('    🔧 <?= __('自动修复') ?>: ' + d.auto_fixes.length, '#67e8f9');
                }
                if (typeof msg === 'string' && msg) {
                    updateStreamStatus(msg, 55);
                }
            });

            eventSource.addEventListener('chunk', e => {
                const d = safeParseJson(e.data);
                if (d?.content) {
                    updateStreamStatus('<?= __('生成中...') ?>', 70);
                    _logLine('📦 <?= __('最终输出') ?> (' + d.content.length + ' <?= __('字符') ?>)', '#22d3ee');
                    // 显示代码预览（前500字符）
                    const preview = d.content.length > 500 ? d.content.substring(0, 500) + '\n...' : d.content;
                    _logLine(preview, '#94a3b8');
                }
            });

            eventSource.addEventListener('complete', e => {
                const d = safeParseJson(e.data);
                if (d) {
                    result = d;
                    try { fetch('http://127.0.0.1:7243/ingest/c0ecf822-3bcf-4f3d-a88a-8940482b2d3a', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ location: 'component_panel:agent complete', message: 'received', data: { component_id: d.component_id ?? null, keys: Object.keys(d || {}) }, timestamp: Date.now(), hypothesisId: 'H1' }) }).catch(() => {}); } catch (err) {}
                    if (d.success) {
                        _logLine('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', '#667eea');
                        _logLine('✅ ' + (d.message || '<?= __('生成完成') ?>'), '#4ade80');
                        if (d.iterations) _logLine('   <?= __('迭代轮次') ?>: ' + d.iterations, '#94a3b8');
                        if (d.tool_calls_count) _logLine('   <?= __('工具调用') ?>: ' + d.tool_calls_count + ' <?= __('次') ?>', '#94a3b8');
                        if (d.model_code) _logLine('   <?= __('模型') ?>: ' + d.model_code, '#94a3b8');
                    } else {
                        _logLine('[WARN] ' + (d.message || '<?= __('生成失败') ?>'), '#fbbf24');
                        if (d.raw_content) _logLine(d.raw_content.substring(0, 500), '#6b7280');
                    }
                }
                finish(true);
            });

            eventSource.addEventListener('error', e => {
                const d = safeParseJson(e.data);
                if (d?.message) {
                    updateStreamStatus('<?= __('错误') ?>: ' + d.message, 0);
                    _logLine('[ERROR] ' + d.message, '#ff6b6b');
                    finish(false, new Error(d.message));
                }
            });

            eventSource.addEventListener('done', () => finish(true));

            eventSource.onerror = e => {
                if (result && result.success) { finish(true); return; }
                _logLine('[FAILED] <?= __('连接中断或服务器错误') ?>', '#ff6b6b');
                finish(false, new Error('<?= __('连接中断或服务器错误') ?>'));
            };
        });

        // 生成完成
        if (result && result.success && result.component) {
            updateStreamStatus('<?= __('生成完成！') ?>', 100);
            const spinnerEl = document.getElementById('ai-gen-spinner');
            if (spinnerEl) { spinnerEl.className = 'me-2'; spinnerEl.innerHTML = '<i class="mdi mdi-check-circle text-success"></i>'; }

            // 获取后端返回的组件信息
            const comp = result.component;
            const compCode = result.component_code || '';
            const compStyleCode = result.style_code || currentStyleCode;
            const phtmlCode = result.phtml_code || '';

            // 更新字符计数
            const charsEl = document.getElementById('ai-gen-chars');
            if (charsEl) charsEl.textContent = phtmlCode.length + ' <?= __('字符') ?>';

            // 优先按 component_id 请求预览 API（写 phtml + ob 渲染），否则回退到组件预览接口
            let fullPreviewHtml = '';
            if (result.component_id) {
                _logLine('▶ <?= __('正在按 ID 请求预览...') ?>', '#94a3b8');
                fullPreviewHtml = await _fetchPreviewById({ component_id: result.component_id });
                if (fullPreviewHtml) _logLine('✅ <?= __('组件预览渲染完成') ?>', '#4ade80');
            }
            if (!fullPreviewHtml) {
                _logLine('▶ <?= __('正在调用组件预览接口...') ?>', '#94a3b8');
                let previewHtml = '';
                try {
                    var prevUrl = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/component/preview') ?>';
                    var prevOpts = { method: 'POST', headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'}, body: 'component_code=' + encodeURIComponent(compCode) + '&style_code=' + encodeURIComponent(compStyleCode) };
                    var previewResp = await window.Weline.Api.request(prevUrl, prevOpts);
                    const previewData = (previewResp && previewResp.data) || previewResp;
                    if (previewData.success && previewData.html) {
                        previewHtml = previewData.html;
                        _logLine('✅ <?= __('组件预览渲染完成') ?> (' + previewHtml.length + ' <?= __('字符') ?>)', '#4ade80');
                    } else {
                        _logLine('[WARN] <?= __('组件预览失败') ?>: ' + (previewData.message || '') + '<?= __('，使用原始代码') ?>', '#fbbf24');
                        previewHtml = phtmlCode;
                    }
                } catch (previewErr) {
                    _logLine('[WARN] <?= __('组件预览接口异常') ?>: ' + previewErr.message, '#fbbf24');
                    previewHtml = phtmlCode;
                }
                fullPreviewHtml = `<!DOCTYPE html><html><head><meta charset="utf-8"><style>
:root{--pb-primary:#667eea;--pb-accent:#7c3aed;--pb-bg:#fff;--pb-text:#333;--pb-heading:#1a1a1a;--pb-link:#667eea;--pb-link-hover:#5a6fd6;--pb-text-muted:#888;--pb-border:#e5e7eb;}
body{margin:0;padding:16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:var(--pb-text);background:var(--pb-bg);}
</style></head><body>${previewHtml}</body></html>`;
            }

            // 构建 workshopResult（保存 refine_token、component_id/draft_id 供刷新预览与微调）
            const wsResult = {
                success: true,
                component: {
                    code: compCode,
                    name: comp.name || params.name,
                    region: params.region,
                    phtml_code: phtmlCode,
                    style_code: compStyleCode,
                    ai_data: comp,
                    ...comp
                },
                validation: { valid: true },
                preview: fullPreviewHtml,
                refine_token: result.refine_token || '',
                draft_id: result.draft_id || 0,
                component_id: result.component_id || 0,
            };
            window.currentGeneratedComponent = wsResult.component;
            // 立即同步写入 localStorage，不依赖 300ms 后的 _workshopShowResult
            if (wsResult.component) {
                try {
                    saveGeneratedComponentToLocal({
                        component: wsResult.component,
                        preview: wsResult.preview?.html || wsResult.preview || '',
                        validation: wsResult.validation || {},
                        templateContent: wsResult.component.phtml_code || '',
                        finalPrompt: wsResult.final_prompt || ''
                    });
                } catch (e) { console.warn('同步保存组件到本地失败:', e); }
            }
            setTimeout(() => { _workshopShowResult(wsResult); }, 300);
        } else if (result) {
            throw new Error(result.message || '<?= __('生成失败') ?>');
        }

    } catch (error) {
        console.error('智能体生成失败:', error);
        _workshopSetStartButtonLoading(false);
        updateStreamStatus('<?= __('生成失败') ?>: ' + error.message, 0);
        const spinnerEl = document.getElementById('ai-gen-spinner');
        if (spinnerEl) { spinnerEl.className = 'me-2'; spinnerEl.innerHTML = '<i class="mdi mdi-alert-circle text-danger"></i>'; }
        _logLine('[FAILED] ' + error.message, '#ff6b6b');
    }
}

// 按 draft_id 或 component_id 请求预览 API，返回完整 HTML 或空字符串
async function _fetchPreviewById(payload) {
    const draftId = payload.draft_id || 0;
    const componentId = payload.component_id || 0;
    if (!draftId && !componentId) return '';
    try {
        const url = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/preview-by-id') ?>';
        const body = draftId ? { draft_id: draftId } : { component_id: componentId };
        var opts = { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(body) };
        var res = await window.Weline.Api.request(url, opts);
        var ok = res && (res.ok !== false);
        if (!ok) return '';
        if (res.data && typeof res.data === 'object' && res.data.success && res.data.html) return res.data.html;
        var text = (res && res.data) !== undefined ? String(res.data) : '';
        if (!text || text.trim().startsWith('<')) { if (text.trim().startsWith('<')) console.warn('Preview-by-id: 接口返回了 HTML 而非 JSON'); return ''; }
        try { var data = JSON.parse(text); if (data && data.success && data.html) return data.html; } catch(e) {}
        return '';
    } catch (e) {
        console.warn('Preview-by-id failed:', e);
        return '';
    }
}

// 按 draft_id 或 component_id 请求原始草稿内容（供调试复制，不渲染）
async function _fetchDraftContentById(payload) {
    const draftId = payload.draft_id || 0;
    const componentId = payload.component_id || 0;
    if (!draftId && !componentId) return '';
    try {
        const url = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/draft-content-by-id') ?>';
        const body = draftId ? { draft_id: draftId } : { component_id: componentId };
        var opts = { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(body) };
        var res = await window.Weline.Api.request(url, opts);
        var ok = res && (res.ok !== false);
        if (!ok) return '';
        if (res.data && typeof res.data === 'object' && res.data.success && res.data.content !== undefined) return res.data.content;
        var text = (res && res.data) !== undefined ? String(res.data) : '';
        if (!text || text.trim().startsWith('<')) { if (text.trim().startsWith('<')) console.warn('Draft-content-by-id: 接口返回了 HTML 而非 JSON'); return ''; }
        try { var data = JSON.parse(text); if (data && data.success && data.content !== undefined) return data.content; } catch(e) {}
        return '';
    } catch (e) {
        console.warn('Draft-content-by-id failed:', e);
        return '';
    }
}

// 从服务器重新拉取当前草稿/组件的预览（未保存前可反复点「刷新预览」查看最新）
async function _refreshPreviewFromDraft() {
    const draftId = _aiWorkshop?.result?.draft_id || 0;
    const componentId = _aiWorkshop?.result?.component_id || 0;
    const iframe = document.getElementById('ai-ws-preview-iframe');
    const wrap = (h) => '<!DOCTYPE html><html><head><meta charset="utf-8"><style>body{margin:0;padding:16px;font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',Roboto,sans-serif;}</style></head><body><script>var component=document.body.querySelector("[id]")||document.body;<\/script>' + h + '</body></html>';
    if (!draftId && !componentId) {
        // 无 ID 时用当前 result.preview 重新填入 iframe，保证按钮有可见效果
        const cached = (_aiWorkshop?.result?.preview != null) ? (_aiWorkshop.result.preview?.html || _aiWorkshop.result.preview) : '';
        if (iframe && cached) {
            iframe.srcdoc = _ensureComponentInPreviewHtml((String(cached).indexOf('<!DOCTYPE') === 0 || String(cached).indexOf('<!doctype') === 0) ? cached : wrap(cached));
            if (typeof BackendToast !== 'undefined') BackendToast.success('<?= __('已使用当前预览刷新') ?>');
        } else {
            if (typeof BackendToast !== 'undefined') BackendToast.warning('<?= __('当前无草稿 ID，无法刷新预览') ?>');
        }
        return;
    }
    const payload = draftId ? { draft_id: draftId } : { component_id: componentId };
    const html = await _fetchPreviewById(payload);
    if (!html) {
        if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __('预览拉取失败') ?>');
        return;
    }
    if (iframe) iframe.srcdoc = _ensureComponentInPreviewHtml((html.indexOf('<!DOCTYPE') === 0 || html.indexOf('<!doctype') === 0) ? html : wrap(html));
    if (_aiWorkshop?.result) _aiWorkshop.result.preview = html;
    if (typeof BackendToast !== 'undefined') BackendToast.success('<?= __('预览已更新') ?>');
}
if (typeof window !== 'undefined') window._refreshPreviewFromDraft = _refreshPreviewFromDraft;

// 复制草稿内容到剪贴板（用于「AI 生成的草稿内容」区块）
function _copyDraftContent(btnEl) {
