                        <p class="mb-2"><strong><?= __('格式2：简化组件格式') ?></strong></p>
                        <pre style="font-size: 10px; background: #1a1a1a; padding: 8px; border-radius: 4px; margin-bottom: 10px;">{ "phtml_code": "&lt;?php // 代码 ?&gt;" }</pre>
                        <p class="mb-2"><strong><?= __('格式3：纯代码格式') ?></strong></p>
                        <pre style="font-size: 10px; background: #1a1a1a; padding: 8px; border-radius: 4px;">{ "code": "&lt;?php // 直接粘贴PHTML代码 ?&gt;" }</pre>
                    </div>
                </div>
            </div>
        `,
        width: '700px',
        showCancelButton: true,
        confirmButtonText: '<i class="mdi mdi-eye"></i> <?= __('预览组件') ?>',
        cancelButtonText: '<?= __('取消') ?>',
        confirmButtonColor: '#f5576c',
        customClass: { container: 'swal2-dark-theme' },
        preConfirm: () => {
            const jsonContent = document.getElementById('importJsonContent').value.trim();
            
            if (!jsonContent) {
                Swal.showValidationMessage('<?= __('请粘贴 JSON 内容') ?>');
                return false;
            }
            
            try {
                const data = JSON.parse(jsonContent);
                return data;
            } catch (e) {
                Swal.showValidationMessage('<?= __('JSON 格式错误') ?>: ' + e.message);
                return false;
            }
        }
    }).then((result) => {
        if (result.isConfirmed && result.value) {
            importAndPreviewJson(result.value);
        }
    });
}

// 导入 JSON 并预览组件
function importAndPreviewJson(jsonData) {
    try {
        // 解析 JSON 数据，支持多种格式
        let componentData = {};
        let validation = { valid: true };
        let finalPrompt = '';
        let templateContent = '';
        
        console.log('[导入JSON] 接收数据:', jsonData);
        
        // 格式1：完整导出格式 { component: { phtml_code: "..." }, ... }
        if (jsonData.component && typeof jsonData.component === 'object') {
            console.log('[导入JSON] 检测到完整导出格式');
            componentData = jsonData.component;
            validation = jsonData.validation || { valid: true };
            finalPrompt = jsonData.final_prompt || '';
            templateContent = componentData.phtml_code || componentData.template_content || '';
        }
        // 格式2：API 返回格式 { success: true, component: { ... } }
        else if (jsonData.success !== undefined && jsonData.component) {
            console.log('[导入JSON] 检测到API返回格式');
            componentData = jsonData.component;
            validation = jsonData.validation || { valid: true };
            finalPrompt = jsonData.final_prompt || '';
            templateContent = componentData.phtml_code || componentData.template_content || '';
        }
        // 格式3：简化格式 { phtml_code: "..." } 或 { template_content: "..." }
        else if (jsonData.phtml_code || jsonData.template_content) {
            console.log('[导入JSON] 检测到简化组件格式');
            componentData = jsonData;
            templateContent = jsonData.phtml_code || jsonData.template_content || '';
        }
        // 格式4：纯代码格式 { code: "PHP代码" }
        else if (jsonData.code && typeof jsonData.code === 'string' && jsonData.code.includes('<' + '?')) {
            console.log('[导入JSON] 检测到纯代码格式');
            templateContent = jsonData.code;
            componentData = {
                name: '<?= __("导入的组件") ?>',
                region: 'content',
                category: 'content'
            };
        }
        // 格式5：result 包装格式 { result: { template_content: "..." } }
        else if (jsonData.result && jsonData.result.template_content) {
            console.log('[导入JSON] 检测到result包装格式');
            templateContent = jsonData.result.template_content;
            componentData = jsonData.result;
            validation = jsonData.validation || { valid: true };
            finalPrompt = jsonData.final_prompt || '';
        }
        // 格式6：preview 格式（从生成结果复制）
        else if (jsonData.preview && (jsonData.preview.html || typeof jsonData.preview === 'string')) {
            console.log('[导入JSON] 检测到preview格式');
            // 尝试从其他字段获取代码
            templateContent = jsonData.component?.phtml_code || jsonData.result?.template_content || '';
            componentData = jsonData.component || {};
            validation = jsonData.validation || { valid: true };
            finalPrompt = jsonData.final_prompt || '';
        }
        else {
            // 打印所有键帮助调试
            console.error('[导入JSON] 无法识别的格式，JSON 键:', Object.keys(jsonData));
            throw new Error('<?= __("无法识别的 JSON 格式。请确保 JSON 包含以下字段之一：") ?>\n' +
                '• component.phtml_code\n' +
                '• phtml_code\n' +
                '• template_content\n' +
                '• code (PHP代码)\n\n' +
                '<?= __("当前 JSON 包含的键") ?>: ' + Object.keys(jsonData).join(', '));
        }
        
        if (!templateContent) {
            console.error('[导入JSON] 未找到模板内容，componentData:', componentData);
            throw new Error('<?= __('JSON 中缺少组件代码。请确保包含 phtml_code 或 template_content 字段，且值不为空。') ?>');
        }
        
        console.log('[导入JSON] 成功提取模板内容，长度:', templateContent.length);
        
        // 生成预览
        generatePreviewFromCode(templateContent, componentData, validation, finalPrompt);
        
    } catch (error) {
        console.error('[导入JSON] 错误:', error);
        BackendToast.error('<?= __('导入失败') ?>：' + (error.message || '<?= __('未知错误') ?>'));
    }
}

// 从代码生成预览
async function generatePreviewFromCode(templateContent, componentData, validation, finalPrompt) {
    // 显示加载状态
    BackendToast.info('<?= __('正在生成预览...') ?>', 5000);
    
    try {
        // 调用后端生成预览
        var prevUrl = '<?= $this->getBackendUrl('pagebuilder/backend/visual/api/ai-component/preview') ?>';
        var prevOpts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ template_content: templateContent, category: componentData.region || componentData.category || 'content' })
        };
        var response = await window.Weline.Api.request(prevUrl, prevOpts);
        
        let previewResult = { success: false, html: '' };
        var ok = response && (response.ok !== false);
        if (ok && response.data) {
            if (typeof response.data === 'object' && response.data !== null) {
                previewResult = response.data;
            } else {
                try { previewResult = safeJsonParse(String(response.data)); } catch (e) { console.warn('预览响应解析失败:', e); }
            }
        }
        
        // 显示导入的组件
        showGeneratedComponent({
            component: {
                ...componentData,
                phtml_code: templateContent
            },
            validation: validation,
            preview: previewResult.success ? previewResult : { html: previewResult.html || '', error: previewResult.error || '' },
            result: { template_content: templateContent },
            final_prompt: finalPrompt
        });
        
    } catch (error) {
        console.error('生成预览失败:', error);
        
        // 即使预览失败，也显示组件（只是没有预览）
        showGeneratedComponent({
            component: {
                ...componentData,
                phtml_code: templateContent
            },
            validation: validation,
            preview: { success: false, html: '', error: error.message },
            result: { template_content: templateContent },
            final_prompt: finalPrompt
        });
    }
}

// 加载参考组件列表
async function loadReferenceComponents(region, selectedCode = '') {
    const select = document.getElementById('aiReferenceComponent');
    if (!select) return;
    
    select.innerHTML = '<option value=""><?= __('加载中...') ?></option>';
    
    try {
        // 从已加载的组件数据中获取对应区域的组件
        const components = getComponentsForRegion(region);
        
        let options = '<option value=""><?= __('-- 不使用参考组件 --') ?></option>';
        
        if (components.length > 0) {
            // 按模板分组显示
            const groups = {};
            components.forEach(comp => {
                const key = comp.isOwn ? 'own' : (comp.isShared ? 'shared' : comp.templateCode);
                if (!groups[key]) {
                    groups[key] = {
                        label: comp.isOwn ? '<?= __('本模板（推荐）') ?>' : (comp.isShared ? '<?= __('通用组件') ?>' : comp.templateName),
                        isOwn: comp.isOwn,
                        components: []
                    };
                }
                groups[key].components.push(comp);
            });
            
            // 优先显示本模板组件
            if (groups.own) {
                options += `<optgroup label="${groups.own.label}">`;
                groups.own.components.forEach(comp => {
                    const selected = comp.code === selectedCode ? 'selected' : '';
                    options += `<option value="${comp.code}" ${selected}>★ ${comp.name}</option>`;
                });
                options += '</optgroup>';
                delete groups.own;
            }
            
            // 显示其他组件
            Object.values(groups).forEach(group => {
                options += `<optgroup label="${group.label}">`;
                group.components.forEach(comp => {
                    const selected = comp.code === selectedCode ? 'selected' : '';
                    options += `<option value="${comp.code}" ${selected}>${comp.name}</option>`;
                });
                options += '</optgroup>';
            });
        } else {
            options += '<option value="" disabled><?= __('该区域暂无可用组件') ?></option>';
        }
        
        select.innerHTML = options;
        
    } catch (error) {
        console.error('加载参考组件失败:', error);
        select.innerHTML = '<option value=""><?= __('-- 不使用参考组件 --') ?></option>';
    }
}

