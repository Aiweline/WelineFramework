                let url = '';
                let requestData = {};
                
                if (window.isTemplateConfigMode) {
                    // 妯℃澘閰嶇疆妯″紡
                    url = '<?= $this->getBackendUrl('*/backend/template/resetFieldsToDefault') ?>';
                    requestData = {
                        style_code: window.currentTemplateStyleCode || '',
                        page_id: window.currentTemplatePageId || 0,
                        config_keys: configKeys
                    };
                } else {
                    // 姝ｅ父椤甸潰閰嶇疆妯″紡
                    url = '<?= $this->getBackendUrl('*/backend/preview/resetFieldsToDefault') ?>';
                    const styleSelect = document.getElementById('style');
                    let styleCode = styleSelect ? styleSelect.value : '';
                    requestData = applyVisualIdentityToPayload({
                        page_id: window.visualPageId || window.pageId || 0,
                        style_code: styleCode,
                        config_keys: configKeys,
                        locale: window.currentVisualLanguage || ''
                    });
                }
                
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestData) };
                var res = await window.Weline.Api.request(url, opts);
                const result = (res && res.data) || res;
                
                if (result.success) {
                    if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                        await loadTemplateStyleConfig();
                    } else if (typeof loadVisualStyleConfig === 'function') {
                        await loadVisualStyleConfig();
                    }
                    
                    // 鍒锋柊棰勮
                    refreshPreview();
                    
                    updateSaveStatus('saved', '<?= __('') ?>');
                    if (typeof showToast === 'function') {
                        showToast('success', '<?= __('鎴愬姛') ?>', `<?= __('') ?> ${result.reset_count || configKeys.length} <?= __('') ?>`);
                    }
                } else {
                    updateSaveStatus('error', '<?= __('閲嶇疆澶辫触') ?>: ' + (result.message || ''));
                    console.error('鉂?閲嶇疆澶辫触:', result);
                    if (typeof showToast === 'function') {
                        showToast('error', '<?= __('澶辫触') ?>', result.message || '<?= __('閲嶇疆澶辫触') ?>');
                    }
                }
            } catch (error) {
                console.error('鉂?閲嶇疆澶辫触:', error);
                updateSaveStatus('error', '<?= __('閲嶇疆澶辫触') ?>');
                if (typeof showToast === 'function') {
                    showToast('error', '<?= __('澶辫触') ?>', error.message || '<?= __('閲嶇疆澶辫触') ?>');
                }
            }
        }
    );
};

// ========== 閰嶇疆椤规悳绱㈠姛鑳?==========
/**
 * 鎼滅储閰嶇疆瀛楁
 * @param {string} searchTerm - 鎼滅储鍏抽敭璇?
 */
window.searchConfigFields = function(searchTerm) {
    const searchBox = document.querySelector('.config-search-box');
    const searchInput = document.getElementById('configSearchInput');
    
    if (!searchTerm || searchTerm.trim() === '') {
        // 娓呯┖鎼滅储
        clearConfigSearch();
        return;
    }
    
    // 鏇存柊鎼滅储妗嗙姸鎬?
    if (searchBox) {
        searchBox.classList.add('has-value');
    }
    
    const term = searchTerm.trim().toLowerCase();
    const allFields = document.querySelectorAll('.config-field-item');
    const allSections = document.querySelectorAll('.config-section');
    const sectionVisibility = new Map(); // 璁板綍姣忎釜section鏄惁鏈夊彲瑙佸瓧娈?
    
    // 閬嶅巻鎵€鏈夐厤缃瓧娈?
    allFields.forEach(function(field) {
        const configKey = (field.getAttribute('data-config-key') || '').toLowerCase();
        const configLabel = (field.getAttribute('data-config-label') || '').toLowerCase();
        const configDescription = (field.getAttribute('data-config-description') || '').toLowerCase();
        
        // 妯＄硦鍖归厤锛氭鏌?key銆乴abel 鎴?description 鏄惁鍖呭惈鎼滅储璇?
        const matches = configKey.includes(term) || 
                       configLabel.includes(term) || 
                       configDescription.includes(term);
        
        if (matches) {
            // 鏄剧ず瀛楁
            field.classList.remove('config-field-hidden');
            
            // 楂樹寒鍖归厤鐨勬枃鏈紙鍦?label 涓級
            const label = field.querySelector('label');
            if (label) {
                // 淇濆瓨鍘熷 HTML锛堝鏋滆繕娌℃湁淇濆瓨锛?
                if (!label.hasAttribute('data-original-html')) {
                    label.setAttribute('data-original-html', label.innerHTML);
                }
                
                // 鍏堢Щ闄や箣鍓嶇殑楂樹寒
                let labelHTML = label.getAttribute('data-original-html') || label.innerHTML || '';
                labelHTML = labelHTML.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
                
                // 鎻愬彇鏂囨湰閮ㄥ垎锛堜笉鍖呮嫭鎭㈠鎸夐挳锛?
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = labelHTML;
                const restoreBtn = tempDiv.querySelector('.visual-config-reset-btn');
                const restoreBtnHTML = restoreBtn ? restoreBtn.outerHTML : '';
                tempDiv.querySelectorAll('.visual-config-reset-btn').forEach(btn => btn.remove());
                const textOnly = tempDiv.textContent || '';
                
                // 楂樹寒鏂囨湰
                const highlightedText = highlightSearchTerm(textOnly, term);
                if (highlightedText !== textOnly) {
                    label.innerHTML = highlightedText + (restoreBtnHTML ? ' ' + restoreBtnHTML : '');
                } else {
                    label.innerHTML = labelHTML; // 鎭㈠鍘熷 HTML
                }
            }
            
            // 璁板綍璇ュ瓧娈垫墍灞炵殑 section 鏈夊彲瑙佸瓧娈?
            const section = field.closest('.config-section');
            if (section) {
                const sectionId = section.id;
                sectionVisibility.set(sectionId, true);
            }
        } else {
            // 闅愯棌瀛楁
            field.classList.add('config-field-hidden');
        }
    });
    
    // 鏇存柊 section 鐨勫彲瑙佹€?
    allSections.forEach(function(section) {
        const sectionId = section.id;
        const hasVisibleFields = sectionVisibility.get(sectionId) || false;
        
        if (hasVisibleFields) {
            section.classList.remove('config-section-empty');
            // 鑷姩灞曞紑鍖归厤鐨?section
            const sectionBody = section.querySelector('.config-section-body');
            if (sectionBody && sectionBody.style.display === 'none') {
                sectionBody.style.display = '';
                const chevron = section.querySelector('.config-section-header i.mdi-chevron-down, .config-section-header i.mdi-chevron-right');
                if (chevron) {
                    chevron.classList.remove('mdi-chevron-right');
                    chevron.classList.add('mdi-chevron-down');
                }
            }
        } else {
            section.classList.add('config-section-empty');
        }
    });
};

/**
 * 楂樹寒鎼滅储鍏抽敭璇?
 * @param {string} text - 鍘熷鏂囨湰
 * @param {string} term - 鎼滅储鍏抽敭璇?
 * @returns {string} 楂樹寒鍚庣殑鏂囨湰
 */
function highlightSearchTerm(text, term) {
    if (!term || !text) return text;
    
    // 绉婚櫎宸叉湁鐨勯珮浜?
    text = text.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
    
    // 鍒涘缓姝ｅ垯琛ㄨ揪寮忚繘琛屼笉鍖哄垎澶у皬鍐欑殑鍖归厤
    const regex = new RegExp('(' + escapeRegExp(term) + ')', 'gi');
    return text.replace(regex, '<span class="config-search-highlight">$1</span>');
}

/**
 * 杞箟姝ｅ垯琛ㄨ揪寮忕壒娈婂瓧绗?
 * @param {string} str - 瑕佽浆涔夌殑瀛楃涓?
 * @returns {string} 杞箟鍚庣殑瀛楃涓?
 */
function escapeRegExp(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

/**
 * HTML杞箟杈呭姪鍑芥暟
 */
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

/**
 * 鎵ц閰嶇疆鍥炲～骞舵坊鍔犺摑鑹茶竟妗嗘爣璁?
 */
window.performConfigFill = function(configItems, filledInputs) {
    let filledCount = 0;
    
    // 鎵ц鍥炲～
    configItems.forEach(function(item) {
        const input = item.input;
        if (input) {
            input.value = item.value;
            // 瑙﹀彂change鍜宨nput浜嬩欢锛岀‘淇濊嚜鍔ㄤ繚瀛樺拰UI鏇存柊
            input.dispatchEvent(new Event('change', { bubbles: true }));
            input.dispatchEvent(new Event('input', { bubbles: true }));
            
            // 娣诲姞钃濊壊杈规鏍囪锛堟案涔呬繚鐣欙級
            input.classList.add('ai-filled-field');
            input.style.borderColor = '#0d6efd';
            input.style.borderWidth = '2px';
            input.style.borderStyle = 'solid';
            
            filledCount++;
        }
    });
    
    // 鏄剧ず鎴愬姛娑堟伅
    BackendToast.success(`<?= __('') ?> ${filledCount} <?= __('涓厤缃」') ?>`);
    
    // 鑷姩淇濆瓨
    if (typeof window.autoSaveConfig === 'function') {
        window.autoSaveConfig(true); // 绔嬪嵆淇濆瓨
    }
}

// 杩欓噷绉婚櫎浜?generateTemplateConfig 鐨勫疄鐜帮紝鏀圭敱 form.phtml 涓殑鍏ㄥ眬鑴氭湰鎻愪緵

/**
 * 娓呯┖鎼滅储
 */
window.clearConfigSearch = function() {
    const searchInput = document.getElementById('configSearchInput');
    const searchBox = document.querySelector('.config-search-box');
    
    if (searchInput) {
        searchInput.value = '';
    }
    
    if (searchBox) {
        searchBox.classList.remove('has-value');
    }
    
    // 鏄剧ず鎵€鏈夊瓧娈?
    const allFields = document.querySelectorAll('.config-field-item');
    allFields.forEach(function(field) {
        field.classList.remove('config-field-hidden');
        
        // 鎭㈠鍘熷 HTML锛堢Щ闄ら珮浜級
        const label = field.querySelector('label');
        if (label) {
            // 濡傛灉鏈変繚瀛樼殑鍘熷 HTML锛屼娇鐢ㄥ畠锛涘惁鍒欑Щ闄ら珮浜爣绛?
            const originalHTML = label.getAttribute('data-original-html');
            if (originalHTML) {
                label.innerHTML = originalHTML;
                label.removeAttribute('data-original-html');
            } else {
                // 绉婚櫎楂樹寒鏍囩锛屼繚鐣欏叾浠?HTML
                let labelHTML = label.innerHTML || '';
                labelHTML = labelHTML.replace(/<span class="config-search-highlight">(.*?)<\/span>/gi, '$1');
                label.innerHTML = labelHTML;
            }
        }
    });
    
    // 鎭㈠鎵€鏈?section 鐨勫彲瑙佹€?
    const allSections = document.querySelectorAll('.config-section');
    allSections.forEach(function(section) {
        section.classList.remove('config-section-empty');
    });
};

// ========== 缁勪欢鎷栨嫿鏀剧疆鍔熻兘 ==========

// 楂樹寒棰勮鍖哄煙涓殑瀵瑰簲鍖哄煙
window.highlightPreviewRegion = function(region) {
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) return;
    
    try {
        const doc = previewFrame.contentWindow.document;
        doc.querySelectorAll('[data-region]').forEach(zone => {
            const zoneRegion = zone.getAttribute('data-region');
            if (zoneRegion === region) {
                zone.style.outline = '3px dashed #3498db';
                zone.style.outlineOffset = '-3px';
                zone.style.transition = 'outline 0.2s';
            }
        });
    } catch (e) {
        console.warn('鏃犳硶璁块棶棰勮iframe:', e);
    }
};

// 鍙栨秷楂樹寒
window.unhighlightPreviewRegion = function() {
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) return;
    
    try {
        const doc = previewFrame.contentWindow.document;
        doc.querySelectorAll('[data-region]').forEach(zone => {
            zone.style.outline = '';
            zone.style.outlineOffset = '';
        });
    } catch (e) {
        console.warn('鏃犳硶璁块棶棰勮iframe:', e);
    }
};

// 璁剧疆棰勮iframe涓殑鏀剧疆鍖哄煙
window.setupPreviewDropZones = function() {
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) return;
    
    // 淇濆瓨涓荤獥鍙ｅ拰iframe鐨勫紩鐢紝浠ヤ究鍦ㄤ簨浠跺鐞嗗嚱鏁颁腑浣跨敤
    const mainWindow = window;
    const iframeElement = previewFrame;
    
    try {
        const doc = previewFrame.contentWindow.document;
        
        // 娣诲姞鏀剧疆鍖哄煙鏍峰紡
        let style = doc.getElementById('component-drop-styles');
        if (!style) {
            style = doc.createElement('style');
            style.id = 'component-drop-styles';
            style.textContent = `
                [data-region] {
                    position: relative;
                    min-height: 50px;
                }
                /* 鎻掑叆浣嶇疆鎸囩ず鍣?*/
                .insert-indicator {
                    height: 3px;
                    background: #3498db;
                    margin: 4px 0;
                    border-radius: 2px;
                    opacity: 0.9;
                    box-shadow: 0 0 8px rgba(52, 152, 219, 0.6);
                    pointer-events: none;
                    transition: opacity 0.2s ease;
                    position: relative;
                }
                .insert-indicator::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 8px;
                    height: 8px;
                    background: #3498db;
                    border-radius: 50%;
                    box-shadow: 0 0 4px rgba(52, 152, 219, 0.8);
                }
                
                [data-region].drag-over {
                    background: rgba(52, 152, 219, 0.1) !important;
                    outline: 3px solid #3498db !important;
                    outline-offset: -3px;
                }
                [data-region]::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    pointer-events: none;
                    z-index: 9998;
                }
                .component-drop-indicator {
                    position: absolute;
                    left: 0;
                    right: 0;
                    height: 4px;
                    background: #3498db;
                    z-index: 9999;
                    pointer-events: none;
                }
                .tpmst-component-wrapper {
                    position: relative !important;
                    transition: box-shadow 0.2s ease;
                    z-index: 1 !important;
                }
                /* header/footer 鍖哄煙鐨勭粍浠跺寘瑁呭櫒闇€瑕佹洿楂樼殑 z-index锛宖ooter 绂佹瑁佸壀浠ヤ究鏄剧ず鎿嶄綔鎸夐挳 */
                [data-region="header"] .tpmst-component-wrapper,
                [data-region="footer"] .tpmst-component-wrapper,
                .pb-slot-footer .tpmst-component-wrapper,
                .pb-slot-footer .pb-component-wrapper {
                    z-index: 10000 !important;
                }
                [data-region="footer"],
                .pb-slot-footer {
                    overflow: visible !important;
                }
                /* footer 鍖哄彇娑?::before 閬僵锛岄伩鍏嶉樆鎸?wrapper 鐨?mouseenter锛屼笌 header 琛屼负涓€鑷?*/
                [data-region="footer"]::before,
                .pb-slot-footer::before {
                    display: none !important;
                }
                [data-region="footer"] .tpmst-component-wrapper,
                .pb-slot-footer .tpmst-component-wrapper,
                .pb-slot-footer .pb-component-wrapper {
                    overflow: visible !important;
                }
                .tpmst-component-wrapper:hover {
                    /* 鍙傜収 header 鏍峰紡锛氫娇鐢ㄨ竟妗嗗唴閮ㄨ櫄绾块槾褰憋紝涓嶈鑳屾櫙钂欑増 */
                    border: 2px dashed rgba(52, 152, 219, 0.6) !important;
                    box-shadow: inset 0 0 0 2px rgba(52, 152, 219, 0.3) !important;
                    background: transparent !important;
                    background-color: transparent !important;
                    z-index: 10001 !important;
                }
                /* 纭繚 hover 鏃朵吉鍏冪礌涔熶笉鏄剧ず鑳屾櫙 */
                .tpmst-component-wrapper:hover::before,
                .tpmst-component-wrapper:hover::after {
                    background: transparent !important;
                    background-color: transparent !important;
                }
                /* 纭繚鍐呴儴鍏冪礌涓嶄細闃绘尅 hover */
                .tpmst-component-wrapper > * {
                    pointer-events: auto;
                }
                /* header/footer 鍐呯殑瀵艰埅鍜屽唴瀹瑰尯鍩熺‘淇濆彲浜や簰 */
                [data-region="header"] .tpmst-component-wrapper .tpmst-nav,
                [data-region="header"] .tpmst-component-wrapper nav,
                [data-region="footer"] .tpmst-component-wrapper footer {
                    position: relative !important;
                }
                /* 纭繚 footer 鍖?wrapper 鍙鎮仠锛氬瓙鍏冪礌涓嶉樆鎸?wrapper 鐨?hover 浼犻€?*/
                [data-region="footer"] .tpmst-component-wrapper {
                    isolation: isolate;
                }
                .tpmst-component-wrapper .component-actions {
                    position: absolute !important;
                    top: 8px !important;
                    right: 8px !important;
                    left: auto !important;
                    bottom: auto !important;
                    display: none !important;
                    flex-direction: row !important;
                    align-items: center !important;
                    justify-content: flex-end !important;
                    gap: 6px;
                    z-index: 100000 !important;
                    background: rgba(255,255,255,0.95) !important;
                    padding: 6px 8px !important;
                    border-radius: 6px !important;
                    box-shadow: 0 2px 12px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05) !important;
                    pointer-events: auto !important;
                    margin: 0 !important;
                    min-width: auto !important;
                    width: auto !important;
                    height: auto !important;
                }
                .tpmst-component-wrapper:hover .component-actions,
                .tpmst-component-wrapper .component-actions:hover,
                .tpmst-component-wrapper .component-actions.pb-actions-visible {
                    display: flex !important;
                }
                /* header/footer 鍖哄煙鐨勬搷浣滄寜閽粺涓€鏀惧湪鍙充笂瑙掞紝z-index 鏇撮珮 */
                [data-region="header"] .tpmst-component-wrapper .component-actions,
                [data-region="footer"] .tpmst-component-wrapper .component-actions,
                .pb-slot-footer .tpmst-component-wrapper .component-actions,
                .pb-slot-footer .pb-component-wrapper .component-actions {
                    z-index: 100001 !important;
                }
                /* footer 鍖哄煙锛氫笌 header 涓€鑷达紝浠?hover 鏃舵樉绀烘寜閽紝澶卞幓 hover 鏃堕殣钘?*/
                .pb-slot-footer .tpmst-component-wrapper .component-actions,
                .pb-slot-footer .pb-component-wrapper .component-actions {
                    display: none !important;
                }
                .pb-slot-footer footer,
                .pb-slot-footer [data-region="footer"],
                .pb-slot-footer .tpmst-region-footer,
                [data-region="footer"] footer {
                    overflow: visible !important;
                }
                .pb-slot-footer:hover .tpmst-component-wrapper .component-actions,
                .pb-slot-footer:hover .pb-component-wrapper .component-actions,
                [data-region="footer"]:hover .tpmst-component-wrapper .component-actions,
                [data-region="footer"]:hover .pb-component-wrapper .component-actions,
                [data-region="footer"] .tpmst-component-wrapper:hover .component-actions,
                [data-region="footer"] .pb-component-wrapper:hover .component-actions,
                .pb-slot-footer .tpmst-component-wrapper:hover .component-actions,
                .pb-slot-footer .pb-component-wrapper:hover .component-actions {
                    display: flex !important;
                }
                .tpmst-component-wrapper .component-actions button {
                    width: 32px;
                    height: 32px;
                    padding: 0;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #3498db;
                    color: #fff;
                    border: none;
                    border-radius: 6px;
                    cursor: pointer;
                    font-size: 14px;
                    transition: all 0.2s ease;
                }
                .tpmst-component-wrapper .component-actions button:hover {
                    background: #2980b9;
                    transform: scale(1.1);
                }
                .tpmst-component-wrapper .component-actions button:last-child {
                    background: #e74c3c;
                }
                .tpmst-component-wrapper .component-actions button:last-child:hover {
                    background: #c0392b;
                }
                /* 鎺掑簭鎸夐挳鏍峰紡 */
                .tpmst-component-wrapper .component-actions button.move-up {
                    background: #27ae60;
                }
                .tpmst-component-wrapper .component-actions button.move-up:hover {
                    background: #229954;
                }
                .tpmst-component-wrapper .component-actions button.move-down {
                    background: #f39c12;
                }
                .tpmst-component-wrapper .component-actions button.move-down:hover {
                    background: #e67e22;
                }
                .tpmst-component-wrapper .component-actions button:disabled {
                    background: #95a5a6;
                    opacity: 0.5;
                }
                .tpmst-component-wrapper .component-actions button:disabled:hover {
                    transform: none;
                }
            `;
            doc.head.appendChild(style);
        }
        
        // 涓烘瘡涓尯鍩熸坊鍔犳斁缃洃鍚?
        doc.querySelectorAll('[data-region]').forEach(zone => {
            // 绉婚櫎鏃х殑鐩戝惉鍣紙濡傛灉鏈夛級
            zone.removeEventListener('dragover', handlePreviewDragOver);
            zone.removeEventListener('dragleave', handlePreviewDragLeave);
            zone.removeEventListener('drop', handlePreviewDrop);
            
            // 娣诲姞鏂扮殑鐩戝惉鍣?
            zone.addEventListener('dragover', handlePreviewDragOver);
            zone.addEventListener('dragleave', handlePreviewDragLeave);
            zone.addEventListener('drop', handlePreviewDrop);
        });

        // footer 鍖哄煙锛氱敤 document 绾?mouseover/mouseout 濮旀墭锛岃緟鍔?hover 鏄剧ず锛堜笌 header/content 涓€鑷达級
        (function() {
            var footerSelector = '[data-region="footer"], .pb-slot-footer';
            var footerZones = doc.querySelectorAll(footerSelector);
            if (footerZones.length === 0) return;
            var actionsSelector = '.tpmst-component-wrapper .component-actions, .pb-component-wrapper .component-actions';
            var hideFooterActions = function(zone) {
                if (!zone) return;
                zone.querySelectorAll(actionsSelector).forEach(function(a) { a.classList.remove('pb-actions-visible'); });
            };
            var showFooterActions = function(zone) {
                if (!zone) return;
                zone.style.position = 'relative';
                zone.querySelectorAll(actionsSelector).forEach(function(a) { a.classList.add('pb-actions-visible'); });
            };
            doc.addEventListener('mouseover', function(e) {
                var zone = e.target && e.target.closest ? e.target.closest(footerSelector) : null;
                if (zone) showFooterActions(zone);
            }, true);
            doc.addEventListener('mouseout', function(e) {
                var zone = e.target && e.target.closest ? e.target.closest(footerSelector) : null;
                var related = e.relatedTarget;
                if (!zone) return;
                if (related && zone.contains(related)) return;
                hideFooterActions(zone);
            }, true);
        })();
        
        // 涓烘瘡涓粍浠舵坊鍔犳搷浣滄寜閽?
        doc.querySelectorAll('.tpmst-component-wrapper').forEach(wrapper => {
            const region = wrapper.getAttribute('data-region');
            
            // 纭繚wrapper鏈夋纭殑瀹氫綅鏍峰紡
            if (wrapper.style.position !== 'relative') {
                wrapper.style.position = 'relative';
            }
            
            // 鍒濆鍖栨垨閲嶇疆 data-original-index
            // 鐢ㄤ簬缁勪欢鎺掑簭鏃惰拷韪師濮嬬储寮曚綅缃?
            // 姣忔鍒锋柊鏃堕兘閲嶇疆锛屽洜涓洪『搴忓凡缁忎繚瀛樺苟鏇存柊
            if (region === 'content') {
                const currentIndex = wrapper.getAttribute('data-index');
                if (currentIndex !== null) {
                    wrapper.setAttribute('data-original-index', currentIndex);
                }
            }
            
            // 绉婚櫎鏃х殑鎿嶄綔鎸夐挳锛堝鏋滃瓨鍦級
            const oldActions = wrapper.querySelector('.component-actions');
            if (oldActions) {
                oldActions.remove();
            }
            
            // 鍒涘缓鏂扮殑鎿嶄綔鎸夐挳瀹瑰櫒
            const actions = doc.createElement('div');
            actions.className = 'component-actions';
            actions.style.position = 'absolute';
            actions.style.right = '8px';
            actions.style.top = '8px';
            
            // content 鍖哄煙娣诲姞鎺掑簭鎸夐挳
            if (region === 'content') {
                const wrapperIndex = wrapper.getAttribute('data-index') || '0';
                
                // 涓婄Щ鎸夐挳
                const moveUpBtn = doc.createElement('button');
                moveUpBtn.className = 'move-up';
                moveUpBtn.title = '涓婄Щ';
                moveUpBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z"/></svg>';
                moveUpBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    // 浠庝富绐楀彛璋冪敤鍑芥暟
                    if (mainWindow && mainWindow.moveComponentUpByIndex) {
                        mainWindow.moveComponentUpByIndex(wrapperIndex);
                    } else {
                        console.error('鏃犳硶鎵惧埌 moveComponentUpByIndex 鍑芥暟', mainWindow);
                    }
                });
                actions.appendChild(moveUpBtn);
                
                // 涓嬬Щ鎸夐挳 - 宸查殣钘?
                // const moveDownBtn = doc.createElement('button');
                // moveDownBtn.className = 'move-down';
                // moveDownBtn.title = '涓嬬Щ';
                // moveDownBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"/></svg>';
                // moveDownBtn.addEventListener('click', function(e) {
                //     e.preventDefault();
                //     e.stopPropagation();
                //     e.stopImmediatePropagation();
                //     // 浠庝富绐楀彛璋冪敤鍑芥暟锛岀‘淇濅紶閫掑瓧绗︿覆绫诲瀷鐨勭储寮?
                //     const indexToPass = String(wrapperIndex);
                //     console.log('涓嬬Щ鎸夐挳鐐瑰嚮锛寃rapperIndex:', wrapperIndex, '浼犻€掔殑绱㈠紩:', indexToPass);
                //     if (mainWindow && typeof mainWindow.moveComponentDownByIndex === 'function') {
                //         mainWindow.moveComponentDownByIndex(indexToPass);
                //     } else {
                //         console.error('鏃犳硶鎵惧埌 moveComponentDownByIndex 鍑芥暟', {
                //             mainWindow: !!mainWindow,
                //             hasFunction: !!(mainWindow && mainWindow.moveComponentDownByIndex),
                //             functionType: typeof (mainWindow && mainWindow.moveComponentDownByIndex)
                //         });
                //     }
                // });
                // actions.appendChild(moveDownBtn);
            }
            
            // 缂栬緫鎸夐挳
            const editBtn = doc.createElement('button');
            editBtn.title = '缂栬緫';
            editBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"/></svg>';
            editBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                // 浠庝富绐楀彛璋冪敤鍑芥暟锛屼紶閫抴rapper鍏冪礌锛堜粠iframe鏂囨。涓幏鍙栵級
                if (mainWindow && mainWindow.editComponentInPreview && iframeElement) {
                    try {
                        // 浠巌frame鏂囨。涓噸鏂拌幏鍙杦rapper鍏冪礌锛岀‘淇濅富绐楀彛鍙互璁块棶
                        const iframeDoc = iframeElement.contentWindow.document;
                        const componentCode = wrapper.getAttribute('data-component');
                        const wrapperRegion = wrapper.getAttribute('data-region');
                        const wrapperIndex = wrapper.getAttribute('data-index');
                        
                        // 鏋勫缓鏌ヨ閫夋嫨鍣細header/footer 鍖哄煙娌℃湁 data-index锛岄渶瑕佸尯鍒嗗鐞?
                        let selector = `.tpmst-component-wrapper[data-component="${componentCode}"][data-region="${wrapperRegion}"]`;
                        if (wrapperIndex !== null && wrapperIndex !== undefined) {
                            selector += `[data-index="${wrapperIndex}"]`;
                        }
                        
                        // 閫氳繃灞炴€ч噸鏂版煡鎵緒rapper
                        const targetWrapper = iframeDoc.querySelector(selector);
                        if (targetWrapper) {
                            mainWindow.editComponentInPreview(targetWrapper);
                        } else {
                            console.error('鏃犳硶鎵惧埌鐩爣缁勪欢鍏冪礌', { componentCode, wrapperRegion, wrapperIndex, selector });
                        }
                    } catch (err) {
                        console.error('缂栬緫缁勪欢鏃跺嚭閿?', err);
                    }
                } else {
                    console.error('鏃犳硶鎵惧埌 editComponentInPreview 鍑芥暟鎴杋frame鍏冪礌', { mainWindow, iframeElement });
                }
            });
            actions.appendChild(editBtn);
            
            // 鍒犻櫎鎸夐挳
            const removeBtn = doc.createElement('button');
            removeBtn.title = '鍒犻櫎';
            removeBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/></svg>';
            removeBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                // 浠庝富绐楀彛璋冪敤鍑芥暟锛屼紶閫抴rapper鍏冪礌锛堜粠iframe鏂囨。涓幏鍙栵級
                if (mainWindow && mainWindow.removeComponentInPreview && iframeElement) {
                    try {
                        // 浠巌frame鏂囨。涓噸鏂拌幏鍙杦rapper鍏冪礌锛岀‘淇濅富绐楀彛鍙互璁块棶
                        const iframeDoc = iframeElement.contentWindow.document;
                        const componentCode = wrapper.getAttribute('data-component');
                        const wrapperRegion = wrapper.getAttribute('data-region');
                        const wrapperIndex = wrapper.getAttribute('data-index');
                        
                        // 鏋勫缓鏌ヨ閫夋嫨鍣細header/footer 鍖哄煙娌℃湁 data-index锛岄渶瑕佸尯鍒嗗鐞?
                        let selector = `.tpmst-component-wrapper[data-component="${componentCode}"][data-region="${wrapperRegion}"]`;
                        if (wrapperIndex !== null && wrapperIndex !== undefined) {
                            selector += `[data-index="${wrapperIndex}"]`;
                        }
                        
                        // 閫氳繃灞炴€ч噸鏂版煡鎵緒rapper
                        const targetWrapper = iframeDoc.querySelector(selector);
                        if (targetWrapper) {
                            mainWindow.removeComponentInPreview(targetWrapper);
                        } else {
                            console.error('鏃犳硶鎵惧埌鐩爣缁勪欢鍏冪礌', { componentCode, wrapperRegion, wrapperIndex, selector });
                        }
                    } catch (err) {
                        console.error('鍒犻櫎缁勪欢鏃跺嚭閿?', err);
                    }
                } else {
                    console.error('鏃犳硶鎵惧埌 removeComponentInPreview 鍑芥暟鎴杋frame鍏冪礌', { mainWindow, iframeElement });
                }
            });
            actions.appendChild(removeBtn);
            
            wrapper.appendChild(actions);
            
            // footer 鍖猴細濮嬬粓鏄剧ず鎸夐挳锛堜笉闅?hover 鍒囨崲锛夛紝閬垮厤宓屽缁撴瀯闃绘尅 hover
            if (region === 'footer') {
                actions.classList.add('pb-footer-actions', 'pb-actions-visible');
            }
        });
        
        // 鏇存柊鎵€鏈?content 鍖哄煙缁勪欢鐨勬帓搴忔寜閽姸鎬?
        doc.querySelectorAll('.tpmst-component-wrapper[data-region="content"]').forEach(wrapper => {
            try {
                const contentZone = wrapper.closest('[data-region="content"]');
                if (!contentZone) return;
                
                const components = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
                const currentIndex = components.indexOf(wrapper);
                
                const moveUpBtn = wrapper.querySelector('.move-up');
                const moveDownBtn = wrapper.querySelector('.move-down');
                
                if (moveUpBtn) {
                    moveUpBtn.disabled = currentIndex === 0;
                }
                if (moveDownBtn) {
                    moveDownBtn.disabled = currentIndex === components.length - 1;
                }
            } catch (e) {
                console.warn('鏇存柊鎺掑簭鎸夐挳鐘舵€佸け璐?', e);
            }
        });
        
    } catch (e) {
        console.warn('鏃犳硶璁剧疆棰勮鏀剧疆鍖哄煙:', e);
    }
};

function handlePreviewDragOver(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
    
    // 濡傛灉鏄?content 鍖哄煙锛屾樉绀烘彃鍏ヤ綅缃寚绀哄櫒
    const targetRegion = this.getAttribute('data-region');
    const isMultiple = this.getAttribute('data-multiple') === 'true';
    
    if (targetRegion === 'content' && isMultiple) {
        showInsertIndicator(e, this);
    }
}

// 鏄剧ず鎻掑叆浣嶇疆鎸囩ず鍣?
function showInsertIndicator(e, dropZone) {
    const components = Array.from(dropZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
    
    // 绉婚櫎涔嬪墠鐨勬寚绀哄櫒
    const existingIndicator = dropZone.querySelector('.insert-indicator');
    if (existingIndicator) {
        existingIndicator.remove();
    }
    
    if (components.length === 0) {
        // 濡傛灉娌℃湁缁勪欢锛屽湪鍖哄煙椤堕儴鏄剧ず鎸囩ず鍣?
        const indicator = document.createElement('div');
        indicator.className = 'insert-indicator';
        dropZone.insertBefore(indicator, dropZone.firstChild);
        return;
    }
    
    // 浣跨敤鐩稿浜?dropZone 鐨勫潗鏍?
    const dropZoneRect = dropZone.getBoundingClientRect();
    const dropY = e.clientY;
    
    // 鎵惧埌榧犳爣浣嶇疆鎵€鍦ㄧ殑缁勪欢鎴栨渶杩戠殑缁勪欢
    let targetComponent = null;
    let insertBefore = true;
    
    for (let i = 0; i < components.length; i++) {
        const component = components[i];
        const rect = component.getBoundingClientRect();
        
        // 妫€鏌ラ紶鏍囨槸鍚﹀湪褰撳墠缁勪欢鍐呴儴
        if (dropY >= rect.top && dropY <= rect.bottom) {
            // 榧犳爣鍦ㄧ粍浠跺唴閮紝鍒ゆ柇鏄湪涓婂崐閮ㄥ垎杩樻槸涓嬪崐閮ㄥ垎
            const componentMiddle = rect.top + rect.height / 2;
            if (dropY < componentMiddle) {
                // 榧犳爣鍦ㄧ粍浠朵笂鍗婇儴鍒嗭紝鍦ㄨ缁勪欢涔嬪墠鎻掑叆
                targetComponent = component;
                insertBefore = true;
            } else {
                // 榧犳爣鍦ㄧ粍浠朵笅鍗婇儴鍒嗭紝鍦ㄨ缁勪欢涔嬪悗鎻掑叆
                targetComponent = component;
                insertBefore = false;
            }
            break;
        }
        
        // 濡傛灉榧犳爣鍦ㄥ綋鍓嶇粍浠朵箣鍓?
        if (dropY < rect.top) {
            targetComponent = component;
            insertBefore = true;
            break;
        }
    }
    
    // 鍒涘缓鎸囩ず鍣?
    const indicator = document.createElement('div');
    indicator.className = 'insert-indicator';
    
    if (targetComponent) {
        if (insertBefore) {
            // 鍦ㄧ洰鏍囩粍浠朵箣鍓嶆彃鍏?
            dropZone.insertBefore(indicator, targetComponent);
        } else {
            // 鍦ㄧ洰鏍囩粍浠朵箣鍚庢彃鍏?
            if (targetComponent.nextSibling) {
                dropZone.insertBefore(indicator, targetComponent.nextSibling);
            } else {
                dropZone.appendChild(indicator);
            }
        }
    } else {
        // 濡傛灉榧犳爣鍦ㄦ墍鏈夌粍浠朵箣鍚庯紝鍦ㄦ渶鍚庝竴涓粍浠朵箣鍚庢彃鍏?
        const lastComponent = components[components.length - 1];
        if (lastComponent.nextSibling) {
            dropZone.insertBefore(indicator, lastComponent.nextSibling);
        } else {
            dropZone.appendChild(indicator);
        }
    }
}

function handlePreviewDragLeave(e) {
    e.preventDefault();
    this.classList.remove('drag-over');
    
    // 绉婚櫎鎻掑叆鎸囩ず鍣?
    const indicator = this.querySelector('.insert-indicator');
    if (indicator) {
        indicator.remove();
    }
}

function handlePreviewDrop(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
    
    // 绉婚櫎鎻掑叆鎸囩ず鍣?
    const indicator = this.querySelector('.insert-indicator');
    if (indicator) {
        indicator.remove();
    }
    
    try {
        const data = JSON.parse(e.dataTransfer.getData('text/plain'));
        const targetRegion = this.getAttribute('data-region');
        const isMultiple = this.getAttribute('data-multiple') === 'true';
        
        // 妫€鏌ュ尯鍩熷尮閰?
        if (data.region !== targetRegion) {
            if (window.parent.BackendToast) {
                window.parent.BackendToast.warning('<?= __('鍖哄煙涓嶅尮閰嶏細姝ょ粍浠跺彧鑳芥斁缃湪') ?> ' + data.region + ' <?= __('鍖哄煙') ?>');
            }
            return;
        }
        
        // 妫€鏌ュ敮涓€鎬?
        const existingComponents = this.querySelectorAll('.tpmst-component-wrapper').length;
        if (!isMultiple && existingComponents > 0) {
            if (window.parent.BackendConfirm) {
                window.parent.BackendConfirm.show('<?= __('') ?>', {
                    title: '<?= __('') ?>',
                    confirmText: '<?= __('纭鏇挎崲') ?>',
                    cancelText: '<?= __('鍙栨秷') ?>'
                }).then((confirmed) => {
                    if (confirmed) {
                        window.parent.addComponentToLayout(data, targetRegion, true);
                    }
                });
            }
            return;
        }
        
        // 璁＄畻鎻掑叆浣嶇疆锛堜粎瀵?content 鍖哄煙鏈夋晥锛?
        let insertPosition = null;
        if (targetRegion === 'content' && isMultiple) {
            insertPosition = calculateInsertPosition(e, this);
        }
        
        // 娣诲姞缁勪欢
        window.parent.addComponentToLayout(data, targetRegion, false, insertPosition);
        
    } catch (err) {
        console.error('Drop error:', err);
    }
}

// 璁＄畻鎻掑叆浣嶇疆
function calculateInsertPosition(e, dropZone) {
    const components = Array.from(dropZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
    
    if (components.length === 0) {
        return 0; // 绗竴涓綅缃?
    }
    
    const dropY = e.clientY;
    
    // 鎵惧埌榧犳爣浣嶇疆鎵€鍦ㄧ殑缁勪欢鎴栨渶杩戠殑缁勪欢
    for (let i = 0; i < components.length; i++) {
        const component = components[i];
        const rect = component.getBoundingClientRect();
        
        // 妫€鏌ラ紶鏍囨槸鍚﹀湪褰撳墠缁勪欢鍐呴儴
        if (dropY >= rect.top && dropY <= rect.bottom) {
            // 榧犳爣鍦ㄧ粍浠跺唴閮紝鍒ゆ柇鏄湪涓婂崐閮ㄥ垎杩樻槸涓嬪崐閮ㄥ垎
            const componentMiddle = rect.top + rect.height / 2;
            if (dropY < componentMiddle) {
                // 榧犳爣鍦ㄧ粍浠朵笂鍗婇儴鍒嗭紝鍦ㄨ缁勪欢涔嬪墠鎻掑叆
                return i;
            } else {
                // 榧犳爣鍦ㄧ粍浠朵笅鍗婇儴鍒嗭紝鍦ㄨ缁勪欢涔嬪悗鎻掑叆
                return i + 1;
            }
        }
        
        // 濡傛灉榧犳爣鍦ㄥ綋鍓嶇粍浠朵箣鍓?
        if (dropY < rect.top) {
            return i;
        }
    }
    
    // 濡傛灉榧犳爣鍦ㄦ墍鏈夌粍浠朵箣鍚庯紝鎻掑叆鍒版湯灏?
    return components.length;
}

// 鏇存柊鎺掑簭鎸夐挳鐨勭鐢ㄧ姸鎬?
function updateSortButtonsState(wrapper) {
    try {
        // wrapper 宸茬粡鏄?iframe 鍐呯殑鍏冪礌
        const contentZone = wrapper.closest('[data-region="content"]');
        if (!contentZone) return;
        
        const components = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        const currentIndex = components.indexOf(wrapper);
        
        const moveUpBtn = wrapper.querySelector('.move-up');
        const moveDownBtn = wrapper.querySelector('.move-down');
        
        if (moveUpBtn) {
            moveUpBtn.disabled = currentIndex === 0;
        }
        if (moveDownBtn) {
            moveDownBtn.disabled = currentIndex === components.length - 1;
        }
    } catch (e) {
        console.warn('鏇存柊鎺掑簭鎸夐挳鐘舵€佸け璐?', e);
    }
}

// 閫氳繃绱㈠紩涓婄Щ缁勪欢
window.moveComponentUpByIndex = async function(componentIndex) {
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) return;
    
    try {
        const doc = previewFrame.contentWindow.document;
        const contentZone = doc.querySelector('[data-region="content"]');
        if (!contentZone) return;
        
        // 鏌ユ壘鎵€鏈塩ontent鍖哄煙鐨勭粍浠?
        const components = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        
        // 閫氳繃data-index鏌ユ壘鐩爣缁勪欢锛堟敮鎸佸瓧绗︿覆鍜屾暟瀛楀尮閰嶏級
        const wrapper = components.find(w => {
            const idx = w.getAttribute('data-index');
            return idx === String(componentIndex) || idx === componentIndex;
        });
        
        if (!wrapper) {
            console.warn('鏈壘鍒扮粍浠讹紝index:', componentIndex);
            return;
        }
        
        const currentIndex = components.indexOf(wrapper);
        
        if (currentIndex <= 0) return; // 宸茬粡鏄涓€涓?
        
        // 淇濆瓨鎵€鏈夌粍浠剁殑鍘熷绱㈠紩锛堝湪绉诲姩涔嬪墠锛?
        // 濡傛灉缁勪欢杩樻病鏈?data-original-index锛屽垯浣跨敤褰撳墠鐨?data-index 浣滀负鍘熷绱㈠紩
        components.forEach((comp, idx) => {
            if (!comp.hasAttribute('data-original-index')) {
                const currentIdx = comp.getAttribute('data-index');
                comp.setAttribute('data-original-index', currentIdx !== null ? currentIdx : String(idx));
            }
        });
        
        // 浜ゆ崲 DOM 浣嶇疆
        const prevComponent = components[currentIndex - 1];
        contentZone.insertBefore(wrapper, prevComponent);
        
        // 鏇存柊鎵€鏈夌粍浠剁殑data-index锛堜繚鎸乨ata-original-index涓嶅彉锛?
        const updatedComponents = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        updatedComponents.forEach((comp, idx) => {
            comp.setAttribute('data-index', String(idx));
        });
        
        // 淇濆瓨鏂伴『搴?
        await saveComponentOrder();
        
        // 鏇存柊鎸夐挳鐘舵€侊紙鍦╥frame涓洿鎺ユ洿鏂帮級
        updatedComponents.forEach(w => {
            try {
                const moveUpBtn = w.querySelector('.move-up');
                const moveDownBtn = w.querySelector('.move-down');
                const currentIdx = updatedComponents.indexOf(w);
                
                if (moveUpBtn) {
                    moveUpBtn.disabled = currentIdx === 0;
                }
                if (moveDownBtn) {
                    moveDownBtn.disabled = currentIdx === updatedComponents.length - 1;
                }
            } catch (e) {
                console.warn('鏇存柊鎸夐挳鐘舵€佸け璐?', e);
            }
        });
    } catch (e) {
        console.error('涓婄Щ缁勪欢澶辫触:', e);
        if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    }
};

// 閫氳繃绱㈠紩涓嬬Щ缁勪欢
window.moveComponentDownByIndex = async function(componentIndex) {
    console.log('moveComponentDownByIndex 琚皟鐢紝componentIndex:', componentIndex);
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) {
        console.warn('涓嬬Щ缁勪欢澶辫触: 鏃犳硶璁块棶棰勮iframe');
        return;
    }
    
    try {
        const doc = previewFrame.contentWindow.document;
        const contentZone = doc.querySelector('[data-region="content"]');
        if (!contentZone) {
            console.warn('涓嬬Щ缁勪欢澶辫触: 鏈壘鍒癱ontent鍖哄煙');
            return;
        }
        
        // 鏌ユ壘鎵€鏈塩ontent鍖哄煙鐨勭粍浠?
        const components = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        console.log('鎵惧埌缁勪欢鏁伴噺:', components.length);
        
        // 閫氳繃data-index鏌ユ壘鐩爣缁勪欢锛堟敮鎸佸瓧绗︿覆鍜屾暟瀛楀尮閰嶏級
        const wrapper = components.find(w => {
            const idx = w.getAttribute('data-index');
            return idx === String(componentIndex) || idx === componentIndex;
        });
        
        if (!wrapper) {
            console.warn('涓嬬Щ缁勪欢澶辫触: 鏈壘鍒扮粍浠讹紝index:', componentIndex, '鎵€鏈夌储寮?', components.map(w => w.getAttribute('data-index')));
            return;
        }
        
        const currentIndex = components.indexOf(wrapper);
        console.log('褰撳墠缁勪欢绱㈠紩:', currentIndex, '鎬荤粍浠舵暟:', components.length);
        
        if (currentIndex >= components.length - 1) {
            console.log('涓嬬Щ缁勪欢: 宸茬粡鏄渶鍚庝竴涓紝鏃犻渶绉诲姩');
            return; // 宸茬粡鏄渶鍚庝竴涓?
        }
        
        // 淇濆瓨鎵€鏈夌粍浠剁殑鍘熷绱㈠紩锛堝湪绉诲姩涔嬪墠锛?
        // 濡傛灉缁勪欢杩樻病鏈?data-original-index锛屽垯浣跨敤褰撳墠鐨?data-index 浣滀负鍘熷绱㈠紩
        components.forEach((comp, idx) => {
            if (!comp.hasAttribute('data-original-index')) {
                const currentIdx = comp.getAttribute('data-index');
                comp.setAttribute('data-original-index', currentIdx !== null ? currentIdx : String(idx));
            }
        });
        
        // 浜ゆ崲 DOM 浣嶇疆
        // 涓嬬Щ锛氬皢 wrapper 鎻掑叆鍒颁笅涓€涓粍浠朵箣鍚?
        // 鍙傜収涓婄Щ鍑芥暟鐨勯€昏緫锛氫笂绉绘槸 insertBefore(wrapper, prevComponent)
        // 涓嬬Щ闇€瑕佹彃鍏ュ埌 nextComponent 涔嬪悗锛屽嵆鎻掑叆鍒?nextComponent.nextSibling 涔嬪墠
        const nextComponent = components[currentIndex + 1];
        
        // 鑾峰彇涓嬩竴涓粍浠剁殑涓嬩竴涓厔寮熻妭鐐癸紙鍦ㄧЩ鍔ㄤ箣鍓嶈幏鍙栵紝閬垮厤绉诲姩鍚庡紩鐢ㄥけ鏁堬級
        const nextSibling = nextComponent.nextSibling;
        
        // 灏?wrapper 鎻掑叆鍒?nextSibling 涔嬪墠锛堝嵆 nextComponent 涔嬪悗锛?
        // 濡傛灉 nextSibling 涓?null锛宨nsertBefore 浼氳嚜鍔ㄨ拷鍔犲埌鏈熬锛堣繖姝ｆ槸鎴戜滑鎯宠鐨勶級
        contentZone.insertBefore(wrapper, nextSibling);
        
        // 鏇存柊鎵€鏈夌粍浠剁殑data-index锛堜繚鎸乨ata-original-index涓嶅彉锛?
        const updatedComponents = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        updatedComponents.forEach((comp, idx) => {
            comp.setAttribute('data-index', String(idx));
        });
        
        // 淇濆瓨鏂伴『搴?
        await saveComponentOrder();
        
        // 鏇存柊鎸夐挳鐘舵€侊紙鍦╥frame涓洿鎺ユ洿鏂帮級
        updatedComponents.forEach(w => {
            try {
                const moveUpBtn = w.querySelector('.move-up');
                const moveDownBtn = w.querySelector('.move-down');
                const currentIdx = updatedComponents.indexOf(w);
                
                if (moveUpBtn) {
                    moveUpBtn.disabled = currentIdx === 0;
                }
                if (moveDownBtn) {
                    moveDownBtn.disabled = currentIdx === updatedComponents.length - 1;
                }
            } catch (e) {
                console.warn('鏇存柊鎸夐挳鐘舵€佸け璐?', e);
            }
        });
    } catch (e) {
        console.error('涓嬬Щ缁勪欢澶辫触:', e);
        if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    }
};

// 淇濆瓨缁勪欢椤哄簭
async function saveComponentOrder() {
    const previewFrame = document.getElementById('previewIframe');
    if (!previewFrame || !previewFrame.contentWindow) return;
    
    try {
        const doc = previewFrame.contentWindow.document;
        const contentZone = doc.querySelector('[data-region="content"]');
        if (!contentZone) return;
        
        // 鑾峰彇褰撳墠 DOM 椤哄簭鐨勭粍浠跺師濮嬬储寮?
        // 鍚庣鏈熸湜鐨勬槸锛氭棫绱㈠紩鐨勬柊椤哄簭鏁扮粍锛屼緥濡?[1, 0, 2] 琛ㄧず鏂伴『搴忔槸锛氭棫绱㈠紩1鐨勭粍浠躲€佹棫绱㈠紩0鐨勭粍浠躲€佹棫绱㈠紩2鐨勭粍浠?
        const components = Array.from(contentZone.querySelectorAll('.tpmst-component-wrapper[data-region="content"]'));
        const newOrder = components.map(wrapper => {
            // 浼樺厛浣跨敤 data-original-index锛屽鏋滄病鏈夊垯浣跨敤 data-index
            const originalIdx = wrapper.getAttribute('data-original-index');
            if (originalIdx !== null) {
                return parseInt(originalIdx, 10);
            }
            return parseInt(wrapper.getAttribute('data-index') || '0', 10);
        });
        
        const identity = getVisualIdentity();
        if (!identity.isVirtual && !identity.pageId) {
            console.error('椤甸潰ID鏈畾涔?);
            return;
        }
        
        // 娣囨繂鐡ㄥ姘З娴ｅ秶鐤?        let savedScrollX = 0;
        let savedScrollY = 0;
        try {
            if (previewFrame.contentWindow) {
                savedScrollX = previewFrame.contentWindow.scrollX || 0;
                savedScrollY = previewFrame.contentWindow.scrollY || 0;
            }
        } catch (e) {}
        
        // 鐠嬪啰鏁?API 娣囨繂鐡ㄩ弬浼淬€庢惔?
        var url = '<?= $this->getBackendUrl('*/backend/visual/api/component/reorder') ?>';
        const reorderPayload = applyVisualIdentityToPayload({ page_id: identity.pageId, region: 'content', order: newOrder });
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(reorderPayload) };        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (result.success) {
            // 鍒锋柊棰勮浠ユ洿鏂扮储寮?
            if (typeof refreshPreview === 'function') {
                refreshPreview({ scrollX: savedScrollX, scrollY: savedScrollY });
            }
        } else {
            console.error('鎺掑簭澶辫触:', result.message);
            BackendToast.error('<?= __('鎺掑簭澶辫触') ?>锛? + (result.message || '<?= __('鏈煡閿欒') ?>'));
            // 濡傛灉澶辫触锛屾仮澶嶅師鏉ョ殑椤哄簭
            if (typeof refreshPreview === 'function') {
                refreshPreview();
            }
        }
    } catch (err) {
        console.error('鎺掑簭閿欒:', err);
        BackendToast.error('<?= __('鎺掑簭澶辫触') ?>锛? + (err.message || '<?= __('鏈煡閿欒') ?>'));
        // 濡傛灉鍑洪敊锛屾仮澶嶅師鏉ョ殑椤哄簭
        if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    }
}

// 娣诲姞缁勪欢鍒板竷灞€
window.addComponentToLayout = async function(componentData, region, replace = false, position = null) {
    const identity = getVisualIdentity();
    const pageId = (window.isTemplateConfigMode && window.currentTemplatePageId) ? window.currentTemplatePageId : identity.pageId;
    const iframe = document.getElementById('previewIframe');
    let savedScrollX = 0;
    let savedScrollY = 0;

    try {
        if (iframe && iframe.contentWindow && iframe.contentDocument) {
            savedScrollX = iframe.contentWindow.scrollX || iframe.contentDocument.documentElement.scrollLeft || 0;
            savedScrollY = iframe.contentWindow.scrollY || iframe.contentDocument.documentElement.scrollTop || 0;
        }
    } catch (e) {
        // Ignore cross-origin read failures from the preview iframe.
    }

    if (!window.isTemplateConfigMode && !identity.isVirtual && !pageId) {
        BackendToast.error('<?= __('错误：页面ID未定义，请刷新页面重试') ?>');
        return;
    }

    try {
        let requestData = {
            page_id: pageId,
            component_code: componentData.code,
            region: region,
            replace: replace,
            template_code: componentData.template || ''
        };

        if (typeof window.visualWelineThemeId === 'number' && window.visualWelineThemeId > 0) {
            requestData.weline_theme_id = window.visualWelineThemeId;
        }

        if (region === 'content' && position !== null && position !== undefined) {
            requestData.position = position;
        }

        if (!window.isTemplateConfigMode) {
            requestData = applyVisualIdentityToPayload(requestData);
        }

        var url = '<?= $this->getBackendUrl('*/backend/visual/api/component/add') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestData) };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;

        if (result.success) {
            if (typeof refreshPreview === 'function') {
                refreshPreview({ scrollX: savedScrollX, scrollY: savedScrollY });
            }
            BackendToast.success('<?= __('组件已添加') ?>' + '：' + componentData.name + ' - ' + region);
        } else {
            console.error('Add component failed:', result.message);
            BackendToast.error('<?= __('添加失败') ?>' + '：' + (result.message || '<?= __('未知错误') ?>'));
        }
    } catch (error) {
        console.error('Add component error:', error);
        BackendToast.error('<?= __('添加失败') ?>' + '：' + (error.message || '<?= __('网络错误') ?>'));
    }
};
window.editComponentInPreview = async function(wrapper) {
    const componentCode = wrapper.getAttribute('data-component');
    const region = wrapper.getAttribute('data-region');
    const index = parseInt(wrapper.getAttribute('data-index') || '0', 10);
    const identity = getVisualIdentity();
    const pageId = identity.pageId;
    const iframe = document.getElementById('previewIframe');

    let savedScrollX = 0;
    let savedScrollY = 0;
    try {
        if (iframe && iframe.contentWindow && iframe.contentDocument) {
            savedScrollX = iframe.contentWindow.scrollX || iframe.contentDocument.documentElement.scrollLeft || 0;
            savedScrollY = iframe.contentWindow.scrollY || iframe.contentDocument.documentElement.scrollTop || 0;
        }
    } catch (e) {
        console.warn('Unable to read preview scroll position:', e);
    }

    if (!identity.isVirtual && !pageId) {
        BackendToast.error('<?= __('错误：页面ID未定义') ?>');
        return;
    }

    BackendToast.info('<?= __('加载配置...') ?>', 2000);

    try {
        const componentStyleCode = wrapper.getAttribute('data-style-code');
        const styleSelect = document.getElementById('style');
        const pageStyleCode = styleSelect ? styleSelect.value : (window.currentStyle || 'tpmst');
        const styleCode = (componentStyleCode || pageStyleCode || 'tpmst').trim() || 'tpmst';

        const metadataUrl = '<?= $this->getBackendUrl('*/backend/visual/api/component/metadata') ?>' +
            '?component_code=' + encodeURIComponent(componentCode) +
            '&style_code=' + encodeURIComponent(styleCode);

        var metaRes = await window.Weline.Api.get(metadataUrl, { silent: true });
        const metaResult = (metaRes && metaRes.data) || metaRes;
        const payload = (metaResult && metaResult.data != null) ? metaResult.data : metaResult;
        const metadata = (payload && payload.metadata != null) ? payload.metadata : (metaResult && metaResult.metadata) || null;

        if (!metadata || typeof metadata !== 'object') {
            const errMsg = (payload && (payload.message || payload.msg)) || (metaResult && (metaResult.message || metaResult.msg)) || '<?= __('获取组件信息失败') ?>';
            throw new Error(errMsg);
        }
        if (payload && payload.success === false) {
            const errMsg = (payload.message || payload.msg) || '<?= __('获取组件信息失败') ?>';
            throw new Error(errMsg);
        }

        let layoutUrl = '<?= $this->getBackendUrl('*/backend/visual/api/component/layoutFields') ?>';
        if (identity.isVirtual) {
            layoutUrl += '?public_id=' + encodeURIComponent(identity.publicId) +
                '&page_type=' + encodeURIComponent(identity.pageType);
            if (identity.virtualThemeId) {
                layoutUrl += '&virtual_theme_id=' + encodeURIComponent(String(identity.virtualThemeId));
            }
        } else {
            layoutUrl += '?page_id=' + encodeURIComponent(String(pageId));
        }

        var layoutRes = await window.Weline.Api.get(layoutUrl, { silent: true });
        const layoutResult = (layoutRes && layoutRes.data) || layoutRes;

        let currentConfig = {};
        if (layoutResult.success && layoutResult.layout_config && layoutResult.layout_config[region]) {
            const componentInLayout = layoutResult.layout_config[region][index];
            if (componentInLayout && componentInLayout.code === componentCode) {
                currentConfig = componentInLayout.config || {};
            }
        }
        const fields = metadata.fields || {};
        
        // 妫€鏌ユ槸鍚︽湁鏂囧瓧绫诲瀷鐨勯厤缃」锛堢敤浜庡垽鏂槸鍚︽樉绀篈I鎸夐挳锛?
        let hasTextFields = false;
        for (const [groupKey, group] of Object.entries(fields)) {
            for (const [fieldKey, field] of Object.entries(group.fields || {})) {
                if (['text', 'textarea'].includes(field.type || 'text')) {
                    hasTextFields = true;
                    break;
                }
            }
            if (hasTextFields) break;
        }
        
        // 鏋勫缓閰嶇疆琛ㄥ崟HTML
        let formHtml = '<div class="component-config-form" style="text-align: left; max-height: 60vh; overflow-y: auto; padding: 0 4px;">';
        
        // 娣诲姞 AI 鐢熸垚鎸夐挳锛堜粎褰撴湁鏂囧瓧閰嶇疆椤逛笖AI鍔熻兘寮€鍚椂鏄剧ず锛?
        <?php if (($ai_enabled ?? '0') === '1'): ?>
        if (hasTextFields && Object.keys(fields).length > 0) {
            const currentTypePrompt = (typeof window.PB_AI_CURRENT_PAGE_TYPE_PROMPT !== 'undefined' ? window.PB_AI_CURRENT_PAGE_TYPE_PROMPT : '');
            const currentTypeName = (typeof window.PB_AI_CURRENT_PAGE_TYPE_NAME !== 'undefined' ? window.PB_AI_CURRENT_PAGE_TYPE_NAME : '');
            const accordionId = 'aiCompConfigAccordion_' + Date.now();
            const collapse1 = 'aiCompTypePrompt_' + Date.now();
            const collapse2 = 'aiCompHowItWorks_' + Date.now();
            const aiPromptValue = (currentConfig._ai_prompt !== undefined && currentConfig._ai_prompt !== null) ? String(currentConfig._ai_prompt) : '';
            formHtml += '<div class="ai-generate-bar" style="margin-bottom: 16px; padding: 10px; background: linear-gradient(135deg, rgba(102,126,234,0.1) 0%, rgba(118,75,162,0.1) 100%); border-radius: 8px; border: 1px solid rgba(102,126,234,0.2);">';
            formHtml += '<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">';
            formHtml += '<span style="font-size: 12px; opacity: 0.8;"><i class="mdi mdi-robot" style="margin-right: 4px;"></i><?= __('') ?></span>';
            formHtml += '<button type="button" id="aiGenerateComponentConfigBtn" class="btn btn-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; padding: 4px 12px; font-size: 12px;">';
            formHtml += '<i class="mdi mdi-auto-fix"></i> <?= __('AI鐢熸垚') ?>';
