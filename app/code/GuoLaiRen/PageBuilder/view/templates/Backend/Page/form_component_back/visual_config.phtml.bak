<!-- 鍙鍖栭厤缃鍣?-->
<div class="visual-config-wrapper" id="visualConfigWrapper" data-theme="<?= htmlspecialchars($themeMode) ?>">
    <!-- 椤堕儴宸ュ叿鏍?-->
    <div class="visual-toolbar">
        <div class="visual-toolbar-left">
            <button type="button" class="btn btn-sm btn-light" onclick="closeVisualConfig()">
                <i class="mdi mdi-close"></i> <?= __('') ?>
