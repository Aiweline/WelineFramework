            <span id="templateInfoBadge" class="ms-2 small text-light" style="opacity:.85; display:none;"></span>
            <?php if (isset($this) && $this->getData('is_template_config_mode')): ?>
            <span class="system-test-badge" style="background: #f39c12; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 600; display: inline-flex; align-items: center; gap: 3px;">
                <i class="mdi mdi-test-tube"></i> <?= __('娴嬭瘯') ?>
            </span>
            <?php endif; ?>
        </div>
        
        <div class="visual-toolbar-center">
            <!-- 璁惧鍒囨崲 -->
            <button type="button" class="device-btn active" data-device="desktop" onclick="switchDevice('desktop')">
                <i class="mdi mdi-monitor"></i> <?= __('妗岄潰') ?>
            </button>
            <button type="button" class="device-btn" data-device="tablet" onclick="switchDevice('tablet')">
                <i class="mdi mdi-tablet"></i> <?= __('骞虫澘') ?>
            </button>
            <button type="button" class="device-btn" data-device="mobile" onclick="switchDevice('mobile')">
                <i class="mdi mdi-cellphone"></i> <?= __('鎵嬫満') ?>
            </button>
            
            <!-- 鍏ㄥ睆鍒囨崲 -->
            <button type="button" class="fullscreen-btn" id="fullscreenBtn" onclick="toggleFullscreen()" title="<?= __('鍏ㄥ睆妯″紡') ?>">
                <i class="mdi mdi-fullscreen"></i>
            </button>
            
            <!-- 璇█鍒囨崲 -->
            <?php
            // 鑾峰彇椤甸潰璇█淇℃伅锛堟ā鏉块厤缃ā寮忎笅浣跨敤娴嬭瘯椤甸潰锛?
            $pageForLanguage = $page;
            if (isset($this) && $this->getData('is_template_config_mode')) {
                // 妯℃澘閰嶇疆妯″紡涓嬶紝濡傛灉鏈夋祴璇曢〉闈紝浣跨敤娴嬭瘯椤甸潰鐨勮瑷€
                $testPage = $this->getData('page');
                if ($testPage && $testPage->getId()) {
                    $pageForLanguage = $testPage;
                }
            }
            
            $pageDefaultLocale = '';
            $pageLocales = [];
            if ($pageForLanguage && $pageForLanguage->getId()) {
                $pageDefaultLocale = $pageForLanguage->getData('default_locale') ?: '';
                $localesData = $pageForLanguage->getData('locales');
                if ($localesData && is_string($localesData)) {
                    $pageLocales = json_decode($localesData, true) ?: [];
                } elseif (is_array($localesData)) {
                    $pageLocales = $localesData;
                }
            }
            ?>
            <?php if (($i18n_enabled ?? '0') === '1' && (!empty($pageDefaultLocale) || !empty($pageLocales))): ?>
            <div class="language-switcher-visual">
                <i class="mdi mdi-translate"></i>
                <select id="visualLanguageSelect" class="form-select form-select-sm" onchange="switchVisualLanguage(this.value)">
                    <?php 
                    // 濡傛灉椤甸潰鏈夐粯璁よ瑷€锛屾樉绀洪粯璁よ瑷€
                    if ($pageDefaultLocale) {
                        $i18nInstance = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\I18n\Model\I18n::class);
                        $defaultLocaleName = $i18nInstance->getLocaleName($pageDefaultLocale);
                        echo '<option value="' . htmlspecialchars($pageDefaultLocale ?? '') . '" selected>' . htmlspecialchars($defaultLocaleName ?? '') . '</option>';
                    }
                    
                    // 鏄剧ず鍏朵粬璇█
                    foreach ($pageLocales as $locale) {
                        if ($locale === $pageDefaultLocale) continue; // 璺宠繃榛樿璇█
                        $i18nInstance = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\I18n\Model\I18n::class);
                        $localeName = $i18nInstance->getLocaleName($locale);
                        echo '<option value="' . htmlspecialchars($locale ?? '') . '">' . htmlspecialchars($localeName ?? '') . '</option>';
                    }
                    ?>
                </select>
            </div>
            <?php endif; ?>
        </div>
        
        <div class="visual-toolbar-right">
            <!-- AI涓€閿敓鎴愭ā鏉块厤缃?-->
            <?php if (($ai_enabled ?? '0') === '1'): ?>
            <button type="button" 
                    class="btn btn-sm btn-gradient-primary" 
                    onclick="generateTemplateConfig()"
                    id="aiGenerateTemplateConfigBtn"
                    title="<?= __('') ?>">
                <i class="mdi mdi-robot"></i> <?= __('AI鐢熸垚閰嶇疆') ?>
            </button>
            <?php endif; ?>
            
            <!-- PageSpeed Insights锛堟墜鏈虹锛屽熀浜庡綋鍓嶉瑙圲RL锛?-->
            <?php
            $isPagePublished = $page && $page->getData('status') == \GuoLaiRen\PageBuilder\Model\Page::STATUS_PUBLISHED;
            $psiBtnDisabled = !$isPagePublished;
            $psiBtnClass = $psiBtnDisabled ? 'btn btn-sm btn-secondary' : 'btn btn-sm btn-success';
            $psiBtnTitle = $psiBtnDisabled 
                ? __('...')
                : __('PageSpeed 娴嬭瘯锛堟墜鏈猴級');
            ?>
            <button type="button"
                    id="psiMobileBtn"
                    class="<?= $psiBtnClass ?>"
                    data-base-url="<?= rtrim(rtrim($this->request->getBaseHost(), '/'), ':') ?>"
                    data-is-published="<?= $isPagePublished ? '1' : '0' ?>"
                    <?= $psiBtnDisabled ? 'disabled' : '' ?>
                    onclick="openPageSpeedMobile()"
                    title="<?= $psiBtnTitle ?>">
                <i class="mdi mdi-speedometer"></i> <?= __('PageSpeed锛堟墜鏈猴級') ?>
            </button>

            <!-- 鏂囦欢绠＄悊鍣?-->
            <button type="button" class="btn btn-sm btn-secondary" onclick="openAssetManager()" title="<?= __('') ?>">
                <i class="mdi mdi-folder"></i> <?= __('鏂囦欢绠＄悊') ?>
            </button>
            
            <!-- 閰嶇疆瀵煎叆瀵煎嚭 -->
            <button type="button" 
                    class="btn btn-sm btn-info" 
                    onclick="exportPageConfig()"
                    id="exportConfigBtn"
                    title="<?= __('瀵煎嚭閰嶇疆') ?>">
                <i class="mdi mdi-download"></i> <?= __('瀵煎嚭閰嶇疆') ?>
            </button>
            <button type="button" 
                    class="btn btn-sm btn-warning" 
                    onclick="importPageConfig()"
                    id="importConfigBtn"
                    title="<?= __('瀵煎叆閰嶇疆') ?>">
                <i class="mdi mdi-upload"></i> <?= __('瀵煎叆閰嶇疆') ?>
            </button>
            
            <!-- 淇濆瓨鐘舵€?-->
            <div class="save-status" id="saveStatus">
                <i class="mdi mdi-check-circle"></i> <span id="saveStatusText"><?= __('') ?></span>
            </div>
            
            <!-- 鍒锋柊閰嶇疆鎸夐挳锛堜粎鍦ㄦā鏉块厤缃ā寮忔樉绀猴級 -->
            <?php if (isset($this) && $this->getData('is_template_config_mode')): ?>
            <button type="button" class="btn btn-sm btn-warning" onclick="refreshTemplateConfig(event)" title="<?= __('閲嶆柊鍔犺浇閰嶇疆瀛楁') ?>">
                <i class="mdi mdi-refresh"></i> <?= __('鍒锋柊閰嶇疆') ?>
            </button>
            <?php endif; ?>
            
            <!-- 鍒锋柊棰勮 -->
            <button type="button" class="btn btn-sm btn-info" onclick="refreshPreview()">
                <i class="mdi mdi-refresh"></i> <?= __('鍒锋柊') ?>
            </button>
        </div>
    </div>
    
