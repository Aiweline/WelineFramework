<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<!-- 鏃╂湡鎸傝浇涓€涓叏灞€鍏ュ彛锛岀‘淇濊〃鍗曞彲璋冪敤锛屽嵆浣夸富鑴氭湰寤惰繜/寮傚父 -->
<script>
if (typeof window.openVisualConfig === 'undefined') {
    window.openVisualConfig = function(passedHandle) {
        try {
            if (passedHandle && typeof passedHandle === 'string') {
                window.visualConfigHandle = passedHandle.trim();
            }
            var wrapper = document.getElementById('visualConfigWrapper');
            if (wrapper) {
                wrapper.classList.add('active');
                document.body.style.overflow = 'hidden';
                
                // 榛樿杩涘叆鍏ㄥ睆妯″紡骞舵敹璧烽厤缃爮
                wrapper.classList.add('fullscreen-mode');
                
                var fullscreenBtn = document.getElementById('fullscreenBtn');
                if (fullscreenBtn) {
                    fullscreenBtn.classList.add('active');
                    var icon = fullscreenBtn.querySelector('i');
                    if (icon) {
                        icon.className = 'mdi mdi-fullscreen-exit';
                    }
                }
                
                var configPanel = document.getElementById('configPanel');
                if (configPanel) {
                    configPanel.classList.add('collapsed');
                }
                
                var floatingBtn = document.getElementById('floatingExpandBtn');
                if (floatingBtn) {
                    floatingBtn.style.display = 'block';
                }
            }
            if (typeof window.visualConfigLazyInit === 'function') {
                window.visualConfigLazyInit();
            } else if (typeof window.openVisualConfigCore === 'function') {
                // 鍏煎锛氬鏋滄牳蹇冨嚱鏁板凡瀹氫箟
                window.openVisualConfigCore(passedHandle);
            } else {
                console.warn('[VisualConfig] 缁勪欢鏈畬鍏ㄥ氨缁紝绋嶅悗灏嗙户缁垵濮嬪寲');
                setTimeout(function(){
                    if (typeof window.visualConfigLazyInit === 'function') {
                        window.visualConfigLazyInit();
                    }
                }, 100);
            }
        } catch (e) {
            console.error('[VisualConfig] 鎵撳紑鍏ュ彛鍑洪敊:', e);
        }
    };
}
</script>
<script>
// ========== 缁勪欢鍒濆鍖栵細鏀寔閫氳繃 handle 鎴?page_id 鍒濆鍖?==========
// 浣跨敤鍞竴鐨勫垵濮嬪寲鏍囪瘑锛岄伩鍏嶅湪 iframe 鐜涓噸澶嶅垵濮嬪寲瀵艰嚧鍐呭瓨鑰楀敖
(function() {
    // 妫€鏌ユ槸鍚﹀凡缁忓湪褰撳墠 window 涓垵濮嬪寲杩囷紙闃叉閲嶅鎵ц锛?
    const initKey = 'visualConfigInit_' + (window.location.href || 'default');
    if (window[initKey]) {
        return;
    }
    window[initKey] = true;
    
    // 鍒濆鍖栧叏灞€鍙橀噺锛堝彧鍦ㄦ湭瀹氫箟鏃惰缃紝閬垮厤瑕嗙洊宸叉湁鍊硷級
    window.visualConfigInitialized = window.visualConfigInitialized || false;
    window.visualPageId = window.visualPageId || null;
    // AI 缁勪欢閰嶇疆鐢熸垚锛氬綋鍓嶉〉闈㈢被鍨嬨€侀〉闈㈡弿杩般€佺被鍨嬫彁绀鸿瘝锛堜緵鎵嬮鐞村睍绀猴級
    window.PB_AI_PAGE_TYPE = <?= json_encode($pageType, JSON_UNESCAPED_UNICODE) ?>;
    window.PB_AI_AI_DESCRIPTION = <?= json_encode($aiDescription, JSON_UNESCAPED_UNICODE) ?>;
    window.PB_AI_CURRENT_PAGE_TYPE_PROMPT = <?= json_encode($currentPageTypePrompt, JSON_UNESCAPED_UNICODE) ?>;
    window.PB_AI_CURRENT_PAGE_TYPE_NAME = <?= json_encode($currentPageTypeName, JSON_UNESCAPED_UNICODE) ?>;
    window.PB_AI_SSE_TERMINAL_HTML = <?= json_encode($aiComponentConfigSseTerminalHtml, JSON_UNESCAPED_UNICODE) ?>;
    window.visualConfigHandle = window.visualConfigHandle || null;
    window.currentVisualLanguage = window.currentVisualLanguage || '';
    window.defaultLanguage = window.defaultLanguage || '';
    window.visualWelineThemeId = <?= (int) $welineThemeId ?>;
    window.visualIsVirtualMode = <?= $visualIsVirtualMode ? 'true' : 'false' ?>;
    window.visualPublicId = <?= json_encode($visualPublicId, JSON_UNESCAPED_UNICODE) ?>;
    window.visualPageType = window.visualPageType || <?= json_encode($visualPageType, JSON_UNESCAPED_UNICODE) ?>;
    window.visualVirtualThemeId = <?= (int) $welineThemeId ?>;
    window.visualPageTreeData = <?= json_encode($virtualPagesByType, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    window.currentStyle = window.currentStyle || <?= json_encode($visualStyleCode, JSON_UNESCAPED_UNICODE) ?>;
    
    // 寤惰繜鍒濆鍖栵紝绛夊緟 DOM 瀹屽叏鍔犺浇鍚庡啀鎵ц锛堥伩鍏嶅湪 iframe 涓珛鍗虫墽琛屽鑷村唴瀛橀棶棰橈級
    const initVisualConfig = function() {
        // 濡傛灉宸茬粡鍒濆鍖栬繃锛岀洿鎺ヨ繑鍥?
        if (window.visualConfigInitialized) {
            return;
        }
        
        // 鍙湁鍦ㄥ彲瑙嗗寲閰嶇疆瀹瑰櫒瀛樺湪鏃舵墠鍒濆鍖?
        if (!document.getElementById('visualConfigWrapper')) {
            // 瀹瑰櫒涓嶅瓨鍦紝鍙兘鏄湪 iframe 涓姩鎬佸姞杞斤紝寤惰繜閲嶈瘯
            setTimeout(initVisualConfig, 100);
            return;
        }
        
        // 灏濊瘯浠庡涓潵婧愯幏鍙?handle 鍜?page_id锛堜紭鍏堜娇鐢ㄥ閮ㄤ紶鍏ョ殑鍏ㄥ眬鍊硷級
        let handle = (typeof window.visualConfigHandle !== 'undefined' && window.visualConfigHandle) ? window.visualConfigHandle : '<?= htmlspecialchars($handle ?? '') ?>';
        let pageId = <?= $pageId ?: 'null' ?>;
        
        // 濡傛灉 handle 涓虹┖锛屽皾璇曚粠 DOM 鑾峰彇
        if (!handle) {
            const handleInput = document.getElementById('handle');
            if (handleInput) {
                handle = handleInput.value.trim();
            }
        }
        
        // 濡傛灉 pageId 涓虹┖锛屽皾璇曚粠鍏ㄥ眬鍙橀噺鑾峰彇
        if (!pageId && typeof window.visualPageId !== 'undefined' && window.visualPageId) {
            pageId = window.visualPageId;
        }
        if (window.visualIsVirtualMode) {
            window.visualPageId = 0;
            window.visualConfigHandle = handle;
            updateVirtualBaseFieldsForCurrentPage();
            window.visualConfigInitialized = true;
            return;
        }
        
        // 濡傛灉鍙湁 handle 娌℃湁 pageId锛岄渶瑕侀€氳繃 API 鑾峰彇
        if (handle && !pageId) {
            var url = '<?= $this->getBackendUrl('*/backend/page/getPageByHandle') ?>?handle=' + encodeURIComponent(handle);
                        var req = window.Weline.Api.get(url, { silent: true });
            req.then(function(res) {
                    var result = (res && res.data) || res;
                    if (result.success && result.data) {
                        pageId = result.data.page_id || null;
                        window.visualPageId = pageId;
                        window.visualConfigHandle = handle;
                        if (result.data.default_locale) {
                            window.defaultLanguage = result.data.default_locale;
                            window.currentVisualLanguage = result.data.default_locale;
                        }
                        window.visualConfigInitialized = true;
                    }
                })
                .catch(error => {
                    if (typeof pageId !== 'undefined' && pageId) {
                        window.visualPageId = pageId;
                        window.visualConfigInitialized = true;
                    }
                });
        } else {
            window.visualPageId = pageId;
            window.visualConfigHandle = handle;
            window.visualConfigInitialized = true;
        }
        
        if (!window.defaultLanguage && <?= $page && $page->getData('default_locale') ? json_encode($page->getData('default_locale'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) : 'null' ?>) {
            window.defaultLanguage = <?= $page && $page->getData('default_locale') ? json_encode($page->getData('default_locale'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) : 'null' ?>;
            window.currentVisualLanguage = window.defaultLanguage;
        }
    };
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVisualConfig);
    } else {
        setTimeout(initVisualConfig, 50);
    }
    
    // 鎻愪緵寤惰繜鍒濆鍖栧嚱鏁帮紙渚涘閮ㄨ皟鐢級
    window.visualConfigLazyInit = initVisualConfig;
    // 鍦ㄥ閮ㄦ覆鏌撳畬鎴愬悗锛岀粍浠跺唴閮ㄤ篃鑳介噸鏂板垵濮嬪寲
    window.addEventListener('VisualEditor:rendered', function(){
        setTimeout(initVisualConfig, 0);
    });
})();

// 椤甸潰ID锛堝吋瀹规€э細濡傛灉鍏ㄥ眬鏈畾涔夛紝浣跨敤缁勪欢鍐呴儴鐨勫€硷級
// 鍙栨秷鍦ㄥ叏灞€鍏紑 pageId锛岄伩鍏嶄笌澶栭儴鍐茬獊锛堢粺涓€鐢辩粍浠跺唴閮ㄧ鐞嗭級

// 鑷姩淇濆瓨闃叉姈瀹氭椂鍣?
let autoSaveTimer = null;

// 鎻愬墠瀹氫箟 autoSaveVisualConfig 鍗犱綅绗︼紙閬垮厤鍦ㄥ嚱鏁板畾涔夊墠璋冪敤瀵艰嚧閿欒锛?
// 杩欎釜鍗犱綅绗︿細鍦?autoSaveConfig 瀹氫箟鍚庤鏇挎崲
if (typeof window.autoSaveVisualConfig === 'undefined') {
    window.autoSaveVisualConfig = function() {
        // 濡傛灉 autoSaveConfig 宸插畾涔夛紝鍒欒皟鐢ㄥ畠锛涘惁鍒欑瓑寰?
        if (typeof window.autoSaveConfig === 'function') {
            return window.autoSaveConfig.apply(window, arguments);
        } else {
            console.warn('鈿狅笍 autoSaveConfig 灏氭湭瀹氫箟锛岃绋嶅悗閲嶈瘯');
            return Promise.reject(new Error('autoSaveConfig not yet defined'));
        }
    };
}
const AUTO_SAVE_DELAY = 1000; // 1绉?

// 鎵撳紑鍙鍖栭厤缃?
function openVisualConfig(passedHandle) {
    const wrapper = document.getElementById('visualConfigWrapper');
    wrapper.classList.add('active');
    document.body.style.overflow = 'hidden';
    
    // 榛樿杩涘叆鍏ㄥ睆妯″紡骞舵敹璧烽厤缃爮
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const configPanel = document.getElementById('configPanel');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    
    // 杩涘叆鍏ㄥ睆妯″紡
    wrapper.classList.add('fullscreen-mode');
    if (fullscreenBtn) {
        fullscreenBtn.classList.add('active');
        const icon = fullscreenBtn.querySelector('i');
        if (icon) {
            icon.className = 'mdi mdi-fullscreen-exit';
        }
        fullscreenBtn.title = '<?= __('') ?>';
    }
    
    // 鏀惰捣閰嶇疆鏍?
    if (configPanel) {
        configPanel.classList.add('collapsed');
    }
    // 鏄剧ず鎮诞灞曞紑鎸夐挳
    if (floatingBtn) {
        floatingBtn.style.display = 'block';
    }
    
    // 濡傛灉澶栭儴浼犲叆浜?handle锛屽垯浠ュ畠涓哄噯锛岀敱缁勪欢鑷閫氳繃鎺ュ彛瑙ｆ瀽 pageId
    if (typeof passedHandle === 'string' && passedHandle.trim()) {
        window.visualConfigHandle = passedHandle.trim();
        // 閲嶇疆锛屼互渚胯Е鍙戦€氳繃 handle 鑾峰彇 page 淇℃伅
        window.visualPageId = null;
        window.visualConfigInitialized = false;
        if (typeof window.visualConfigLazyInit === 'function') {
            window.visualConfigLazyInit();
        }
    }
    
    // 妫€娴嬫槸鍚︿负妯℃澘閰嶇疆妯″紡锛屽鏋滄槸鍒欏姞杞芥ā鏉块厤缃?
    const isTemplateMode = window.isTemplateConfigMode || false;
    if (isTemplateMode) {
        const styleCode = window.currentTemplateStyleCode || '';
        const templatePageId = window.currentTemplatePageId || 0;
        
        if (styleCode) {
            // 娓呯┖闈欐€侀厤缃唴瀹癸紝鍑嗗鍔犺浇鍔ㄦ€侀厤缃?
            const configPanel = document.querySelector('.config-panel-body');
            if (configPanel) {
                configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('姝ｅ湪鍔犺浇閰嶇疆...') ?></div></div>';
            }
            
            // 鍔犺浇妯℃澘閰嶇疆
            loadTemplateStyleConfig();
            
            // 鍔犺浇棰勮
            refreshTemplatePreview();
        }
    }
    // 闈炴ā鏉挎ā寮忥細鏍规嵁澶栭儴鏍峰紡閫夋嫨鍔犺浇閰嶇疆骞跺埛鏂伴瑙?
    if (!isTemplateMode) {
        if (typeof loadVisualStyleConfig === 'function') {
            loadVisualStyleConfig().then(() => {
                if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
                if (typeof window.visualEditorLoadPageTree === 'function') {
                    var pid = window.visualPageId || window.pageId;
                    if (pid) window.visualEditorLoadPageTree(pid);
                }
            });
        }
    }
    
    // 寤惰繜妫€鏌ユ槸鍚︽湁鏈繚瀛樼殑AI缁勪欢
    setTimeout(() => {
        if (typeof checkUnsavedAiComponent === 'function') {
            checkUnsavedAiComponent();
        }
    }, 1000);
}

// AI鐢熸垚鐘舵€佹爣蹇楋紝鐢ㄤ簬绂佹鍦ㄧ敓鎴愭椂鍏抽棴鍙鍖栭厤缃?
window.isAiGenerating = false;

// 鍏抽棴鍙鍖栭厤缃?
function closeVisualConfig() {
    // 濡傛灉姝ｅ湪AI鐢熸垚锛岀姝㈠叧闂?
    if (window.isAiGenerating) {
        BackendToast.info('<?= __('AI姝ｅ湪鐢熸垚閰嶇疆锛岃绛夊緟鐢熸垚瀹屾垚') ?>');
        return;
    }
    document.getElementById('visualConfigWrapper').classList.remove('active');
    document.body.style.overflow = '';
}

// 鍚戝閮ㄦ姏鍑哄叏灞€鍑芥暟渚涜〃鍗曡皟鐢?
try {
    if (!window.openVisualConfig) {
        window.openVisualConfig = openVisualConfig;
    }
    if (!window.closeVisualConfig) {
        window.closeVisualConfig = closeVisualConfig;
    }
} catch (_) {}

function getCurrentVisualPageType() {
    if (window.visualIsVirtualMode) {
        if (window.visualPageType) {
            return window.visualPageType;
        }
        const keys = window.visualPageTreeData ? Object.keys(window.visualPageTreeData) : [];
        return keys.length ? keys[0] : '';
    }
    return '';
}

function getCurrentVisualStyleCode() {
    if (window.visualIsVirtualMode) {
        const pageType = getCurrentVisualPageType();
        const pageInfo = window.visualPageTreeData && pageType ? window.visualPageTreeData[pageType] : null;
        if (pageInfo && pageInfo.style_code) {
            return pageInfo.style_code;
        }
    }
    const externalStyleSelect = document.getElementById('style');
    return externalStyleSelect ? externalStyleSelect.value : (window.currentStyle || '');
}

function getVisualIdentity() {
    return {
        isVirtual: !!window.visualIsVirtualMode,
        pageId: window.visualPageId || window.pageId || 0,
        publicId: window.visualPublicId || '',
        pageType: getCurrentVisualPageType(),
        virtualThemeId: window.visualVirtualThemeId || 0
    };
}

function applyVisualIdentityToPayload(payload) {
    const identity = getVisualIdentity();
    const nextPayload = Object.assign({}, payload || {});
    if (identity.isVirtual) {
        delete nextPayload.page_id;
        nextPayload.public_id = identity.publicId;
        nextPayload.page_type = identity.pageType;
        if (identity.virtualThemeId) {
            nextPayload.virtual_theme_id = identity.virtualThemeId;
        }
    } else if (!nextPayload.page_id) {
        nextPayload.page_id = identity.pageId;
    }
    return nextPayload;
}

function appendVisualIdentityToFormData(formData) {
    if (!(formData instanceof FormData)) {
        return formData;
    }
    const identity = getVisualIdentity();
    formData.delete('page_id');
    formData.delete('public_id');
    formData.delete('page_type');
    formData.delete('virtual_theme_id');
    if (identity.isVirtual) {
        formData.append('public_id', identity.publicId || '');
        formData.append('page_type', identity.pageType || '');
        if (identity.virtualThemeId) {
            formData.append('virtual_theme_id', String(identity.virtualThemeId));
        }
    } else {
        formData.append('page_id', String(identity.pageId || 0));
    }
    return formData;
}

function buildVisualPreviewUrl() {
    const identity = getVisualIdentity();
    let previewUrl = '<?= $this->getBackendUrl('*/backend/preview/full') ?>';
    if (identity.isVirtual) {
        previewUrl += '?public_id=' + encodeURIComponent(identity.publicId) + '&page_type=' + encodeURIComponent(identity.pageType) + '&visual_editor=1';
    } else {
        previewUrl += '?page_id=' + encodeURIComponent(String(identity.pageId || 0)) + '&visual_editor=1';
    }

    const styleCode = getCurrentVisualStyleCode();
    if (styleCode) {
        previewUrl += '&style_code=' + encodeURIComponent(styleCode);
    }
    if (window.currentVisualLanguage) {
        previewUrl += '&locale=' + encodeURIComponent(window.currentVisualLanguage);
    }
    if (typeof window.visualWelineThemeId === 'number' && window.visualWelineThemeId > 0) {
        previewUrl += '&weline_theme_id=' + encodeURIComponent(String(window.visualWelineThemeId));
    }
    previewUrl += '&t=' + Date.now();
    return previewUrl;
}

function updateVirtualBaseFieldsForCurrentPage() {
    if (!window.visualIsVirtualMode) {
        return;
    }
    const pageType = getCurrentVisualPageType();
    const pageInfo = window.visualPageTreeData && pageType ? window.visualPageTreeData[pageType] : null;
    if (!pageInfo) {
        return;
    }
    const handleField = document.getElementById('handle');
    const styleField = document.getElementById('style');
    const metaTitleField = document.getElementById('meta_title');
    const metaDescriptionField = document.getElementById('meta_description');
    const metaKeywordsField = document.getElementById('meta_keywords');
    if (handleField) handleField.value = pageInfo.handle || '';
    if (styleField) styleField.value = pageInfo.style_code || '';
    if (metaTitleField) metaTitleField.value = pageInfo.meta_title || '';
    if (metaDescriptionField) metaDescriptionField.value = pageInfo.meta_description || '';
    if (metaKeywordsField) metaKeywordsField.value = pageInfo.meta_keywords || '';
    if (pageInfo.style_code) {
        window.currentStyle = pageInfo.style_code;
    }
    if (pageInfo.locale) {
        window.currentVisualLanguage = pageInfo.locale;
        if (!window.defaultLanguage) {
            window.defaultLanguage = pageInfo.locale;
        }
    }
}

window.switchVirtualVisualPage = function(pageType) {
    if (!window.visualIsVirtualMode || !pageType || !window.visualPageTreeData || !window.visualPageTreeData[pageType]) {
        return;
    }
    window.visualPageType = pageType;
    updateVirtualBaseFieldsForCurrentPage();
    if (typeof window.refreshSeoSection === 'function') {
        window.refreshSeoSection();
    }
    if (typeof loadVisualStyleConfig === 'function') {
        loadVisualStyleConfig();
    }
    if (typeof window.refreshPreview === 'function') {
        window.refreshPreview();
    }
    if (typeof window.refreshComponentPanelForCurrentPageType === 'function') {
        window.refreshComponentPanelForCurrentPageType();
    }
    if (typeof window.visualEditorSelectPageInTree === 'function') {
        window.visualEditorSelectPageInTree(pageType);
    }
};

// 鑾峰彇鍒嗙粍灞曞紑鐘舵€佺殑 localStorage key
function getVisualConfigStateKey() {
    if (window.visualIsVirtualMode) {
        return `visual_config_sections_virtual_${window.visualPublicId || 'default'}_${getCurrentVisualPageType() || 'default'}`;
    }
    const pageId = document.querySelector('[data-page-id]')?.getAttribute('data-page-id') || 
                   window.location.pathname.match(/\/page\/(\d+)/)?.[1] || 
                   'default';
    return `visual_config_sections_${pageId}`;
}

// 淇濆瓨鍒嗙粍灞曞紑鐘舵€佸埌 localStorage
function saveSectionState(sectionId, isExpanded) {
    try {
        const stateKey = getVisualConfigStateKey();
        const states = JSON.parse(localStorage.getItem(stateKey) || '{}');
        states[sectionId] = isExpanded;
        localStorage.setItem(stateKey, JSON.stringify(states));
    } catch (e) {
        console.warn('淇濆瓨鍒嗙粍鐘舵€佸け璐?', e);
    }
}

// 浠?localStorage 鎭㈠鍒嗙粍灞曞紑鐘舵€?
function restoreSectionState(sectionId) {
    try {
        const stateKey = getVisualConfigStateKey();
        const states = JSON.parse(localStorage.getItem(stateKey) || '{}');
        return states[sectionId] !== false; // 榛樿灞曞紑锛坱rue锛夛紝闄ら潪鏄庣‘璁剧疆涓?false
    } catch (e) {
        console.warn('鎭㈠鍒嗙粍鐘舵€佸け璐?', e);
        return true; // 榛樿灞曞紑
    }
}

// 鍒囨崲閰嶇疆鍖哄煙
function toggleSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const isCollapsed = section.classList.contains('collapsed');
    section.classList.toggle('collapsed');
    const isExpanded = !section.classList.contains('collapsed');
    
    // 淇濆瓨鐘舵€佸埌 localStorage
    saveSectionState(sectionId, isExpanded);
}

// 鍒囨崲璁惧瑙嗗浘
function switchDevice(device) {
    // 鏇存柊鎸夐挳鐘舵€?
    document.querySelectorAll('.device-btn').forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-device') === device);
    });
    
    // 鏇存柊棰勮瀹瑰櫒
    const container = document.getElementById('previewContainer');
    container.className = 'preview-container device-' + device;
}

// 鏇存柊淇濆瓨鐘舵€侊紙鍏ㄥ眬鍑芥暟锛?
window.updateSaveStatus = function(status, text) {
    const statusEl = document.getElementById('saveStatus');
    const textEl = document.getElementById('saveStatusText');
    
    if (statusEl) {
        statusEl.className = 'save-status ' + status;
    }
    if (textEl) {
        textEl.textContent = text;
    }
}

 // 鑷姩淇濆瓨閰嶇疆锛堝叏灞€鍑芥暟锛岀‘淇濆彲浠ヨ selectColorScheme 璋冪敤锛?
 window.autoSaveConfig = function(immediate = false) {
    // 娓呴櫎涔嬪墠鐨勫畾鏃跺櫒
    if (autoSaveTimer) {
        clearTimeout(autoSaveTimer);
        autoSaveTimer = null;
    }
    
    // 淇濆瓨鍑芥暟
    const saveFunction = async () => {
        if (typeof window.updateSaveStatus === 'function') {
            window.updateSaveStatus('saving', '<?= __('淇濆瓨涓?..') ?>');
        }
        
        try {
            // 鏀堕泦鎵€鏈夐厤缃?
            const config = {};
            document.querySelectorAll('.auto-save-field').forEach(field => {
                const key = field.getAttribute('data-config-key');
                // 澶勭悊 radio 绫诲瀷
                if (field.type === 'radio') {
                    if (field.checked) {
                        config[key] = field.value;
                    }
                } else {
                    config[key] = field.value;
                }
            });
            
            // 妫€娴嬫槸鍚︿负妯℃澘閰嶇疆妯″紡
            const isTemplateMode = window.isTemplateConfigMode || false;
            const styleCode = window.currentTemplateStyleCode || '';
            const templatePageId = window.currentTemplatePageId || 0;
            
            // 鏋勫缓璇锋眰浣擄紙浣跨敤鍏ㄥ眬 pageId 鎴栦粠 window 鑾峰彇锛?
            const identity = getVisualIdentity();
            const currentPageId = identity.pageId;
            // 灏濊瘯浠庡閮ㄤ笅鎷夋璇诲彇褰撳墠鏍峰紡浠ｇ爜
            let currentStyleCode = '';
            const externalStyleSelect = document.getElementById('style');
            if (externalStyleSelect && externalStyleSelect.value) {
                currentStyleCode = externalStyleSelect.value;
            } else if (typeof window.currentStyle !== 'undefined' && window.currentStyle) {
                currentStyleCode = window.currentStyle;
            }

            let requestBody = applyVisualIdentityToPayload({
                page_id: currentPageId,
                style_config: config
            });
            
            // 濡傛灉鏄ā鏉块厤缃ā寮忥紝浣跨敤妯℃澘鎺ュ彛
            let saveUrl = '<?= $this->getBackendUrl('*/backend/preview/autoSave') ?>';
            if (isTemplateMode && styleCode) {
                saveUrl = '<?= $this->getBackendUrl('*/backend/template/autoSave') ?>';
                requestBody.page_id = templatePageId || pageId;
                requestBody.style_code = styleCode;
            } else {
                // 鏅€氶〉闈㈤厤缃ā寮忥細闄勫甫鏍峰紡浠ｇ爜锛屾敮鎸佽瑷€锛堝鏈夛級
                if (currentStyleCode) {
                    requestBody.style_code = currentStyleCode;
                }
                if (window.currentVisualLanguage) {
                    requestBody.locale = window.currentVisualLanguage;
                }
            }
            
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestBody) };
            var res = await window.Weline.Api.request(saveUrl, opts);
            const result = (res && res.data) || res;
            
            if (result.success) {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('saved', '<?= __('') ?>');
                }
                
                // 濡傛灉涓嶆槸绔嬪嵆淇濆瓨妯″紡锛岃嚜鍔ㄥ埛鏂伴瑙堬紙绔嬪嵆淇濆瓨妯″紡涓嬬敱璋冪敤鑰呭喅瀹氭槸鍚﹀埛鏂帮級
                if (!immediate) {
                    if (typeof window.refreshPreview === 'function') {
                        window.refreshPreview();
                    }
                }
                
                return Promise.resolve();
            } else {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
                }
                console.error('淇濆瓨澶辫触:', result.message);
                return Promise.reject(new Error(result.message || '淇濆瓨澶辫触'));
            }
        } catch (error) {
            if (typeof window.updateSaveStatus === 'function') {
                window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
            }
            console.error('淇濆瓨寮傚父:', error);
            return Promise.reject(error);
        }
    };
    
    if (immediate) {
        // 绔嬪嵆淇濆瓨锛岃繑鍥?Promise
        return saveFunction();
    } else {
        // 寤惰繜淇濆瓨锛岃繑鍥?Promise
        return new Promise((resolve, reject) => {
            autoSaveTimer = setTimeout(async () => {
                try {
                    await saveFunction();
                    resolve();
                } catch (error) {
                    reject(error);
                }
            }, AUTO_SAVE_DELAY);
        });
    }
}

// 鏇存柊 autoSaveVisualConfig 涓哄畬鏁村疄鐜帮紙鏇挎崲涔嬪墠鐨勫崰浣嶇锛岀‘淇濈洿鎺ヨ皟鐢?autoSaveConfig锛?
window.autoSaveVisualConfig = function() {
    return window.autoSaveConfig.apply(window, arguments);
};

// 鍒锋柊棰勮锛堝叏灞€鍑芥暟锛岀‘淇濆彲浠ヨ selectColorScheme 璋冪敤锛?
// 鏀寔淇濇寔婊氬姩浣嶇疆锛屽彲浼犲叆棰勫厛淇濆瓨鐨勪綅缃?{ scrollX, scrollY }
window.refreshPreview = function(savedPosition) {
    const loading = document.getElementById('previewLoading');
    const iframe = document.getElementById('previewIframe');
    
    if (!loading || !iframe) {
        return;
    }
    
    // 淇濆瓨褰撳墠婊氬姩浣嶇疆锛堝鏋滄病鏈変紶鍏ラ淇濆瓨鐨勪綅缃級
    let savedScrollX = 0;
    let savedScrollY = 0;
    
    if (savedPosition && (savedPosition.scrollX || savedPosition.scrollY)) {
        // 浣跨敤浼犲叆鐨勯淇濆瓨浣嶇疆
        savedScrollX = savedPosition.scrollX || 0;
        savedScrollY = savedPosition.scrollY || 0;
    } else {
        // 灏濊瘯鑾峰彇褰撳墠婊氬姩浣嶇疆
        try {
            if (iframe.contentWindow && iframe.contentDocument) {
                savedScrollX = iframe.contentWindow.scrollX || iframe.contentDocument.documentElement.scrollLeft || 0;
                savedScrollY = iframe.contentWindow.scrollY || iframe.contentDocument.documentElement.scrollTop || 0;
            }
        } catch (e) {
            // 蹇界暐
        }
    }
    
    loading.classList.add('active');
    
    // 妫€娴嬫槸鍚︿负妯℃澘閰嶇疆妯″紡
    const isTemplateMode = window.isTemplateConfigMode || false;
    const styleCode = window.currentTemplateStyleCode || '';
    const templatePageId = window.currentTemplatePageId || 0;
    
    // 鏋勫缓棰勮 URL锛堜娇鐢ㄥ叏灞€ pageId 鎴栦粠 window 鑾峰彇锛?
    let previewUrl = buildVisualPreviewUrl();
    
    if (isTemplateMode && styleCode) {
        previewUrl = '<?= $this->getBackendUrl('*/backend/preview/full') ?>?visual_editor=1&style_code=' + encodeURIComponent(styleCode);
        if (templatePageId) {
            previewUrl += '&page_id=' + encodeURIComponent(String(templatePageId));
        }
        if (window.currentVisualLanguage) {
            previewUrl += '&locale=' + encodeURIComponent(window.currentVisualLanguage);
        }
        if (typeof window.visualWelineThemeId === 'number' && window.visualWelineThemeId > 0) {
            previewUrl += '&weline_theme_id=' + encodeURIComponent(String(window.visualWelineThemeId));
        }
        previewUrl += '&t=' + Date.now();
    }
        iframe.src = previewUrl;
    
    // 鐩戝惉鍔犺浇瀹屾垚
    iframe.onload = function() {
        loading.classList.remove('active');
        
        // 鎭㈠婊氬姩浣嶇疆
        if (savedScrollY > 0 || savedScrollX > 0) {
            // 寤惰繜鎭㈠锛岀‘淇濆唴瀹瑰凡娓叉煋
            setTimeout(() => {
                try {
                    if (iframe.contentWindow) {
                        iframe.contentWindow.scrollTo(savedScrollX, savedScrollY);
                    }
                } catch (e) {
                    // 蹇界暐
                }
            }, 100);
        }
        
        // 閲嶆柊璁剧疆鎷栨斁鍖哄煙
        setTimeout(() => {
            if (typeof setupPreviewDropZones === 'function') {
                setupPreviewDropZones();
            }
        }, 200);
    };
}

// 鍙鍖栫紪杈戝唴 iframe 鐐瑰嚮 header/footer 閾炬帴鏃堕€氳繃 postMessage 閫氱煡璺宠浆锛屽湪姝ょ粺涓€澶勭悊
window.addEventListener('message', function(e) {
    if (!e.data || e.data.type !== 'PageBuilderVisualEditor' || e.data.action !== 'navigate') return;
    if (window.visualIsVirtualMode && e.data.page_type) {
        window.switchVirtualVisualPage(e.data.page_type);
        return;
    }
    if (!e.data.page_id) return;
    var targetPageId = parseInt(e.data.page_id, 10);
    if (!targetPageId) return;
    window.visualPageId = targetPageId;
    if (typeof window.pageId !== 'undefined') window.pageId = targetPageId;
    if (typeof window.refreshPreview === 'function') window.refreshPreview();
    if (typeof window.visualEditorLoadPageTree === 'function') window.visualEditorLoadPageTree(targetPageId);
    if (typeof window.visualEditorSelectPageInTree === 'function') window.visualEditorSelectPageInTree(targetPageId);
});

// 閫氳繃鍙鍖栭潰鏉胯嚜鍔ㄤ繚瀛?SEO / TDK锛堢洿鎺ュ啓鍏ラ〉闈㈣褰曪紝鑰屼笉鏄牱寮忛厤缃級
window.saveSeoConfig = async function () {
    try {
        const metaTitleInput = document.getElementById('seo_meta_title');
        const metaDescInput = document.getElementById('seo_meta_description');
        const metaKeywordsInput = document.getElementById('seo_meta_keywords');
        if (!metaTitleInput || !metaDescInput || !metaKeywordsInput) {
            return;
        }

        const identity = getVisualIdentity();
        if (!identity.isVirtual && !identity.pageId) {
            return;
        }

        const locale = window.currentVisualLanguage || window.defaultLanguage || '';

        if (typeof window.updateSaveStatus === 'function') {
            window.updateSaveStatus('saving', '<?= __('淇濆瓨涓?..') ?>');
        }

        const payload = applyVisualIdentityToPayload({
            page_id: identity.pageId,
            locale: locale,
            meta_title: metaTitleInput.value || '',
            meta_description: metaDescInput.value || '',
            meta_keywords: metaKeywordsInput.value || ''
        });

        var url = '<?= $this->getBackendUrl('*/backend/page/autoSaveSeo') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(payload) };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        if (result && result.success) {
            if (typeof window.updateSaveStatus === 'function') {
                window.updateSaveStatus('saved', '<?= __('') ?>');
            }
            if (typeof window.refreshPreview === 'function') {
                window.refreshPreview();
            }
        } else {
            if (typeof window.updateSaveStatus === 'function') {
                window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
            }
            console.error('[SEO AutoSave] 澶辫触:', result && result.message ? result.message : 'unknown');
        }
    } catch (e) {
        if (typeof window.updateSaveStatus === 'function') {
            window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
        }
        console.error('[SEO AutoSave] 寮傚父:', e);
    }
};

// 鑹茬郴閫夋嫨鍑芥暟锛堝叏灞€鍑芥暟锛?
window.selectColorScheme = function(fieldId, schemeKey) {
    const hiddenInput = document.getElementById(fieldId);
    if (!hiddenInput) return;
    
    // 鏇存柊闅愯棌杈撳叆妗嗙殑鍊?
    hiddenInput.value = schemeKey;
    
    // 鏇存柊UI锛氱Щ闄ゆ墍鏈夐€変腑鐘舵€?
    const container = document.getElementById(fieldId + '_container');
    if (container) {
        container.querySelectorAll('.color-scheme-item').forEach(item => {
            item.classList.remove('selected');
            const check = item.querySelector('.color-scheme-check');
            if (check) {
                check.classList.remove('active');
            }
        });
        
        // 娣诲姞鏂扮殑閫変腑鐘舵€?
        const selectedItem = container.querySelector(`[data-scheme-key="${schemeKey}"]`);
        if (selectedItem) {
            selectedItem.classList.add('selected');
            const check = selectedItem.querySelector('.color-scheme-check');
            if (check) {
                check.classList.add('active');
            }
        }
    }
    
    // 瑙﹀彂鑷姩淇濆瓨
    if (typeof window.updateSaveStatus === 'function') {
        window.updateSaveStatus('', '<?= __('') ?>');
    }
    
    // 妫€娴嬫槸鍚︿负妯℃澘閰嶇疆妯″紡
    const isTemplateMode = window.isTemplateConfigMode || false;
    
    // 绔嬪嵆瑙﹀彂淇濆瓨锛堜笉寤惰繜锛岃壊绯诲垏鎹㈤渶瑕佺珛鍗崇敓鏁堬級
    if (isTemplateMode) {
        // 妯℃澘閰嶇疆妯″紡锛氱珛鍗充繚瀛樺苟鍒锋柊棰勮
        if (typeof window.autoSaveConfig === 'function') {
            window.autoSaveConfig(true).then(() => {
                // 淇濆瓨鎴愬姛鍚庡埛鏂伴瑙?
                if (typeof refreshTemplatePreview === 'function') {
                    refreshTemplatePreview();
                } else if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
            }).catch(error => {
                console.error('鉂?淇濆瓨澶辫触:', error);
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
                }
            });
        } else {
            console.error('鉂?autoSaveConfig 鍑芥暟鏈畾涔?);
        }
    } else {
        // 姝ｅ父妯″紡锛氱珛鍗充繚瀛樺苟鍒锋柊棰勮
        if (typeof window.autoSaveConfig === 'function') {
            window.autoSaveConfig(true).then(() => {
                // 淇濆瓨鎴愬姛鍚庡埛鏂伴瑙?
                if (typeof window.refreshPreview === 'function') {
                    window.refreshPreview();
                }
            }).catch(error => {
                console.error('鉂?淇濆瓨澶辫触:', error);
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('error', '<?= __('淇濆瓨澶辫触') ?>');
                }
            });
        } else {
            console.error('鉂?autoSaveConfig 鍑芥暟鏈畾涔?);
        }
    }
}

// 鐩戝惉鎵€鏈夎嚜鍔ㄤ繚瀛樺瓧娈?
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.auto-save-field').forEach(field => {
        field.addEventListener('input', function() {
            updateSaveStatus('', '<?= __('') ?>');
            autoSaveConfig();
        });
        
        field.addEventListener('change', function() {
            updateSaveStatus('', '<?= __('') ?>');
            autoSaveConfig();
        });
    });
    // 鍏ㄥ眬浜嬩欢濮旀墭锛氫繚璇佸姩鎬佹覆鏌撶殑瀛楁涔熻兘瑙﹀彂鑷姩淇濆瓨
    const delegatedAutoSaveHandler = function(e) {
        const target = e.target;
        if (target && target.classList && target.classList.contains('auto-save-field')) {
            if (typeof updateSaveStatus === 'function') {
                updateSaveStatus('', '<?= __('') ?>');
            }
            if (typeof autoSaveConfig === 'function') {
                autoSaveConfig();
            }
        }
    };
    document.addEventListener('input', delegatedAutoSaveHandler, true);
    document.addEventListener('change', delegatedAutoSaveHandler, true);
    // 鐩戝惉澶栭儴鏍峰紡閫夋嫨鍣ㄥ彉鍖栵紝鑱斿姩鍔犺浇閰嶇疆鍜岄瑙?
    const externalStyleSelect = document.getElementById('style');
    if (externalStyleSelect) {
        externalStyleSelect.addEventListener('change', function() {
            // 鏅€氶〉闈㈡ā寮忎笅锛屾牴鎹€変腑鏍峰紡鍔ㄦ€佸姞杞介厤缃?
            if (!window.isTemplateConfigMode && typeof loadVisualStyleConfig === 'function') {
                loadVisualStyleConfig().then(() => {
                    if (typeof window.refreshPreview === 'function') {
                        window.refreshPreview();
                    }
                });
            }
        });
    }
});

// 閿洏蹇嵎閿?
document.addEventListener('keydown', function(e) {
    // ESC 閫€鍑哄叏灞忥紙濡傛灉涓嶅湪AI鐢熸垚涓級
    if (e.key === 'Escape') {
        closeVisualConfig();
    }
    
    // Ctrl+S 淇濆瓨
    if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        autoSaveConfig();
    }
});

// ========== 妯℃澘閰嶇疆妯″紡涓撶敤鍑芥暟 ==========

// 妯℃澘閰嶇疆妯″紡锛氬姞杞芥ā鏉挎牱寮忛厤缃?
async function loadTemplateStyleConfig(forceScan = false) {
    const styleCode = window.currentTemplateStyleCode || '';
    const templatePageId = window.currentTemplatePageId || 0;
    
    if (!styleCode) {
        console.error('妯℃澘浠ｇ爜涓嶈兘涓虹┖');
        return;
    }
    
    try {
        let url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
            '?style_code=' + encodeURIComponent(styleCode) +
            '&page_id=' + templatePageId;
        
        if (forceScan) {
            url += '&force_scan=1&t=' + Date.now();
        }
        
        var res = await window.Weline.Api.get(url, { silent: true });
        const result = (res && res.data) || res;
        
        if (result.success && result.data) {
            // 鏄剧ず妯℃澘淇℃伅锛堝悕绉?+ 浠ｇ爜锛?
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            renderTemplateConfig(result.data);
        } else {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('鍔犺浇閰嶇疆澶辫触') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('鍔犺浇閰嶇疆澶辫触:', error);
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-danger m-3"><?= __('鍔犺浇閰嶇疆澶辫触') ?></div>';
        }
    }
}

// 妯℃澘閰嶇疆妯″紡锛氭覆鏌撴ā鏉块厤缃?
function renderTemplateConfig(configGroups) {

    // 鍒濆鍖?SEO / TDK 閰嶇疆鍧楋細鍚屾褰撳墠璇█涓嬬殑 TDK 鍊硷紝骞剁粦瀹氳嚜鍔ㄤ繚瀛?
    function initSeoSection() {
        const metaTitleInput = document.getElementById('seo_meta_title');
        const metaDescInput = document.getElementById('seo_meta_description');
        const metaKeywordsInput = document.getElementById('seo_meta_keywords');

        if (!metaTitleInput || !metaDescInput || !metaKeywordsInput) {
            return;
        }

        const getCurrentLocale = function () {
            return window.currentVisualLanguage || window.defaultLanguage || '';
        };

        const isDefaultLocale = function (locale) {
            const def = window.defaultLanguage || '';
            if (!locale || !def) {
                return true;
            }
            return locale === def;
        };

        const syncFromBaseFields = function () {
            const locale = getCurrentLocale();
            const useDefault = isDefaultLocale(locale);

            const titleId = useDefault ? 'meta_title' : 'meta_title_' + locale;
            const descId = useDefault ? 'meta_description' : 'meta_description_' + locale;
            const keywordsId = useDefault ? 'meta_keywords' : 'meta_keywords_' + locale;

            const baseTitle = document.getElementById(titleId);
            const baseDesc = document.getElementById(descId);
            const baseKeywords = document.getElementById(keywordsId);

            metaTitleInput.value = baseTitle ? (baseTitle.value || '') : '';
            metaDescInput.value = baseDesc ? (baseDesc.value || '') : '';
            metaKeywordsInput.value = baseKeywords ? (baseKeywords.value || '') : '';
        };

        const syncToBaseFields = function () {
            const locale = getCurrentLocale();
            const useDefault = isDefaultLocale(locale);

            const titleId = useDefault ? 'meta_title' : 'meta_title_' + locale;
            const descId = useDefault ? 'meta_description' : 'meta_description_' + locale;
            const keywordsId = useDefault ? 'meta_keywords' : 'meta_keywords_' + locale;

            const baseTitle = document.getElementById(titleId);
            const baseDesc = document.getElementById(descId);
            const baseKeywords = document.getElementById(keywordsId);

            if (baseTitle) {
                baseTitle.value = metaTitleInput.value;
            }
            if (baseDesc) {
                baseDesc.value = metaDescInput.value;
            }
            if (baseKeywords) {
                baseKeywords.value = metaKeywordsInput.value;
            }
        };

        let seoSaveTimer = null;

        const scheduleSeoSave = function () {
            if (seoSaveTimer) {
                clearTimeout(seoSaveTimer);
                seoSaveTimer = null;
            }
            seoSaveTimer = setTimeout(function () {
                window.saveSeoConfig && window.saveSeoConfig();
            }, 800);
        };

        const bindSeoField = function (input) {
            input.addEventListener('input', function () {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('', '<?= __('') ?>');
                }
                syncToBaseFields();
                scheduleSeoSave();
            });
            input.addEventListener('change', function () {
                if (typeof window.updateSaveStatus === 'function') {
                    window.updateSaveStatus('', '<?= __('') ?>');
                }
                syncToBaseFields();
                scheduleSeoSave();
            });
        };

        // 棣栨鍚屾褰撳墠璇█鐨?TDK 鍊?
        syncFromBaseFields();

        // 缁戝畾杈撳叆浜嬩欢
        bindSeoField(metaTitleInput);
        bindSeoField(metaDescInput);
        bindSeoField(metaKeywordsInput);

        // 褰撻瑙堣瑷€鍒囨崲鏃讹紝澶栭儴浼氭洿鏂?window.currentVisualLanguage锛岃繖閲屾彁渚涗竴涓畝鏄撶殑閲嶆柊鍚屾鎺ュ彛
        window.refreshSeoSection && window.refreshSeoSection();
        window.refreshSeoSection = function () {
            syncFromBaseFields();
        };
    }
    // 杈呭姪鍑芥暟锛氭覆鏌撳崟涓厤缃瓧娈?
    function renderConfigField(configKey, config) {
        const rawValue = config.value !== undefined ? config.value : (config.default || '');
        const fieldId = 'config_' + configKey.replace(/\./g, '_');
        
        let fieldHtml = `<div class="mb-3 config-field-item" data-config-key="${escapeHtmlForTemplate(configKey)}" data-config-label="${escapeHtmlForTemplate(config.label || '')}" data-config-description="${escapeHtmlForTemplate(config.description || config.note || '')}">`;
        // 娣诲姞鎭㈠榛樿鍊兼寜閽埌鏍囩涓?
        const escapedDefault = escapeHtmlForTemplate(config.default || '');
        fieldHtml += `<label for="${fieldId}" class="form-label">`;
        fieldHtml += `${escapeHtmlForTemplate(config.label)}`;
        fieldHtml += ` <a href="javascript:void(0)" 
                         class="link-warning ms-1 visual-config-reset-btn" 
                         data-field-id="${fieldId}"
                         data-config-key="${escapeHtmlForTemplate(configKey)}"
                         data-config-type="${config.type || 'text'}"
                         data-default-value="${escapedDefault}"
                         onclick="resetVisualConfigField(this)"
                         title="<?= __('') ?>">
                        <i class="mdi mdi-restore"></i> <span class="reset-text"><?= __('鎭㈠') ?></span>
                     </a>`;
        fieldHtml += `</label>`;
        
        // 鏄剧ず鎻忚堪淇℃伅锛堝鏋滄湁锛?
        if (config.description && config.description.trim()) {
            // 灏?\n 杞崲涓?<br>锛屽悓鏃惰浆涔夊叾浠朒TML瀛楃
            let descriptionHtml = String(config.description || '')
                .replace(/\\n/g, '\n')  // 鍏堣浆鎹㈠瓧闈㈤噺 \n 涓哄疄闄呮崲琛?
                .replace(/\r\n/g, '\n')  // 缁熶竴澶勭悊 \r\n
                .replace(/\n/g, '<br>'); // 灏嗘崲琛岀杞崲涓?<br>
            descriptionHtml = escapeHtmlForTemplate(descriptionHtml.replace(/<br>/g, '__BR__'))
                .replace(/__BR__/g, '<br>'); // 淇濈暀 <br> 鏍囩
            
            fieldHtml += `<div class="form-text text-muted mb-2" style="font-size: 0.875rem; line-height: 1.4;">`;
            fieldHtml += `<i class="mdi mdi-information-outline me-1" style="font-size: 14px;"></i>`;
            fieldHtml += descriptionHtml;
            fieldHtml += `</div>`;
        }
        
        // 鐗规畩澶勭悊锛氳壊绯婚€夋嫨锛堝甫棰勮鍥撅級
        if (config.type === 'color_scheme' && config.color_schemes) {
            fieldHtml += `<div class="color-scheme-selector" id="${fieldId}_container">`;
            fieldHtml += `<input type="hidden" id="${fieldId}" class="auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
            
            const colorSchemes = config.color_schemes;
            fieldHtml += `<div class="color-scheme-grid">`;
            
            for (const schemeKey in colorSchemes) {
                const scheme = colorSchemes[schemeKey];
                const isSelected = rawValue == schemeKey;
                // 棰勮鍥剧墖璺緞锛氫娇鐢ㄥ悗绔潤鎬佽祫婧愭帴鍙?
                let previewUrl = '';
                if (scheme.preview_image) {
                    const pv = String(scheme.preview_image || '');
                    if (/^(https?:)?\/\//.test(pv) || pv.startsWith('/')) {
                        // 宸叉槸缁濆URL鎴栦互/寮€澶?
                        previewUrl = pv;
                    } else {
                        // 鐩稿璺緞锛屾嫾鎺ユā鏉块潤鎬佸熀鍑哢RL
                        previewUrl = '<?= $this->fetchTemplateStatic("GuoLaiRen_PageBuilder::") ?>' + pv.replace(/^style\//, 'templates/style/');
                    }
                }
                
                fieldHtml += `<div class="color-scheme-item ${isSelected ? 'selected' : ''}" 
                        data-scheme-key="${escapeHtmlForTemplate(schemeKey)}" 
                        onclick="selectColorScheme('${fieldId}', '${escapeHtmlForTemplate(schemeKey)}')">`;
                
                // 棰勮鍥炬垨娓愬彉鑹茶儗鏅?
                if (previewUrl) {
                    fieldHtml += `<div class="color-scheme-preview">`;
                    fieldHtml += `<img src="${previewUrl}" alt="${escapeHtmlForTemplate(scheme.display_name)}" 
                            onerror="this.style.display='none'">`;
                    fieldHtml += `</div>`;
                } else if (scheme.gradient_colors && scheme.gradient_colors.length >= 2) {
                    // 浣跨敤娓愬彉鑹蹭綔涓鸿儗鏅?
                    const gradientColors = scheme.gradient_colors;
                    const gradientStr = gradientColors.join(', ');
                    fieldHtml += `<div class="color-scheme-preview gradient-preview" 
                            style="background: linear-gradient(135deg, ${gradientStr});">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                } else {
                    // 鏃犻瑙堝浘涔熸棤娓愬彉鑹叉椂鏄剧ず榛樿鍗犱綅绗?
                    fieldHtml += `<div class="color-scheme-preview no-image">`;
                    fieldHtml += `<i class="mdi mdi-palette"></i>`;
                    fieldHtml += `</div>`;
                }
                
                // 閫変腑鏍囪
                fieldHtml += `<div class="color-scheme-check ${isSelected ? 'active' : ''}">`;
                fieldHtml += `<i class="mdi mdi-check-circle"></i>`;
                fieldHtml += `</div>`;
                
                // 鍚嶇О鍜屾弿杩?
                fieldHtml += `<div class="color-scheme-info">`;
                fieldHtml += `<div class="color-scheme-name">${escapeHtmlForTemplate(scheme.display_name)}</div>`;
                if (scheme.description) {
                    fieldHtml += `<div class="color-scheme-desc">${escapeHtmlForTemplate(scheme.description)}</div>`;
                }
                fieldHtml += `</div>`;
                
                fieldHtml += `</div>`;
            }
            
            fieldHtml += `</div>`;
            fieldHtml += `</div>`;
        } else if (config.type === 'color') {
            // 鍏煎 CSS 棰滆壊瀛楃涓诧紙hex / rgba / linear-gradient(...) 绛夛級
            // 鐢变簬 type="color" 鍙帴鍙?#rrggbb锛宺gba 浼氳娴忚鍣ㄩ噸缃?鏍￠獙澶辫触锛屽鑷撮粯璁よВ鏋愰敊璇強淇濆瓨涓嶇敓鏁?
            const colorVal = String(rawValue ?? '');
            const safeVal = colorVal.trim() !== '' ? colorVal : '#000000';
            fieldHtml += `<input type="text" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(safeVal)}" 
                    placeholder="rgba(255,255,255,0.05)">`;
        } else if (config.type === 'textarea') {
            // 澶勭悊 textarea 鐨勫€硷細灏嗗瓧闈㈤噺 \n 鍜?\r\n 杞崲涓哄疄闄呮崲琛岀
            // 娉ㄦ剰锛歵extarea 鍐呭涓殑鎹㈣绗︿笉闇€瑕?HTML 杞箟锛屼絾闇€瑕佽浆涔夊叾浠?HTML 鐗规畩瀛楃
            let textareaValue = String(rawValue || '');
            // 灏嗗瓧绗︿覆瀛楅潰閲?\n 杞崲涓哄疄闄呮崲琛岀锛堝鐞嗕粠 JSON 浼犻€掕繃鏉ョ殑杞箟瀛楃锛?
            textareaValue = textareaValue
                .replace(/\\r\\n/g, '\n')  // 鍏堝鐞?\r\n
                .replace(/\\n/g, '\n')     // 鍐嶅鐞?\n
                .replace(/\\r/g, '\n');    // 鏈€鍚庡鐞嗗崟鐙殑 \r
            
            // 杞箟 HTML 鐗规畩瀛楃锛屼絾淇濈暀鎹㈣绗︼紙textarea 涓崲琛岀鏄湁鏁堢殑锛?
            // 灏嗘崲琛岀涓存椂鏇挎崲锛岃浆涔夊悗鍐嶆仮澶?
            const escaped = textareaValue
                .replace(/\n/g, '__NEWLINE__')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;')
                .replace(/__NEWLINE__/g, '\n');
            
            fieldHtml += `<textarea id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" rows="3">${escaped}</textarea>`;
        } else if (config.type === 'select' && config.options) {
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}">`;
            for (const optValue in config.options) {
                fieldHtml += `<option value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'selected' : ''}>${escapeHtmlForTemplate(config.options[optValue])}</option>`;
            }
            fieldHtml += `</select>`;
        } else if (config.type === 'multiselect' && config.options) {
            // 澶氶€変笅鎷?
            const selectedValues = Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : []);
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field" multiple style="min-height: 120px;"
                    data-config-key="${escapeHtmlForTemplate(configKey)}">`;
            for (const optValue in config.options) {
                const isSelected = selectedValues.includes(String(optValue));
                fieldHtml += `<option value="${escapeHtmlForTemplate(optValue)}" ${isSelected ? 'selected' : ''}>${escapeHtmlForTemplate(config.options[optValue])}</option>`;
            }
            fieldHtml += `</select>`;
            fieldHtml += `<small class="form-text text-muted"><?= __('') ?></small>`;
        } else if (config.type === 'radio' && config.options) {
            // Radio 绫诲瀷
            for (const optValue in config.options) {
                const optLabel = config.options[optValue];
                fieldHtml += `<div class="form-check">`;
                fieldHtml += `<input type="radio" id="${fieldId}_${optValue}" class="form-check-input auto-save-field" 
                        name="${fieldId}" data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(optValue)}" ${rawValue == optValue ? 'checked' : ''}>`;
                fieldHtml += `<label class="form-check-label" for="${fieldId}_${optValue}">${escapeHtmlForTemplate(optLabel)}</label>`;
                fieldHtml += `</div>`;
            }
        } else if (config.type === 'checkbox_group' && config.options) {
            // 澶嶉€夋缁?
            const selectedValues = Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : []);
            fieldHtml += `<div class="checkbox-group" id="${fieldId}_group">`;
            for (const optValue in config.options) {
                const isChecked = selectedValues.includes(String(optValue));
                fieldHtml += `<div class="form-check">`;
                fieldHtml += `<input type="checkbox" id="${fieldId}_${optValue}" class="form-check-input auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" data-checkbox-group="${fieldId}" value="${escapeHtmlForTemplate(optValue)}" ${isChecked ? 'checked' : ''}>`;
                fieldHtml += `<label class="form-check-label" for="${fieldId}_${optValue}">${escapeHtmlForTemplate(config.options[optValue])}</label>`;
                fieldHtml += `</div>`;
            }
            fieldHtml += `</div>`;
        } else if (config.type === 'number') {
            // 鏁板瓧杈撳叆锛堟敮鎸?min/max/step锛?
            const minAttr = config.min !== undefined ? `min="${config.min}"` : '';
            const maxAttr = config.max !== undefined ? `max="${config.max}"` : '';
            const stepAttr = config.step !== undefined ? `step="${config.step}"` : '';
            fieldHtml += `<input type="number" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || '')}" ${minAttr} ${maxAttr} ${stepAttr}>`;
        } else if (config.type === 'url') {
            // URL 杈撳叆
            fieldHtml += `<input type="url" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || 'https://')}">`;
        } else if (config.type === 'image' || config.type === 'image_picker') {
            // 鍥剧墖閫夋嫨鍣?
            fieldHtml += `<div class="input-group">
                <input type="text" id="${fieldId}" class="form-control auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                        placeholder="<?= __('鍥剧墖URL') ?>">
                <button type="button" class="btn btn-outline-secondary btn-select-image" data-target="${fieldId}">
                    <i class="mdi mdi-image"></i> <?= __('閫夋嫨') ?>
                </button>
            </div>`;
            if (rawValue) {
                fieldHtml += `<div class="mt-2 image-preview-container">
                    <img src="${escapeHtmlForTemplate(rawValue)}" class="img-thumbnail" style="max-height: 100px;">
                    <button type="button" class="btn btn-sm btn-outline-danger ms-2" onclick="document.getElementById('${fieldId}').value='';this.parentElement.remove();">
                        <i class="mdi mdi-delete"></i>
                    </button>
                </div>`;
            }
        } else if (config.type === 'file') {
            // 鏂囦欢閫夋嫨鍣?
            fieldHtml += `<div class="input-group">
                <input type="text" id="${fieldId}" class="form-control auto-save-field" 
                        data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                        placeholder="<?= __('鏂囦欢璺緞') ?>">
                <button type="button" class="btn btn-outline-secondary btn-select-file" data-target="${fieldId}" data-accept="${escapeHtmlForTemplate(config.accept || '*')}">
                    <i class="mdi mdi-folder-open"></i> <?= __('娴忚') ?>
                </button>
            </div>`;
        } else if (config.type === 'date') {
            // 鏃ユ湡閫夋嫨鍣?
            fieldHtml += `<input type="date" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
        } else if (config.type === 'datetime') {
            // 鏃ユ湡鏃堕棿閫夋嫨鍣?
            fieldHtml += `<input type="datetime-local" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}">`;
        } else if (config.type === 'rich_text') {
            // 瀵屾枃鏈紪杈戝櫒
            fieldHtml += `<textarea id="${fieldId}" class="form-control auto-save-field rich-text-editor" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" rows="${config.rows || 6}">${escapeHtmlForTemplate(rawValue)}</textarea>`;
            fieldHtml += `<small class="form-text text-muted"><?= __('鏀寔 HTML 鏍煎紡') ?></small>`;
        } else if (config.type === 'eav_select') {
            // EAV 灞炴€ч€夋嫨鍣?
            const entityCode = config.entity_code || 'product';
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field eav-attribute-select" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" data-entity-code="${escapeHtmlForTemplate(entityCode)}">
                <option value=""><?= __('-- 鍔犺浇涓?.. --') ?></option>
            </select>`;
            // 寤惰繜鍔犺浇鑴氭湰
            fieldHtml += `<script>
                (function() {
                    var select = document.getElementById('${fieldId}');
                    if (!select) return;
                    var url = '<?= $this->getUrl("weline/eav/api/options/attributes") ?>?entity_code=' + encodeURIComponent(escapeHtmlForTemplate(entityCode));
                    var req = window.Weline.Api.get(url, { silent: true });
                    req.then(function(res) {
                        var data = (res && res.data) || res;
                            if (data.success && data.data.attributes) {
                                select.innerHTML = '<option value=""><?= __('-- 璇烽€夋嫨灞炴€?--') ?></option>';
                                data.data.attributes.forEach(function(attr) {
                                    var opt = document.createElement('option');
                                    opt.value = attr.code;
                                    opt.textContent = attr.name + ' (' + attr.code + ')';
                                    if ('${escapeHtmlForTemplate(rawValue)}' === attr.code) opt.selected = true;
                                    select.appendChild(opt);
                                });
                            }
                        })
                        .catch(function(err) {
                            select.innerHTML = '<option value=""><?= __('鍔犺浇澶辫触') ?></option>';
                        });
                })();
            <\/script>`;
        } else if (config.type === 'eav_options') {
            // EAV 灞炴€ч€夐」閫夋嫨鍣?
            const entityCode = config.entity_code || 'product';
            const attributeCode = config.attribute_code || '';
            const multiple = config.multiple || false;
            fieldHtml += `<select id="${fieldId}" class="form-select auto-save-field eav-options-select" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" 
                    data-entity-code="${escapeHtmlForTemplate(entityCode)}" 
                    data-attribute-code="${escapeHtmlForTemplate(attributeCode)}" 
                    ${multiple ? 'multiple style="min-height: 120px;"' : ''}>
                <option value=""><?= __('-- 鍔犺浇涓?.. --') ?></option>
            </select>`;
            if (attributeCode) {
                const selectedValues = multiple ? (Array.isArray(rawValue) ? rawValue : (rawValue ? String(rawValue).split(',') : [])) : [rawValue];
                fieldHtml += `<script>
                    (function() {
                        var select = document.getElementById('${fieldId}');
                        if (!select) return;
                        var currentValues = ${JSON.stringify(selectedValues)};
                        var url = '<?= $this->getUrl("weline/eav/api/options") ?>?entity_code=' + encodeURIComponent(escapeHtmlForTemplate(entityCode)) + '&attribute_code=' + encodeURIComponent(escapeHtmlForTemplate(attributeCode));
                        var req = window.Weline.Api.get(url, { silent: true });
                        req.then(function(res) {
                            var data = (res && res.data) || res;
                                if (data.success && data.data.options) {
                                    select.innerHTML = '<option value=""><?= __('-- 璇烽€夋嫨 --') ?></option>';
                                    data.data.options.forEach(function(opt) {
                                        var option = document.createElement('option');
                                        option.value = opt.id;
                                        option.textContent = opt.value;
                                        if (currentValues.includes(String(opt.id))) option.selected = true;
                                        select.appendChild(option);
                                    });
                                }
                            })
                            .catch(function(err) {
                                select.innerHTML = '<option value=""><?= __('鍔犺浇澶辫触') ?></option>';
                            });
                    })();
                <\/script>`;
            }
        } else {
            fieldHtml += `<input type="${config.type || 'text'}" id="${fieldId}" class="form-control auto-save-field" 
                    data-config-key="${escapeHtmlForTemplate(configKey)}" value="${escapeHtmlForTemplate(rawValue)}" 
                    placeholder="${escapeHtmlForTemplate(config.placeholder || '')}">`;
        }
        
        fieldHtml += `</div>`;
        return fieldHtml;
    }
    
    // 杈呭姪鍑芥暟锛氭覆鏌撳崟涓厤缃垎缁?
    function renderConfigGroup(fileKey, groupKey, group, isColorScheme = false) {
        const sectionId = 'config_' + fileKey + '_' + groupKey;
        let groupHtml = `<div class="config-section ${isColorScheme ? 'color-scheme-section' : ''}" id="${sectionId}">`;
        
        // 閰嶈壊鏂规鍒嗙粍锛氫笉鍙姌鍙狅紝涓嶆樉绀烘姌鍙犲浘鏍?
        if (isColorScheme) {
            groupHtml += `<div class="config-section-header" style="cursor: default;">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'palette'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `</div>`;
        } else {
            groupHtml += `<div class="config-section-header" onclick="toggleSection('${sectionId}')">`;
            groupHtml += `<span><i class="mdi mdi-${group.icon || 'cog'}"></i> ${escapeHtmlForTemplate(group.label || groupKey)}</span>`;
            groupHtml += `<i class="mdi mdi-chevron-down"></i>`;
            groupHtml += `</div>`;
        }
        
        groupHtml += `<div class="config-section-body" ${isColorScheme ? 'style="display: block !important;"' : ''}>`;
        
        if (group.configs && typeof group.configs === 'object') {
            for (const configKey in group.configs) {
                const config = group.configs[configKey];
                groupHtml += renderConfigField(configKey, config);
            }
        }
        
        groupHtml += `</div></div>`;
        return groupHtml;
    }
    
    // 鏀堕泦鎵€鏈夐厤缃垎缁勶紝纭繚鑹茬郴閰嶇疆锛坒ileKey === 'color_scheme'锛夋覆鏌撳湪鏈€椤堕儴
    let html = '';

    // 鍦ㄦ牱寮忓垎缁勪箣鍓嶆覆鏌撲竴涓嫭绔嬬殑 SEO / TDK 閰嶇疆鍧楋紙浠呮櫘閫氶〉闈㈡ā寮忥級
    if (!window.isTemplateConfigMode) {
        html += `<div class="config-section seo-section" id="seo_section">
            <div class="config-section-header">
                <span><i class="mdi mdi-google"></i> <?= __('SEO / TDK 璁剧疆') ?></span>
            </div>
            <div class="config-section-body">
                <div class="mb-3">
                    <label for="seo_meta_title" class="form-label"><?= __('') ?></label>
                    <input type="text"
                           id="seo_meta_title"
                           class="form-control"
                           placeholder="<?= __('鐢ㄤ簬娴忚鍣ㄦ爣棰樺拰鎼滅储缁撴灉鐨勪富鏍囬') ?>">
                    <div class="form-text">
                        <?= __('') ?>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="seo_meta_description" class="form-label"><?= __('') ?></label>
                    <textarea id="seo_meta_description"
                              class="form-control"
                              rows="3"
                              placeholder="<?= __('') ?>"></textarea>
                    <div class="form-text">
                        <?= __('') ?>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="seo_meta_keywords" class="form-label"><?= __('鍏抽敭璇嶏紙Meta Keywords锛屽彲閫夛級') ?></label>
                    <input type="text"
                           id="seo_meta_keywords"
                           class="form-control"
                           placeholder="<?= __('浠ヨ嫳鏂囬€楀彿鍒嗛殧鐨勫叧閿瘝锛屼緥濡傦細landing page,seo,marketing') ?>">
                    <div class="form-text">
                        <?= __('') ?>
                    </div>
                </div>

                <div class="alert alert-info mb-0">
                    <i class="mdi mdi-information-outline"></i>
                    <?= __('') ?>
                </div>
            </div>
        </div>`;
    }
    const orderedFileKeys = Object.keys(configGroups || {});
    // 灏?color_scheme 鎻愬墠
    const idx = orderedFileKeys.indexOf('color_scheme');
    if (idx > 0) {
        orderedFileKeys.splice(idx, 1);
        orderedFileKeys.unshift('color_scheme');
    }
    
    for (const fileKey of orderedFileKeys) {
        const fileGroup = configGroups[fileKey];
        if (!fileGroup) continue;
        const isColorSchemeFile = fileKey === 'color_scheme';
        if (fileGroup.groups && typeof fileGroup.groups === 'object' && Object.keys(fileGroup.groups).length > 0) {
            for (const groupKey in fileGroup.groups) {
                const group = fileGroup.groups[groupKey];
                html += renderConfigGroup(fileKey, groupKey, group, isColorSchemeFile);
            }
        }
    }
    
    const configFields = document.querySelector('.config-panel-body');
    if (configFields) {
        configFields.innerHTML = html || '<div class="alert alert-info m-3"><?= __('') ?></div>';

        // 鏅€氶〉闈㈡ā寮忎笅锛屽垵濮嬪寲 SEO / TDK 閰嶇疆鍧楋紝鑷姩浠庨〉闈㈣〃鍗?TDK 瀛楁鍥炲～
        if (!window.isTemplateConfigMode) {
            try {
                initSeoSection();
            } catch (e) {
                console.error('[VisualConfig] 鍒濆鍖?SEO / TDK 鍖哄煙澶辫触:', e);
            }
        }
        
        // 鎭㈠鍒嗙粍灞曞紑鐘舵€侊紙SEO/TDK 涓庨厤鑹插垎缁勫缁堝睍寮€锛屽叾浠栨牴鎹ā鏉跨被鍨嬪喅瀹氾級
        const allSections = Array.from(document.querySelectorAll('.config-section:not(.color-scheme-section):not(.seo-section)'));
        let firstSectionFound = false;
        
        // 鑾峰彇褰撳墠鏍峰紡浠ｇ爜锛屽垽鏂槸鍚︿负鏂扮増妯℃澘
        const externalStyleSelect = document.getElementById('style');
        const currentStyleCode = externalStyleSelect ? externalStyleSelect.value : (window.currentStyle || window.currentTemplateStyleCode || '');
        
        // 鏂扮増妯℃澘鍒楄〃锛堣繖浜涙ā鏉块粯璁ゆ敹璧锋墍鏈夐潪 SEO/TDK 鍒嗙粍锛?
        const newStyleTemplates = ['tpmst', 'marketing-landing', 'modern-shop'];
        const isNewStyleTemplate = newStyleTemplates.some(t => currentStyleCode.toLowerCase().includes(t.toLowerCase()));
        
        // 鑾峰彇鎵€鏈変繚瀛樼殑鐘舵€?
        let savedStates = {};
        try {
            const stateKey = getVisualConfigStateKey();
            savedStates = JSON.parse(localStorage.getItem(stateKey) || '{}');
        } catch (e) {
            console.warn('璇诲彇鍒嗙粍鐘舵€佸け璐?', e);
        }
        
        // 妫€鏌ユ槸鍚︽湁浠讳綍淇濆瓨鐨勭姸鎬侊紙鐢ㄤ簬鍒ゆ柇鏄惁鏄娆″姞杞斤級
        const hasAnySavedState = Object.keys(savedStates).length > 0;
        
        allSections.forEach((section, index) => {
            const sectionId = section.id;
            if (!sectionId) return;
            
            // 妫€鏌ユ槸鍚︽湁淇濆瓨鐨勭姸鎬?
            const hasSavedState = sectionId in savedStates;
            
            if (hasSavedState) {
                // 鏈変繚瀛樼殑鐘舵€侊紝鎭㈠瀹?
                const isExpanded = savedStates[sectionId] !== false;
                if (!isExpanded) {
                    section.classList.add('collapsed');
                } else {
                    section.classList.remove('collapsed');
                }
            } else {
                // 娌℃湁淇濆瓨鐨勭姸鎬侊紝鏍规嵁妯℃澘绫诲瀷鍐冲畾榛樿琛屼负
                if (isNewStyleTemplate) {
                    // 鏂扮増妯℃澘锛氶粯璁ゅ叏閮ㄦ敹璧?
                    section.classList.add('collapsed');
                    saveSectionState(sectionId, false);
                } else if (!hasAnySavedState && !firstSectionFound && index === 0) {
                    // 鏃фā鏉匡細棣栨鍔犺浇涓旀槸绗竴涓粍锛岄粯璁ゅ睍寮€
                    firstSectionFound = true;
                    section.classList.remove('collapsed');
                    saveSectionState(sectionId, true);
                } else {
                    // 鍏朵粬鎯呭喌榛樿鎶樺彔
                    section.classList.add('collapsed');
                    saveSectionState(sectionId, false);
                }
            }
        });
        
        // 缁戝畾鑷姩淇濆瓨浜嬩欢锛堝氨鍦扮粦瀹氾紝纭繚鍔ㄦ€佹覆鏌撳悗绔嬪嵆鐢熸晥锛?
        document.querySelectorAll('.auto-save-field').forEach(field => {
            const handler = function() {
                if (typeof updateSaveStatus === 'function') {
                    updateSaveStatus('', '<?= __('') ?>');
                }
                if (typeof autoSaveConfig === 'function') {
                    autoSaveConfig();
                }
            };
            field.removeEventListener('input', handler);
            field.removeEventListener('change', handler);
            field.addEventListener('input', handler, { passive: true });
            field.addEventListener('change', handler, { passive: true });
        });
        
        // 涓烘瘡涓厤缃垎缁勬坊鍔犳仮澶嶉粯璁ゅ€兼寜閽紙鍦ㄥ垎缁勬爣棰樻梺杈癸級
        document.querySelectorAll('.config-section').forEach(section => {
            const header = section.querySelector('.config-section-header span');
            const resetButtons = section.querySelectorAll('.visual-config-reset-btn');
            
            if (header && resetButtons.length > 0) {
                // 妫€鏌ユ槸鍚﹀凡缁忔湁鎵归噺鎭㈠鎸夐挳
                if (!section.querySelector('.reset-all-fields-btn')) {
                    const resetAllBtn = document.createElement('a');
                    resetAllBtn.href = 'javascript:void(0)';
                    resetAllBtn.className = 'link-danger ms-2 reset-all-fields-btn';
                    resetAllBtn.innerHTML = '<i class="mdi mdi-restore"></i> <?= __('鎭㈠鍏ㄩ儴') ?>';
                    resetAllBtn.title = '<?= __('') ?>';
                    resetAllBtn.onclick = function(e) {
                        e.stopPropagation();
                        resetVisualConfigGroup(section);
                    };
                    header.appendChild(resetAllBtn);
                }
            }
        });
    }
}

// 妯℃澘閰嶇疆妯″紡锛氬埛鏂版ā鏉块瑙堬紙鍒悕锛屼繚鎸佸吋瀹癸級
function refreshTemplatePreview() {
    refreshPreview();
}

// 妯℃澘閰嶇疆妯″紡锛氬埛鏂伴厤缃紙閲嶆柊鎵弿妯℃澘瀛楁锛?
function refreshTemplateConfig(event) {
    const btn = event ? event.target.closest('button') : document.querySelector('button[onclick*="refreshTemplateConfig"]');
    if (!btn) return;
    
    const icon = btn.querySelector('i');
    const originalClass = icon.className;
    
    btn.disabled = true;
    icon.className = 'mdi mdi-loading mdi-spin';
    
    const configPanel = document.querySelector('.config-panel-body');
    if (configPanel) {
        configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('姝ｅ湪鍒锋柊閰嶇疆...') ?></div></div>';
    }
    
    loadTemplateStyleConfig(true)
        .then(() => {
            refreshTemplatePreview();
        })
        .catch(error => {
            console.error('鉂?鍒锋柊澶辫触:', error);
            if (configPanel) {
                configPanel.innerHTML = '<div class="alert alert-danger m-3"><?= __('鍒锋柊閰嶇疆澶辫触') ?></div>';
            }
        })
        .finally(() => {
            btn.disabled = false;
            icon.className = originalClass;
        });
}

// HTML杞箟杈呭姪鍑芥暟锛堟ā鏉块厤缃ā寮忎娇鐢級
function escapeHtmlForTemplate(text) {
    if (typeof text === 'undefined' || text === null) return '';
    const div = document.createElement('div');
    div.textContent = String(text);
    return div.innerHTML;
}

// ========== 鏅€氶〉闈㈡ā寮忥細鍔犺浇鎸囧畾鏍峰紡鐨勯厤缃?==========
async function loadVisualStyleConfig() {
    try {
        const identity = getVisualIdentity();
        const currentPageId = identity.pageId;
        const styleCode = getCurrentVisualStyleCode();
        const locale = window.currentVisualLanguage || '';

        if (!styleCode) {
            const configFields = document.querySelector('.config-panel-body');
            if (configFields) {
                configFields.innerHTML = '<div class="alert alert-info m-3"><?= __('璇峰厛閫夋嫨鏍峰紡妯℃澘锛堟柟妗堬級') ?></div>';
            }
            return;
        }

        // 鏄剧ず鍔犺浇涓?
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2"><?= __('姝ｅ湪鍔犺浇閰嶇疆...') ?></div></div>';
        }

        // 澶嶇敤妯℃澘閰嶇疆鐨勮幏鍙栨帴鍙?
        let url;
        let layoutUrl = '<?= $this->getBackendUrl('*/backend/visual/api/component/layoutFields') ?>';
        if (identity.isVirtual) {
            url = '<?= $this->getBackendUrl('pagebuilder/backend/page/virtual-style-config') ?>' +
                '?style_code=' + encodeURIComponent(styleCode) +
                '&public_id=' + encodeURIComponent(identity.publicId) +
                '&page_type=' + encodeURIComponent(identity.pageType);
        } else {
            url = '<?= $this->getBackendUrl('*/backend/template/getStyleConfig') ?>' +
                '?style_code=' + encodeURIComponent(styleCode) +
                '&page_id=' + encodeURIComponent(currentPageId);
        }
        if (locale) {
            url += '&locale=' + encodeURIComponent(locale);
        }

        var res = await window.Weline.Api.get(url, { silent: true });
        const result = (res && res.data) || res;
        if (result.success && result.data) {
            // 鏄剧ず妯℃澘淇℃伅锛堝悕绉?+ 浠ｇ爜锛?
            if (result.style_info) {
                const badge = document.getElementById('templateInfoBadge');
                if (badge) {
                    const name = result.style_info.name || '';
                    const code = result.style_info.code || '';
                    if (name || code) {
                        badge.textContent = name && code ? (name + ' (' + code + ')') : (name || code);
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }
            // 鐩存帴澶嶇敤娓叉煋閫昏緫
            renderTemplateConfig(result.data);
        } else {
            if (configPanel) {
                configPanel.innerHTML = '<div class="alert alert-danger m-3">' + (result.message || '<?= __('鍔犺浇閰嶇疆澶辫触') ?>') + '</div>';
            }
        }
    } catch (error) {
        console.error('鍔犺浇閰嶇疆澶辫触:', error);
        const configPanel = document.querySelector('.config-panel-body');
        if (configPanel) {
            configPanel.innerHTML = '<div class="alert alert-danger m-3"><?= __('鍔犺浇閰嶇疆澶辫触') ?></div>';
        }
    }
}

// ========== 鍒锋柊鏍峰紡閰嶇疆鎸夐挳锛堟櫘閫氶〉闈㈡ā寮忥級 ==========
window.refreshVisualStyleConfig = async function(event) {
    try {
        // 澶勭悊鎸夐挳 loading 鐘舵€侊紙鍙€夛級
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = true;
            if (icon) { icon.className = 'mdi mdi-loading mdi-spin'; }
        }

        // 閲嶆柊鍔犺浇鏍峰紡閰嶇疆
        await loadVisualStyleConfig();

        // 鍒锋柊棰勮锛堝鏋滃搴斿嚱鏁板瓨鍦ㄥ垯璋冪敤锛?
        if (typeof refreshVisualPreview === 'function') {
            refreshVisualPreview();
        } else if (typeof refreshPreview === 'function') {
            refreshPreview();
        }
    } catch (error) {
        console.error('鍒锋柊鏍峰紡閰嶇疆澶辫触:', error);
        BackendToast.error('<?= __('鍒锋柊澶辫触') ?>锛? + (error && error.message ? error.message : 'Unknown error'));
    } finally {
        const btn = event ? (event.target.closest('button') || event.target) : document.querySelector('button[onclick*="refreshVisualStyleConfig"]');
        const icon = btn ? btn.querySelector('i') : null;
        if (btn) {
            btn.disabled = false;
            if (icon) { icon.className = 'mdi mdi-refresh'; }
        }
    }
};

// ========== 鍏ㄥ睆妯″紡鍔熻兘 ==========
window.toggleFullscreen = function() {
    const wrapper = document.getElementById('visualConfigWrapper');
    const btn = document.getElementById('fullscreenBtn');
    const icon = btn ? btn.querySelector('i') : null;
    const panel = document.getElementById('configPanel');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    
    if (!wrapper || !btn) return;
    
    wrapper.classList.toggle('fullscreen-mode');
    btn.classList.toggle('active');
    
    // 鍒囨崲鍥炬爣
    if (icon) {
        if (wrapper.classList.contains('fullscreen-mode')) {
            icon.className = 'mdi mdi-fullscreen-exit';
            btn.title = '<?= __('') ?>';
            // 杩涘叆鍏ㄥ睆鏃剁珛鍗虫敹璧烽厤缃潰鏉?
            if (panel) panel.classList.add('collapsed');
            // 鏄剧ず鎮诞灞曞紑鎸夐挳
            if (floatingBtn) floatingBtn.style.display = 'block';
        } else {
            icon.className = 'mdi mdi-fullscreen';
            btn.title = '<?= __('鍏ㄥ睆妯″紡') ?>';
            // 閫€鍑哄叏灞忔椂灞曞紑閰嶇疆闈㈡澘
            if (panel) panel.classList.remove('collapsed');
            // 闅愯棌鎮诞灞曞紑鎸夐挳
            if (floatingBtn) floatingBtn.style.display = 'none';
        }
    }
};

// ========== 閰嶇疆闈㈡澘鏀惰捣/灞曞紑鍔熻兘 ==========
window.toggleConfigPanel = function() {
    const panel = document.getElementById('configPanel');
    const btn = document.getElementById('configPanelToggle');
    const floatingBtn = document.getElementById('floatingExpandBtn');
    const wrapper = document.getElementById('visualConfigWrapper');
    
    if (!panel) return;
    
    panel.classList.toggle('collapsed');
    
    // 鏇存柊闈㈡澘鍐呯殑鏀惰捣鎸夐挳鍥炬爣
    if (btn) {
        const icon = btn.querySelector('i');
        if (icon) {
            if (panel.classList.contains('collapsed')) {
                icon.className = 'mdi mdi-chevron-right';
                btn.title = '<?= __('灞曞紑闈㈡澘') ?>';
            } else {
                icon.className = 'mdi mdi-chevron-left';
                btn.title = '<?= __('鏀惰捣闈㈡澘') ?>';
            }
        }
    }
    
    // 鎺у埗鎮诞灞曞紑鎸夐挳鐨勬樉绀猴紙浠呭叏灞忔ā寮忎笅锛?
    if (wrapper && wrapper.classList.contains('fullscreen-mode') && floatingBtn) {
        if (panel.classList.contains('collapsed')) {
            floatingBtn.style.display = 'block';
        } else {
            floatingBtn.style.display = 'none';
        }
    }
};

// ========== 璇█鍒囨崲鍔熻兘 ==========
window.switchVisualLanguage = function(language) {
    
    // 鏇存柊褰撳墠璇█锛堝鏋滄槸鍦ㄦā鏉块厤缃ā寮忥紝闇€瑕佺壒娈婂鐞嗭級
    if (window.isTemplateConfigMode) {
        // 妯℃澘閰嶇疆妯″紡涓嬬殑璇█鍒囨崲閫昏緫
        window.currentVisualLanguage = language;
        
        // 鏄剧ず鍔犺浇鎻愮ず
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-info m-3"><i class="mdi mdi-loading mdi-spin"></i> 姝ｅ湪鍔犺浇 ' + language + ' 璇█閰嶇疆...</div>';
        }
        
        // 閲嶆柊鍔犺浇閰嶇疆锛堟ā鏉块厤缃ā寮忥級
        if (typeof loadTemplateStyleConfig === 'function') {
            loadTemplateStyleConfig().then(() => {
                refreshPreview();
            });
        }
    } else {
        // 姝ｅ父椤甸潰閰嶇疆妯″紡涓嬬殑璇█鍒囨崲閫昏緫
        window.currentVisualLanguage = language;
        
        // 鏄剧ず鍔犺浇鎻愮ず
        const configFields = document.querySelector('.config-panel-body');
        if (configFields) {
            configFields.innerHTML = '<div class="alert alert-info m-3"><i class="mdi mdi-loading mdi-spin"></i> 姝ｅ湪鍔犺浇 ' + language + ' 璇█閰嶇疆...</div>';
        }
        
        // 閲嶆柊鍔犺浇閰嶇疆锛堥〉闈㈤厤缃ā寮忥級
        if (typeof loadVisualStyleConfig === 'function') {
            loadVisualStyleConfig().then(() => {
                if (typeof refreshVisualPreview === 'function') {
                    refreshVisualPreview();
                } else {
                    refreshPreview();
                }
            });
        }
    }
};

// ========== PageSpeed Insights 鍔熻兘 ==========
window.openPageSpeedMobile = function(){
    // 妫€鏌ラ〉闈㈡槸鍚﹀凡鍙戝竷
    const btn = document.getElementById('psiMobileBtn');
    if (btn) {
        const isPublished = btn.getAttribute('data-is-published') === '1';
        if (!isPublished) {
            BackendToast.warning('<?= __('') ?>');
            return;
        }
    }
    
    // 鑾峰彇椤甸潰鍙ユ焺
    let handle = '';
    if (window.isTemplateConfigMode) {
        // 妯℃澘閰嶇疆妯″紡锛氫娇鐢ㄦ祴璇曢〉闈㈠彞鏌?
        const page = <?= ($page && $page->getId()) ? json_encode($page->getData('handle'), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) : 'null' ?>;
        handle = page || '';
    } else {
        // 姝ｅ父妯″紡锛氫粠琛ㄥ崟鑾峰彇
        const handleInput = document.getElementById('handle');
        handle = handleInput ? handleInput.value.trim() : '';
    }
    
    if (!handle){
        BackendToast.warning('<?= __('椤甸潰鍙ユ焺涓嶈兘涓虹┖锛屾棤娉曟祴璇?PageSpeed') ?>');
        return;
    }
    
    const baseUrl = '<?= rtrim(rtrim($this->request->getBaseHost(), '/'), ':') ?>';
    // 鏈湴鐜涓嶅惎鐢?
    try {
        const u = new URL(baseUrl);
        const h = u.hostname || '';
        const isPrivate = (
            h === 'localhost' || h === '127.0.0.1' || h === '::1' ||
            /\.local$/i.test(h) || /^10\./.test(h) || /^192\.168\./.test(h) || /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(h)
        );
        if (isPrivate) {
            const btn = document.getElementById('psiMobileBtn');
            if (btn) {
                btn.disabled = true;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-secondary');
                btn.title = '<?= __('鏈湴鎴栧唴缃戝湴鍧€鏃犳硶浣跨敤 PageSpeed锛岃閮ㄧ讲鍒板叕缃戞垨鎻愪緵鍙闂?URL') ?>';
            }
            return;
        }
    } catch(_) {}
    
    const previewUrl = baseUrl + '/' + handle + '?preview=1';
    // 浣跨敤瀹樻柟 analysis 鎺ュ彛骞朵紶鍏?url 鍙傛暟锛岄粯璁ゆ墜鏈虹
    const psiUrl = 'https://pagespeed.web.dev/analysis?url=' + encodeURIComponent(previewUrl) + '&form_factor=mobile';
    window.open(psiUrl, '_blank', 'noopener');
};

// 鍒濆鍖栨椂鏍规嵁 base-url 鍜屽彂甯冪姸鎬佺鐢ㄦ寜閽紙閬垮厤棣栨鐐瑰嚮鎵嶅弽棣堬級
(function(){
    const btn = document.getElementById('psiMobileBtn');
    if (!btn) return;
    
    // 妫€鏌ラ〉闈㈡槸鍚﹀凡鍙戝竷
    const isPublished = btn.getAttribute('data-is-published') === '1';
    if (!isPublished) {
        btn.disabled = true;
        btn.classList.remove('btn-success');
        btn.classList.add('btn-secondary');
        btn.title = '<?= __('') ?>';
    }
    
    // 妫€鏌ユ槸鍚︿负鏈湴鎴栧唴缃戝湴鍧€
    const baseUrl = btn.getAttribute('data-base-url') || '';
    try {
        const u = new URL(baseUrl);
        const h = u.hostname || '';
        const isPrivate = (
            h === 'localhost' || h === '127.0.0.1' || h === '::1' ||
            /\.local$/i.test(h) || /^10\./.test(h) || /^192\.168\./.test(h) || /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(h)
        );
        if (isPrivate) {
            btn.disabled = true;
            btn.classList.remove('btn-success');
            btn.classList.add('btn-secondary');
            // 濡傛灉椤甸潰涔熸湭鍙戝竷锛屽悎骞舵彁绀轰俊鎭?
            if (!isPublished) {
                btn.title = '<?= __('PageSpeed 娴嬭瘯锛堟墜鏈猴級 - 椤甸潰鏈彂甯冧笖褰撳墠涓烘湰鍦?鍐呯綉鍦板潃锛屾棤娉曡繘琛屾祴璇曘€俓n\n鍘熷洜锛歕n1. 椤甸潰鏈彂甯僜n2. 鏈湴鎴栧唴缃戝湴鍧€鏃犳硶浣跨敤 PageSpeed\n\n瑙ｅ喅鏂规硶锛歕n1. 璇峰厛鍦ㄩ〉闈㈢紪杈戣〃鍗曚腑灏嗛〉闈㈢姸鎬佽缃负"宸插彂甯?\n2. 璇烽儴缃插埌鍏綉鎴栨彁渚涘彲璁块棶 URL') ?>';
            } else {
                btn.title = '<?= __('鏈湴鎴栧唴缃戝湴鍧€鏃犳硶浣跨敤 PageSpeed锛岃閮ㄧ讲鍒板叕缃戞垨鎻愪緵鍙闂?URL') ?>';
            }
        }
    } catch(_) {}
})();

// ========== 閰嶇疆瀵煎叆瀵煎嚭鍔熻兘 ==========
window.exportPageConfig = async function() {
    try {
        if (window.visualIsVirtualMode && !window.isTemplateConfigMode) {
            BackendToast.info('<?= __("宸ヤ綔鍖鸿櫄鎷熼〉闈㈡殏涓嶆敮鎸佸鍑洪厤缃紝璇峰湪鍙戝竷鍚庝娇鐢ㄣ€?") ?>');
            return;
        }
        let pageId = window.pageId || 0;
        let styleCode = '';
        
        if (window.isTemplateConfigMode) {
            // 妯℃澘閰嶇疆妯″紡
            pageId = window.currentTemplatePageId || 0;
            styleCode = window.currentTemplateStyleCode || '';
        } else {
            // 姝ｅ父椤甸潰閰嶇疆妯″紡
            pageId = window.visualPageId || pageId;
            const styleSelect = document.getElementById('style');
            styleCode = styleSelect ? styleSelect.value : '';
            if (!styleCode && typeof currentStyle !== 'undefined' && currentStyle) {
                styleCode = currentStyle;
            }
        }
        
        if (!pageId || !styleCode) {
            BackendToast.error('<?= __("瀵煎嚭澶辫触锛氳鍏堥€夋嫨鏍峰紡妯℃澘") ?>');
            return;
        }
        
        // 鏄剧ず鍔犺浇鐘舵€?
        const exportBtn = document.getElementById('exportConfigBtn');
        const originalHtml = exportBtn ? exportBtn.innerHTML : '';
        if (exportBtn) {
            exportBtn.disabled = true;
            exportBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("瀵煎嚭涓?..") ?>';
        }
        
        // 璋冪敤瀵煎嚭鎺ュ彛
        let url = '';
        if (window.isTemplateConfigMode) {
            url = '<?= $this->getBackendUrl("*/backend/template/exportConfig") ?>' + 
                '?style_code=' + encodeURIComponent(styleCode) + 
                '&page_id=' + encodeURIComponent(pageId);
        } else {
            url = '<?= $this->getBackendUrl("*/backend/page/exportConfig") ?>' + 
                '?page_id=' + encodeURIComponent(pageId) + 
                '&style_code=' + encodeURIComponent(styleCode);
        }
        
        const response = await fetch(url, {
            method: 'GET',
            credentials: 'same-origin'
        });
        
        if (!response.ok) {
            throw new Error('HTTP ' + response.status);
        }
        
        // 鑾峰彇鏂囦欢鍚?
        const contentDisposition = response.headers.get('Content-Disposition');
        let filename = 'config-' + pageId + '-' + styleCode + '.xlsx';
        if (contentDisposition) {
            const filenameMatch = contentDisposition.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
            if (filenameMatch && filenameMatch[1]) {
                filename = filenameMatch[1].replace(/['"]/g, '');
            }
        }
        
        // 涓嬭浇鏂囦欢
        const blob = await response.blob();
        const downloadUrl = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = downloadUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(downloadUrl);
        
        if (typeof showToast === 'function') {
            showToast('success', '<?= __("瀵煎嚭鎴愬姛") ?>', '<?= __("閰嶇疆宸插鍑哄埌Excel鏂囦欢") ?>');
        }
        
        // 鎭㈠鎸夐挳鐘舵€?
        if (exportBtn) {
            exportBtn.innerHTML = originalHtml;
            exportBtn.disabled = false;
        }
    } catch (error) {
        console.error('瀵煎嚭閰嶇疆澶辫触:', error);
        BackendToast.error('<?= __("瀵煎嚭澶辫触") ?>锛? + (error.message || '<?= __("鏈煡閿欒") ?>'));
        
        // 鎭㈠鎸夐挳鐘舵€?
        const exportBtn = document.getElementById('exportConfigBtn');
        if (exportBtn) {
            exportBtn.disabled = false;
            exportBtn.innerHTML = '<i class="mdi mdi-download"></i> <?= __("瀵煎嚭閰嶇疆") ?>';
        }
    }
};

window.importPageConfig = function() {
    // 鍒涘缓闅愯棌鐨勬枃浠惰緭鍏ュ厓绱?
    let fileInput = document.getElementById('configImportFileInput');
    if (!fileInput) {
        fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.id = 'configImportFileInput';
        fileInput.accept = '.xlsx,.xls';
        fileInput.style.display = 'none';
        fileInput.onchange = handleConfigImport;
        document.body.appendChild(fileInput);
    }
    fileInput.click();
};

async function handleConfigImport(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    try {
        if (window.visualIsVirtualMode && !window.isTemplateConfigMode) {
            BackendToast.info('<?= __("宸ヤ綔鍖鸿櫄鎷熼〉闈㈡殏涓嶆敮鎸佸鍏ラ厤缃紝璇峰湪鍙戝竷鍚庝娇鐢ㄣ€?") ?>');
            return;
        }
        const formData = new FormData();
        formData.append('config_file', file);
        
        let pageId = window.pageId || 0;
        let styleCode = '';
        let url = '';
        
        if (window.isTemplateConfigMode) {
            pageId = window.currentTemplatePageId || 0;
            styleCode = window.currentTemplateStyleCode || '';
            url = '<?= $this->getBackendUrl("*/backend/template/importConfig") ?>';
            formData.append('style_code', styleCode);
            formData.append('page_id', pageId);
        } else {
            pageId = window.visualPageId || pageId;
            const styleSelect = document.getElementById('style');
            styleCode = styleSelect ? styleSelect.value : '';
            url = '<?= $this->getBackendUrl("*/backend/page/importConfig") ?>';
            formData.append('page_id', pageId);
            formData.append('style_code', styleCode);
        }
        
        // 鏄剧ず鍔犺浇鐘舵€?
        const importBtn = document.getElementById('importConfigBtn');
        const originalHtml = importBtn ? importBtn.innerHTML : '';
        if (importBtn) {
            importBtn.disabled = true;
            importBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("瀵煎叆涓?..") ?>';
        }
        
        var opts = { method: 'POST', body: formData, credentials: 'same-origin' };
        var res = await window.Weline.Api.request(url, opts);
        const result = (res && res.data) || res;
        
        if (result.success) {
            BackendToast.success('<?= __("瀵煎叆鎴愬姛") ?>锛? + (result.message || '<?= __("閰嶇疆宸插鍏?") ?>'));
            
            // 閲嶆柊鍔犺浇閰嶇疆
            if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                loadTemplateStyleConfig().then(() => {
                    refreshPreview();
                });
            } else if (typeof loadVisualStyleConfig === 'function') {
                loadVisualStyleConfig().then(() => {
                    if (typeof refreshVisualPreview === 'function') {
                        refreshVisualPreview();
                    } else {
                        refreshPreview();
                    }
                });
            }
        } else {
            throw new Error(result.message || '<?= __("瀵煎叆澶辫触") ?>');
        }
        
        // 鎭㈠鎸夐挳鐘舵€?
        if (importBtn) {
            importBtn.innerHTML = originalHtml;
            importBtn.disabled = false;
        }
        
        // 娓呯┖鏂囦欢杈撳叆
        event.target.value = '';
    } catch (error) {
        console.error('瀵煎叆閰嶇疆澶辫触:', error);
        BackendToast.error('<?= __("瀵煎叆澶辫触") ?>锛? + (error.message || '<?= __("鏈煡閿欒") ?>'));
        
        // 鎭㈠鎸夐挳鐘舵€?
        const importBtn = document.getElementById('importConfigBtn');
        if (importBtn) {
            importBtn.disabled = false;
            importBtn.innerHTML = '<i class="mdi mdi-upload"></i> <?= __("瀵煎叆閰嶇疆") ?>';
        }
        
        // 娓呯┖鏂囦欢杈撳叆
        event.target.value = '';
    }
}

// ========== 鎭㈠榛樿鍊煎姛鑳?==========
/**
 * 鎭㈠鍗曚釜閰嶇疆瀛楁涓洪粯璁ゅ€?
 */
window.resetVisualConfigField = function(button) {
    const fieldId = button.getAttribute('data-field-id');
    const fieldType = button.getAttribute('data-config-type');
    const defaultValue = button.getAttribute('data-default-value');
    const configKey = button.getAttribute('data-config-key');
    
    
    const field = document.getElementById(fieldId);
    if (!field) {
        console.error('鉂?鎵句笉鍒板瓧娈?', fieldId);
        return;
    }
    
    // 鏍规嵁瀛楁绫诲瀷杩涜涓嶅悓鐨勫鐞?
    switch (fieldType) {
        case 'text':
        case 'number':
        case 'responsive':
        case 'textarea':
            // 鏂囨湰绫诲瀷锛氳缃负榛樿鍊硷紙濡傛灉涓虹┖鍒欐竻绌猴級
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'select':
            // 涓嬫媺妗嗭細璁剧疆涓洪粯璁ゅ€兼垨绗竴涓€夐」
            if (defaultValue) {
                // 灏濊瘯鎵惧埌骞堕€夋嫨榛樿鍊?
                for (let i = 0; i < field.options.length; i++) {
                    if (field.options[i].value === defaultValue) {
                        field.selectedIndex = i;
                        break;
                    }
                }
            } else {
                field.selectedIndex = 0;
            }
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
            
        case 'radio':
            // Radio 绫诲瀷锛氶€夋嫨榛樿鍊煎搴旂殑 radio
            if (defaultValue) {
                const radioField = document.querySelector(`input[name="${fieldId}"][value="${defaultValue}"]`);
                if (radioField) {
                    radioField.checked = true;
                    radioField.dispatchEvent(new Event('change', { bubbles: true }));
                }
            } else {
                // 濡傛灉娌℃湁榛樿鍊硷紝閫夋嫨绗竴涓?
                const firstRadio = document.querySelector(`input[name="${fieldId}"]`);
                if (firstRadio) {
                    firstRadio.checked = true;
                    firstRadio.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
            break;
            
        case 'color':
            // 棰滆壊閫夋嫨鍣細鐩存帴璁剧疆鍊?
            field.value = defaultValue || '#ffffff';
            field.dispatchEvent(new Event('change', { bubbles: true }));
            break;
        
        case 'color_scheme':
            // 鑹茬郴閫夋嫨锛氳皟鐢ㄩ€夋嫨鍑芥暟浠ユ洿鏂伴殣钘忚緭鍏ヤ笌UI
            if (typeof window.selectColorScheme === 'function') {
                const schemeKey = defaultValue || 'default';
                window.selectColorScheme(fieldId, schemeKey);
            } else {
                // 鍚庡锛氱洿鎺ュ啓鍊煎苟瑙﹀彂淇濆瓨
                field.value = defaultValue || 'default';
                field.dispatchEvent(new Event('change', { bubbles: true }));
                if (typeof window.autoSaveConfig === 'function') {
                    window.autoSaveConfig(true);
                }
            }
            break;
            
        default:
            // 鍏朵粬绫诲瀷锛氳缃负榛樿鍊?
            field.value = defaultValue || '';
            field.dispatchEvent(new Event('change', { bubbles: true }));
    }
    
    // 鏄剧ず鎻愮ず淇℃伅
    if (typeof showToast === 'function') {
        showToast('success', '<?= __('鎴愬姛') ?>', '<?= __('') ?>');
    } else {
    }
};

/**
 * 鏄剧ず鎭㈠榛樿鍊肩‘璁ゆā鎬佹
 */
function showResetConfigConfirmModal(title, message, details, onConfirm) {
    // 妫€鏌?bootstrap 鏄惁鍙敤
    if (typeof bootstrap === 'undefined') {
        console.error('鉂?Bootstrap 鏈姞杞斤紒');
        BackendConfirm.show(message, { title: title }).then((confirmed) => {
            if (confirmed) onConfirm();
        });
        return;
    }
    
    const modalElement = document.getElementById('resetConfigConfirmModal');
    if (!modalElement) {
        console.error('鉂?鎵句笉鍒扮‘璁ゆā鎬佹');
        BackendConfirm.show(message, { title: title }).then((confirmed) => {
            if (confirmed) onConfirm();
        });
        return;
    }
    
    // 璁剧疆妯℃€佹鍐呭
    document.getElementById('resetConfigMessage').textContent = message;
    const detailsEl = document.getElementById('resetConfigDetails');
    if (details) {
        detailsEl.innerHTML = details;
        detailsEl.style.display = 'block';
    } else {
        detailsEl.style.display = 'none';
    }
    
    // 绉婚櫎鏃х殑纭鎸夐挳浜嬩欢鐩戝惉鍣?
    const confirmBtn = document.getElementById('confirmResetConfigBtn');
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
    
    // 缁戝畾鏂扮殑纭浜嬩欢
    newConfirmBtn.onclick = function() {
        const modal = bootstrap.Modal.getInstance(modalElement);
        if (modal) {
            modal.hide();
        }
        onConfirm();
    };
    
    // 鏄剧ず妯℃€佹
    const modal = new bootstrap.Modal(modalElement);
    modal.show();
}

/**
 * 鎭㈠鎵€鏈夐厤缃」涓洪粯璁ゅ€?
 */
window.resetAllVisualConfig = function() {
    // 鏀堕泦鎵€鏈夋仮澶嶆寜閽?
    const allResetButtons = document.querySelectorAll('.visual-config-reset-btn');
    if (allResetButtons.length === 0) {
        if (typeof showToast === 'function') {
            showToast('info', '<?= __('鎻愮ず') ?>', '<?= __('') ?>');
        }
        return;
    }
    
    // 鏄剧ず纭妯℃€佹
    showResetConfigConfirmModal(
        '<?= __('纭鎭㈠鍏ㄩ儴閰嶇疆') ?>',
        '<?= __('') ?>',
        `<i class="mdi mdi-alert"></i> <?= __('杩欏皢褰卞搷') ?> <strong>${allResetButtons.length}</strong> <?= __('') ?>`,
        async function() {
            try {
                // 鏀堕泦鎵€鏈夐渶瑕侀噸缃殑瀛楁鐨?configKey
                const configKeys = [];
                
                allResetButtons.forEach(button => {
                    const configKey = button.getAttribute('data-config-key');
                    if (configKey) {
                        configKeys.push(configKey);
                    }
                });
                
                
                // 鏇存柊淇濆瓨鐘舵€?
                updateSaveStatus('saving', '<?= __('閲嶇疆涓?..') ?>');
                
                let url = '';
                let requestData = {};
                
                if (window.isTemplateConfigMode) {
                    // 妯℃澘閰嶇疆妯″紡
                    url = '<?= $this->getBackendUrl('*/backend/template/resetFieldsToDefault') ?>';
                    requestData = {
                        style_code: window.currentTemplateStyleCode || '',
                        page_id: window.currentTemplatePageId || 0,
                        config_keys: configKeys
                    };
                } else {
                    // 姝ｅ父椤甸潰閰嶇疆妯″紡
                    url = '<?= $this->getBackendUrl('*/backend/preview/resetFieldsToDefault') ?>';
                    const styleSelect = document.getElementById('style');
                    let styleCode = styleSelect ? styleSelect.value : '';
                    requestData = applyVisualIdentityToPayload({
                        page_id: window.visualPageId || window.pageId || 0,
                        style_code: styleCode,
                        config_keys: configKeys,
                        locale: window.currentVisualLanguage || ''
                    });
                }
                
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(requestData) };
                var res = await window.Weline.Api.request(url, opts);
                const result = (res && res.data) || res;
                
                if (result.success) {
                    if (window.isTemplateConfigMode && typeof loadTemplateStyleConfig === 'function') {
                        await loadTemplateStyleConfig();
                    } else if (typeof loadVisualStyleConfig === 'function') {
                        await loadVisualStyleConfig();
                    }
                    
                    // 鍒锋柊棰勮
                    refreshPreview();
                    
                    updateSaveStatus('saved', '<?= __('') ?>');
                    if (typeof showToast === 'function') {
                        showToast('success', '<?= __('鎴愬姛') ?>', `<?= __('') ?> ${result.reset_count || configKeys.length} <?= __('') ?>`);
                    }
                } else {
                    updateSaveStatus('error', '<?= __('閲嶇疆澶辫触') ?>: ' + (result.message || ''));
                    console.error('鉂?閲嶇疆澶辫触:', result);
                    if (typeof showToast === 'function') {
                        showToast('error', '<?= __('澶辫触') ?>', result.message || '<?= __('閲嶇疆澶辫触') ?>');
                    }
                }
            } catch (error) {
                console.error('鉂?閲嶇疆澶辫触:', error);
                updateSaveStatus('error', '<?= __('閲嶇疆澶辫触') ?>: ' + error.message);
                if (typeof showToast === 'function') {
                    showToast('error', '<?= __('閿欒') ?>', error.message || '<?= __('閲嶇疆澶辫触') ?>');
                }
            }
        }
    );
};

/**
 * 鎭㈠鏁翠釜閰嶇疆鍒嗙粍鐨勬墍鏈夊瓧娈典负榛樿鍊?
 */
window.resetVisualConfigGroup = function(section) {
    if (!section) return;
    
    const resetButtons = section.querySelectorAll('.visual-config-reset-btn');
    if (resetButtons.length === 0) {
