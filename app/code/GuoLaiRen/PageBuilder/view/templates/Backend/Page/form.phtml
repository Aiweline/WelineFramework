/**
 * 自动保存样式切换
 * 当用户切换样式时，自动保存到后端，并刷新可视化编辑器
 */
async function autoSaveStyleChange(newStyle) {
    console.log('💾 自动保存样式切换:', newStyle);
    
    // 显示保存提示
    showLoading();
    
    try {
        // 准备表单数据
        const form = document.getElementById('page-form');
        const formData = new FormData(form);
        
        // 更新样式字段
        formData.set('style', newStyle);
        
        // 发送AJAX请求
        const response = await fetch(form.action, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: formData,
            credentials: 'same-origin'
        });
        
        const result = await response.json();
        
        if (result.success) {
            console.log('✅ 样式保存成功');
            
            // 显示成功提示
            showMessage('success', '<?= __('样式已保存，正在刷新页面...') ?>');
            
            // 延迟500ms后刷新页面，让用户看到成功提示
            setTimeout(() => {
                console.log('🔄 刷新页面以应用新样式');
                window.location.reload();
            }, 500);
            
        } else {
            console.error('❌ 样式保存失败:', result.message);
            showMessage('error', '<?= __('样式保存失败：') ?>' + (result.message || '<?= __('未知错误') ?>'));
            
            // 恢复原来的样式选择
            if (result.old_style) {
                styleSelect.value = result.old_style;
            }
        }
    } catch (error) {
        console.error('❌ 保存样式时发生错误:', error);
        showMessage('error', '<?= __('网络错误，样式保存失败') ?>');
    } finally {
        hideLoading();
    }
}

