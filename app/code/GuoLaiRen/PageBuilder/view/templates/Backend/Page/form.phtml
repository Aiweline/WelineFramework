            console.log('📊 跟踪代码已继承（可编辑）:', {
                ga4: !!parentPageData.ga4_id,
                gtm: !!parentPageData.gtm_id,
                fbPixel: !!parentPageData.fb_pixel_id
            });
        }
        
        // 6. 锁定页面类型（禁用"首页"选项）
        if (typeSelect) {
            // 如果当前选中的是"首页"，清空选择
            if (typeSelect.value === 'home_page') {
                typeSelect.value = '';
                console.log('🔒 已清除"首页"类型选择');
            }
            
            // 禁用"首页"选项
            Array.from(typeSelect.options).forEach(option => {
                if (option.value === 'home_page') {
                    option.disabled = true;
                    const baseText = option.textContent.replace(/ \(.*?\)$/, '');
                    option.textContent = baseText + ' <?= __('(子页面不能是主页)') ?>';
                    console.log('🔒 "首页"类型已禁用');
                }
            });
        }
        
        const mode = window.location.pathname.includes('/edit') ? '编辑' : '创建';
        console.log(`🔒 ${mode}子页面：继承配置已应用`, {
            parent_id: currentParentId || urlParentId,
            mode: mode,
            hasParentData: !!parentPageData
        });
        
        // ✅ 继承配置已完成，允许正常操作（但继承的字段仍然锁定）
        setTimeout(() => {
            window.isApplyingInheritance = false;
            console.log('✅ 继承配置已完成，解除自动保存禁令');
        }, 1000); // 延迟1秒，确保所有DOM操作都完成
    }
    
    // 更新页面类型选项的可用性
    function updatePageTypeOptions() {
        const parentId = parentIdSelect.value;
        const isChildPage = parentId && parentId !== '0';
        
        // 如果选择了父页面且当前类型是"首页"，清空选择
        if (isChildPage && typeSelect.value === 'home_page') {
            typeSelect.value = '';
            console.log('🔒 父页面已选择，已清除"首页"类型选择');
        }
        
        // 遍历所有页面类型选项
        Array.from(typeSelect.options).forEach(option => {
            // 如果选择了父页面，禁用"主页"选项
            if (isChildPage && option.value === 'home_page') {
                option.disabled = true;
                // 移除旧的提示文字，再添加新的
                const baseText = option.textContent.replace(/ \(.*?\)$/, '');
                option.textContent = baseText + ' <?= __('(子页面不能是主页)') ?>';
            } else if (option.value === 'home_page') {
                // 恢复主页选项
                option.disabled = false;
                const baseText = option.textContent.replace(/ \(.*?\)$/, '');
                option.textContent = baseText;
            }
        });
        
        console.log('🔄 父页面联动:', {
            parentId: parentId,
            isChildPage: isChildPage,
            currentType: typeSelect.value,
            isLocked: isFromAddChildPage
        });
    }
    
    // 监听父页面选择变化（仅当未锁定时生效）
    if (!isFromAddChildPage) {
        parentIdSelect.addEventListener('change', function() {
            updatePageTypeOptions();
        });
    }
    
    // 页面加载时立即初始化（确保子页面创建时类型限制生效）
    updatePageTypeOptions();
    
    // 额外强制检查：如果有父页面，确保"首页"不被选中
    if ((parentIdSelect.value && parentIdSelect.value !== '0') || isFromAddChildPage) {
        setTimeout(() => {
            if (typeSelect.value === 'home_page') {
                typeSelect.value = '';
                console.log('🔒 强制清除"首页"选择');
            }
            
            // 确保"首页"选项被禁用
            Array.from(typeSelect.options).forEach(option => {
                if (option.value === 'home_page') {
                    option.disabled = true;
                    const baseText = option.textContent.replace(/ \(.*?\)$/, '');
                    option.textContent = baseText + ' <?= __('(子页面不能是主页)') ?>';
                }
            });
        }, 100);
    }
    
    console.log('✅ 父页面与页面类型联动已初始化', {
        isFromAddChildPage: isFromAddChildPage,
        parentIdLocked: parentIdSelect.disabled,
        currentType: typeSelect.value
    });
});

