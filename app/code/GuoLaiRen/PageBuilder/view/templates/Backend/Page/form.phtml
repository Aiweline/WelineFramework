window.publishPage = function() {
    const statusSelect = document.getElementById('status');
    const publishBtn = document.getElementById('publishPageBtn');
    const form = document.getElementById('page-form');
    
    if (!statusSelect || !form) {
        console.error('❌ 找不到状态选择器或表单');
        BackendToast.error('<?= __('系统错误，请刷新页面重试') ?>');
        return;
    }
    
    // 设置状态为已发布
    statusSelect.value = '1';
    
    // 显示加载状态
    const originalHTML = publishBtn.innerHTML;
    publishBtn.disabled = true;
    publishBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('发布中...') ?>';
    
    console.log('📤 正在发布页面...');
    console.log('📊 状态已设置为: 已发布 (1)');
    console.log('📋 表单ID:', form.id);
    
    // 提交表单
    try {
        form.submit();
    } catch (error) {
        console.error('❌ 发布失败:', error);
        BackendToast.error('<?= __('发布失败，请重试') ?>');
        
        // 恢复按钮状态
        publishBtn.disabled = false;
        publishBtn.innerHTML = originalHTML;
    }
};

/**
 * ========================================
 * 确保状态选择器区域始终可见
 * ========================================
 */
document.addEventListener('DOMContentLoaded', function() {
    function ensureStatusVisible() {
        const statusSelect = document.getElementById('status');
        const statusLabel = document.querySelector('label[for="status"]');
        const statusCard = statusSelect?.closest('.card');
        
        if (statusSelect && statusLabel && statusCard) {
            // 强制显示
            statusCard.style.display = 'block';
            statusCard.style.visibility = 'visible';
            statusCard.style.opacity = '1';
            statusSelect.style.display = 'block';
            statusSelect.style.visibility = 'visible';
            statusLabel.style.display = 'block';
            statusLabel.style.visibility = 'visible';
        }
    }
    
    // 立即执行一次
    ensureStatusVisible();
    
    // 定期检查（防止被其他代码隐藏）
    setInterval(ensureStatusVisible, 1000);
    
    // 监听DOM变化，确保状态区域不被隐藏
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && 
                (mutation.attributeName === 'style' || mutation.attributeName === 'class')) {
                ensureStatusVisible();
            }
        });
    });
    
    const statusCard = document.querySelector('.col-lg-4 .card:first-child');
    if (statusCard) {
        observer.observe(statusCard, {
            attributes: true,
            attributeFilter: ['style', 'class']
        });
    }
});

