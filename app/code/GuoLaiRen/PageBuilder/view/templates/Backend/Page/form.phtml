// 表单验证和提交
(function() {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.prototype.slice.call(forms).forEach(function(form) {
        // Handle 唯一性检查相关变量
        let handleCheckTimeout = null;
        let lastCheckedHandle = '';
        let isHandleValid = false;
        const handleInput = document.getElementById('handle');
        const handleValidationIcon = document.getElementById('handle-validation-icon');
        const handleValidationMessage = document.getElementById('handle-validation-message');
        const currentPageId = <?= $isEdit && $page ? $page->getId() : 0 ?>;
        
        // Debounce 函数
        function debounce(func, delay) {
            return function(...args) {
                clearTimeout(handleCheckTimeout);
                handleCheckTimeout = setTimeout(() => func.apply(this, args), delay);
            };
        }
        
        // 检查 handle 唯一性
        async function checkHandleUniqueness(handle) {
            if (!handle || handle.trim() === '') {
                hideHandleValidation();
                return;
            }
            
            // 编辑模式下，如果 handle 等于原始值，直接标记为可用（无需请求）
            const originalValue = handleInput.getAttribute('data-original-value') || '';
            if (currentPageId > 0 && handle === originalValue) {
                console.log('✅ Handle 未改变，保持原值:', handle);
                lastCheckedHandle = handle;
                isHandleValid = true;
                showHandleAvailable('<?= __('当前页面的句柄') ?>');
                handleInput.classList.remove('is-invalid');
                handleInput.classList.add('is-valid');
                return;
            }
            
            // 显示检查中状态
            showHandleChecking();
            
            try {
                const checkUrl = '<?= $this->getBackendUrl('*/backend/page/checkHandle') ?>' +
                    '?handle=' + encodeURIComponent(handle) +
                    '&page_id=' + currentPageId;
                
                console.log('🔍 检查 handle 唯一性:', handle, '(页面ID:', currentPageId, ')');
                
                var opts = { method: 'GET', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin', silent: true };
                var res = await window.Weline.Api.request(checkUrl, opts);
                const result = (res && res.data) || res;
                console.log('✅ 检查结果:', result);
                
                lastCheckedHandle = handle;
                isHandleValid = result.available === true;
                
                if (result.available) {
                    showHandleAvailable(result.message);
                    handleInput.classList.remove('is-invalid');
                    handleInput.classList.add('is-valid');
                } else {
                    showHandleUnavailable(result.message, result.existing_page);
                    handleInput.classList.remove('is-valid');
                    handleInput.classList.add('is-invalid');
                }
                
            } catch (error) {
                console.error('❌ 检查 handle 失败:', error);
                showHandleUnavailable('<?= __('检查失败，请稍后重试') ?>');
                isHandleValid = false;
                handleInput.classList.remove('is-valid');
                handleInput.classList.add('is-invalid');
            }
        }
        
        // 显示检查中状态
        function showHandleChecking() {
            handleValidationIcon.style.display = 'block';
            handleValidationIcon.querySelectorAll('span').forEach(s => s.style.display = 'none');
            handleValidationIcon.querySelector('.handle-checking').style.display = 'inline';
            handleValidationMessage.style.display = 'none';
        }
        
        // 显示可用状态
        function showHandleAvailable(message) {
            handleValidationIcon.style.display = 'block';
            handleValidationIcon.querySelectorAll('span').forEach(s => s.style.display = 'none');
            handleValidationIcon.querySelector('.handle-available').style.display = 'inline';
            
            handleValidationMessage.style.display = 'block';
            handleValidationMessage.className = 'small mt-1 text-success';
            handleValidationMessage.innerHTML = '<i class="mdi mdi-check me-1"></i>' + message;
        }
        
        // 显示不可用状态
        function showHandleUnavailable(message, existingPage) {
            handleValidationIcon.style.display = 'block';
            handleValidationIcon.querySelectorAll('span').forEach(s => s.style.display = 'none');
            handleValidationIcon.querySelector('.handle-unavailable').style.display = 'inline';
            
            handleValidationMessage.style.display = 'block';
            handleValidationMessage.className = 'small mt-1 text-danger';
            
            let messageHtml = '<i class="mdi mdi-alert me-1"></i>' + message;
            if (existingPage) {
                messageHtml += '<br><span class="text-muted">已被页面使用：' + 
                    (existingPage.name || existingPage.title || 'ID:' + existingPage.id) + 
                    '</span>';
            }
            handleValidationMessage.innerHTML = messageHtml;
        }
        
        // 隐藏验证状态
        function hideHandleValidation() {
            handleValidationIcon.style.display = 'none';
            handleValidationMessage.style.display = 'none';
            handleInput.classList.remove('is-valid', 'is-invalid');
            isHandleValid = false;
        }
        
        // 监听 handle 输入（带 debounce）
        const debouncedCheck = debounce(function(event) {
            const handle = event.target.value.trim();
            checkHandleUniqueness(handle);
        }, 500); // 500ms 延迟
        
        handleInput.addEventListener('input', debouncedCheck);
        
        // 监听 handle 输入（实时格式化为小写）
        handleInput.addEventListener('input', function(event) {
            // 自动转换为小写并移除非法字符
            let value = event.target.value.toLowerCase();
            value = value.replace(/[^a-z0-9\-]/g, '');
            if (value !== event.target.value) {
                event.target.value = value;
            }
        });
        
        // ==================== 访问地址更新逻辑 ====================
        // 展示用：一律用站点库里的 URL（域名不变）；同 host 且当前请求带端口时，仅在展示时注入端口
        <?php 
        $websitesForUrl = $this->getData('websites') ?? [];
        $websiteUrlMap = [];
        foreach ($websitesForUrl as $ws) {
            $wsId = (int)($ws['website_id'] ?? 0);
            $wsUrl = $ws['url'] ?? '';
            if ($wsId > 0 && $wsUrl) {
                $websiteUrlMap[$wsId] = rtrim($wsUrl, '/');
            }
        }
        $currentOriginForJs = rtrim($this->request->getBaseHost(), '/');
        $currentPortForJs = parse_url($currentOriginForJs, PHP_URL_PORT);
        ?>
        const websiteUrlMap = <?= json_encode($websiteUrlMap) ?>;
        const currentOriginForPort = '<?= htmlspecialchars($currentOriginForJs, ENT_QUOTES, 'UTF-8') ?>';
        const currentPortForDisplay = <?= json_encode($currentPortForJs !== null && $currentPortForJs !== '' ? (string)$currentPortForJs : '') ?>;

        function isSameHostOrLocal(siteHost, currHost) {
            if (!siteHost || !currHost) return false;
            var s = siteHost.toLowerCase(), c = currHost.toLowerCase();
            if (s === c) return true;
            return (s === 'localhost' || s === '127.0.0.1') && (c === 'localhost' || c === '127.0.0.1');
        }
        function injectPortForDisplay(url, port) {
            if (!url || !port || port === '80' || port === '443') return url;
            try {
                var u = new URL(url);
                u.port = port;
                return u.origin + (u.pathname || '') + (u.search || '') + (u.hash || '');
            } catch (e) { return url; }
        }
        function getDisplayBaseUrl(websiteId) {
            if (!websiteId || !websiteUrlMap[websiteId]) return currentOriginForPort;
            return websiteUrlMap[websiteId];
        }
        function getDisplayBaseUrlWithPort(websiteId) {
            var base = getDisplayBaseUrl(websiteId);
            if (!currentPortForDisplay) return base;
            try {
                var siteHost = new URL(base).hostname;
                var currHost = new URL(currentOriginForPort).hostname;
                if (isSameHostOrLocal(siteHost, currHost)) return injectPortForDisplay(base, currentPortForDisplay);
            } catch (e) {}
            return base;
        }
        window.getDisplayBaseUrlWithPort = getDisplayBaseUrlWithPort;
        window.currentOriginForPort = currentOriginForPort;
        
        // 更新访问地址显示的函数
        function updatePageUrlDisplay() {
            const urlInput = document.getElementById('pageUrlDisplay');
            const websiteSelect = document.getElementById('website_id');
            const handleInputEl = document.getElementById('handle');
            const pageTypeSelect = document.getElementById('type');
            
            if (!urlInput) return;
            
            // 获取当前选中的网站ID
            const websiteId = websiteSelect ? parseInt(websiteSelect.value) || 0 : 0;
            
            // 展示用 base（站点 URL；同 host 且当前请求带端口时注入端口便于打开）
            const baseUrl = getDisplayBaseUrlWithPort(websiteId);
            
            // 获取当前handle
            const handle = handleInputEl ? handleInputEl.value.trim() : '';
            
            // 检查是否是首页类型
            const pageType = pageTypeSelect ? pageTypeSelect.value : '';
            const isHomePage = pageType === '<?= \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME ?>';
            
            // 构建访问地址
            let pageUrl;
            if (isHomePage && !handle) {
                // 首页类型且没有handle：直接使用网站地址
                pageUrl = baseUrl;
            } else if (handle) {
                // 有handle：网站地址 + handle
                pageUrl = baseUrl + '/' + handle.replace(/^\//, '');
            } else {
                // 没有handle：只显示网站地址
                pageUrl = baseUrl;
            }
            
            urlInput.value = pageUrl;
        }
        
        // 监听 handle 输入变化更新访问地址
        handleInput.addEventListener('input', updatePageUrlDisplay);
        
        // 监听站点选择变化更新访问地址
        const websiteSelectEl = document.getElementById('website_id');
        if (websiteSelectEl) {
            websiteSelectEl.addEventListener('change', updatePageUrlDisplay);
        }
        
        // 监听页面类型选择变化更新访问地址
        const pageTypeSelectEl = document.getElementById('type');
        if (pageTypeSelectEl) {
            pageTypeSelectEl.addEventListener('change', updatePageUrlDisplay);
        }
        
        form.addEventListener('submit', function(event) {
            // 同步所有 CKEditor 编辑器的内容到 textarea
            if (window.pageEditors) {
                for (let editorId in window.pageEditors) {
                    const editor = window.pageEditors[editorId];
                    const textarea = document.getElementById(editorId);
                    if (textarea) {
                        textarea.value = editor.getData();
                    }
                }
            }
            
            // 🔧 确保样式字段的值被正确设置（从选中的样式卡片获取）
            const styleSelect = document.getElementById('style');
            if (styleSelect) {
                let styleCodeToSet = null;
                
                // 优先从选中的样式卡片获取样式代码
                const selectedStyleCard = document.querySelector('.style-card.selected');
                if (selectedStyleCard && selectedStyleCard.dataset.styleCode) {
                    styleCodeToSet = selectedStyleCard.dataset.styleCode;
                    console.log('🔧 从样式卡片获取样式代码:', styleCodeToSet);
                }
                
                // 如果样式卡片没有选中，尝试从隐藏的 select 获取
                if (!styleCodeToSet && styleSelect.value) {
                    styleCodeToSet = styleSelect.value;
                    console.log('🔧 从隐藏select获取样式代码:', styleCodeToSet);
                }
                
                // 如果样式选择器为空但有父页面数据，使用父页面的样式
                if (!styleCodeToSet && window.parentPageData && window.parentPageData.style) {
                    styleCodeToSet = window.parentPageData.style;
                    console.log('🔧 使用父页面样式:', styleCodeToSet);
                }
                
                // 如果仍然没有值，尝试从页面数据中获取（编辑模式）
                if (!styleCodeToSet && pageIdForm) {
                    // 从当前页面的样式数据中获取
                    const currentPageStyle = '<?= $page && $page->getData("style") ? htmlspecialchars($page->getData("style")) : "" ?>';
                    if (currentPageStyle) {
                        styleCodeToSet = currentPageStyle;
                        console.log('🔧 使用当前页面样式:', styleCodeToSet);
                    }
                }
                
                // 设置样式值
                if (styleCodeToSet) {
                    if (styleSelect.value !== styleCodeToSet) {
                        console.log('🔧 设置样式字段值:', styleCodeToSet);
                        styleSelect.value = styleCodeToSet;
                    }
                }
                
                // 如果样式选择器被锁定（readOnly），确保值仍然可以被提交
                // 移除 readOnly 属性，但保持视觉上的锁定状态
                if (styleSelect.readOnly) {
                    const currentValue = styleSelect.value;
                    styleSelect.readOnly = false;
                    styleSelect.removeAttribute('readonly');
                    styleSelect.style.pointerEvents = 'auto';
                    styleSelect.value = currentValue;
                    console.log('🔧 解除样式选择器只读状态以允许提交，当前值:', currentValue);
                }
                
                // 最后检查：如果样式字段仍然为空，记录警告
                if (!styleSelect.value) {
                    console.warn('⚠️ 警告：样式字段为空，可能导致表单验证失败');
                }
            }
            
            // 检查 handle 唯一性
            const currentHandle = handleInput.value.trim();
            if (currentHandle && lastCheckedHandle === currentHandle && !isHandleValid) {
                event.preventDefault();
                event.stopPropagation();
                BackendToast.warning('<?= __('页面句柄已被使用，请使用其他句柄后再提交！') ?>');
                handleInput.focus();
                handleInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return false;
            }
            
            // 检查表单验证
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
                form.classList.add('was-validated');
                
                // 查找所有无效字段并显示提示
                const invalidFields = form.querySelectorAll(':invalid');
                if (invalidFields.length > 0) {
                    const firstInvalid = invalidFields[0];
                    const fieldName = firstInvalid.getAttribute('name') || firstInvalid.id || '字段';
                    let errorMessage = `<?= __('请填写必填字段：') ?>${fieldName}`;
                    
                    // 特殊处理样式字段
                    if (firstInvalid.id === 'style' || firstInvalid.name === 'style') {
                        errorMessage = '<?= __('请先选择页面样式模板！') ?>';
                    }
                    
                    // 滚动到第一个无效字段
                    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalid.focus();
                    
                    // 显示错误提示
                    setTimeout(() => {
                        BackendToast.error(errorMessage);
                    }, 100);
                }
                
                console.error('❌ 表单验证失败，无效字段数量:', invalidFields.length);
                invalidFields.forEach(field => {
                    console.error('  - 无效字段:', field.id || field.name, '值:', field.value);
                });
                
                return false;
            }
            form.classList.add('was-validated');
            
            // 提交前最后检查：确保样式字段有值
            if (styleSelect && !styleSelect.value) {
                event.preventDefault();
                event.stopPropagation();
                BackendToast.warning('<?= __('请先选择页面样式模板！') ?>');
                // 滚动到样式选择区域
                const styleSection = document.querySelector('#styleCardsContainer') || styleSelect;
                if (styleSection) {
                    styleSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                return false;
            }
            
            console.log('✅ 表单验证通过，准备提交');
            console.log('📋 表单数据:', {
                handle: form.querySelector('[name="handle"]')?.value,
                name: form.querySelector('[name="name"]')?.value,
                type: form.querySelector('[name="type"]')?.value,
                style: form.querySelector('[name="style"]')?.value,
                status: form.querySelector('[name="status"]')?.value
            });
        }, false);
    });
})();

