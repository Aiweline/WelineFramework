    const urlParams = new URLSearchParams(window.location.search);
    const urlParentId = urlParams.get('parent_id');
    const isFromAddChildPage = urlParentId && urlParentId !== '0';
    
    // 获取父页面数据（从PHP传递）
    const parentPageData = <?= json_encode($this->getData('parent_page_data')) ?>;
    // 保存到 window 对象，以便在表单提交时使用
    window.parentPageData = parentPageData;
    
    // 检查当前页面是否有父页面（编辑模式）
    // 优先使用 PHP 传递的 parent_id 值，避免读取可能被修改的 select 值
    const phpParentId = '<?= $this->getData('parent_id') ?? 0 ?>';
