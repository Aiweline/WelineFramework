                        // 获取页面关联站点的 URL
                        $pageWebsiteUrl = '';
                        $pageWebsiteId = $page ? (int)($page->getData('website_id') ?? 0) : 0;
                        if ($pageWebsiteId > 0) {
                            try {
                                $websiteModel = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Websites\Model\Website::class);
                                $pageWebsite = clone $websiteModel;
                                $pageWebsite->load($pageWebsiteId);
                                if ($pageWebsite->getId()) {
                                    $pageWebsiteUrl = $pageWebsite->getData(\Weline\Websites\Model\Website::schema_fields_URL);
                                }
                            } catch (\Exception $e) {
                                // 忽略错误
                            }
                        }
                        // 展示用 base：一律用站点库里的 URL（域名不变）；仅当同 host 且当前请求带端口时，在展示地址上注入端口便于打开
                        $baseUrlForDisplay = $pageWebsiteUrl !== '' ? rtrim($pageWebsiteUrl, '/') : rtrim($this->request->getBaseHost(), '/');
                        $currentOrigin = rtrim($this->request->getBaseHost(), '/');
                        $currentPortForDisplay = parse_url($currentOrigin, PHP_URL_PORT);
                        $currHost = parse_url($currentOrigin, PHP_URL_HOST);
                        $siteHost = parse_url($baseUrlForDisplay, PHP_URL_HOST);
                        $isLocal = function ($h) { return $h !== false && in_array(strtolower($h), ['localhost', '127.0.0.1'], true); };
                        $sameHostForPort = ($currHost !== false && $siteHost !== false && (strcasecmp($currHost, $siteHost) === 0 || ($isLocal($currHost) && $isLocal($siteHost))));
                        if ($sameHostForPort && $currentPortForDisplay !== null && $currentPortForDisplay !== '' && $currentPortForDisplay !== '80' && $currentPortForDisplay !== '443') {
                            $parsed = parse_url($baseUrlForDisplay);
                            $baseUrlForDisplay = ($parsed['scheme'] ?? 'http') . '://' . ($parsed['host'] ?? '') . ':' . $currentPortForDisplay . ($parsed['path'] ?? '') . (isset($parsed['query']) ? '?' . $parsed['query'] : '') . (isset($parsed['fragment']) ? '#' . $parsed['fragment'] : '');
                            $baseUrlForDisplay = rtrim(preg_replace('#/+#', '/', $baseUrlForDisplay), '/');
                        }
                        $handleForDisplay = $page ? ($page->getData('handle') ?? '') : '';
                        $pageType = $page ? ($page->getData('type') ?? '') : '';
                        $isHomePage = ($pageType === \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME);
                        function appendPortIfExists($url) {
                            $parsedUrl = parse_url($url);
                            $scheme = isset($parsedUrl['scheme']) ? $parsedUrl['scheme'] . '://' : '';
                            $host = $parsedUrl['host'] ?? '';
                            $port = isset($parsedUrl['port']) ? ':' . $parsedUrl['port'] : '';
                            $path = isset($parsedUrl['path']) ? $parsedUrl['path'] : '';
                            $user = $parsedUrl['user'] ?? '';
                            $pass = isset($parsedUrl['pass']) ? ':' . $parsedUrl['pass']  : '';
                            $pass = ($user || $pass) ? "$pass@" : '';
                            $auth = $user ? "$user$pass" : '';
                            $query = isset($parsedUrl['query']) ? '?' . $parsedUrl['query'] : '';
                            $fragment = isset($parsedUrl['fragment']) ? '#' . $parsedUrl['fragment'] : '';
                            return "$scheme$auth$host$port$path$query$fragment";
                        }
                        $displayedBaseUrlWithPort = appendPortIfExists($baseUrlForDisplay);

                        $initialPageUrl = ($isHomePage && empty($handleForDisplay)) 
                            ? $displayedBaseUrlWithPort 
                            : ($displayedBaseUrlWithPort . '/' . ltrim($handleForDisplay, '/'));
