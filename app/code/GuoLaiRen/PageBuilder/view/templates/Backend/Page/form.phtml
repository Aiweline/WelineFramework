<script>
// ==================== Toast 通知函数（全局） ====================
function showToast(type, title, message) {
    // 检查是否有全局的 Toast 方法
    if (typeof Toastify !== 'undefined') {
        Toastify({
            text: title + (message ? '<br>' + message : ''),
            duration: 3000,
            gravity: "top",
            position: "right",
            backgroundColor: type === 'success' ? "#28a745" : "#dc3545",
            escapeMarkup: false
        }).showToast();
    } else if (typeof toastr !== 'undefined') {
        toastr[type](message || '', title);
    } else {
        // 降级为简单的通知元素
        if (type === 'success') {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;top:20px;right:20px;background:#28a745;color:white;padding:15px 20px;border-radius:5px;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:11000;max-width:400px;';
            toast.innerHTML = '<strong>' + title + '</strong><br>' + (message || '');
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.transition = 'opacity 0.3s';
                toast.style.opacity = '0';
                setTimeout(() => document.body.removeChild(toast), 300);
            }, 3000);
        } else {
            BackendToast.info(title + (message ? ': ' + message : ''));
        }
    }
}

/**
 * AI一键生成模板配置（可视化配置工具栏按钮使用）
 * - 调用后端 AI 接口生成配置
 * - 回填前弹出确认面板预览所有配置项
 * - 回填后为对应输入框添加蓝色边框标记
 */
window.generateTemplateConfig = function() {
    // 获取页面ID和模板代码
    let pageId = window.visualPageId || <?= $pageId ?: 0 ?>;
    let styleCode = window.currentTemplateStyleCode || window.currentStyle || '';
    
    // 如果还没有，尝试从全局变量获取
    if (!pageId && typeof window.visualConfigData !== 'undefined' && window.visualConfigData) {
        pageId = window.visualConfigData.page_id || pageId;
        styleCode = window.visualConfigData.style_code || styleCode;
    }
    
    // 如果还没有，尝试从DOM获取
    if (!pageId) {
        const pageIdInput = document.querySelector('input[name="page_id"], input[id="page_id"]');
        if (pageIdInput) {
            pageId = parseInt(pageIdInput.value) || 0;
        }
    }
    
    if (!styleCode) {
        const styleSelect = document.querySelector('select[name="style"], select[id="style"]');
        if (styleSelect) {
            styleCode = styleSelect.value || '';
        }
    }
    
    if (pageId <= 0) {
        BackendToast.warning('<?= __('页面ID不能为空') ?>');
        return;
    }
    
    if (!styleCode) {
        BackendToast.warning('<?= __('模板代码不能为空') ?>');
        return;
    }
    
    const btn = document.getElementById('aiGenerateTemplateConfigBtn');
    if (!btn) {
        console.error('[AI生成配置] 找不到按钮 #aiGenerateTemplateConfigBtn');
        return;
    }
    const originalHtml = btn.innerHTML;
    
    // 设置AI生成状态标志，禁止关闭可视化配置
    window.isAiGenerating = true;

    // 弹出“正在生成”等待框，禁止用户关闭（直到成功或失败）
    // 显示"正在生成"提示
    BackendToast.info('<?= __('AI正在生成配置，请稍候...') ?>', 0);
    
    // 显示加载状态
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> <?= __('生成中...') ?>';
    
    // 准备请求数据
    const formData = new FormData();
    formData.append('page_id', pageId);
    formData.append('style_code', styleCode);
    
    var url = '<?= $this->getBackendUrl("*/backend/ai-generate/template-config") ?>';
    var opts = { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } };
    var req = window.Weline.Api.request(url, opts);
    req.then(function(res) {
        var data = (res && res.data) || res;
        // 调试日志
        console.log('[AI生成配置] 响应数据:', data);
        
        // 清除AI生成状态标志，允许关闭可视化配置
        window.isAiGenerating = false;
        
        // 恢复按钮状态
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        
        // 检查响应数据
        if (!data) {
            console.error('[AI生成配置] 响应数据为空');
            BackendToast.error('<?= __('响应数据为空') ?>');
            return;
        }
        
        if (!data.success) {
            console.error('[AI生成配置] 生成失败:', data.message || '未知错误');
            const errorMessage = data.message || '<?= __('生成失败') ?>';
            BackendToast.error(errorMessage);
            return;
        }
        
        if (!data.data || (typeof data.data === 'object' && Object.keys(data.data).length === 0)) {
            console.warn('[AI生成配置] 没有生成任何配置项');
            BackendToast.warning('<?= __('AI没有生成任何配置项') ?>');
            return;
        }
        
        // 收集要回填的配置项信息
        const configs = data.data;
        console.log('[AI生成配置] 配置项数量:', Object.keys(configs).length);
        const configItems = [];
        const filledInputs = []; // 用于存储将被填充的输入框
        const allConfigItems = []; // 存储所有配置项（包括找不到输入框的）
            
        for (const key in configs) {
            if (configs.hasOwnProperty(key)) {
                const value = configs[key];
                
                // 方法1: 先尝试直接通过data-config-key查找输入框
                let input = document.querySelector(`input[data-config-key="${key}"], textarea[data-config-key="${key}"], select[data-config-key="${key}"]`);
                
                // 方法2: 如果没找到，尝试通过auto-save-field类查找
                if (!input) {
                    input = document.querySelector(`.auto-save-field[data-config-key="${key}"]`);
                }
                
                // 方法3: 查找配置字段容器，然后在容器内查找输入框
                let fieldContainer = null;
                if (!input) {
                    fieldContainer = document.querySelector(`[data-config-key="${key}"]`);
                    if (fieldContainer) {
                        // 在容器内查找输入框
                        input = fieldContainer.querySelector('input[type="text"], input[type="number"], input[type="email"], input[type="url"], textarea, select');
                        
                        // 如果还是没找到，尝试通过auto-save-field类查找
                        if (!input) {
                            input = fieldContainer.querySelector('.auto-save-field');
                        }
                    }
                } else {
                    // 如果找到了输入框，尝试找到其容器以获取标签
                    fieldContainer = input.closest('[data-config-key]');
                }
                
                // 获取配置项标签
                let label = key;
                if (fieldContainer) {
                    label = fieldContainer.getAttribute('data-config-label') || label;
                } else if (input) {
                    // 尝试从输入框的父容器获取标签
                    const parentContainer = input.closest('.config-field-item, .form-group, .mb-3');
                    if (parentContainer) {
                        const labelElement = parentContainer.querySelector('label');
                        if (labelElement) {
                            label = labelElement.textContent.trim() || label;
                        }
                    }
                }
                
                // 记录所有配置项（用于显示）
                allConfigItems.push({
                    key: key,
                    label: label,
                    value: value,
                    hasInput: false
                });
                
                if (input && (input.tagName === 'TEXTAREA' || input.tagName === 'INPUT' || input.tagName === 'SELECT')) {
                    console.log('[AI生成配置] 找到配置项:', key, '标签:', label, '输入框:', input);
                    configItems.push({
                        key: key,
                        label: label,
                        value: value,
                        input: input
                    });
                    filledInputs.push(input);
                    // 更新allConfigItems中对应项的hasInput状态
                    allConfigItems[allConfigItems.length - 1].hasInput = true;
                } else {
                    console.warn('[AI生成配置] 未找到配置项输入框:', key);
                }
            }
        }
        
        console.log('[AI生成配置] 找到可填充的配置项数量:', configItems.length, '总配置项数量:', allConfigItems.length);
        
        // 即使没有找到可填充的配置项，也显示所有生成的配置项
        if (configItems.length === 0) {
            console.warn('[AI生成配置] 没有找到可填充的配置项，但会显示所有生成的配置项');
        }
        
        // 构建提示面板内容（显示所有配置项，包括找不到输入框的）
        let previewHtml = '<div class="ai-fill-preview">';
        previewHtml += '<table class="table table-sm table-bordered">';
        previewHtml += '<thead><tr><th style="width: 30%;"><?= __('配置项') ?></th><th style="width: 70%;"><?= __('生成值') ?></th></tr></thead>';
        previewHtml += '<tbody>';
        
        // 使用allConfigItems显示所有配置项
        const itemsToShow = configItems.length > 0 ? configItems : allConfigItems;
        
        itemsToShow.forEach(function(item) {
            const displayValue = typeof item.value === 'string' && item.value.length > 100 
                ? item.value.substring(0, 100) + '...' 
                : item.value;
            const canFill = item.input || item.hasInput;
            const rowClass = canFill ? '' : 'table-warning';
            previewHtml += '<tr class="' + rowClass + '">';
            previewHtml += '<td><strong>' + escapeHtml(item.label) + '</strong><br><small class="text-muted">' + escapeHtml(item.key) + '</small>';
            if (!canFill) {
                previewHtml += '<br><span class="badge bg-warning text-dark small"><?= __('未找到对应输入框') ?></span>';
            }
            previewHtml += '</td>';
            previewHtml += '<td><code>' + escapeHtml(String(displayValue)) + '</code></td>';
            previewHtml += '</tr>';
        });
        
        previewHtml += '</tbody></table>';
        previewHtml += '</div>';
        
        // 如果有些配置项找不到输入框，添加提示
        const unfilledCount = allConfigItems.length - configItems.length;
        if (unfilledCount > 0) {
            previewHtml += '<div class="alert alert-warning mt-3 mb-0">';
            previewHtml += '<i class="mdi mdi-alert"></i> ';
            previewHtml += '<?= __('有') ?> ' + unfilledCount + ' <?= __('个配置项未找到对应的输入框，将不会自动填充') ?>';
            previewHtml += '</div>';
        }
        
        // 显示提示面板，必须等待用户点击确认应用才执行回填
        console.log('[AI生成配置] 准备显示提示面板，可填充配置项数量:', configItems.length, '总配置项数量:', allConfigItems.length);
        
        // 构建提示信息
        let summaryText = '';
        if (configItems.length > 0) {
            summaryText = '<p class="mt-3 text-muted"><small><?= __('共') ?> ' + allConfigItems.length + ' <?= __('个配置项生成，其中') ?> ' + configItems.length + ' <?= __('个可以自动填充') ?></small></p>';
        } else {
            summaryText = '<p class="mt-3 text-warning"><small><?= __('共') ?> ' + allConfigItems.length + ' <?= __('个配置项生成，但未找到对应的输入框，无法自动填充') ?></small></p>';
        }
        
        // 关闭等待中的“正在生成”弹窗，然后显示预览弹窗
        if (configItems.length > 0) {
            
            // 使用 BackendConfirm 显示确认弹窗
            console.log('[AI生成配置] 显示确认弹窗');
            const confirmMessage = '<?= __('AI生成配置完成') ?>：<?= __('即将回填') ?> ' + configItems.length + ' <?= __('个配置项，是否确认应用？') ?>';
            BackendConfirm.show(confirmMessage, {
                title: '<?= __('AI生成配置完成') ?>',
                confirmText: '<?= __('确认应用') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'info'
            }).then(function(confirmed) {
                console.log('[AI生成配置] 用户操作结果:', confirmed);
                if (confirmed) {
                    // 用户点击确认应用后执行回填
                    console.log('[AI生成配置] 用户确认，开始执行回填');
                    // 检查 performConfigFill 是否在全局作用域
                    if (typeof window.performConfigFill === 'function') {
                        window.performConfigFill(configItems, filledInputs);
                    } else if (typeof performConfigFill === 'function') {
                        performConfigFill(configItems, filledInputs);
                    } else {
                        console.error('[AI生成配置] performConfigFill 函数未定义');
                        // 降级处理：直接填充
                        configItems.forEach(function(item) {
                            if (item.input) {
                                item.input.value = item.value;
                                item.input.dispatchEvent(new Event('change', { bubbles: true }));
                                item.input.dispatchEvent(new Event('input', { bubbles: true }));
                                item.input.classList.add('ai-filled-field');
                                item.input.style.borderColor = '#0d6efd';
                                item.input.style.borderWidth = '2px';
                                item.input.style.borderStyle = 'solid';
                            }
                        });
                        BackendToast.success('<?= __('已生成并填充') ?> ' + configItems.length + ' <?= __('个配置项') ?>');
                    }
                } else {
                    console.log('[AI生成配置] 用户取消');
                }
            });
        } else {
            BackendToast.warning('<?= __('共') ?> ' + allConfigItems.length + ' <?= __('个配置项生成，但未找到对应的输入框') ?>');
        }
    })
    .catch(error => {
        // 关闭等待中的“正在生成”弹窗
        // Toast 自动消失，无需手动关闭
        // 清除AI生成状态标志，允许关闭可视化配置
        window.isAiGenerating = false;
        
        // 恢复按钮状态
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        
        console.error('AI生成配置错误:', error);
        BackendToast.error('<?= __('生成请求失败，请稍后重试') ?>');
    });
}

</script>

<!-- 页面关系树复制功能 -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ==================== 点击 Handle 文本复制 ====================
    const clickableHandles = document.querySelectorAll('.clickable-handle');
    clickableHandles.forEach(function(element) {
        element.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const handle = this.getAttribute('data-handle');
            const pageName = this.getAttribute('data-page-name');
            const originalBg = this.style.backgroundColor;
            const originalText = this.textContent;
            
            // 添加 / 前缀
            const handleWithSlash = '/' + handle;
            
            copyToClipboard(handleWithSlash, null, null, null, 
                '<?= __("Handle 已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("Handle") ?>: ' + handleWithSlash);
            
            // 视觉反馈
            this.style.backgroundColor = '#d4edda';
            this.textContent = '✓ ' + handleWithSlash;
            setTimeout(() => {
                this.style.backgroundColor = originalBg;
                this.textContent = originalText;
            }, 1500);
        });
    });
    
    // ==================== 点击链接文本复制 ====================
    const clickableUrls = document.querySelectorAll('.clickable-url');
    clickableUrls.forEach(function(element) {
        element.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const url = this.getAttribute('data-url');
            const pageName = this.getAttribute('data-page-name');
            const originalColor = this.style.color;
            const originalText = this.textContent;
            
            copyToClipboard(url, null, null, null, 
                '<?= __("链接已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
            
            // 视觉反馈
            this.style.color = '#198754';
            this.style.fontWeight = 'bold';
            this.textContent = '✓ ' + originalText;
            setTimeout(() => {
                this.style.color = originalColor;
                this.style.fontWeight = '';
                this.textContent = originalText;
            }, 1500);
        });
    });
    
    // ==================== 复制 Handle 按钮功能 ====================
    const copyHandleButtons = document.querySelectorAll('.copy-handle-btn');
    copyHandleButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const handle = this.getAttribute('data-handle');
            const pageName = this.getAttribute('data-page-name');
            const originalHtml = this.innerHTML;
            const originalClass = this.className;
            
            // 添加 / 前缀
            const handleWithSlash = '/' + handle;
            
            copyToClipboard(handleWithSlash, this, originalHtml, originalClass, 
                '<?= __("Handle 已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("Handle") ?>: ' + handleWithSlash);
        });
    });
    
    // ==================== 复制链接按钮功能 ====================
    const copyUrlButtons = document.querySelectorAll('.copy-page-url-btn');
    copyUrlButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const url = this.getAttribute('data-url');
            const pageName = this.getAttribute('data-page-name');
            const originalHtml = this.innerHTML;
            const originalClass = this.className;
            
            copyToClipboard(url, this, originalHtml, originalClass, 
                '<?= __("链接已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
        });
    });
    
    // ==================== 复制到剪贴板的通用函数 ====================
    function copyToClipboard(text, button, originalHtml, originalClass, successTitle, successMessage) {
        // 使用现代 Clipboard API
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text)
                .then(() => {
                    showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage);
                })
                .catch(err => {
                    console.error('<?= __("复制失败") ?>:', err);
                    fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage);
                });
        } else {
            // 降级方案
            fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage);
        }
    }
    
    // ==================== 降级复制方法 ====================
    function fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        textArea.style.top = '-999999px';
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        
        try {
            const successful = document.execCommand('copy');
            if (successful) {
                showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage);
            } else {
                throw new Error('execCommand failed');
            }
        } catch (err) {
            console.error('<?= __("复制失败") ?>:', err);
            // 最后降级方案：提示用户手动复制
            prompt('<?= __("请手动复制以下内容") ?>:', text);
        } finally {
            document.body.removeChild(textArea);
        }
    }
    
    // ==================== 显示复制成功状态 ====================
    function showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage) {
        // Toast 通知
        showToast('success', successTitle, successMessage);
        
        // 如果是按钮，更新按钮状态
        if (button) {
            button.innerHTML = '<i class="mdi mdi-check"></i> <?= __("已复制") ?>';
            button.className = 'btn btn-sm btn-success copy-success-btn';
            
            // 2秒后恢复原状
            setTimeout(() => {
                button.innerHTML = originalHtml;
                button.className = originalClass;
            }, 2000);
        }
    }
    
    // ==================== 页面URL相关函数 ====================
    // 复制页面URL
    window.copyPageUrl = function(event) {
        const urlInput = document.getElementById('pageUrlDisplay');
        if (!urlInput) return;
        
        const url = urlInput.value;
        if (!url) return;
        
        // 获取按钮元素
        const button = event ? event.target.closest('button') : document.querySelector('button[onclick*="copyPageUrl"]');
        
        // 使用通用复制函数
        copyToClipboard(url, button, null, null, 
            '<?= __("地址已复制") ?>', 
            '<?= __("页面地址") ?>: ' + url);
    };
    
    // 打开页面URL
    window.openPageUrl = function() {
        const urlInput = document.getElementById('pageUrlDisplay');
        if (!urlInput || !urlInput.value) return;
        
        // 在新窗口打开
        window.open(urlInput.value, '_blank');
        console.log('🌐 打开页面:', urlInput.value);
    };
    
    // ==================== Toast 通知函数（已在全局定义） ====================
    // showToast 函数现在是全局函数，可以在任何地方调用
});

// ==================== AI生成内容功能（全局函数，可在onclick中调用） ====================
/**
 * 打开AI生成内容模态框
 */
window.openAiGenerateModal = function() {
    const modal = document.getElementById('aiGenerateModal');
    if (modal) {
        // 确保按钮状态已重置（如果之前有生成过程）
        const closeBtn = modal.querySelector('.btn-close');
        const cancelBtn = modal.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
        const submitBtn = document.getElementById('aiGenerateSubmitBtn');
        const spinner = document.getElementById('aiGenerateSpinner');
        
        if (closeBtn) {
            closeBtn.style.pointerEvents = '';
            closeBtn.style.opacity = '';
            closeBtn.removeAttribute('disabled');
            closeBtn.removeAttribute('aria-disabled');
        }
        if (cancelBtn) {
            cancelBtn.disabled = false;
            cancelBtn.style.opacity = '';
            cancelBtn.style.cursor = '';
            cancelBtn.removeAttribute('aria-disabled');
        }
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm d-none" id="aiGenerateSpinner" role="status"></span><i class="mdi mdi-robot"></i> <?= __('生成内容') ?>';
        }
        if (spinner) {
            spinner.classList.add('d-none');
        }
        
        const bootstrapModal = new bootstrap.Modal(modal);
        bootstrapModal.show();
        
        // 如果是编辑模式，自动生成描述
        <?php if ($isEdit && $page && $page->getId()): ?>
        const descriptionTextarea = document.getElementById('aiDescription');
        if (descriptionTextarea && !descriptionTextarea.value.trim()) {
            // 基于当前页面信息生成描述
            const pageTitle = document.getElementById('title')?.value || '';
            const metaTitle = document.getElementById('meta_title')?.value || '';
            const metaDescription = document.getElementById('meta_description')?.value || '';
            const pageContent = document.getElementById('custom_content')?.value || '';
            
            let autoDescription = '';
            if (pageTitle) {
                autoDescription += `页面标题：${pageTitle}\n`;
            }
            if (metaTitle) {
                autoDescription += `SEO标题：${metaTitle}\n`;
            }
            if (metaDescription) {
                autoDescription += `SEO描述：${metaDescription}\n`;
            }
            if (pageContent) {
                const contentText = pageContent.replace(/<[^>]*>/g, '').trim();
                if (contentText) {
                    const contentSummary = contentText.length > 200 ? contentText.substring(0, 200) + '...' : contentText;
                    autoDescription += `当前页面内容摘要：${contentSummary}\n`;
                }
            }
            
            if (autoDescription) {
                autoDescription += '\n请基于以上信息优化和完善页面内容。';
                descriptionTextarea.value = autoDescription;
            }
        }
        <?php endif; ?>
    }
};

/**
 * 生成页面内容
 */
window.generatePageContent = function() {
    const descriptionTextarea = document.getElementById('aiDescription');
    let description = descriptionTextarea?.value.trim() || '';
    
    // 如果是编辑模式且描述为空，自动从页面信息生成描述
    <?php if ($isEdit && $page && $page->getId()): ?>
    if (!description) {
        // 从表单字段获取当前页面信息
        const pageTitle = document.getElementById('title')?.value || '';
        const metaTitle = document.getElementById('meta_title')?.value || '';
        const metaDescription = document.getElementById('meta_description')?.value || '';
        const pageContent = document.getElementById('custom_content')?.value || '';
        
        // 构建自动描述
        let autoDescription = '';
        if (pageTitle) {
            autoDescription += `页面标题：${pageTitle}\n`;
        }
        if (metaTitle) {
            autoDescription += `SEO标题：${metaTitle}\n`;
        }
        if (metaDescription) {
            autoDescription += `SEO描述：${metaDescription}\n`;
        }
        if (pageContent) {
            const contentText = pageContent.replace(/<[^>]*>/g, '').trim();
            if (contentText) {
                const contentSummary = contentText.length > 200 ? contentText.substring(0, 200) + '...' : contentText;
                autoDescription += `当前页面内容摘要：${contentSummary}\n`;
            }
        }
        
        if (autoDescription) {
            autoDescription += '\n请基于以上信息优化和完善页面内容。';
            description = autoDescription;
            // 同时更新文本框显示
            if (descriptionTextarea) {
                descriptionTextarea.value = description;
            }
        }
    }
    
    if (!description) {
        BackendToast.warning('<?= __('请输入页面描述，或确保页面有标题、SEO信息或内容') ?>');
        return;
    }
    <?php else: ?>
    if (!description) {
        BackendToast.warning('<?= __('请输入页面描述') ?>');
        return;
    }
    <?php endif; ?>

    const submitBtn = document.getElementById('aiGenerateSubmitBtn');
    const spinner = document.getElementById('aiGenerateSpinner');
    if (!submitBtn) return;
    
    const originalHtml = submitBtn.innerHTML;

    // 获取模态框元素
    const modalElement = document.getElementById('aiGenerateModal');
    const modal = bootstrap.Modal.getInstance(modalElement);
    const closeBtn = modalElement?.querySelector('.btn-close');
    const cancelBtn = modalElement?.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
    
    // 标记正在生成中
    let isGenerating = true;
    
    // 禁用关闭操作：防止生成过程中关闭弹窗
    if (modal) {
        // 保存原始配置
        const originalBackdrop = modal._config.backdrop;
        const originalKeyboard = modal._config.keyboard;
        
        // 设置不允许关闭
        modal._config.backdrop = 'static';
        modal._config.keyboard = false;
        
        // 更新模态框元素的属性
        modalElement.setAttribute('data-bs-backdrop', 'static');
        modalElement.setAttribute('data-bs-keyboard', 'false');
        
        // 监听 hide 事件，在生成过程中阻止关闭
        const preventHideHandler = function(e) {
            if (isGenerating) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                return false;
            }
        };
        modalElement.addEventListener('hide.bs.modal', preventHideHandler, { capture: true });
        
        // 保存恢复函数到模态框实例
        modal._restoreClose = function() {
            isGenerating = false;
            modal._config.backdrop = originalBackdrop;
            modal._config.keyboard = originalKeyboard;
            modalElement.removeAttribute('data-bs-backdrop');
            modalElement.removeAttribute('data-bs-keyboard');
            modalElement.removeEventListener('hide.bs.modal', preventHideHandler, { capture: true });
        };
    }
    
    // 禁用关闭按钮和取消按钮
    if (closeBtn) {
        closeBtn.style.pointerEvents = 'none';
        closeBtn.style.opacity = '0.5';
        closeBtn.setAttribute('disabled', 'disabled');
        closeBtn.setAttribute('aria-disabled', 'true');
    }
    if (cancelBtn) {
        cancelBtn.disabled = true;
        cancelBtn.style.opacity = '0.5';
        cancelBtn.style.cursor = 'not-allowed';
        cancelBtn.setAttribute('aria-disabled', 'true');
    }

    // 显示加载状态
    submitBtn.disabled = true;
    if (spinner) spinner.classList.remove('d-none');
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> <?= __('生成中...') ?>';

    // 收集页面信息
    const pageType = document.getElementById('page_type')?.value || 'page';
    const title = document.getElementById('title')?.value || '';
    const metaTitle = document.getElementById('meta_title')?.value || '';
    const metaDescription = document.getElementById('meta_description')?.value || '';
    const metaKeywords = document.getElementById('meta_keywords')?.value || '';
    const handle = document.getElementById('handle')?.value || '';
    const styleCode = document.getElementById('style')?.value || '';
    const defaultLocale = document.getElementById('default_locale')?.value || '';

    // 准备请求数据
    const formData = new FormData();
    formData.append('description', description);
    formData.append('page_type', pageType);
    <?php if ($isEdit && $page && $page->getId()): ?>
    formData.append('page_id', <?= $page->getId() ?>);
    <?php endif; ?>
    if (title) formData.append('title', title);
    if (metaTitle) formData.append('meta_title', metaTitle);
    if (metaDescription) formData.append('meta_description', metaDescription);
    if (metaKeywords) formData.append('meta_keywords', metaKeywords);
    if (handle) formData.append('handle', handle);
    if (styleCode) formData.append('style_code', styleCode);
    if (defaultLocale) formData.append('default_locale', defaultLocale);

    var url = '<?= $this->getBackendUrl("*/backend/ai-generate/page-content") ?>';
    var opts = { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } };
    var req = window.Weline.Api.request(url, opts);
    req.then(function(res) {
        var data = (res && res.data) || res;
        // 恢复关闭功能
        const modalElement = document.getElementById('aiGenerateModal');
        const modal = bootstrap.Modal.getInstance(modalElement);
        const closeBtn = modalElement?.querySelector('.btn-close');
        const cancelBtn = modalElement?.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
        
        if (modal && modal._restoreClose) {
            modal._restoreClose();
        }
        
        if (closeBtn) {
            closeBtn.style.pointerEvents = '';
            closeBtn.style.opacity = '';
            closeBtn.removeAttribute('disabled');
            closeBtn.removeAttribute('aria-disabled');
        }
        if (cancelBtn) {
            cancelBtn.disabled = false;
            cancelBtn.style.opacity = '';
            cancelBtn.style.cursor = '';
            cancelBtn.removeAttribute('aria-disabled');
        }
        
        // 恢复按钮状态
        submitBtn.disabled = false;
        if (spinner) spinner.classList.add('d-none');
        submitBtn.innerHTML = originalHtml;

        if (data.success && data.data) {
            // 填充生成的内容，并添加 AI 填充标识
            if (data.data.title && document.getElementById('title')) {
                const titleInput = document.getElementById('title');
                titleInput.value = data.data.title;
                titleInput.classList.add('ai-filled');
            }
            if (data.data.meta_title && document.getElementById('meta_title')) {
                const metaTitleInput = document.getElementById('meta_title');
                metaTitleInput.value = data.data.meta_title;
                metaTitleInput.classList.add('ai-filled');
            }
            if (data.data.meta_description && document.getElementById('meta_description')) {
                const metaDescInput = document.getElementById('meta_description');
                metaDescInput.value = data.data.meta_description;
                metaDescInput.classList.add('ai-filled');
            }
            if (data.data.meta_keywords && document.getElementById('meta_keywords')) {
                const metaKeywordsInput = document.getElementById('meta_keywords');
                metaKeywordsInput.value = data.data.meta_keywords;
                metaKeywordsInput.classList.add('ai-filled');
            }
            if (data.data.content && document.getElementById('custom_content')) {
                const contentEditor = window.pageEditors && window.pageEditors['custom_content'];
                if (contentEditor) {
                    contentEditor.setData(data.data.content);
                    // 为 CKEditor 编辑器添加 AI 填充标识
                    // 方法1: 通过编辑器实例获取可编辑元素
                    setTimeout(() => {
                        try {
                            if (contentEditor.editing && contentEditor.editing.view) {
                                const domRoot = contentEditor.editing.view.domRoots.get(contentEditor.editing.view.document);
                                if (domRoot) {
                                    domRoot.classList.add('ai-filled');
                                }
                            }
                        } catch (e) {
                            console.log('CKEditor DOM root access failed:', e);
                        }
                        
                        // 方法2: 通过 DOM 查询找到编辑器容器
                        const customContentElement = document.getElementById('custom_content');
                        if (customContentElement) {
                            const editorContainer = customContentElement.closest('.ck-editor');
                            if (editorContainer) {
                                const editableElement = editorContainer.querySelector('.ck-editor__editable');
                                if (editableElement) {
                                    editableElement.classList.add('ai-filled');
                                }
                            }
                        }
                    }, 100);
                } else {
                    const contentInput = document.getElementById('custom_content');
                    contentInput.value = data.data.content;
                    contentInput.classList.add('ai-filled');
                }
            }

            // 关闭模态框
            if (modal) modal.hide();

            // 显示成功消息
            BackendToast.success('<?= __('AI已成功生成页面内容，请检查并调整') ?>');
        } else {
            // 清理错误消息中的HTML标签（双重保险）
            let errorMessage = data.message || '<?= __('生成失败') ?>';
            if (errorMessage) {
                // 创建临时div来去除HTML标签
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = errorMessage;
                errorMessage = tempDiv.textContent || tempDiv.innerText || errorMessage;
            }
            
            BackendToast.error(errorMessage);
        }
    })
    .catch(error => {
        // 恢复关闭功能
        const modalElement = document.getElementById('aiGenerateModal');
        const modal = bootstrap.Modal.getInstance(modalElement);
        const closeBtn = modalElement?.querySelector('.btn-close');
        const cancelBtn = modalElement?.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
        
        if (modal && modal._restoreClose) {
            modal._restoreClose();
        }
        
        if (closeBtn) {
            closeBtn.style.pointerEvents = '';
            closeBtn.style.opacity = '';
            closeBtn.removeAttribute('disabled');
            closeBtn.removeAttribute('aria-disabled');
        }
        if (cancelBtn) {
            cancelBtn.disabled = false;
            cancelBtn.style.opacity = '';
            cancelBtn.style.cursor = '';
            cancelBtn.removeAttribute('aria-disabled');
        }
        
        // 恢复按钮状态
        submitBtn.disabled = false;
        if (spinner) spinner.classList.add('d-none');
        submitBtn.innerHTML = originalHtml;

        console.error('AI生成错误:', error);
        BackendToast.error('<?= __('生成请求失败，请稍后重试') ?>');
    });
};

/**
 * ========================================
 * 打开前端在线预览（使用对应网站的链接）
 * ========================================
 */
window.openFrontendPreview = function() {
    const handleInput = document.getElementById('handle');
    const handle = handleInput ? handleInput.value.trim() : '';
    const typeInput = document.getElementById('type');
    const pageType = typeInput ? typeInput.value : '';
    const isHomePage = (pageType === '<?= \GuoLaiRen\PageBuilder\Model\Page::TYPE_HOME ?>');
    const styleSelect = document.getElementById('style');
    const selectedStyleCode = styleSelect ? styleSelect.value : '';
    const defaultLocaleInput = document.getElementById('default_locale');
    const selectedLocale = window.currentVisualLanguage || (defaultLocaleInput ? defaultLocaleInput.value : '') || '';
    const requestPageId = pageIdForm || (window.visualPageId || 0);
    
    // 首页类型且没有handle时，允许预览（直接使用网站地址）
    if (!handle && !isHomePage) {
        BackendToast.warning('<?= __('页面句柄不能为空，无法预览') ?>');
        return;
    }
    
    // 展示/预览用：站点库里的 URL；同 host 且当前请求带端口时由 getDisplayBaseUrlWithPort 注入端口
    <?php 
    $websites = $this->getData('websites') ?? [];
    $websiteUrls = [];
    foreach ($websites as $website) {
        $wid = (int)($website['website_id'] ?? 0);
        $wUrl = $website['url'] ?? '';
        if ($wid > 0 && $wUrl) {
            $websiteUrls[$wid] = rtrim($wUrl, '/');
        }
    }
    ?>
    const websiteUrlsPreview = <?= json_encode($websiteUrls) ?>;
    
    // 获取当前选中的网站ID
    const websiteSelect = document.getElementById('website_id');
    const websiteId = websiteSelect ? parseInt(websiteSelect.value, 10) || 0 : 0;
    
    // 预览打开用 base（站点 URL；同 host 时注入当前端口便于打开，跨 script 用 window）
    const baseUrl = typeof window.getDisplayBaseUrlWithPort === 'function' ? window.getDisplayBaseUrlWithPort(websiteId) : (websiteUrlsPreview[websiteId] || window.currentOriginForPort || '<?= htmlspecialchars(rtrim($this->request->getBaseHost(), '/'), ENT_QUOTES, 'UTF-8') ?>');
    
    // 构建预览URL：handle 放 query 并 encodeURIComponent，配合 website_id 解码
    let previewUrl = baseUrl;
    const queryParams = [];
    if (handle) {
        queryParams.push('handle=' + encodeURIComponent(handle));
    }
    queryParams.push('preview=1');
    if (websiteId > 0) {
        queryParams.push('website_id=' + String(websiteId));
    }
    if (requestPageId > 0) {
        queryParams.push('page_id=' + encodeURIComponent(String(requestPageId)));
    }
    if (selectedStyleCode) {
        queryParams.push('style_code=' + encodeURIComponent(selectedStyleCode));
    }
    if (selectedLocale) {
        queryParams.push('locale=' + encodeURIComponent(selectedLocale));
    }
    queryParams.push('t=' + Date.now());
    previewUrl += (baseUrl.indexOf('?') === -1 ? '?' : '&') + queryParams.join('&');
    
    // 在新窗口打开前端预览
    window.open(previewUrl, '_blank');
    
    console.log('🌐 打开前端预览:', previewUrl);
};
</script>