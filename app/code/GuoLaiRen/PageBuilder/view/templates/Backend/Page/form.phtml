// 页面ID（用于翻译功能）
const pageId = <?= ($isEdit && $page && $page->getId()) ? $page->getId() : 'null' ?>;

// 当前页面的样式设置（编辑时从后端传入）
const currentStyleSettings = <?= json_encode($this->getData('style_settings') ?? []) ?>;
console.log('📦 当前样式配置数据:', currentStyleSettings);

// 样式选择器
const styleSelect = document.getElementById('style');
const styleDescContainer = document.getElementById('style-description-container');
const styleDescText = document.getElementById('style-description-text');
const styleConfigContainer = document.getElementById('style-config-container');
const styleConfigFields = document.getElementById('style-config-fields');

/**
 * 加载样式配置
 */
function loadStyleConfig(styleCode) {
    console.log('🔧 loadStyleConfig 被调用, styleCode:', styleCode);
    
    if (!styleCode) {
        console.log('⚠️ styleCode 为空，隐藏配置区域');
        if (styleConfigContainer) {
            styleConfigContainer.style.display = 'none';
        }
        if (styleDescContainer) {
            styleDescContainer.style.display = 'none';
        }
        return;
    }
    
    // 显示样式描述
    const selectedOption = styleSelect ? styleSelect.options[styleSelect.selectedIndex] : null;
    const description = selectedOption ? selectedOption.getAttribute('data-description') : null;
    if (description && styleDescText && styleDescContainer) {
        styleDescText.textContent = description;
        styleDescContainer.style.display = 'block';
    } else if (styleDescContainer) {
        styleDescContainer.style.display = 'none';
    }
    
    // 显示加载中
    if (styleConfigFields) {
        styleConfigFields.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> <?= __('加载配置中...') ?></div>';
    }
    if (styleConfigContainer) {
        styleConfigContainer.style.display = 'block';
    }
    
    // 构建请求 URL，包含 page_id 和 locale 参数
    let configUrl = '<?= $this->getBackendUrl('pagebuilder/backend/page/getStyleConfig') ?>?style_code=' + encodeURIComponent(styleCode);
    
    <?php if ($isEdit && $page && $page->getId()): ?>
    // 如果是编辑页面，添加 page_id 参数
    configUrl += '&page_id=<?= $page->getId() ?>';
    
    // 添加默认语言参数
    <?php if ($pageDefaultLocale): ?>
    configUrl += '&locale=<?= $pageDefaultLocale ?>';
    <?php endif; ?>
    <?php endif; ?>
    
    console.log('📡 配置请求 URL:', configUrl);
    
    // 通过AJAX获取样式配置
    fetch(configUrl, {
        method: 'GET',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        credentials: 'same-origin'
    })
        .then(response => {
            console.log('📥 配置响应状态:', response.status, response.statusText);
            return response.json();
        })
        .then(data => {
            console.log('📦 配置响应数据:', data);
            if (data.success && data.data) {
                renderStyleConfig(data.data);
            } else {
                console.warn('⚠️ 该样式没有可配置项');
                if (styleConfigFields) {
                    styleConfigFields.innerHTML = '<div class="alert alert-warning"><?= __('该样式没有可配置项') ?></div>';
                }
            }
        })
        .catch(error => {
            console.error('❌ 加载配置失败:', error);
            if (styleConfigFields) {
                styleConfigFields.innerHTML = '<div class="alert alert-danger"><?= __('加载配置失败：') ?>' + error.message + '</div>';
            }
        });
}

/**
 * 渲染样式配置表单（支持两级分组：文件 -> 分组）
 */
function renderStyleConfig(configGroups) {
    console.log('🔨 开始渲染样式配置表单');
    console.log('📋 配置组:', configGroups);
    console.log('💾 当前保存的配置值:', currentStyleSettings);
    
    if (!styleConfigFields) {
        console.error('❌ styleConfigFields 元素不存在');
        return;
    }
    
    if (!configGroups || Object.keys(configGroups).length === 0) {
        styleConfigFields.innerHTML = '<div class="alert alert-info"><?= __('该样式没有可配置项') ?></div>';
        return;
    }
    
    let html = '';
    
    // 遍历文件级别（header, content, footer）
    for (const fileKey in configGroups) {
        const fileGroup = configGroups[fileKey];
        
        // 跳过没有分组的文件
        if (!fileGroup.groups || Object.keys(fileGroup.groups).length === 0) {
            continue;
        }
        
        // 文件级别的大卡片（可折叠）
        const fileIcon = fileGroup.icon || 'mdi-file';
        html += `
            <div class="config-file-group mb-4" data-file="${fileKey}">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white" style="cursor: pointer;" onclick="toggleFileGroup('${fileKey}')">
                        <h5 class="mb-0">
                            <i class="mdi ${fileIcon}"></i> ${fileGroup.label || fileKey}
                            <i class="mdi mdi-chevron-down float-end" id="icon_${fileKey}"></i>
                        </h5>
                    </div>
                    <div class="card-body" id="body_${fileKey}">
        `;
        
        // 遍历该文件下的分组（layout, style, size等）
        for (const groupKey in fileGroup.groups) {
            const group = fileGroup.groups[groupKey];
            
            // 跳过没有配置项的分组
            if (!group.configs || Object.keys(group.configs).length === 0) {
                continue;
            }
            
            // 调试：输出分组信息
            console.log(`📁 分组 ${fileKey}.${groupKey}:`, {
                label: group.label,
                tag: group.tag,
                help_title: group.help_title,
                help_content: group.help_content
            });
            
            // 使用服务器返回的图标，如果没有则使用默认图标
            const icon = group.icon || 'mdi-cog';
            
            // 使用 fileKey + groupKey 确保ID唯一性，分组默认收起
            html += `
                <div class="config-group config-section collapsed mb-3" data-group="${groupKey}" id="visual_${fileKey}_${groupKey}_group">
                    <div class="card">
                        <div class="card-header bg-light" style="cursor: pointer;" onclick="toggleFormSection('visual_${fileKey}_${groupKey}_group')">
                            <h6 class="mb-0">
                                <i class="mdi ${icon}"></i> ${group.label || groupKey}`;
            
            // 如果分组有标记（如 MD, MTD），显示响应式徽章
            if (group.tag) {
                let tagIcons = '';
                if (group.tag.includes('M')) tagIcons += '<i class="mdi mdi-cellphone" style="font-size: 0.85rem;"></i> ';
                if (group.tag.includes('T')) tagIcons += '<i class="mdi mdi-tablet" style="font-size: 0.85rem;"></i> ';
                if (group.tag.includes('D')) tagIcons += '<i class="mdi mdi-monitor" style="font-size: 0.85rem;"></i> ';
                
                html += ` <span class="badge bg-info ms-2" style="font-size: 0.65rem; vertical-align: middle;">
                            ${tagIcons}
                         </span>`;
            }
            
            html += `
                                <i class="mdi mdi-chevron-down float-end"></i>
                            </h6>
                        </div>
                        <div class="card-body config-section-body">`;
            
            // 如果有说明信息，直接显示（不折叠）
            if (group.help_title || group.help_content) {
                const escapedContent = escapeHtml(group.help_content || '');
                
                html += `
                    <div class="alert alert-info mb-3" role="alert">
                        <h6 class="alert-heading mb-2">
                            <i class="mdi mdi-information-outline"></i> ${escapeHtml(group.help_title || '说明')}
                        </h6>
                        <div class="help-content-static">
                            ${escapedContent}
                        </div>
                    </div>`;
            }
            
            html += `
                            <div class="row">
            `;
            
            // 渲染每个配置项
            for (const configKey in group.configs) {
                const config = group.configs[configKey];
            const rawValue = currentStyleSettings[configKey] || config.default || '';
            const currentValue = escapeHtml(rawValue); // 转义 HTML 特殊字符
            
            // 调试信息：显示配置项和当前值
            if (currentStyleSettings[configKey]) {
                console.log(`  - ${config.label} (${configKey}): "${rawValue}"`);
            }
            
            html += `<div class="col-md-6 mb-3">`;
            html += `<label for="style_config_${configKey.replace(/\./g, '_')}" class="form-label">${escapeHtml(config.label || '')}`;
            
            // 添加响应式标记图标（使用 Material Design Icons）
            if (config.responsive) {
                // 解析描述信息，提取支持的设备类型
                let devices = '';
                let icons = '';
                
                // 根据描述信息判断支持的设备
                if (config.description) {
                    const desc = config.description;
                    if (desc.includes('移动端')) {
                        icons += '<i class="mdi mdi-cellphone" style="font-size: 0.85rem;"></i> ';
                    }
                    if (desc.includes('平板')) {
                        icons += '<i class="mdi mdi-tablet" style="font-size: 0.85rem;"></i> ';
                    }
                    if (desc.includes('PC端')) {
                        icons += '<i class="mdi mdi-monitor" style="font-size: 0.85rem;"></i> ';
                    }
                }
                
                // 如果没有解析到设备类型，默认显示移动端和PC端
                if (!icons) {
                    icons = '<i class="mdi mdi-cellphone" style="font-size: 0.85rem;"></i> <i class="mdi mdi-monitor" style="font-size: 0.85rem;"></i>';
                }
                
                html += ` <span class="badge bg-info ms-1" title="${escapeHtml(config.description || '支持响应式配置')}" style="font-size: 0.75rem; vertical-align: middle;">
                            ${icons}
                         </span>`;
            }
            
            // 添加翻译按钮（仅在编辑模式下）
            if (pageId && pageId !== 'null') {
                const escapedValue = String(rawValue || '').replace(/'/g, "\\'").replace(/"/g, "&quot;");
                const escapedLabel = String(config.label || '').replace(/'/g, "\\'").replace(/"/g, "&quot;");
                html += ` <a href="javascript:void(0)" 
                             class="link-info ms-1 style-config-translate-btn" 
                             data-config-key="${configKey}"
                             data-config-label="${escapedLabel}"
                             data-config-value="${escapedValue}"
                             title="<?= __('翻译此配置项') ?>">
                            <i class="mdi mdi-translate"></i>
                         </a>`;
            }
            
            html += `</label>`;
            
            // 添加描述信息
            if (config.description) {
                html += `<div class="form-text text-muted mb-2" style="margin-top: -8px; font-size: 0.85rem;">
                            <i class="mdi mdi-information-outline"></i> ${escapeHtml(config.description)}
                         </div>`;
            }
            
            // 根据类型渲染不同的输入控件
            const fieldId = `style_config_${configKey.replace(/\./g, '_')}`;
            
            switch (config.type) {
                case 'responsive':
                    // 响应式配置：支持 60/80 或 60/70/80 格式，使用 text 输入框
                    html += `
                        <div class="input-group">
                            <input type="text" 
                                   class="form-control" 
                                   id="${fieldId}" 
                                   name="style_settings[${configKey}]" 
                                   value="${currentValue}"
                                   placeholder="${escapeHtml(config.default || '')}"
                                   title="<?= __('支持单一值(如: 80)或多端值(如: 60/80 或 60/70/80)') ?>">
                            ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit || '')}</span>` : ''}
                        </div>
                    `;
                    break;
                    
                case 'text':
                case 'number':
                    html += `
                        <div class="input-group">
                            <input type="${config.type}" 
                                   class="form-control" 
                                   id="${fieldId}" 
                                   name="style_settings[${configKey}]" 
                                   value="${currentValue}"
                                   placeholder="${escapeHtml(config.default || '')}">
                            ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit || '')}</span>` : ''}
                        </div>
                    `;
                    break;
                    
                case 'select':
                    html += `<select class="form-select" id="${fieldId}" name="style_settings[${configKey}]">`;
                    if (config.options && config.options.length > 0) {
                        config.options.forEach(option => {
                            const optValue = String(option || '');
                            const selected = rawValue == optValue ? 'selected' : '';
                            html += `<option value="${escapeHtml(optValue)}" ${selected}>${escapeHtml(optValue)}</option>`;
                        });
                    }
                    html += `</select>`;
                    break;
                    
                case 'color':
                    html += `
                        <div class="input-group">
                            <input type="color" 
                                   class="form-control form-control-color" 
                                   id="${fieldId}" 
                                   name="style_settings[${configKey}]" 
                                   value="${escapeHtml(currentValue || config.default || '#ffffff')}" 
                                   title="<?= __('选择颜色') ?>">
                            <input type="text" 
                                   class="form-control" 
                                   value="${escapeHtml(currentValue || config.default || '#ffffff')}" 
                                   readonly>
                        </div>
                    `;
                    break;
                    
                case 'textarea':
                    html += `
                        <textarea class="form-control" 
                                  id="${fieldId}" 
                                  name="style_settings[${configKey}]" 
                                  rows="3"
                                  placeholder="${escapeHtml(config.default || '')}">${currentValue}</textarea>
                    `;
                    break;
                    
                case 'image':
                    html += `
                        <input type="text" 
                               class="form-control" 
                               id="${fieldId}" 
                               name="style_settings[${configKey}]" 
                               value="${currentValue}"
                               placeholder="${escapeHtml(config.default || '')}">
                        <div class="form-text"><?= __('输入图片URL') ?></div>
                    `;
                    break;
            }
            
            html += `</div>`;
            }
            
            // 关闭分组卡片
            html += `
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }
        
        // 关闭文件分组卡片
        html += `
                    </div>
                </div>
            </div>
        `;
    }
    
    styleConfigFields.innerHTML = html;
    
    // 为颜色选择器添加事件监听
    styleConfigFields.querySelectorAll('input[type="color"]').forEach(colorInput => {
        const textInput = colorInput.parentElement.querySelector('input[type="text"]');
        colorInput.addEventListener('change', function() {
            textInput.value = this.value;
        });
    });
}

/**
 * 切换文件分组的折叠状态
 */
function toggleFileGroup(fileKey) {
    const body = document.getElementById('body_' + fileKey);
    const icon = document.getElementById('icon_' + fileKey);
    
    if (body && icon) {
        if (body.style.display === 'none') {
            body.style.display = 'block';
            icon.classList.remove('mdi-chevron-right');
            icon.classList.add('mdi-chevron-down');
        } else {
            body.style.display = 'none';
            icon.classList.remove('mdi-chevron-down');
            icon.classList.add('mdi-chevron-right');
        }
    }
}

/**
 * 切换主表单分组的折叠状态
 */
function toggleFormSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (section) {
        section.classList.toggle('collapsed');
    }
}

/**
 * 通过AJAX加载样式列表
 * 实时扫描样式目录并渲染为卡片
 */
let allStyles = []; // 存储所有样式数据用于搜索

async function loadStyleList() {
    console.log('🚀 开始加载样式列表...');
    
    const styleSelect = document.getElementById('style');
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsLoading = document.getElementById('styleCardsLoading');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    if (!styleSelect || !styleCardsContainer) {
        console.error('❌ 未找到必要的DOM元素');
        return;
    }
    
    const currentStyle = '<?= $page ? htmlspecialchars($page->getData('style')) : '' ?>';
    const currentPageId = '<?= $page ? $page->getId() : '' ?>';
    console.log('🎯 当前选择的样式:', currentStyle || '(无)');
    console.log('📄 当前页面ID:', currentPageId || '(新建)');
    
    try {
        // 显示加载状态
        styleCardsLoading.style.display = 'block';
        styleCardsEmpty.style.display = 'none';
        styleCardsContainer.innerHTML = '';
        
        // 构建请求 URL
        const apiUrl = '<?= $this->getBackendUrl('pagebuilder/backend/page/getStyles') ?>';
        console.log('📡 请求 URL:', apiUrl);
        
        // 发送AJAX请求
        const response = await fetch(apiUrl, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        console.log('📥 收到响应:', response.status, response.statusText);
        
        // 检查响应状态
        if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ HTTP错误响应:', response.status, errorText);
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        // 解析JSON
        const result = await response.json();
        console.log('📦 解析响应数据:', result);
        
        if (result.success && result.data) {
            allStyles = result.data; // 保存到全局变量
            
            // 更新隐藏的select（用于表单提交）
            styleSelect.innerHTML = '<option value=""><?= __('请选择样式') ?></option>';
            result.data.forEach(style => {
                const option = document.createElement('option');
                option.value = style.code;
                option.textContent = style.name;
                if (currentStyle && style.code === currentStyle) {
                    option.selected = true;
                }
                styleSelect.appendChild(option);
            });
            
            // 渲染样式卡片
            renderStyleCards(result.data, currentStyle, currentPageId);
            
            // 启用可视化配置按钮
            const visualBtn = document.getElementById('openVisualConfigBtn');
            if (visualBtn && currentStyle) {
                visualBtn.disabled = false;
                console.log('✅ 可视化配置按钮已启用');
            }
            
            // 加载样式配置（如果有选中的样式）
            if (currentStyle) {
                console.log(`🔧 开始加载样式配置: ${currentStyle}`);
                loadStyleConfig(currentStyle);
            }
            
            console.log(`✅ 样式列表加载成功，共 ${result.count} 个样式`);
        } else {
            console.error('❌ 加载样式列表失败:', result);
            styleCardsEmpty.innerHTML = '<i class="mdi mdi-alert"></i> ' + (result.message || '加载失败，请刷新重试');
            styleCardsEmpty.style.display = 'block';
        }
    } catch (error) {
        console.error('❌ 加载样式列表异常:', error);
        console.error('错误堆栈:', error.stack);
        
        // 显示详细的错误信息
        const errorMessage = error.message || '未知错误';
        styleCardsEmpty.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle"></i>
                <strong>加载失败</strong><br>
                <small>${errorMessage}</small><br>
                <button class="btn btn-sm btn-outline-danger mt-2" onclick="loadStyleList()">
                    <i class="mdi mdi-refresh"></i> 重试
                </button>
            </div>
        `;
        styleCardsEmpty.style.display = 'block';
    } finally {
        styleCardsLoading.style.display = 'none';
    }
}

/**
 * 渲染样式卡片
 */
function renderStyleCards(styles, currentStyle, currentPageId) {
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    styleCardsContainer.innerHTML = '';
    
    if (!styles || styles.length === 0) {
        styleCardsEmpty.style.display = 'block';
        return;
    }
    
    styleCardsEmpty.style.display = 'none';
    
    const previewImageUrl = '<?= $this->getBackendUrl('pagebuilder/backend/page/stylePreviewImage') ?>';
    const previewFullUrl = '<?= $this->getBackendUrl('pagebuilder/backend/preview/full') ?>';
    
    styles.forEach(style => {
        const col = document.createElement('div');
        col.className = 'col';
        
        const isSelected = currentStyle && style.code === currentStyle;
        const hasPreviewImage = style.preview_image && style.preview_image.trim() !== '';
        
        const card = document.createElement('div');
        card.className = 'card style-card' + (isSelected ? ' selected' : '');
        card.dataset.styleCode = style.code;
        card.dataset.styleName = style.name;
        card.dataset.styleDescription = style.description || '';
        
        // 预览区域
        let previewHtml = '';
        let previewActionsHtml = '';
        
        if (hasPreviewImage) {
            // 有预览图，通过控制器获取图片
            const imageUrl = `${previewImageUrl}?code=${encodeURIComponent(style.code)}`;
            
            // 预览操作按钮：放大预览 + 真实预览
            previewActionsHtml = currentPageId ? `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                </div>
            ` : `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview">
                    ${previewActionsHtml}
                    <img src="${imageUrl}" 
                         alt="${style.name}" 
                         onerror="this.parentElement.innerHTML='<div class=\\'style-card-preview-placeholder\\'><i class=\\'mdi mdi-image-broken\\'></i><div>图片加载失败</div></div>'">
                </div>
            `;
        } else if (currentPageId) {
            // 没有预览图但有页面ID，使用iframe实时预览并转换为canvas
            const iframeUrl = `${previewFullUrl}?page_id=${currentPageId}&style_code=${encodeURIComponent(style.code)}`;
            const canvasId = `style-preview-canvas-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            const iframeId = `style-preview-iframe-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            
            // 预览操作按钮：真实预览
            previewActionsHtml = `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview" id="preview-${style.code}">
                    ${previewActionsHtml}
                    <div class="style-card-preview-loading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <div style="margin-top: 10px; font-size: 12px;">正在生成预览...</div>
                    </div>
                    <canvas id="${canvasId}" style="display: none; width: 100%; height: 100%;"></canvas>
                    <iframe id="${iframeId}" 
                            src="${iframeUrl}" 
                            style="position: absolute; left: -9999px; width: 1200px; height: 800px; border: none;"
                            onload="captureIframePreview('${iframeId}', '${canvasId}', 'preview-${style.code}')">
                    </iframe>
                </div>
            `;
        } else {
            // 没有预览图也没有页面ID，显示占位符
            previewHtml = `
                <div class="style-card-preview">
                    <div class="style-card-preview-placeholder">
                        <i class="mdi mdi-palette"></i>
                        <div>无预览</div>
                    </div>
                </div>
            `;
        }
        
        // 卡片内容
        card.innerHTML = `
            ${previewHtml}
            <div class="style-card-body">
                <div class="style-card-title">
                    <span>${style.name}</span>
                    <span class="style-card-selected-badge">
                        <i class="mdi mdi-check"></i> 已选择
                    </span>
                </div>
                ${style.description ? `<div class="style-card-description">${style.description}</div>` : ''}
                <div class="style-card-meta">
                    <span class="style-card-code">${style.code}</span>
                    ${hasPreviewImage ? '<i class="mdi mdi-image text-success" title="有预览图"></i>' : '<i class="mdi mdi-monitor text-muted" title="实时预览"></i>'}
                </div>
            </div>
        `;
        
        // 点击卡片选择样式
        card.addEventListener('click', () => selectStyle(style.code));
        
        col.appendChild(card);
        styleCardsContainer.appendChild(col);
    });
}

/**
 * 选择样式
 */
async function selectStyle(styleCode) {
    console.log('🎯 选择样式:', styleCode);
    
    const styleSelect = document.getElementById('style');
    const oldStyle = styleSelect.value;
    
    // 更新隐藏的select
    styleSelect.value = styleCode;
    
    // 更新卡片选中状态
    document.querySelectorAll('.style-card').forEach(card => {
        if (card.dataset.styleCode === styleCode) {
            card.classList.add('selected');
        } else {
            card.classList.remove('selected');
        }
    });
    
    // 启用可视化配置按钮
    const visualBtn = document.getElementById('openVisualConfigBtn');
    if (visualBtn) {
        visualBtn.disabled = false;
    }
    
    // 加载样式配置
    loadStyleConfig(styleCode);
    
    // 如果是编辑模式，自动保存样式切换
    const pageId = '<?= $isEdit && $page ? $page->getId() : '' ?>';
    if (pageId && styleCode !== oldStyle) {
        await autoSaveStyleChange(styleCode);
    }
}

/**
 * 打开图片放大预览
 * @param {string} imageUrl - 图片URL
 * @param {string} styleName - 样式名称
 */
function openImagePreview(imageUrl, styleName) {
    console.log('🖼️ 打开图片预览:', styleName);
    
    const modal = document.getElementById('stylePreviewModal');
    const modalTitle = document.getElementById('previewModalTitle');
    const modalIcon = document.getElementById('previewModalIcon');
    const modalBody = document.getElementById('previewModalBody');
    
    // 设置标题和图标
    modalTitle.textContent = `${styleName} - 预览图`;
    modalIcon.className = 'mdi mdi-magnify-plus';
    
    // 显示图片
    modalBody.innerHTML = `<img src="${imageUrl}" alt="${styleName}">`;
    
    // 显示模态框
    modal.classList.add('active');
    
    // 禁止body滚动
    document.body.style.overflow = 'hidden';
}

/**
 * 打开真实页面预览
 * @param {string} styleCode - 样式代码
 * @param {string} styleName - 样式名称
 * @param {number} pageId - 页面ID
 */
function openRealPreview(styleCode, styleName, pageId) {
    console.log('🖥️ 打开真实预览:', styleName, styleCode);
    
    const modal = document.getElementById('stylePreviewModal');
    const modalTitle = document.getElementById('previewModalTitle');
    const modalIcon = document.getElementById('previewModalIcon');
    const modalBody = document.getElementById('previewModalBody');
    
    // 设置标题和图标
    modalTitle.textContent = `${styleName} - 真实预览`;
    modalIcon.className = 'mdi mdi-monitor';
    
    // 构建iframe URL
    const previewUrl = '<?= $this->getBackendUrl('pagebuilder/backend/preview/full') ?>?page_id=' + pageId + '&style_code=' + encodeURIComponent(styleCode);
    
    // 显示加载状态和iframe
    modalBody.innerHTML = `
        <div class="style-preview-loading">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2">正在加载预览...</div>
        </div>
        <iframe src="${previewUrl}" onload="this.previousElementSibling.style.display='none'"></iframe>
    `;
    
    // 显示模态框
    modal.classList.add('active');
    
    // 禁止body滚动
    document.body.style.overflow = 'hidden';
}

/**
 * 关闭样式预览模态框
 */
function closeStylePreviewModal() {
    const modal = document.getElementById('stylePreviewModal');
    modal.classList.remove('active');
    
    // 恢复body滚动
    document.body.style.overflow = '';
    
    // 清空内容（移除iframe）
    setTimeout(() => {
        const modalBody = document.getElementById('previewModalBody');
        modalBody.innerHTML = '';
    }, 300);
}

// 点击模态框背景关闭
document.addEventListener('click', function(e) {
    const modal = document.getElementById('stylePreviewModal');
    if (e.target === modal) {
        closeStylePreviewModal();
    }
});

// ESC键关闭模态框
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('stylePreviewModal');
        if (modal && modal.classList.contains('active')) {
            closeStylePreviewModal();
        }
    }
});

/**
 * 截取iframe内容并转换为canvas预览
 * 
 * @param {string} iframeId - iframe元素ID
 * @param {string} canvasId - canvas元素ID
 * @param {string} previewId - 预览容器ID
 */
async function captureIframePreview(iframeId, canvasId, previewId) {
    console.log('🎬 开始截取预览:', iframeId);
    
    const iframe = document.getElementById(iframeId);
    const canvas = document.getElementById(canvasId);
    const previewContainer = document.getElementById(previewId);
    const loadingEl = previewContainer ? previewContainer.querySelector('.style-card-preview-loading') : null;
    
    if (!iframe || !canvas || !previewContainer) {
        console.error('❌ 截图失败：找不到必要的DOM元素');
        if (loadingEl) {
            loadingEl.innerHTML = '<div class="text-danger small">预览生成失败</div>';
        }
        return;
    }
    
    try {
        // 等待iframe完全加载
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问iframe内容');
        }
        
        console.log('📸 开始使用html2canvas截图...');
        
        // 使用html2canvas截取iframe内容
        const screenshotCanvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.25, // 降低分辨率以提高性能
            width: 1200,
            height: 800,
            logging: false,
            removeContainer: false
        });
        
        // 将截图绘制到目标canvas（调整尺寸以适应卡片）
        const ctx = canvas.getContext('2d');
        canvas.width = 400; // 卡片宽度
        canvas.height = 200; // 卡片高度
        
        // 计算缩放比例（保持宽高比）
        const scale = Math.min(canvas.width / screenshotCanvas.width, canvas.height / screenshotCanvas.height);
        const x = (canvas.width / 2) - (screenshotCanvas.width / 2) * scale;
        const y = (canvas.height / 2) - (screenshotCanvas.height / 2) * scale;
        
        ctx.drawImage(screenshotCanvas, x, y, screenshotCanvas.width * scale, screenshotCanvas.height * scale);
        
        // 显示canvas，隐藏加载状态
        canvas.style.display = 'block';
        if (loadingEl) {
            loadingEl.style.display = 'none';
        }
        
        // 移除iframe（已经不需要了）
        setTimeout(() => {
            if (iframe.parentElement) {
                iframe.remove();
            }
        }, 100);
        
        console.log('✅ 预览截图成功');
        
    } catch (error) {
        console.error('❌ 截图失败:', error);
        
        // 显示错误提示
        if (loadingEl) {
            loadingEl.innerHTML = `
                <div class="style-card-preview-placeholder">
                    <i class="mdi mdi-alert-circle"></i>
                    <div style="font-size: 12px; margin-top: 5px;">预览生成失败</div>
                    <div style="font-size: 11px; color: #999; margin-top: 3px;">点击卡片可选择此样式</div>
                </div>
            `;
        }
        
        // 移除iframe
        if (iframe.parentElement) {
            iframe.remove();
        }
    }
}

/**
 * 搜索过滤样式
 */
function filterStyles(searchTerm) {
    const term = searchTerm.toLowerCase().trim();
    
    if (!term) {
        // 如果搜索框为空，显示所有样式
        renderStyleCards(allStyles, document.getElementById('style').value, '<?= $page ? $page->getId() : '' ?>');
        return;
    }
    
    // 过滤样式：匹配名称、描述或代码
    const filtered = allStyles.filter(style => {
        const name = (style.name || '').toLowerCase();
        const description = (style.description || '').toLowerCase();
        const code = (style.code || '').toLowerCase();
        return name.includes(term) || description.includes(term) || code.includes(term);
    });
    
    // 渲染过滤后的结果
    renderStyleCards(filtered, document.getElementById('style').value, '<?= $page ? $page->getId() : '' ?>');
}

