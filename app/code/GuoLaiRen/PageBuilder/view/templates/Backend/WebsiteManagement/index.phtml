<script>
// 切换使用指南
function toggleUsageGuide() {
    const body = document.getElementById('usage-guide-body');
    const icon = document.getElementById('usage-guide-icon');
    body.classList.toggle('show');
    icon.style.transform = body.classList.contains('show') ? 'rotate(180deg)' : 'rotate(0deg)';
}

// 异步搜索功能
(function() {
    let searchTimeout = null;
    const searchForm = document.getElementById('search-form');
    const searchInput = document.getElementById('search-input');
    const tableContainer = document.getElementById('website-table-container');
    const clearSearchBtn = document.getElementById('clear-search');
    const searchUrl = '<?= $this->getBackendUrl('*/backend/websiteManagement') ?>';
    
    // 执行异步搜索
    function performSearch() {
        if (!searchForm || !tableContainer) return;
        
        const searchValue = searchInput ? searchInput.value.trim() : '';
        
        // 显示加载状态
        tableContainer.innerHTML = '<div class="text-center p-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __("加载中...") ?></span></div><p class="mt-3"><?= __("正在搜索...") ?></p></div>';
        
        // 构建 AJAX URL
        const params = new URLSearchParams();
        if (searchValue) {
            params.append('search', searchValue);
        }
        const ajaxUrl = searchUrl + (params.toString() ? '?' + params.toString() : '');
        
        // 发送 AJAX 请求
        fetch(ajaxUrl, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) {
            if (!response.ok) {
                throw new Error('HTTP error! status: ' + response.status);
            }
            return response.text();
        })
        .then(function(text) {
            try {
                return JSON.parse(text);
            } catch (e) {
                console.error('JSON parse error:', e, text);
                throw new Error('<?= __("服务器返回的不是有效的JSON数据") ?>');
            }
        })
        .then(function(data) {
            if (data.success) {
                // 更新表格内容
                tableContainer.innerHTML = data.html;
                
                // 执行新插入的 script 标签
                const scripts = tableContainer.querySelectorAll('script');
                scripts.forEach(function(oldScript) {
                    const newScript = document.createElement('script');
                    Array.from(oldScript.attributes).forEach(function(attr) {
                        newScript.setAttribute(attr.name, attr.value);
                    });
                    newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                    oldScript.parentNode.replaceChild(newScript, oldScript);
                });
                
                // 更新清除按钮显示状态
                const currentClearBtn = document.getElementById('clear-search');
                if (searchValue) {
                    if (!currentClearBtn) {
                        const btn = document.createElement('a');
                        btn.href = searchUrl;
                        btn.className = 'btn btn-outline-secondary';
                        btn.id = 'clear-search';
                        btn.innerHTML = '<i class="mdi mdi-close"></i> <?= __("清除") ?>';
                        searchForm.appendChild(btn);
                        btn.addEventListener('click', function(e) {
                            e.preventDefault();
                            searchInput.value = '';
                            performSearch();
                        });
                    }
                } else {
                    if (currentClearBtn && currentClearBtn.parentNode) {
                        currentClearBtn.parentNode.removeChild(currentClearBtn);
                    }
                }
                
                // 重新初始化 w-delete 功能
                if (typeof window.initWDelete === 'function') {
                    window.initWDelete();
                }
            } else {
                tableContainer.innerHTML = '<div class="alert alert-danger"><?= __("搜索失败") ?>: ' + (data.message || '<?= __("未知错误") ?>') + '</div>';
            }
        })
        .catch(function(error) {
            console.error('Search error:', error);
            tableContainer.innerHTML = '<div class="alert alert-danger"><?= __("搜索出错，请刷新页面重试") ?></div>';
        });
    }
    
    // 初始化
    document.addEventListener('DOMContentLoaded', function() {
        if (!searchForm || !searchInput) return;
        
        // 阻止表单默认提交
        searchForm.addEventListener('submit', function(e) {
            e.preventDefault();
            clearTimeout(searchTimeout);
            performSearch();
        });
        
        // 输入框输入时自动搜索（防抖）
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                performSearch();
            }, 500);
        });
        
        // 回车键立即搜索
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                clearTimeout(searchTimeout);
                performSearch();
            }
        });
        
        // 清除按钮点击事件
        if (clearSearchBtn) {
            clearSearchBtn.addEventListener('click', function(e) {
                e.preventDefault();
                searchInput.value = '';
                performSearch();
            });
        }
    });
})();
</script>
</body>
</html>
