<script>
(function() {
    'use strict';
    
    // 切换使用指南
    var usageGuideToggle = document.getElementById('pagebuilder-website-usage-guide-toggle');
    if (usageGuideToggle) {
        usageGuideToggle.addEventListener('click', function() {
            var body = document.getElementById('pagebuilder-website-usage-guide-body');
            var icon = document.getElementById('pagebuilder-website-usage-guide-icon');
            if (body && icon) {
                body.classList.toggle('show');
                icon.style.transform = body.classList.contains('show') ? 'rotate(180deg)' : 'rotate(0deg)';
            }
        });
    }

    var searchForm = document.getElementById('pagebuilder-website-search-form');
    var searchInput = document.getElementById('pagebuilder-website-search-input');
    var searchUrl = <?= json_encode($listUrl, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;

    function submitWebsiteSearch() {
        var searchValue = searchInput ? searchInput.value.trim() : '';
        var params = new URLSearchParams();
        if (searchValue) {
            params.set('search', searchValue);
        }

        window.location.href = searchUrl + (params.toString() ? '?' + params.toString() : '');
    }

    if (searchForm) {
        searchForm.addEventListener('submit', function(e) {
            e.preventDefault();
            submitWebsiteSearch();
        });
    }

    if (searchInput) {
        searchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                submitWebsiteSearch();
            }
        });
    }
})();
</script>
