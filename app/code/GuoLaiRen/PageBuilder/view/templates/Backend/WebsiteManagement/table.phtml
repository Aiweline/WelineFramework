<?php
/**
 * PageBuilder 网站管理 - 紧凑表格模板
 *
 * @var \Weline\Framework\View\Template $this
 */
$websites = $this->getData('websites') ?: [];
$pagination = $this->getData('pagination') ?: '';
?>
<div class="table-responsive">
    <table class="table table-hover align-middle pagebuilder-website-compact-table">
        <thead>
        <tr>
            <th><lang>站点</lang></th>
            <th><lang>访问入口</lang></th>
            <th><lang>语言 / 货币</lang></th>
            <th class="text-end"><lang>操作</lang></th>
        </tr>
        </thead>
        <tbody>
        <?php if (empty($websites)): ?>
            <tr>
                <td colspan="4" class="text-center py-5">
                    <i class="mdi mdi-web-off d-block" style="font-size: 3rem; color: var(--backend-color-text-tertiary, #adb5bd);"></i>
                    <p class="mt-3 mb-1" style="color: var(--backend-color-text-secondary, #6c757d);"><lang>暂无网站</lang></p>
                    <p class="small mb-0" style="color: var(--backend-color-text-tertiary, #adb5bd);"><lang>点击上方“新建站点”添加第一个网站</lang></p>
                </td>
            </tr>
        <?php else: ?>
            <?php foreach ($websites as $website): ?>
                <?php
                $websiteId = (int)($website['website_id'] ?? 0);
                $name = (string)($website['name'] ?? '');
                $code = (string)($website['code'] ?? '');
                $timezone = (string)($website['default_timezone'] ?? '');
                $domainList = $website['domain_list'] ?? [];
                if (!is_array($domainList)) {
                    $domainList = [];
                }
                $siteUrl = (string)($website['url'] ?? '');
                if ($siteUrl === '' && $domainList !== []) {
                    $firstDomain = $domainList[0] ?? [];
                    $firstHost = (string)($firstDomain['domain'] ?? '');
                    if ($firstHost !== '') {
                        $siteUrl = (!empty($firstDomain['https_enabled']) ? 'https://' : 'http://') . $firstHost;
                    }
                }
                $defaultCurrency = (string)($website['default_currency'] ?? '');
                $currencyCodes = $website['currency_codes'] ?? [];
                if (!is_array($currencyCodes)) {
                    $currencyCodes = [];
                }
                $languageCodes = $website['language_codes'] ?? [];
                if (!is_array($languageCodes)) {
                    $languageCodes = [];
                }
                ?>
                <tr>
                    <td>
                        <div class="pagebuilder-website-site-cell">
                            <div class="pagebuilder-website-site-name"><?= htmlspecialchars($name) ?></div>
                            <div class="pagebuilder-website-site-meta">
                                <span class="pagebuilder-website-inline-code"><?= htmlspecialchars($code) ?></span>
                                <span class="pagebuilder-website-meta-chip">#<?= $websiteId ?></span>
                                <?php if ($timezone !== ''): ?>
                                    <span class="pagebuilder-website-meta-chip"><?= htmlspecialchars($timezone) ?></span>
                                <?php endif; ?>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="pagebuilder-website-access-cell">
                            <?php if ($siteUrl !== ''): ?>
                                <a href="<?= htmlspecialchars($siteUrl) ?>" target="_blank" rel="noopener" class="pagebuilder-website-url-link pagebuilder-website-url-row">
                                    <span><?= htmlspecialchars($siteUrl) ?></span>
                                    <i class="mdi mdi-open-in-new"></i>
                                </a>
                            <?php else: ?>
                                <span class="text-muted small"><lang>未生成访问地址</lang></span>
                            <?php endif; ?>

                            <div class="pagebuilder-website-domain-list">
                                <?php if ($domainList !== []): ?>
                                    <?php foreach ($domainList as $domainRow): ?>
                                        <?php
                                        $domain = (string)($domainRow['domain'] ?? '');
                                        if ($domain === '') {
                                            continue;
                                        }
                                        $isPrimary = !empty($domainRow['is_primary']);
                                        $protocol = !empty($domainRow['https_enabled']) ? 'https' : 'http';
                                        $domainUrl = $protocol . '://' . $domain;
                                        ?>
                                        <span class="pagebuilder-website-domain-badge">
                                            <a href="<?= htmlspecialchars($domainUrl) ?>" target="_blank" rel="noopener" class="pagebuilder-website-domain-link" title="<?= htmlspecialchars($domain) ?>">
                                                <?= htmlspecialchars($domain) ?>
                                                <i class="mdi mdi-open-in-new ms-1 small"></i>
                                            </a>
                                            <?php if ($isPrimary): ?>
                                                <span class="badge bg-primary-subtle text-primary ms-1"><lang>主</lang></span>
                                            <?php endif; ?>
                                        </span>
                                    <?php endforeach; ?>
                                <?php else: ?>
                                    <span class="text-muted small">-</span>
                                <?php endif; ?>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="pagebuilder-website-market-cell">
                            <div class="pagebuilder-website-market-row">
                                <span class="pagebuilder-website-market-label"><lang>货币</lang></span>
                                <div class="pagebuilder-website-chip-group">
                                    <?php if ($defaultCurrency !== ''): ?>
                                        <span class="badge bg-primary-subtle text-primary"><?= __('默认') ?> <?= htmlspecialchars($defaultCurrency) ?></span>
                                    <?php endif; ?>
                                    <?php if ($currencyCodes !== []): ?>
                                        <?php foreach ($currencyCodes as $currencyCode): ?>
                                            <span class="badge bg-info-subtle text-info"><?= htmlspecialchars((string)$currencyCode) ?></span>
                                        <?php endforeach; ?>
                                    <?php elseif ($defaultCurrency === ''): ?>
                                        <span class="text-muted small"><lang>全部</lang></span>
                                    <?php endif; ?>
                                </div>
                            </div>
                            <div class="pagebuilder-website-market-row">
                                <span class="pagebuilder-website-market-label"><lang>语言</lang></span>
                                <div class="pagebuilder-website-chip-group">
                                    <?php if ($languageCodes !== []): ?>
                                        <?php foreach ($languageCodes as $languageCode): ?>
                                            <span class="badge bg-success-subtle text-success"><?= htmlspecialchars((string)$languageCode) ?></span>
                                        <?php endforeach; ?>
                                    <?php else: ?>
                                        <span class="text-muted small"><lang>全部</lang></span>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="text-end pagebuilder-website-op-cell">
                        <div class="d-flex gap-2 flex-wrap align-items-center justify-content-end">
                            <?php if ($siteUrl !== ''): ?>
                                <a href="<?= htmlspecialchars($siteUrl) ?>" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary" title="<?= __('在新标签页打开网站') ?>">
                                    <i class="mdi mdi-open-in-new"></i> <lang>访问</lang>
                                </a>
                            <?php endif; ?>
                            <block class='Weline\Component\Block\OffCanvas'
                                   cache='0'
                                   id='edit_website_{{website.website_id}}'
                                   action='*/backend/websiteManagement/edit'
                                   vars='website'
                                   action-params='{id:website.website_id}'
                                   title='编辑网站'
                                   close-button-show='1'
                                   close-button-text='关闭'
                                   direction='right'
                                   class-names='w-75 h-100'
                                   off-canvas-body-style=''
                                   target-button-text='编辑'
                                   icon='mdi mdi-pencil'
                                   target-button-class='btn btn-sm btn-outline-info'
                                   target-tag='a'
                                   save='1'
                            />
                            <a href="<?= $this->getBackendUrl('*/backend/websiteManagement/delete') ?>?id=<?= $websiteId ?>"
                               w-delete="true"
                               w-msg="<?= __('您确定要删除此网站吗？删除后不可恢复。') ?>"
                               class="btn btn-sm btn-outline-danger"
                               title="<?= __('删除网站') ?>">
                                <i class="mdi mdi-delete-outline"></i> <lang>删除</lang>
                            </a>
                        </div>
                    </td>
                </tr>
            <?php endforeach; ?>
        <?php endif; ?>
        </tbody>
    </table>

    <?= $pagination ?>
</div>
