<script>
(function() {
    'use strict';
    
    // 时区搜索功能 - 原生实现
    var timezoneSearch = document.getElementById('timezone-search');
    var timezoneSelect = document.getElementById('default_timezone');
    
    if (!timezoneSearch || !timezoneSelect) return;
    
    // 存储所有选项的原始数据
    var allOptions = [];
    for (var i = 1; i < timezoneSelect.options.length; i++) {
        var option = timezoneSelect.options[i];
        allOptions.push({
            value: option.value,
            text: option.textContent,
            selected: option.selected
        });
    }
    
    // 搜索过滤函数
    function filterTimezones(searchTerm) {
        var term = searchTerm.toLowerCase().trim();
        
        // 清空当前选项（保留第一个空选项）
        timezoneSelect.innerHTML = '<option value="">-- <?= __("请选择") ?> --</option>';
        
        if (!term) {
            // 如果没有搜索词，显示所有选项
            allOptions.forEach(function(opt) {
                var option = document.createElement('option');
                option.value = opt.value;
                option.textContent = opt.text;
                if (opt.selected) {
                    option.selected = true;
                    timezoneSearch.value = opt.text;
                }
                timezoneSelect.appendChild(option);
            });
        } else {
            // 过滤匹配的选项
            var matched = allOptions.filter(function(opt) {
                return opt.text.toLowerCase().includes(term);
            });
            
            matched.forEach(function(opt) {
                var option = document.createElement('option');
                option.value = opt.value;
                option.textContent = opt.text;
                if (opt.selected) {
                    option.selected = true;
                    timezoneSearch.value = opt.text;
                }
                timezoneSelect.appendChild(option);
            });
            
            // 如果只有一个匹配项，自动选中
            if (matched.length === 1) {
                timezoneSelect.selectedIndex = 1;
                timezoneSearch.value = matched[0].text;
            }
        }
    }
    
    // 输入搜索（防抖）
    var searchTimeout;
    timezoneSearch.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() {
            filterTimezones(timezoneSearch.value);
        }, 200);
    });
    
    // 选择时区后，更新搜索框显示
    timezoneSelect.addEventListener('change', function() {
        if (timezoneSelect.value) {
            timezoneSearch.value = timezoneSelect.options[timezoneSelect.selectedIndex].textContent;
        } else {
            timezoneSearch.value = '';
        }
    });
    
    // 初始化：如果有选中的值，显示在搜索框
    if (timezoneSelect.value) {
        timezoneSearch.value = timezoneSelect.options[timezoneSelect.selectedIndex].textContent;
    }
})();
</script>
