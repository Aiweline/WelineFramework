<script>
// 可视化构建器 JavaScript
const VB = {
    pageId: <?= $pageId ?>,
    styleCode: '<?= htmlspecialchars($styleCode) ?>',
    layoutConfig: <?= json_encode($layoutConfig, JSON_UNESCAPED_UNICODE) ?>,
    // API端点 - 按职责分离
    api: {
        layout: '<?= $this->getBackendUrl('*/backend/visual/api/layout') ?>',
        component: '<?= $this->getBackendUrl('*/backend/visual/api/component') ?>'
    },
    
    // 当前选中的目标（用于智能筛选）
    selectedTarget: null,
    
    // 初始化
    init() {
        this.initSortable();
        this.initViewportButtons();
        this.initRegionSelection();
        this.renderPreview();
    },
    
    // 初始化区域选择（用于智能筛选）
    initRegionSelection() {
        // 选中区域时筛选组件库
        document.querySelectorAll('[data-section]').forEach(section => {
            section.addEventListener('click', (e) => {
                if (e.target.closest('.vb-component')) return; // 忽略组件点击
                const region = section.dataset.section;
                this.selectTarget({ type: 'region', region: region });
            });
        });
        
        // 选中 slot 时筛选组件库
        document.querySelectorAll('[data-slot]').forEach(slot => {
            slot.addEventListener('click', (e) => {
                e.stopPropagation();
                const slotName = slot.dataset.slot;
                const parentEl = slot.closest('[data-component]');
                const parentCode = parentEl ? parentEl.dataset.component : null;
                const parentInstanceId = parentEl ? parentEl.dataset.instanceId : null;
                this.selectTarget({ 
                    type: 'slot', 
                    parentComponentCode: parentCode,
                    parentInstanceId: parentInstanceId,
                    slot: slotName 
                });
            });
        });
        
        // 点击空白区域清除筛选
        document.addEventListener('click', (e) => {
            if (!e.target.closest('[data-section]') && 
                !e.target.closest('[data-slot]') && 
                !e.target.closest('.component-library')) {
                this.clearComponentFilter();
            }
        });
    },
    
    // 选中目标（区域或 slot）
    async selectTarget(target) {
        this.selectedTarget = target;
        
        // 高亮选中的区域/slot
        document.querySelectorAll('.vb-section-selected').forEach(el => {
            el.classList.remove('vb-section-selected');
        });
        
        if (target.type === 'region') {
            const section = document.querySelector(`[data-section="${target.region}"]`);
            if (section) section.classList.add('vb-section-selected');
        }
        
        // 筛选组件库
        await this.filterComponentLibrary(target);
    },
    
    // 筛选组件库
    async filterComponentLibrary(target) {
        try {
            const params = new URLSearchParams({
                style_code: this.styleCode,
            });
            
            if (target.type === 'region') {
                params.append('region', target.region);
            } else if (target.type === 'slot') {
                params.append('parent_component_code', target.parentComponentCode);
                params.append('slot', target.slot);
            }
            
            const response = await fetch(this.api.component + '/compatible?' + params);
            const data = await response.json();
            
            if (data.success) {
                this.highlightCompatibleComponents(data.components);
                this.scrollComponentLibraryToCategory(target.type === 'region' ? target.region : data.accepts?.[0]);
                this.showFilterHint(target, data.components.length);
            }
        } catch (error) {
            console.error('筛选组件库失败:', error);
        }
    },
    
    // 高亮兼容的组件
    highlightCompatibleComponents(componentCodes) {
        document.querySelectorAll('.component-card').forEach(card => {
            const code = card.dataset.componentCode;
            if (componentCodes.includes(code)) {
                card.classList.remove('filtered-out');
                card.classList.add('compatible');
            } else {
                card.classList.add('filtered-out');
                card.classList.remove('compatible');
            }
        });
    },
    
    // 滚动组件库到指定分类
    scrollComponentLibraryToCategory(category) {
        const categoryHeader = document.querySelector(`.component-category[data-category="${category}"]`);
        if (categoryHeader) {
            categoryHeader.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    },
    
    // 显示筛选提示
    showFilterHint(target, count) {
        const hintContainer = document.querySelector('.component-filter-hint');
        if (!hintContainer) return;
        
        let hintText = '';
        if (target.type === 'region') {
            hintText = `已筛选 ${target.region} 区域兼容组件`;
        } else {
            hintText = `已筛选 slot "${target.slot}" 兼容组件`;
        }
        
        hintContainer.innerHTML = `
            <span>${hintText} (${count} 个)</span>
            <button class="btn btn-sm btn-link clear-filter-btn" onclick="VB.clearComponentFilter()">
                <i class="mdi mdi-close"></i> 清除筛选
            </button>
        `;
        hintContainer.style.display = 'block';
    },
    
    // 清除组件筛选
    clearComponentFilter() {
        this.selectedTarget = null;
        
        document.querySelectorAll('.vb-section-selected').forEach(el => {
            el.classList.remove('vb-section-selected');
        });
        
        document.querySelectorAll('.component-card').forEach(card => {
            card.classList.remove('filtered-out', 'compatible');
        });
        
        const hintContainer = document.querySelector('.component-filter-hint');
        if (hintContainer) {
            hintContainer.style.display = 'none';
        }
    },
    
    // 初始化拖拽排序
    initSortable() {
        const container = document.getElementById('preview-content');
        if (typeof Sortable !== 'undefined' && container) {
            // 销毁现有的 Sortable 实例
            if (this._sortableInstance) {
                this._sortableInstance.destroy();
            }
            
            this._sortableInstance = new Sortable(container, {
                animation: 150,
                handle: '.component-drag-handle, .mdi-drag',
                draggable: '.vb-component',
                ghostClass: 'vb-component-dragging',
                chosenClass: 'vb-component-chosen',
                dragClass: 'vb-component-drag',
                // 嵌套组件跟随移动：整个组件（包含子组件）作为一个整体拖拽
                // Sortable.js 默认会拖拽整个元素及其子元素
                onStart: (evt) => {
                    // 标记正在拖拽
                    document.body.classList.add('vb-dragging');
                    
                    // 高亮可放置区域
                    this.highlightDropTargets(evt.item.dataset.component);
                },
                onEnd: (evt) => {
                    // 移除拖拽标记
                    document.body.classList.remove('vb-dragging');
                    this.clearDropTargetHighlights();
                    
                    // 保存新顺序（嵌套组件会随父组件一起移动）
                    this.reorderComponents();
                }
            });
        }
        
        // 初始化嵌套 slot 容器的拖拽
        this.initNestedSortable();
    },
    
    // 初始化嵌套 slot 的拖拽
    initNestedSortable() {
        document.querySelectorAll('.vb-slot-container').forEach(slotContainer => {
            if (slotContainer._sortable) {
                slotContainer._sortable.destroy();
            }
            
            if (typeof Sortable !== 'undefined') {
                slotContainer._sortable = new Sortable(slotContainer, {
                    animation: 150,
                    handle: '.component-drag-handle, .mdi-drag',
                    draggable: '.vb-component',
                    group: 'nested',
                    ghostClass: 'vb-component-dragging',
                    onEnd: (evt) => {
                        // 更新嵌套组件顺序
                        const parentInstanceId = evt.to.closest('[data-instance-id]')?.dataset.instanceId;
                        const slotName = evt.to.dataset.slot;
                        if (parentInstanceId && slotName) {
                            this.reorderNestedComponents(parentInstanceId, slotName);
                        }
                    }
                });
            }
        });
    },
    
    // 高亮可放置的目标区域
    highlightDropTargets(componentCode) {
        // TODO: 根据组件的 placeable_in 高亮可放置区域
    },
    
    // 清除放置目标高亮
    clearDropTargetHighlights() {
        document.querySelectorAll('.vb-drop-target').forEach(el => {
            el.classList.remove('vb-drop-target');
        });
    },
    
    // 重新排序嵌套组件
    async reorderNestedComponents(parentInstanceId, slotName) {
        const slotContainer = document.querySelector(`[data-instance-id="${parentInstanceId}"] [data-slot="${slotName}"]`);
        if (!slotContainer) return;
        
        const order = [];
        slotContainer.querySelectorAll('.vb-component').forEach(el => {
            order.push(el.dataset.instanceId);
        });
        
        try {
            const response = await fetch(this.api.component + '/reorderNested', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    page_id: this.pageId,
                    parent_instance_id: parentInstanceId,
                    slot: slotName,
                    order: order
                })
            });
            
            const result = await response.json();
            if (result.success) {
                this.layoutConfig = result.layout_config;
            }
        } catch (error) {
            console.error('排序嵌套组件失败:', error);
        }
    },
    
    // 视口切换
    initViewportButtons() {
        document.querySelectorAll('[data-viewport]').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('[data-viewport]').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                // TODO: 实现视口预览切换
            });
        });
    },
    
    // 渲染预览
    renderPreview() {
        // TODO: 实现实时预览渲染
    },
    
    // 验证组件放置
    async validateComponentPlacement(componentCode, region, parentComponentCode = null, slot = null) {
        try {
            const response = await fetch(this.api.component + '/validate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    component_code: componentCode,
                    region: region,
                    style_code: this.styleCode,
                    parent_component_code: parentComponentCode,
                    slot: slot
                })
            });
            
            const result = await response.json();
            return result;
        } catch (error) {
            console.error('验证失败:', error);
            return { success: false, valid: false, message: '验证请求失败' };
        }
    },
    
    // 添加组件（支持局部刷新）
    async addComponent(componentCode, fromTemplate, options = {}) {
        const region = options.region || this.selectedTarget?.region || 'content';
        const position = options.position ?? null;
        const parentComponentId = options.parentInstanceId || this.selectedTarget?.parentInstanceId || null;
        const targetSlot = options.slot || this.selectedTarget?.slot || null;
        
        try {
            // 先验证是否可以放置
            const validation = await this.validateComponentPlacement(
                componentCode, 
                region, 
                parentComponentId ? this.getComponentCodeByInstanceId(parentComponentId) : null,
                targetSlot
            );
            
            if (!validation.valid) {
                showToast('error', validation.message || '不能放置到此位置');
                return;
            }
            
            // 显示加载占位符（局部刷新优化）
            const placeholderId = 'placeholder-' + Date.now();
            this.insertPlaceholder(placeholderId, region, position);
            
            const response = await fetch(this.api.component + '/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    page_id: this.pageId,
                    component_code: componentCode,
                    region: region,
                    template_code: fromTemplate,
                    position: position,
                    parent_component_id: parentComponentId,
                    slot: targetSlot,
                    return_html: true  // 请求返回渲染的 HTML
                })
            });
            
            const result = await response.json();
            
            // 移除占位符
            this.removePlaceholder(placeholderId);
            
            if (result.success) {
                this.layoutConfig = result.layout_config;
                
                // 如果返回了组件 HTML，使用局部刷新
                if (result.partial && result.component_html) {
                    this.insertComponentDOM(result, region, position);
                    showToast('success', '组件添加成功');
                } else {
                    // 回退到全量刷新
                    this.refreshContentArea();
                    showToast('success', result.message || '组件添加成功');
                }
            } else {
                if (result.validation_failed) {
                    showToast('error', result.message || '验证失败：不能放置到此位置');
                } else {
                    showToast('error', result.message || '添加失败');
                }
            }
        } catch (error) {
            console.error(error);
            showToast('error', '网络错误');
        }
    },
    
    // 插入组件 DOM（局部刷新）
    insertComponentDOM(result, region, position) {
        const { instance_id, component_html } = result;
        
        // 创建临时容器解析 HTML
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = component_html.trim();
        const componentElement = tempDiv.firstElementChild;
        
        // 找到目标容器
        const container = document.getElementById(`preview-${region}`);
        if (!container) {
            console.warn('目标容器不存在:', region);
            this.refreshContentArea();
            return;
        }
        
        const children = container.querySelectorAll('.vb-component');
        
        // 插入到指定位置
        if (position !== null && position < children.length) {
            container.insertBefore(componentElement, children[position]);
        } else {
            // 插入到添加区域之前
            const addZone = container.querySelector('.vb-add-zone');
            if (addZone) {
                container.insertBefore(componentElement, addZone);
            } else {
                container.appendChild(componentElement);
            }
        }
        
        // 重新初始化拖拽
        this.initSortable();
    },
    
    // 插入加载占位符
    insertPlaceholder(placeholderId, region, position) {
        const container = document.getElementById(`preview-${region}`);
        if (!container) return;
        
        const placeholder = document.createElement('div');
        placeholder.className = 'vb-component vb-component-loading';
        placeholder.id = placeholderId;
        placeholder.innerHTML = `
            <div class="vb-component-loading-spinner">
                <i class="mdi mdi-loading mdi-spin"></i>
                <span>加载中...</span>
            </div>
        `;
        
        const children = container.querySelectorAll('.vb-component:not(.vb-component-loading)');
        if (position !== null && position < children.length) {
            container.insertBefore(placeholder, children[position]);
        } else {
            const addZone = container.querySelector('.vb-add-zone');
            if (addZone) {
                container.insertBefore(placeholder, addZone);
            } else {
                container.appendChild(placeholder);
            }
        }
    },
    
    // 移除占位符
    removePlaceholder(placeholderId) {
        const placeholder = document.getElementById(placeholderId);
        if (placeholder) {
            placeholder.remove();
        }
    },
    
    // 根据实例ID获取组件代码
    getComponentCodeByInstanceId(instanceId) {
        const component = document.querySelector(`[data-instance-id="${instanceId}"]`);
        return component ? component.dataset.component : null;
    },
    
    // 移除组件
    async removeComponent(instanceId) {
        if (!confirm('确定要移除此组件吗？')) return;
        
        try {
            const response = await fetch(this.api.layout + '/removeComponent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    page_id: this.pageId,
                    instance_id: instanceId
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                this.layoutConfig = result.layout_config;
                this.refreshContentArea();
                showToast('success', '组件已移除');
            } else {
                showToast('error', result.message || '移除失败');
            }
        } catch (error) {
            console.error(error);
            showToast('error', '网络错误');
        }
    },
    
    // 重新排序
    async reorderComponents() {
        const container = document.getElementById('preview-content');
        const order = [];
        
        container.querySelectorAll('.vb-component').forEach(el => {
            order.push(el.dataset.instanceId);
        });
        
        try {
            const response = await fetch(this.api.layout + '/reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    page_id: this.pageId,
                    order: JSON.stringify(order)
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                this.layoutConfig = result.layout_config;
            }
        } catch (error) {
            console.error(error);
        }
    },
    
    // 刷新内容区域
    refreshContentArea() {
        const container = document.getElementById('preview-content');
        const addZone = container.querySelector('.vb-add-zone');
        
        // 移除现有组件
        container.querySelectorAll('.vb-component').forEach(el => el.remove());
        
        // 渲染新组件
        const components = this.layoutConfig.content || [];
        components.forEach(comp => {
            const html = this.renderComponentCard(comp);
            addZone.insertAdjacentHTML('beforebegin', html);
        });
        
        // 重新初始化排序
        this.initSortable();
    },
    
    // 渲染组件卡片
    renderComponentCard(comp) {
        const isExternal = comp.from_template !== this.styleCode;
        const badge = isExternal ? `<span class="badge bg-warning text-dark">${comp.from_template}</span>` : '';
        
        const displayName = comp.name || comp.component;

        return `
            <div class="vb-component" data-instance-id="${comp.id}" data-component="${comp.component}">
                <div class="vb-component-header">
                    <span class="vb-component-name">
                        <i class="mdi mdi-drag"></i>
                        ${displayName}
                    </span>
                    ${badge}
                    <div class="vb-component-actions">
                        <button class="btn btn-sm btn-link" onclick="VB.editComponent('${comp.id}')">
                            <i class="mdi mdi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-link text-danger" onclick="VB.removeComponent('${comp.id}')">
                            <i class="mdi mdi-delete"></i>
                        </button>
                    </div>
                </div>
                <div class="vb-component-preview">
                    <div class="vb-component-thumbnail">
                        <i class="mdi mdi-view-module"></i>
                    </div>
                </div>
            </div>
        `;
    },
    
    // 编辑组件
    editComponent(instanceId) {
        // TODO: 打开组件配置面板
        const panel = document.getElementById('config-panel');
        panel.style.display = 'block';
        
        // 加载组件配置表单
        const content = document.getElementById('config-panel-content');
        content.innerHTML = '<p class="text-center py-4">加载配置中...</p>';
    },
    
    // 切换原始模板模式
    async toggleOriginalTemplate() {
        const currentMode = this.layoutConfig.use_original_template;
        const newMode = !currentMode;
        
        try {
            const response = await fetch(this.api.layout + '/toggleOriginal', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    page_id: this.pageId,
                    use_original: newMode ? '1' : '0'
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                this.layoutConfig = result.layout_config;
                document.getElementById('template-mode-text').textContent = newMode ? '自定义布局' : '恢复原始';
                showToast('success', result.message);
            } else {
                showToast('error', result.message || '切换失败');
            }
        } catch (error) {
            console.error(error);
            showToast('error', '网络错误');
        }
    },
    
    // 保存布局
    async saveLayout() {
        try {
            const response = await fetch(this.api.layout + '/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    page_id: this.pageId,
                    layout_config: JSON.stringify(this.layoutConfig)
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('success', '布局保存成功');
            } else {
                showToast('error', result.message || '保存失败');
            }
        } catch (error) {
            console.error(error);
            showToast('error', '网络错误');
        }
    },
    
    // 获取组件信息
    async getComponentInfo(componentCode) {
        try {
            const response = await fetch(this.api.component + '/info?' + new URLSearchParams({
                component_code: componentCode
            }));
            
            const result = await response.json();
            return result.success ? result.component : null;
        } catch (error) {
            console.error(error);
            return null;
        }
    },
    
    // 预览组件
    async previewComponent(componentCode, config = {}) {
        try {
            const response = await fetch(this.api.component + '/preview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    component_code: componentCode,
                    config: JSON.stringify(config)
                })
            });
            
            const result = await response.json();
            return result.success ? result.html : null;
        } catch (error) {
            console.error(error);
            return null;
        }
    }
};

// 全局函数
function addComponent(componentCode, fromTemplate) {
    VB.addComponent(componentCode, fromTemplate);
}

function removeComponent(instanceId) {
    VB.removeComponent(instanceId);
}

function editComponent(instanceId) {
    VB.editComponent(instanceId);
}

function editSection(section) {
    // TODO: 编辑 header/footer 区域
}

function toggleOriginalTemplate() {
    VB.toggleOriginalTemplate();
}

function saveLayout() {
    VB.saveLayout();
}

function closeConfigPanel() {
    document.getElementById('config-panel').style.display = 'none';
}

// 拖拽处理
function dragComponent(event) {
    event.dataTransfer.setData('component', event.target.dataset.component);
    event.dataTransfer.setData('fromTemplate', event.target.dataset.fromTemplate);
}

function allowDrop(event) {
    event.preventDefault();
    event.currentTarget.classList.add('drag-over');
}

function dropComponent(event) {
    event.preventDefault();
    event.currentTarget.classList.remove('drag-over');
    
    const componentCode = event.dataTransfer.getData('component');
    const fromTemplate = event.dataTransfer.getData('fromTemplate');
    
    if (componentCode) {
        VB.addComponent(componentCode, fromTemplate);
    }
}

// Toast 提示
function showToast(type, message) {
    // 使用框架的消息提示或简单的 alert
    if (typeof toastr !== 'undefined') {
        toastr[type](message);
    } else {
        alert(message);
    }
}

// 初始化
document.addEventListener('DOMContentLoaded', function() {
    VB.init();
});
</script>
