// 渲染站点列表
function renderAccountWebsiteList(websites) {
    const container = document.getElementById('accountWebsiteBindingContainer');
    
    if (!websites || websites.length === 0) {
        container.innerHTML = '<div class="text-center py-5 text-muted">' +
            '<i class="mdi mdi-web-off" style="font-size: 48px;"></i>' +
            '<p class="mt-3">' + i18n.noWebsites + '</p>' +
            '</div>';
        return;
    }
    
    // 使用纯JavaScript构建列表，避免PHP混合
    let html = '<div class="p-3 border-bottom bg-white sticky-top" style="z-index: 10;">' +
        '<div class="input-group">' +
        '<span class="input-group-text"><i class="mdi mdi-magnify"></i></span>' +
        '<input type="text" class="form-control" id="accountWebsiteSearchInput" ' +
        'placeholder="' + i18n.searchPlaceholder + '" onkeyup="searchAccountWebsites(this.value)">' +
        '</div>' +
        '<div class="mt-2">' +
        '<small class="text-muted">' +
        '<i class="mdi mdi-check-circle text-success me-1"></i>' +
        i18n.selected + ': <strong id="accountSelectedCount">' + selectedWebsiteIdsForAccount.length + '</strong> ' + i18n.websites +
        '</small>';
    
    if (selectedWebsiteIdsForAccount.length > 0) {
        html += '<button type="button" class="btn btn-sm btn-link text-danger float-end" onclick="clearAccountWebsiteSelections()">' +
            '<i class="mdi mdi-close-circle me-1"></i>' + i18n.clearSelection +
            '</button>';
    }
    
    html += '</div></div><div id="accountWebsiteListContainer" class="p-3">';
    
    websites.forEach(website => {
        const isSelected = selectedWebsiteIdsForAccount.includes(website.website_id);
        html += '<div class="account-website-item card mb-2' + (isSelected ? ' border-success' : '') + '" ' +
            'data-website-id="' + website.website_id + '" ' +
            'data-website-name="' + website.name.toLowerCase() + '" ' +
            'data-website-domain="' + website.domain.toLowerCase() + '">' +
            '<div class="card-body p-3"><div class="form-check">' +
            '<input class="form-check-input" type="checkbox" ' +
            'id="account_website_' + website.website_id + '" ' +
            'value="' + website.website_id + '"' +
            (isSelected ? ' checked' : '') +
            ' onchange="toggleAccountWebsiteSelection(' + website.website_id + ', this.checked)">' +
            '<label class="form-check-label d-flex justify-content-between align-items-start w-100" for="account_website_' + website.website_id + '">' +
            '<div class="flex-grow-1">' +
            '<div class="fw-bold">' + website.name + '</div>' +
            '<div class="text-muted small"><i class="mdi mdi-web me-1"></i>' + website.domain + '</div>';
        
        if (website.is_default) {
            html += '<span class="badge bg-info mt-1">' + i18n.defaultWebsite + '</span>';
        }
        
        html += '</div></label></div></div></div>';
    });
    
    html += '</div>';
    container.innerHTML = html;
}

// 搜索站点
function searchAccountWebsites(keyword) {
    keyword = keyword.toLowerCase().trim();
    const items = document.querySelectorAll('.account-website-item');
    let visibleCount = 0;
    
    items.forEach(item => {
        const name = item.dataset.websiteName || '';
        const domain = item.dataset.websiteDomain || '';
        
        if (name.includes(keyword) || domain.includes(keyword)) {
            item.style.display = '';
            visibleCount++;
        } else {
            item.style.display = 'none';
        }
    });
    
    // 无结果提示
    const container = document.getElementById('accountWebsiteListContainer');
    let noResultDiv = container.querySelector('.no-result-message');
    
    if (visibleCount === 0 && keyword !== '') {
        if (!noResultDiv) {
            noResultDiv = document.createElement('div');
            noResultDiv.className = 'no-result-message text-center text-muted py-4';
            noResultDiv.innerHTML = `
                <i class="mdi mdi-magnify-close" style="font-size: 48px;"></i>
                <p class="mt-2">${i18n.noMatch}</p>
            `;
            container.appendChild(noResultDiv);
        }
    } else {
        if (noResultDiv) {
            noResultDiv.remove();
        }
    }
}

// 切换站点选择状态
function toggleAccountWebsiteSelection(websiteId, isChecked) {
    if (isChecked) {
        if (!selectedWebsiteIdsForAccount.includes(websiteId)) {
            selectedWebsiteIdsForAccount.push(websiteId);
        }
        // 添加高亮
        const item = document.querySelector(`.account-website-item[data-website-id="${websiteId}"]`);
        if (item) {
            item.classList.add('border-success');
        }
    } else {
        const index = selectedWebsiteIdsForAccount.indexOf(websiteId);
        if (index > -1) {
            selectedWebsiteIdsForAccount.splice(index, 1);
        }
        // 移除高亮
        const item = document.querySelector(`.account-website-item[data-website-id="${websiteId}"]`);
        if (item) {
            item.classList.remove('border-success');
        }
    }
    
    // 更新计数
    const countElement = document.getElementById('accountSelectedCount');
    if (countElement) {
        countElement.textContent = selectedWebsiteIdsForAccount.length;
    }
}

// 清除站点选择
function clearAccountWebsiteSelections() {
    SafeSwal.fire({
        title: '<?= __("确认清除") ?>',
        text: '<?= __("确定要清除所有选择吗？") ?>',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<?= __("确定") ?>',
        cancelButtonText: '<?= __("取消") ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            selectedWebsiteIdsForAccount = [];
            
            // 清除复选框
            document.querySelectorAll('#accountWebsiteBindingContainer input[type="checkbox"]').forEach(checkbox => {
                checkbox.checked = false;
            });
            
            // 清除高亮样式
            document.querySelectorAll('.account-website-item').forEach(item => {
                item.classList.remove('border-success');
            });
            
            // 重新渲染
            renderAccountWebsiteList(allAvailableWebsites);
            
            SafeSwal.fire({
                icon: 'success',
                title: '<?= __("已清除") ?>',
                timer: 1000,
                showConfirmButton: false
            });
        }
    });
}

// 保存站点绑定
