    const originalBtnHtml = saveBtn.innerHTML;
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("保存中..") ?>';
    saveBtn.classList.add('btn-secondary');
    saveBtn.classList.remove('btn-primary');
    
    // 显示loading弹窗
    SafeSwal.fire({
        title: '<?= __("保存中") ?>',
        html: '<div class="text-center"><div class="spinner-border text-primary mb-3" role="status"></div><p class="text-muted"><?= __("正在保存站点绑定...") ?></p><small class="text-muted"><?= __("已选择") ?>: <strong>' + selectedWebsiteIdsForAccount.length + '</strong> <?= __("个站点") ?></small></div>',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: () => {
            SafeSwal.showLoading();
        }
    });
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/saveWebsiteBindings') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        console.log('保存响应:', response);
        return response.json();
    })
    .then(resp => {
        console.log('解析响应:', resp);
        
        if (resp.success) {
            // 显示成功
            SafeSwal.fire({
                icon: 'success',
                title: '<?= __("保存成功") ?>',
                html: '<p class="mb-2">' + (resp.message || '<?= __("配置保存成功") ?>') + '</p><small class="text-success"><i class="mdi mdi-check-circle me-1"></i><?= __("页面将自动刷新") ?></small>',
                timer: 2000,
                timerProgressBar: true,
                showConfirmButton: false
            }).then(() => {
                // 关闭 offcanvas
                const offcanvasElement = document.getElementById('accountWebsiteBindingOffcanvas');
                if (offcanvasElement) {
                    const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
                    if (offcanvas) {
                        offcanvas.hide();
                    }
                }
                
                // 刷新页面
                setTimeout(() => {
                    location.reload();
                }, 500);
            });
        } else {
            throw new Error(resp.message || '<?= __("保存失败") ?>');
        }
    })
    .catch(error => {
        console.error('保存失败:', error);
        
        // 显示错误
        SafeSwal.fire({
            icon: 'error',
            title: '<?= __("保存失败") ?>',
            html: '<p class="mb-2">' + error.message + '</p><small class="text-muted"><?= __("请检查网络连接后重试") ?></small>',
            confirmButtonText: '<?= __("确定") ?>',
            confirmButtonColor: '#dc3545'
        }).then(() => {
            // 恢复按钮状态
            saveBtn.disabled = false;
            saveBtn.innerHTML = originalBtnHtml;
            saveBtn.classList.remove('btn-secondary');
            saveBtn.classList.add('btn-primary');
        });
    });
}

