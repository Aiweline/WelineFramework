// 生成 Sitemap（直接生成，不询问确认）
function generateSitemap() {
    SafeSwal.fire({
        title: '<?= __("生成中") ?>',
        html: '<div class="text-center"><div class="spinner-border text-primary mb-3" role="status"></div><p class="text-muted"><?= __("正在生成 Sitemap，请稍候...") ?></p></div>',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: () => {
            SafeSwal.showLoading();
        }
    });
    
    const formData = new FormData();
    formData.append('generate_all', '1');
    formData.append('use_providers', '1');
    
    fetch('<?= $this->getBackendUrl('seo/backend/sitemap/generate') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            SafeSwal.fire({
                icon: 'success',
                title: '<?= __("生成成功") ?>',
                html: data.message || '<?= __("Sitemap 生成成功") ?>',
                timer: 2500,
                timerProgressBar: true,
                showConfirmButton: false
            }).then(() => {
                location.reload();
            });
        } else {
            SafeSwal.fire({
                icon: 'error',
                title: '<?= __("生成失败") ?>',
                text: data.message || '<?= __("Sitemap 生成失败") ?>',
                confirmButtonText: '<?= __("确定") ?>'
            });
        }
    })
    .catch(error => {
        console.error('生成 Sitemap 失败:', error);
        SafeSwal.fire({
            icon: 'error',
            title: '<?= __("生成失败") ?>',
            text: '<?= __("请求失败，请重试") ?>',
            confirmButtonText: '<?= __("确定") ?>'
        });
    });
}

// 加载账户表单到 Offcanvas
function loadAccountForm(accountId) {
    const container = document.getElementById('accountFormContainer');
    const titleElement = document.getElementById('accountOffcanvasTitle');
    
    // 设置标题
    if (accountId > 0) {
        titleElement.textContent = '<?= __("编辑SEO账户") ?> #' + accountId;
    } else {
        titleElement.textContent = '<?= __("添加SEO账户") ?>';
    }
    
    // 显示加载状态
    container.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden"><?= __("加载中...") ?></span>
            </div>
            <p class="mt-2 text-muted"><?= __("正在加载表单...") ?></p>
        </div>
    `;
    
    // 构建URL
    const url = '<?= $this->getBackendUrl('seo/backend/account/form', ['module' => $module, 'scope' => $scope]) ?>' + 
                (accountId > 0 ? '&id=' + accountId : '');
    
    // 发起请求
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('HTTP error! status: ' + response.status);
        }
        return response.text();
    })
    .then(html => {
        container.innerHTML = html;
        
        // 绑定表单提交事件
        const form = container.querySelector('form');
        if (form) {
            form.addEventListener('submit', handleAccountFormSubmit);
        }
    })
    .catch(error => {
        console.error('Error loading form:', error);
        container.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                <?= __("加载失败") ?>: ${error.message}
            </div>
        `;
    });
}

// 处理账户表单提交
function handleAccountFormSubmit(event) {
    event.preventDefault();
    
    const form = event.target;
    const formData = new FormData(form);
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalBtnHtml = submitBtn ? submitBtn.innerHTML : '';
    
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __("保存中...") ?>';
    }
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showMessage('success', data.message || '<?= __("确认") ?>');
            
            // 关闭 offcanvas
            const offcanvasElement = document.getElementById('accountOffcanvas');
            const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
            if (offcanvas) {
                offcanvas.hide();
            }
            
            // 刷新页面
            setTimeout(() => {
                location.reload();
            }, 800);
        } else {
            showMessage('error', data.message || '<?= __("确认") ?>');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHtml;
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showMessage('error', '<?= __("保存失败，请重试") ?>');
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnHtml;
        }
    });
    
    return false;
}

