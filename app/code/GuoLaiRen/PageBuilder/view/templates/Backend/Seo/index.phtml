                                       value="${priority}" min="0" max="1" step="0.1">
                            </div>
                            
                            <div class="config-field">
                                <label>
                                    <i class="mdi mdi-upload-network"></i>
                                    <span>${i18n.autoSubmit}</span>
                                </label>
                                <div class="form-check form-switch" style="padding-top: 8px;">
                                    <input class="form-check-input" type="checkbox" name="is_auto_submit" 
                                           value="1" ${isAutoSubmit === 1 ? 'checked' : ''} 
                                           style="width: 48px; height: 24px; cursor: pointer;">
                                    <label class="form-check-label ms-2" style="color: #64748b; font-size: 0.85rem;">
                                        ${isAutoSubmit === 1 ? i18n.enabled : i18n.disabled}
                                    </label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="config-actions">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetWebsiteConfig(this)">
                                <i class="mdi mdi-restore me-1"></i>
                                ${i18n.reset}
                            </button>
                            <button type="button" class="btn btn-sm btn-primary" onclick="saveWebsiteConfig(this)">
                                <i class="mdi mdi-content-save me-1"></i>
                                ${i18n.saveConfig}
                            </button>
                        </div>
                    </form>
                </div>
            `;
        }).join('');
        
        container.innerHTML = websitesHtml || '<div class="alert alert-warning">' + i18n.noData + '</div>';
        
    } catch (error) {
        console.error('加载站点配置失败:', error);
        container.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                ${error.message || i18n.loadFailed}
            </div>
        `;
    }
}

// 保存站点配置
function saveWebsiteConfig(button) {
    const form = button.closest('.website-config-form');
    const accountId = form.dataset.accountId;
    const websiteId = form.dataset.websiteId;
    const formData = new FormData(form);
    
    const config = {
        sitemap_frequency: formData.get('sitemap_frequency'),
        crawl_frequency: formData.get('crawl_frequency'),
        priority: formData.get('priority'),
        is_auto_submit: formData.get('is_auto_submit') ? 1 : 0
    };
    
    console.log('保存配置参数:', { accountId, websiteId, config });
    
    // 禁用按钮并显示loading状态
    button.disabled = true;
    const originalHtml = button.innerHTML;
    button.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>' + i18n.saving;
    button.classList.add('btn-secondary');
    button.classList.remove('btn-primary');
    
    // 显示loading弹窗
    SafeSwal.fire({
        title: i18n.saving,
        html: '<div class="text-center"><div class="spinner-border text-primary mb-3" role="status"></div><p class="text-muted">' + '<?= __("正在保存配置，请稍候...") ?>' + '</p></div>',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: () => {
            SafeSwal.showLoading();
        }
    });
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/saveWebsiteConfig') ?>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            account_id: accountId,
            website_id: websiteId,
            config: config
        })
    })
    .then(response => response.json())
    .then(data => {
        console.log('保存响应:', data);
        
        if (data.success) {
            // 显示成功
            SafeSwal.fire({
                icon: 'success',
                title: i18n.saveSuccess,
                html: '<p class="mb-2">' + (data.message || '<?= __("配置保存成功") ?>') + '</p><small class="text-muted"><?= __("页面将自动刷新") ?></small>',
                timer: 2500,
                timerProgressBar: true,
                showConfirmButton: false
            }).then(() => {
                // 更新按钮状态
                button.innerHTML = '<i class="mdi mdi-check-circle me-1"></i><?= __("已保存") ?>';
                button.classList.remove('btn-secondary');
                button.classList.add('btn-success');
                
                // 1秒后恢复按钮
                setTimeout(() => {
                    button.innerHTML = originalHtml;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-primary');
                    button.disabled = false;
                }, 1000);
            });
        } else {
            throw new Error(data.message || i18n.saveFailed);
        }
    })
    .catch(error => {
        console.error('保存配置失败:', error);
        
        // 显示错误
        SafeSwal.fire({
            icon: 'error',
            title: i18n.saveFailed,
            html: '<p class="mb-2">' + error.message + '</p><small class="text-muted"><?= __("请检查网络连接后重试") ?></small>',
            confirmButtonText: '<?= __("确定") ?>',
            confirmButtonColor: '#dc3545'
        }).then(() => {
            // 恢复按钮
            button.innerHTML = originalHtml;
            button.classList.remove('btn-secondary');
            button.classList.add('btn-primary');
            button.disabled = false;
        });
    });
}

// 重置站点配置
