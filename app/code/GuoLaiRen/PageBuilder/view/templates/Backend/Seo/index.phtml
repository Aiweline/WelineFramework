let currentBindingAccountId = 0;
let allAvailableWebsites = [];
let selectedWebsiteIdsForAccount = [];

// 加载账户站点绑定面板
function loadAccountWebsiteBinding(accountId) {
    currentBindingAccountId = accountId;
    const container = document.getElementById('accountWebsiteBindingContainer');
    const titleElement = document.getElementById('accountWebsiteBindingTitle');
    
    titleElement.innerHTML = '<i class="mdi mdi-web me-2"></i><?= __("绑定站点") ?> <small class="text-muted">(<?= __("账户") ?> #' + accountId + ')</small>';
    
    // 显示加载状态
    container.innerHTML = `
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <div class="loading-text">
                <?= __("正在加载数据...") ?>
            </div>
            <div class="loading-tips">
                <i class="mdi mdi-information-outline"></i>
                <span><?= __("搜索可用站点") ?></span>
            </div>
        </div>
    `;
    
    // 获取账户站点绑定信息
    const url = '<?= $this->getBackendUrl('seo/backend/account/websites') ?>' + '?account_id=' + accountId;
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            allAvailableWebsites = data.websites || [];
            selectedWebsiteIdsForAccount = data.bound_website_ids || [];
            renderAccountWebsiteList(allAvailableWebsites);
        } else {
            container.innerHTML = `
                <div class="loading-state">
                    <div style="text-align: center;">
                        <i class="mdi mdi-alert-circle-outline" style="font-size: 5rem; color: #ef4444; opacity: 0.8; margin-bottom: 24px;"></i>
                        <div class="loading-text" style="color: #ef4444;">
                            <?= __("加载失败") ?>
                        </div>
                        <div class="loading-tips" style="margin-top: 12px; color: #64748b;">
                            <i class="mdi mdi-information-outline"></i>
                            <span>${data.message || '<?= __("请稍后重试") ?>'}</span>
                        </div>
                        <button class="btn btn-outline-primary mt-4" onclick="loadAccountWebsiteBinding(${accountId})">
                            <i class="mdi mdi-refresh me-2"></i>
                            <?= __("重试") ?>
                        </button>
                    </div>
                </div>
            `;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = `
            <div class="loading-state">
                <div style="text-align: center;">
                    <i class="mdi mdi-alert-circle-outline" style="font-size: 5rem; color: #ef4444; opacity: 0.8; margin-bottom: 24px;"></i>
                        <div class="loading-text" style="color: #ef4444;">
                            <?= __("请求失败") ?>
                        </div>
                        <div class="loading-tips" style="margin-top: 12px; color: #64748b;">
                            <i class="mdi mdi-information-outline"></i>
                            <span><?= __("请检查网络连接后重试") ?></span>
                        </div>
                        <button class="btn btn-outline-primary mt-4" onclick="loadAccountWebsiteBinding(${accountId})">
                            <i class="mdi mdi-refresh me-2"></i>
                            <?= __("重试") ?>
                    </button>
                </div>
            </div>
        `;
    });
