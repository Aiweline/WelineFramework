// Safe Swal wrapper (local loading - no async wait needed)
const SafeSwal = {
    fire: function(config) {
        if (typeof Swal !== 'undefined') {
            return Swal.fire(config);
        } else {
            console.warn('SweetAlert2 not loaded, using native dialogs');
            
            if (config.icon === 'success' || config.icon === 'error' || config.icon === 'warning') {
                const message = config.html || config.text || config.title || '';
                const plainMessage = message.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
                alert(plainMessage);
                
                if (config.timer && config.showConfirmButton === false) {
                    return Promise.resolve({ isConfirmed: true });
                }
            }
            
            if (config.showCancelButton) {
                const message = config.html || config.text || config.title || '';
                const plainMessage = message.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
                const result = confirm(plainMessage);
                return Promise.resolve({ isConfirmed: result });
            }
            
            return Promise.resolve({ isConfirmed: true });
        }
    },
    showLoading: function() {
        if (typeof Swal !== 'undefined') {
            Swal.showLoading();
        }
    }
};

// Friendly message function
function showMessage(type, message, title = null) {
    if (typeof Swal !== 'undefined') {
        const config = {
            icon: type === 'success' ? 'success' : type === 'error' ? 'error' : 'warning',
            title: title || (type === 'success' ? '<?= __("确认") ?>' : '<?= __("确认") ?>'),
            text: message,
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: type === 'success' ? 3000 : 5000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer);
                toast.addEventListener('mouseleave', Swal.resumeTimer);
            }
        };
        SafeSwal.fire(config);
    } else {
        const prefix = type === 'success' ? '\u2713 ' : type === 'error' ? '\u2717 ' : '\u26A0 ';
        alert(prefix + (title || '') + '\n' + message);
    }
}

// SEO 账户平台处理 - AJAX 表单处理函数
(function initSeoAccountPlatformHandlers() {
    if (typeof window.handlePlatformChange === 'function') {
        return;
    }

    function getPlatformData() {
        if (window.PLATFORM_DATA) {
            return window.PLATFORM_DATA;
        }
        const dataEl = document.getElementById('seoAccountPlatformData');
        if (!dataEl) {
            return null;
        }
        try {
            const data = JSON.parse(dataEl.textContent || '{}');
            window.PLATFORM_DATA = data;
            return data;
        } catch (e) {
            console.error('解析平台数据失败:', e);
            return null;
        }
    }

    function hideAllPlatformInfo() {
        const info = document.getElementById('platformFeaturesInfo');
        const guide = document.getElementById('platformGuideInfo');
        const fillBtn = document.getElementById('fillTemplateBtn');
        if (info) info.style.display = 'none';
        if (guide) guide.style.display = 'none';
        if (fillBtn) fillBtn.style.display = 'none';
    }

    function showPlatformInfo(platformCode) {
        const data = getPlatformData();
        if (!data || !data[platformCode]) {
            hideAllPlatformInfo();
            return;
        }

        const platform = data[platformCode];
        const featuresInfo = document.getElementById('platformFeaturesInfo');
        const guideInfo = document.getElementById('platformGuideInfo');
        const fillBtn = document.getElementById('fillTemplateBtn');

        if (featuresInfo) featuresInfo.style.display = 'block';
        if (guideInfo) guideInfo.style.display = 'block';
        if (fillBtn) fillBtn.style.display = 'inline-block';

        const title = document.getElementById('platformFeaturesTitle');
        if (title) title.textContent = platform.name || '';

        const featuresList = document.getElementById('platformFeaturesList');
        if (featuresList && Array.isArray(platform.features)) {
            featuresList.innerHTML = platform.features.map(f => `<li>${f}</li>`).join('');
        }

        const hint = document.getElementById('platformConfigHint');
        if (hint) hint.textContent = platform.config_hint || '';

        const guideTitle = document.getElementById('platformGuideTitle');
        if (guideTitle) guideTitle.textContent = platform.guide_title || '';

        const guideSteps = document.getElementById('platformGuideSteps');
        if (guideSteps && Array.isArray(platform.guide_steps)) {
            guideSteps.innerHTML = platform.guide_steps.map(s => `<li>${s}</li>`).join('');
        }

        const configTemplate = document.getElementById('platformConfigTemplate');
        if (configTemplate && platform.config_template) {
            configTemplate.textContent = JSON.stringify(platform.config_template, null, 2);
        }

        const guideContent = document.getElementById('platformGuideContent');
        const guideIcon = document.getElementById('guideToggleIcon');
        if (guideContent) guideContent.style.display = 'block';
        if (guideIcon) guideIcon.style.transform = 'rotate(180deg)';

        const configTextarea = document.getElementById('configJsonTextarea');
        if (configTextarea && !configTextarea.value.trim() && platform.config_template) {
            configTextarea.placeholder = JSON.stringify(platform.config_template, null, 2);
        }
    }

    window.handlePlatformChange = function handlePlatformChange(platformCode) {
        const platformSelect = document.getElementById('platformSelect');
        const code = platformCode || (platformSelect ? platformSelect.value : '');
        window.currentSelectedPlatform = code || '';
        if (!code) {
            hideAllPlatformInfo();
            return;
        }
        showPlatformInfo(code);
    };

    window.toggleGuideContent = function toggleGuideContent() {
        const content = document.getElementById('platformGuideContent');
        const icon = document.getElementById('guideToggleIcon');
        if (!content || !icon) {
            return;
        }
        const isVisible = content.style.display !== 'none';
        content.style.display = isVisible ? 'none' : 'block';
        icon.style.transform = isVisible ? 'rotate(0deg)' : 'rotate(180deg)';
    };

    window.fillConfigTemplate = function fillConfigTemplate() {
        const data = getPlatformData();
        const platformSelect = document.getElementById('platformSelect');
        const code = window.currentSelectedPlatform || (platformSelect ? platformSelect.value : '');
        if (!data || !code || !data[code]) {
            showMessage('warning', '<?= __("请先选择平台") ?>');
            return;
        }
        const configTextarea = document.getElementById('configJsonTextarea');
        const template = data[code].config_template;
        if (!configTextarea || !template) {
            return;
        }
        if (configTextarea.value.trim() !== '') {
            SafeSwal.fire({
                icon: 'question',
                title: '<?= __("确认") ?>',
                text: '<?= __("当前配置将被替换，确定吗？") ?>',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then((result) => {
                if (result.isConfirmed) {
                    configTextarea.value = JSON.stringify(template, null, 2);
                    configTextarea.focus();
                }
            });
            return;
        }
        configTextarea.value = JSON.stringify(template, null, 2);
        configTextarea.focus();
    };

    window.handleJsonFileUpload = function handleJsonFileUpload(input) {
        const file = input.files[0];
        if (!file) {
            return;
        }
        
        if (!file.name.endsWith('.json') && file.type !== 'application/json') {
            showMessage('error', '<?= __("请选择JSON文件") ?>');
            input.value = '';
            return;
        }
        
        if (file.size > 5 * 1024 * 1024) {
            showMessage('error', '<?= __("文件大小不能超过5MB") ?>');
            input.value = '';
            return;
        }
        
        const configTextarea = document.getElementById('configJsonTextarea');
        
        function readJsonFile() {
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const content = e.target.result;
                    const jsonObj = JSON.parse(content);
                    if (configTextarea) {
                        configTextarea.value = JSON.stringify(jsonObj, null, 2);
                        configTextarea.focus();
                    }
                    showMessage('success', '<?= __("JSON文件导入成功") ?>');
                } catch (err) {
                    showMessage('error', '<?= __("JSON解析失败") ?>: ' + err.message);
                }
                input.value = '';
            };
            reader.onerror = function() {
                showMessage('error', '<?= __("文件读取失败") ?>');
                input.value = '';
            };
            reader.readAsText(file);
        }
        
        if (configTextarea && configTextarea.value.trim() !== '') {
            SafeSwal.fire({
                icon: 'question',
                title: '<?= __("确认") ?>',
                text: '<?= __("当前配置将被替换，确定导入吗？") ?>',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then((result) => {
                if (result.isConfirmed) {
                    readJsonFile();
                } else {
                    input.value = '';
                }
            });
            return;
        }
        
        readJsonFile();
    };
})();

