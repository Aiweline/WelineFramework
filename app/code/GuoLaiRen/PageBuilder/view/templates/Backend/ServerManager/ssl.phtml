<script>
(function () {
    'use strict';
    var listUrl = '<?= $listUrl ?>';
    var detailUrl = '<?= $detailUrl ?>';
    var domainPoolUrl = '<?= $domainPoolUrl ?>';
    var requestUrl = '<?= $requestUrl ?>';
    var renewUrl = '<?= $renewUrl ?>';
    var toggleHttpsUrl = '<?= $toggleHttpsUrl ?>';
    var deleteUrl = '<?= $deleteUrl ?>';
    var bodyEl = document.getElementById('pb-ssl-body');
    var refreshBtn = document.getElementById('pb-ssl-refresh');
    var domainRefreshBtn = document.getElementById('pb-ssl-domain-refresh');
    var requestBtn = document.getElementById('pb-ssl-request-btn');
    var domainEl = document.getElementById('pb-ssl-domain');
    var emailEl = document.getElementById('pb-ssl-email');
    var providerEl = document.getElementById('pb-ssl-provider');
    var detailModalEl = document.getElementById('pbSslDetailModal');
    var detailModal = detailModalEl ? new bootstrap.Modal(detailModalEl) : null;
    var detailDomainEl = document.getElementById('pb-ssl-detail-domain');
    var detailSummaryEl = document.getElementById('pb-ssl-detail-summary');
    var detailPathsEl = document.getElementById('pb-ssl-detail-paths');
    var detailCertPemEl = document.getElementById('pb-ssl-detail-cert-pem');
    var detailChainPemEl = document.getElementById('pb-ssl-detail-chain-pem');
    var detailKeyPemEl = document.getElementById('pb-ssl-detail-key-pem');

    function encodeBody(payload) {
        return Object.keys(payload).map(function (key) {
            return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
        }).join('&');
    }

    function post(url, payload) {
        return fetch(url, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: encodeBody(payload),
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        });
    }

    function getJson(url) {
        return fetch(url, {
            method: 'GET',
            headers: {'Accept': 'application/json'},
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        });
    }

    function escapeHtml(value) {
        var div = document.createElement('div');
        div.textContent = String(value || '');
        return div.innerHTML;
    }

    function escapeAttribute(value) {
        return escapeHtml(value).replace(/"/g, '&quot;');
    }

    function normalizeValue(value, fallback) {
        if (value === null || value === undefined || value === '') {
            return fallback || '-';
        }
        return String(value);
    }

    function statusLabel(status) {
        var normalized = String(status || '').toLowerCase();
        var map = {
            active: '<?= __('有效') ?>',
            pending: '<?= __('待申请') ?>',
            expired: '<?= __('已过期') ?>',
            error: '<?= __('错误') ?>',
            revoked: '<?= __('已吊销') ?>'
        };
        return map[normalized] || normalizeValue(status, '-');
    }

    function providerLabel(provider) {
        var normalized = String(provider || '').toLowerCase();
        var map = {
            letsencrypt: 'Let\'s Encrypt',
            litessl: 'LiteSSL',
            manual: '<?= __('手动导入') ?>'
        };
        return map[normalized] || normalizeValue(provider, '-');
    }

    function copyText(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
            return navigator.clipboard.writeText(text);
        }

        return new Promise(function (resolve, reject) {
            var textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.setAttribute('readonly', 'readonly');
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();

            try {
                var copied = document.execCommand('copy');
                document.body.removeChild(textarea);
                if (copied) {
                    resolve();
                } else {
                    reject(new Error('copy_failed'));
                }
            } catch (error) {
                document.body.removeChild(textarea);
                reject(error);
            }
        });
    }

    function setPemValue(element, value, emptyMessage) {
        if (!element) {
            return;
        }
        element.value = String(value || '').trim() || emptyMessage;
    }

    function renderDetailTable(target, rows) {
        if (!target) {
            return;
        }
        target.innerHTML = rows.map(function (row) {
            return '' +
                '<tr>' +
                '<th class="text-muted" style="width: 32%;">' + escapeHtml(row.label) + '</th>' +
                '<td>' + escapeHtml(row.value) + '</td>' +
                '</tr>';
        }).join('');
    }

    function loadDomainPool() {
        getJson(domainPoolUrl).then(function (result) {
            if (!result.success) {
                BackendToast.warning(result.message || '<?= __('域名池加载失败') ?>');
                return;
            }
            var rows = Array.isArray(result.data) ? result.data : [];
            var options = ['<option value=""><?= __('请选择域名池中的域名') ?></option>'];
            rows.forEach(function (row) {
                var domain = row.domain || '';
                if (!domain) {
                    return;
                }
                var rootDomain = row.root_domain || '';
                var httpsStatus = row.https_status || '';
                var label = domain;
                if (rootDomain && rootDomain !== domain) {
                    label += ' (' + rootDomain + ')';
                }
                if (httpsStatus) {
                    label += ' [' + httpsStatus + ']';
                }
                options.push('<option value="' + escapeHtml(domain) + '">' + escapeHtml(label) + '</option>');
            });
            domainEl.innerHTML = options.join('');
        }).catch(function () {
            BackendToast.error('<?= __('域名池请求失败') ?>');
        });
    }

    function renderRows(items) {
        if (!Array.isArray(items) || !items.length) {
            bodyEl.innerHTML = '<tr><td colspan="7" class="text-center text-muted"><?= __('暂无证书数据') ?></td></tr>';
            return;
        }
        bodyEl.innerHTML = items.map(function (item) {
            var domain = item.domain || '-';
            var status = item.status || '-';
            var expiresAt = item.expires_at || '-';
            var issuer = item.issuer || '-';
            var provider = item.provider || '-';
            var checked = item.https_enabled ? 'checked' : '';
            var normalizedDomain = String(domain).toLowerCase();
            var isProtectedDomain = normalizedDomain === 'localhost' || normalizedDomain === '127.0.0.1' || normalizedDomain === '::1';
            var statusLower = String(status).toLowerCase();
            var statusClass = 'bg-secondary';
            if (statusLower === 'active') {
                statusClass = 'bg-success';
            } else if (statusLower === 'pending') {
                statusClass = 'bg-warning';
            } else if (statusLower === 'expired' || statusLower === 'error') {
                statusClass = 'bg-danger';
            }
            var deleteDisabledAttr = isProtectedDomain ? 'disabled title="<?= __('本地域名证书不允许删除') ?>"' : '';
            var deleteBtnClass = 'btn btn-sm btn-outline-danger' + (isProtectedDomain ? ' disabled' : '');
            var safeDomain = escapeHtml(domain);
            var safeStatus = escapeHtml(statusLabel(status));
            var safeExpiresAt = escapeHtml(expiresAt);
            var safeIssuer = escapeHtml(normalizeValue(issuer, '-'));
            var safeProvider = escapeHtml(providerLabel(provider));
            return '' +
                '<tr>' +
                '<td><strong>' + safeDomain + '</strong></td>' +
                '<td><span class="badge ' + statusClass + '">' + safeStatus + '</span></td>' +
                '<td><input type="checkbox" data-op="toggle" data-domain="' + escapeAttribute(domain) + '" ' + checked + '></td>' +
                '<td>' + safeExpiresAt + '</td>' +
                '<td>' + safeIssuer + '</td>' +
                '<td>' + safeProvider + '</td>' +
                '<td class="text-end">' +
                '<button class="btn btn-sm btn-outline-secondary me-1" data-op="view" data-domain="' + escapeAttribute(domain) + '"><?= __('详情') ?></button>' +
                '<button class="btn btn-sm btn-outline-primary me-1" data-op="renew" data-domain="' + escapeAttribute(domain) + '"><?= __('续签') ?></button>' +
                '<button class="' + deleteBtnClass + '" data-op="delete" data-domain="' + escapeAttribute(domain) + '" ' + deleteDisabledAttr + '><?= __('删除') ?></button>' +
                '</td>' +
                '</tr>';
        }).join('');
    }

    function loadList() {
        getJson(listUrl).then(function (result) {
            if (!result.success) {
                BackendToast.warning(result.message || '<?= __('证书列表加载失败') ?>');
                bodyEl.innerHTML = '<tr><td colspan="7" class="text-center text-danger"><?= __('加载失败') ?></td></tr>';
                return;
            }
            renderRows(result.data || []);
        }).catch(function () {
            BackendToast.error('<?= __('证书列表请求失败') ?>');
        });
    }

    function openDetail(domain) {
        if (!detailModal) {
            return;
        }

        BackendToast.info('<?= __('正在加载证书详情...') ?>');
        getJson(detailUrl + '?domain=' + encodeURIComponent(domain)).then(function (result) {
            if (!result.success) {
                BackendToast.warning(result.message || '<?= __('证书详情加载失败') ?>');
                return;
            }

            var data = result.data || {};
            var certInfo = data.cert_info || {};
            var pemSummary = data.pem_summary || {};
            detailDomainEl.textContent = normalizeValue(data.domain || domain, '');

            renderDetailTable(detailSummaryEl, [
                {label: '<?= __('状态') ?>', value: statusLabel(data.status)},
                {label: '<?= __('证书类型') ?>', value: normalizeValue(data.cert_type, '-')},
                {label: '<?= __('颁发机构') ?>', value: normalizeValue(certInfo.issuer || data.issuer, '-')},
                {label: '<?= __('服务商') ?>', value: providerLabel(data.provider)},
                {label: '<?= __('颁发时间') ?>', value: normalizeValue(certInfo.issued_at || data.issued_at, '-')},
                {label: '<?= __('到期时间') ?>', value: normalizeValue(certInfo.expires_at || data.expires_at, '-')},
                {label: '<?= __('主题域名') ?>', value: normalizeValue(certInfo.subject || data.domain, '-')},
                {label: '<?= __('网站ID') ?>', value: normalizeValue(data.website_id, '0')}
            ]);

            renderDetailTable(detailPathsEl, [
                {label: '<?= __('HTTPS 已启用') ?>', value: data.https_enabled ? '<?= __('是') ?>' : '<?= __('否') ?>'},
                {label: '<?= __('自动续签') ?>', value: data.auto_renew ? '<?= __('是') ?>' : '<?= __('否') ?>'},
                {label: '<?= __('最后续签时间') ?>', value: normalizeValue(data.last_renew_at, '-')},
                {label: '<?= __('证书路径') ?>', value: normalizeValue(data.cert_path, '-')},
                {label: '<?= __('私钥路径') ?>', value: normalizeValue(data.key_path, '-')},
                {label: '<?= __('证书链路径') ?>', value: normalizeValue(data.chain_path, '-')},
                {label: '<?= __('PEM 可用性') ?>', value: [
                    pemSummary.has_cert_pem ? '<?= __('证书') ?>' : '',
                    pemSummary.has_chain_pem ? '<?= __('证书链') ?>' : '',
                    pemSummary.has_key_pem ? '<?= __('私钥') ?>' : ''
                ].filter(Boolean).join(' / ') || '<?= __('无') ?>'},
                {label: '<?= __('续签错误') ?>', value: normalizeValue(data.renew_error, '-')}
            ]);

            setPemValue(detailCertPemEl, data.cert_pem, '<?= __('暂无证书内容') ?>');
            setPemValue(detailChainPemEl, data.chain_pem, '<?= __('暂无证书链内容') ?>');
            setPemValue(detailKeyPemEl, data.key_pem, '<?= __('暂无私钥内容') ?>');
            detailModal.show();
        }).catch(function () {
            BackendToast.error('<?= __('证书详情请求失败') ?>');
        });
    }

    function applyRequest() {
        var domain = (domainEl.value || '').trim();
        var email = (emailEl.value || '').trim();
        var provider = providerEl.value || 'letsencrypt';
        if (!domain || !email) {
            BackendToast.warning('<?= __('请先从域名池选择域名并填写邮箱') ?>');
            return;
        }
        post(requestUrl, {domain: domain, email: email, provider: provider}).then(function (result) {
            if (result.success) {
                BackendToast.success(result.message || '<?= __('申请成功') ?>');
                loadList();
            } else {
                BackendToast.error(result.message || '<?= __('申请失败') ?>');
            }
        }).catch(function () {
            BackendToast.error('<?= __('申请请求失败') ?>');
        });
    }

    bodyEl.addEventListener('click', function (event) {
        var target = event.target;
        if (!(target instanceof HTMLElement)) return;
        var op = target.getAttribute('data-op');
        var domain = target.getAttribute('data-domain');
        if (!op || !domain) return;
        if (op === 'view') {
            openDetail(domain);
            return;
        }
        if (op === 'renew') {
            BackendConfirm.show('<?= __('确认立即续签该证书吗？') ?>', {
                title: '<?= __('续签证书') ?>',
                type: 'warning',
                confirmText: '<?= __('续签') ?>',
                cancelText: '<?= __('取消') ?>'
            }).then(function (confirmed) {
                if (!confirmed) return;
                post(renewUrl, {domain: domain}).then(function (result) {
                    if (result.success) {
                        BackendToast.success(result.message || '<?= __('续签成功') ?>');
                        loadList();
                    } else {
                        BackendToast.warning(result.message || '<?= __('续签失败') ?>');
                    }
                }).catch(function () {
                    BackendToast.error('<?= __('续签请求失败') ?>');
                });
            });
            return;
        }
        if (op === 'delete') {
            var normalizedDomain = String(domain).toLowerCase();
            if (normalizedDomain === 'localhost' || normalizedDomain === '127.0.0.1' || normalizedDomain === '::1') {
                BackendToast.warning('<?= __('本地域名证书不允许删除') ?>');
                return;
            }
            BackendConfirm.show('<?= __('确认删除该证书吗？') ?>').then(function (confirmed) {
                if (!confirmed) return;
                post(deleteUrl, {domain: domain}).then(function (result) {
                    if (result.success) {
                        BackendToast.success(result.message || '<?= __('删除成功') ?>');
                        loadList();
                    } else {
                        BackendToast.warning(result.message || '<?= __('删除失败') ?>');
                    }
                });
            });
        }
    });

    if (detailModalEl) {
        detailModalEl.addEventListener('click', function (event) {
            var target = event.target;
            if (!(target instanceof HTMLElement)) {
                return;
            }
            var copyTargetId = target.getAttribute('data-copy-target');
            if (!copyTargetId) {
                return;
            }
            var source = document.getElementById(copyTargetId);
            if (!(source instanceof HTMLTextAreaElement)) {
                return;
            }
            var text = String(source.value || '').trim();
            if (!text || text.indexOf('<?= __('暂无') ?>') === 0) {
                BackendToast.warning('<?= __('当前没有可复制的证书内容') ?>');
                return;
            }

            copyText(text).then(function () {
                BackendToast.success('<?= __('复制成功') ?>');
            }).catch(function () {
                BackendToast.error('<?= __('复制失败，请手动选择内容后复制') ?>');
            });
        });
    }

    bodyEl.addEventListener('change', function (event) {
        var target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        if (target.getAttribute('data-op') !== 'toggle') return;
        var domain = target.getAttribute('data-domain');
        if (!domain) return;
        post(toggleHttpsUrl, {domain: domain, enabled: target.checked ? 1 : 0}).then(function (result) {
            if (result.success) {
                BackendToast.success(result.message || '<?= __('HTTPS状态已更新') ?>');
            } else {
                BackendToast.warning(result.message || '<?= __('更新失败') ?>');
                target.checked = !target.checked;
            }
        }).catch(function () {
            target.checked = !target.checked;
            BackendToast.error('<?= __('请求失败') ?>');
        });
    });

    refreshBtn.addEventListener('click', loadList);
    domainRefreshBtn.addEventListener('click', loadDomainPool);
    requestBtn.addEventListener('click', applyRequest);
    loadDomainPool();
    loadList();
})();
</script>
