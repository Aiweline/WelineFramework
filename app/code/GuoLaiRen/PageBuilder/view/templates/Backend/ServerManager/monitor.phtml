<script>
(function () {
    'use strict';

    var statusUrl = '<?= $statusUrl ?>';
    var refreshBtn = document.getElementById('pb-monitor-refresh-btn');
    var timer = null;
    var i18n = {
        loadingFailed: '<?= __('监控数据加载失败') ?>',
        requestFailed: '<?= __('监控请求失败，请检查服务状态后重试。') ?>',
        yes: '<?= __('是') ?>',
        no: '<?= __('否') ?>',
        running: '<?= __('运行中') ?>',
        stopped: '<?= __('已停止') ?>',
        unknown: '<?= __('未知') ?>',
        noSuggestion: '<?= __('暂无建议') ?>',
        noInstances: '<?= __('暂无实例') ?>'
    };

    function requestJson(url) {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function') {
            return window.Weline.Api.request(url, {
                method: 'GET',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                silent: true
            }).then(function (response) {
                return response.data || {};
            });
        }
        return fetch(url, {
            method: 'GET',
            headers: {'Accept': 'application/json'},
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        });
    }

    function formatTimestamp(timestamp) {
        var value = Number(timestamp || 0);
        if (!value) {
            return '-';
        }
        return new Date(value * 1000).toLocaleString();
    }

    function boolText(value) {
        return value ? i18n.yes : i18n.no;
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = String(text || '');
        return div.innerHTML;
    }

    function renderTopCards(payload) {
        var servers = payload.servers || {};
        var entries = Object.values(servers);
        var running = 0;
        var maintenance = 0;
        var totalWorkers = 0;

        entries.forEach(function (row) {
            if (row && row.running) {
                running += 1;
            }
            if (row && row.maintenance_mode) {
                maintenance += 1;
            }
            totalWorkers += Number((row && row.worker_count) || 0);
        });

        document.getElementById('pb-monitor-running').textContent = String(running);
        document.getElementById('pb-monitor-total').textContent = String(entries.length);
        document.getElementById('pb-monitor-maintenance').textContent = String(maintenance);
        document.getElementById('pb-monitor-workers').textContent = String(totalWorkers);
        document.getElementById('pb-monitor-time').textContent = formatTimestamp(payload.timestamp);
    }

    function renderInstanceTable(payload) {
        var tbody = document.getElementById('pb-monitor-instance-body');
        var servers = payload.servers || {};
        var rows = Object.entries(servers);

        if (!rows.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">' + i18n.noInstances + '</td></tr>';
            return;
        }

        tbody.innerHTML = rows.map(function (entry) {
            var name = entry[0];
            var row = entry[1] || {};
            var endpoint = (row.host || '127.0.0.1') + ':' + (row.port || 9981);
            var running = !!row.running;
            var statusBadge = running
                ? '<span class="badge bg-success-subtle text-success-emphasis">' + i18n.running + '</span>'
                : '<span class="badge bg-secondary-subtle text-secondary-emphasis">' + i18n.stopped + '</span>';

            var sslBadge = row.ssl_cert
                ? '<span class="badge bg-info-subtle text-info-emphasis"><?= __('已配置') ?></span>'
                : '<span class="badge bg-light text-muted"><?= __('未配置') ?></span>';

            var maintenanceBadge = row.maintenance_mode
                ? '<span class="badge bg-warning-subtle text-warning-emphasis"><?= __('开启') ?></span>'
                : '<span class="badge bg-success-subtle text-success-emphasis"><?= __('关闭') ?></span>';

            return ''
                + '<tr>'
                + '<td><strong>' + escapeHtml(name) + '</strong></td>'
                + '<td><code>' + escapeHtml(endpoint) + '</code></td>'
                + '<td>' + Number(row.worker_count || 0) + '</td>'
                + '<td>' + sslBadge + '</td>'
                + '<td>' + maintenanceBadge + '</td>'
                + '<td>' + statusBadge + '</td>'
                + '</tr>';
        }).join('');
    }

    function renderOrchestrator(payload) {
        var orchestrator = payload.orchestrator || {};
        var data = orchestrator.data || {};
        var services = Array.isArray(data.services) ? data.services : [];

        document.getElementById('pb-orch-instance').textContent = data.instance || '-';
        document.getElementById('pb-orch-port').textContent = String(data.control_port || '-');
        document.getElementById('pb-orch-services').textContent = String(services.length);
        document.getElementById('pb-orch-running').textContent = boolText(!!data.running);
        document.getElementById('pb-orch-maintenance').textContent = boolText(!!data.maintenance_mode);
        document.getElementById('pb-orch-restart').textContent = boolText(!!data.rolling_restart_in_progress);
    }

    function renderSummary(payload) {
        var summary = payload.summary || {};
        var optimizations = summary.optimizations || {};
        var missing = Object.values(optimizations).filter(function (item) {
            return item && !item.installed;
        });

        document.getElementById('pb-summary-installed').textContent = String(summary.installed || 0);
        document.getElementById('pb-summary-missing').textContent = String(summary.missing || 0);
        document.getElementById('pb-summary-current').textContent = summary.current_boost || '-';
        document.getElementById('pb-summary-potential').textContent = summary.potential_boost || '-';

        var listEl = document.getElementById('pb-summary-list');
        if (!missing.length) {
            listEl.innerHTML = '<div class="text-muted small">' + i18n.noSuggestion + '</div>';
            return;
        }

        listEl.innerHTML = missing.slice(0, 6).map(function (item) {
            return ''
                + '<div class="pb-server-monitor-list-item">'
                + '<span class="pb-server-monitor-list-name">' + escapeHtml(item.name || i18n.unknown) + '</span>'
                + '<span class="pb-server-monitor-list-impact">' + escapeHtml(item.impact || '-') + '</span>'
                + '</div>';
        }).join('');
    }

    function renderPhpInfo(payload) {
        var info = payload.php_info || {};
        var extensions = Array.isArray(info.extensions) ? info.extensions : [];
        var hasEvent = extensions.indexOf('event') !== -1;
        var hasOpcache = extensions.indexOf('opcache') !== -1;
        var optimizations = ((payload.summary || {}).optimizations || {});
        var hasJit = hasOpcache && !!((optimizations.jit || {}).enabled);

        document.getElementById('pb-env-version').textContent = info.version || '-';
        document.getElementById('pb-env-os').textContent = info.os || '-';
        document.getElementById('pb-env-arch').textContent = info.arch || '-';
        document.getElementById('pb-env-event').textContent = hasEvent ? i18n.yes : i18n.no;
        document.getElementById('pb-env-opcache').textContent = hasOpcache ? i18n.yes : i18n.no;
        document.getElementById('pb-env-jit').textContent = hasJit ? i18n.yes : i18n.no;
    }

    function render(payload) {
        renderTopCards(payload);
        renderInstanceTable(payload);
        renderOrchestrator(payload);
        renderSummary(payload);
        renderPhpInfo(payload);
    }

    function refresh() {
        requestJson(statusUrl).then(function (result) {
            if (!result.success) {
                BackendToast.warning(result.message || i18n.loadingFailed);
                return;
            }
            render(result);
        }).catch(function (error) {
            BackendToast.error(i18n.requestFailed + ' ' + (error && error.message ? error.message : ''));
        });
    }

    if (window.Weline && typeof window.Weline.declare === 'function') {
        window.Weline.declare('api');
    }

    refreshBtn.addEventListener('click', refresh);
    refresh();
    timer = window.setInterval(refresh, 30000);

    window.addEventListener('beforeunload', function () {
        if (timer) {
            clearInterval(timer);
        }
    });
})();
</script>
