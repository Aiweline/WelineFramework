$sessionPersistUrl = $this->getBackendUrl('*/backend/server-manager/session-persist');
$sessionGcUrl = $this->getBackendUrl('*/backend/server-manager/session-gc');
$memoryNamespacesUrl = $this->getBackendUrl('*/backend/server-manager/memory-namespaces');
$memoryNamespaceDetailUrl = $this->getBackendUrl('*/backend/server-manager/memory-namespace-detail');
$memoryNamespaceClearUrl = $this->getBackendUrl('*/backend/server-manager/memory-namespace-clear');
$memoryKeyDeleteUrl = $this->getBackendUrl('*/backend/server-manager/memory-key-delete');
$memoryPersistUrl = $this->getBackendUrl('*/backend/server-manager/memory-persist');
