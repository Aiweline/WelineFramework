<script>
(function () {
    'use strict';
    var PB_SSE_CONNECT_DELAY_MS = 5000;
    
    // P0可观测性：初始化增强SSE日志器
    var sseLogger = null;
    try {
        if (window.PbAiSseConnectionManager) {
            sseLogger = window.PbAiSseConnectionManager.createLogger('pagebuilder-workspace', {
                publicId: <?= \json_encode(($publicId ?? ''), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
                enableDetailedLogging: true,
                maxLogEntries: 500
            });
        }
    } catch (e) {
        console.warn('[SSE] 初始化增强日志器失败:', e);
    }
    
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['pagebuilder-workspace-terminal'] : null;
    var publicId = <?= \json_encode(($publicId ?? ''), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var streamBaseUrl = <?= \json_encode(($streamSseUrl ?? ''), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var streamStageCode = 'plan';
    var lastEventId = <?= (int)($initialLastEventId ?? 0) ?>;
    var seenEventIds = [];
    var seenEventIdMap = Object.create(null);
    var recentSignalMap = Object.create(null);
    var suppressTransportErrorUntil = 0;
    var hasActiveOperation = false;
    var lastActivityTime = Date.now();
    var workspaceStreamPaused = !!window.__pbWorkspaceStreamPaused;
    var workspaceStreamFatal = false; // 402 等不可恢复错误后停止重连
    var workspaceReconnectTimer = null;
    var workspaceStartTimer = null;
    var workspaceReconnectDelayMs = 1200;
    var workspaceReconnectMaxDelayMs = 10000;
    
    // P0可观测性：增强的连接追踪
    var connectionStartTime = null;
    var currentConnectionId = null;
    var connectionRetryCount = 0;
    
    /** P0/P1：同标签页稳定 token，便于服务端区分并发 stream-sse */
    var workspaceStreamTabToken = (function () {
        var storageKey = 'pb_ai_ws_tab_' + String(publicId || '');
        try {
            var existing = sessionStorage.getItem(storageKey);
            if (existing && String(existing).length <= 64) {
                return String(existing);
            }
            var t = 't' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 12);
            sessionStorage.setItem(storageKey, t);
            return t;
        } catch (e) {
            return 't' + Date.now().toString(36);
        }
    })();

    if (!terminal || !streamBaseUrl || !publicId) {
        return;
    }

    function getPlanTerminalInstance() {
        if (!window.WelineSseTerminal || typeof window.WelineSseTerminal !== 'object') {
            return null;
        }
        return window.WelineSseTerminal['pb-ai-plan-sse-terminal'] || null;
    }

    function mirrorToPlanTerminal(message, level, payload) {
        var planTerminal = getPlanTerminalInstance();
        if (!planTerminal || typeof planTerminal.log !== 'function') {
            return;
        }
        var text = String(message || '');
        if (text === '') {
            return;
        }
        var planTerminalStatusEl = document.getElementById('pb-ai-plan-sse-terminal_status');
        if (planTerminalStatusEl) {
            planTerminalStatusEl.textContent = '<?= __('已连接') ?>';
        }
        try {
            planTerminal.log(text, level || 'info', payload && typeof payload === 'object' ? payload : undefined);
        } catch (error) {
            // ignore mirror errors to avoid breaking workspace stream
        }
    }

    var planTypingBuffer = '';
    var planTypingFlushTimer = null;
    var planTypingChunkCount = 0;
    var planMarkdownStreamBuffer = '';

    function appendPlanMarkdownChunk(rawChunk) {
        var chunk = String(rawChunk || '');
        if (chunk === '') {
            return;
        }
        // 忽略明显 JSON 噪声分片，避免把 {"markdown": "..."} 原文渲染到预览。
        if (isJsonNoiseChunk(chunk)) {
            return;
        }
        planMarkdownStreamBuffer += chunk;
        // 使用累积 buffer 而非从 DOM 读取，保证预览同步
        if (typeof window.updatePlanModalContent === 'function') {
            window.updatePlanModalContent(planMarkdownStreamBuffer);
        } else {
            var mdEl = document.getElementById('pb-ai-plan-md-content');
            if (mdEl) {
                mdEl.textContent = planMarkdownStreamBuffer;
            }
        }
    }

    function isJsonNoiseChunk(chunk) {
        var text = String(chunk || '').trim();
        if (!text) {
            return false;
        }
        if (text.indexOf('"plan_json"') >= 0 || text.indexOf('"markdown"') >= 0) {
            return true;
        }
        if ((text.charAt(0) === '{' || text.charAt(0) === '[') && /"[^"]+"\s*:/.test(text)) {
            return true;
        }
        return false;
    }

    function flushPlanTypingBuffer(force) {
        if (planTypingFlushTimer) {
            window.clearTimeout(planTypingFlushTimer);
            planTypingFlushTimer = null;
        }
        var text = String(planTypingBuffer || '');
        if (!text) {
            return;
        }
        var shouldFlush = !!force
            || /[\n\r。！？!?]$/.test(text)
            || text.length >= 48
            || planTypingChunkCount >= 18;
        if (!shouldFlush) {
            planTypingFlushTimer = window.setTimeout(function () {
                flushPlanTypingBuffer(true);
            }, 180);
            return;
        }
        mirrorToPlanTerminal(text, 'chunk', { event_type: 'plan_chunk' });
        planTypingBuffer = '';
        planTypingChunkCount = 0;
    }

    function appendPlanTypingChunk(rawChunk) {
        var chunk = String(rawChunk || '');
        if (!chunk) {
            return;
        }
        planTypingBuffer += chunk;
        planTypingChunkCount += 1;
        // 立即将 chunk 写入终端，保证实时可观测
        mirrorToPlanTerminal(chunk, 'chunk', { event_type: 'plan_chunk' });
        flushPlanTypingBuffer(false);
    }

    function parseSsePayload(event) {
        if (!event || typeof event.data !== 'string' || event.data === '') {
            return {};
        }
        try { return JSON.parse(event.data); } catch (error) { return {}; }
    }

    function buildWorkspaceStreamUrl() {
        try {
            var requestUrl = new URL(streamBaseUrl, window.location.origin);
            requestUrl.searchParams.set('public_id', publicId);
            if (streamStageCode) {
                requestUrl.searchParams.set('stage', streamStageCode);
            }
            if (workspaceStreamTabToken) {
                requestUrl.searchParams.set('tab_token', workspaceStreamTabToken);
            }
            if (lastEventId > 0) {
                requestUrl.searchParams.set('last_event_id', String(lastEventId));
            } else {
                requestUrl.searchParams.delete('last_event_id');
            }
            return requestUrl.toString();
        } catch (error) {
            var separator = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + separator + 'public_id=' + encodeURIComponent(publicId);
            if (streamStageCode) {
                url += '&stage=' + encodeURIComponent(streamStageCode);
            }
            url += '&tab_token=' + encodeURIComponent(workspaceStreamTabToken || '');
            if (lastEventId > 0) {
                url += '&last_event_id=' + encodeURIComponent(String(lastEventId));
            }
            return url;
        }
    }

    function clearWorkspaceReconnectTimer() {
        if (workspaceReconnectTimer) {
            window.clearTimeout(workspaceReconnectTimer);
            workspaceReconnectTimer = null;
        }
        if (workspaceStartTimer) {
            window.clearTimeout(workspaceStartTimer);
            workspaceStartTimer = null;
        }
    }

    function scheduleWorkspaceReconnect(reason) {
        workspaceStreamPaused = !!window.__pbWorkspaceStreamPaused;
        if (workspaceStreamPaused || workspaceStreamFatal) {
            return;
        }
        clearWorkspaceReconnectTimer();
        workspaceReconnectTimer = window.setTimeout(function () {
            workspaceReconnectTimer = null;
            startWorkspaceStream('reconnect:' + String(reason || 'unknown'));
        }, workspaceReconnectDelayMs);
        workspaceReconnectDelayMs = Math.min(workspaceReconnectDelayMs * 2, workspaceReconnectMaxDelayMs);
    }

    function startWorkspaceStream(sourceTag) {
        workspaceStreamPaused = !!window.__pbWorkspaceStreamPaused;
        if (workspaceStreamPaused || workspaceStreamFatal) {
            return;
        }
        clearWorkspaceReconnectTimer();
        var nextUrl = buildWorkspaceStreamUrl();
        if (!nextUrl) {
            return;
        }
        try {
            var current = typeof terminal.getUrl === 'function' ? String(terminal.getUrl() || '') : '';
            if (typeof terminal.isRunning === 'function' && terminal.isRunning()) {
                if (current === nextUrl) {
                    return;
                }
                if (typeof terminal.stop === 'function') {
                    terminal.stop({ suppressTransportError: true });
                }
            }
        } catch (guardErr) {
            // 继续尝试 start，避免偶发 API 异常导致永不连接
        }
        connectionStartTime = Date.now();
        currentConnectionId = 'ws_' + connectionStartTime + '_' + Math.random().toString(36).slice(2, 8);
        var source = String(sourceTag || '');
        var fastStart = /start-plan|start-plan-confirmed|manual|explicit/i.test(source);
        var connectDelayMs = fastStart ? 80 : PB_SSE_CONNECT_DELAY_MS;
        terminal.setUrl(nextUrl);
        workspaceStartTimer = window.setTimeout(function () {
            workspaceStartTimer = null;
            terminal.start(nextUrl);
        }, connectDelayMs);
    }
    window.__pbStartWorkspaceStream = startWorkspaceStream;
    window.__pbClearWorkspaceReconnectTimer = clearWorkspaceReconnectTimer;
    window.__pbEnsureWorkspaceStream = function (sourceTag) {
        // 用户显式触发阶段一/阶段二开始时，强制解除暂停与fatal锁，确保能够重连。
        workspaceStreamPaused = false;
        workspaceStreamFatal = false;
        window.__pbWorkspaceStreamPaused = false;
        clearWorkspaceReconnectTimer();
        startWorkspaceStream(sourceTag || 'ensure');
    };

    function formatWorkspaceLog(entry) {
        var payload = entry && entry.payload && typeof entry.payload === 'object' ? entry.payload : {};
        var stageLabel = payload.stage_label || payload.stage_code || entry.stage_code || '';
        var message = payload.message || entry.message || entry.event_type || '';
        if (!message && payload.operation) {
            message = String(payload.operation);
        }
        return stageLabel ? (stageLabel + ': ' + message) : message;
    }

    function formatPlanMirrorLog(entry) {
        var payload = entry && entry.payload && typeof entry.payload === 'object' ? entry.payload : {};
        var eventType = String(entry && entry.event_type ? entry.event_type : '');
        var operation = String(payload.operation || entry.operation || '');
        var message = String(payload.message || entry.message || eventType || '').trim();
        var isPlanEvent = operation === 'plan'
            || eventType === 'plan_chunk'
            || eventType === 'plan_generated'
            || eventType === 'plan_saved'
            || eventType === 'plan_refined'
            || eventType === 'plan_rebuilt';
        if (isPlanEvent) {
            // 终端以方案正文为主；保留开始信号，过滤高频进度提示避免刷屏。
            if (eventType === 'operation_progress') {
                return '';
            }
            return message;
        }
        return '';
    }

    function rememberEventId(eventId) {
        if (!eventId || seenEventIdMap[eventId]) {
            return;
        }
        seenEventIdMap[eventId] = true;
        seenEventIds.push(eventId);
        if (seenEventIds.length > 400) {
            var removedEventId = seenEventIds.shift();
            if (removedEventId) {
                delete seenEventIdMap[removedEventId];
            }
        }
    }

    function isDuplicateSignal(kind, payload) {
        var message = payload && payload.message ? String(payload.message) : '';
        var cursor = payload && payload.last_event_id ? String(payload.last_event_id) : '';
        var fingerprint = kind + '|' + cursor + '|' + message;
        var now = Date.now();
        var lastSeenAt = recentSignalMap[fingerprint] || 0;
        recentSignalMap[fingerprint] = now;
        Object.keys(recentSignalMap).forEach(function (key) {
            if (now - recentSignalMap[key] > 5000) {
                delete recentSignalMap[key];
            }
        });
        return lastSeenAt > 0 && (now - lastSeenAt) < 2000;
    }

    terminal.on('snapshot', function (event) {
        var data = parseSsePayload(event);
        mirrorToPlanTerminal('<?= __('已连接共享事件流') ?>', 'start', data);
        workspaceReconnectDelayMs = 1200;
        if (connectionStartTime) {
            connectionRetryCount = 0;
        }
        if (Array.isArray(data.events)) {
            data.events.forEach(function (entry) {
                var eventId = parseInt(entry && entry.event_id ? entry.event_id : 0, 10) || 0;
                if (eventId > lastEventId) {
                    lastEventId = eventId;
                }
                rememberEventId(eventId);
            });
        } else {
            var snapshotLastEventId = parseInt(data && data.last_event_id ? data.last_event_id : 0, 10) || 0;
            if (snapshotLastEventId > lastEventId) {
                lastEventId = snapshotLastEventId;
                rememberEventId(snapshotLastEventId);
            }
        }

        if (data.active_operation && typeof data.active_operation === 'object') {
            var opStatus = String(data.active_operation.status || '');
            hasActiveOperation = (opStatus === 'queued' || opStatus === 'running');
            if (hasActiveOperation) {
                lastActivityTime = Date.now();
            }
        }
    });

    terminal.on('log', function (event) {
        var entry = parseSsePayload(event);
        if (!entry || typeof entry !== 'object') {
            return;
        }
        var eventType = String(entry.event_type || '');
        var eventId = parseInt(entry.event_id || 0, 10) || 0;
        if (eventId > 0 && seenEventIdMap[eventId]) {
            return;
        }
        if (eventId > lastEventId) {
            lastEventId = eventId;
        }
        rememberEventId(eventId);
        var workspaceMessage = formatWorkspaceLog(entry);
        terminal.log(workspaceMessage, entry.level || 'info');
        var operation = String((entry && entry.payload && entry.payload.operation) || entry.operation || '');
        var isPlanEvent = operation === 'plan'
            || eventType === 'plan_chunk'
            || eventType === 'plan_generated'
            || eventType === 'plan_saved'
            || eventType === 'plan_refined'
            || eventType === 'plan_rebuilt';
        if (!isPlanEvent) {
            return;
        }
        if (eventType === 'plan_chunk') {
            var chunkText = String(entry.message || (entry.payload && entry.payload.message) || '');
            appendPlanTypingChunk(chunkText);
            appendPlanMarkdownChunk(chunkText);
        } else {
            flushPlanTypingBuffer(true);
            var planMessage = formatPlanMirrorLog(entry);
            if (planMessage) {
                mirrorToPlanTerminal(planMessage, entry.level || 'info', entry);
            }
        }

        lastActivityTime = Date.now();

        if (eventType === 'operation_started' || eventType === 'operation_progress') {
            hasActiveOperation = true;
        } else if (eventType === 'operation_completed' || eventType === 'operation_failed') {
            hasActiveOperation = false;
        }
        if ((eventType === 'plan_generated' || eventType === 'plan_saved') && window.__pbWorkspaceApi && typeof window.__pbWorkspaceApi.refreshWorkspaceStateFromServer === 'function') {
            window.__pbWorkspaceApi.refreshWorkspaceStateFromServer();
        }
    });

    terminal.on('done', function (event) {
        var data = parseSsePayload(event);
        if (isDuplicateSignal('done', data)) {
            return;
        }
        if (data && data.last_event_id) {
            lastEventId = parseInt(data.last_event_id, 10) || lastEventId;
        }
        suppressTransportErrorUntil = Date.now() + 1500;
        if (data && data.message) {
            flushPlanTypingBuffer(true);
            terminal.log(data.message, 'done');
            mirrorToPlanTerminal(String(data.message), 'done', data);
        }
    });

    terminal.on('error', function (event) {
        var data = parseSsePayload(event);
        if (!data.message && Date.now() < suppressTransportErrorUntil) {
            return;
        }
        if (isDuplicateSignal('error', data)) {
            return;
        }
        var message = (data && data.message) ? String(data.message) : '';
        var httpCode = parseInt((data && (data.http_code || data.code)) || 0, 10) || 0;
        if (message) {
            flushPlanTypingBuffer(true);
            terminal.log(message, 'error');
            mirrorToPlanTerminal(message, 'error', data);
        }

        var lowerMessage = message.toLowerCase();
        var fatal402 = httpCode === 402
            || lowerMessage.indexOf('http 402') >= 0
            || lowerMessage.indexOf('402') >= 0
            || lowerMessage.indexOf('insufficient balance') >= 0
            || lowerMessage.indexOf('余额不足') >= 0
            || lowerMessage.indexOf('额度不足') >= 0;
        if (fatal402) {
            workspaceStreamFatal = true;
            clearWorkspaceReconnectTimer();
            if (terminal && typeof terminal.stop === 'function') {
                terminal.stop({ suppressTransportError: true });
            }
            terminal.log('<?= __('AI 链接失败（402），已停止重试，请检查账户余额或密钥配置。') ?>', 'error');
            if (window.BackendToast && typeof window.BackendToast.error === 'function') {
                window.BackendToast.error('<?= __('AI 链接失败（402），已停止重试，请检查账户余额或密钥配置。') ?>');
            }
            return;
        }

        if (message.indexOf('会话不存在') >= 0 || message.indexOf('无访问权限') >= 0 || message.indexOf('参数无效') >= 0) {
            clearWorkspaceReconnectTimer();
            if (terminal && typeof terminal.stop === 'function') {
                terminal.stop({ suppressTransportError: true });
            }
            return;
        }

        if (!workspaceStreamPaused && !workspaceStreamFatal) {
            connectionRetryCount += 1;
            scheduleWorkspaceReconnect('terminal_error');
        }
    });

    // 首次进入工作区时延迟建立 SSE，避免页面刚加载就立即占用连接。
    var initialConnectDelayMs = 0;
    window.setTimeout(function () {
        startWorkspaceStream();
    }, initialConnectDelayMs);
})();
</script>
