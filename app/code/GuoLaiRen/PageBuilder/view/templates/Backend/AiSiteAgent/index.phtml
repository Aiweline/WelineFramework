<script>
(function () {
    var createBtn = document.getElementById('pb-ai-site-create');
    var msgBox = document.getElementById('pb-ai-site-msg');
    var createTitleEl = document.getElementById('pb-ai-create-site-title');
    var createBriefEl = document.getElementById('pb-ai-create-brief');
    var directionModeEl = document.getElementById('pb-ai-create-direction-mode');
    var directionSelectEl = document.getElementById('pb-ai-create-design-direction');
    var directionReasonEl = document.getElementById('pb-ai-create-direction-reason');
    var directionMatchUrl = <?= json_encode($designDirectionMatchUrl, JSON_THROW_ON_ERROR) ?>;
    var selectAllBtn = document.getElementById('pb-ai-session-select-all');
    var checkAllEl = document.getElementById('pb-ai-session-check-all');
    var batchDeleteBtn = document.getElementById('pb-ai-session-batch-delete');
    var selectedHint = document.getElementById('pb-ai-session-selected-hint');
    var selectedCountEl = document.getElementById('pb-ai-session-selected-count');
    var selectAllLabel = <?= json_encode(__('全选'), JSON_THROW_ON_ERROR) ?>;
    var clearAllLabel = <?= json_encode(__('取消全选'), JSON_THROW_ON_ERROR) ?>;

    function showErr(msg) {
        if (window.BackendToast && typeof window.BackendToast.error === 'function') {
            window.BackendToast.error(msg);
        } else if (msgBox) {
            msgBox.textContent = msg;
            msgBox.classList.remove('d-none');
        }
    }

    function showSuccess(msg) {
        if (window.BackendToast && typeof window.BackendToast.success === 'function') {
            window.BackendToast.success(msg);
        }
    }

    function showFriendlyGateMessage(msg) {
        var text = String(msg || '').trim();
        if (!text) {
            return;
        }
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(text);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(text);
        }
    }

    function getSessionChecks() {
        return Array.prototype.slice.call(document.querySelectorAll('.pb-ai-session-check'));
    }

    function getSelectedSessionIds() {
        return getSessionChecks().filter(function (item) { return !!item.checked; }).map(function (item) { return String(item.value || ''); });
    }

    function syncBatchButtons() {
        if (!batchDeleteBtn) {
            return;
        }
        var checks = getSessionChecks();
        var selected = checks.filter(function (item) { return !!item.checked; }).length;
        batchDeleteBtn.disabled = selected === 0;
        if (selectedHint) {
            selectedHint.classList.toggle('d-none', selected === 0);
        }
        if (selectedCountEl) {
            selectedCountEl.textContent = String(selected);
        }
        if (selectAllBtn) {
            selectAllBtn.textContent = selected === checks.length && checks.length > 0 ? clearAllLabel : selectAllLabel;
        }
        if (checkAllEl) {
            checkAllEl.checked = checks.length > 0 && selected === checks.length;
            checkAllEl.indeterminate = selected > 0 && selected < checks.length;
        }
    }

    function deleteSessionByPublicId(publicId) {
        return fetch(<?= json_encode($deleteSessionUrl, JSON_THROW_ON_ERROR) ?>, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'public_id=' + encodeURIComponent(publicId),
            credentials: 'same-origin'
        }).then(function (response) { return response.json(); });
    }

    function setDirectionReason(text) {
        if (directionReasonEl) {
            directionReasonEl.textContent = String(text || '');
        }
    }

    function collectCreatePayload() {
        var mode = directionModeEl ? String(directionModeEl.value || 'auto') : 'auto';
        var code = directionSelectEl ? String(directionSelectEl.value || '') : '';
        return {
            site_title: createTitleEl ? String(createTitleEl.value || '').trim() : '',
            brief_description: createBriefEl ? String(createBriefEl.value || '').trim() : '',
            design_direction_mode: mode,
            design_direction_code: mode === 'manual' ? code : ''
        };
    }

    var directionMatchTimer = 0;
    function scheduleDirectionMatch() {
        if (!directionMatchUrl || !directionModeEl || directionModeEl.value !== 'auto') {
            return;
        }
        window.clearTimeout(directionMatchTimer);
        directionMatchTimer = window.setTimeout(function () {
            var payload = collectCreatePayload();
            var body = 'site_title=' + encodeURIComponent(payload.site_title)
                + '&brief_description=' + encodeURIComponent(payload.brief_description)
                + '&adapter_code=' + encodeURIComponent('pagebuilder_plan_generation');
            fetch(directionMatchUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'same-origin',
                body: body
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (!data || !data.success) {
                    return;
                }
                if (data.matched && data.item && directionSelectEl) {
                    directionSelectEl.value = String(data.item.code || '');
                } else if (directionSelectEl) {
                    directionSelectEl.value = '';
                }
                setDirectionReason(data.reason || '');
            }).catch(function () {});
        }, 350);
    }

    [createTitleEl, createBriefEl].forEach(function (el) {
        if (el) {
            el.addEventListener('input', scheduleDirectionMatch);
        }
    });
    if (directionModeEl) {
        directionModeEl.addEventListener('change', function () {
            if (directionModeEl.value === 'none' && directionSelectEl) {
                directionSelectEl.value = '';
                setDirectionReason(<?= json_encode(__('使用通用设计方向，不套用垂直行业模板。'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            if (directionModeEl.value === 'manual') {
                setDirectionReason(<?= json_encode(__('手动选择会覆盖自动推荐。'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            scheduleDirectionMatch();
        });
    }
    if (directionSelectEl) {
        directionSelectEl.addEventListener('change', function () {
            if (directionModeEl && String(directionSelectEl.value || '') !== '' && directionModeEl.value === 'auto') {
                directionModeEl.value = 'manual';
                setDirectionReason(<?= json_encode(__('已切换为手动选择方向。'), JSON_THROW_ON_ERROR) ?>);
            }
        });
    }

    if (createBtn) {
        createBtn.addEventListener('click', function () {
            if (msgBox) {
                msgBox.classList.add('d-none');
                msgBox.textContent = '';
            }
            createBtn.disabled = true;
            var payload = collectCreatePayload();
            var createBody = Object.keys(payload).map(function (key) {
                return encodeURIComponent(key) + '=' + encodeURIComponent(payload[key]);
            }).join('&');
            fetch(<?= json_encode($createUrl, JSON_THROW_ON_ERROR) ?>, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'same-origin',
                body: createBody
            }).then(function (r) { return r.json(); }).then(function (data) {
                if (data && data.success && data.workspace_url) {
                    window.location.href = data.workspace_url;
                    return;
                }
                var msg = (data && data.message) ? data.message : <?= json_encode(__('创建会话失败，请重试'), JSON_THROW_ON_ERROR) ?>;
                showErr(msg);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误，请重试'), JSON_THROW_ON_ERROR) ?>);
            }).finally(function () {
                createBtn.disabled = false;
            });
        });
    }

    if (checkAllEl) {
        checkAllEl.addEventListener('change', function () {
            var checked = !!checkAllEl.checked;
            getSessionChecks().forEach(function (item) { item.checked = checked; });
            syncBatchButtons();
        });
    }

    if (selectAllBtn) {
        selectAllBtn.addEventListener('click', function () {
            var checks = getSessionChecks();
            if (checks.length === 0) {
                return;
            }
            var selected = checks.filter(function (item) { return !!item.checked; }).length;
            var shouldSelectAll = selected !== checks.length;
            checks.forEach(function (item) { item.checked = shouldSelectAll; });
            syncBatchButtons();
        });
    }

    document.addEventListener('change', function (event) {
        var target = event.target;
        if (!(target instanceof HTMLInputElement)) {
            return;
        }
        if (!target.classList.contains('pb-ai-session-check')) {
            return;
        }
        syncBatchButtons();
    });

    document.addEventListener('click', function (event) {
        var target = event.target;
        if (!(target instanceof Element)) {
            return;
        }
        var gatedBtn = target.closest('.pb-ai-gated-action');
        if (!(gatedBtn instanceof HTMLButtonElement)) {
            return;
        }
        event.preventDefault();
        event.stopPropagation();
        showFriendlyGateMessage(gatedBtn.getAttribute('data-gate-message') || <?= json_encode(__('当前操作暂不可用，请先等待站点就绪并进入等待发布状态。'), JSON_THROW_ON_ERROR) ?>);
    });

    if (batchDeleteBtn) {
        batchDeleteBtn.addEventListener('click', function () {
            var selectedIds = getSelectedSessionIds();
            if (selectedIds.length === 0) {
                return;
            }
            BackendConfirm.show(<?= json_encode(__('确定要批量删除已选会话吗？删除后不可恢复。'), JSON_THROW_ON_ERROR) ?>).then(function (confirmed) {
                if (!confirmed) {
                    return;
                }
                batchDeleteBtn.disabled = true;
                Promise.all(selectedIds.map(function (publicId) {
                    return deleteSessionByPublicId(publicId).catch(function () {
                        return {success: false};
                    });
                })).then(function (results) {
                    var successCount = results.filter(function (item) { return item && item.success; }).length;
                    var failCount = selectedIds.length - successCount;
                    if (successCount > 0) {
                        showSuccess(<?= json_encode(__('批量删除已完成。'), JSON_THROW_ON_ERROR) ?> + ' ' + successCount);
                    }
                    if (failCount > 0) {
                        showErr(<?= json_encode(__('部分会话删除失败，请重试。'), JSON_THROW_ON_ERROR) ?> + ' ' + failCount);
                    }
                    window.location.reload();
                }).catch(function () {
                    showErr(<?= json_encode(__('批量删除失败，请重试'), JSON_THROW_ON_ERROR) ?>);
                }).finally(function () {
                    batchDeleteBtn.disabled = false;
                });
            });
        });
    }

    syncBatchButtons();
})();
</script>
<js:part name="w-delete"/>
