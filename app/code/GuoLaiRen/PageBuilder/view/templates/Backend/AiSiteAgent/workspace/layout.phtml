                            <?php
                            $payloadPreview = '';
                            if ($payload !== []) {
                                try {
                                    $payloadPreview = (string)\json_encode($payload, \JSON_UNESCAPED_UNICODE | \JSON_UNESCAPED_SLASHES | \JSON_THROW_ON_ERROR);
                                } catch (\JsonException) {
                                    $payloadPreview = '{}';
                                }
                                if (\function_exists('mb_strimwidth')) {
                                    $payloadPreview = (string)\mb_strimwidth($payloadPreview, 0, 1200, '...');
                                } elseif (\strlen($payloadPreview) > 1200) {
                                    $payloadPreview = \substr($payloadPreview, 0, 1200) . '...';
                                }
                            }
                            ?>
