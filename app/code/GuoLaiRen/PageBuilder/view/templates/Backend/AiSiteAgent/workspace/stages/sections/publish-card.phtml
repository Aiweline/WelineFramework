<?php
$pbAiLatestBuildFailed = !empty($state['latest_build_failed'] ?? false) || !empty($state['publish_blocked_by_latest_ai_failure'] ?? false);
$pbAiRetryableFailures = $state['retryable_ai_failures'] ?? [];
$pbAiRetryableCount = (int)($state['retryable_ai_failure_count'] ?? 0);
$pbAiRetryablePending = $pbAiRetryableCount > 0 || (\is_array($pbAiRetryableFailures) && !empty($pbAiRetryableFailures));
$pbAiActiveOperationBlocking = \in_array($activeOperationStatus, ['pending', 'queued', 'running', 'processing', 'in_progress'], true);
$pbAiCanPublishContract = !empty($state['can_publish']);
$pbAiPublishDisabled = $pbAiLatestBuildFailed || $pbAiRetryablePending || !$pbAiCanPublishContract || $pbAiActiveOperationBlocking;
$pbAiPublishBlockingMessage = '';
if ($pbAiRetryablePending) {
    $pbAiPublishBlockingMessage = (string)__('存在 retry_allowed 或 partial_retry_required 失败项，发布前必须先完成重试。');
} elseif ($pbAiActiveOperationBlocking) {
    $pbAiPublishBlockingMessage = (string)__('AI 队列仍处于 pending、queued 或 running 状态，发布按钮已锁定。');
} elseif ($pbAiLatestBuildFailed) {
    $pbAiLatestBuildFailure = $state['latest_build_failure'] ?? [];
    $pbAiPublishBlockingMessage = (string)($state['publish_blocked_reason'] ?? ($pbAiLatestBuildFailure['message'] ?? ''));
    if ($pbAiPublishBlockingMessage === '') {
        $pbAiPublishBlockingMessage = (string)__('最新 AI 生成失败或仍在运行，禁止发布旧站点；请先重新生成并等待成功完成。');
    }
} elseif (!$pbAiCanPublishContract) {
    $pbAiPublishBlockingMessage = (string)__('当前工作台尚未满足 can_publish 合同，发布按钮保持锁定。');
} else {
    $pbAiPublishBlockingMessage = (string)__('can_publish 已满足，可以先运行发布检查，再确认发布。');
}
$pbAiPublishBlockingClass = ($pbAiLatestBuildFailed || $pbAiRetryablePending) ? 'alert-danger' : 'alert-warning';
?>
<div class="card border-0 shadow-sm" data-stage-panel="publish">
    <div class="card-header bg-transparent border-0 pt-4 pb-0">
        <h5 class="card-title mb-1"><?= htmlspecialchars((string)__('确认发布'), ENT_QUOTES, 'UTF-8') ?></h5>
        <p class="text-muted mb-0"><?= htmlspecialchars((string)__('确认后会发布到同一个草稿站点，不会额外创建第二个网站实体。'), ENT_QUOTES, 'UTF-8') ?></p>
    </div>
    <div class="card-body p-4">
        <div
            class="alert <?= htmlspecialchars($pbAiPublishBlockingClass, ENT_QUOTES, 'UTF-8') ?> small<?= $pbAiPublishDisabled ? '' : ' d-none' ?>"
            id="pb-ai-publish-blocking-alert"
            role="status">
            <?= htmlspecialchars($pbAiPublishBlockingMessage, ENT_QUOTES, 'UTF-8') ?>
        </div>
        <button type="button" class="btn btn-primary mb-3" id="pb-ai-run-publish-check"><?= htmlspecialchars((string)__('运行发布检查'), ENT_QUOTES, 'UTF-8') ?></button>
        <button
            type="button"
            class="btn btn-success mb-3 ms-2"
            id="pb-ai-start-publish"
            data-pb-contract-can-publish="<?= $pbAiCanPublishContract ? '1' : '0' ?>"
            data-pb-contract-blocked-by-failure="<?= $pbAiLatestBuildFailed ? '1' : '0' ?>"
            data-pb-contract-blocked-by-running="<?= $pbAiActiveOperationBlocking ? '1' : '0' ?>"
            data-pb-contract-blocked-by-retryable="<?= $pbAiRetryablePending ? '1' : '0' ?>"<?= !$pbAiPublishDisabled ? '' : ' disabled aria-disabled="true" title="' . htmlspecialchars($pbAiPublishBlockingMessage, ENT_QUOTES, 'UTF-8') . '"' ?>>
            <?= htmlspecialchars((string)__('立即发布'), ENT_QUOTES, 'UTF-8') ?>
        </button>
        <button
            type="button"
            class="btn btn-outline-warning mb-3 ms-2<?= $pbAiRetryablePending ? '' : ' d-none' ?>"
            id="pb-ai-retry-build-failures"
            data-retryable-ai-label="<?= htmlspecialchars((string)__('继续重试失败项'), ENT_QUOTES, 'UTF-8') ?>"
            data-retryable-ai-operation="build">
            <span data-retryable-ai-label-text><?= htmlspecialchars((string)__('继续重试失败项'), ENT_QUOTES, 'UTF-8') ?></span>
            <span class="badge text-bg-light ms-1" data-retryable-ai-count><?= (int)$pbAiRetryableCount ?></span>
        </button>
        <pre class="bg-light rounded p-3 small mb-0 d-none" id="pb-ai-publish-check-output" style="max-height:320px;overflow:auto;"></pre>
    </div>
</div>
