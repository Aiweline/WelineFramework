            + renderQueueSummaryItem('output_tokens', queueMessages.outputTokensLabel, formatTokenCount(tokenUsage.output_tokens), false)
            + renderQueueSummaryItem('total_tokens', queueMessages.totalTokensLabel, formatTokenCount(tokenUsage.total_tokens), false)
            + '</div>';
    }

    function renderQueueInfoPanel(operation, info) {
        var normalized = normalizeOperation(operation);
        var panel = panelMap[normalized];
        if (!panel) {
            return;
        }
        var metaEl = document.getElementById(panel.meta);
        var procEl = document.getElementById(panel.process);
        var resEl = document.getElementById(panel.result);
        var statusEl = document.querySelector(panel.status);
        if (!metaEl || !procEl || !resEl) {
            return;
        }
        var progressRows = derivePageBlockProgressRows(info);
        if (!info || typeof info !== 'object' || (normalizeQueueId(info.queue_id) <= 0 && progressRows.length === 0)) {
            metaEl.innerHTML = '<div class="alert alert-light border mb-0 small">' + escapeHtml(panel.empty) + '</div>';
            procEl.textContent = '';
            resEl.textContent = '';
            if (statusEl) {
                statusEl.textContent = '';
            }
            return;
        }
        var stateJson = '';
        try {
            var debugInfo = info && typeof info === 'object' ? Object.assign({}, info) : info;
            if (debugInfo && typeof debugInfo === 'object') {
                delete debugInfo.plan_json_block_progress;
                if (Array.isArray(debugInfo.page_block_progress)) {
                    debugInfo.page_block_progress = compactPageBlockProgressForMemory(debugInfo.page_block_progress).map(function (row) {
                        var copy = Object.assign({}, row);
                        delete copy.block_rows;
                        return copy;
                    });
                }
            }
            stateJson = JSON.stringify(debugInfo, null, 2);
        } catch (e) {
            stateJson = String(info);
        }
        var qid = normalizeQueueId(info.queue_id != null ? info.queue_id : 0);
        var idRow = '<div class="d-flex flex-wrap align-items-center gap-2 mb-2">'
            + '<span class="text-muted small mb-0">' + escapeHtml(queueMessages.queueIdLabel) + '</span>'
            + '<code class="small mb-0">' + escapeHtml(qid > 0 ? String(qid) : queueMessages.unknown) + '</code>'
            + '</div>';
        metaEl.innerHTML = idRow
            + renderQueueInfoSummary(normalized, info)
            + renderQueuePageBlockProgress(info)
            + '<pre class="small mb-0 border rounded p-2 bg-light text-break" style="white-space:pre-wrap;max-height:min(24vh,12rem);overflow:auto;">'
            + escapeHtml(stateJson)
            + '</pre>';
        procEl.textContent = String(info.process || '').trim() || queueMessages.unknown;
        renderLiveLogSummary(normalized, String(info.terminal_summary || info.message || '').trim());
        if (statusEl) {
            statusEl.textContent = String(info.queue_status || '').trim();
        }
    }

    function resolveQueuePanelStatus(info, payload, eventKind) {
        var parsedPayload = payload && typeof payload === 'object' ? payload : {};
        var status = String(
            parsedPayload.queue_status
            || (info && info.queue_status)
            || ''
        ).toLowerCase().trim();
        if (status) {
            return status;
        }
        var kind = String(eventKind || '').toLowerCase().trim();
        if (kind === 'error' || kind === 'failed') {
            return 'error';
        }
        if (kind === 'done' || kind === 'complete' || kind === 'completed') {
            return 'done';
        }
        if (kind === 'progress' || kind === 'plan_json_progress' || kind === 'total') {
            return 'running';
        }
        return '';
    }

    function getLastWorkspaceState() {
        try {
            return window.__pbLastWorkspaceState && typeof window.__pbLastWorkspaceState === 'object'
                ? window.__pbLastWorkspaceState
                : {};
        } catch (e) {
            return {};
        }
    }

    function rememberQueueInfo(operation, info) {
        var normalized = normalizeOperation(operation);
        var panel = panelMap[normalized];
        if (!panel) {
            return getLastWorkspaceState();
        }
        var state = sanitizeWorkspaceStateForMemory(getLastWorkspaceState());
        state.queue_status = state.queue_status && typeof state.queue_status === 'object' && !Array.isArray(state.queue_status)
            ? Object.assign({}, state.queue_status)
            : {};
        state.queue_status[panel.operation] = sanitizeQueueInfoForMemory(info);
        var remembered = sanitizeWorkspaceStateForMemory(state);
        try {
            window.__pbLastWorkspaceState = remembered;
        } catch (e) {
            // ignore
        }
        return remembered;
    }

    function sanitizeQueueInfoForMemory(info) {
        var safe = info && typeof info === 'object' ? Object.assign({}, info) : {};
        ['result_log', 'queue_result_delta', 'chunk', 'content', 'events', 'top_logs'].forEach(function (key) {
            delete safe[key];
        });
        if (safe.plan_json_task_summary && typeof safe.plan_json_task_summary === 'object') {
            safe.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(safe.plan_json_task_summary);
        }
        if (safe.task_summary && typeof safe.task_summary === 'object') {
            safe.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(safe.task_summary);
            delete safe.task_summary;
        }
        if (safe.task_progress && typeof safe.task_progress === 'object') {
            safe.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(safe.task_progress);
            delete safe.task_progress;
        }
        if (Array.isArray(safe.page_block_progress)) {
            safe.page_block_progress = compactPageBlockProgressForMemory(safe.page_block_progress);
        }
        if (Array.isArray(safe.plan_json_block_progress)) {
            safe.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(safe.plan_json_block_progress);
        }
        return safe;
    }

    function resolveCanonicalQueueInfo(workspaceState, operation) {
        var state = workspaceState && typeof workspaceState === 'object' ? workspaceState : {};
        var op = String(operation || '').trim().toLowerCase();
        function normalize(candidate) {
            if (typeof candidate === 'string' || typeof candidate === 'number') {
                var scalarStatus = String(candidate || '').trim();
                return scalarStatus !== '' ? { operation: op, queue_status: scalarStatus } : {};
            }
            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) {
                return {};
            }
            if (op && Object.prototype.hasOwnProperty.call(candidate, op)) {
                return normalize(candidate[op]);
            }
            var directStatus = String(candidate.queue_status || '').trim();
            if (directStatus === '' && !candidate.operation && !candidate.job_type && !candidate.job_key && !candidate.biz_key) {
                return {};
            }
            return sanitizeQueueInfoForMemory(candidate);
        }
        var active = state.active_operation && typeof state.active_operation === 'object' ? state.active_operation : {};
        var activeOperations = state.active_operations && typeof state.active_operations === 'object' ? state.active_operations : {};
        var scopedActive = op && activeOperations[op] && typeof activeOperations[op] === 'object' ? activeOperations[op] : {};
        var candidates = [state.queue_status, scopedActive.queue_status, active.queue_status, scopedActive, active];
        for (var i = 0; i < candidates.length; i += 1) {
            var info = normalize(candidates[i]);
            if (Object.keys(info).length > 0) {
                return info;
            }
        }
        return {};
    }

    function sanitizeWorkspaceStateForMemory(workspaceState) {
        var state = workspaceState && typeof workspaceState === 'object' ? Object.assign({}, workspaceState) : {};
        ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
            delete state[key];
        });
        if (state.scope && typeof state.scope === 'object') {
            state.scope = Object.assign({}, state.scope);
            ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
                delete state.scope[key];
            });
        }
        if (state.queue_status && typeof state.queue_status === 'object' && !Array.isArray(state.queue_status)) {
            state.queue_status = Object.assign({}, state.queue_status);
            ['plan', 'build', 'publish'].forEach(function (key) {
                if (state.queue_status[key] && typeof state.queue_status[key] === 'object') {
                    state.queue_status[key] = sanitizeQueueInfoForMemory(state.queue_status[key]);
                }
            });
        }
        if (Array.isArray(state.plan_json_block_progress)) {
            state.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(state.plan_json_block_progress);
        }
        return state;
    }

    function getLiveLogElement(operation) {
        var normalized = normalizeOperation(operation);
        var panel = panelMap[normalized];
        return panel ? document.getElementById(panel.result) : null;
    }

    function renderLiveLogSummary(operation, summary) {
        var resEl = getLiveLogElement(operation);
        if (!resEl) {
            return;
        }
        var text = String(summary || '').trim();
        if (text !== '') {
            resEl.dataset.pbLiveLog = '0';
            resEl.textContent = text;
            resEl.scrollTop = 0;
            return;
        }
        if (resEl.dataset.pbLiveLog === '1' && resEl.childNodes.length > 0) {
            return;
        }
        resEl.dataset.pbLiveLog = '0';
        resEl.textContent = queueMessages.unknown;
    }

    function appendLiveQueueLog(operation, delta) {
        var resEl = getLiveLogElement(operation);
        var text = String(delta || '');
        if (!resEl || text === '') {
            return;
        }
        var normalized = normalizeOperation(operation);
        var panel = panelMap[normalized];
        var panelEl = panel ? document.getElementById(panel.panel) : null;
        if (panelEl && !panelEl.open) {
            return;
        }
        if (resEl.dataset.pbLiveLog !== '1') {
            resEl.textContent = '';
            resEl.dataset.pbLiveLog = '1';
        }
        text.split(/\r\n|\n|\r/).forEach(function (line) {
            var item = String(line || '').trim();
            if (item === '') {
                return;
            }
            var node = document.createElement('div');
            node.textContent = item;
            resEl.appendChild(node);
            while (resEl.childNodes.length > LIVE_LOG_MAX_LINES) {
                resEl.removeChild(resEl.firstChild);
            }
        });
        resEl.scrollTop = resEl.scrollHeight;
    }

    function disposeLiveStream(operation, summary) {
        var resEl = getLiveLogElement(operation);
        if (!resEl) {
            return;
        }
        resEl.textContent = '';
        resEl.dataset.pbLiveLog = '0';
        renderLiveLogSummary(operation, summary || '');
    }

    function isTerminalQueueStatus(status) {
        return ['done', 'complete', 'completed', 'success', 'error', 'failed', 'failure', 'stop', 'stopped', 'cancelled', 'canceled'].indexOf(String(status || '').toLowerCase()) >= 0;
    }

    function mergeQueueInfoFromSsePayload(operation, payload, eventKind) {
        var normalized = normalizeOperation(operation || (payload && payload.operation));
        var panel = panelMap[normalized];
        if (!panel || !payload || typeof payload !== 'object') {
            return null;
        }
        var stateQueueInfo = payload.state && typeof payload.state === 'object'
            ? resolveCanonicalQueueInfo(payload.state, panel.operation)
            : {};
        if (Object.keys(stateQueueInfo).length > 0) {
            if (payload.state.plan_json_task_summary && typeof payload.state.plan_json_task_summary === 'object') {
                stateQueueInfo.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.state.plan_json_task_summary);
            }
            if (Array.isArray(payload.state.page_block_progress)) {
                stateQueueInfo.page_block_progress = compactPageBlockProgressForMemory(payload.state.page_block_progress);
            }
            if (Array.isArray(payload.state.plan_json_block_progress)) {
                stateQueueInfo.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(payload.state.plan_json_block_progress);
            }
            if (payload.task_summary && typeof payload.task_summary === 'object') {
                stateQueueInfo.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.task_summary);
            } else if (payload.task_progress && typeof payload.task_progress === 'object') {
                stateQueueInfo.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.task_progress);
            } else if (payload.plan_json_task_summary && typeof payload.plan_json_task_summary === 'object') {
                stateQueueInfo.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.plan_json_task_summary);
            }
            if (Array.isArray(payload.page_block_progress)) {
                stateQueueInfo.page_block_progress = compactPageBlockProgressForMemory(payload.page_block_progress);
            }
            if (Array.isArray(payload.plan_json_block_progress)) {
                stateQueueInfo.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(payload.plan_json_block_progress);
            }
            return stateQueueInfo;
        }
        if (payload.queue_info && typeof payload.queue_info === 'object') {
            return sanitizeQueueInfoForMemory(payload.queue_info);
        }
        var hasQueueSignal = !!(
            (payload.queue_state && typeof payload.queue_state === 'object')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_id')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_status')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_process')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_result_log')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_result_delta')
            || Object.prototype.hasOwnProperty.call(payload, 'job_key')
            || Object.prototype.hasOwnProperty.call(payload, 'job_type')
            || Object.prototype.hasOwnProperty.call(payload, 'token')
            || Object.prototype.hasOwnProperty.call(payload, 'execution_token')
            || Object.prototype.hasOwnProperty.call(payload, 'token_usage')
            || Object.prototype.hasOwnProperty.call(payload, 'task_summary')
            || Object.prototype.hasOwnProperty.call(payload, 'task_progress')
            || Object.prototype.hasOwnProperty.call(payload, 'plan_json_task_summary')
            || Object.prototype.hasOwnProperty.call(payload, 'page_block_progress')
            || Object.prototype.hasOwnProperty.call(payload, 'plan_json_block_progress')
            || Object.prototype.hasOwnProperty.call(payload, 'progress_kind')
            || Object.prototype.hasOwnProperty.call(payload, 'active_operation_status')
        );
        if (!hasQueueSignal) {
            return null;
        }
        var state = getLastWorkspaceState();
        var existing = resolveCanonicalQueueInfo(state, panel.operation);
        var queueState = Object.assign({}, existing);
        if (payload.queue_state && typeof payload.queue_state === 'object') {
            queueState = Object.assign(queueState, payload.queue_state);
        }
        var payloadQueueId = normalizeQueueId(payload.queue_id);
        if (payloadQueueId > 0) {
            queueState.queue_id = payloadQueueId;
        }
        ['queue_status', 'job_key', 'job_type', 'token', 'execution_token', 'input_tokens', 'output_tokens', 'total_tokens'].forEach(function (key) {
            if (Object.prototype.hasOwnProperty.call(payload, key)) {
                if (key === 'queue_status') {
                    queueState.queue_status = payload[key];
                    return;
                }
                queueState[key] = payload[key];
            }
        });
        if (payload.token_usage && typeof payload.token_usage === 'object') {
            queueState.token_usage = Object.assign({}, queueState.token_usage && typeof queueState.token_usage === 'object' ? queueState.token_usage : {}, payload.token_usage);
        }
        if (payload.task_summary && typeof payload.task_summary === 'object') {
            queueState.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.task_summary);
        } else if (payload.task_progress && typeof payload.task_progress === 'object') {
            queueState.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.task_progress);
        } else if (payload.plan_json_task_summary && typeof payload.plan_json_task_summary === 'object') {
            queueState.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.plan_json_task_summary);
        } else if (payload.state && payload.state.plan_json_task_summary && typeof payload.state.plan_json_task_summary === 'object') {
            queueState.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(payload.state.plan_json_task_summary);
        }
        if (Array.isArray(payload.page_block_progress)) {
            queueState.page_block_progress = compactPageBlockProgressForMemory(payload.page_block_progress);
        } else if (payload.state && Array.isArray(payload.state.page_block_progress)) {
            queueState.page_block_progress = compactPageBlockProgressForMemory(payload.state.page_block_progress);
        }
        if (Array.isArray(payload.plan_json_block_progress)) {
            queueState.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(payload.plan_json_block_progress);
        } else if (payload.state && Array.isArray(payload.state.plan_json_block_progress)) {
            queueState.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(payload.state.plan_json_block_progress);
        }
        var process = String(existing.process || '');
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_process')) {
            process = String(payload.queue_process || '');
        } else if (String(eventKind || '') === 'progress' && payloadQueueId > 0 && payload.message) {
            process = String(payload.message || '');
        }
        var delta = '';
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_result_delta')) {
            delta = String(payload.queue_result_delta || '');
        } else if (String(eventKind || '') === 'chunk' && payloadQueueId > 0) {
            delta = String(payload.chunk || payload.content || payload.message || '');
        }
        appendLiveQueueLog(normalized, delta);
        var terminalSummary = '';
        if (Object.prototype.hasOwnProperty.call(payload, 'terminal_summary')) {
            terminalSummary = String(payload.terminal_summary || '');
        } else if (isTerminalQueueStatus(resolveQueuePanelStatus(queueState, payload, eventKind))) {
            terminalSummary = String(payload.message || process || '').trim();
        }
        return {
            queue_id: normalizeQueueId(existing.queue_id || queueState.queue_id || payloadQueueId),
            name: String(queueState.name || ''),
            module: String(queueState.module || ''),
            biz_key: String(queueState.biz_key || ''),
            queue_status: String(queueState.queue_status || ''),
            semantic_status: String(queueState.semantic_status || ''),
            pid: normalizeQueueId(queueState.pid),
            type_id: normalizeQueueId(queueState.type_id),
            finished: Number(queueState.finished || 0),
            start_at: String(queueState.start_at || ''),
            end_at: String(queueState.end_at || ''),
            job_key: String(queueState.job_key || ''),
            job_type: String(queueState.job_type || ''),
            token: String(queueState.token || queueState.execution_token || ''),
            token_usage: queueState.token_usage && typeof queueState.token_usage === 'object' ? queueState.token_usage : {},
            input_tokens: queueState.input_tokens,
            output_tokens: queueState.output_tokens,
            total_tokens: queueState.total_tokens,
            plan_json_task_summary: queueState.plan_json_task_summary && typeof queueState.plan_json_task_summary === 'object' ? compactPlanJsonTaskSummaryForMemory(queueState.plan_json_task_summary) : {},
            page_block_progress: Array.isArray(queueState.page_block_progress) ? compactPageBlockProgressForMemory(queueState.page_block_progress) : [],
            plan_json_block_progress: Array.isArray(queueState.plan_json_block_progress) ? compactPlanJsonBlockProgressForMemory(queueState.plan_json_block_progress) : [],
            process: process,
            terminal_summary: terminalSummary
        };
    }

    function syncPanelOpenState(workspaceState) {
        var active = workspaceState && workspaceState.active_operation && typeof workspaceState.active_operation === 'object'
            ? workspaceState.active_operation
            : {};
        var op = normalizeOperation(active.operation);
        var activeStatus = String(active.queue_status || '').toLowerCase();
        var shouldOpen = activeStatus === 'queued' || activeStatus === 'pending' || activeStatus === 'running' || activeStatus === 'processing';
        Object.keys(panelMap).forEach(function (key) {
            var panelEl = document.getElementById(panelMap[key].panel);
            if (panelEl && key === op && shouldOpen && panelEl.dataset.pbUserClosed !== '1') {
                panelEl.open = true;
            } else if (panelEl && key === op && !shouldOpen) {
                panelEl.dataset.pbProgrammaticToggle = '1';
                panelEl.open = false;
                delete panelEl.dataset.pbProgrammaticToggle;
            }
        });
    }

    function bindPanelManualToggle() {
        Object.keys(panelMap).forEach(function (key) {
            var panelEl = document.getElementById(panelMap[key].panel);
            if (!panelEl || panelEl.dataset.pbManualToggleBound === '1') {
                return;
            }
            panelEl.dataset.pbManualToggleBound = '1';
            panelEl.addEventListener('toggle', function () {
                if (panelEl.dataset.pbProgrammaticToggle === '1') {
                    return;
                }
            if (panelEl.open) {
                delete panelEl.dataset.pbUserClosed;
            } else {
                panelEl.dataset.pbUserClosed = '1';
                disposeLiveStream(key, '');
            }
            });
        });
    }

    function syncFromSsePayload(operation, payload, eventKind) {
        var normalized = normalizeOperation(operation || (payload && payload.operation));
        if (!normalized) {
            return;
        }
        var info = mergeQueueInfoFromSsePayload(normalized, payload || {}, eventKind);
        if (!info || typeof info !== 'object') {
            return;
        }
        renderQueueInfoPanel(normalized, info);
        rememberQueueInfo(normalized, info);
        var queuePanelStatus = resolveQueuePanelStatus(info, payload, eventKind);
        syncPanelOpenState(Object.assign({}, getLastWorkspaceState(), {
            active_operation: { operation: normalized, status: queuePanelStatus }
        }));
        if (isTerminalQueueStatus(queuePanelStatus)) {
            disposeLiveStream(normalized, info.terminal_summary || payload.terminal_summary || payload.message || '');
        }
    }

    function syncFromWorkspaceState(workspaceState) {
        if (!workspaceState || typeof workspaceState !== 'object') {
            return;
        }
        var safeState = sanitizeWorkspaceStateForMemory(workspaceState);
        try {
            window.__pbLastWorkspaceState = safeState;
        } catch (e) {
            // ignore
        }
        var buildInfo = resolveCanonicalQueueInfo(safeState, 'build');
        var planJsonRows = derivePlanJsonBlockRowsFromPages(safeState.plan_json);
        if (planJsonRows.length > 0) {
            buildInfo.plan_json_block_progress = planJsonRows;
        }
        if (Object.keys(buildInfo).length > 0) {
            if (safeState.plan_json_task_summary && typeof safeState.plan_json_task_summary === 'object') {
                buildInfo.plan_json_task_summary = compactPlanJsonTaskSummaryForMemory(safeState.plan_json_task_summary);
            }
            if (Array.isArray(safeState.page_block_progress)) {
                buildInfo.page_block_progress = compactPageBlockProgressForMemory(safeState.page_block_progress);
            }
            if (Array.isArray(safeState.plan_json_block_progress)) {
                buildInfo.plan_json_block_progress = compactPlanJsonBlockProgressForMemory(safeState.plan_json_block_progress);
            }
        }
        renderQueueInfoPanel('build', buildInfo);
        syncPanelOpenState(safeState);
    }

    function bindBuildQueueInfoRefresh() {
        var btn = document.getElementById('pb-ai-build-queue-info-refresh');
        if (!btn || btn.dataset.pbBound === '1') {
            return;
        }
        btn.dataset.pbBound = '1';
        btn.addEventListener('click', function () {
            btn.disabled = true;
            var refreshPromise = (window.__pbWorkspaceApi && typeof window.__pbWorkspaceApi.refreshWorkspaceStateFromCache === 'function')
                ? window.__pbWorkspaceApi.refreshWorkspaceStateFromCache()
                : Promise.reject(new Error('workspace cache refresh unavailable'));
            refreshPromise.then(function (data) {
                btn.disabled = false;
                if (data && data.success && data.data) {
                    if (typeof window.hydrateWorkspaceFromState === 'function') {
                        window.hydrateWorkspaceFromState(data.data);
                    } else {
                        syncFromWorkspaceState(data.data);
                    }
                    toast('success', queueMessages.refreshed);
                    return;
                }
                toast('error', (data && data.message) ? String(data.message) : queueMessages.refreshFailed);
            }).catch(function () {
                btn.disabled = false;
                toast('error', queueMessages.refreshFailed);
            });
        });
    }

    window.__pbBuildQueueProgress = {
        syncFromWorkspaceState: syncFromWorkspaceState,
        syncFromSsePayload: syncFromSsePayload,
        renderQueueInfoPanel: renderQueueInfoPanel,
        disposeLiveStream: disposeLiveStream,
        bindBuildQueueInfoRefresh: bindBuildQueueInfoRefresh
    };
    bindPanelManualToggle();
    bindBuildQueueInfoRefresh();
    syncFromWorkspaceState(getLastWorkspaceState());
})();
</script>
