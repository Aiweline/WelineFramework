    function normalizeTaskStatus(status) {
        var normalized = String(status || '').toLowerCase().trim();
        if (normalized === '1') {
            return 'done';
        }
        if (normalized === '2') {
            return 'running';
        }
        if (normalized === '0') {
            return 'pending';
        }
        if (normalized === '-1') {
            return 'failed';
        }
        if (normalized === 'todo' || normalized === 'pending') {
            return 'pending';
        }
        if (normalized === 'processing' || normalized === 'in_progress') {
            return 'running';
        }
        if (normalized === 'complete' || normalized === 'completed' || normalized === 'success') {
            return 'done';
        }
        if (normalized === 'error' || normalized === 'failure') {
            return 'failed';
        }
        if (normalized === 'canceled') {
            return 'cancelled';
        }
        return ['done', 'running', 'queued', 'failed', 'cancelled', 'stale'].indexOf(normalized) >= 0
            ? normalized
            : 'pending';
    }

    function compactPlanJsonTaskSummaryForMemory(summary) {
        if (!summary || typeof summary !== 'object') {
            return {};
        }
        var safe = {};
        ['total', 'done', 'pending', 'todo', 'queued', 'running', 'failed', 'cancelled', 'stale'].forEach(function (key) {
            safe[key] = normalizeCount(summary[key]);
        });
        var groups = summary.groups && typeof summary.groups === 'object' ? summary.groups : {};
        safe.groups = {};
        Object.keys(groups).slice(0, 80).forEach(function (groupKey) {
            var group = groups[groupKey];
            if (!group || typeof group !== 'object') {
                return;
            }
            var safeGroup = {};
            ['total', 'done', 'pending', 'todo', 'queued', 'running', 'failed', 'cancelled', 'stale'].forEach(function (key) {
                safeGroup[key] = normalizeCount(group[key]);
            });
            safeGroup.page_type = String(group.page_type || groupKey || '').trim();
            var tasks = Array.isArray(group.tasks) ? group.tasks : [];
            safeGroup.tasks = tasks.slice(0, 80).map(function (task) {
                task = task && typeof task === 'object' ? task : {};
                return {
                    task_key: String(task.task_key || ''),
                    label: String(task.label || task.task_key || ''),
                    section_code: String(task.section_code || ''),
                    component: String(task.component || ''),
                    task_type: String(task.task_type || ''),
                    page_type: String(task.page_type || safeGroup.page_type || ''),
                    status: normalizeTaskStatus(task.status),
                    attempt_no: normalizeCount(task.attempt_no),
                    message: String(task.message || '').slice(0, 300),
                    updated_at: String(task.updated_at || ''),
                    finished_at: String(task.finished_at || '')
                };
            });
            safe.groups[groupKey] = safeGroup;
        });
        return safe;
    }

    function compactPageBlockProgressForMemory(progress) {
        if (!Array.isArray(progress)) {
            return [];
        }
        return progress.slice(0, PAGE_BLOCK_PROGRESS_MAX_ROWS).map(function (row) {
            row = row && typeof row === 'object' ? row : {};
            return {
                page_type: String(row.page_type || ''),
                done: normalizeCount(row.done || row.completed_blocks || row.block_done_count),
                total: normalizeCount(row.total || row.expected_blocks || row.executable_blocks || row.block_total),
                running: normalizeCount(row.running),
                queued: normalizeCount(row.queued),
                pending: normalizeCount(row.pending || row.todo || row.block_pending_count),
                failed: normalizeCount(row.failed || row.block_failed_count),
                cancelled: normalizeCount(row.cancelled || row.canceled),
                stale: normalizeCount(row.stale),
                complete: !!row.complete,
                block_rows: compactPlanJsonBlockProgressForMemory(row.block_rows || [])
            };
        }).filter(function (row) {
            return row.page_type !== '';
        });
    }

    function compactPlanJsonBlockProgressForMemory(progress) {
        if (!Array.isArray(progress)) {
            return [];
        }
        return progress.slice(0, PLAN_JSON_BLOCK_PROGRESS_MAX_ROWS).map(function (row) {
            row = row && typeof row === 'object' ? row : {};
            var pageType = String(row.page_type || row.pageType || '').trim();
            var sectionKey = String(row.section_key || row.block_key || row.section_code || '').trim();
            var blockId = String(row.block_id || row.id || '').trim();
            var label = String(row.label || row.title || sectionKey || blockId || '').trim();
            return {
                page_type: pageType,
                block_id: blockId.slice(0, 96),
                section_key: sectionKey.slice(0, 96),
                label: label.slice(0, 120),
                status: normalizeTaskStatus(row.status || row.state || row.execution_status),
                message: String(row.message || row.error_message || row.failure_reason || '').slice(0, PLAN_JSON_BLOCK_MESSAGE_MAX_CHARS),
                updated_at: String(row.updated_at || row.finished_at || '').slice(0, 96)
            };
        }).filter(function (row) {
            return row.page_type !== '' || row.block_id !== '' || row.section_key !== '' || row.label !== '';
        });
    }

    function countPlanJsonBlockStatuses(blockRows) {
        var counts = {
            total: 0,
            done: 0,
            running: 0,
            queued: 0,
            pending: 0,
            failed: 0,
            cancelled: 0,
            stale: 0
        };
        (Array.isArray(blockRows) ? blockRows : []).forEach(function (row) {
            counts.total += 1;
            var status = normalizeTaskStatus(row && row.status);
            if (Object.prototype.hasOwnProperty.call(counts, status)) {
                counts[status] += 1;
            } else {
                counts.pending += 1;
            }
        });
        counts.complete = counts.total > 0 && counts.done >= counts.total;
        return counts;
    }

    function groupPlanJsonBlockProgressByPage(blockRows) {
        var buckets = {};
        var order = [];
        (Array.isArray(blockRows) ? blockRows : []).forEach(function (row) {
            row = row && typeof row === 'object' ? row : {};
            var pageType = String(row.page_type || 'unknown').trim() || 'unknown';
            if (!buckets[pageType]) {
                buckets[pageType] = [];
                order.push(pageType);
            }
            buckets[pageType].push(row);
        });
        return order.map(function (pageType) {
            var rows = buckets[pageType] || [];
            var counts = countPlanJsonBlockStatuses(rows);
            counts.page_type = pageType;
            counts.block_rows = rows;
            return counts;
        });
    }

    function derivePlanJsonBlockRowsFromPages(planJson) {
        var pages = planJson && typeof planJson === 'object' && planJson.pages && typeof planJson.pages === 'object'
            ? planJson.pages
            : {};
        var pageMeta = {
            page_key: true, page_type: true, type: true, status: true, message: true, error: true, error_message: true,
            updated_at: true, started_at: true, finished_at: true, attempt_no: true, result_ref: true,
            title: true, label: true, page_label: true, page_title: true, page_goal: true, page_status: true,
            content_locale: true, ordered_block_keys: true,
            seo: true, route: true, slug: true, path: true, layout: true, sections: true, content: true,
            description: true, summary: true, html: true, html_content: true, fields: true
        };
        var rows = [];
        Object.keys(pages).forEach(function (pageType) {
            var page = pages[pageType];
            if (!page || typeof page !== 'object' || Array.isArray(page)) {
                return;
            }
            var keys = Array.isArray(page.ordered_block_keys) && page.ordered_block_keys.length > 0
                ? page.ordered_block_keys.slice()
                : Object.keys(page);
            keys.forEach(function (blockKey) {
                if (pageMeta[blockKey]) {
                    return;
                }
                var block = page[blockKey];
                if (!block || typeof block !== 'object' || Array.isArray(block)) {
                    return;
                }
                rows.push({
                    page_type: String(block.page_type || page.page_type || pageType || '').trim(),
                    block_key: String(block.block_key || block.block_id || block.section_key || blockKey || '').trim(),
                    block_id: String(block.block_key || block.block_id || block.section_key || blockKey || '').trim(),
                    label: String(block.label || block.title || block.name || blockKey || '').trim(),
                    status: normalizeTaskStatus(block.status),
                    message: String(block.error || block.error_message || block.message || '').trim()
                });
            });
        });
        return compactPlanJsonBlockProgressForMemory(rows);
    }

    function attachPlanJsonBlockRowsToPages(pageRows, blockRows) {
        var grouped = groupPlanJsonBlockProgressByPage(blockRows);
        if (grouped.length === 0) {
            return pageRows;
        }
        var groupedByPage = {};
        grouped.forEach(function (row) {
            groupedByPage[row.page_type] = row;
        });
        return pageRows.map(function (row) {
            var copy = Object.assign({}, row);
            var detail = groupedByPage[copy.page_type];
            if (!detail) {
                return copy;
            }
            copy.block_rows = detail.block_rows || [];
            ['total', 'done', 'running', 'queued', 'pending', 'failed', 'cancelled', 'stale'].forEach(function (key) {
                if (normalizeCount(copy[key]) === 0 && normalizeCount(detail[key]) > 0) {
                    copy[key] = normalizeCount(detail[key]);
                }
            });
            copy.complete = !!copy.complete || (normalizeCount(copy.total) > 0 && normalizeCount(copy.done) >= normalizeCount(copy.total));
            return copy;
        });
    }

    function resolvePlanJsonTaskSummary(info) {
        if (!info || typeof info !== 'object') {
            return {};
        }
        if (info.plan_json_task_summary && typeof info.plan_json_task_summary === 'object') {
            return info.plan_json_task_summary;
        }
        if (info.task_summary && typeof info.task_summary === 'object') {
            return info.task_summary;
        }
        if (info.task_progress && typeof info.task_progress === 'object') {
            return info.task_progress;
        }
        return {};
    }

    function derivePageBlockProgressRows(info) {
        if (!info || typeof info !== 'object') {
            return [];
        }
        var planJsonBlockRows = derivePlanJsonBlockRowsFromPages(info.plan_json || (info.state && info.state.plan_json));
        if (planJsonBlockRows.length > 0) {
            return groupPlanJsonBlockProgressByPage(planJsonBlockRows);
        }
        var blockRows = compactPlanJsonBlockProgressForMemory(info.plan_json_block_progress);
        var direct = compactPageBlockProgressForMemory(info.page_block_progress);
        if (direct.length > 0) {
            return attachPlanJsonBlockRowsToPages(direct, blockRows);
        }
        if (blockRows.length > 0) {
            return groupPlanJsonBlockProgressByPage(blockRows);
        }
        var summary = resolvePlanJsonTaskSummary(info);
        var groups = summary.groups && typeof summary.groups === 'object' ? summary.groups : {};
        var rows = Object.keys(groups).map(function (groupKey) {
            var group = groups[groupKey];
            if (!group || typeof group !== 'object') {
                return null;
            }
            var pageType = String(group.page_type || groupKey || '').trim();
            if (pageType === '' || pageType === 'shared') {
                return null;
            }
            var total = normalizeCount(group.total);
            var done = normalizeCount(group.done);
            return {
                page_type: pageType,
                done: done,
                total: total,
                running: normalizeCount(group.running),
                queued: normalizeCount(group.queued),
                pending: normalizeCount(group.pending || group.todo),
                failed: normalizeCount(group.failed),
                cancelled: normalizeCount(group.cancelled),
                stale: normalizeCount(group.stale),
                complete: total > 0 && done >= total
            };
        }).filter(Boolean);
        return attachPlanJsonBlockRowsToPages(rows, blockRows);
    }

    function renderPlanJsonBlockProgressRows(blockRows) {
        blockRows = Array.isArray(blockRows) ? blockRows : [];
        if (blockRows.length === 0) {
            return '';
        }
        var visibleRows = blockRows.slice(0, 32);
        var html = '<div class="mt-1 small border-start ps-2" data-plan-json-block-progress>';
        visibleRows.forEach(function (row) {
            var status = normalizeTaskStatus(row.status);
            var statusClass = status === 'failed' ? 'text-danger' : (status === 'done' ? 'text-success' : (status === 'running' ? 'text-primary' : 'text-muted'));
            var label = String(row.label || row.section_key || row.block_id || '').trim();
            var key = String(row.section_key || row.block_id || '').trim();
            html += '<div class="d-flex flex-wrap align-items-start justify-content-between gap-2">'
                + '<span class="text-break">'
                + (key ? '<code>' + escapeHtml(key) + '</code> ' : '')
