                + '<span class="' + statusClass + '">' + escapeHtml(status) + '</span>'
                + '</div>';
            if (row.message) {
                html += '<div class="text-muted text-break mb-1">' + escapeHtml(row.message) + '</div>';
            }
        });
        if (blockRows.length > visibleRows.length) {
            html += '<div class="text-muted">+' + (blockRows.length - visibleRows.length) + ' more blocks</div>';
        }
        return html + '</div>';
    }

    function renderQueuePageBlockProgress(info) {
        var rows = derivePageBlockProgressRows(info);
        if (rows.length === 0) {
            return '';
        }
        var totalPages = rows.length;
        var donePages = rows.filter(function (row) { return row.complete; }).length;
        var totalBlocks = rows.reduce(function (sum, row) { return sum + normalizeCount(row.total); }, 0);
        var doneBlocks = rows.reduce(function (sum, row) { return sum + normalizeCount(row.done); }, 0);
        var html = '<div class="border rounded p-2 bg-body mb-2" data-build-page-block-progress>'
            + '<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">'
            + '<strong class="small">Page/block progress</strong>'
            + '<span class="text-muted small">pages ' + donePages + '/' + totalPages + ' Уи» blocks ' + doneBlocks + '/' + totalBlocks + '</span>'
            + '</div>';
        rows.forEach(function (row) {
            var total = normalizeCount(row.total);
            var done = normalizeCount(row.done);
            var pct = total > 0 ? Math.max(0, Math.min(100, Math.round((done / total) * 100))) : 0;
            var detail = [];
            ['running', 'queued', 'pending', 'failed', 'cancelled', 'stale'].forEach(function (key) {
                var count = normalizeCount(row[key]);
                if (count > 0) {
                    detail.push(key + ' ' + count);
                }
            });
            html += '<div class="mb-2" data-page-type="' + escapeHtml(row.page_type) + '">'
                + '<div class="d-flex align-items-center justify-content-between gap-2 small">'
                + '<code>' + escapeHtml(row.page_type) + '</code>'
                + '<span class="text-muted">' + done + '/' + total + (detail.length ? ' Уи» ' + escapeHtml(detail.join(' Уи» ')) : '') + '</span>'
                + '</div>'
                + '<div class="progress" style="height:4px;" aria-hidden="true">'
                + '<div class="progress-bar' + (row.failed > 0 ? ' bg-danger' : '') + '" style="width:' + pct + '%"></div>'
                + '</div>'
                + renderPlanJsonBlockProgressRows(row.block_rows)
                + '</div>';
        });
        return html + '</div>';
    }

    function toast(type, message) {
