<?php
/**
 * 第二阶段：按阶段一已确认方案拆解任务，并以内联面板形式展示。
 *
 * @var bool $pbAiPhaseOneConfirmedForTaskPlan
 * @var bool $pbAiPhaseTwoTaskPlanPresent
 * @var bool $pbAiTaskPlanQueueRunning
 */
$phaseOneOk = !empty($pbAiPhaseOneConfirmedForTaskPlan);
$phaseTwoTaskPlanPresent = !empty($pbAiPhaseTwoTaskPlanPresent);
$phaseTwoQueueRunning = !empty($pbAiTaskPlanQueueRunning);
$phaseTwoTaskPlanConfirmed = (int)($state['task_plan_confirmed'] ?? 0) === 1;
$phaseTwoActiveOperation = \is_array($activeOperation ?? null) ? $activeOperation : [];
$phaseTwoActiveOperationName = \strtolower(\trim((string)($phaseTwoActiveOperation['operation'] ?? '')));
$phaseTwoActiveOperationStatus = \strtolower(\trim((string)($phaseTwoActiveOperation['status'] ?? '')));
$phaseTwoBuildPhaseActive = $phaseTwoTaskPlanConfirmed
    || !empty($state['has_pending_build_tasks'])
    || !empty($pbAiTaskPlanStageEntryDecision['build_queue_running'])
    || ($phaseTwoActiveOperationName === 'build' && \in_array($phaseTwoActiveOperationStatus, ['queued', 'running'], true))
    || ((int)(($buildTaskSummary['queued'] ?? 0) ?: 0) + (int)(($buildTaskSummary['running'] ?? 0) ?: 0) > 0);
$phaseTwoPanelOpen = $phaseTwoQueueRunning || ($phaseTwoTaskPlanPresent && !$phaseTwoBuildPhaseActive);
$phaseTwoTriggerLabel = $phaseTwoTaskPlanPresent
    ? (string)__('查看第二阶段任务方案')
    : (string)__('生成第二阶段任务方案');
$phaseTwoEmptyText = $phaseTwoQueueRunning
    ? (string)__('任务规划生成中…')
    : (string)__('尚未生成第二阶段任务方案。');
/*
 * 阶段二预览契约：始终从草稿读取，不再 fallback 到 virtual_theme_plan.confirmed_markdown。
 * state.task_plan.markdown / state.task_plan_markdown 在后端已仅取 draft（确认后由 execution_blueprint
 * derive 出等价草稿），这里只读这两个字段加上 virtual_theme_plan.draft_markdown 作为最终兜底。
 */
$phaseTwoInitialMarkdown = trim((string)(
    ($state['task_plan']['markdown'] ?? '')
    ?: ($state['task_plan_markdown'] ?? '')
    ?: ($scope['virtual_theme_plan']['draft_markdown'] ?? '')
));
?>
<div class="accordion pb-ai-task-plan-accordion mt-3" id="pb-ai-task-plan-accordion">
    <div class="accordion-item border rounded overflow-hidden shadow-sm">
        <h2 class="accordion-header m-0" id="pb-ai-task-plan-accordion-heading">
            <button type="button"
                class="accordion-button<?= $phaseTwoPanelOpen ? '' : ' collapsed' ?> fw-semibold py-3"
                id="pb-ai-task-plan-accordion-trigger"
                data-pb-gate-phase-one="1"
                <?= $phaseOneOk ? 'data-bs-toggle="collapse"' : '' ?>
                data-bs-target="#pb-ai-task-plan-panel-collapse"
                aria-expanded="<?= $phaseTwoPanelOpen ? 'true' : 'false' ?>"
                aria-controls="pb-ai-task-plan-panel-collapse"<?= $phaseOneOk ? '' : ' disabled aria-disabled="true"' ?>>
                <i class="mdi mdi-format-list-checks me-2"></i><?= htmlspecialchars($phaseTwoTriggerLabel, ENT_QUOTES, 'UTF-8') ?>
            </button>
        </h2>
        <div id="pb-ai-task-plan-panel-collapse"
            class="accordion-collapse collapse<?= $phaseTwoPanelOpen ? ' show' : '' ?>"
            aria-labelledby="pb-ai-task-plan-accordion-heading"
            data-bs-parent="#pb-ai-task-plan-accordion">
            <div class="accordion-body p-0">
                <div class="px-4 py-3 border-bottom bg-light">
                    <div class="small text-muted mb-0">
                        <?= htmlspecialchars((string)__('本阶段会把第一阶段已确认的建站方案拆解为可执行的页面与区块任务清单。微调只修改指定范围，重建会生成全量新方案；确认后才能进入构建。'), ENT_QUOTES, 'UTF-8') ?>
                    </div>
                </div>
                <div class="alert alert-info border-0 rounded-0 mb-0">
                    <i class="mdi mdi-information-outline me-1"></i>
                    <?= htmlspecialchars((string)__('第二阶段基于已确认方案自动拆解任务；确认任务方案后可手动点击“构建网站”进入后台构建。'), ENT_QUOTES, 'UTF-8') ?>
                </div>
                <div class="p-4">
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <div class="d-flex flex-column">
                                <div class="border rounded pb-ai-task-plan-preview-outer">
                                    <div id="pb-ai-task-plan-preview-content" class="p-3 flex-grow-1 overflow-auto min-h-0" title="<?= htmlspecialchars((string)__('单击任务方案预览区可全屏查看'), ENT_QUOTES, 'UTF-8') ?>">
                                        <?php /*
                                            阶段二预览同样由前端 buildPlanPreviewHtml 基于结构化数据接管渲染，
                                            服务端只输出占位文案，避免 markdown 直接展示在屏幕上。
                                        */ ?>
                                        <div id="pb-ai-task-plan-rendered-content"><?= htmlspecialchars($phaseTwoEmptyText, ENT_QUOTES, 'UTF-8') ?></div>
                                    </div>
                                    <textarea id="pb-ai-task-plan-markdown" class="d-none" aria-hidden="true" tabindex="-1"><?= htmlspecialchars($phaseTwoInitialMarkdown, ENT_QUOTES, 'UTF-8') ?></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="border rounded p-2">
                                <w:theme:sse-terminal id="pb-ai-task-plan-sse-terminal" title="@lang{第二阶段任务方案流}" height="200px" events="start,progress,chunk,total,done,error,warning,info" show-start-toggle="false" />
                            </div>
                        </div>
                    </div>
                    <div class="progress mb-2">
                        <div id="pb-ai-task-plan-progress-bar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                    <div id="pb-ai-task-plan-status" class="text-muted small mb-3"><?= htmlspecialchars((string)__('准备开始生成任务计划。'), ENT_QUOTES, 'UTF-8') ?></div>
                    <div class="d-flex flex-wrap align-items-center gap-2 justify-content-between border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#pb-ai-task-plan-panel-collapse" aria-expanded="true" aria-controls="pb-ai-task-plan-panel-collapse">
                            <?= htmlspecialchars((string)__('收起第二阶段面板'), ENT_QUOTES, 'UTF-8') ?>
                        </button>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <button type="button" class="btn btn-outline-danger<?= $phaseTwoTaskPlanPresent ? '' : ' d-none' ?>" id="pb-ai-task-plan-regenerate">
                                <?= htmlspecialchars((string)__('方案重建'), ENT_QUOTES, 'UTF-8') ?>
                            </button>
                            <button type="button" class="btn btn-outline-primary d-none" id="pb-ai-save-task-plan-draft">
                                <?= htmlspecialchars((string)__('保存方案'), ENT_QUOTES, 'UTF-8') ?>
                            </button>
                            <button type="button" class="btn btn-primary" id="pb-ai-confirm-task-plan" disabled>
                                <?= htmlspecialchars((string)__('确认任务方案'), ENT_QUOTES, 'UTF-8') ?>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
