<script>
// P0可观测性：初始化增强SSE日志器
(function() {
    var workspaceApi = window.__pbWorkspaceApi;
    if (!workspaceApi || typeof workspaceApi !== 'object') {
        workspaceApi = {};
        window.__pbWorkspaceApi = workspaceApi;
    }
    workspaceApi.observability = workspaceApi.observability && typeof workspaceApi.observability === 'object'
        ? workspaceApi.observability
        : {};

    var sseLogger = null;
    try {
        if (window.PbAiSseConnectionManager) {
            sseLogger = window.PbAiSseConnectionManager.createLogger('pagebuilder-workspace', {
                publicId: '<?= htmlspecialchars($publicId ?? '', ENT_QUOTES, 'UTF-8') ?>',
                enableDetailedLogging: true,
                maxLogEntries: 500
            });
            
            // 统一收敛到 workspace API
            workspaceApi.observability = workspaceApi.observability && typeof workspaceApi.observability === 'object'
                ? workspaceApi.observability
                : {};
            workspaceApi.observability.sseLogger = sseLogger;
            // 向后兼容
            window.pbAiWorkspaceSseLogger = sseLogger;
            
            console.info('[SSE] P0可观测性增强已初始化');
            
            if (sseLogger) {
                sseLogger.log('info', 'P0可观测性增强初始化完成', {
                    event: 'observability_initialized',
                    publicId: '<?= htmlspecialchars($publicId ?? '', ENT_QUOTES, 'UTF-8') ?>',
                    stage: '<?= htmlspecialchars($currentStage ?? '', ENT_QUOTES, 'UTF-8') ?>'
                });
            }
        }
    } catch (e) {
        console.warn('[SSE] 初始化增强日志器失败:', e);
    }
})();
</script>

