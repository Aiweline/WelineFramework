<script>
// 调试面板控制
(function () {
    'use strict';

    var workspaceApi = window.__pbWorkspaceApi;
    if (!workspaceApi || typeof workspaceApi !== 'object') {
        workspaceApi = {};
        window.__pbWorkspaceApi = workspaceApi;
    }
    workspaceApi.observability = workspaceApi.observability && typeof workspaceApi.observability === 'object'
        ? workspaceApi.observability
        : {};

    workspaceApi.observability.toggleDebugPanel = function () {
        var panel = document.getElementById('pb-ai-sse-debug-panel');
        if (!panel) {
            return;
        }
        if (panel.style.display === 'none') {
            panel.style.display = 'block';
            workspaceApi.observability.updateDebugPanel();
        } else {
            panel.style.display = 'none';
        }
    };

    workspaceApi.observability.updateDebugPanel = function () {
        try {
            var healthReport = workspaceApi.observability.getHealthReport ? workspaceApi.observability.getHealthReport() : null;
            var statsEl = document.getElementById('pb-ai-sse-stats');
            var logsEl = document.getElementById('pb-ai-sse-logs');

            if (statsEl && healthReport) {
                statsEl.innerHTML = `
                <div><strong>连接状态:</strong> ${healthReport.connectionHealth.isHealthy ? '✅ 健康' : '❌ 异常'}</div>
                <div><strong>总消息数:</strong> ${healthReport.connectionHealth.totalMessages}</div>
                <div><strong>重复消息:</strong> ${healthReport.connectionHealth.duplicateMessages} (${healthReport.connectionHealth.duplicateRate})</div>
                <div><strong>重复连接:</strong> ${healthReport.duplicateConnections.totalDuplicates}</div>
                <div><strong>连接断开:</strong> ${healthReport.connectionHealth.connectionDrops}</div>
                <div><strong>最后消息:</strong> ${healthReport.connectionHealth.lastMessageAgo}ms 前</div>
            `;
            }

            if (logsEl && workspaceApi.observability.sseLogger && typeof workspaceApi.observability.sseLogger.getRecentLogs === 'function') {
                var recentLogs = workspaceApi.observability.sseLogger.getRecentLogs(20);
                logsEl.textContent = JSON.stringify(recentLogs, null, 2);
            }
        } catch (e) {
            console.error('更新调试面板失败:', e);
        }
    };

    // 向后兼容旧全局入口
    window.togglePbAiSseDebugPanel = function () {
        return workspaceApi.observability.toggleDebugPanel();
    };
    window.updatePbAiSseDebugPanel = function () {
        return workspaceApi.observability.updateDebugPanel();
    };

    // 快捷键支持
    document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.shiftKey && e.key === 'D') {
            e.preventDefault();
            workspaceApi.observability.toggleDebugPanel();
        }
    });

    console.info('[SSE] 按 Ctrl+Shift+D 打开调试面板');
})();
</script>

