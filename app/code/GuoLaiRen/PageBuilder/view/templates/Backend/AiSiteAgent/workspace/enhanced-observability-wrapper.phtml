    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid #313244; padding-bottom: 10px;">
        <h4 style="margin: 0; color: #89b4fa;">SSE连接调试面板</h4>
        <button onclick="document.getElementById('pb-ai-sse-debug-panel').style.display='none'" style="background: #45475a; border: none; color: #cdd6f4; padding: 5px 10px; border-radius: 4px; cursor: pointer;">✕</button>
