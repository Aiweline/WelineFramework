    <div style="margin-bottom: 15px;">
        <button onclick="console.log(window.getPbAiSseHealthReport())" style="background: #45475a; border: none; color: #cdd6f4; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-right: 5px;">查看健康报告</button>
        <button onclick="window.exportPbAiSseLogs()" style="background: #45475a; border: none; color: #cdd6f4; padding: 5px 10px; border-radius: 4px; cursor: pointer;">导出日志</button>
    </div>

    <div id="pb-ai-sse-stats" style="background: #313244; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
        <div>加载中...</div>
    </div>

    <div id="pb-ai-sse-logs" style="background: #181825; padding: 10px; border-radius: 4px; max-height: 300px; overflow-y: auto;">
