        }
        return runtimePlanJsonPagesHaveBlocks(resolveRuntimePlanJson(state))
            || (String(eventKind || '') === 'done' && (!payload || payload.success !== false));
    }

    /**
     * Read canonical queue status from the normalized SSE/queue payload.
     */
    function readQueueStatusFromPayload(operation, payload) {
        if (!payload || typeof payload !== 'object') {
            return '';
        }
        var status = String(payload.queue_status || '').trim().toLowerCase();
        if (status !== '') {
            return status;
        }
        var queueState = payload.queue_state && typeof payload.queue_state === 'object'
            ? payload.queue_state
            : null;
        if (queueState) {
            status = String(queueState.queue_status || '').trim().toLowerCase();
            if (status !== '') {
                return status;
            }
        }
        var state = payload.state && typeof payload.state === 'object' ? payload.state : {};
        var queueInfo = resolveRuntimeQueueInfoFromState(state, operation || payload.operation || '');
        return String(
            queueInfo.queue_status
            || ''
        ).trim().toLowerCase();
    }

    function collectRetryableFailureItemsFromPayload(operation, payload) {
        var normalizedOperation = String(operation || '').trim();
        var containers = [];
        if (payload && typeof payload === 'object') {
            containers.push(payload);
            if (payload.state && typeof payload.state === 'object') {
                containers.push(payload.state);
            }
            if (payload.data && typeof payload.data === 'object') {
                containers.push(payload.data);
            }
            if (payload.scope && typeof payload.scope === 'object') {
                containers.push(payload.scope);
            }
        }
        var items = [];

        function appendFromLedger(ledger) {
            if (!ledger || typeof ledger !== 'object') {
                return;
            }
            if (Array.isArray(ledger)) {
                ledger.forEach(function (item) {
                    if (item && typeof item === 'object') {
                        if (normalizedOperation === '' || String(item.operation || '').trim() === normalizedOperation) {
                            items.push(item);
                        }
                    }
                });
                return;
            }
            if (normalizedOperation !== '' && ledger[normalizedOperation] && typeof ledger[normalizedOperation] === 'object') {
                appendFromLedger(ledger[normalizedOperation].items || ledger[normalizedOperation]);
                return;
            }
            if (ledger.items) {
                appendFromLedger(ledger.items);
            }
        }

        containers.forEach(function (container) {
            appendFromLedger(container.retryable_ai_failures);
        });

        var seen = {};
        return items.filter(function (item, index) {
            var key = String(item.item_key || item.key || index);
            var op = String(item.operation || normalizedOperation || '');
            var fingerprint = op + ':' + key;
            if (seen[fingerprint]) {
                return false;
            }
            seen[fingerprint] = true;
            return true;
        });
    }

    function buildRetryableFailureDetailLines(operation, payload) {
        var items = collectRetryableFailureItemsFromPayload(operation, payload);
        if (!items.length) {
            return [];
        }
        var lines = [];
        for (var i = 0; i < items.length; i += 1) {
            var item = items[i] || {};
            var label = String(item.label || item.title || item.page_label || item.item_key || ('Item ' + String(i + 1))).trim();
            var message = String(item.message || item.error_message || item.error || '').trim();
            var taskKeys = Array.isArray(item.task_keys) ? item.task_keys.filter(Boolean) : [];
            var meta = [];
            if (item.page_label) {
                meta.push(String(item.page_label));
            }
            if (item.retry_scope) {
                meta.push(String(item.retry_scope));
            }
            if (taskKeys.length) {
                meta.push('tasks: ' + taskKeys.join(', '));
            }
            var line = '失败项 ' + String(i + 1) + ': ' + label;
            if (message !== '') {
                line += ' | ' + message;
            }
            if (meta.length) {
                line += ' | ' + meta.join(' | ');
            }
            lines.push(line);
        }
        return lines;
    }

    function reloadWorkspacePageNow() {
