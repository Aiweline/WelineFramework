    function pickOperationResponsePayload(data) {
        if (!data || typeof data !== 'object') {
            return null;
        }
        var level1 = (data.data && typeof data.data === 'object') ? data.data : null;
        var level2 = (level1 && level1.data && typeof level1.data === 'object') ? level1.data : null;
        if (data.execution_token || data.stream_url) {
            return data;
        }
        if (level1 && (level1.execution_token || level1.stream_url)) {
            return level1;
        }
        if (level2 && (level2.execution_token || level2.stream_url)) {
            return level2;
        }
        if (data.operation) {
            return data;
        }
        if (level1 && level1.operation) {
            return level1;
        }
        if (level2 && level2.operation) {
            return level2;
        }
        return data;
    }

    function startFromResponse(data, fallbackOperation) {
        if (!data || !data.success) {
            return false;
        }
        var payload = pickOperationResponsePayload(data) || {};
        if (data.data && typeof data.data === 'object') {
            hydrateWorkspaceFromState(data.data);
        } else if (payload.data && typeof payload.data === 'object') {
            hydrateWorkspaceFromState(payload.data);
        }
        var normalized = normalizeOperationStreamStartPayload(payload, fallbackOperation);
        var executionToken = normalized.executionToken;
        var operation = normalized.operation;
        var streamUrl = normalized.streamUrl;
        var hasObservableStreamStart = !!(executionToken && streamUrl);
        var shouldDeferToQueuePoll = !hasObservableStreamStart && !!(
            payload
            && (
                payload.deferred_queue_progress
                || payload.queue_waiting_for_scheduler
                || (payload.active_operation && typeof payload.active_operation === 'object' && (
                    payload.active_operation.queue_waiting_for_scheduler
                ))
            )
        );
        if (shouldDeferToQueuePoll) {
            syncQueuedStageUi(operation, 'progress', Object.assign({}, payload || {}, {
                message: String((payload && payload.message) || <?= \json_encode((string)__('队列任务已提交，正在等待系统调度。'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>),
                deferred_queue_progress: true,
                queue_waiting_for_scheduler: true
            }), { level: 'info' });
            startDeferredQueueStatePoll(operation || fallbackOperation || 'build');
            return true;
        }
        if (!executionToken || !streamUrl) {
            var missing = [];
            if (!executionToken) {
                missing.push('execution_token');
            }
            if (!streamUrl) {
                missing.push('stream_url');
            }
            toast('error', <?= \json_encode((string)__('操作已创建但缺少 SSE 参数'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + ': ' + missing.join(', '));
            return false;
        }
        return startOperationStream(streamUrl, operation, executionToken, 'startFromResponse');
    }

    window.PbAiOperationRunner = {
        startFromResponse: startFromResponse
    };

    function observeExistingDraftOperationOnLoad() {
        var active = activeOperation && typeof activeOperation === 'object' ? activeOperation : {};
        var operation = String(active.operation || '').trim();
        var status = String(active.status || '').toLowerCase();
        if (!operation || ['queued', 'pending', 'running', 'processing'].indexOf(status) === -1) {
            return;
        }
        if (operation !== 'plan' && operation !== 'build' && operation !== 'publish' && operation !== 'image_asset') {
            return;
        }
        var hasExecutionToken = !!String(active.execution_token || '').trim();
        if (!hasExecutionToken) {
            startDeferredQueueStatePoll(operation);
            return;
        }
        var started = startFromResponse(Object.assign({ success: true }, active), operation);
        if (!started) {
            startDeferredQueueStatePoll(operation);
        }
    }

    window.setTimeout(observeExistingDraftOperationOnLoad, 180);

    function startPublishFlow(triggerButton, options) {
        var opts = options && typeof options === 'object' ? options : {};
        var retryAttempt = parseInt(opts.retryAttempt || 0, 10) || 0;
        if (hasPublishBlockingAiStateForRuntime()) {
            syncPublishStartButtonForRuntime();
            toast('warning', messages.publishBlockedLatestBuildFailure || messages.publishRunning || '');
            return;
        }
        if (!startPublishUrl) {
            toast('error', messages.publishStartUnavailable);
            if (triggerButton) {
                triggerButton.disabled = false;
            }
            return;
        }
        if (triggerButton && triggerButton.disabled && !opts.skipDisabledGuard) {
            toast('warning', messages.publishRunning);
            return;
        }
        if (triggerButton) {
            triggerButton.disabled = true;
        }
        submitWorkspaceForm(startPublishUrl, { public_id: publicId, confirm_visual_theme: '1' }).then(function (data) {
            if (!data || !data.success) {
                var errorCode = String((data && (data.code || (data.data && data.data.code))) || '').toUpperCase();
                if (errorCode === 'WORKSPACE_NOT_READY' && retryAttempt < 3) {
                    fetchWorkspaceSnapshotState().then(function (workspaceState) {
                        syncDeferredQueueWorkspaceState('publish', workspaceState);
                        window.setTimeout(function () {
                            startPublishFlow(triggerButton, {
                                skipDisabledGuard: true,
                                retryAttempt: retryAttempt + 1
                            });
                        }, 1000);
                    }).catch(function () {
                        window.setTimeout(function () {
                            startPublishFlow(triggerButton, {
                                skipDisabledGuard: true,
                                retryAttempt: retryAttempt + 1
                            });
                        }, 1000);
                    });
                    return;
                }
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                toast('error', (data && data.message) ? String(data.message) : <?= \json_encode((string)__('启动发布失败'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                return;
            }
            if (!startFromResponse(data, 'publish')) {
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                toast('error', messages.operationStreamMissing);
            }
        }).catch(function () {
            if (triggerButton) {
                triggerButton.disabled = false;
            }
            toast('error', <?= \json_encode((string)__('网络错误，请稍后重试'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
        });
    }

    function checkBeforePublishAndStart(triggerButton) {
        if (hasPublishBlockingAiStateForRuntime()) {
            syncPublishStartButtonForRuntime();
            toast('warning', messages.publishBlockedLatestBuildFailure || messages.publishRunning || '');
            return;
        }
        if (triggerButton && triggerButton.disabled) {
            toast('warning', messages.publishRunning);
            return;
        }
        if (!publishCheckUrl) {
            startPublishFlow(triggerButton);
            return;
        }
        if (triggerButton) {
            triggerButton.disabled = true;
        }
        toast('info', messages.publishChecking);
        submitWorkspaceForm(publishCheckUrl, { public_id: publicId }).then(function (checkData) {
            var payload = checkData && checkData.data && typeof checkData.data === 'object' ? checkData.data : {};
            var passed = !!(payload && payload.passed);
            if (!passed) {
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                var items = Array.isArray(payload.items) ? payload.items : [];
                var firstFailedItem = null;
                items.forEach(function (item) {
                    if (!item || typeof item !== 'object') {
                        return;
                    }
                    if (!firstFailedItem && !item.ok) {
                        firstFailedItem = item;
                    }
                });
                if (firstFailedItem && firstFailedItem.label) {
                    toast('warning', <?= \json_encode((string)__('发布前仍有未完成项：'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + String(firstFailedItem.label));
                    return;
                }
                toast('warning', <?= \json_encode((string)__('发布前检查未通过，请先完成页面与配置。'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                return;
            }
            startPublishFlow(triggerButton, { skipDisabledGuard: true });
        }).catch(function () {
            if (triggerButton) {
                triggerButton.disabled = false;
            }
            toast('error', <?= \json_encode((string)__('网络错误，请稍后重试'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
        });
    }

    window.__pbStartPublishFromButton = function (triggerButton) {
        checkBeforePublishAndStart(triggerButton || document.getElementById('pb-ai-start-publish'));
    };

    var publishBtn = document.getElementById('pb-ai-start-publish');
    if (publishBtn && publishBtn.dataset.pbMainPublishBound !== '1') {
        publishBtn.dataset.pbRuntimePublishBound = '1';
        publishBtn.addEventListener('click', function () {
            window.__pbStartPublishFromButton(publishBtn);
        });
    }

    // 禁止页面加载时自动弹出继续构建/观察执行流确认。

    // 禁用会跳走的导航按钮
    function disableNavigationDuringOperation() {
        // 禁用返回按钮
        document.querySelectorAll('.pb-guided-sidebar .btn[href], .pb-ai-back-btn, #pb-guided-back').forEach(function(btn) {
            if (btn.tagName === 'A' || btn.classList.contains('btn')) {
                btn.setAttribute('data-disabled-during-operation', 'true');
                btn.setAttribute('disabled', 'disabled');
                btn.style.opacity = '0.5';
                btn.style.pointerEvents = 'none';
            }
        });

        // 禁用切换到其他页面的按钮（如 expert/guided 切换）
        document.querySelectorAll('.pb-ai-expert-toggle, [data-switch-workspace]').forEach(function(btn) {
            btn.setAttribute('data-disabled-during-operation', 'true');
            btn.setAttribute('disabled', 'disabled');
            btn.style.opacity = '0.5';
            btn.style.pointerEvents = 'none';
        });

        // 禁用开始新的构建按钮（但保留当前构建的进度显示）
        document.querySelectorAll('.pb-ai-run-virtual-theme, .pb-ai-start-build').forEach(function(btn) {
            if (!btn.classList.contains('pb-ai-run-virtual-theme-running')) {
                btn.setAttribute('data-disabled-during-operation', 'true');
                btn.setAttribute('disabled', 'disabled');
                btn.style.opacity = '0.5';
                btn.style.pointerEvents = 'none';
            }
        });
    }

    // 恢复导航按钮
    function enableNavigationAfterOperation() {
        document.querySelectorAll('[data-disabled-during-operation]').forEach(function(el) {
            el.removeAttribute('data-disabled-during-operation');
            el.removeAttribute('disabled');
            el.style.opacity = '';
            el.style.pointerEvents = '';
        });
        if (window.__pbSyncRunVirtualThemeGateState && typeof window.__pbSyncRunVirtualThemeGateState === 'function') {
            window.__pbSyncRunVirtualThemeGateState();
        }
    }
})();
</script>
