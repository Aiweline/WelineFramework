        if (kind === 'error' && isBenignOperationInProgressConflict(payload, fallback)) {
            kind = 'warning';
            level = 'warning';
        }
        var mirroredKind = '';
        if (kind === 'start' || kind === 'progress' || kind === 'chunk' || kind === 'total' || kind === 'error') {
            mirroredKind = kind;
        } else if (kind === 'done_error') {
            mirroredKind = 'error';
        } else if (kind === 'done') {
            mirroredKind = 'done';
        } else if (kind === 'warning') {
            // 后台队列观察模式：首条 warning 需驱动阶段一/二 SSE 终端与进度条，否则面板空白且一直显示「已断开」
            mirroredKind = 'warning';
        } else if (kind === 'info') {
            mirroredKind = 'info';
        }
        if (mirroredKind !== '') {
            var opMirror = resolveOperationForQueuedMirror(payload);
            if (payload && payload.operation && opMirror === 'plan') {
                runningOperationType = opMirror;
            }
            syncQueuedStageUi(opMirror, mirroredKind, payload, { level: level || 'info' });
        }
        if (kind === 'info' && payload && Array.isArray(payload.detail_lines) && payload.detail_lines.length > 0) {
            if (workspaceTerminal) {
                var fpInfo = ['info-detail', payload.detail_lines.join('\n')].join('|');
                if (fpInfo !== lastOperationTerminalFingerprint) {
                    lastOperationTerminalFingerprint = fpInfo;
                    for (var li = 0; li < payload.detail_lines.length; li++) {
                        var lm = String(payload.detail_lines[li] || '').trim();
                        if (lm !== '') {
                            workspaceTerminal.log(lm, level || 'info');
                        }
                    }
                }
            }
            return;
        }
        if (!workspaceTerminal) {
            return;
        }
        var message = buildOperationTerminalMessage(payload, fallback);
        if (!message) {
            return;
        }
        var fingerprint = [
            String(kind || ''),
            String(level || ''),
            String(payload && payload.page_type || ''),
            String(payload && payload.progress_percent || ''),
            message
        ].join('|');
        if (fingerprint === lastOperationTerminalFingerprint) {
            return;
        }
        lastOperationTerminalFingerprint = fingerprint;
        workspaceTerminal.log(message, level || 'info');
    }

    function resolveQueuedStageUiBinding(operation) {
        var normalized = String(operation || '').toLowerCase();
        if (normalized !== 'plan') {
            return null;
        }
        var api = resolveWorkspaceApi();
        var terminal = typeof api.bindPlanStageTerminal === 'function'
            ? api.bindPlanStageTerminal()
            : (window.WelineSseTerminal ? window.WelineSseTerminal['pb-ai-plan-sse-terminal'] : null);
        return {
            terminal: terminal,
            setStatus: api.setPlanModeStatus,
            setProgress: api.setPlanModalProgress,
            setLoading: api.setPlanModeRunButtonLoading,
            getConfirmedState: api.getPlanConfirmedState
        };
    }

    function getQueuedStageDefaultMessage(operation, eventKind) {
        var kind = String(eventKind || '').toLowerCase();
        if (kind === 'total') { return 'Plan prompt generated; syncing queue progress.'; }
        if (kind === 'start') { return 'Plan generation has entered the background queue.'; }
        if (kind === 'progress') { return 'Plan generation is running in the background queue.'; }
        if (kind === 'done') { return 'Plan generation completed.'; }
        if (kind === 'error') { return 'Plan generation failed. Please retry.'; }
        if (kind === 'warning') { return 'Plan generation is waiting for the system scheduler.'; }
        return 'Plan generation state updated.';
    }

    function getQueuedStageProgressPercent(operation, payload, eventKind) {
        var percent = parseInt(String(payload && payload.progress_percent || 0), 10) || 0;
        if (percent > 0) {
            return Math.max(0, Math.min(100, percent));
        }
        var kind = String(eventKind || '').toLowerCase();
        var queueStatus = readQueueStatusFromPayload(operation, payload);
        var queueStillWaiting = !!(payload && (payload.deferred_queue_progress || payload.queue_waiting_for_scheduler))
            || ['pending', 'queued'].indexOf(queueStatus) !== -1;
        if (queueStillWaiting) { return 10; }
        if (queueStatus === 'running' || queueStatus === 'processing') { return 35; }
        if (kind === 'start') { return 12; }
        if (kind === 'progress') { return 48; }
        if (kind === 'total' || kind === 'done' || kind === 'error') { return 100; }
        if (kind === 'warning') {
            var qs = String(payload && payload.queue_status || '').toLowerCase();
            if (qs === 'running') { return 40; }
            if (qs === 'pending') { return 10; }
            return 8;
        }
        return 0;
    }

    function payloadIndicatesQueuedStageDraft(operation, payload, eventKind) {
        var normalized = String(operation || '').toLowerCase();
        var state = payload && payload.state && typeof payload.state === 'object' ? payload.state : {};
        if (normalized !== 'plan') {
            return false;
        }
        if (Object.prototype.hasOwnProperty.call(state, 'has_stage_one_plan')) {
            return !!state.has_stage_one_plan || !!state.plan_confirmed;
        }
        return !!state.plan_confirmed || !!(payload && payload.plan_confirmed)
            || (String(eventKind || '') === 'done' && (!payload || payload.success !== false));
    }

    /**
     * 从 SSE/queue payload 中读取队列权威状态。
     *
     * 主字段：payload.queue_status（由 AiSiteSsePayloadNormalizer 写入并强制小写）。
     * 过渡 fallback（normalizer 镜像）：payload.status / queue_info.status / snapshot.job_status 等。
     * 契约稳定后可在 1-2 个 release 内仅保留 queue_status 主字段。
     */
    function readQueueStatusFromPayload(operation, payload) {
        if (!payload || typeof payload !== 'object') {
            return '';
        }
        var status = String(payload.queue_status || '').trim().toLowerCase();
        if (status !== '') {
            return status;
        }
        var snapshot = payload.queue_snapshot && typeof payload.queue_snapshot === 'object'
            ? payload.queue_snapshot
            : null;
        if (snapshot) {
            status = String(snapshot.status || snapshot.job_status || snapshot.queue_status || '').trim().toLowerCase();
            if (status !== '') {
                return status;
            }
        }
        var state = payload.state && typeof payload.state === 'object' ? payload.state : {};
        var key = resolveRuntimeQueueInfoKey(operation || payload.operation || '');
        var queueInfo = state[key] && typeof state[key] === 'object' ? state[key] : {};
        snapshot = queueInfo.snapshot && typeof queueInfo.snapshot === 'object' ? queueInfo.snapshot : null;
        return String(
            queueInfo.status
            || queueInfo.queue_status
            || queueInfo.state
            || (snapshot ? (snapshot.status || snapshot.job_status || snapshot.queue_status || '') : '')
            || ''
        ).trim().toLowerCase();
    }

    function collectRetryableFailureItemsFromPayload(operation, payload) {
        var normalizedOperation = String(operation || '').trim();
        var containers = [];
        if (payload && typeof payload === 'object') {
            containers.push(payload);
            if (payload.state && typeof payload.state === 'object') {
                containers.push(payload.state);
            }
            if (payload.data && typeof payload.data === 'object') {
                containers.push(payload.data);
            }
            if (payload.scope && typeof payload.scope === 'object') {
                containers.push(payload.scope);
            }
        }
        var items = [];

        function appendFromLedger(ledger) {
            if (!ledger || typeof ledger !== 'object') {
                return;
            }
            if (Array.isArray(ledger)) {
                ledger.forEach(function (item) {
                    if (item && typeof item === 'object') {
                        if (normalizedOperation === '' || String(item.operation || '').trim() === normalizedOperation) {
                            items.push(item);
                        }
                    }
                });
                return;
            }
            if (normalizedOperation !== '' && ledger[normalizedOperation] && typeof ledger[normalizedOperation] === 'object') {
                appendFromLedger(ledger[normalizedOperation].items || ledger[normalizedOperation]);
                return;
            }
            if (ledger.items) {
                appendFromLedger(ledger.items);
            }
        }

        containers.forEach(function (container) {
            appendFromLedger(container.retryable_ai_failures);
            if (container.scope && typeof container.scope === 'object') {
                appendFromLedger(container.scope.retryable_ai_failures);
            }
        });

        var seen = {};
        return items.filter(function (item, index) {
            var key = String(item.item_key || item.key || index);
            var op = String(item.operation || normalizedOperation || '');
            var fingerprint = op + ':' + key;
            if (seen[fingerprint]) {
                return false;
            }
            seen[fingerprint] = true;
            return true;
        });
    }

    function buildRetryableFailureDetailLines(operation, payload) {
        var items = collectRetryableFailureItemsFromPayload(operation, payload);
        if (!items.length) {
            return [];
        }
        var lines = [];
        for (var i = 0; i < items.length; i += 1) {
            var item = items[i] || {};
            var label = String(item.label || item.title || item.page_label || item.item_key || ('Item ' + String(i + 1))).trim();
            var message = String(item.message || item.error_message || item.error || '').trim();
            var taskKeys = Array.isArray(item.task_keys) ? item.task_keys.filter(Boolean) : [];
            var meta = [];
            if (item.page_label) {
                meta.push(String(item.page_label));
            }
            if (item.retry_scope) {
                meta.push(String(item.retry_scope));
            }
            if (taskKeys.length) {
                meta.push('tasks: ' + taskKeys.join(', '));
            }
            var line = '失败项 ' + String(i + 1) + ': ' + label;
            if (message !== '') {
                line += ' | ' + message;
            }
            if (meta.length) {
                line += ' | ' + meta.join(' | ');
            }
            lines.push(line);
        }
        return lines;
    }

    function reloadWorkspacePageNow() {
        if (queueCompletionReloadTimer) {
            window.clearTimeout(queueCompletionReloadTimer);
            queueCompletionReloadTimer = null;
        }
        window.location.reload();
    }

    function scheduleReloadAfterQueueCompleted(operation, payload, eventKind) {
        var normalizedOperation = String(operation || '').toLowerCase();
        var status = readQueueStatusFromPayload(operation, payload);
        var completed = ['done', 'complete', 'completed'].indexOf(status) !== -1;
        if (!completed || queueCompletionReloadTimer) {
            return;
        }
        if (normalizedOperation === 'plan' && typeof window.__pbSchedulePlanWorkspaceReload === 'function') {
            window.__pbSchedulePlanWorkspaceReload('plan_queue_done', 900);
            return;
        }
        queueCompletionReloadTimer = window.setTimeout(function () {
            reloadWorkspacePageNow();
        }, 650);
    }

    function syncQueuedStageUi(operation, eventKind, payload, options) {
        if (
            String(operation || '').toLowerCase() === 'plan'
            && window.__pbPhase1TaskProgress
            && typeof window.__pbPhase1TaskProgress.syncFromSsePayload === 'function'
        ) {
            window.__pbPhase1TaskProgress.syncFromSsePayload(operation, payload || {}, eventKind);
        }
        if (
            String(operation || '').toLowerCase() === 'build'
            && window.__pbBuildQueueProgress
            && typeof window.__pbBuildQueueProgress.syncFromSsePayload === 'function'
        ) {
            window.__pbBuildQueueProgress.syncFromSsePayload(operation, payload || {}, eventKind);
        }
        var binding = resolveQueuedStageUiBinding(operation);
        if (!binding) {
            return;
        }
        var opts = options && typeof options === 'object' ? options : {};
        var message = String((payload && payload.message) || getQueuedStageDefaultMessage(operation, eventKind) || '').trim();
        var percent = getQueuedStageProgressPercent(operation, payload, eventKind);
        var observerBg = payload && (payload.observer_mode || payload.background_mode);
        var level = opts.level || (eventKind === 'error' ? 'error' : ((eventKind === 'done' || eventKind === 'total') ? eventKind : (eventKind === 'progress' ? 'progress' : (eventKind === 'warning' ? 'warning' : 'info'))));
        if (eventKind !== 'info') {
            if (typeof binding.setLoading === 'function') {
                binding.setLoading(
                    eventKind === 'start'
                    || eventKind === 'progress'
                    || eventKind === 'chunk'
                    || (eventKind === 'warning' && !!observerBg)
                );
            }
            if ((eventKind === 'start' || eventKind === 'progress' || eventKind === 'total' || eventKind === 'done' || eventKind === 'error' || eventKind === 'warning') && typeof binding.setStatus === 'function') {
                binding.setStatus(message, level);
            }
            if ((eventKind === 'start' || eventKind === 'progress' || eventKind === 'total' || eventKind === 'done' || eventKind === 'error' || eventKind === 'warning') && typeof binding.setProgress === 'function') {
                binding.setProgress(
                    message,
                    percent,
                    eventKind === 'done'
                        ? payloadIndicatesQueuedStageDraft(operation, payload, eventKind) && !(typeof binding.getConfirmedState === 'function' && binding.getConfirmedState())
                        : false,
                    level
                );
            }
        }
        if (binding.terminal && typeof binding.terminal.log === 'function') {
            if (eventKind === 'chunk') {
                var chunkText = String((payload && (payload.content || payload.chunk || payload.message)) || '');
                if (chunkText !== '') {
                    if (typeof binding.terminal.writeChunk === 'function') {
                        binding.terminal.writeChunk(chunkText, payload || {});
                    } else {
                        binding.terminal.log(chunkText, 'chunk', payload || {});
                    }
                }
            } else if (eventKind === 'info' && payload && Array.isArray(payload.detail_lines) && payload.detail_lines.length > 0) {
                for (var ii = 0; ii < payload.detail_lines.length; ii++) {
                    var dl = String(payload.detail_lines[ii] || '').trim();
                    if (dl !== '') {
                        binding.terminal.log(dl, 'info', payload || {});
                    }
                }
                if (payload.observer_detail && typeof binding.terminal.setStatus === 'function') {
                    startObserverSyncTerminalPulse(binding.terminal);
                }
            } else if (message !== '') {
                binding.terminal.log(message, level, payload || {});
            }
            var failureDetailLines = buildRetryableFailureDetailLines(operation, payload || {});
            if (failureDetailLines.length) {
                for (var fi = 0; fi < failureDetailLines.length; fi += 1) {
                    binding.terminal.log(failureDetailLines[fi], level === 'error' ? 'error' : 'warning', payload || {});
                }
            }
            if (eventKind === 'warning' && observerBg && typeof binding.terminal.setStatus === 'function') {
                startObserverSyncTerminalPulse(binding.terminal);
            }
        }
    }

    function resolveOperationSseBaseUrl() {
        if (operationSseBaseUrl) {
            return String(operationSseBaseUrl);
        }
        try {
            var currentUrl = new URL(window.location.href);
            var normalizedPath = String(currentUrl.pathname || '').replace(/\/workspace(?:\/)?$/i, '/operation-sse');
            if (normalizedPath !== currentUrl.pathname) {
                currentUrl.pathname = normalizedPath;
                currentUrl.search = '';
                return currentUrl.toString();
            }
        } catch (error) {
            // no-op
        }
        return '';
    }

    function buildOperationUrl(executionToken) {
        var baseUrl = resolveOperationSseBaseUrl();
        if (!baseUrl || !executionToken) {
            return '';
        }
        try {
            var requestUrl = new URL(baseUrl, window.location.origin);
            requestUrl.searchParams.set('public_id', publicId);
            requestUrl.searchParams.set('execution_token', executionToken);
            return requestUrl.toString();
        } catch (error) {
            var separator = baseUrl.indexOf('?') >= 0 ? '&' : '?';
            return baseUrl
                + separator
                + 'public_id=' + encodeURIComponent(publicId)
                + '&execution_token=' + encodeURIComponent(executionToken);
        }
    }

    function resolveNestedOperationPayload(container, operation) {
        if (!container || typeof container !== 'object') {
            return null;
        }
        var normalizedOperation = String(operation || '').trim();
        var activeOperation = container.active_operation && typeof container.active_operation === 'object'
            ? container.active_operation
            : null;
        if (activeOperation && String(activeOperation.execution_token || '').trim()) {
            return activeOperation;
        }
        var activeOperations = container.active_operations && typeof container.active_operations === 'object'
            ? container.active_operations
            : null;
        if (!activeOperations) {
            return activeOperation;
        }
        if (normalizedOperation && activeOperations[normalizedOperation] && typeof activeOperations[normalizedOperation] === 'object') {
            return activeOperations[normalizedOperation];
        }
        var operationKeys = ['plan', 'build', 'publish'];
        for (var i = 0; i < operationKeys.length; i++) {
            var key = operationKeys[i];
            if (activeOperations[key] && typeof activeOperations[key] === 'object') {
                var candidateToken = String(activeOperations[key].execution_token || '').trim();
                if (candidateToken) {
                    return activeOperations[key];
                }
            }
        }
        return activeOperation;
    }

    function normalizeOperationStreamStartPayload(payload, fallbackOperation) {
        var operation = String((payload && payload.operation) || fallbackOperation || '');
        var executionToken = String((payload && payload.execution_token) || '');
        var streamUrl = String((payload && payload.stream_url) || '');
        var level1 = payload && payload.data && typeof payload.data === 'object' ? payload.data : null;
        var level2 = level1 && level1.data && typeof level1.data === 'object' ? level1.data : null;
        var activeOperationPayload = payload && payload.active_operation && typeof payload.active_operation === 'object'
            ? payload.active_operation
            : (level1 && level1.active_operation && typeof level1.active_operation === 'object' ? level1.active_operation : null);
        var nestedOperationPayload = resolveNestedOperationPayload(level1, operation)
            || resolveNestedOperationPayload(level2, operation)
            || null;

        if (!operation && activeOperationPayload) {
            operation = String(activeOperationPayload.operation || fallbackOperation || '');
        }
        if (!operation && nestedOperationPayload) {
            operation = String(nestedOperationPayload.operation || fallbackOperation || '');
        }
        if (!executionToken) {
            executionToken = String(
                (activeOperationPayload && activeOperationPayload.execution_token)
                || (nestedOperationPayload && nestedOperationPayload.execution_token)
                || (level1 && level1.execution_token)
                || ''
            );
        }
        if (!streamUrl) {
            streamUrl = String(
                (activeOperationPayload && activeOperationPayload.stream_url)
                || (nestedOperationPayload && nestedOperationPayload.stream_url)
                || (level1 && level1.stream_url)
                || ''
            );
        }

        // 若后端仅返回 stream_url，尝试反解 execution_token
        if (!executionToken && streamUrl) {
            try {
                var parsed = new URL(streamUrl, window.location.origin);
                executionToken = String(parsed.searchParams.get('execution_token') || '');
            } catch (error) {
                var matched = streamUrl.match(/[?&]execution_token=([^&]+)/);
                if (matched && matched[1]) {
                    executionToken = decodeURIComponent(String(matched[1]));
                }
            }
        }

        // 仅接受 operation-sse 作为 EventSource 目标；否则回退到本地拼装
        var streamLooksValid = false;
        if (streamUrl) {
            try {
                var normalizedUrl = new URL(streamUrl, window.location.origin);
                streamLooksValid = String(normalizedUrl.pathname || '').toLowerCase().indexOf('/operation-sse') >= 0;
            } catch (error) {
                streamLooksValid = streamUrl.toLowerCase().indexOf('/operation-sse') >= 0;
            }
        }
        if (!streamLooksValid || !streamUrl) {
            streamUrl = buildOperationUrl(executionToken);
        }

        return {
            operation: operation,
            executionToken: executionToken,
            streamUrl: streamUrl
        };
    }

    function closeOperationSource(source) {
        stopObserverSyncTerminalPulse();
        if (!source || source === runningSource) {
            stopDeferredQueueStatePoll();
        }

        if (runningSourceStartTimer) {
            window.clearTimeout(runningSourceStartTimer);
            runningSourceStartTimer = null;
        }
        var target = source || runningSource;
        if (!target) {
            return;
        }
        try {
            target.close();
        } catch (error) {
            // no-op
        }
        if (!source || target === runningSource) {
            runningSource = null;
        }
    }

    function normalizeRedirectUrlForCurrentHost(redirectUrl) {
        var raw = String(redirectUrl || '').trim();
        if (!raw) {
            return '';
        }
        try {
            var currentUrl = new URL(window.location.href);
            var parsed = new URL(raw, currentUrl.origin);
            var redirectHost = String(parsed.hostname || '').toLowerCase();
            var currentHost = String(currentUrl.hostname || '').toLowerCase();
            if (!redirectHost) {
                return parsed.toString();
            }
            var isLocalhost = redirectHost === 'localhost' || redirectHost === '127.0.0.1' || redirectHost === '::1';
            if (isLocalhost && currentHost && currentHost !== redirectHost) {
                parsed.protocol = currentUrl.protocol;
                parsed.host = currentUrl.host;
            }
            return parsed.toString();
        } catch (error) {
            return raw;
        }
    }

        function finishOperation(payload) {
        var operation = payload && payload.operation ? String(payload.operation) : '';
        if (operation === 'plan') {
            var nextState = null;
            if (payload && payload.state && typeof payload.state === 'object') {
                nextState = payload.state;
            } else if (payload && payload.data && payload.data.state && typeof payload.data.state === 'object') {
                nextState = payload.data.state;
            }
            if (nextState) {
                hydrateWorkspaceFromState(nextState);
                updateTaskSummaryFromState(nextState);
                if (nextState.virtual_pages_by_type && typeof nextState.virtual_pages_by_type === 'object') {
                    if (typeof previewBridge.setVirtualPagesByType === 'function') {
                        previewBridge.setVirtualPagesByType(nextState.virtual_pages_by_type);
                    }
                }
            }
            return;
        }
        if (operation === 'publish') {
            var publishState = null;
            if (payload && payload.state && typeof payload.state === 'object') {
                publishState = payload.state;
            } else if (payload && payload.data && payload.data.state && typeof payload.data.state === 'object') {
                publishState = payload.data.state;
            }
            if (publishState) {
                hydrateWorkspaceFromState(publishState);
                updateTaskSummaryFromState(publishState);
                updateStageStatusSummary(publishState);
            }
            return;
        }
        var redirectUrl = '';
        if (payload && payload.data && payload.data.redirect_url) {
            redirectUrl = String(payload.data.redirect_url);
        } else if (payload && payload.redirect_url) {
            redirectUrl = String(payload.redirect_url);
        }
        if (redirectUrl) {
            window.location.href = normalizeRedirectUrlForCurrentHost(redirectUrl);
            return;
        }
        window.location.reload();
    }

    function resetOperationUiOnFailure(operation) {
