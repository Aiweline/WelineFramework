        var frame = document.getElementById('pb-ai-visual-preview-frame');
        if (!frame) {
            return;
        }
        var doc;
        try {
            doc = frame.contentDocument;
        } catch (error) {
            return;
        }
        if (!doc) {
            return;
        }
        var selector = '.pb-ai-block-wrapper[data-page-type="' + blockRefreshState.pageType + '"][data-component="' + blockRefreshState.blockId + '"]';
        var wrapper = doc.querySelector(selector);
        if (!wrapper) {
            return;
        }
        if (!wrapper.style.position) {
            wrapper.style.position = 'relative';
        }
        var overlay = wrapper.querySelector('.pb-ai-inline-stream-state');
        if (!overlay) {
            overlay = doc.createElement('div');
            overlay.className = 'pb-ai-inline-stream-state';
            overlay.style.cssText = 'position:absolute;inset:18px;display:flex;align-items:center;justify-content:center;padding:18px;border-radius:18px;background:rgba(15,23,42,.78);color:#fff;font-size:14px;font-weight:600;z-index:100100;backdrop-filter:blur(8px);text-align:center;';
            wrapper.appendChild(overlay);
        }
        overlay.textContent = String(messageText || '');
    }

    function clearBlockStreamingState() {
        var frame = document.getElementById('pb-ai-visual-preview-frame');
        if (frame) {
            try {
                var doc = frame.contentDocument;
                if (doc) {
                    doc.querySelectorAll('.pb-ai-inline-stream-state').forEach(function (el) { el.remove(); });
                }
            } catch (error) {
                // no-op
            }
        }
        blockRefreshState.active = false;
        blockRefreshState.pageType = '';
        blockRefreshState.blockId = '';
    }

    function updateTaskSummaryFromState(workspaceState) {
        var summary = workspaceState && workspaceState.build_task_summary && typeof workspaceState.build_task_summary === 'object'
            ? workspaceState.build_task_summary
            : null;
        if (!summary) {
            return;
        }
        window.__pbTaskSummary = summary;
        if (typeof window.applyTaskSummarySelectionFilter === 'function') {
            window.applyTaskSummarySelectionFilter();
        }
    }

    window.applyTaskSummarySelectionFilter = function applyTaskSummarySelectionFilter() {
        var summary = window.__pbTaskSummary && typeof window.__pbTaskSummary === 'object'
            ? window.__pbTaskSummary
            : null;
        if (!summary) {
            return;
        }
        var selectedMap = Object.create(null);
        normalizeRequiredPageTypesForSummary(getSelectedPageTypesForSummary()).forEach(function (pageType) {
            selectedMap[String(pageType || '')] = true;
        });
        Object.keys(getTaskAlwaysVisiblePageTypeMapForSummary()).forEach(function (fixedType) {
            selectedMap[fixedType] = true;
        });

        var totalEl = document.getElementById('pb-ai-task-total');
        var doneEl = document.getElementById('pb-ai-task-done');
        var pendingEl = document.getElementById('pb-ai-task-pending');
        var runningEl = document.getElementById('pb-ai-task-running');

        var groupsContainer = document.getElementById('pb-ai-task-groups');
        var groups = summary.groups && typeof summary.groups === 'object' ? summary.groups : null;
        if (!groupsContainer || !groups) {
            if (totalEl) { totalEl.textContent = String(summary.total || 0); }
            if (doneEl) { doneEl.textContent = String(summary.done || 0); }
            if (pendingEl) { pendingEl.textContent = String(summary.pending || 0); }
            if (runningEl) { runningEl.textContent = String(summary.running || 0); }
            return;
        }
        var calcTotal = 0;
        var calcDone = 0;
        var calcPending = 0;
        var calcRunning = 0;
        groupsContainer.innerHTML = '';
        Object.keys(groups).forEach(function (groupKey) {
            var group = groups[groupKey];
            if (!group || typeof group !== 'object') {
                return;
            }
            var pageType = String(group.page_type || groupKey || '').trim();
            if (!selectedMap[pageType]) {
                return;
            }
            var wrapper = document.createElement('div');
            wrapper.className = 'border rounded p-2 small';
            var done = parseInt(String(group.done || 0), 10) || 0;
            var total = parseInt(String(group.total || 0), 10) || 0;
            var running = parseInt(String(group.running || 0), 10) || 0;
            var pending = Math.max(total - done - running, 0);
            calcTotal += total;
            calcDone += done;
            calcRunning += running;
            calcPending += pending;
            wrapper.innerHTML = '<div class="d-flex align-items-center justify-content-between gap-2"><strong>'
                + pageType
                + '</strong><span class="text-muted">'
                + done + '/' + total
                + '</span></div>';
            groupsContainer.appendChild(wrapper);
        });
        if (totalEl) { totalEl.textContent = String(calcTotal); }
        if (doneEl) { doneEl.textContent = String(calcDone); }
        if (pendingEl) { pendingEl.textContent = String(calcPending); }
        if (runningEl) { runningEl.textContent = String(calcRunning); }
    };

    var workspaceApiRef = window.__pbWorkspaceApi && typeof window.__pbWorkspaceApi === 'object' ? window.__pbWorkspaceApi : {};
    workspaceApiRef.updateTaskSummaryFromState = updateTaskSummaryFromState;
    workspaceApiRef.refreshWorkspaceStateFromServer = refreshWorkspaceStateFromServer;
    window.__pbWorkspaceApi = workspaceApiRef;
    window.updateTaskSummaryFromState = updateTaskSummaryFromState;

    function refreshWorkspaceStateFromServer() {
        if (!stateJsonUrl || typeof fetch !== 'function') {
            return Promise.resolve(null);
        }

        return fetch(stateJsonUrl, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        }).then(function (response) {
            return response.text().then(function (text) {
                var payload = null;
                try {
                    payload = JSON.parse(text);
                } catch (error) {
                    return null;
                }
                if (!payload || !payload.success || !payload.data || typeof payload.data !== 'object') {
                    return null;
                }
                hydrateWorkspaceFromState(payload.data);
                if (payload.data.virtual_pages_by_type && typeof payload.data.virtual_pages_by_type === 'object') {
                    if (typeof previewBridge.setVirtualPagesByType === 'function') {
                        previewBridge.setVirtualPagesByType(payload.data.virtual_pages_by_type);
                    }
                }
                if (payload.data.active_operation && typeof payload.data.active_operation === 'object') {
                    activeOperation = payload.data.active_operation;
                }
                maybePromptWorkspaceContinuation(payload.data);
                return payload.data;
            });
        }).catch(function () {
            return null;
        });
    }

    function startOperationStream(streamUrl, operation, executionToken, sourceTag) {
        if (!streamUrl) {
            return false;
        }

        var operationKey = String(operation || '') + ':' + String(executionToken || '');
        var now = Date.now();
        if (runningSource && runningOperationKey === operationKey) {
            return true;
        }
        // 同一个 operation_key 在短时间内可能会被多路触发（snapshot 自动恢复、state 拉取、手工启动返回）
        // 这里增加冷却窗口，避免出现“同一条 SSE 被接管多次”的重复连接。
        if (runningOperationKey === operationKey) {
            var lastStartedAt = parseInt(runningStartAtByOperationKey[operationKey] || 0, 10) || 0;
            if (lastStartedAt > 0 && (now - lastStartedAt) < 3000) {
                return false;
            }
        }

        if (String(operation || '') === 'build') {
            // 只有在还没有显示 build guard 时才显示（比如直接调用 startOperationStream 而不是通过 pbAiConfirmGenerateThemeContinue）
            if (buildStartupPending && document.getElementById('pb-ai-build-guard') && !document.getElementById('pb-ai-build-guard').classList.contains('d-none')) {
                // Build guard 已经显示了（由 pbAiConfirmGenerateThemeContinue 显示），不重复显示
            } else {
                buildStartupPending = true;
                if (typeof previewBridge.showBuildGuard === 'function') {
                    previewBridge.showBuildGuard(messages.buildPreparing);
                }
            }
            if (typeof previewBridge.setBuildNavigationGuard === 'function') {
                previewBridge.setBuildNavigationGuard(true);
            }
        }

        try {
            closeOperationSource();
            runningOperationKey = operationKey;
            runningStartAtByOperationKey[operationKey] = now;
            ensureWorkspaceTerminalVisible(operation);
            if (typeof previewBridge.pauseWorkspaceStream === 'function') {
                previewBridge.pauseWorkspaceStream();
            }
        } catch (preSourceError) {
            resetOperationUiOnFailure(operation);
            if (typeof previewBridge.resumeWorkspaceStream === 'function') {
                previewBridge.resumeWorkspaceStream();
            }
            return false;
        }

        var settled = false;
        var lastServerError = '';
        var source = null;
        try {
            source = new EventSource(streamUrl);
        } catch (eventSourceError) {
