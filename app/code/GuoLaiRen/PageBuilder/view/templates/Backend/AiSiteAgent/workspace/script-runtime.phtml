    function getQueuedStageDefaultMessage(operation, eventKind) {
        var kind = String(eventKind || '').toLowerCase();
        if (kind === 'total') { return 'Plan prompt generated; syncing queue progress.'; }
        if (kind === 'start') { return 'Plan generation has entered the background queue.'; }
        if (kind === 'progress') { return 'Plan generation is running in the background queue.'; }
        if (kind === 'done') { return 'Plan generation completed.'; }
        if (kind === 'error') { return 'Plan generation failed. Please retry.'; }
        if (kind === 'warning') { return 'Plan generation is waiting for the system scheduler.'; }
        return 'Plan generation state updated.';
    }

    function getQueuedStageProgressPercent(operation, payload, eventKind) {
        var percent = parseInt(String(payload && payload.progress_percent || 0), 10) || 0;
        if (percent > 0) {
            return Math.max(0, Math.min(100, percent));
        }
        var kind = String(eventKind || '').toLowerCase();
        var queueStatus = readQueueStatusFromPayload(operation, payload);
        var queueStillWaiting = !!(payload && (payload.deferred_queue_progress || payload.queue_waiting_for_scheduler))
            || ['pending', 'queued'].indexOf(queueStatus) !== -1;
        if (queueStillWaiting) { return 10; }
        if (queueStatus === 'running' || queueStatus === 'processing') { return 35; }
        if (kind === 'start') { return 12; }
        if (kind === 'progress') { return 48; }
        if (kind === 'total' || kind === 'done' || kind === 'error') { return 100; }
        if (kind === 'warning') {
            var qs = String(payload && payload.queue_status || '').toLowerCase();
            if (qs === 'running') { return 40; }
            if (qs === 'pending') { return 10; }
            return 8;
        }
        return 0;
    }

    function payloadIndicatesQueuedStageDraft(operation, payload, eventKind) {
        var normalized = String(operation || '').toLowerCase();
        var state = payload && payload.state && typeof payload.state === 'object' ? payload.state : {};
        if (normalized !== 'plan') {
