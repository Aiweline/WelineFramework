            if (payload && payload.state && typeof payload.state === 'object') {
                publishState = payload.state;
            } else if (payload && payload.data && payload.data.state && typeof payload.data.state === 'object') {
                publishState = payload.data.state;
            }
            if (publishState) {
                hydrateWorkspaceFromState(publishState);
                updateTaskSummaryFromState(publishState);
                updateStageStatusSummary(publishState);
            }
            return;
        }
        var redirectUrl = '';
        if (payload && payload.data && payload.data.redirect_url) {
            redirectUrl = String(payload.data.redirect_url);
        } else if (payload && payload.redirect_url) {
            redirectUrl = String(payload.redirect_url);
