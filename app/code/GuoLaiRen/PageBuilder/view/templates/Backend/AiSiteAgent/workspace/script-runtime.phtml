    function maybePromptToObserveRunningOperation(data) {
        if (!data || typeof data !== 'object') {
            return false;
        }
        var op = data.active_operation && typeof data.active_operation === 'object' ? data.active_operation : null;
        if (!op) {
            return false;
        }
        var opStatus = String(op.status || '');
        var opName = String(op.operation || '');
        var executionToken = String(op.execution_token || '');
        if (['queued', 'running'].indexOf(opStatus) < 0 || !executionToken || !opName) {
            return false;
        }
        if (['build', 'regenerate_page', 'publish'].indexOf(opName) < 0) {
            return false;
        }
        var operationKey = 'observe:' + opName + ':' + executionToken;
        if (resumePromptHandledByKey[operationKey]) {
            return false;
        }
        resumePromptHandledByKey[operationKey] = true;
        showWorkspaceResumeConfirm(messages.resumeRunningPrompt).then(function (confirmed) {
            if (!confirmed) {
                toast('info', messages.resumeDeferred);
                return;
            }
            disableNavigationDuringOperation();
            startOperationStream(buildOperationUrl(executionToken), opName, executionToken, 'explicitResumeRunningOperation');
        });
        return true;
    }

    function maybePromptToContinuePendingBuild(data) {
        if (!data || typeof data !== 'object') {
            return false;
        }
        var op = data.active_operation && typeof data.active_operation === 'object' ? data.active_operation : null;
        if (op && ['queued', 'running'].indexOf(String(op.status || '')) >= 0) {
            return false;
        }
        if (!data.plan_confirmed || !data.has_execution_blueprint || !data.has_pending_build_tasks || !resumeBuildUrl || !publicId) {
            return false;
        }
        var signature = '';
        if (data.scope && typeof data.scope === 'object') {
            signature = String(
                data.scope.execution_blueprint_confirmed_signature
                || data.scope.execution_blueprint_signature
                || ''
            );
        }
        var promptKey = 'pending:' + (signature || publicId);
        if (resumePromptHandledByKey[promptKey]) {
            return false;
