        var message = String(payload.message || fallback || '');
        var pageType = String(payload.page_type || '');
        var pageLabel = compactPageDisplayLabel(payload.page_label || '', pageType);
        if (pageLabel && pageType && message.indexOf(pageLabel) < 0) {
            return pageLabel + ' · ' + message;
        }
        return message;
    }

    function logOperationToWorkspaceTerminal(kind, payload, level, fallback) {
        if (!workspaceTerminal) {
            return;
        }
        var message = buildOperationTerminalMessage(payload, fallback);
        if (!message) {
            return;
        }
        var fingerprint = [
            String(kind || ''),
            String(level || ''),
            String(payload && payload.page_type || ''),
            String(payload && payload.progress_percent || ''),
            message
        ].join('|');
        if (fingerprint === lastOperationTerminalFingerprint) {
            return;
        }
        lastOperationTerminalFingerprint = fingerprint;
        workspaceTerminal.log(message, level || 'info');
    }

    function resolveOperationSseBaseUrl() {
        if (operationSseBaseUrl) {
            return String(operationSseBaseUrl);
        }
        try {
            var currentUrl = new URL(window.location.href);
            var normalizedPath = String(currentUrl.pathname || '').replace(/\/workspace(?:\/)?$/i, '/operation-sse');
            if (normalizedPath !== currentUrl.pathname) {
                currentUrl.pathname = normalizedPath;
                currentUrl.search = '';
                return currentUrl.toString();
            }
        } catch (error) {
            // no-op
        }
        return '';
    }

    function buildOperationUrl(executionToken) {
        var baseUrl = resolveOperationSseBaseUrl();
        if (!baseUrl || !executionToken) {
            return '';
        }
        try {
            var requestUrl = new URL(baseUrl, window.location.origin);
            requestUrl.searchParams.set('public_id', publicId);
            requestUrl.searchParams.set('execution_token', executionToken);
            return requestUrl.toString();
        } catch (error) {
            var separator = baseUrl.indexOf('?') >= 0 ? '&' : '?';
            return baseUrl
                + separator
                + 'public_id=' + encodeURIComponent(publicId)
                + '&execution_token=' + encodeURIComponent(executionToken);
        }
    }

    function normalizeOperationStreamStartPayload(payload, fallbackOperation) {
        var operation = String((payload && payload.operation) || fallbackOperation || '');
        var executionToken = String((payload && payload.execution_token) || '');
        var streamUrl = String((payload && payload.stream_url) || '');

        // 若后端仅返回 stream_url，尝试反解 execution_token
        if (!executionToken && streamUrl) {
            try {
                var parsed = new URL(streamUrl, window.location.origin);
                executionToken = String(parsed.searchParams.get('execution_token') || '');
            } catch (error) {
                var matched = streamUrl.match(/[?&]execution_token=([^&]+)/);
                if (matched && matched[1]) {
                    executionToken = decodeURIComponent(String(matched[1]));
                }
            }
        }

        // 仅接受 operation-sse 作为 EventSource 目标；否则回退到本地拼装
        var streamLooksValid = false;
        if (streamUrl) {
            try {
                var normalizedUrl = new URL(streamUrl, window.location.origin);
                streamLooksValid = String(normalizedUrl.pathname || '').toLowerCase().indexOf('/operation-sse') >= 0;
            } catch (error) {
                streamLooksValid = streamUrl.toLowerCase().indexOf('/operation-sse') >= 0;
            }
        }
        if (!streamLooksValid || !streamUrl) {
            streamUrl = buildOperationUrl(executionToken);
        }

        return {
            operation: operation,
            executionToken: executionToken,
            streamUrl: streamUrl
        };
    }

    function closeOperationSource(source) {
        var target = source || runningSource;
        if (!target) {
            return;
        }
        try {
            target.close();
        } catch (error) {
            // no-op
        }
        if (!source || target === runningSource) {
            runningSource = null;
        }
    }

    function normalizeRedirectUrlForCurrentHost(redirectUrl) {
        var raw = String(redirectUrl || '').trim();
        if (!raw) {
            return '';
        }
        try {
            var currentUrl = new URL(window.location.href);
            var parsed = new URL(raw, currentUrl.origin);
            var redirectHost = String(parsed.hostname || '').toLowerCase();
            var currentHost = String(currentUrl.hostname || '').toLowerCase();
            if (!redirectHost) {
                return parsed.toString();
            }
            var isLocalhost = redirectHost === 'localhost' || redirectHost === '127.0.0.1' || redirectHost === '::1';
            if (isLocalhost && currentHost && currentHost !== redirectHost) {
                parsed.protocol = currentUrl.protocol;
                parsed.host = currentUrl.host;
            }
            return parsed.toString();
        } catch (error) {
            return raw;
        }
    }

    function finishOperation(payload) {
        var redirectUrl = '';
        if (payload && payload.data && payload.data.redirect_url) {
            redirectUrl = String(payload.data.redirect_url);
        } else if (payload && payload.redirect_url) {
            redirectUrl = String(payload.redirect_url);
        }
        if (redirectUrl) {
            window.location.href = normalizeRedirectUrlForCurrentHost(redirectUrl);
            return;
        }
        window.location.reload();
    }

    function resetOperationUiOnFailure(operation) {
        if (String(operation || '') === 'build') {
