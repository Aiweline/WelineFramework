        if (workspaceTerminal && operation) {
            workspaceTerminal.log(<?= \json_encode((string)__('开始执行工作区操作：'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + String(operation), 'start');
        }
