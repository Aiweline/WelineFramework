                        <i class="mdi mdi-tune-variant me-1"></i>
                        <lang>高级：Scope JSON 编辑</lang>
                    </summary>
                    <div class="mb-3">
                        <label class="form-label" for="pb-ai-scope-full"><lang>Scope JSON（整体替换）</lang></label>
                        <textarea class="form-control font-monospace small" id="pb-ai-scope-full" rows="8"><?= htmlspecialchars($scope_preview, ENT_QUOTES, 'UTF-8') ?></textarea>
                        <div class="mt-2 d-flex gap-2 flex-wrap">
                            <button type="button" class="btn btn-primary btn-sm" id="pb-ai-replace-scope"><lang>保存 Scope</lang></button>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="pb-ai-merge-scope"><lang>合并补丁</lang></button>
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label" for="pb-ai-scope-patch"><lang>补丁 JSON（仅合并）</lang></label>
                        <textarea class="form-control font-monospace small" id="pb-ai-scope-patch" rows="4" placeholder="{}"></textarea>
                    </div>
                </details>
                <div id="pb-ai-workspace-msg" class="alert alert-danger mt-3 mb-0 d-none" role="alert"></div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><lang>事件流（最近）</lang></h5>
                <button type="button" class="btn btn-sm btn-soft-primary" id="pb-ai-reload-page">
                    <i class="mdi mdi-refresh me-1"></i>
                    <lang>刷新页面</lang>
                </button>
            </div>
            <div class="card-body p-0">
                <?php if ($events === []) { ?>
                    <p class="text-muted p-3 mb-0"><lang>尚无事件记录。</lang></p>
                <?php } else { ?>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                            <tr>
                                <th><lang>ID</lang></th>
                                <th><lang>时间</lang></th>
                                <th><lang>类型</lang></th>
                                <th><lang>负载</lang></th>
                            </tr>
                            </thead>
                            <tbody id="pb-ai-events-tbody">
                            <?php foreach ($events as $ev) {
                                $payloadJson = isset($ev['payload']) && \is_array($ev['payload'])
                                    ? (string) \json_encode($ev['payload'], \JSON_UNESCAPED_UNICODE)
                                    : '{}';
                                $eid = (int) ($ev['event_id'] ?? 0);
                                ?>
                                <tr>
                                    <td class="small text-muted"><?= $eid ?></td>
                                    <td class="text-muted small"><?= htmlspecialchars((string) ($ev['create_time'] ?? ''), ENT_QUOTES, 'UTF-8') ?></td>
                                    <td><code><?= htmlspecialchars((string) ($ev['event_type'] ?? ''), ENT_QUOTES, 'UTF-8') ?></code></td>
                                    <td class="small font-monospace text-break"><?= htmlspecialchars($payloadJson, ENT_QUOTES, 'UTF-8') ?></td>
                                </tr>
                            <?php } ?>
                            </tbody>
                        </table>
                    </div>
                <?php } ?>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <?php
        $pb_ai_sse_terminal_path = $stream_sse_path;
        $pb_ai_sse_terminal_title = htmlspecialchars(__('AI 建站事件流'), ENT_QUOTES, 'UTF-8');
        ?>
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><lang>实时事件</lang> <span class="text-muted small">(SSE)</span></h5>
                <button type="button" class="btn btn-sm btn-primary" id="pb-ai-start-sse">
                    <i class="mdi mdi-play me-1"></i>
                    <lang>连接</lang>
                </button>
            </div>
            <div class="card-body p-0">
                <w:theme:sse-terminal
                    id="pb-ai-site-agent-terminal"
                    path="pb_ai_sse_terminal_path"
                    title="pb_ai_sse_terminal_title"
                    height="280px"
                    events="start,snapshot,log,done,error,progress,warning,info"
                />
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    'use strict';
    var publicId = <?= json_encode($publicId, JSON_THROW_ON_ERROR) ?>;
    var mergeScopeUrl = <?= json_encode($mergeScopeUrl, JSON_THROW_ON_ERROR) ?>;
    var replaceScopeUrl = <?= json_encode($replaceScopeUrl, JSON_THROW_ON_ERROR) ?>;
    var setStageUrl = <?= json_encode($setStageUrl, JSON_THROW_ON_ERROR) ?>;
    var bindLinksUrl = <?= json_encode($bindLinksUrl, JSON_THROW_ON_ERROR) ?>;
    var streamBaseUrl = <?= json_encode($streamBaseUrl, JSON_THROW_ON_ERROR) ?>;
    var lastEventId = <?= (int) $last_event_id ?>;
    var queryDomainUrl = <?= json_encode($query_domain_status_url, JSON_THROW_ON_ERROR) ?>;
    var aiBriefUrl = <?= json_encode($ai_generate_brief_url, JSON_THROW_ON_ERROR) ?>;
    var publishCheckUrl = <?= json_encode($publish_check_url, JSON_THROW_ON_ERROR) ?>;

    function setDomainStatusPre(text) {
        ['pb-ai-domain-status-out', 'pb-ai-domain-status-out-wait'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.textContent = text;
                el.classList.remove('d-none');
            }
        });
    }

    var msgBox = document.getElementById('pb-ai-workspace-msg');
    function showErr(msg) {
        if (window.BackendToast && typeof BackendToast.error === 'function') {
            BackendToast.error(msg);
        }
        if (msgBox) {
            msgBox.textContent = msg;
            msgBox.classList.remove('d-none');
        }
    }
    function clearMsg() {
        if (msgBox) {
            msgBox.classList.add('d-none');
            msgBox.textContent = '';
        }
    }
    function postForm(url, fields) {
        var fd = new FormData();
        Object.keys(fields).forEach(function (k) {
            fd.append(k, fields[k]);
        });
        return fetch(url, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (r) { return r.json(); });
    }

    var saveStageBtn = document.getElementById('pb-ai-save-stage');
    var stageSelect = document.getElementById('pb-ai-stage-select');
    if (saveStageBtn && stageSelect) {
        saveStageBtn.addEventListener('click', function () {
            clearMsg();
            postForm(setStageUrl, { public_id: publicId, stage: stageSelect.value }).then(function (data) {
                if (data && data.success) {
                    var el = document.getElementById('pb-ai-display-stage');
                    if (el) el.textContent = data.stage || stageSelect.value;
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('已保存'), JSON_THROW_ON_ERROR) ?>);
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var bindBtn = document.getElementById('pb-ai-bind-links');
    var bindWebsite = document.getElementById('pb-ai-bind-website');
    var bindTheme = document.getElementById('pb-ai-bind-theme');
    if (bindBtn && bindWebsite && bindTheme) {
        bindBtn.addEventListener('click', function () {
            clearMsg();
            var wid = parseInt(bindWebsite.value, 10) || 0;
            var tid = parseInt(bindTheme.value, 10) || 0;
            postForm(bindLinksUrl, {
                public_id: publicId,
                website_id: String(wid),
                weline_theme_id: String(tid)
            }).then(function (data) {
                if (data && data.success) {
                    var wEl = document.getElementById('pb-ai-display-website');
                    var tEl = document.getElementById('pb-ai-display-theme');
                    if (wEl) wEl.textContent = String(data.website_id || 0);
                    if (tEl) tEl.textContent = String(data.weline_theme_id || 0);
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('已保存'), JSON_THROW_ON_ERROR) ?>);
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var fullTa = document.getElementById('pb-ai-scope-full');
    var patchTa = document.getElementById('pb-ai-scope-patch');
    var replaceBtn = document.getElementById('pb-ai-replace-scope');
    var mergeBtn = document.getElementById('pb-ai-merge-scope');
    if (replaceBtn && fullTa) {
        replaceBtn.addEventListener('click', function () {
            clearMsg();
            postForm(replaceScopeUrl, { public_id: publicId, scope: fullTa.value }).then(function (data) {
                if (data && data.success) {
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('Scope 已保存'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }
    if (mergeBtn && patchTa) {
        mergeBtn.addEventListener('click', function () {
            clearMsg();
            postForm(mergeScopeUrl, { public_id: publicId, scope_patch: patchTa.value }).then(function (data) {
                if (data && data.success) {
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('已合并'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var reloadBtn = document.getElementById('pb-ai-reload-page');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', function () { window.location.reload(); });
    }

    function mergeScopePatch(patch) {
        return postForm(mergeScopeUrl, {
            public_id: publicId,
            scope_patch: JSON.stringify(patch)
        });
    }
    function applyStageOnly(stage) {
        return postForm(setStageUrl, { public_id: publicId, stage: stage });
    }

    document.querySelectorAll('.pb-ai-wizard-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var st = btn.getAttribute('data-wizard-stage');
            if (!st) return;
            document.querySelectorAll('.pb-ai-wizard-tab').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            document.querySelectorAll('.pb-ai-wizard-panel').forEach(function (p) {
                var match = p.getAttribute('data-wizard-panel') === st;
                p.classList.toggle('d-none', !match);
            });
        });
    });

    document.querySelectorAll('.pb-ai-wiz-apply-stage').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var st = btn.getAttribute('data-stage');
            if (!st) return;
            clearMsg();
            applyStageOnly(st).then(function (data) {
                if (data && data.success) {
                    var el = document.getElementById('pb-ai-display-stage');
                    if (el) el.textContent = st;
                    if (stageSelect) stageSelect.value = st;
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('阶段已更新'), JSON_THROW_ON_ERROR) ?>);
                    // 同步切换步骤 UI，避免只改了 scope 但界面仍停留在旧面板
                    document.querySelectorAll('.pb-ai-wizard-tab').forEach(function (b) {
                        var bs = b.getAttribute('data-wizard-stage');
                        b.classList.toggle('active', bs === st);
                    });
                    document.querySelectorAll('.pb-ai-wizard-panel').forEach(function (p) {
                        var match = p.getAttribute('data-wizard-panel') === st;
                        p.classList.toggle('d-none', !match);
                    });
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    });

    function runQueryDomain() {
        clearMsg();
        var domInput = document.getElementById('wiz-target-domain');
        var domain = domInput ? domInput.value.trim() : '';
        postForm(queryDomainUrl, { public_id: publicId, domain: domain }).then(function (data) {
            if (data && data.success) {
                try {
                    setDomainStatusPre(JSON.stringify(data.data ?? {}, null, 2));
                } catch (e) {
                    setDomainStatusPre(String(data.data));
                }
                if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('已更新域名状态'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            showErr((data && data.message) ? data.message : <?= json_encode(__('查询失败'), JSON_THROW_ON_ERROR) ?>);
        }).catch(function () {
            showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
        });
    }

    var qdBtn = document.getElementById('pb-ai-query-domain');
    var qdWaitBtn = document.getElementById('pb-ai-query-domain-wait');
    if (qdBtn) qdBtn.addEventListener('click', runQueryDomain);
    if (qdWaitBtn) qdWaitBtn.addEventListener('click', runQueryDomain);
    var autoPollBtn = document.getElementById('pb-ai-auto-domain-toggle');
    var autoTimer = null;
    if (autoPollBtn) {
        autoPollBtn.addEventListener('click', function () {
            var running = autoPollBtn.getAttribute('data-running') === '1';
            if (running) {
                if (autoTimer) clearInterval(autoTimer);
                autoTimer = null;
                autoPollBtn.setAttribute('data-running', '0');
                autoPollBtn.innerHTML = '<i class="mdi mdi-timer-outline me-1"></i><?= addslashes(__('自动轮询（10秒）')) ?>';
                if (window.BackendToast && BackendToast.info) BackendToast.info(<?= json_encode(__('已停止轮询'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            runQueryDomain();
            autoTimer = setInterval(runQueryDomain, 10000);
            autoPollBtn.setAttribute('data-running', '1');
            autoPollBtn.innerHTML = '<i class="mdi mdi-pause-circle-outline me-1"></i><?= addslashes(__('停止轮询')) ?>';
            if (window.BackendToast && BackendToast.info) BackendToast.info(<?= json_encode(__('已开启轮询'), JSON_THROW_ON_ERROR) ?>);
        });
    }

    var genBriefBtn = document.getElementById('pb-ai-gen-brief');
    if (genBriefBtn) {
        genBriefBtn.addEventListener('click', function () {
            clearMsg();
            var hintsEl = document.getElementById('wiz-brief-desc');
            var hints = hintsEl ? hintsEl.value.trim() : '';
            postForm(aiBriefUrl, { public_id: publicId, hints: hints }).then(function (data) {
                if (data && data.success) {
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('AI 简报已写入'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('生成失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var publishCheckBtn = document.getElementById('pb-ai-publish-check');
    var publishOut = document.getElementById('pb-ai-publish-check-out');
    if (publishCheckBtn) {
        publishCheckBtn.addEventListener('click', function () {
            clearMsg();
            postForm(publishCheckUrl, { public_id: publicId }).then(function (data) {
                if (data && data.success) {
                    var text = '';
                    try {
                        text = JSON.stringify(data.data ?? {}, null, 2);
                    } catch (e) {
                        text = String(data.data);
                    }
                    if (publishOut) {
                        publishOut.textContent = text;
                        publishOut.classList.remove('d-none');
                    }
                    if (window.BackendToast && BackendToast.success) {
                        BackendToast.success((data.data && data.data.passed) ? <?= json_encode(__('发布检查通过'), JSON_THROW_ON_ERROR) ?> : <?= json_encode(__('发布检查存在缺项'), JSON_THROW_ON_ERROR) ?>);
                    }
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('检查失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    document.querySelectorAll('.pb-ai-wiz-save').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var step = btn.getAttribute('data-wizard-save');
            var patch = {};
            if (step === 'brief') {
                var t = document.getElementById('wiz-site-title');
                var g = document.getElementById('wiz-site-tagline');
                var d = document.getElementById('wiz-brief-desc');
                patch.site_title = t ? t.value.trim() : '';
                patch.site_tagline = g ? g.value.trim() : '';
                patch.brief_description = d ? d.value.trim() : '';
            } else if (step === 'domain') {
                var dom = document.getElementById('wiz-target-domain');
                var n = document.getElementById('wiz-domain-notes');
                patch.target_domain = dom ? dom.value.trim() : '';
                patch.domain_notes = n ? n.value.trim() : '';
            } else if (step === 'virtual_theme') {
                var h = document.getElementById('wiz-theme-hint');
                patch.virtual_theme_notes = h ? h.value.trim() : '';
            } else if (step === 'page_types') {
                var pt = document.getElementById('wiz-page-types');
                var raw = pt ? pt.value : '';
                patch.page_types = raw.split(/[,，]/).map(function (s) { return s.trim(); }).filter(Boolean);
            } else if (step === 'content') {
                var c = document.getElementById('wiz-content-notes');
                patch.content_notes = c ? c.value.trim() : '';
            } else if (step === 'visual_edit') {
                var pidEl = document.getElementById('wiz-preview-page-id');
                var pid = pidEl ? parseInt(pidEl.value, 10) : 0;
                patch.preview_page_id = isNaN(pid) ? 0 : Math.max(0, pid);
            } else {
                return;
            }
            clearMsg();
            mergeScopePatch(patch).then(function (data) {
                if (data && data.success) {
                    if (window.BackendToast && BackendToast.success) BackendToast.success(<?= json_encode(__('已保存'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                showErr((data && data.message) ? data.message : <?= json_encode(__('保存失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                showErr(<?= json_encode(__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    });

    var sseBtn = document.getElementById('pb-ai-start-sse');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['pb-ai-site-agent-terminal'] : null;
    if (sseBtn && terminal) {
        sseBtn.addEventListener('click', function () {
            clearMsg();
            var sep = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + sep + 'public_id=' + encodeURIComponent(publicId) + '&last_event_id=' + encodeURIComponent(String(lastEventId));
            terminal.clear();
            terminal.setUrl(url);
            sseBtn.disabled = true;
            terminal.start();
            terminal.on('done', function () { sseBtn.disabled = false; });
            terminal.on('error', function () { sseBtn.disabled = false; });
        });
    }
})();
</script>
