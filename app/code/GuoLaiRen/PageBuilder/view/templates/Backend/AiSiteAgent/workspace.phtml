        } catch (error) {
            var separator = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + separator + 'public_id=' + encodeURIComponent(publicId);
            url += '&lease_token=' + encodeURIComponent(streamLeaseToken);
            if (lastEventId > 0) {
                url += '&last_event_id=' + encodeURIComponent(String(lastEventId));
            }
            return url;
        }
    }

    function touchStreamLease() {
        if (!touchStreamLeaseUrl || !publicId || !streamLeaseToken) {
            return Promise.resolve({ success: false });
        }
        return postLeaseForm(touchStreamLeaseUrl, {
            public_id: publicId,
            lease_token: streamLeaseToken
