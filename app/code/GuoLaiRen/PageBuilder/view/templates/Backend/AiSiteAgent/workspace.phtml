    }
    if ($optLabel === '') {
        $optLabel = (string)$optAccountId;
    }
    $registrarSelectOptions[] = [
        'value' => (string)$optAccountId,
        'label' => $optLabel,
        'group' => $registrarName !== '' ? $registrarName : (string)__('其他'),
        'meta' => (string)($account['registrar_code'] ?? ''),
