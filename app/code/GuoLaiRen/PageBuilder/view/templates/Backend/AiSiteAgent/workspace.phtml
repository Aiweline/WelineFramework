<script>
(function () {
    'use strict';
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['pagebuilder-workspace-terminal'] : null;
    var publicId = <?= \json_encode($publicId, \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var streamBaseUrl = <?= \json_encode($streamSseUrl, \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var lastEventId = <?= (int)$initialLastEventId ?>;
    var reconnectTimer = null;
    var reconnectAttempts = 0;
    var reconnectAttemptsMax = 20;
    var seenEventIds = [];
    var seenEventIdMap = Object.create(null);
    var recentSignalMap = Object.create(null);
    var suppressTransportErrorUntil = 0;
    var hasActiveOperation = false;
    var lastActivityTime = Date.now();

    if (!terminal || !streamBaseUrl || !publicId) {
        return;
    }

    function parseSsePayload(event) {
        if (!event || typeof event.data !== 'string' || event.data === '') {
            return {};
        }
        try { return JSON.parse(event.data); } catch (error) { return {}; }
    }

    function buildWorkspaceStreamUrl() {
        try {
            var requestUrl = new URL(streamBaseUrl, window.location.origin);
            requestUrl.searchParams.set('public_id', publicId);
            if (lastEventId > 0) {
                requestUrl.searchParams.set('last_event_id', String(lastEventId));
            } else {
                requestUrl.searchParams.delete('last_event_id');
            }
            return requestUrl.toString();
        } catch (error) {
            var separator = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + separator + 'public_id=' + encodeURIComponent(publicId);
            if (lastEventId > 0) {
                url += '&last_event_id=' + encodeURIComponent(String(lastEventId));
            }
            return url;
        }
    }

    function formatWorkspaceLog(entry) {
        var payload = entry && entry.payload && typeof entry.payload === 'object' ? entry.payload : {};
        var stageLabel = payload.stage_label || payload.stage_code || entry.stage_code || '';
        var message = payload.message || entry.message || entry.event_type || '';
        if (!message && payload.operation) {
            message = String(payload.operation);
        }
        return stageLabel ? (stageLabel + ': ' + message) : message;
    }

    function rememberEventId(eventId) {
        if (!eventId || seenEventIdMap[eventId]) {
            return;
        }
        seenEventIdMap[eventId] = true;
        seenEventIds.push(eventId);
        if (seenEventIds.length > 400) {
            var removedEventId = seenEventIds.shift();
            if (removedEventId) {
                delete seenEventIdMap[removedEventId];
            }
        }
    }

    function isDuplicateSignal(kind, payload) {
        var message = payload && payload.message ? String(payload.message) : '';
        var cursor = payload && payload.last_event_id ? String(payload.last_event_id) : '';
        var fingerprint = kind + '|' + cursor + '|' + message;
        var now = Date.now();
        var lastSeenAt = recentSignalMap[fingerprint] || 0;
        recentSignalMap[fingerprint] = now;
        Object.keys(recentSignalMap).forEach(function (key) {
            if (now - recentSignalMap[key] > 5000) {
                delete recentSignalMap[key];
            }
        });
        return lastSeenAt > 0 && (now - lastSeenAt) < 2000;
    }

    function scheduleReconnect() {
        if (reconnectTimer || reconnectAttempts >= reconnectAttemptsMax) {
            return;
        }
        reconnectAttempts++;

        // 动态调整重连延迟：
        // - 长连接模式下，正常断开后立即重连（500ms）
        // - 错误断开时延迟重连（2 秒）
        var reconnectDelay = 500;

        reconnectTimer = window.setTimeout(function () {
            reconnectTimer = null;
            if (terminal.isRunning()) {
                return;
            }
            var nextUrl = buildWorkspaceStreamUrl();
            if (!nextUrl) {
                return;
            }
            terminal.setUrl(nextUrl);
            terminal.start(nextUrl);
        }, reconnectDelay);
    }

    terminal.on('snapshot', function (event) {
        var data = parseSsePayload(event);
        if (!Array.isArray(data.events)) {
            return;
        }
        data.events.forEach(function (entry) {
            var eventId = parseInt(entry && entry.event_id ? entry.event_id : 0, 10) || 0;
            if (eventId > lastEventId) {
                lastEventId = eventId;
            }
            rememberEventId(eventId);
        });

        // 检查是否有活动操作
        if (data.active_operation && typeof data.active_operation === 'object') {
            var opStatus = String(data.active_operation.status || '');
            hasActiveOperation = (opStatus === 'queued' || opStatus === 'running');
            if (hasActiveOperation) {
                lastActivityTime = Date.now();
            }
        }
    });

    terminal.on('log', function (event) {
        var entry = parseSsePayload(event);
        if (!entry || typeof entry !== 'object') {
            return;
        }
        var eventId = parseInt(entry.event_id || 0, 10) || 0;
        if (eventId > 0 && seenEventIdMap[eventId]) {
            return;
        }
        if (eventId > lastEventId) {
            lastEventId = eventId;
        }
        rememberEventId(eventId);
        terminal.log(formatWorkspaceLog(entry), entry.level || 'info');

        // 检测到新事件，标记为有活动
        lastActivityTime = Date.now();

        // 检查事件类型，判断是否有活动操作
        var eventType = String(entry.event_type || '');
        if (eventType === 'operation_started' || eventType === 'operation_progress') {
            hasActiveOperation = true;
        } else if (eventType === 'operation_completed' || eventType === 'operation_failed') {
            hasActiveOperation = false;
        }
    });

    terminal.on('done', function (event) {
        var data = parseSsePayload(event);
        if (isDuplicateSignal('done', data)) {
            return;
        }
        if (data && data.last_event_id) {
            lastEventId = parseInt(data.last_event_id, 10) || lastEventId;
        }
        reconnectAttempts = 0;
        suppressTransportErrorUntil = Date.now() + 1500;
        if (data && data.message) {
            terminal.log(data.message, 'done');
        }
        scheduleReconnect();
    });

    terminal.on('error', function (event) {
        var data = parseSsePayload(event);
        if (!data.message && Date.now() < suppressTransportErrorUntil) {
            return;
        }
        if (isDuplicateSignal('error', data)) {
            return;
        }
        var message = (data && data.message) ? String(data.message) : '';
        if (message) {
            terminal.log(message, 'error');
            if (message.indexOf('会话不存在') >= 0 || message.indexOf('无访问权限') >= 0 || message.indexOf('参数无效') >= 0) {
                reconnectAttempts = 0;
                return;
            }
        }
        // 错误时延迟 2 秒重连
        reconnectTimer = window.setTimeout(function () {
            reconnectTimer = null;
            if (terminal.isRunning()) {
                return;
            }
            var nextUrl = buildWorkspaceStreamUrl();
            if (!nextUrl) {
                return;
            }
            terminal.setUrl(nextUrl);
            terminal.start(nextUrl);
        }, 2000);
    });

    var initialStreamUrl = buildWorkspaceStreamUrl();
