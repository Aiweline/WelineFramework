            target.close();
        } catch (error) {
            // no-op
        }
        if (!source || target === runningSource) {
            runningSource = null;
        }
    }

    function finishOperation(payload) {
        var redirectUrl = '';
        if (payload && payload.data && payload.data.redirect_url) {
            redirectUrl = String(payload.data.redirect_url);
        } else if (payload && payload.redirect_url) {
            redirectUrl = String(payload.redirect_url);
        }
        if (redirectUrl) {
            window.location.href = redirectUrl;
            return;
        }
        window.location.reload();
    }

    function resetOperationUiOnFailure(operation) {
        if (String(operation || '') === 'build') {
            if (typeof previewBridge.resetBuildStartUi === 'function') {
                previewBridge.resetBuildStartUi();
            }
        }
        if (String(operation || '') === 'publish') {
            var publishBtn = document.getElementById('pb-ai-start-publish');
            if (publishBtn) {
                publishBtn.disabled = false;
            }
            document.querySelectorAll('.pb-ai-start-publish-shortcut').forEach(function (btn) {
                btn.disabled = false;
            });
        }
        clearBlockStreamingState();
    }

    function renderBlockStreamingState(messageText) {
        if (!blockRefreshState.active || !blockRefreshState.pageType || !blockRefreshState.blockId) {
            return;
        }
        var frame = document.getElementById('pb-ai-visual-preview-frame');
        if (!frame) {
            return;
        }
        var doc;
        try {
            doc = frame.contentDocument;
        } catch (error) {
            return;
        }
        if (!doc) {
            return;
        }
        var selector = '.pb-ai-block-wrapper[data-page-type="' + blockRefreshState.pageType + '"][data-component="' + blockRefreshState.blockId + '"]';
        var wrapper = doc.querySelector(selector);
        if (!wrapper) {
            return;
        }
        if (!wrapper.style.position) {
            wrapper.style.position = 'relative';
        }
        var overlay = wrapper.querySelector('.pb-ai-inline-stream-state');
        if (!overlay) {
            overlay = doc.createElement('div');
            overlay.className = 'pb-ai-inline-stream-state';
            overlay.style.cssText = 'position:absolute;inset:18px;display:flex;align-items:center;justify-content:center;padding:18px;border-radius:18px;background:rgba(15,23,42,.78);color:#fff;font-size:14px;font-weight:600;z-index:100100;backdrop-filter:blur(8px);text-align:center;';
            wrapper.appendChild(overlay);
        }
        overlay.textContent = String(messageText || '');
    }

    function clearBlockStreamingState() {
        var frame = document.getElementById('pb-ai-visual-preview-frame');
        if (frame) {
            try {
                var doc = frame.contentDocument;
                if (doc) {
                    doc.querySelectorAll('.pb-ai-inline-stream-state').forEach(function (el) { el.remove(); });
                }
            } catch (error) {
                // no-op
            }
        }
        blockRefreshState.active = false;
        blockRefreshState.pageType = '';
        blockRefreshState.blockId = '';
    }

    function startOperationStream(streamUrl, operation, executionToken) {
        if (!streamUrl) {
            return false;
        }

        var operationKey = String(operation || '') + ':' + String(executionToken || '');
        if (runningSource && runningOperationKey === operationKey) {
            return true;
        }

        closeOperationSource();
        runningOperationKey = operationKey;
        ensureWorkspaceTerminalVisible(operation);
        if (typeof previewBridge.pauseWorkspaceStream === 'function') {
            previewBridge.pauseWorkspaceStream();
        }

        var settled = false;
        var lastServerError = '';
        var source = new EventSource(streamUrl);
        runningSource = source;

        source.addEventListener('start', function (event) {
            logOperationToWorkspaceTerminal('start', parsePayload(event), 'start', <?= \json_encode((string)__('工作区操作已启动'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
        });

        source.addEventListener('error', function (event) {
            var payload = parsePayload(event);
            if (payload && payload.message) {
                lastServerError = String(payload.message);
                if (Array.isArray(payload.required_params) && payload.required_params.length > 0) {
                    lastServerError += ' [' + payload.required_params.join(', ') + ']';
                }
                logOperationToWorkspaceTerminal('error', payload, 'error', payload.message);
            }
        });

        source.addEventListener('progress', function (event) {
            var payload = parsePayload(event);
            if (!payload || !payload.message) {
                return;
            }
            logOperationToWorkspaceTerminal('progress', payload, 'progress', payload.message);

            if (window.PbAiWorkspacePreview && payload.page_type) {
                var progressPercent = parseInt(payload.progress_percent || 0, 10) || 0;
                var messageText = progressPercent > 0
                    ? (<?= \json_encode((string)__('生成中'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + ' ' + progressPercent + '%')
                    : String(payload.message);
                window.PbAiWorkspacePreview.markPageGenerationStatus(String(payload.page_type), 'running', messageText);
                if (blockRefreshState.active && String(payload.page_type || '') === String(blockRefreshState.pageType || '')) {
                    renderBlockStreamingState(messageText);
                }
            }

            // 实时更新预览 iframe（如果存在）
            var previewFrame = document.getElementById('pb-ai-visual-preview-frame');
            if (previewFrame && payload.page_type && payload.progress_percent >= 100 && !blockRefreshState.active) {
                // 页面生成完成，刷新预览
                window.setTimeout(function() {
                    if (previewFrame.src) {
                        previewFrame.src = previewFrame.src;
                    }
                }, 500);
            }
        });

        source.addEventListener('page_generated', function (event) {
            var payload = parsePayload(event);
            if (!payload || !payload.page_type) {
                return;
            }
            logOperationToWorkspaceTerminal('page_generated', payload, 'done', <?= \json_encode((string)__('页面已完成真实 AI 生成'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);

            if (window.PbAiWorkspacePreview) {
                var pageType = String(payload.page_type);
                var pageLabel = String(payload.page_label || pageTypeLabelMap[pageType] || pageType);
                var pageId = parseInt(payload.page_id || 0, 10) || 0;
                window.PbAiWorkspacePreview.upsertPreviewTab(pageType, pageLabel, pageId, true);
                window.PbAiWorkspacePreview.markPageGenerationStatus(pageType, 'done', <?= \json_encode((string)__('已生成'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                window.PbAiWorkspacePreview.switchPreviewByType(pageType);
            }

            // 页面生成完成，实时刷新预览
            var previewFrame = document.getElementById('pb-ai-visual-preview-frame');
            if (previewFrame && previewFrame.src && !blockRefreshState.active) {
                window.setTimeout(function() {
                    // 刷新 iframe 以显示新生成的页面
                    previewFrame.src = previewFrame.src;
                }, 800);
            }

            // 显示页面生成完成的提示
            var pageLabel = payload.page_label || payload.page_type;
            toast('success', <?= \json_encode((string)__('页面已生成：'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + pageLabel);
        });

        source.addEventListener('done', function (event) {
            if (settled) {
                return;
            }
            settled = true;
            var payload = parsePayload(event);
            closeOperationSource(source);

            var success = !payload || payload.success !== false;
            if (!success) {
                logOperationToWorkspaceTerminal('done_error', payload, 'error', lastServerError || '工作区操作执行失败');
                toast('error', (payload && payload.message) ? String(payload.message) : lastServerError || <?= \json_encode((string)__('操作执行失败'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                resetOperationUiOnFailure(operation);
                if (typeof previewBridge.resumeWorkspaceStream === 'function') {
                    previewBridge.resumeWorkspaceStream();
                }
                return;
            }

            toast('success', (payload && payload.message) ? String(payload.message) : <?= \json_encode((string)__('操作执行完成'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
            logOperationToWorkspaceTerminal('done', payload, 'done', '工作区操作执行完成');
            if (
                blockRefreshState.active
                && String(operation || '') === 'regenerate_page'
                && payload
                && payload.state
                && payload.state.virtual_pages_by_type
            ) {
                if (typeof previewBridge.setVirtualPagesByType === 'function') {
                    previewBridge.setVirtualPagesByType(payload.state.virtual_pages_by_type);
                }
                var pageState = payload.state.virtual_pages_by_type[blockRefreshState.pageType] || null;
                var nextBlock = pageState && Array.isArray(pageState.blocks)
                    ? pageState.blocks.find(function (item) { return String(item.block_id || '') === String(blockRefreshState.blockId || ''); })
                    : null;
                if (nextBlock) {
                    if (typeof previewBridge.updateVirtualBlockState === 'function') {
                        previewBridge.updateVirtualBlockState(blockRefreshState.pageType, nextBlock);
                    }
                    var replaced = typeof previewBridge.replaceCurrentBlockHtml === 'function'
                        ? previewBridge.replaceCurrentBlockHtml(blockRefreshState.pageType, nextBlock)
                        : false;
                    if (replaced && typeof previewBridge.bindEmbeddedPreviewFrameBridge === 'function') {
                        previewBridge.bindEmbeddedPreviewFrameBridge();
                    }
                    clearBlockStreamingState();
                    if (replaced) {
                        if (typeof previewBridge.resumeWorkspaceStream === 'function') {
                            previewBridge.resumeWorkspaceStream();
                        }
                        return;
                    }
                }
            }
            clearBlockStreamingState();
            if (typeof previewBridge.resumeWorkspaceStream === 'function') {
                previewBridge.resumeWorkspaceStream();
            }
            finishOperation(payload);
        });

        source.onerror = function () {
            if (settled) {
                return;
            }
            if (lastServerError) {
                toast('error', lastServerError);
                settled = true;
                closeOperationSource(source);
                resetOperationUiOnFailure(operation);
                if (typeof previewBridge.resumeWorkspaceStream === 'function') {
                    previewBridge.resumeWorkspaceStream();
                }
            }
        };

        return true;
    }

    function startFromResponse(data, fallbackOperation) {
        if (!data || !data.success) {
            return false;
        }
        var executionToken = String(data.execution_token || '');
        var operation = String(data.operation || fallbackOperation || '');
        var streamUrl = String(data.stream_url || buildOperationUrl(executionToken));
        if (!executionToken || !streamUrl) {
            var missing = [];
            if (!executionToken) {
                missing.push('execution_token');
            }
            if (!streamUrl) {
                missing.push('stream_url');
            }
            toast('error', <?= \json_encode((string)__('操作已创建但缺少 SSE 参数'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + ': ' + missing.join(', '));
            return false;
        }
        return startOperationStream(streamUrl, operation, executionToken);
    }

    window.PbAiOperationRunner = {
        startFromResponse: startFromResponse
    };

    function startPublishFlow(triggerButton) {
        if (!startPublishUrl || (triggerButton && triggerButton.disabled)) {
            return;
        }
        if (triggerButton) {
            triggerButton.disabled = true;
        }
        postForm(startPublishUrl, { public_id: publicId }).then(function (data) {
            if (!data || !data.success) {
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                toast('error', (data && data.message) ? String(data.message) : <?= \json_encode((string)__('启动发布失败'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                return;
            }
            if (!startFromResponse(data, 'publish')) {
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                toast('error', messages.operationStreamMissing);
            }
        }).catch(function () {
            if (triggerButton) {
                triggerButton.disabled = false;
            }
            toast('error', <?= \json_encode((string)__('网络错误，请稍后重试'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
        });
    }

    function checkBeforePublishAndStart(triggerButton) {
        if (!publishCheckUrl) {
            startPublishFlow(triggerButton);
            return;
        }
        if (triggerButton) {
            triggerButton.disabled = true;
        }
        postForm(publishCheckUrl, { public_id: publicId }).then(function (checkData) {
            var payload = checkData && checkData.data && typeof checkData.data === 'object' ? checkData.data : {};
            var passed = !!(payload && payload.passed);
            if (!passed) {
                if (triggerButton) {
                    triggerButton.disabled = false;
                }
                var items = Array.isArray(payload.items) ? payload.items : [];
                var siteReadyItem = null;
                var firstFailedItem = null;
                items.forEach(function (item) {
                    if (!item || typeof item !== 'object') {
                        return;
                    }
                    if (String(item.key || '') === 'site_ready') {
                        siteReadyItem = item;
                    }
                    if (!firstFailedItem && !item.ok) {
                        firstFailedItem = item;
                    }
                });
                if (siteReadyItem && !siteReadyItem.ok) {
                    toast('warning', <?= \json_encode((string)__('域名尚未就绪，请先等待域名流程完成后再确认建站。'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                    return;
                }
                if (firstFailedItem && firstFailedItem.label) {
                    toast('warning', <?= \json_encode((string)__('发布前仍有未完成项：'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?> + String(firstFailedItem.label));
                    return;
                }
                toast('warning', <?= \json_encode((string)__('发布前检查未通过，请先完成页面与配置。'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
                return;
            }
            startPublishFlow(triggerButton);
        }).catch(function () {
            if (triggerButton) {
                triggerButton.disabled = false;
            }
            toast('error', <?= \json_encode((string)__('网络错误，请稍后重试'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>);
        });
    }

    var publishBtn = document.getElementById('pb-ai-start-publish');
    if (publishBtn) {
        publishBtn.addEventListener('click', function () {
            checkBeforePublishAndStart(publishBtn);
        });
    }

    document.querySelectorAll('.pb-ai-start-publish-shortcut').forEach(function (btn) {
        btn.addEventListener('click', function () {
            checkBeforePublishAndStart(btn);
        });
    });

    if (
        activeOperation
        && typeof activeOperation === 'object'
        && ['queued', 'running'].indexOf(String(activeOperation.status || '')) >= 0
        && String(activeOperation.execution_token || '') !== ''
    ) {
        startOperationStream(
            buildOperationUrl(String(activeOperation.execution_token || '')),
            String(activeOperation.operation || ''),
            String(activeOperation.execution_token || '')
        );
    }
})();
</script>
