));
if ($sessionResolvedTargetDomain === '' && \is_array($scope['recommended_domain_list'] ?? null)) {
    foreach ($scope['recommended_domain_list'] as $candidate) {
        $c = \trim(\is_string($candidate) ? $candidate : (string)$candidate);
        if ($c !== '') {
            $sessionResolvedTargetDomain = \strtolower($c);
            break;
        }
    }
}

/** 阶段一建站方案是否已在会话中存在（用于方案1确认后直接进入构建的门闩） */
