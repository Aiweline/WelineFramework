if ($selectedPageTypes === []) {
    $selectedPageTypes = ['home_page'];
}
$selectedPageTypesSafe = \is_array($selectedPageTypes ?? null) ? $selectedPageTypes : ['home_page'];
$pageTypesUserCustomizedRaw = $scope['page_types_user_customized'] ?? null;
if (\is_bool($pageTypesUserCustomizedRaw)) {
    $pageTypesUserCustomized = $pageTypesUserCustomizedRaw;
} elseif (\is_int($pageTypesUserCustomizedRaw) || \is_float($pageTypesUserCustomizedRaw)) {
    $pageTypesUserCustomized = (int)$pageTypesUserCustomizedRaw === 1;
} elseif (\is_string($pageTypesUserCustomizedRaw)) {
    $pageTypesUserCustomized = \in_array(\strtolower(\trim($pageTypesUserCustomizedRaw)), ['1', 'true', 'yes', 'on'], true);
} else {
    $pageTypesUserCustomized = false;
}
$pageTypeLabels = $this->getData('page_type_labels');
$pageTypeLabels = \is_array($pageTypeLabels) ? $pageTypeLabels : [];
if ($pageTypeLabels === []) {
    $pageTypeLabels = \GuoLaiRen\PageBuilder\Model\Page::getPageTypes();
}
if ($pageTypeLabels === []) {
    $pageTypeLabels = [
        'home_page' => (string)__('首页'),
        'about_page' => (string)__('关于我们'),
        'contact_page' => (string)__('联系我们'),
    ];
}
$virtualPagesByType = \is_array($state['virtual_pages_by_type'] ?? null) ? $state['virtual_pages_by_type'] : [];
