    &$domainChoiceTags,
    &$domainChoiceSeen,
    $domainChoiceRegistrarLabels,
    $domainChoiceSelectedRegistrarLabel
): void {
    $domain = \strtolower(\trim($domain));
    if ($domain === '') {
        return;
    }
    $accountId = $accountId > 0 ? $accountId : 0;
    $key = $accountId . '|' . $domain;
    if (isset($domainChoiceSeen[$key])) {
        return;
    }
    $domainChoiceSeen[$key] = true;
    $registrarLabel = $accountId > 0
        ? (string)($domainChoiceRegistrarLabels[$accountId] ?? $domainChoiceSelectedRegistrarLabel)
        : '';
    $domainChoiceTags[] = [
        'domain' => $domain,
        'account_id' => $accountId,
        'registrar_label' => $registrarLabel,
        'source' => $source,
        'source_label' => $sourceLabel,
    ];
};
