$previewPageOptions = \is_array($state['preview_page_options'] ?? null) ? $state['preview_page_options'] : [];
if ($previewPageOptions === [] && $virtualPagesByType !== []) {
    foreach ($virtualPagesByType as $pageType => $pageData) {
        if (!\is_string($pageType) || !\is_array($pageData)) {
            continue;
        }
        $title = \trim((string)($pageData['title'] ?? $pageData['name'] ?? ''));
        $handle = \trim((string)($pageData['handle'] ?? ''));
        $label = (string)($pageTypeLabels[$pageType] ?? ($title !== '' ? $title : $pageType));
        if ($handle !== '') {
            $label .= ' (' . $handle . ')';
        }
        $previewPageOptions[] = [
            'value' => $pageType,
            'page_id' => 0,
            'type' => $pageType,
            'title' => $title,
            'handle' => $handle,
            'label' => $label,
        ];
    }
}
foreach ($previewPageOptions as &$previewPageOption) {
    if (!\is_array($previewPageOption)) {
        continue;
    }
    $optType = \trim((string)($previewPageOption['type'] ?? $previewPageOption['value'] ?? ''));
    $optHandle = \trim((string)($previewPageOption['handle'] ?? ''));
    $optTitle = \trim((string)($previewPageOption['title'] ?? ''));
    $optLabel = (string)($pageTypeLabels[$optType] ?? ($optTitle !== '' ? $optTitle : $optType));
    if ($optHandle !== '') {
        $optLabel .= ' (' . $optHandle . ')';
    }
    $previewPageOption['label'] = $optLabel;
}
unset($previewPageOption);
$displayPagesByType = $pagesByType !== [] ? $pagesByType : $virtualPagesByType;
