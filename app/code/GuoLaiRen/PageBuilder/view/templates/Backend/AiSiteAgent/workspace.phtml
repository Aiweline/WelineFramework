        ? $virtualPagesByType[$previewPageType]['blocks']
        : [];
    foreach ($previewBlocks as $previewBlock) {
        if (!\is_array($previewBlock)) {
            continue;
        }
        $initialBlocks[] = [
            'block_id' => (string)($previewBlock['block_id'] ?? ''),
            'type' => (string)($previewBlock['type'] ?? ''),
