    function markPageGenerationStatus(pageType, status, text) {
        var row = ensurePageStatusRow(pageType);
        if (!row) {
            return;
        }
        var labelEl = row.querySelector('.fw-semibold');
        var badgeEl = row.querySelector('.badge');
        if (!labelEl || !badgeEl) {
            return;
        }
        labelEl.textContent = normalizePageTypeLabel(pageType);
        badgeEl.className = 'badge';
        if (status === 'done') {
            badgeEl.classList.add('bg-soft-success', 'text-success');
            badgeEl.textContent = text || messages.generated;
        } else if (status === 'running') {
            badgeEl.classList.add('bg-soft-warning', 'text-warning');
            badgeEl.textContent = text || messages.generating;
        } else if (status === 'failed') {
            badgeEl.classList.add('bg-soft-danger', 'text-danger');
            badgeEl.textContent = text || 'Failed';
        } else {
            badgeEl.classList.add('bg-soft-secondary', 'text-secondary');
            badgeEl.textContent = text || messages.waiting;
        }
    }

