<?php
/**
 * @var \Weline\Framework\View\Template $this
 * Guided UI mode (default):
 *   - 3-step horizontal stepper (用户文案)
 *   - Single main action per step
 *   - Dev artifacts (指标卡/JSON/Public ID) hidden by default
 * Expert UI mode (?expert=1):
 *   - Full current layout preserved
 */

$session = $this->getData('session');
$state = $this->getData('workspace_state');
$state = \is_array($state) ? $state : [];
$scope = $this->getData('scope');
$scope = \is_array($scope) ? $scope : [];
$scopePreview = (string)($this->getData('scope_preview') ?? '{}');
$stateJsonUrl = (string)($this->getData('state_json_url') ?? '');
$streamSseUrl = (string)($this->getData('stream_sse_url') ?? '');
$mergeScopeUrl = (string)($this->getData('merge_scope_url') ?? '');
$replaceScopeUrl = (string)($this->getData('replace_scope_url') ?? '');
$setStageUrl = (string)($this->getData('set_stage_url') ?? '');
$runVirtualThemeUrl = (string)($this->getData('run_virtual_theme_url') ?? '');
$startRegeneratePageUrl = (string)($this->getData('start_regenerate_page_url') ?? '');
$startRefineComponentUrl = (string)($this->getData('start_refine_component_url') ?? '');
$updateBlockConfigUrl = (string)($this->getData('update_block_config_url') ?? '');
$startPublishUrl = (string)($this->getData('start_publish_url') ?? '');
$operationSseUrl = (string)($this->getData('operation_sse_url') ?? '');
$switchPreviewPageUrl = (string)($this->getData('switch_preview_page_url') ?? '');
$publishCheckUrl = (string)($this->getData('publish_check_url') ?? '');
$backUrl = (string)($this->getData('back_url') ?? $this->getBackendUrl('websites/backend/site-builder-agent/index', ['provider' => 'pagebuilder']));
$stageOptions = $this->getData('stage_options');
$stageOptions = \is_array($stageOptions) ? $stageOptions : [];
$guidedUi = (bool)($this->getData('guided_ui') ?? true);
$expertUrl = (string)($this->getData('workspace_expert_url') ?? '');
$guidedUrl = (string)($this->getData('workspace_guided_url') ?? '');
$recommendDomainUrl = (string)($this->getData('recommend_domain_url') ?? '');
$checkDomainUrl = (string)($this->getData('check_domain_url') ?? '');
$startDomainPurchaseUrl = (string)($this->getData('start_domain_purchase_url') ?? '');
$domainPurchaseState = $this->getData('domain_purchase_state');
$domainPurchaseState = \is_array($domainPurchaseState) ? $domainPurchaseState : [];
$recommendedDomainList = $this->getData('recommended_domain_list');
$recommendedDomainList = \is_array($recommendedDomainList) ? $recommendedDomainList : [];
$recommendedRegistrarLabel = (string)($this->getData('recommended_registrar_label') ?? '');
$preferredRegistrarAccountId = (int)($this->getData('preferred_registrar_account_id') ?? 0);
$registrarAccounts = $this->getData('registrar_accounts');
$registrarAccounts = \is_array($registrarAccounts) ? $registrarAccounts : [];
$registrarSelectOptions = [];
foreach ($registrarAccounts as $account) {
    if (!\is_array($account)) {
        continue;
    }
    $optAccountId = (int)($account['account_id'] ?? 0);
    if ($optAccountId <= 0) {
        continue;
    }
    $registrarName = \trim((string)($account['registrar_name'] ?? $account['registrar_code'] ?? ''));
    $accountName = \trim((string)($account['account_name'] ?? ''));
    $optLabel = \trim((string)($account['label'] ?? ''));
    if ($optLabel === '') {
        $optLabel = $registrarName !== ''
            ? $registrarName . ($accountName !== '' ? (' - ' . $accountName) : '')
            : ($accountName !== '' ? $accountName : (string)($account['registrar_code'] ?? ''));
    }
    if ($optLabel === '') {
        $optLabel = (string)$optAccountId;
    }
    $registrarSelectOptions[] = [
        'value' => (string)$optAccountId,
        'label' => $optLabel,
        'group' => $registrarName !== '' ? $registrarName : (string)__('其他'),
        'meta' => (string)($account['registrar_code'] ?? ''),
    ];
}
try {
    $registrarSelectOptionsJson = \json_encode($registrarSelectOptions, JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR);
} catch (\JsonException) {
    $registrarSelectOptionsJson = '[]';
}
$purchaseDialogJsUrl = (\defined('DEV') && DEV)
    ? '/Weline/Websites/view/statics/backend/domain-purchase-dialog.js'
    : $this->getViewFileUrl('Weline_Websites::backend/domain-purchase-dialog.js');

if (!$session instanceof \GuoLaiRen\PageBuilder\Model\AiSiteAgentSession) {
    return;
}

$publicId = $session->getPublicId();
$currentStage = (string)($state['stage'] ?? \GuoLaiRen\PageBuilder\Model\AiSiteAgentSession::STAGE_VIRTUAL_THEME);
$websiteProfile = \is_array($state['website_profile'] ?? null) ? $state['website_profile'] : [];
$cfgDebugSiteTitle = \trim((string)($this->getData('ai_site_debug_default_site_title') ?? ''));
$cfgDebugBrief = \trim((string)($this->getData('ai_site_debug_default_brief') ?? ''));
$guidedWorkspaceSiteTitle = \trim((string)($websiteProfile['site_title'] ?? $scope['site_title'] ?? ''));
if ($guidedWorkspaceSiteTitle === '' && $cfgDebugSiteTitle !== '') {
    $guidedWorkspaceSiteTitle = $cfgDebugSiteTitle;
}
$guidedWorkspaceBrief = \trim((string)($websiteProfile['brief_description'] ?? $scope['brief_description'] ?? $scope['user_description'] ?? ''));
if ($guidedWorkspaceBrief === '' && $cfgDebugBrief !== '') {
    $guidedWorkspaceBrief = $cfgDebugBrief;
}
$pageTypes = $scope['page_types'] ?? [];
$pageTypes = \is_array($pageTypes) ? $pageTypes : [];
$pageTypeLabels = \GuoLaiRen\PageBuilder\Model\Page::getPageTypes();
$selectedPageTypes = $pageTypes !== [] ? $pageTypes : \array_keys($pageTypeLabels);
$pageTypesUserCustomized = !empty($scope[\GuoLaiRen\PageBuilder\Service\AiSiteScopeCompatibilityService::PAGE_TYPES_USER_CUSTOMIZED_KEY]);
$pagesByType = \is_array($state['pagebuilder_pages_by_type'] ?? null) ? $state['pagebuilder_pages_by_type'] : [];
$virtualPagesByType = \is_array($state['virtual_pages_by_type'] ?? null) ? $state['virtual_pages_by_type'] : [];
$previewPageOptions = \is_array($state['preview_page_options'] ?? null) ? $state['preview_page_options'] : [];
if ($previewPageOptions === [] && $virtualPagesByType !== []) {
    foreach ($virtualPagesByType as $pageType => $pageData) {
        if (!\is_string($pageType) || !\is_array($pageData)) {
            continue;
        }
        $title = \trim((string)($pageData['title'] ?? $pageData['name'] ?? ''));
        $handle = \trim((string)($pageData['handle'] ?? ''));
        $label = $title !== '' ? $title : (string)($pageTypeLabels[$pageType] ?? $pageType);
        if ($handle !== '') {
            $label .= ' (' . $handle . ')';
        }
        $previewPageOptions[] = [
            'value' => $pageType,
            'page_id' => 0,
            'type' => $pageType,
            'title' => $title,
            'handle' => $handle,
            'label' => $label,
        ];
    }
}
$displayPagesByType = $pagesByType !== [] ? $pagesByType : $virtualPagesByType;
$draftWebsiteId = (int)($state['draft_website_id'] ?? 0);
$virtualThemeId = (int)($state['virtual_theme_id'] ?? 0);
$previewPageId = (int)($state['preview_page_id'] ?? 0);
$previewPageType = (string)($state['preview_page_type'] ?? '');
$previewFullUrl = (string)($state['preview_full_url'] ?? '');
$visualPreviewUrl = (string)($state['visual_preview_url'] ?? '');
$visualEditUrl = (string)($state['visual_edit_url'] ?? '');
$embeddedVisualUrl = $visualPreviewUrl !== '' ? $visualPreviewUrl : $visualEditUrl;
$activeOperation = \is_array($state['active_operation'] ?? null) ? $state['active_operation'] : [];
$activeOperationStatus = \trim((string)($activeOperation['status'] ?? ''));
$canPublish = !empty($state['can_publish']);
$events = \is_array($state['events'] ?? null) ? $state['events'] : [];
$initialLastEventId = 0;
foreach ($events as $eventItem) {
    $initialLastEventId = \max($initialLastEventId, (int)($eventItem['event_id'] ?? 0));
}

$workspaceTrack = (string)($state['workspace_track'] ?? \GuoLaiRen\PageBuilder\Service\AiSiteScopeCompatibilityService::WORKSPACE_TRACK_VIRTUAL_THEME);
$siteReadyFlag = (int)($state['site_ready'] ?? 1);

/** 常用页面类型（快速模式默认勾选） */
$defaultCheckedPageTypes = ['home_page', 'about_page', 'contact_page'];
$commonPageTypes = [];
$extraPageTypes = [];
foreach ($pageTypeLabels as $pt => $label) {
    if (\in_array($pt, $defaultCheckedPageTypes, true)) {
        $commonPageTypes[$pt] = $label;
    } else {
        $extraPageTypes[$pt] = $label;
    }
}
$extraPageTypesOpenByDefault = false;

/** 步骤映射（用户文案 ↔ 内部 stage） */
$guidedSteps = [
    [
        'key' => 'virtual_theme',
        'label' => __('1 说说你的网站'),
        'icon' => 'mdi-pencil-outline',
        'done_when' => $draftWebsiteId > 0,
    ],
    [
        'key' => 'visual_edit',
        'label' => __('2 看看效果'),
        'icon' => 'mdi-eye-outline',
        'done_when' => $visualPreviewUrl !== '',
    ],
    [
        'key' => 'publish',
        'label' => __('3 准备上线'),
        'icon' => 'mdi-rocket-launch-outline',
        'done_when' => $currentStage === 'publish',
    ],
];

/** 当前激活的 guided 步骤索引 */
$activeStepIndex = 0;
foreach ($guidedSteps as $i => $s) {
    if ($s['key'] === $currentStage) {
        $activeStepIndex = $i;
        break;
    }
}
?>
<?php
$guidedScopeDefaults = [
    'site_title' => $guidedWorkspaceSiteTitle,
    'site_tagline' => (string)($websiteProfile['site_tagline'] ?? $scope['site_tagline'] ?? ''),
    'target_domain' => (string)($websiteProfile['target_domain'] ?? $scope['target_domain'] ?? ''),
    'brief_description' => $guidedWorkspaceBrief,
    'site_profile_manual' => \is_array($scope['site_profile_manual'] ?? null) ? $scope['site_profile_manual'] : [],
];
$guidedSessionSummary = [
    'site_title' => (string)($guidedScopeDefaults['site_title'] ?? ''),
    'site_tagline' => (string)($guidedScopeDefaults['site_tagline'] ?? ''),
    'target_domain' => (string)($guidedScopeDefaults['target_domain'] ?? ''),
    'brief_description' => (string)($guidedScopeDefaults['brief_description'] ?? ''),
    'page_types' => $selectedPageTypes,
];
$domainStatus = (string)($domainPurchaseState['status'] ?? 'idle');
$domainStatusBadgeClass = match ($domainStatus) {
    'completed' => 'bg-soft-success text-success',
    'failed' => 'bg-soft-danger text-danger',
    'queued', 'running' => 'bg-soft-info text-info',
    default => 'bg-soft-secondary text-muted',
};
$domainActionLabel = match ($domainStatus) {
    'completed' => (string)__('已购买完成'),
    'queued', 'running' => (string)__('正在购买域名'),
    'failed' => (string)__('重新发起购买'),
    default => (string)__('购买域名并建站'),
};
$domainOrderDisplay = (int)($domainPurchaseState['order_id'] ?? 0) > 0
    ? (string)((int)($domainPurchaseState['order_id'] ?? 0))
    : ((int)($domainPurchaseState['purchase_order_id'] ?? 0) > 0
        ? (string)((int)($domainPurchaseState['purchase_order_id'] ?? 0))
        : (string)__('暂未生成'));
?>
