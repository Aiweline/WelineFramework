<?php
/**
 * 嵌入工作区 iframe：预览上下文不可用时展示的占位页（同域，可与父页 postMessage 通信）。
 *
 * @var \Weline\Framework\View\Template $this
 */
$sessionOk = (bool)($this->getData('pb_preview_unavailable_session_ok') ?? false);
$buildPlanConfirmed = (bool)($this->getData('pb_preview_unavailable_build_plan_confirmed') ?? false);
$buildQueueRunning = (bool)($this->getData('pb_preview_unavailable_build_queue_running') ?? false);
$pageTypeRaw = \trim((string)($this->getData('pb_preview_unavailable_page_type') ?? ''));
$pageTypeJson = \json_encode($pageTypeRaw, \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR);
$buildPlanConfirmedJson = $buildPlanConfirmed ? 'true' : 'false';
$buildQueueRunningJson = $buildQueueRunning ? 'true' : 'false';
$titleGeneric = (string)__('预览页面不存在或无访问权限');
$titleNotGenerated = (string)__('预览页面尚未生成');
$hintReady = (string)__('当前预览页面尚未生成。确认建站方案后，系统会基于执行蓝图直接创建后台构建任务。');
$btnTitleLocked = (string)__('请先确认建站方案，再进行 AI 生成。');
$btnTitleBuilding = (string)__('虚拟主题构建中，请等待当前构建完成。');
$btnLabel = (string)__('AI生成');
$btnLabelBuilding = (string)__('构建中');
?>
<!DOCTYPE html>
<html lang="<?= htmlspecialchars(\strtolower(\str_replace('_', '-', (string)\Weline\Framework\App\State::getLang())), ENT_QUOTES, 'UTF-8') ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><?= htmlspecialchars($sessionOk ? $titleNotGenerated : $titleGeneric, ENT_QUOTES, 'UTF-8') ?></title>
    <style>
        body{margin:0;padding:32px 20px;font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;background:#f8fafc;color:#0f172a;line-height:1.55;}
        .wrap{max-width:520px;margin:0 auto;}
        .card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.06);}
        h1{font-size:1.05rem;margin:0 0 12px;font-weight:600;color:#0f172a;}
        p{margin:0 0 16px;color:#475569;font-size:.95rem;}
        .actions{display:flex;flex-wrap:wrap;gap:10px;align-items:center;}
        button#pb-ai-preview-generate{border:none;border-radius:8px;padding:10px 18px;font-size:.95rem;font-weight:600;cursor:pointer;background:#2563eb;color:#fff;}
        button#pb-ai-preview-generate:disabled{opacity:.45;cursor:not-allowed;background:#94a3b8;}
        .muted{font-size:.85rem;color:#64748b;}
        .err{color:#b91c1c;background:#fff7f7;border:1px solid #fecaca;border-radius:8px;padding:14px 16px;}
    </style>
</head>
<body>
<div class="wrap">
    <?php if ($sessionOk): ?>
        <div class="card">
            <h1><?= htmlspecialchars($titleNotGenerated, ENT_QUOTES, 'UTF-8') ?></h1>
            <p><?= htmlspecialchars($hintReady, ENT_QUOTES, 'UTF-8') ?></p>
            <div class="actions">
                <button type="button" id="pb-ai-preview-generate"<?= ($buildPlanConfirmed && !$buildQueueRunning) ? '' : ' disabled aria-disabled="true"' ?>
                    <?= !$buildPlanConfirmed ? (' title="' . htmlspecialchars($btnTitleLocked, ENT_QUOTES, 'UTF-8') . '"') : ($buildQueueRunning ? (' title="' . htmlspecialchars($btnTitleBuilding, ENT_QUOTES, 'UTF-8') . '"') : '') ?>>
                    <?= htmlspecialchars($buildQueueRunning ? $btnLabelBuilding : $btnLabel, ENT_QUOTES, 'UTF-8') ?>
                </button>
            </div>
            <?php if (!$buildPlanConfirmed || $buildQueueRunning): ?>
                <p class="muted" style="margin-top:14px;margin-bottom:0;"><?= htmlspecialchars(!$buildPlanConfirmed ? $btnTitleLocked : $btnTitleBuilding, ENT_QUOTES, 'UTF-8') ?></p>
            <?php endif; ?>
        </div>
    <?php else: ?>
        <div class="err" role="alert"><?= htmlspecialchars($titleGeneric, ENT_QUOTES, 'UTF-8') ?></div>
    <?php endif; ?>
</div>
<script>
(function () {
    var buildPlanOk = <?= $buildPlanConfirmedJson ?>;
    var buildRunning = <?= $buildQueueRunningJson ?>;
    var pageType = <?= $pageTypeJson ?>;
    var btn = document.getElementById('pb-ai-preview-generate');
    if (!btn || !buildPlanOk || buildRunning) {
        return;
    }
    btn.addEventListener('click', function () {
        if (!window.parent || window.parent === window) {
            return;
        }
        try {
            var origin = window.location.origin || '*';
            window.parent.postMessage({
                type: 'pb-ai-workspace-preview',
                action: 'request-ai-generate',
                page_type: pageType
            }, origin);
        } catch (e) {}
    });
})();
</script>
</body>
</html>
