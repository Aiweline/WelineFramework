<script>
(function () {
    var listUrl = <?= json_encode($listUrl, JSON_THROW_ON_ERROR) ?>;
    var saveUrl = <?= json_encode($saveUrl, JSON_THROW_ON_ERROR) ?>;
    var disableUrl = <?= json_encode($disableUrl, JSON_THROW_ON_ERROR) ?>;
    var deleteUrl = <?= json_encode($deleteUrl, JSON_THROW_ON_ERROR) ?>;
    var cloneBuiltinUrl = <?= json_encode($cloneBuiltinUrl, JSON_THROW_ON_ERROR) ?>;
    var currentItems = <?= json_encode($items, JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE | JSON_THROW_ON_ERROR) ?>;
    var editingCode = '';
    var listEl = document.getElementById('pb-dd-list');
    var emptyEl = document.getElementById('pb-dd-empty');
    var statusEl = document.getElementById('pb-dd-status');
    var countEl = document.getElementById('pb-dd-list-count');
    var codeEl = document.getElementById('pb-dd-code');
    var deleteCurrentBtn = document.getElementById('pb-dd-delete-current');
    var labels = {
        newTitle: <?= json_encode((string)__('新建设计方向'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        editTitle: <?= json_encode((string)__('编辑设计方向'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        newBadge: <?= json_encode((string)__('新建'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        editBadge: <?= json_encode((string)__('编辑'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        readonly: <?= json_encode((string)__('内置'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        custom: <?= json_encode((string)__('自定义'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        active: <?= json_encode((string)__('启用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        disabled: <?= json_encode((string)__('停用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        edit: <?= json_encode((string)__('编辑'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        clone: <?= json_encode((string)__('复制'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        disable: <?= json_encode((string)__('停用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        enable: <?= json_encode((string)__('启用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        delete: <?= json_encode((string)__('删除'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        confirmDelete: <?= json_encode((string)__('确定删除这个自定义设计方向？删除后不可恢复。'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        refreshed: <?= json_encode((string)__('已刷新'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        saved: <?= json_encode((string)__('已保存'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        deleted: <?= json_encode((string)__('已删除'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        cloned: <?= json_encode((string)__('已复制为自定义方向'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        disabledDone: <?= json_encode((string)__('已停用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>,
        enabledDone: <?= json_encode((string)__('已启用'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>
    };

    function post(url, payload) {
        if (!url) {
            return Promise.reject(new Error('API url is empty.'));
        }
        var body = Object.keys(payload || {}).map(function (key) {
            var value = payload[key];
            if (typeof value === 'object' && value !== null) {
                value = JSON.stringify(value);
            }
            return encodeURIComponent(key) + '=' + encodeURIComponent(String(value == null ? '' : value));
        }).join('&');
        return fetch(url, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest'},
            credentials: 'same-origin',
            body: body
        }).then(function (response) {
            return response.json().catch(function () {
                throw new Error('Invalid JSON response.');
            });
        });
    }

    function parseLines(value) {
        var raw = String(value || '').trim();
        if (!raw) {
            return [];
        }
        try {
            var parsed = JSON.parse(raw);
            if (Array.isArray(parsed) || (parsed && typeof parsed === 'object')) {
                return parsed;
            }
        } catch (e) {}
        return raw.split(/\r?\n/).map(function (line) { return line.trim(); }).filter(Boolean);
    }

    function parseObject(value) {
        var raw = String(value || '').trim();
        if (!raw) {
            return {};
        }
        try {
            var parsed = JSON.parse(raw);
            return parsed && typeof parsed === 'object' ? parsed : {};
        } catch (e) {
            return parseLines(raw);
        }
    }

    function formatStructured(value) {
        if (value == null || value === '') {
            return '';
        }
        if (Array.isArray(value)) {
            return value.every(function (item) { return typeof item !== 'object'; }) ? value.join("\n") : JSON.stringify(value, null, 2);
        }
        if (typeof value === 'object') {
            return JSON.stringify(value, null, 2);
        }
        return String(value);
    }

    function setStatus(text) {
        if (statusEl) {
            statusEl.textContent = String(text || '');
        }
    }

    function isCustom(item) {
        return String(item && (item.source_type || item.source) || '') === 'custom' && !item.readonly;
    }

    function clonePayload(item, status) {
        var payload = Object.assign({}, item || {});
        payload.status = status || payload.status || 'active';
        payload.source_type = 'custom';
        delete payload.readonly;
        delete payload.selectable;
        delete payload.exists;
        return payload;
    }

    function visibleItems() {
        var filter = document.getElementById('pb-dd-filter').value;
        var keyword = String(document.getElementById('pb-dd-search').value || '').toLowerCase().trim();
        return (Array.isArray(currentItems) ? currentItems : []).filter(function (item) {
            var source = String(item.source_type || item.source || '');
            var status = String(item.status || 'active');
            if (filter === 'active' && status !== 'active') return false;
            if (filter === 'disabled' && status !== 'disabled') return false;
            if (filter === 'custom' && source !== 'custom') return false;
            if (filter === 'builtin' && source === 'custom') return false;
            if (!keyword) return true;
            return [
                item.code,
                item.name,
                item.description,
                (Array.isArray(item.match_keywords) ? item.match_keywords.join(' ') : ''),
                (Array.isArray(item.visual_keywords) ? item.visual_keywords.join(' ') : '')
            ].join(' ').toLowerCase().indexOf(keyword) !== -1;
        });
    }

    function render() {
        if (!listEl) {
            return;
        }
        var items = visibleItems();
        listEl.innerHTML = '';
        if (countEl) {
            countEl.textContent = String(items.length) + ' / ' + String((currentItems || []).length);
        }
        if (emptyEl) {
            emptyEl.classList.toggle('d-none', items.length > 0);
        }
        items.forEach(function (item) {
            var row = document.createElement('div');
            row.className = 'list-group-item';
            if (String(item.status || 'active') === 'disabled') {
                row.classList.add('text-muted');
            }
            row.innerHTML =
                '<div class="d-flex justify-content-between gap-3">' +
                    '<div class="min-w-0 flex-grow-1">' +
                        '<div class="d-flex flex-wrap align-items-center gap-2 mb-1">' +
                            '<button type="button" class="btn btn-link p-0 fw-semibold text-start dd-name"></button>' +
                            '<span class="badge dd-status"></span>' +
                            '<span class="badge dd-source"></span>' +
                        '</div>' +
                        '<div class="small text-muted dd-meta"></div>' +
                        '<div class="small mt-1 dd-desc"></div>' +
                    '</div>' +
                    '<div class="d-flex flex-column gap-1 dd-actions"></div>' +
                '</div>';
            var nameBtn = row.querySelector('.dd-name');
            nameBtn.textContent = String(item.name || item.code || '');
            nameBtn.addEventListener('click', function () {
                if (isCustom(item)) {
                    fillEditor(item);
                }
            });
            var statusBadge = row.querySelector('.dd-status');
            var status = String(item.status || 'active');
            statusBadge.textContent = status === 'disabled' ? labels.disabled : labels.active;
            statusBadge.className = 'badge dd-status ' + (status === 'disabled' ? 'bg-soft-secondary text-secondary' : 'bg-soft-success text-success');
            var source = String(item.source_type || item.source || '');
            var sourceBadge = row.querySelector('.dd-source');
            sourceBadge.textContent = source === 'custom' ? labels.custom : labels.readonly;
            sourceBadge.className = 'badge dd-source ' + (source === 'custom' ? 'bg-soft-primary text-primary' : 'bg-soft-info text-info');
            row.querySelector('.dd-meta').textContent = String(item.code || '') + ' · v' + String(item.version || 1) + (item.updated_at ? ' · ' + String(item.updated_at) : '');
            row.querySelector('.dd-desc').textContent = String(item.description || '').slice(0, 180);
            renderActions(row.querySelector('.dd-actions'), item);
            listEl.appendChild(row);
        });
    }

    function actionButton(icon, text, className, title) {
        var button = document.createElement('button');
        button.type = 'button';
        button.className = className || 'btn btn-outline-secondary btn-sm';
        button.title = title || text;
        button.innerHTML = '<i class="mdi ' + icon + ' me-1" aria-hidden="true"></i>' + text;
        return button;
    }

    function renderActions(actions, item) {
        if (!actions) {
            return;
        }
        if (isCustom(item)) {
            var editBtn = actionButton('mdi-pencil-outline', labels.edit, 'btn btn-outline-secondary btn-sm');
            editBtn.addEventListener('click', function () { fillEditor(item); });
            actions.appendChild(editBtn);

            if (String(item.status || 'active') === 'disabled') {
                var enableBtn = actionButton('mdi-check-circle-outline', labels.enable, 'btn btn-outline-success btn-sm');
                enableBtn.addEventListener('click', function () {
                    post(saveUrl, clonePayload(item, 'active')).then(function (data) {
                        if (!data || !data.success) throw new Error((data && data.message) || 'enable failed');
                        setStatus(labels.enabledDone);
                        return refresh(false);
                    }).catch(showError);
                });
                actions.appendChild(enableBtn);
            } else {
                var disableBtn = actionButton('mdi-close-circle-outline', labels.disable, 'btn btn-outline-warning btn-sm');
                disableBtn.addEventListener('click', function () {
                    post(disableUrl, {code: item.code}).then(function (data) {
                        if (!data || !data.success) throw new Error((data && data.message) || 'disable failed');
                        setStatus(labels.disabledDone);
                        return refresh(false);
                    }).catch(showError);
                });
                actions.appendChild(disableBtn);
            }

            var deleteBtn = actionButton('mdi-delete-outline', labels.delete, 'btn btn-outline-danger btn-sm');
            deleteBtn.addEventListener('click', function () { deleteItem(item); });
            actions.appendChild(deleteBtn);
            return;
        }

        var cloneBtn = actionButton('mdi-content-copy', labels.clone, 'btn btn-outline-primary btn-sm');
        cloneBtn.addEventListener('click', function () {
            post(cloneBuiltinUrl, {code: item.code}).then(function (data) {
                if (!data || !data.success) throw new Error((data && data.message) || 'clone failed');
                setStatus(labels.cloned);
                return refresh(false).then(function () {
                    if (data.item) fillEditor(data.item);
                });
            }).catch(showError);
        });
        actions.appendChild(cloneBtn);
    }

    function fillEditor(item) {
        item = item || {};
        editingCode = String(item.code || '');
        document.getElementById('pb-dd-editor-title').textContent = editingCode ? labels.editTitle : labels.newTitle;
        document.getElementById('pb-dd-editor-mode').textContent = editingCode ? String(item.code || '') : <?= json_encode((string)__('保存后会进入当前管理员的自定义设计方向库。'), JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR) ?>;
        var badge = document.getElementById('pb-dd-editor-badge');
        badge.textContent = editingCode ? labels.editBadge : labels.newBadge;
        badge.className = 'badge ' + (editingCode ? 'bg-soft-primary text-primary' : 'bg-soft-info text-info');
        codeEl.value = String(item.code || '');
        codeEl.readOnly = editingCode !== '';
        document.getElementById('pb-dd-name').value = String(item.name || '');
        document.getElementById('pb-dd-status-select').value = String(item.status || 'active') === 'disabled' ? 'disabled' : 'active';
        document.getElementById('pb-dd-description').value = String(item.description || '');
        document.querySelectorAll('.pb-dd-array').forEach(function (el) {
            el.value = formatStructured(item[el.getAttribute('data-field') || '']);
        });
        document.getElementById('pb-dd-color-system').value = formatStructured(item.color_system || {});
        document.getElementById('pb-dd-block-rules').value = formatStructured(item.block_rules || {});
        document.getElementById('pb-dd-cta-style').value = String(item.cta_style || '');
        document.getElementById('pb-dd-supplemental').value = String(item.supplemental_prompt || '');
        deleteCurrentBtn.classList.toggle('d-none', !editingCode);
        setStatus('');
    }

    function collect() {
        var payload = {
            code: codeEl.value,
            name: document.getElementById('pb-dd-name').value,
            description: document.getElementById('pb-dd-description').value,
            color_system: parseObject(document.getElementById('pb-dd-color-system').value),
            block_rules: parseObject(document.getElementById('pb-dd-block-rules').value),
            cta_style: document.getElementById('pb-dd-cta-style').value,
            supplemental_prompt: document.getElementById('pb-dd-supplemental').value,
            status: document.getElementById('pb-dd-status-select').value === 'disabled' ? 'disabled' : 'active'
        };
        document.querySelectorAll('.pb-dd-array').forEach(function (el) {
            payload[el.getAttribute('data-field') || ''] = parseLines(el.value);
        });
        return payload;
    }

    function refresh(updateStatus) {
        return post(listUrl, {include_disabled: 1}).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) || 'load failed');
            }
            currentItems = data.items || [];
            render();
            if (updateStatus !== false) {
                setStatus(labels.refreshed);
            }
        }).catch(showError);
    }

    function deleteItem(item) {
        if (!isCustom(item)) {
            return;
        }
        if (!window.confirm(labels.confirmDelete)) {
            return;
        }
        post(deleteUrl, {code: item.code}).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) || 'delete failed');
            }
            if (editingCode === String(item.code || '')) {
                fillEditor({});
            }
            setStatus(labels.deleted);
            return refresh(false);
        }).catch(showError);
    }

    function showError(err) {
        setStatus(err && err.message ? err.message : 'error');
    }

    document.getElementById('pb-dd-save').addEventListener('click', function () {
        post(saveUrl, collect()).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) || 'save failed');
            }
            setStatus(labels.saved);
            return refresh(false).then(function () {
                if (data.item) {
                    fillEditor(data.item);
                }
            });
        }).catch(showError);
    });
    document.getElementById('pb-dd-clear').addEventListener('click', function () { fillEditor({}); });
    deleteCurrentBtn.addEventListener('click', function () {
        var item = currentItems.find(function (candidate) { return String(candidate.code || '') === editingCode; });
        if (item) {
            deleteItem(item);
        }
    });
    document.getElementById('pb-dd-new').addEventListener('click', function () { fillEditor({}); });
    document.getElementById('pb-dd-refresh').addEventListener('click', function () { refresh(true); });
    document.getElementById('pb-dd-filter').addEventListener('change', render);
    document.getElementById('pb-dd-search').addEventListener('input', render);
    render();
}());
</script>
