    function setAssetSlotButtonLocked(card, locked) {
        card.querySelectorAll('[data-asset-generate]').forEach(function (button) {
            button.disabled = !!locked;
            if (locked) {
                button.setAttribute('aria-disabled', 'true');
            } else {
                button.removeAttribute('aria-disabled');
            }
        });
    }

    function syncAssetSlotPreview(card, preview) {
        var wrapper = card.querySelector('[data-asset-slot-preview-wrap]');
        var image = wrapper ? wrapper.querySelector('[data-asset-slot-preview]') : null;
        if (!preview) {
            if (wrapper) {
                wrapper.remove();
            }
            return;
        }
        if (!wrapper) {
            wrapper = document.createElement('div');
            wrapper.className = 'pb-ai-asset-preview mb-2';
            wrapper.setAttribute('data-asset-slot-preview-wrap', '');
            image = document.createElement('img');
            image.alt = '';
            image.setAttribute('data-asset-slot-preview', '');
            wrapper.appendChild(image);
            var binding = card.querySelector('[data-asset-slot-binding]');
            if (binding && binding.parentNode === card) {
                binding.insertAdjacentElement('afterend', wrapper);
            } else {
                card.insertBefore(wrapper, card.firstChild);
            }
        }
        if (image && image.getAttribute('src') !== preview) {
            image.setAttribute('src', preview);
        }
    }

    function updateAssetSlotCard(card, view) {
        setAssetSlotText(card, '[data-asset-slot-label]', view.displayLabel || view.slotId || '-');
        setAssetSlotText(card, '[data-asset-slot-status]', view.status);
        toggleAssetSlotValue(card, '[data-asset-slot-binding]', !!view.binding, view.binding);
        syncAssetSlotPreview(card, view.preview);
        var finalUrl = card.querySelector('[data-asset-slot-final-url]');
        if (finalUrl) {
            finalUrl.classList.toggle('d-none', !view.finalUrl);
            if (view.finalUrl && finalUrl.getAttribute('href') !== view.finalUrl) {
                finalUrl.setAttribute('href', view.finalUrl);
            }
        }
        toggleAssetSlotValue(card, '[data-asset-slot-purpose]', !!view.purpose, view.purpose);
        toggleAssetSlotValue(card, '[data-asset-slot-locked]', view.locked, 'locked');
        toggleAssetSlotValue(card, '[data-asset-slot-error-badge]', !!view.error, 'error');
        toggleAssetSlotValue(card, '[data-asset-slot-error-text]', !!view.error, view.error);
        setAssetSlotButtonLocked(card, view.locked);
