        var title = escapeHtml(sanitizePreviewText(rawTitle, humanizePreviewKey(rawTitle) || ('娴犺濮?' + (idx + 1))));
        var rawTaskKey = String(task.task_key || '');
        var taskKey = escapeHtml(rawTaskKey);
        var groupKey = escapeHtml(String(task.group_key || pageType || 'shared'));
        var planContext = (task.plan_context && typeof task.plan_context === 'object') ? task.plan_context : {};
        var taskScript = (task.task_script && typeof task.task_script === 'object') ? task.task_script : {};
        var implementationContract = (task.implementation_contract && typeof task.implementation_contract === 'object') ? task.implementation_contract : {};
        var blockTask = (task.block_task && typeof task.block_task === 'object') ? task.block_task : {};
        var pageGoal = escapeHtml(sanitizePreviewText(planContext.page_goal || '', safePageLabel + ' 页面目标：明确本页价值与转化意图。')).replace(/\n/g, '<br>');
        var blockGoal = escapeHtml(sanitizePreviewText(planContext.block_goal || '', '区块目标：说明该区块承担的信息与行动目标。')).replace(/\n/g, '<br>');
        var scene = escapeHtml(sanitizePreviewText(taskScript.scene || '', rawTaskKey || safePageLabel)).replace(/\n/g, '<br>');
        var storyGoal = escapeHtml(sanitizePreviewText(taskScript.story_goal || '', '叙事目标：让用户理解品牌价值并愿意继续操作。')).replace(/\n/g, '<br>');
        var fillRule = escapeHtml(sanitizePreviewText(taskScript.content_fill_rule || '', '内容填充规则：保证文案完整、准确、可执行。')).replace(/\n/g, '<br>');
        var stage3Directive = escapeHtml(sanitizePreviewText(taskScript.stage3_directive || '', '第三阶段执行指令：按任务拆分逐步落地，确保可验收。')).replace(/\n/g, '<br>');
        var acceptance = normalizeStructuredItems(implementationContract.acceptance || []);
