            + '</div>';
    }

    function renderTaskPlanPageSection(pageType, tasks) {
        var normalizedTasks = Array.isArray(tasks) ? tasks : [];
        if (normalizedTasks.length === 0) {
            return '';
        }
        var pageLabel = resolvePreviewTabPageLabel(pageType, '');
        return ''
            + '<div class="card border-0 shadow-sm mb-0">'
            + '<div class="card-body">'
            + '<div class="d-flex flex-wrap align-items-start justify-content-between gap-2">'
            + '<div><div class="fw-semibold">' + escapeHtml(pageLabel) + '</div>'
            + '<div class="text-muted small mt-1">' + escapeHtml(String(pageType || '')) + '</div></div>'
            + '<span class="text-muted small">' + escapeHtml(String(normalizedTasks.length)) + ' ' + escapeHtml(previewLabels.tasksUnit) + '</span>'
            + '</div>'
            + '<div class="mt-3 pb-ai-sortable-list" data-pb-sort-list="1" data-pb-sort-stage="task-plan" data-pb-sort-bucket="page" data-pb-sort-page-type="' + escapeHtml(String(pageType || '')) + '">' + normalizedTasks.map(function (task, idx) {
                return renderTaskPlanTaskCard(task, idx, pageType);
            }).filter(Boolean).join('') + '</div>'
            + '</div>'
            + '</div>';
    }

    function renderTaskPlanStructuredPreviewHtml(planRoot) {
        if (!planRoot || typeof planRoot !== 'object') {
            return '<div class="text-muted small">' + escapeHtml(String(messages.planStructuredPreviewEmpty || '')) + '</div>';
        }
        var themeSections = [];
        var tabs = [];
        var scriptBrief = planRoot.task_script_brief && typeof planRoot.task_script_brief === 'object' ? planRoot.task_script_brief : null;
        if (scriptBrief) {
            themeSections.push(renderStructuredListSection(previewLabels.taskScriptBrief, scriptBrief));
        }

        var sharedTasks = Array.isArray(planRoot.shared_tasks) ? planRoot.shared_tasks : [];
        if (sharedTasks.length > 0) {
            themeSections.push(
                '<div class="card border-0 shadow-sm mb-3">'
                + '<div class="card-body">'
                + '<div class="fw-semibold">' + escapeHtml(previewLabels.sharedTasks) + '</div>'
                + '<div class="mt-3 pb-ai-sortable-list" data-pb-sort-list="1" data-pb-sort-stage="task-plan" data-pb-sort-bucket="shared" data-pb-sort-page-type="shared">' + sharedTasks.map(function (task, idx) {
                    return renderTaskPlanTaskCard(task, idx, 'shared');
                }).filter(Boolean).join('') + '</div>'
                + '</div>'
                + '</div>'
            );
        }

        var pageTasks = planRoot.page_tasks && typeof planRoot.page_tasks === 'object' ? planRoot.page_tasks : {};

        var riskHtml = renderStructuredListSection(previewLabels.riskNotes, planRoot.risk_notes || null);
        if (riskHtml) {
            themeSections.push(riskHtml);
        }

        tabs.push({
            key: 'theme',
            label: previewLabels.themeTab,
            content: themeSections.join('') || renderPreviewTabEmptyState(previewLabels.themeTabEmpty)
        });

        Object.keys(pageTasks).forEach(function (pageType) {
            var tasks = Array.isArray(pageTasks[pageType]) ? pageTasks[pageType] : [];
            var sectionHtml = renderTaskPlanPageSection(pageType, tasks);
            if (!sectionHtml) {
                return;
            }
            tabs.push({
                key: String(pageType || 'page'),
                label: resolvePreviewTabPageLabel(pageType, ''),
                content: sectionHtml
            });
        });

        if (tabs.length === 0) {
            return '<div class="text-muted small">' + escapeHtml(String(messages.planStructuredPreviewEmpty || '')) + '</div>';
        }

        return ''
            + buildPreviewStageToolbar('task-plan')
            + '<div class="mb-2">'
            + '<div class="fw-semibold">' + escapeHtml(String(messages.planStructuredPreviewTitle || '')) + '</div>'
            + '<div class="text-muted small">' + escapeHtml(previewLabels.taskPlanHint) + '</div>'
            + '</div>'
            + renderPreviewTabs('task-plan', tabs);
    }

    function getSortableItems(list) {
        if (!list || !list.querySelectorAll) {
            return [];
        }
        return Array.prototype.filter.call(list.querySelectorAll('[data-pb-sort-item="1"]'), function (item) {
            return item && item.parentNode === list;
        });
    }

    function collectSortableKeys(list) {
        return getSortableItems(list).map(function (item) {
            return String(item.getAttribute('data-pb-sort-key') || '').trim();
        }).filter(function (key) {
            return key !== '';
        });
    }

    function resetPreviewSortState(options) {
        var opts = options && typeof options === 'object' ? options : {};
        if (previewSortState.item && previewSortState.item.classList) {
            previewSortState.item.classList.remove('pb-ai-sort-dragging');
        }
        if (previewSortState.list && previewSortState.list.classList) {
            previewSortState.list.classList.remove('pb-ai-sort-active', 'pb-ai-sort-drag-over');
        }
        if (previewSortState.handle && previewSortState.handle.classList) {
            previewSortState.handle.classList.remove('is-dragging');
        }
        previewSortState.active = false;
        previewSortState.item = null;
        previewSortState.list = null;
        previewSortState.handle = null;
        previewSortState.stage = '';
        previewSortState.bucket = '';
        previewSortState.pageType = '';
        previewSortState.orderedKeysBefore = [];
        if (!opts.preservePending) {
            previewSortState.pending = false;
        }
    }

    function rerenderCurrentPlanPreview() {
        updatePlanModalContent(String((currentPlanPayload && currentPlanPayload.markdown) || ''), { persistField: false });
    }

    function rerenderCurrentTaskPlanPreview() {
        updateTaskPlanModalContent(String((currentTaskPlanPayload && currentTaskPlanPayload.markdown) || ''), { persistField: false });
    }

    function getCurrentTaskPlanStructuredRootForEdit() {
        var payload = currentTaskPlanPayload && typeof currentTaskPlanPayload === 'object'
            ? currentTaskPlanPayload
            : {};
        var structured = pickStructuredPlanRoot(payload);
        if (!structured || typeof structured !== 'object' || Array.isArray(structured)) {
            structured = {};
        }
        payload.structured = structured;
        if (!payload.virtual_theme_plan || typeof payload.virtual_theme_plan !== 'object') {
            payload.virtual_theme_plan = {};
        }
        currentTaskPlanPayload = payload;
        return structured;
    }

    function getEditableTaskPlanTaskList(structuredRoot, pageType) {
        if (!structuredRoot || typeof structuredRoot !== 'object') {
            return [];
        }
        var normalizedPageType = String(pageType || 'shared').trim();
        if (['shared', 'theme', 'global', 'shared_theme'].indexOf(normalizedPageType) !== -1) {
            if (!Array.isArray(structuredRoot.shared_tasks)) {
                structuredRoot.shared_tasks = [];
            }
            return structuredRoot.shared_tasks;
        }
        if (!structuredRoot.page_tasks || typeof structuredRoot.page_tasks !== 'object' || Array.isArray(structuredRoot.page_tasks)) {
            structuredRoot.page_tasks = {};
        }
        if (!Array.isArray(structuredRoot.page_tasks[normalizedPageType])) {
            structuredRoot.page_tasks[normalizedPageType] = [];
        }
        return structuredRoot.page_tasks[normalizedPageType];
    }

    function findEditableTaskPlanTask(structuredRoot, pageType, taskKey, taskIndex) {
        var list = getEditableTaskPlanTaskList(structuredRoot, pageType);
        var normalizedTaskKey = String(taskKey || '').trim();
        var idx = parseInt(String(taskIndex || ''), 10);
        if (!isNaN(idx) && list[idx] && typeof list[idx] === 'object') {
            if (!normalizedTaskKey || String(list[idx].task_key || '').trim() === normalizedTaskKey) {
                return list[idx];
            }
        }
        if (normalizedTaskKey) {
            for (var i = 0; i < list.length; i += 1) {
                if (list[i] && typeof list[i] === 'object' && String(list[i].task_key || '').trim() === normalizedTaskKey) {
                    return list[i];
                }
            }
        }
        return null;
    }

    function syncTaskPlanStructuredDraftAfterEdit(structuredRoot) {
        if (!currentTaskPlanPayload || typeof currentTaskPlanPayload !== 'object') {
            currentTaskPlanPayload = {};
        }
        currentTaskPlanPayload.structured = structuredRoot;
        if (!currentTaskPlanPayload.virtual_theme_plan || typeof currentTaskPlanPayload.virtual_theme_plan !== 'object') {
            currentTaskPlanPayload.virtual_theme_plan = {};
        }
        currentTaskPlanPayload.virtual_theme_plan.draft = structuredRoot;
        currentTaskPlanPayload.virtual_theme_plan.draft_generated_at = currentTaskPlanPayload.virtual_theme_plan.draft_generated_at || new Date().toISOString();
    }

    function applyTaskPlanFieldEditorValue(editor) {
        if (!editor || !editor.getAttribute) {
            return false;
        }
        var structured = getCurrentTaskPlanStructuredRootForEdit();
        var task = findEditableTaskPlanTask(
            structured,
            editor.getAttribute('data-page-type') || 'shared',
            editor.getAttribute('data-task-key') || '',
            editor.getAttribute('data-task-index') || ''
        );
        if (!task) {
            return false;
        }
        if (!task.task_script || typeof task.task_script !== 'object' || Array.isArray(task.task_script)) {
            task.task_script = {};
        }
        if (!Array.isArray(task.task_script.field_content_requirements)) {
            task.task_script.field_content_requirements = [];
        }
        var fieldIndex = parseInt(String(editor.getAttribute('data-field-index') || ''), 10);
        if (isNaN(fieldIndex) || fieldIndex < 0) {
            return false;
        }
        while (task.task_script.field_content_requirements.length <= fieldIndex) {
            task.task_script.field_content_requirements.push({});
        }
        var row = task.task_script.field_content_requirements[fieldIndex];
        if (!row || typeof row !== 'object' || Array.isArray(row)) {
            row = {};
            task.task_script.field_content_requirements[fieldIndex] = row;
        }
        var prop = String(editor.getAttribute('data-field-prop') || 'sample').trim() || 'sample';
        if (['sample', 'implementation_note'].indexOf(prop) === -1) {
            prop = 'sample';
        }
        row[prop] = String(editor.value || '');
        row.edited_at = new Date().toISOString();
        task.task_script.edited_at = row.edited_at;
        structured.last_field_content_edit = {
            page_type: String(editor.getAttribute('data-page-type') || 'shared'),
            task_key: String(editor.getAttribute('data-task-key') || ''),
            field_index: fieldIndex,
            field_prop: prop,
            edited_at: row.edited_at
        };
        syncTaskPlanStructuredDraftAfterEdit(structured);
        setTaskPlanModeStatus(messages.taskPlanFieldEditPending || messages.taskPlanDraftSaved);
        return true;
    }

    function bindTaskPlanFieldEditors(container) {
        var root = typeof container === 'string' ? document.getElementById(container) : container;
        if (!root || root.dataset.pbTaskPlanFieldEditorsBound === '1') {
            return;
        }
        root.dataset.pbTaskPlanFieldEditorsBound = '1';
        var handle = function (event) {
            var editor = event.target && event.target.closest ? event.target.closest('[data-pb-task-plan-field-edit="1"]') : null;
            if (!editor || !root.contains(editor)) {
                return;
            }
            applyTaskPlanFieldEditorValue(editor);
        };
        root.addEventListener('input', handle);
        root.addEventListener('change', handle);
    }

    function resolveSortableAfterItem(list, clientY) {
        var siblings = getSortableItems(list).filter(function (item) {
            return item !== previewSortState.item;
        });
        var closest = {
            offset: Number.NEGATIVE_INFINITY,
            item: null
        };
        siblings.forEach(function (item) {
            var rect = item.getBoundingClientRect();
            var offset = clientY - rect.top - (rect.height / 2);
            if (offset < 0 && offset > closest.offset) {
                closest = {
                    offset: offset,
                    item: item
                };
            }
        });
        return closest.item;
    }

    function persistPlanBlockSort(pageType, orderedKeys) {
        if (!String(sortPlanBlocksUrl || '').trim()) {
            rerenderCurrentPlanPreview();
            toast('warning', messages.planSortUnavailable);
            previewSortState.pending = false;
            return;
        }
        postForm(sortPlanBlocksUrl, {
            public_id: publicId,
            page_type: String(pageType || ''),
            ordered_block_keys: JSON.stringify(orderedKeys || [])
        }).then(function (data) {
            previewSortState.pending = false;
            if (data && data.success && data.data && typeof data.data === 'object') {
                hydrateWorkspaceFromState(data.data);
                toast('success', (data && data.message) ? String(data.message) : messages.planSortSaved);
                return;
            }
            rerenderCurrentPlanPreview();
            toast('warning', (data && data.message) ? String(data.message) : messages.planSortSaveFailed);
        }).catch(function (error) {
            previewSortState.pending = false;
            rerenderCurrentPlanPreview();
            toast('error', (error && error.message) ? String(error.message) : messages.planSortSaveFailed);
        });
    }

    function persistTaskPlanSort(bucket, pageType, orderedKeys) {
        var commit = function () {
            if (!String(sortTaskPlanTasksUrl || '').trim()) {
                rerenderCurrentTaskPlanPreview();
                toast('warning', messages.taskPlanSortUnavailable);
                previewSortState.pending = false;
                return;
            }
            postForm(sortTaskPlanTasksUrl, {
                public_id: publicId,
                bucket: String(bucket || 'page'),
                page_type: String(pageType || ''),
                ordered_task_keys: JSON.stringify(orderedKeys || [])
            }).then(function (data) {
                previewSortState.pending = false;
                if (data && data.success && data.data && typeof data.data === 'object') {
                    hydrateWorkspaceFromState(data.data);
                    toast('success', (data && data.message) ? String(data.message) : messages.taskPlanSortSaved);
                    return;
                }
                rerenderCurrentTaskPlanPreview();
                toast('warning', (data && data.message) ? String(data.message) : messages.taskPlanSortSaveFailed);
            }).catch(function (error) {
                previewSortState.pending = false;
                rerenderCurrentTaskPlanPreview();
                toast('error', (error && error.message) ? String(error.message) : messages.taskPlanSortSaveFailed);
            });
        };

        confirmTaskPlanMutationRiskIfNeeded().then(function (confirmed) {
            if (!confirmed) {
                previewSortState.pending = false;
                rerenderCurrentTaskPlanPreview();
                toast('info', messages.resumeDeferred);
                return;
            }
            commit();
        }).catch(function () {
            previewSortState.pending = false;
            rerenderCurrentTaskPlanPreview();
            toast('warning', messages.taskPlanSortSaveFailed);
        });
    }

    function persistPreviewSort(list, snapshot) {
        if (!list) {
            previewSortState.pending = false;
            return;
        }
        var meta = snapshot && typeof snapshot === 'object' ? snapshot : {};
        var orderedKeys = collectSortableKeys(list);
        var before = Array.isArray(meta.orderedKeysBefore) ? meta.orderedKeysBefore : [];
        if (orderedKeys.length < 2 || orderedKeys.join('||') === before.join('||')) {
            previewSortState.pending = false;
            return;
        }
        if (String(meta.stage || '') === 'task-plan') {
            persistTaskPlanSort(meta.bucket, meta.pageType, orderedKeys);
            return;
        }
        persistPlanBlockSort(meta.pageType, orderedKeys);
    }

    function bindPreviewSortables(container) {
        var root = typeof container === 'string' ? document.getElementById(container) : container;
        if (!root || root.dataset.pbPreviewSortBound === '1') {
            return;
        }
        root.dataset.pbPreviewSortBound = '1';
        root.addEventListener('click', function (event) {
            var handle = event.target && event.target.closest ? event.target.closest('[data-pb-sort-handle="1"]') : null;
            if (!handle || !root.contains(handle)) {
                return;
            }
            event.preventDefault();
            event.stopPropagation();
        });
        root.addEventListener('dragstart', function (event) {
            if (previewSortState.pending) {
                event.preventDefault();
                return;
            }
            var handle = event.target && event.target.closest ? event.target.closest('[data-pb-sort-handle="1"]') : null;
            if (!handle || !root.contains(handle)) {
                return;
            }
            var item = handle.closest('[data-pb-sort-item="1"]');
            var list = item && item.parentNode && item.parentNode.getAttribute && item.parentNode.getAttribute('data-pb-sort-list') === '1'
                ? item.parentNode
                : null;
            var sortKey = String(item && item.getAttribute ? item.getAttribute('data-pb-sort-key') : '').trim();
            if (!item || !list || sortKey === '') {
                event.preventDefault();
                return;
            }
            resetPreviewSortState();
            previewSortState.active = true;
            previewSortState.item = item;
            previewSortState.list = list;
            previewSortState.handle = handle;
            previewSortState.stage = String(list.getAttribute('data-pb-sort-stage') || 'plan').trim();
            previewSortState.bucket = String(list.getAttribute('data-pb-sort-bucket') || '').trim();
            previewSortState.pageType = String(list.getAttribute('data-pb-sort-page-type') || '').trim();
            previewSortState.orderedKeysBefore = collectSortableKeys(list);
            item.classList.add('pb-ai-sort-dragging');
            list.classList.add('pb-ai-sort-active');
            handle.classList.add('is-dragging');
            if (event.dataTransfer) {
                event.dataTransfer.effectAllowed = 'move';
                event.dataTransfer.dropEffect = 'move';
                try {
                    event.dataTransfer.setData('text/plain', sortKey);
                } catch (error) {
                    // 无操作：部分浏览器不允许 drag data，忽略即可。
                }
            }
        });
        root.addEventListener('dragover', function (event) {
            var list = event.target && event.target.closest ? event.target.closest('[data-pb-sort-list="1"]') : null;
            if (!previewSortState.active || !list || list !== previewSortState.list || !root.contains(list)) {
                return;
            }
            event.preventDefault();
            list.classList.add('pb-ai-sort-drag-over');
            var afterItem = resolveSortableAfterItem(list, event.clientY);
            if (!afterItem) {
                list.appendChild(previewSortState.item);
                return;
            }
            if (afterItem !== previewSortState.item) {
                list.insertBefore(previewSortState.item, afterItem);
            }
        });
        root.addEventListener('dragleave', function (event) {
            var list = event.target && event.target.closest ? event.target.closest('[data-pb-sort-list="1"]') : null;
            if (!list || list !== previewSortState.list || !root.contains(list)) {
                return;
            }
            var related = event.relatedTarget;
            if (related && list.contains(related)) {
                return;
            }
            list.classList.remove('pb-ai-sort-drag-over');
        });
        root.addEventListener('drop', function (event) {
            var list = event.target && event.target.closest ? event.target.closest('[data-pb-sort-list="1"]') : null;
            if (!previewSortState.active || !list || list !== previewSortState.list || !root.contains(list)) {
                return;
            }
            event.preventDefault();
            previewSortState.pending = true;
            var activeList = previewSortState.list;
            var snapshot = {
                stage: previewSortState.stage,
                bucket: previewSortState.bucket,
                pageType: previewSortState.pageType,
                orderedKeysBefore: Array.isArray(previewSortState.orderedKeysBefore) ? previewSortState.orderedKeysBefore.slice() : []
            };
            resetPreviewSortState({ preservePending: true });
            persistPreviewSort(activeList, snapshot);
        });
        root.addEventListener('dragend', function () {
            if (!previewSortState.active) {
                return;
            }
            resetPreviewSortState({ preservePending: previewSortState.pending });
        });
    }

    function isPlanGenerationRunningNow() {
        var runningStatuses = ['queued', 'running', 'pending', 'processing'];
        var active = currentActiveOperationState && typeof currentActiveOperationState === 'object'
            ? currentActiveOperationState
            : {};
        var activeOperation = String(active.operation || '').trim().toLowerCase();
        var activeStatus = String(active.status || '').trim().toLowerCase();
        if (activeOperation === 'plan' && runningStatuses.indexOf(activeStatus) !== -1) {
            return true;
        }
        var workspaceState = (window.__pbWorkspaceState && typeof window.__pbWorkspaceState === 'object')
            ? window.__pbWorkspaceState
            : ((window.__pbLastWorkspaceState && typeof window.__pbLastWorkspaceState === 'object') ? window.__pbLastWorkspaceState : null);
        if (!workspaceState || typeof workspaceState !== 'object') {
            return !!isOperationRunning;
        }
        var queueInfo = workspaceState.plan_queue_info && typeof workspaceState.plan_queue_info === 'object'
            ? workspaceState.plan_queue_info
            : null;
        var snapshot = queueInfo && queueInfo.snapshot && typeof queueInfo.snapshot === 'object'
            ? queueInfo.snapshot
            : null;
        var queueStatus = snapshot
            ? String(snapshot.job_status || snapshot.status || snapshot.queue_status || '').trim().toLowerCase()
            : '';
        if (queueStatus !== '' && runningStatuses.indexOf(queueStatus) !== -1) {
            return true;
        }
        return !!isOperationRunning;
    }

    function getPlanStructuredPreviewEmptyText() {
        if (isPlanGenerationRunningNow()) {
            return String(messages.planStructuredPreviewEmptyRunning || '方案正在生成中');
        }
        return String(messages.planStructuredPreviewEmpty || '方案等待确认');
    }

    function renderPlanPreviewEmptyStateHtml() {
        return ''
            + '<div class="d-flex align-items-center justify-content-center text-center w-100 h-100 py-5">'
            + '<div class="text-muted fs-5 fw-semibold">' + escapeHtml(getPlanStructuredPreviewEmptyText()) + '</div>'
            + '</div>';
    }

    function renderPlanStructuredPreviewHtml(planRoot) {
        if (!planRoot || typeof planRoot !== 'object') {
            return renderPlanPreviewEmptyStateHtml();
        }
        if (isTaskPlanStructuredRoot(planRoot)) {
            return renderTaskPlanStructuredPreviewHtml(planRoot);
        }
        function looksLikePagePlanObject(value) {
            if (!value || typeof value !== 'object' || Array.isArray(value)) {
                return false;
            }
            if (Array.isArray(value.blocks) && value.blocks.length > 0) {
                return true;
            }
            if (String(value.page_goal || value.goal || '').trim() !== '') {
                return true;
            }
            if (String(value.title || '').trim() !== '') {
                return true;
            }
            if (Array.isArray(value.primary_keywords) && value.primary_keywords.length > 0) {
                return true;
            }
            if (Array.isArray(value.secondary_keywords) && value.secondary_keywords.length > 0) {
                return true;
            }
            return false;
        }

        var pages = planRoot.pages && typeof planRoot.pages === 'object' ? planRoot.pages : null;
        if (!pages) {
            // 无显式 pages 字段时：从根对象中挑出「像单页方案」的键作为 pages（排除 plan_json、seo 等保留键）。
            var reservedKeys = {
                pages: true,
                page_types: true,
                seo_strategy: true,
                navigation_plan: true,
                footer_plan: true,
                palette: true,
                execution_steps: true,
                stage2_task_hints: true
            };
            var candidate = {};
            var hit = 0;
            Object.keys(planRoot).forEach(function (k) {
                if (reservedKeys[k]) {
                    return;
                }
                var v = planRoot[k];
                if (looksLikePagePlanObject(v)) {
                    candidate[k] = v;
                    hit += 1;
                }
            });
            if (hit > 0) {
                pages = candidate;
            } else if (looksLikePagePlanObject(planRoot)) {
                pages = { plan: planRoot };
            }
        }
        if (Array.isArray(pages) && pages.length > 0) {
            var mapped = {};
            pages.forEach(function (page, idx) {
                if (!page || typeof page !== 'object') {
                    return;
                }
                var key = String(page.page_type || page.type || page.title || ('page_' + (idx + 1)));
                mapped[key] = page;
            });
            pages = mapped;
        }
        var themeSections = [];
        var tabs = [];
        var themeHtml = renderThemeSummarySection(planRoot);
        var sharedBlocksHtml = renderPlanSharedBlocksSection(planRoot);
        var headerPlan = planRoot.navigation_plan || planRoot.header_plan || planRoot.header || null;
        var footerPlan = planRoot.footer_plan || planRoot.footer || null;
        var headerHtml = renderStructuredListSection(previewLabels.headerPlan, headerPlan, {
            reasonItems: collectPreviewReasonItems(headerPlan)
        });
        var footerHtml = renderStructuredListSection(previewLabels.footerPlan, footerPlan, {
            reasonItems: collectPreviewReasonItems(footerPlan)
        });
        if (themeHtml) {
            themeSections.push(themeHtml);
        }
        if (sharedBlocksHtml) {
            themeSections.push(sharedBlocksHtml);
        }
        if (headerHtml) {
            themeSections.push(headerHtml);
        }
        if (footerHtml) {
            themeSections.push(footerHtml);
        }
        tabs.push({
            key: 'theme',
            label: previewLabels.themeTab,
            content: themeSections.join('') || renderPreviewTabEmptyState(previewLabels.themeTabEmpty)
        });
        if (pages && typeof pages === 'object') {
            Object.keys(pages).forEach(function (pageType) {
                var page = pages[pageType];
                var pageCardHtml = renderPlanPagePreviewCard(pageType, page);
                if (!pageCardHtml) {
                    return;
                }
                tabs.push({
                    key: String(pageType || 'page'),
                    label: resolvePreviewTabPageLabel(pageType, page && (page.title || page.label || '')),
                    content: pageCardHtml
                });
            });
        }
        if (tabs.length === 0) {
            return renderPlanPreviewEmptyStateHtml();
        }
        return ''
            + buildPreviewStageToolbar('plan')
            + '<div class="mb-2">'
            + '<div class="fw-semibold">' + escapeHtml(String(messages.planStructuredPreviewTitle || '')) + '</div>'
            + '<div class="text-muted small">' + escapeHtml(String(messages.planStructuredPreviewNote || '')) + '</div>'
            + '</div>'
            + renderPreviewTabs('plan', tabs);
    }

    function buildPlanPreviewHtml(markdownText, payload) {
        var md = String(markdownText || '').trim();
        var parsedFromMd = tryParseJsonObject(md);
        if (parsedFromMd && typeof parsedFromMd === 'object' && typeof parsedFromMd.markdown === 'string' && String(parsedFromMd.markdown || '').trim() !== '') {
            md = String(parsedFromMd.markdown || '').trim();
        } else if (parsedFromMd && typeof parsedFromMd === 'object' && coerceStructuredPlanRootFromParsedJson(parsedFromMd)) {
            md = '';
        }

        var structuredRoot = pickStructuredPlanRoot(payload);
        if (!structuredRoot && parsedFromMd && typeof parsedFromMd === 'object') {
            structuredRoot = coerceStructuredPlanRootFromParsedJson(parsedFromMd);
        }

        // 有结构化根数据时优先渲染结构化预览；当 Markdown 与结构化数据都为空时显示状态文案，避免空白区域。
        if (!structuredRoot && md === '') {
            return renderPlanPreviewEmptyStateHtml();
