            if (payload.type === 'PageBuilderVisualEditor' && String(payload.action || '') === 'navigate') {
                var targetTab = findPreviewTabByPayload(payload);
                if (targetTab) {
                    switchPreviewByTab(targetTab);
                }
            }
        });
    }

