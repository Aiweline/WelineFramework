            current_url: String(imageRegenerateState.current_url_raw || imageRegenerateState.current_url || '').trim(),
            resolved_url: String(imageRegenerateState.current_url || '').trim(),
            block_id: String(imageRegenerateState.block_id || '').trim(),
            component_code: String(imageRegenerateState.component_code || imageRegenerateState.component || '').trim()
        }).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && (data.message || data.error)) ? String(data.message || data.error) : 'Image regeneration failed to start.');
            }
            var payload = data && data.data && typeof data.data === 'object' ? data.data : (data || {});
            var nextState = payload.state || payload.workspace_state || payload;
            if (nextState && typeof nextState === 'object' && (nextState.scope || nextState.asset_manifest || nextState.active_operation)) {
