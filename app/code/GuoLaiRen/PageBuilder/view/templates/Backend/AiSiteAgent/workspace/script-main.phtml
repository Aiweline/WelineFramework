            + '</div>'
            + '<p class="mb-2">' + escapeHtml(message) + '</p>'
            + (processText ? '<div class="small text-muted mb-1">' + <?= \json_encode((string)__('进程状态'), \JSON_UNESCAPED_UNICODE | \JSON_HEX_TAG | \JSON_HEX_AMP | \JSON_HEX_APOS | \JSON_HEX_QUOT) ?> + '</div><pre class="small bg-light border rounded p-2 mb-2 text-break" style="white-space:pre-wrap;max-height:7rem;overflow:auto;">' + escapeHtml(processText) + '</pre>' : '')
            + (resultText ? '<div class="small text-muted mb-1">' + <?= \json_encode((string)__('队列日志'), \JSON_UNESCAPED_UNICODE | \JSON_HEX_TAG | \JSON_HEX_AMP | \JSON_HEX_APOS | \JSON_HEX_QUOT) ?> + '</div><pre class="small bg-light border rounded p-2 mb-0 text-break" style="white-space:pre-wrap;max-height:8rem;overflow:auto;">' + escapeHtml(resultText) + '</pre>' : '')
            + '</div>'
            + '<div class="modal-footer">'
            + '<button type="button" class="btn btn-primary" data-bs-dismiss="modal" data-pb-queue-notice-confirm="1">' + escapeHtml(confirmLabel) + '</button>'
            + '</div>'
            + '</div>'
            + '</div>';
        var confirmBtn = modalEl.querySelector('[data-pb-queue-notice-confirm="1"]');
        if (confirmBtn && reloadOnAck) {
            confirmBtn.addEventListener('click', function () {
                window.location.reload();
            }, { once: true });
        }
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            resolveBootstrapModalInstance(modalEl).show();
            return;
        }
        toast(level === 'error' ? 'error' : (level === 'success' ? 'success' : 'warning'), message);
    }

    function safeWorkspaceBootStep(label, callback) {
        try {
            if (typeof callback === 'function') {
                callback();
            }
        } catch (error) {
            console.error('[PageBuilder AI workspace boot]', label, error);
        }
    }

    if (initialWorkspaceState && typeof initialWorkspaceState === 'object') {
        safeWorkspaceBootStep('hydrate_initial_state', function () {
            hydrateInitialWorkspaceStateOnce();
        });
        safeWorkspaceBootStep('entry_queue_notice', function () {
            showWorkspaceEntryQueueNotice(initialWorkspaceState);
        });
    }
    safeWorkspaceBootStep('asset_panel', bindAssetPanelLogic);
    safeWorkspaceBootStep('reference_image_upload', bindReferenceImageUploadLogic);
    safeWorkspaceBootStep('reference_image_sync', function () {
        syncReferenceImagePanelFromWorkspaceState(initialWorkspaceState);
    });
    var bootStage = String(currentStageCode || currentWorkspaceStage || '').trim().toLowerCase();
    if (bootStage === 'visual_edit') {
        safeWorkspaceBootStep('visual_edit_stage', bindVisualEditStageLogic);
    } else if (bootStage === 'publish') {
        safeWorkspaceBootStep('publish_stage', bindPublishStageLogic);
    } else {
        safeWorkspaceBootStep('plan_stage', bindPlanStageLogic);
    }
    safeWorkspaceBootStep('plan_reload_reconciliation', function () {
        window.setTimeout(runPlanReloadReconciliation, 180);
    });
})();
