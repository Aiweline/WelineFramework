        if (format === 'nav-items' && Array.isArray(raw)) {
            return raw.map(function (item) {
                if (!item || typeof item !== 'object') {
                    return '';
                }
                return [String(item.label || ''), String(item.href || '')].join('|');
            }).filter(Boolean).join('\n');
        }
        if (format === 'card-items' && Array.isArray(raw)) {
