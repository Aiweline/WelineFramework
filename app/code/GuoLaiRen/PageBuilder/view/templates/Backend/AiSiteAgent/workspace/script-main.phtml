            }
            if (status) {
                status.className = 'small mt-3 text-success';
                status.textContent = 'Queued. Waiting for the scheduler to generate the selected image.';
            }
            if (window.PbAiOperationRunner && typeof window.PbAiOperationRunner.startFromResponse === 'function') {
                window.PbAiOperationRunner.startFromResponse(data, 'image_asset');
            }
            hideBootstrapModal(modal);
        }).catch(function (error) {
            if (status) {
                status.className = 'small mt-3 text-danger';
                status.textContent = String(error && error.message ? error.message : messages.networkError);
            }
        }).finally(function () {
            if (submit) {
                submit.disabled = false;
            }
        });
    }

