    function preparePlanPreviewActionContext(actionContext) {
        var nextContext = actionContext && typeof actionContext === 'object' ? actionContext : null;
        var previousFingerprint = getPreviewActionContextFingerprint(currentPlanModeActionContext);
        var nextFingerprint = getPreviewActionContextFingerprint(nextContext);
        currentPlanModeActionContext = nextContext;
        currentPlanModeTargetScope = nextContext ? String(nextContext.targetScope || '').trim() : '';
        syncPendingPreviewActionDomState('plan', nextContext);
        var promptInput = document.getElementById('pb-ai-plan-mode-prompt');
        if (promptInput) {
            bindPromptInputValidationReset(promptInput);
            if (nextFingerprint !== previousFingerprint || String(promptInput.value || '').trim() === '') {
                promptInput.value = '';
            }
            promptInput.placeholder = nextContext && nextContext.promptHint
                ? String(nextContext.promptHint)
                : getPromptInputDefaultPlaceholder(promptInput);
            setPromptInputInvalidState(promptInput, false);
        }
        updatePlanModeContextUi(nextContext && nextContext.summary ? nextContext.summary : messages.planModeInstructionHint);
        setPlanModeStatus(nextContext ? messages.planActionPrepared : (String(planSseUrl || '').trim() ? messages.planModeReady : messages.planModeUnavailable));
    }

    function prepareTaskPlanPreviewActionContext(actionContext) {
