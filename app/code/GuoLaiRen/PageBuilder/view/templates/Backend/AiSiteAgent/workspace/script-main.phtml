                    if (targetTab) {
                        switchPreviewByTab(targetTab);
                    }
                }, true);
            });
        }

        if (frame.dataset.pbWorkspaceLoadBound !== '1') {
            frame.dataset.pbWorkspaceLoadBound = '1';
            frame.addEventListener('load', function () {
                window.setTimeout(attachBridge, 60);
            });
        }

        window.setTimeout(attachBridge, 60);
    }

