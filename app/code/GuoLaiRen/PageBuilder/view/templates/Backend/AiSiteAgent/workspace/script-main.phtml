    function markBuildOperationTerminalForUi(operation, status, message) {
        var normalizedOperation = String(operation || '').trim().toLowerCase();
        var previous = currentActiveOperationState && typeof currentActiveOperationState === 'object'
            ? currentActiveOperationState
            : {};
        var previousOperation = String(previous.operation || '').trim().toLowerCase();
        var isBuildTerminal = isPublishBlockingOperationName(normalizedOperation)
            || previousOperation === 'build'
            || isPublishBlockingOperationName(previousOperation);
        if (!isBuildTerminal) {
            return;
        }
        var normalizedStatus = String(status || 'error').trim().toLowerCase() || 'error';
        var active = Object.assign({}, previous, {
            operation: String(previous.operation || (normalizedOperation === 'visual_edit' ? 'build' : normalizedOperation || 'build')),
            status: normalizedStatus
        });
        if (message) {
            active.message = String(message);
        }
        currentActiveOperationState = active;
        isOperationRunning = false;
        buildStartupPending = false;
        if (!latestWorkspaceState || typeof latestWorkspaceState !== 'object') {
            latestWorkspaceState = {};
        }
        latestWorkspaceState.active_operation = active;
        var statePatch = { active_operation: active };
        if (isPublishFailureStatus(normalizedStatus)) {
            var failure = {
                blocked: true,
                operation: String(active.operation || normalizedOperation || 'build'),
                status: normalizedStatus,
                message: String(message || active.message || '')
            };
            latestWorkspaceState.latest_build_failed = true;
            latestWorkspaceState.latest_build_failure = failure;
            latestWorkspaceState.publish_blocked_by_latest_ai_failure = true;
            latestWorkspaceState.publish_blocked_reason = failure.message;
            latestWorkspaceState.can_publish = false;
            latestWorkspaceState.workspace_status = 'failed';
            statePatch.latest_build_failed = true;
            statePatch.latest_build_failure = failure;
            statePatch.publish_blocked_by_latest_ai_failure = true;
            statePatch.publish_blocked_reason = failure.message;
            statePatch.can_publish = false;
            statePatch.workspace_status = 'failed';
        }
        renderQueueUiState('build', {
            state: normalizedStatus,
            message: String(message || active.message || ''),
            percent: (normalizedStatus === 'done' || normalizedStatus === 'complete' || normalizedStatus === 'completed') ? 100 : 0
        }, { updateStatus: false });
        try {
            var workspaceMirror = window.__pbWorkspaceState && typeof window.__pbWorkspaceState === 'object'
                ? Object.assign({}, window.__pbWorkspaceState, statePatch)
                : Object.assign({}, statePatch);
            var lastMirror = window.__pbLastWorkspaceState && typeof window.__pbLastWorkspaceState === 'object'
                ? Object.assign({}, window.__pbLastWorkspaceState, statePatch)
                : Object.assign({}, statePatch);
            window.__pbWorkspaceState = normalizeWorkspaceStateShape(workspaceMirror);
            window.__pbLastWorkspaceState = sanitizeWorkspaceStateForMemory(normalizeWorkspaceStateShape(lastMirror));
        } catch (e) {
            // UI state is already updated locally; cross-script mirrors are best-effort.
        }
        syncPublishRepairButtonDisabledState();
        syncBuildPlanStartButtonState(latestWorkspaceState);
        syncRebuildBuildStageButtonState(latestWorkspaceState);
        syncPublishStageEntryFromWorkspaceState(latestWorkspaceState);
    }

    function resetBuildStartUi() {
