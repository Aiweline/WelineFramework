        if (domain === '') {
            bindTargetDomainInvalidClearOnce();
            setTargetDomainFieldInvalid(true);
            toast('warning', messages.domainRequiredForBuild);
            return Promise.resolve(false);
        }
        if (/\.weline\.local$/i.test(domain)) {
            return Promise.resolve(true);
