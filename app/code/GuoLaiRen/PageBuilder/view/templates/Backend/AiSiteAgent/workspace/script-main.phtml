    function collectPreviewReasonItems(value) {
        var reasons = [];
        var seen = {};
        function pushReason(raw) {
            var text = sanitizePreviewText(raw, '');
            if (!text || seen[text]) {
                return;
            }
            seen[text] = true;
            reasons.push(text);
        }
        function visit(candidate, depth) {
            if (depth > 3 || candidate === null || typeof candidate === 'undefined') {
                return;
            }
            if (Array.isArray(candidate)) {
                candidate.forEach(function (item) {
                    visit(item, depth + 1);
                });
                return;
            }
            if (!candidate || typeof candidate !== 'object') {
                return;
            }
            ['reason', 'why', 'selection_reason', 'decision_reason', 'planning_reason', 'rationale', 'explanation'].forEach(function (key) {
                if (Object.prototype.hasOwnProperty.call(candidate, key)) {
                    pushReason(candidate[key]);
                }
            });
            Object.keys(candidate).forEach(function (key) {
                var normalized = String(key || '').toLowerCase();
                var child = candidate[key];
                if (normalized === 'reason' || normalized === 'why' || normalized === 'selection_reason' || normalized === 'decision_reason' || normalized === 'planning_reason' || normalized === 'rationale' || normalized === 'explanation') {
                    return;
                }
                if (child && typeof child === 'object') {
                    visit(child, depth + 1);
                }
            });
        }
        visit(value, 0);
        return reasons;
    }

