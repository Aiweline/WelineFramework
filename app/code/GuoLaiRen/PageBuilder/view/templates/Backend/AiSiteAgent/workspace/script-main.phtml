    function getPreviewActionContextFingerprint(context) {
        if (!context || typeof context !== 'object') {
            return '';
        }
        return [
            String(context.stage || '').trim(),
            String(context.action || '').trim(),
            String(context.scopeKind || '').trim(),
            String(context.targetScope || '').trim(),
            String(context.pageType || '').trim(),
            String(context.blockKey || '').trim(),
            String(context.pageLabel || '').trim(),
            String(context.blockLabel || '').trim()
        ].join('::');
    }

    function syncPendingPreviewActionDomState(stage, context) {
        var normalizedStage = String(stage || 'plan').trim() === 'task-plan' ? 'task-plan' : 'plan';
        var ids = normalizedStage === 'task-plan'
            ? ['pb-ai-task-plan-run-mode', 'pb-ai-task-plan-mode-prompt', 'pb-ai-task-plan-mode-context']
            : ['pb-ai-plan-run-mode', 'pb-ai-plan-mode-prompt', 'pb-ai-plan-mode-context'];
        var fingerprint = getPreviewActionContextFingerprint(context);
        ids.forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) {
                return;
            }
            if (!fingerprint) {
                el.removeAttribute('data-pb-pending-action');
                el.removeAttribute('data-pb-pending-action-fingerprint');
                return;
            }
            el.setAttribute('data-pb-pending-action', '1');
            el.setAttribute('data-pb-pending-action-fingerprint', fingerprint);
        });
    }

    function hasPendingPreviewActionDomState(stage) {
        var normalizedStage = String(stage || 'plan').trim() === 'task-plan' ? 'task-plan' : 'plan';
        var ids = normalizedStage === 'task-plan'
            ? ['pb-ai-task-plan-run-mode', 'pb-ai-task-plan-mode-prompt', 'pb-ai-task-plan-mode-context']
            : ['pb-ai-plan-run-mode', 'pb-ai-plan-mode-prompt', 'pb-ai-plan-mode-context'];
        return ids.some(function (id) {
            var el = document.getElementById(id);
            return !!(el && String(el.getAttribute('data-pb-pending-action') || '').trim() === '1');
        });
    }

    function getPromptInputDefaultPlaceholder(input) {
        if (!input) {
            return '';
        }
        return String(input.getAttribute('data-default-placeholder') || input.getAttribute('placeholder') || '').trim();
    }

    function setPromptInputInvalidState(input, invalid) {
        if (!input || !input.classList) {
            return;
        }
        input.classList.toggle('is-invalid', !!invalid);
    }

    function bindPromptInputValidationReset(input) {
        if (!input || input.dataset.pbPromptValidationBound === '1') {
            return;
        }
        input.dataset.pbPromptValidationBound = '1';
        input.addEventListener('input', function () {
            if (String(input.value || '').trim() !== '') {
                setPromptInputInvalidState(input, false);
            }
        });
    }

    function buildPreviewActionPrompt(stage, action, scopeKind, pageLabel, blockLabel) {
        var pageText = String(pageLabel || '页面').trim();
        var blockText = String(blockLabel || '区块').trim();
        var stageText = stage === 'task-plan' ? '第二阶段任务方案' : '第一阶段方案';
        var scope = String(scopeKind || 'block').trim();
        var actionText = getPreviewActionLabel(action);

        if (scope === 'stage') {
            return '请' + actionText + '“' + stageText + '”，并保持页面结构完整、逻辑一致。';
        }
        if (scope === 'page') {
            return '请在“' + pageText + '”范围内执行“' + actionText + '”，并确保该页与站点整体风格一致。';
        }
        return '请在“' + pageText + '”的“' + blockText + '”区块执行“' + actionText + '”，输出可直接发布的内容。';
    }

    function buildPreviewActionContext(stage, action, scopeKind, pageLabel, blockLabel, targetScope, pageType, blockKey) {
        var normalizedStage = String(stage || 'plan').trim();
        var normalizedScopeKind = String(scopeKind || 'block').trim();
        var pageText = String(pageLabel || '').trim();
        var blockText = String(blockLabel || '').trim();
        var actionLabel = getPreviewActionLabel(action);
        var subject = '';

        if (normalizedScopeKind === 'stage') {
            subject = normalizedStage === 'task-plan' ? '第二阶段任务方案' : '第一阶段方案';
        } else if (normalizedScopeKind === 'page') {
            subject = '页面“' + (pageText || '未命名页面') + '”';
        } else {
            subject = '页面“' + (pageText || '未命名页面') + '”的区块“' + (blockText || '未命名区块') + '”';
        }

        return {
            stage: normalizedStage,
            action: String(action || '').trim(),
            scopeKind: normalizedScopeKind,
            targetScope: String(targetScope || '').trim(),
            pageType: String(pageType || '').trim(),
            blockKey: String(blockKey || '').trim(),
            pageLabel: pageText,
            blockLabel: blockText,
            promptHint: buildPreviewActionPrompt(normalizedStage, action, normalizedScopeKind, pageText, blockText),
            summary: '准备执行“' + actionLabel + '”，作用范围：' + subject + '。'
        };
    }

