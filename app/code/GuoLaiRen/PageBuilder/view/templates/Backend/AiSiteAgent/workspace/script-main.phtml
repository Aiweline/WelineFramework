            status.textContent = 'Queueing image regeneration...';
        }
        postForm(startAssetGenerationUrl, {
            public_id: publicId,
            slot_id: slotId,
            prompt_brief: instruction,
            slot_type: slot ? (readAssetSlotValue(slot, ['slot_type', 'kind']) || 'section_image') : 'section_image',
            page_type: String(imageRegenerateState.page_type || getActivePreviewPageType() || '').trim(),
