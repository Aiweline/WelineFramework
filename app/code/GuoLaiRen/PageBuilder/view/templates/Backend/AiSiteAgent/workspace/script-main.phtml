    }

    function isQueueUiBusyStatus(status) {
        return ['pending', 'queued', 'running', 'processing'].indexOf(String(status || '').trim().toLowerCase()) !== -1;
    }

    function normalizePlanQueueLatestMessage(message) {
        var text = String(message || '').replace(/\r\n|\r/g, '\n').trim();
        if (text === '') {
            return '';
        }
        var lines = text.split('\n').map(function (line) {
            return String(line || '').trim();
        }).filter(Boolean);
        return lines.length > 0 ? lines[lines.length - 1] : text;
    }

    function updatePlanQueueLatestMessage(message) {
        var latestEl = document.getElementById('pb-ai-plan-queue-latest-message');
        if (!latestEl) {
            return;
        }
        var text = normalizePlanQueueLatestMessage(message);
        latestEl.textContent = text;
        latestEl.classList.toggle('d-none', text === '');
    }

    window.__pbUpdatePlanQueueLatestMessage = updatePlanQueueLatestMessage;

    function renderQueueUiState(kind, queueState, options) {
        var queueKind = String(kind || 'plan').trim() === 'build' ? 'build' : 'plan';
        var state = queueState && typeof queueState === 'object' ? queueState : {};
        var opts = options && typeof options === 'object' ? options : {};
        var status = String(state.state || state.status || state.queue_status || 'idle').trim().toLowerCase();
        var percent = Math.max(0, Math.min(100, parseInt(state.percent || state.progress || 0, 10) || 0));
        var message = String(state.message || state.process || '').trim();
        var latestPlanState = queueKind === 'plan' ? getLatestWorkspaceStateForQueuePrompt() : {};
        var planStillRunning = queueKind === 'plan'
            && (isPhaseOneQueueUnfinished() || hasRunningQueueForUi(latestPlanState, 'plan'));
        if (planStillRunning && !isQueueUiBusyStatus(status)) {
            status = 'running';
            percent = Math.max(1, Math.min(99, percent || 1));
            message = message || String(messages.planGenerating || messages.planModeRunning || '');
        }
        if (queueKind === 'plan' && isPlanFailureStatusForWorkspaceUi(status) && shouldIgnoreResolvedPlanTerminalFailure({}, message)) {
            status = 'completed';
            percent = 100;
            message = String(messages.planModeDone || messages.planGenerated || '');
        }
        if (queueKind === 'plan' && !planStillRunning && ['done', 'complete', 'completed', 'success'].indexOf(status) !== -1) {
            var planBlockingMessage = getPhaseOnePlanBlockingErrorMessage(latestPlanState);
            if (planBlockingMessage !== '') {
                status = 'failed';
                percent = 100;
                message = planBlockingMessage;
            }
        }
        if (queueKind === 'plan') {
            updatePlanQueueLatestMessage(message);
        }
        var label = queueKind === 'build' ? 'Build' : 'Stage 1 plan';
        var detail = label + ': ' + (status || 'idle');
        if (message) {
            detail += ' - ' + message;
        }
        document.querySelectorAll('[data-pb-queue-state-detail="' + queueKind + '"]').forEach(function (el) {
            el.textContent = detail;
        });
        document.querySelectorAll(queueKind === 'build' ? '[data-build-queue-status="build"]' : '[data-phase1-queue-status="plan"]').forEach(function (el) {
            el.textContent = status || 'idle';
        });
        if (queueKind === 'plan') {
            var planProgressBar = document.getElementById('pb-ai-plan-progress-bar');
            if (planProgressBar) {
                planProgressBar.style.width = percent + '%';
            }
        } else {
            var buildProgressBar = document.getElementById('pb-ai-build-guard-progress-bar');
            if (buildProgressBar) {
                buildProgressBar.style.width = percent + '%';
            }
        }
        if (opts.updateStatus !== false) {
            updateStageStatusSummary(getLatestWorkspaceStateForQueuePrompt());
        }
    }

    function normalizeQueueStatusForPrompt(status) {
        return String(status || '').trim().toLowerCase();
    }

    function isQueueStatusRunningForUi(status) {
        return ['pending', 'queued', 'running', 'processing'].indexOf(normalizeQueueStatusForPrompt(status)) !== -1;
    }

    function isQueueStatusTerminalForUi(status) {
        return ['done', 'complete', 'completed', 'error', 'failed', 'stop', 'stopped', 'cancelled', 'canceled'].indexOf(normalizeQueueStatusForPrompt(status)) !== -1;
    }

    function isTruthyQueueFlagForUi(value) {
        if (value === true || value === 1) {
            return true;
        }
        var normalized = String(value || '').trim().toLowerCase();
        return normalized === '1' || normalized === 'true' || normalized === 'yes';
    }

    function isQueueTerminalRecoveryForUi(info) {
        if (!info || typeof info !== 'object') {
            return false;
        }
        var snapshot = info.snapshot && typeof info.snapshot === 'object' ? info.snapshot : {};
        var semanticStatus = normalizeQueueStatusForPrompt(info.semantic_status || snapshot.semantic_status || '');
        if (semanticStatus === 'stale' || isQueueStatusTerminalForUi(semanticStatus)) {
            return true;
        }
        if (isTruthyQueueFlagForUi(info.queue_terminal_recovered || snapshot.queue_terminal_recovered)) {
            return true;
        }
        if (isTruthyQueueFlagForUi(info.finished || snapshot.finished)) {
            return true;
        }
        return isTruthyQueueFlagForUi(info.retry_allowed || snapshot.retry_allowed)
            && (semanticStatus === 'stale' || isQueueStatusTerminalForUi(semanticStatus));
    }

    function readQueueStatusForPrompt(info) {
        if (!info || typeof info !== 'object') {
            return normalizeQueueStatusForPrompt(info);
        }
        var snapshot = info.snapshot && typeof info.snapshot === 'object' ? info.snapshot : {};
        var directStatus = normalizeQueueStatusForPrompt(info.status || info.queue_status || info.state || '');
        var snapshotStatus = normalizeQueueStatusForPrompt(snapshot.status || snapshot.job_status || snapshot.queue_status || '');
        if (isQueueTerminalRecoveryForUi(info)) {
            var semanticStatus = normalizeQueueStatusForPrompt(info.semantic_status || snapshot.semantic_status || '');
            if (isPlanSuccessStatusForWorkspaceUi(directStatus)) {
                return directStatus;
            }
            if (isPlanSuccessStatusForWorkspaceUi(snapshotStatus)) {
                return snapshotStatus;
            }
            if (isPlanSuccessStatusForWorkspaceUi(semanticStatus)) {
                return semanticStatus;
            }
            return semanticStatus && (semanticStatus === 'stale' || isQueueStatusTerminalForUi(semanticStatus))
                ? semanticStatus
                : 'cancelled';
        }
        if (isQueueStatusTerminalForUi(directStatus) || isQueueStatusRunningForUi(directStatus)) {
            return directStatus;
        }
        if (isQueueStatusTerminalForUi(snapshotStatus) || isQueueStatusRunningForUi(snapshotStatus)) {
            return snapshotStatus;
        }
        return directStatus || snapshotStatus;
    }

    function hasRunningQueueForUi(workspaceState, operationFilter) {
        var state = workspaceState && typeof workspaceState === 'object'
            ? workspaceState
            : getLatestWorkspaceStateForQueuePrompt();
        var normalizedFilter = String(operationFilter || '').trim().toLowerCase();
        if ((normalizedFilter === '' || normalizedFilter === 'plan') && isWorkspacePlanQueueTerminal(state)) {
            return false;
        }
        var operations = normalizedFilter === 'plan' || normalizedFilter === 'build'
            ? [normalizedFilter]
            : ['plan', 'build'];
        var candidates = [];
        if (state.active_operation && typeof state.active_operation === 'object') {
            var activeOperationName = String(state.active_operation.operation || '').trim().toLowerCase();
            if (!normalizedFilter || activeOperationName === normalizedFilter) {
                candidates.push(state.active_operation);
            }
        }
        var activeOperations = state.active_operations && typeof state.active_operations === 'object'
            ? state.active_operations
            : {};
        operations.forEach(function (operation) {
            if (activeOperations[operation] && typeof activeOperations[operation] === 'object') {
                candidates.push(activeOperations[operation]);
            }
            var queueInfo = state[operation + '_queue_info'];
            if (queueInfo && typeof queueInfo === 'object') {
                candidates.push(queueInfo);
            }
        });
        return candidates.some(function (item) {
            return isQueueStatusRunningForUi(readQueueStatusForPrompt(item));
        });
    }

    function hasAnyRunningQueueForUi(workspaceState) {
        return hasRunningQueueForUi(workspaceState, '');
    }

    function hasBuildOperationRunningForUi(workspaceState) {
        var state = workspaceState && typeof workspaceState === 'object'
            ? normalizeWorkspaceStateShape(workspaceState)
            : getLatestWorkspaceStateForQueuePrompt();
        var candidates = [];
        if (state.active_operation && typeof state.active_operation === 'object') {
            candidates.push(state.active_operation);
        }
        if (state.active_operations && typeof state.active_operations === 'object' && state.active_operations.build) {
            candidates.push(state.active_operations.build);
        }
        if (state.build_queue_info && typeof state.build_queue_info === 'object') {
            candidates.push(state.build_queue_info);
        }
        return candidates.some(function (item) {
            var operation = String(item.operation || 'build').trim().toLowerCase();
            var status = readQueueStatusForPrompt(item);
            return (operation === 'build' || operation === 'visual_edit') && isQueueStatusRunningForUi(status);
        });
    }

    function isBuildActionLocked(workspaceState) {
        return !!buildStartupPending
            || isThemeBuildGenerationRunning()
            || hasBuildOperationRunningForUi(workspaceState);
    }

    function countRetryableAiFailureBucket(bucket) {
        if (!bucket) {
            return 0;
        }
        if (Array.isArray(bucket)) {
            return bucket.length;
        }
        if (typeof bucket !== 'object') {
            return 0;
        }
        if (bucket.message || bucket.error || bucket.item_key || bucket.page_type || bucket.section_code) {
            return 1;
        }
        var directCount = parseInt(String(bucket.count || bucket.total || bucket.retryable_count || 0), 10) || 0;
        if (directCount > 0) {
            return directCount;
        }
        var total = 0;
        ['items', 'failures', 'failed_items', 'batches'].forEach(function (key) {
            if (Array.isArray(bucket[key])) {
                total += bucket[key].length;
                return;
            }
            if (bucket[key] && typeof bucket[key] === 'object') {
                Object.keys(bucket[key]).forEach(function (itemKey) {
                    total += countRetryableAiFailureBucket(bucket[key][itemKey]);
                });
            }
        });
        if (total > 0) {
            return total;
        }
        Object.keys(bucket).forEach(function (key) {
            if (key === 'operation' || key === 'message' || key === 'status') {
                return;
            }
            total += countRetryableAiFailureBucket(bucket[key]);
        });
        return total;
    }

    function getRetryableAiFailureCount(workspaceState, operation) {
        var state = workspaceState && typeof workspaceState === 'object'
            ? workspaceState
            : getLatestWorkspaceStateForQueuePrompt();
        var scope = state.scope && typeof state.scope === 'object' ? state.scope : {};
        var normalizedOperation = String(operation || '').trim();
        var summary = state.retryable_ai_failure_summary && typeof state.retryable_ai_failure_summary === 'object'
            ? state.retryable_ai_failure_summary
            : {};
        var summaryOperations = summary.operations && typeof summary.operations === 'object' ? summary.operations : {};
        var candidates = [];
        if (normalizedOperation !== '') {
            candidates.push(parseInt(String(summaryOperations[normalizedOperation] || 0), 10) || 0);
            [state.retryable_ai_failures, scope.retryable_ai_failures].forEach(function (ledger) {
                if (!ledger || typeof ledger !== 'object') {
                    return;
                }
                if (Array.isArray(ledger)) {
                    candidates.push(ledger.filter(function (item) {
                        return !item || typeof item !== 'object' || String(item.operation || '').trim() === normalizedOperation;
                    }).length);
                    return;
                }
                if (ledger[normalizedOperation]) {
                    candidates.push(countRetryableAiFailureBucket(ledger[normalizedOperation]));
                } else if (String(ledger.operation || '').trim() === normalizedOperation) {
                    candidates.push(countRetryableAiFailureBucket(ledger));
                }
            });
            if (normalizedOperation === 'build' && !hasPublishBlockingAiOperationRunningFromWorkspaceState(state)) {
                [
                    state.latest_build_failed,
                    state.publish_blocked_by_latest_ai_failure,
                    scope.latest_build_failed,
                    scope.publish_blocked_by_latest_ai_failure
                ].forEach(function (flag) {
                    if (flag) {
                        candidates.push(1);
                    }
                });
            }
        } else {
            candidates.push(parseInt(String(state.retryable_ai_failure_count || 0), 10) || 0);
            candidates.push(parseInt(String(scope.retryable_ai_failure_count || 0), 10) || 0);
            candidates.push(parseInt(String(summary.count || 0), 10) || 0);
            candidates.push(getRetryableAiFailureCount(state, 'plan'));
            candidates.push(getRetryableAiFailureCount(state, 'build'));
        }
        return Math.max.apply(Math, candidates.concat([0]));
    }

    function hasRetryableAiFailures(workspaceState, operation) {
        return getRetryableAiFailureCount(workspaceState, operation) > 0;
    }

    function hasPublishBlockingRetryableAiFailures(workspaceState) {
        return hasRetryableAiFailures(workspaceState, 'plan')
            || hasRetryableAiFailures(workspaceState, 'build');
    }

    function collectRetryableAiFailureItems(workspaceState, operation) {
        var state = workspaceState && typeof workspaceState === 'object'
            ? workspaceState
            : getLatestWorkspaceStateForQueuePrompt();
        var scope = state.scope && typeof state.scope === 'object' ? state.scope : {};
        var normalizedOperation = String(operation || '').trim();
        var items = [];
        function appendItem(item) {
            if (!item || typeof item !== 'object') {
                return;
            }
            if (normalizedOperation !== '' && String(item.operation || '').trim() !== normalizedOperation) {
                return;
            }
            items.push(item);
        }
        function appendObjectMap(map) {
            if (!map || typeof map !== 'object') {
                return;
            }
            Object.keys(map).forEach(function (key) {
                appendItem(map[key]);
            });
        }
        function appendBucket(bucket) {
            if (!bucket) {
                return;
            }
            if (Array.isArray(bucket)) {
                bucket.forEach(appendItem);
                return;
            }
            if (typeof bucket !== 'object') {
                return;
            }
            if (bucket.message || bucket.error || bucket.item_key || bucket.page_type || bucket.section_code) {
                appendItem(bucket);
            }
            if (Array.isArray(bucket.items)) {
                bucket.items.forEach(appendItem);
            } else if (bucket.items && typeof bucket.items === 'object') {
                appendObjectMap(bucket.items);
            }
            if (Array.isArray(bucket.failures)) {
                bucket.failures.forEach(appendItem);
            } else if (bucket.failures && typeof bucket.failures === 'object') {
                appendObjectMap(bucket.failures);
            }
            if (Array.isArray(bucket.failed_items)) {
                bucket.failed_items.forEach(appendItem);
            } else if (bucket.failed_items && typeof bucket.failed_items === 'object') {
                appendObjectMap(bucket.failed_items);
            }
        }
        var summary = state.retryable_ai_failure_summary && typeof state.retryable_ai_failure_summary === 'object'
            ? state.retryable_ai_failure_summary
            : {};
        appendBucket(summary);
        [state.retryable_ai_failures, scope.retryable_ai_failures].forEach(function (ledger) {
            if (!ledger || typeof ledger !== 'object') {
                return;
            }
            if (normalizedOperation !== '' && ledger[normalizedOperation]) {
                appendBucket(ledger[normalizedOperation]);
                return;
            }
            appendBucket(ledger);
        });
        if (items.length === 0 && normalizedOperation === 'build') {
            [state.latest_build_failure, scope.latest_build_failure].forEach(appendItem);
        }
        var seen = {};
        return items.filter(function (item) {
            var itemKey = String((item && item.item_key) || (item && item.page_type) || '').trim();
            var retryScope = String((item && item.retry_scope) || '').trim();
            var op = String((item && item.operation) || normalizedOperation || '').trim();
            var fingerprint = op + ':' + retryScope + ':' + itemKey;
            if (fingerprint === '::' || seen[fingerprint]) {
                return false;
            }
            seen[fingerprint] = true;
            return true;
        });
    }

    function formatRetryableAiFailureItem(item, index) {
        var failure = item && typeof item === 'object' ? item : {};
        var parts = [];
        ['operation', 'page_type', 'section_code', 'block_key', 'item_key', 'retry_scope', 'queue_id'].forEach(function (key) {
            var value = String(failure[key] || '').trim();
            if (value !== '') {
                parts.push(key + '=' + value);
            }
        });
        var rawMessage = String(failure.message || failure.error || '').trim();
        var message = failure.operation === 'build' || String(failure.retry_scope || '') === 'build_task'
            ? normalizeBuildFailureMessage(rawMessage)
            : rawMessage;
        var label = parts.length > 0 ? parts.join(' / ') : (message !== '' ? message : 'unknown');
        var failureClass = String(failure.failure_class || '').trim();
        var failureSource = String(failure.failure_source || '').trim();
        var validationSummary = String(failure.validation_summary || '').trim();
        var aiResponseSummary = String(failure.ai_response_summary || '').trim();
        var validationIssues = failure.validation_issues;
        var issueText = '';
        if (Array.isArray(validationIssues) && validationIssues.length > 0) {
            try {
                issueText = JSON.stringify(validationIssues.slice(0, 6));
            } catch (ignore) {
                issueText = '';
            }
        }
        var itemPrefix = String(messages.retryableAiFailureItemPrefix || '失败项');
        var html = '<li>' + escapeHtml(itemPrefix + ' ' + String(index + 1) + ': ' + label);
        if (failureClass !== '') {
            html += '<div class="text-muted">失败类型：' + escapeHtml(failureClass) + '</div>';
        } else if (failureSource !== '') {
            html += '<div class="text-muted">失败来源：' + escapeHtml(failureSource) + '</div>';
        }
        if (message !== '' && (parts.length > 0 || label !== message)) {
            html += '<div class="text-muted">摘要：' + escapeHtml(message) + '</div>';
        }
        if (validationSummary !== '') {
            html += '<div class="text-muted">门禁摘要：' + escapeHtml(validationSummary) + '</div>';
        }
        if (issueText !== '') {
            html += '<div class="text-muted">门禁明细：' + escapeHtml(issueText) + '</div>';
        }
        if (aiResponseSummary !== '') {
            html += '<div class="text-muted">AI 产出摘要：' + escapeHtml(aiResponseSummary) + '</div>';
        }
        html += '</li>';
        return html;
    }

    function syncPublishFailureListFromWorkspaceState(workspaceState) {
        var nodes = document.querySelectorAll('[data-pb-ai-publish-failure-list]');
        if (!nodes.length) {
            return;
        }
        var items = collectRetryableAiFailureItems(workspaceState, 'build');
        var title = String(messages.publishFailureListTitle || '失败项明细');
        var html = '';
        if (items.length > 0) {
            html = '<div class="fw-semibold mb-1">' + escapeHtml(title) + '</div><ul class="mb-0 ps-3">'
                + items.map(formatRetryableAiFailureItem).join('')
                + '</ul>';
        }
        nodes.forEach(function (listEl) {
            if (items.length === 0) {
                listEl.classList.add('d-none');
                listEl.innerHTML = '';
                return;
            }
            listEl.classList.remove('d-none');
            listEl.innerHTML = html;
        });
    }

    function syncPlanFailureListFromWorkspaceState(workspaceState) {
        var listEl = document.getElementById('pb-ai-plan-failure-list');
        if (!listEl) {
            return;
        }
        var items = collectRetryableAiFailureItems(workspaceState, 'plan');
        if (items.length === 0) {
            listEl.classList.add('d-none');
            listEl.innerHTML = '';
            return;
        }
        listEl.classList.remove('d-none');
        var planTitle = String(messages.planFailureListTitle || '');
        var planHint = String(messages.planFailureListHint || '');
        listEl.innerHTML = '<div class="fw-semibold mb-1">' + escapeHtml(planTitle) + '</div>'
            + '<div class="small mb-2">' + escapeHtml(planHint) + '</div>'
            + '<ul class="mb-0 ps-3">'
            + items.map(formatRetryableAiFailureItem).join('')
            + '</ul>';
    }

    function getRetryableAiFailureMessage(workspaceState, operation) {
        if (hasRunningQueueForUi(workspaceState, operation)) {
            return String(messages.retryableAiQueueRunning || 'Current queue is still running.');
        }
        var count = getRetryableAiFailureCount(workspaceState, operation);
        if (count > 0) {
            return String(messages.retryableAiFailuresPendingWithCount || 'There are %{count} retryable AI failures.')
                .replace('%{count}', String(count));
        }
        return String(messages.retryableAiFailuresPending || 'There are retryable AI failures.');
    }

    function setRetryableGuardedControlState(el, disabled, message) {
        if (!el) {
            return;
        }
        if (disabled) {
            if (el.dataset.pbRetryableAiGuarded !== '1') {
                el.dataset.pbRetryableAiPrevDisabled = el.disabled ? '1' : '0';
                el.dataset.pbRetryableAiPrevTitle = el.hasAttribute('title') ? String(el.getAttribute('title') || '') : '__none__';
            }
            el.dataset.pbRetryableAiGuarded = '1';
            el.disabled = true;
            el.setAttribute('aria-disabled', 'true');
            el.setAttribute('title', String(message || ''));
            return;
        }
        if (el.dataset.pbRetryableAiGuarded === '1') {
            el.disabled = el.dataset.pbRetryableAiPrevDisabled === '1';
            if (el.dataset.pbRetryableAiPrevTitle === '__none__') {
                el.removeAttribute('title');
            } else {
                el.setAttribute('title', el.dataset.pbRetryableAiPrevTitle || '');
            }
            el.removeAttribute('aria-disabled');
            delete el.dataset.pbRetryableAiGuarded;
            delete el.dataset.pbRetryableAiPrevDisabled;
            delete el.dataset.pbRetryableAiPrevTitle;
        }
    }

    function syncRetryableAiFailureButton(button, operation, workspaceState) {
        if (!button) {
            return 0;
        }
        var state = workspaceState && typeof workspaceState === 'object'
            ? workspaceState
            : getLatestWorkspaceStateForQueuePrompt();
        var count = getRetryableAiFailureCount(state, operation);
        var visible = count > 0;
        button.classList.toggle('d-none', !visible);
        if (operation === 'build' && visible) {
            var retryPayload = resolveRetryableAiOperationResumePayload(operation);
            button.dataset.pbRetryableAiResolvedOperation = retryPayload && retryPayload.operation ? String(retryPayload.operation) : '';
            button.dataset.pbRetryableAiResolvedQueueId = retryPayload && retryPayload.queue_id ? String(retryPayload.queue_id) : '';
        } else {
            delete button.dataset.pbRetryableAiResolvedOperation;
            delete button.dataset.pbRetryableAiResolvedQueueId;
        }
        var countEl = button.querySelector('[data-retryable-ai-count]');
        if (countEl) {
            countEl.textContent = String(count);
        }
        var labelEl = button.querySelector('[data-retryable-ai-label-text]');
        var labelText = String(button.getAttribute('data-retryable-ai-label') || messages.retryFailedItemsLabel || '').trim();
        if (labelEl && labelText) {
            labelEl.textContent = labelText;
        }
        var busy = visible && (hasRunningQueueForUi(state, operation) || (operation === 'build' && isBuildActionLocked(state)));
        button.disabled = busy;
        button.setAttribute('aria-disabled', busy ? 'true' : 'false');
        if (visible) {
            button.setAttribute('title', getRetryableAiFailureMessage(state, operation));
        } else {
            button.removeAttribute('title');
        }
        return visible ? 1 : 0;
    }

    function syncRetryableAiFailureActionGuards(workspaceState) {
        var state = workspaceState && typeof workspaceState === 'object'
            ? workspaceState
            : getLatestWorkspaceStateForQueuePrompt();
        var planBlockMessage = getPhaseOnePlanBlockingErrorMessage(state);
        var planBlocked = planBlockMessage !== '';
        var buildBlocked = hasRetryableAiFailures(state, 'build');
        setRetryableGuardedControlState(document.getElementById('pb-ai-confirm-plan'), planBlocked, planBlockMessage);
        setRetryableGuardedControlState(document.getElementById('pb-ai-start-build-site'), buildBlocked, getRetryableAiFailureMessage(state, 'build'));
        setRetryableGuardedControlState(document.getElementById('pb-ai-start-publish'), buildBlocked, getRetryableAiFailureMessage(state, 'build'));
        setRetryableGuardedControlState(document.getElementById('pb-ai-go-publish-stage'), buildBlocked, getRetryableAiFailureMessage(state, 'build'));
        setRetryableGuardedControlState(document.getElementById('pb-ai-run-publish-check'), buildBlocked, getRetryableAiFailureMessage(state, 'build'));
        setRetryableGuardedControlState(document.getElementById('pb-ai-publish-checklist-confirm'), buildBlocked, getRetryableAiFailureMessage(state, 'build'));
        document.querySelectorAll('[data-retryable-ai-operation]').forEach(function (button) {
            var operation = String(button.getAttribute('data-retryable-ai-operation') || '').trim();
            if (operation === 'plan' || operation === 'build') {
                syncRetryableAiFailureButton(button, operation, state);
            }
        });
        var buildRetryBtn = document.getElementById('pb-ai-retry-build-failures');
