        var status = String(notice.queue_status_label || notice.queue_status || '');
        var operation = String(notice.operation_label || notice.operation || '');
        var processText = String(notice.process || '').trim();
        var resultText = String(notice.result_excerpt || '').trim();
        var reloadOnAck = !!notice.reload_on_ack || String(notice.ack_action || '') === 'reload_workspace';
        var confirmLabel = String(notice.confirm_label || <?= \json_encode((string)__('知道了'), \JSON_UNESCAPED_UNICODE | \JSON_HEX_TAG | \JSON_HEX_AMP | \JSON_HEX_APOS | \JSON_HEX_QUOT) ?>);
        var badgeClass = level === 'error'
            ? 'text-bg-danger'
            : (level === 'success' ? 'text-bg-success' : (level === 'warning' ? 'text-bg-warning' : 'text-bg-info'));
        var modalEl = document.getElementById('pb-ai-workspace-entry-queue-notice');
        if (!modalEl) {
            modalEl = document.createElement('div');
