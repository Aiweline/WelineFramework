    function syncAssetPanelFromWorkspaceState(workspaceState) {
        var list = document.getElementById('pb-ai-asset-slot-list');
        var empty = document.getElementById('pb-ai-asset-panel-empty');
        var count = document.getElementById('pb-ai-asset-panel-count');
        if (!list) {
            return;
        }
        var slots = normalizeAssetManifestSlots(readAssetManifestFromWorkspaceState(workspaceState));
        var seen = {};
        if (count) {
            count.textContent = String(slots.length);
        }
        if (empty) {
            empty.classList.toggle('d-none', slots.length > 0);
        }
        slots.forEach(function (slot) {
            var view = collectAssetSlotViewModel(slot);
            seen[view.slotId] = true;
            var card = findAssetSlotCard(list, view.slotId);
            if (!card) {
                var holder = document.createElement('div');
                holder.innerHTML = renderAssetSlotCardHtml(view);
                card = holder.firstElementChild;
                list.appendChild(card);
                setAssetSlotButtonLocked(card, view.locked);
            } else {
                updateAssetSlotCard(card, view);
            }
        });
        list.querySelectorAll('[data-asset-slot-id]').forEach(function (card) {
            var slotId = card.getAttribute('data-asset-slot-id') || '';
            if (!seen[slotId]) {
                card.remove();
            }
        });
    }

    function readReferenceImagesFromWorkspaceState(workspaceState) {
        if (!workspaceState || typeof workspaceState !== 'object') {
            return [];
        }
        if (Array.isArray(workspaceState.reference_images)) {
            return workspaceState.reference_images;
        }
        if (workspaceState.scope && typeof workspaceState.scope === 'object' && Array.isArray(workspaceState.scope.reference_images)) {
            return workspaceState.scope.reference_images;
        }
        return [];
    }

    function syncReferenceImagePanelFromWorkspaceState(workspaceState) {
        var list = document.getElementById('pb-ai-reference-image-list');
        var status = document.getElementById('pb-ai-reference-image-status');
        if (!list) {
            return;
        }
        var images = readReferenceImagesFromWorkspaceState(workspaceState);
        if (status && images.length > 0) {
            status.textContent = String(images.length) + ' reference image(s) available to the AI.';
        }
        if (!images.length) {
            if (list.querySelector('[data-pb-temp-reference-image="1"]')) {
                return;
            }
            list.innerHTML = '<span class="small text-muted" data-pb-reference-image-empty="1">No reference images uploaded.</span>';
            return;
        }
        list.innerHTML = images.map(function (image) {
            var url = image && image.url ? String(image.url) : '';
            var name = image && image.name ? String(image.name) : 'reference image';
            return '<div class="border rounded bg-body p-2" style="width:8.5rem;">'
                + (url ? '<img src="' + escapeHtml(url) + '" alt="' + escapeHtml(name) + '" class="d-block w-100 rounded mb-2" style="height:5rem;object-fit:cover;">' : '')
                + '<div class="small text-truncate" title="' + escapeHtml(name) + '">' + escapeHtml(name) + '</div>'
                + '</div>';
        }).join('');
    }

    function bindReferenceImageUploadLogic() {
        var input = document.getElementById('pb-ai-reference-image-input');
        var selectButton = document.getElementById('pb-ai-reference-image-select-btn');
        if (!input || input.dataset.pbBound === '1') {
            return;
        }
        input.dataset.pbBound = '1';
        var panel = document.getElementById('pb-ai-reference-image-panel');

        function uploadReferenceImageFile(file) {
            var status = document.getElementById('pb-ai-reference-image-status');
            if (!file) {
                return;
            }

            // 只处理图片。剪贴板/拖拽有时会携带空 type 或非图片条目，这里做个保底过滤。
            var mime = file.type ? String(file.type) : '';
            if (mime && mime.indexOf('image/') !== 0) {
                return;
            }

            // 先在 UI 里展示一个临时预览（粘贴/拖拽反馈更明显）。
            // 之后 hydrateWorkspaceFromState() 会用后端返回的 reference_images 覆盖该列表。
            var list = document.getElementById('pb-ai-reference-image-list');
            var previewUrl = null;
            if (list && typeof URL !== 'undefined' && URL && typeof URL.createObjectURL === 'function') {
                try {
                    previewUrl = URL.createObjectURL(file);
                } catch (e) {
                    previewUrl = null;
                }
            }
            if (list && previewUrl) {
                var empty = list.querySelector('[data-pb-reference-image-empty="1"]');
                if (empty) {
                    empty.remove();
                }
                var name = file.name ? String(file.name) : 'pasted image';
                var card = document.createElement('div');
                card.className = 'border rounded bg-body p-2';
                card.style.width = '8.5rem';
                card.setAttribute('data-pb-temp-reference-image', '1');
                card.innerHTML = ''
                    + '<img alt="' + escapeHtml(name) + '" class="d-block w-100 rounded mb-2" style="height:5rem;object-fit:cover;" src="' + escapeHtml(previewUrl) + '">'
                    + '<div class="small text-truncate" title="' + escapeHtml(name) + '">' + escapeHtml(name) + '</div>';
                list.appendChild(card);
                var img = card.querySelector('img');
                if (img) {
                    img.onload = function () {
                        if (previewUrl) {
                            try {
                                URL.revokeObjectURL(previewUrl);
                            } catch (e) {
                                // no-op
                            }
                        }
                    };
                }
            }

            if (!uploadReferenceImageUrl) {
                if (status) {
                    status.textContent = 'Reference image upload endpoint is not configured.';
                }
                input.value = '';
                return;
            }

            if (status) {
                status.textContent = 'Uploading reference image...';
            }
            postForm(uploadReferenceImageUrl, {
                public_id: publicId,
                reference_image: file
            }).then(function (data) {
                if (!data || !data.success) {
                    throw new Error((data && (data.message || data.error)) ? String(data.message || data.error) : 'Reference image upload failed.');
                }
                if (data.data && typeof data.data === 'object') {
                    hydrateWorkspaceFromState(data.data);
                } else {
                    var nextState = latestWorkspaceState && typeof latestWorkspaceState === 'object' ? Object.assign({}, latestWorkspaceState) : {};
                    nextState.reference_images = Array.isArray(data.reference_images) ? data.reference_images : readReferenceImagesFromWorkspaceState(nextState);
                    nextState.scope = Object.assign({}, nextState.scope || {}, { reference_images: nextState.reference_images });
                    hydrateWorkspaceFromState(nextState);
                }
                if (status) {
                    status.textContent = 'Reference image uploaded.';
                }
            }).catch(function (error) {
                if (status) {
                    status.textContent = error && error.message ? error.message : 'Reference image upload failed.';
                }
            }).finally(function () {
                input.value = '';
            });
        }

        input.addEventListener('change', function () {
            var file = input.files && input.files[0] ? input.files[0] : null;
            uploadReferenceImageFile(file);
        });

        if (selectButton && selectButton.dataset.pbBound !== '1') {
            selectButton.dataset.pbBound = '1';
            selectButton.addEventListener('click', function () {
                if (input && !input.disabled) {
                    input.click();
                }
            });
        }

        if (panel) {
            // 拖拽到面板上传
            panel.addEventListener('dragover', function (event) {
                if (!event) {
                    return;
                }
                event.preventDefault();
                event.stopPropagation();
                panel.classList.add('border-primary');
                panel.classList.add('bg-white');
            });
            panel.addEventListener('dragleave', function (event) {
                if (!event) {
                    return;
                }
                event.preventDefault();
                event.stopPropagation();
                panel.classList.remove('border-primary');
                panel.classList.remove('bg-white');
            });
            panel.addEventListener('drop', function (event) {
                if (!event) {
                    return;
                }
                event.preventDefault();
                event.stopPropagation();
                panel.classList.remove('border-primary');
                panel.classList.remove('bg-white');

                var files = event.dataTransfer && event.dataTransfer.files ? event.dataTransfer.files : null;
                if (!files || !files.length) {
                    return;
                }
                var file = null;
                for (var i = 0; i < files.length; i += 1) {
                    var candidate = files[i];
                    if (candidate && candidate.type && String(candidate.type).indexOf('image/') === 0) {
                        file = candidate;
                        break;
                    }
                }
                file = file || files[0];
                uploadReferenceImageFile(file);
            });
        }

        // 粘贴剪贴板图片上传
        document.addEventListener('paste', function (event) {
            if (!event || !event.clipboardData) {
                return;
            }
            var items = event.clipboardData.items;
            if (!items || !items.length) {
                return;
            }

            var file = null;
            for (var i = 0; i < items.length; i += 1) {
                var item = items[i];
                if (!item || typeof item.type !== 'string') {
                    continue;
                }
                if (item.type.indexOf('image/') !== 0) {
                    continue;
                }
                if (typeof item.getAsFile === 'function') {
                    file = item.getAsFile();
                }
                if (!file && typeof item.getAsBlob === 'function') {
                    var blob = item.getAsBlob();
                    if (blob) {
                        file = (typeof File !== 'undefined')
                            ? new File([blob], 'reference-image', { type: blob.type || item.type })
                            : blob;
                    }
                }
                break;
            }

            if (!file) {
                return;
            }
            event.preventDefault();
            uploadReferenceImageFile(file);
        }, true);
    }

    function bindAssetPanelLogic() {
        var root = document.getElementById('pb-ai-asset-panel');
        if (!root || root.dataset.pbBound === '1') {
            return;
        }
        root.dataset.pbBound = '1';
        var toolButton = document.getElementById('pb-ai-image-tool-generate');
        if (toolButton && toolButton.dataset.pbBound !== '1') {
            toolButton.dataset.pbBound = '1';
            toolButton.addEventListener('click', function () {
                var promptInput = document.getElementById('pb-ai-image-tool-prompt');
                var typeInput = document.getElementById('pb-ai-image-tool-type');
                var pageInput = document.getElementById('pb-ai-image-tool-page');
                var status = document.getElementById('pb-ai-image-tool-status');
                var prompt = promptInput ? String(promptInput.value || '').trim() : '';
                if (!prompt || !startAssetGenerationUrl) {
                    if (status) {
                        status.textContent = prompt ? '' : 'Prompt required';
                    }
                    return;
                }
                toolButton.disabled = true;
                if (status) {
                    status.textContent = 'queue...';
                }
                postForm(startAssetGenerationUrl, {
                    public_id: publicId,
                    prompt_brief: prompt,
                    slot_type: typeInput ? String(typeInput.value || 'section_image') : 'section_image',
                    page_type: pageInput ? String(pageInput.value || '').trim() : '',
                    label: 'AI Image Tool',
                    mode: 'generate',
                    execution_token: Date.now().toString(36) + '-' + Math.random().toString(36).slice(2)
                }).then(function (data) {
                    var rootResponse = data && typeof data === 'object' ? data : {};
                    var payload = data && data.data && typeof data.data === 'object' ? data.data : (data || {});
                    var queueId = String(payload.queue_id || rootResponse.queue_id || (payload.queue && payload.queue.queue_id) || '');
                    var slotId = String(payload.slot_id || '');
                    if (status) {
                        status.textContent = 'queue_id=' + (queueId || '-') + (slotId ? ' slot=' + slotId : '');
                    }
                    var nextState = payload.state || payload.workspace_state || payload;
                    if (nextState && typeof nextState === 'object' && (nextState.scope || nextState.asset_manifest)) {
                        hydrateWorkspaceFromState(nextState);
                    }
                    if (promptInput) {
                        promptInput.value = '';
                    }
                    if (window.PbAiOperationRunner && typeof window.PbAiOperationRunner.startFromResponse === 'function') {
                        window.PbAiOperationRunner.startFromResponse(data, 'image_asset');
                    }
                }).catch(function (error) {
                    if (status) {
                        status.textContent = String(error && error.message ? error.message : messages.networkError);
                    }
                }).finally(function () {
                    toolButton.disabled = false;
                });
            });
        }
        root.addEventListener('click', function (event) {
            var button = event.target && event.target.closest ? event.target.closest('[data-asset-generate]') : null;
            if (!button || button.disabled) {
                return;
            }
            var slotId = String(button.getAttribute('data-slot-id') || '').trim();
            if (!slotId || !startAssetGenerationUrl) {
                return;
            }
            var mode = String(button.getAttribute('data-asset-generate') || 'generate');
            var card = button.closest('[data-asset-slot-id]');
            var meta = card ? card.querySelector('[data-asset-queue-meta]') : null;
            button.disabled = true;
            if (meta) {
                meta.textContent = 'queue...';
            }
            postForm(startAssetGenerationUrl, {
                public_id: publicId,
                slot_id: slotId,
                mode: mode,
                execution_token: Date.now().toString(36) + '-' + Math.random().toString(36).slice(2)
            }).then(function (data) {
                var rootResponse = data && typeof data === 'object' ? data : {};
                var payload = data && data.data && typeof data.data === 'object' ? data.data : (data || {});
                var queueId = String(payload.queue_id || rootResponse.queue_id || (payload.queue && payload.queue.queue_id) || '');
                var status = String(payload.queue_status || rootResponse.queue_status || payload.status || (payload.queue && payload.queue.status) || 'queued');
                var token = String(payload.execution_token || rootResponse.execution_token || '');
                if (meta) {
                    meta.textContent = 'queue_id=' + (queueId || '-') + ' status=' + status + (token ? ' token=' + token : '');
                }
                var nextState = payload.state || payload.workspace_state || payload;
                if (nextState && typeof nextState === 'object' && (nextState.scope || nextState.asset_manifest)) {
                    hydrateWorkspaceFromState(nextState);
                }
                if (window.PbAiOperationRunner && typeof window.PbAiOperationRunner.startFromResponse === 'function') {
                    window.PbAiOperationRunner.startFromResponse(data, 'image_asset');
                }
            }).catch(function (error) {
                if (meta) {
                    meta.textContent = String(error && error.message ? error.message : messages.networkError);
                }
            }).finally(function () {
                button.disabled = false;
            });
        });
    }

