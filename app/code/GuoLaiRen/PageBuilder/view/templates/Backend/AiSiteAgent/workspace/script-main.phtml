    function handlePreviewActionClick(button) {
        if (!button || !button.getAttribute) {
            window.__pbPreviewActionDebug = {
                ok: false,
                reason: 'invalid-button'
            };
            return false;
        }
        try {
            var stage = String(button.getAttribute('data-pb-preview-stage') || '').trim();
            if (!stage && button.closest) {
                var taskPlanHost = button.closest('#pb-ai-task-plan-rendered-content, #pb-ai-task-plan-preview-content, #pb-ai-task-plan-panel-collapse');
                stage = taskPlanHost ? 'task-plan' : 'plan';
            }
            var action = String(button.getAttribute('data-pb-preview-action') || '').trim();
            var scopeKind = String(button.getAttribute('data-pb-scope-kind') || '').trim();
            var targetScope = String(button.getAttribute('data-target-scope') || '').trim();
            var pageType = String(button.getAttribute('data-page-type') || '').trim();
            var blockKey = String(button.getAttribute('data-block-key') || '').trim();
            var pageLabel = String(button.getAttribute('data-page-label') || button.getAttribute('data-page-type') || '').trim();
            var blockLabel = String(button.getAttribute('data-block-label') || button.getAttribute('data-block-key') || button.getAttribute('data-task-key') || '').trim();
            var actionContext = buildPreviewActionContext(stage, action, scopeKind, pageLabel, blockLabel, targetScope, pageType, blockKey);
            window.__pbPreviewActionDebug = {
                ok: true,
                stage: stage,
                action: action,
                scopeKind: scopeKind,
                targetScope: targetScope,
                pageLabel: pageLabel,
                blockLabel: blockLabel,
                summary: actionContext && actionContext.summary ? String(actionContext.summary) : ''
            };
            if (stage === 'task-plan') {
                var taskMode = (action === 'rebuild' || action === 'rebuild-stage') ? 'rebuild_task_plan' : 'refine_task_plan';
                if (action === 'refine-stage' || action === 'rebuild-stage') {
                    actionContext.targetScope = '';
                }
                window.__pbPreviewActionDebug.mode = taskMode;
                showTaskPlanPreviewActionFlow(taskMode, actionContext);
                return true;
            }
            var planMode = (action === 'rebuild' || action === 'rebuild-stage') ? 'rebuild' : 'refine';
            if (action === 'refine-stage' || action === 'rebuild-stage') {
                actionContext.targetScope = '';
            }
            if (handlePlanBlockMutationAction(action, scopeKind, pageType, blockKey, blockLabel, actionContext)) {
                window.__pbPreviewActionDebug.mode = 'block-mutation';
                return true;
            }
            window.__pbPreviewActionDebug.mode = planMode;
            showPlanPreviewActionFlow(planMode, actionContext);
            return true;
        } catch (error) {
            window.__pbPreviewActionDebug = {
                ok: false,
                reason: 'exception',
                message: error && error.message ? String(error.message) : String(error || '')
            };
            if (window.console && typeof window.console.error === 'function') {
                window.console.error('pb preview action failed', error);
            }
            return false;
        }
    }
    window.PbAiWorkspacePreviewAction = handlePreviewActionClick;

    function handlePlanBlockMutationAction(action, scopeKind, pageType, blockKey, blockLabel, actionContext) {
        var normalizedAction = String(action || '').trim();
        if (['add-block', 'delete', 'rebuild'].indexOf(normalizedAction) === -1) {
            return false;
        }
        if (!String(mutatePlanBlockUrl || '').trim() || !pageType) {
            return false;
        }
        if ((normalizedAction === 'delete' || normalizedAction === 'rebuild') && (!blockKey || scopeKind !== 'block')) {
            return false;
        }

        var mutationAction = normalizedAction === 'add-block' ? 'create' : (normalizedAction === 'delete' ? 'delete' : 'rebuild');
        if (mutationAction === 'delete' && typeof window.confirm === 'function') {
            var label = blockLabel || blockKey;
            if (!window.confirm('Delete this plan block: ' + label + '?')) {
                return true;
            }
        }

        var blockConfig = {};
        if (mutationAction === 'create') {
            var title = '';
            if (typeof window.prompt === 'function') {
                title = String(window.prompt(previewLabels.addBlockAction || 'Add block', blockLabel || '') || '').trim();
            }
            if (!title) {
                title = blockLabel ? (blockLabel + ' follow-up') : 'New plan block';
            }
            blockConfig = {
                title: title,
                goal: title,
                instruction: actionContext && actionContext.summary ? String(actionContext.summary) : title
            };
            if (blockKey) {
                blockConfig.after_block_key = blockKey;
            }
        } else if (mutationAction === 'rebuild') {
            blockConfig = {
                mutation_note: actionContext && actionContext.summary ? String(actionContext.summary) : 'Local stage-one block rebuild requested.',
                reason: actionContext && actionContext.summary ? String(actionContext.summary) : 'Local stage-one block rebuild requested.'
            };
        }

        postForm(mutatePlanBlockUrl, {
            public_id: publicId,
            page_type: pageType,
            action: mutationAction,
            block_key: blockKey,
            block_config: JSON.stringify(blockConfig)
        }).then(function (data) {
            if (data && data.success && data.data && typeof data.data === 'object') {
                hydrateWorkspaceFromState(data.data);
                toast('success', data.message ? String(data.message) : 'Stage-1 plan block updated.');
                return;
            }
            toast('warning', data && data.message ? String(data.message) : messages.networkError);
        }).catch(function (error) {
            toast('error', (error && error.message) ? String(error.message) : messages.networkError);
        });

        return true;
    }

    function bindPreviewActionButtons(container) {
        var root = typeof container === 'string' ? document.getElementById(container) : container;
        if (!root || root.dataset.pbPreviewActionBound === '1') {
            return;
        }
        root.dataset.pbPreviewActionBound = '1';
        root.addEventListener('click', function (event) {
            if (event.defaultPrevented) {
                return;
