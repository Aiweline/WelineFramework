            updateTaskPlanModalContent(taskPlanStreamAccumMarkdown);
            var approx = Math.min(92, 35 + Math.floor(taskPlanStreamAccumMarkdown.length / 600));
            setTaskPlanModalProgress(messages.taskPlanModeRunning, approx, false);
