            return items;
        }
        if (typeof value === 'object') {
            var textValue = sanitizePreviewText(value.title || value.name || value.label || value.text || value.value || value.sample || '', '');
            if (textValue) {
                items.push(safePrefix ? (safePrefix + ': ' + textValue) : textValue);
            }
            Object.keys(value).forEach(function (key) {
                if (['title', 'name', 'label', 'text', 'value', 'sample'].indexOf(key) !== -1) {
                    return;
                }
                var childPrefix = safePrefix ? (safePrefix + ' / ' + (humanizePreviewKey(key) || key)) : (humanizePreviewKey(key) || key);
                items = items.concat(flattenTaskPlanDetailItems(value[key], childPrefix, safeDepth + 1));
