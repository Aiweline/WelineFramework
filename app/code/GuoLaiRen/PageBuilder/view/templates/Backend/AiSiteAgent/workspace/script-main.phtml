    function collectTaskPlanPlanningReasonItems(task, blockTask, planContext) {
        var items = [];
        var seen = {};
        function push(raw) {
            var text = sanitizePreviewText(raw, '');
            if (!text || looksLikePreviewMetaInstruction(text) || seen[text]) {
                return;
            }
            seen[text] = true;
            items.push(text);
        }
        var taskObj = task && typeof task === 'object' ? task : {};
        var blockTaskObj = blockTask && typeof blockTask === 'object' ? blockTask : {};
        var contextObj = planContext && typeof planContext === 'object' ? planContext : {};
        [
            blockTaskObj.planning_reason,
            taskObj.planning_reason,
            contextObj.planning_reason,
            contextObj.block_why,
            taskObj.reason,
            contextObj.reason,
            taskObj.decision_reason
        ].forEach(push);
        return items;
