    function normalizePlanSseUrl(url) {
        var normalized = String(url || '').trim();
        if (normalized === '') {
            return normalized;
        }
        return normalized.replace('/post-plan-sse', '/plan-sse');
    }

    function normalizePublishedSiteUrl(rawUrl) {
        var value = String(rawUrl || '').trim();
        if (!value) {
            return '';
        }
        if (/^https?:\/\//i.test(value)) {
            return value;
        }
        if (/^[a-z0-9.-]+\.[a-z]{2,}(\/.*)?$/i.test(value)) {
            return 'https://' + value;
        }
        return '';
    }

    function resolvePublishedSiteUrl(workspaceState) {
        if (!workspaceState || typeof workspaceState !== 'object') {
            return '';
        }
        var scope = workspaceState.scope && typeof workspaceState.scope === 'object' ? workspaceState.scope : {};
        var profile = workspaceState.website_profile && typeof workspaceState.website_profile === 'object'
            ? workspaceState.website_profile
            : {};
        var candidates = [
            workspaceState.published_site_url,
            workspaceState.site_url,
            workspaceState.live_url,
            profile.target_domain,
            scope.target_domain
        ];
        for (var i = 0; i < candidates.length; i++) {
            var normalized = normalizePublishedSiteUrl(candidates[i]);
            if (normalized) {
                return normalized;
            }
        }
        return '';
    }

    function isWorkspacePublished(workspaceState) {
        if (!workspaceState || typeof workspaceState !== 'object') {
            return false;
        }
        var publishStatus = String(workspaceState.publish_status || '').toLowerCase();
        var workspaceStatus = String(workspaceState.workspace_status || '').toLowerCase();
        return publishStatus === 'published' || workspaceStatus === 'published';
    }

    function syncPublishedSiteAccess(workspaceState) {
        var panel = document.getElementById('pb-ai-published-site-access');
        var link = document.getElementById('pb-ai-published-site-link');
        var label = document.getElementById('pb-ai-site-access-label');
        if (!panel || !link || !label) {
            return;
        }
        var liveUrl = resolvePublishedSiteUrl(workspaceState || {});
        var published = isWorkspacePublished(workspaceState || {});
        var previewUrl = String(previewFullUrl || visualPreviewUrl || currentEmbeddedVisualUrl || '').trim();
        var displayUrl = String(liveUrl || previewUrl).trim();
        if (!displayUrl) {
            panel.classList.add('d-none');
            link.removeAttribute('href');
            link.textContent = '';
            return;
        }
        if (liveUrl) {
            publishedSiteUrl = liveUrl;
        }
        panel.classList.remove('d-none');
        label.textContent = published && liveUrl
            ? '发布已完成：可直接访问真实站点地址'
            : '当前为预览地址（未发布也可访问预览）';
        link.href = displayUrl;
        link.textContent = displayUrl;
    }
