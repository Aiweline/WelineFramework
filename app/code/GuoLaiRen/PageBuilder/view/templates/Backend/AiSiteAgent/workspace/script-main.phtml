    function findAssetSlotCard(list, slotId) {
        var cards = list.querySelectorAll('[data-asset-slot-id]');
        for (var i = 0; i < cards.length; i += 1) {
            if (cards[i].getAttribute('data-asset-slot-id') === slotId) {
                return cards[i];
            }
        }
        return null;
    }

    function setAssetSlotText(card, selector, text) {
        var el = card.querySelector(selector);
        if (el && el.textContent !== text) {
            el.textContent = text;
        }
    }

    function toggleAssetSlotValue(card, selector, visible, text) {
        var el = card.querySelector(selector);
        if (!el) {
            return;
        }
        el.classList.toggle('d-none', !visible);
        if (visible && typeof text === 'string' && el.textContent !== text) {
            el.textContent = text;
        }
