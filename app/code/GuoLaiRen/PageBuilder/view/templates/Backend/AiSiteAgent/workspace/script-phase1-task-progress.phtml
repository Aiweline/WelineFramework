<?php
/**
 * 建站方案侧栏「任务进度」内嵌：plan 队列快照 / process / result 刷新逻辑。
 * 依赖 script-main 已挂载的 window.PbAiWorkspacePreview（postForm、toast、escapeHtml）与 window.hydrateWorkspaceFromState。
 */
?>
<script>
(function () {
    'use strict';
    var bridge = window.PbAiWorkspacePreview && typeof window.PbAiWorkspacePreview === 'object'
        ? window.PbAiWorkspacePreview
        : {};
    var publicId = <?= \json_encode($publicId, \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var workspaceSnapshotUrl = <?= \json_encode((string)($workspaceSnapshotUrl ?? ''), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>;
    var queueMessages = {
        empty: <?= \json_encode((string)__('当前没有可展示的建站方案队列记录（尚未入队或队列已清理）。'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        refreshed: <?= \json_encode((string)__('队列信息已刷新'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        refreshFailed: <?= \json_encode((string)__('刷新队列信息失败'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        queueIdLabel: <?= \json_encode((string)__('队列编号'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        queueIdUnknown: <?= \json_encode((string)__('—'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        jobKeyLabel: <?= \json_encode((string)__('Job'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        jobTypeLabel: <?= \json_encode((string)__('类型'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        statusLabel: <?= \json_encode((string)__('状态'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        tokenLabel: <?= \json_encode((string)__('Token'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        inputTokensLabel: <?= \json_encode((string)__('输入 tokens'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        outputTokensLabel: <?= \json_encode((string)__('输出 tokens'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>,
        totalTokensLabel: <?= \json_encode((string)__('总 tokens'), \JSON_UNESCAPED_UNICODE | \JSON_THROW_ON_ERROR) ?>
    };
    var LIVE_LOG_MAX_LINES = 200;

    function escapeHtml(text) {
        if (typeof bridge.escapeHtml === 'function') {
            return bridge.escapeHtml(text);
        }
        var div = document.createElement('div');
        div.textContent = String(text == null ? '' : text);
        return div.innerHTML;
    }

    function toast(type, message) {
        if (typeof bridge.toast === 'function') {
            bridge.toast(type, message);
        }
    }

    function postForm(url, fields) {
        if (typeof bridge.postForm !== 'function') {
            return Promise.reject(new Error('postForm unavailable'));
        }
        return bridge.postForm(url, fields);
    }

    function normalizeTokenCount(value) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return null;
        }
        var parsed = parseInt(String(value), 10);
        return !isNaN(parsed) && parsed >= 0 ? parsed : null;
    }

    function formatTokenCount(value) {
        var normalized = normalizeTokenCount(value);
        return normalized === null ? queueMessages.queueIdUnknown : String(normalized);
    }

    function toObjectSafe(value) {
        if (!value) {
            return {};
        }
        if (typeof value === 'object') {
            return value;
        }
        if (typeof value === 'string') {
            var text = String(value || '').trim();
            if (!text) {
                return {};
            }
            try {
                var parsed = JSON.parse(text);
                return parsed && typeof parsed === 'object' ? parsed : {};
            } catch (e) {
                return {};
            }
        }
        return {};
    }

    function resolvePayloadProgressKind(payload) {
        if (!payload || typeof payload !== 'object') {
            return '';
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'progress_kind')) {
            return String(payload.progress_kind || '').toLowerCase();
        }
        if (payload.state && typeof payload.state === 'object' && Object.prototype.hasOwnProperty.call(payload.state, 'progress_kind')) {
            return String(payload.state.progress_kind || '').toLowerCase();
        }
        return '';
    }

    function pickTokenCount(source, keys) {
        if (!source || typeof source !== 'object') {
            return null;
        }
        for (var i = 0; i < keys.length; i += 1) {
            var key = keys[i];
            if (!Object.prototype.hasOwnProperty.call(source, key)) {
                continue;
            }
            var normalized = normalizeTokenCount(source[key]);
            if (normalized !== null) {
                return normalized;
            }
        }
        return null;
    }

    function mergeTokenUsageNumbers(baseUsage, nextUsage) {
        var base = baseUsage && typeof baseUsage === 'object' ? baseUsage : {};
        var next = nextUsage && typeof nextUsage === 'object' ? nextUsage : {};
        var input = normalizeTokenCount(next.input_tokens);
        var output = normalizeTokenCount(next.output_tokens);
        var total = normalizeTokenCount(next.total_tokens);
        var baseInput = normalizeTokenCount(base.input_tokens);
        var baseOutput = normalizeTokenCount(base.output_tokens);
        var baseTotal = normalizeTokenCount(base.total_tokens);
        if (input === null) {
            input = baseInput;
        } else if (baseInput !== null && baseInput > input) {
            input = baseInput;
        }
        if (output === null) {
            output = baseOutput;
        } else if (baseOutput !== null && baseOutput > output) {
            output = baseOutput;
        }
        if (total === null) {
            total = baseTotal;
        } else if (baseTotal !== null && baseTotal > total) {
            total = baseTotal;
        }
        if (total === null && input !== null && output !== null) {
            total = input + output;
        }
        return {
            input_tokens: input,
            output_tokens: output,
            total_tokens: total
        };
    }

    function parseTokenCountByPatterns(text, patterns) {
        var source = String(text || '');
        if (!source) {
            return null;
        }
        for (var i = 0; i < patterns.length; i += 1) {
            var match = source.match(patterns[i]);
            if (!match || typeof match[1] === 'undefined') {
                continue;
            }
            var normalized = normalizeTokenCount(match[1]);
            if (normalized !== null) {
                return normalized;
            }
        }
        return null;
    }

    function extractTokenUsageFromText(text) {
        var source = String(text || '');
        if (!source) {
            return null;
        }
        var input = parseTokenCountByPatterns(source, [
            /(?:input_tokens|input token|input tokens|prompt_tokens|prompt token|prompt tokens|prompt_eval_count|输入\s*tokens?)\s*[:=]\s*(\d+)/i,
            /(?:input_tokens|prompt_tokens|prompt_eval_count|输入\s*tokens?)\D+(\d+)/i
        ]);
        var output = parseTokenCountByPatterns(source, [
            /(?:output_tokens|output token|output tokens|completion_tokens|completion token|completion tokens|eval_count|输出\s*tokens?)\s*[:=]\s*(\d+)/i,
            /(?:output_tokens|completion_tokens|eval_count|输出\s*tokens?)\D+(\d+)/i
        ]);
        var total = parseTokenCountByPatterns(source, [
            /(?:total_tokens|total token|total tokens|总\s*tokens?)\s*[:=]\s*(\d+)/i,
            /(?:total_tokens|总\s*tokens?)\D+(\d+)/i
        ]);
        if (input === null && output === null && total === null) {
            return null;
        }
        if (total === null && input !== null && output !== null) {
            total = input + output;
        }
        return {
            input_tokens: input,
            output_tokens: output,
            total_tokens: total
        };
    }

    function resolveTokenUsage(info) {
        var snapshot = info && info.snapshot && typeof info.snapshot === 'object' ? info.snapshot : {};
        var usage = Object.assign(
            {},
            toObjectSafe(snapshot.token_usage),
            toObjectSafe(info && info.token_usage)
        );

        var input = pickTokenCount(usage, ['input_tokens', 'prompt_tokens', 'input_token', 'prompt_token', 'prompt_eval_count']);
        if (input === null) {
            input = pickTokenCount(info, ['input_tokens', 'prompt_tokens', 'input_token', 'prompt_token', 'prompt_eval_count']);
        }
        if (input === null) {
            input = pickTokenCount(snapshot, ['input_tokens', 'prompt_tokens', 'input_token', 'prompt_token', 'prompt_eval_count']);
        }

        var output = pickTokenCount(usage, ['output_tokens', 'completion_tokens', 'output_token', 'completion_token', 'eval_count']);
        if (output === null) {
            output = pickTokenCount(info, ['output_tokens', 'completion_tokens', 'output_token', 'completion_token', 'eval_count']);
        }
        if (output === null) {
            output = pickTokenCount(snapshot, ['output_tokens', 'completion_tokens', 'output_token', 'completion_token', 'eval_count']);
        }

        var total = pickTokenCount(usage, ['total_tokens', 'total_token']);
        if (total === null) {
            total = pickTokenCount(info, ['total_tokens', 'total_token']);
        }
        if (total === null) {
            total = pickTokenCount(snapshot, ['total_tokens', 'total_token']);
        }
        if (total === null && input !== null && output !== null) {
            total = input + output;
        }

        return {
            input_tokens: input,
            output_tokens: output,
            total_tokens: total
        };
    }

    function renderQueueSummaryItem(key, label, value, codeLike) {
        var display = String(value == null || value === '' ? queueMessages.queueIdUnknown : value);
        var valueTag = codeLike ? 'code' : 'strong';
        var tokenUsageAttr = (key === 'input_tokens' || key === 'output_tokens' || key === 'total_tokens')
            ? ' data-token-usage-field="' + escapeHtml(key) + '"'
            : '';
        return '<div class="col-6" role="listitem" data-queue-info-field="' + escapeHtml(key) + '"' + tokenUsageAttr + '>'
            + '<div class="text-muted small">' + escapeHtml(label) + '</div>'
            + '<' + valueTag + ' class="small text-break">' + escapeHtml(display) + '</' + valueTag + '>'
            + '</div>';
    }

    function renderQueueInfoSummary(info) {
        var snapshot = info && info.snapshot && typeof info.snapshot === 'object' ? info.snapshot : {};
        var tokenUsage = resolveTokenUsage(info || {});
        var jobKey = snapshot.job_key || (info && info.job_key) || snapshot.biz_key || '';
        var jobType = snapshot.job_type || (info && info.job_type) || '';
        var status = snapshot.job_status || snapshot.status || (info && (info.job_status || info.status)) || '';
        var token = snapshot.token || snapshot.execution_token || (info && (info.token || info.execution_token)) || '';

        return '<div class="row g-2 mb-2 pb-ai-plan-queue-token-summary" role="list" data-queue-info-list="stage1">'
            + renderQueueSummaryItem('job_key', queueMessages.jobKeyLabel, jobKey, true)
            + renderQueueSummaryItem('job_type', queueMessages.jobTypeLabel, jobType, false)
            + renderQueueSummaryItem('job_status', queueMessages.statusLabel, status, false)
            + renderQueueSummaryItem('token', queueMessages.tokenLabel, token, true)
            + renderQueueSummaryItem('input_tokens', queueMessages.inputTokensLabel, formatTokenCount(tokenUsage.input_tokens), false)
            + renderQueueSummaryItem('output_tokens', queueMessages.outputTokensLabel, formatTokenCount(tokenUsage.output_tokens), false)
            + renderQueueSummaryItem('total_tokens', queueMessages.totalTokensLabel, formatTokenCount(tokenUsage.total_tokens), false)
            + '</div>';
    }

    function renderPlanQueuePageList(items) {
        var values = Array.isArray(items) ? items.map(function (item) {
            return String(item || '').trim();
        }).filter(Boolean) : [];
        return values.length > 0 ? values.join(', ') : '-';
    }

    function renderPlanQueueProgressBar(label, count, total, tone, items) {
        var safeTotal = Math.max(1, parseInt(String(total || 0), 10) || 0);
        var safeCount = Math.max(0, parseInt(String(count || 0), 10) || 0);
        var width = Math.max(0, Math.min(100, Math.round((safeCount / safeTotal) * 100)));
        return '<div class="pb-ai-plan-fanout-row mb-2">'
            + '<div class="d-flex align-items-center justify-content-between gap-2 mb-1">'
            + '<span class="fw-semibold">' + escapeHtml(label) + '</span>'
            + '<span class="text-muted">' + safeCount + '/' + safeTotal + '</span>'
            + '</div>'
            + '<div class="progress" style="height:6px;">'
            + '<div class="progress-bar bg-' + escapeHtml(tone) + '" role="progressbar" style="width:' + width + '%" aria-valuenow="' + width + '" aria-valuemin="0" aria-valuemax="100"></div>'
            + '</div>'
            + '<div class="text-muted mt-1">' + escapeHtml(renderPlanQueuePageList(items)) + '</div>'
            + '</div>';
    }

    function normalizePlanQueuePageProgress(progress, fallbackMessage) {
        var source = progress && typeof progress === 'object' ? progress : {};
        var total = parseInt(String(source.total || 0), 10) || 0;
        var done = Array.isArray(source.done) ? source.done : [];
        var running = Array.isArray(source.running) ? source.running : [];
        var failed = Array.isArray(source.failed) ? source.failed : [];
        var pending = Array.isArray(source.pending) ? source.pending : [];
        var details = Array.isArray(source.details) ? source.details : [];
        if (total > 0) {
            return {
                total: total,
                done: done,
                running: running,
                failed: failed,
                pending: pending,
                details: details
            };
        }

        var text = String(fallbackMessage || '').trim();
        var match = text.match(/(?:页面总设计已生成|正在生成页面总设计)[^\d]*(\d+)\s*\/\s*(\d+)[^\w\u4e00-\u9fa5]*([a-z0-9_]+)?/i);
        if (!match) {
            return null;
        }
        var current = Math.max(0, parseInt(match[1], 10) || 0);
        total = Math.max(current, parseInt(match[2], 10) || 0);
        var pageType = String(match[3] || '').trim();
        var completed = /已生成/.test(text);
        var doneCount = completed ? current : Math.max(0, current - 1);
        var runningList = pageType !== '' && !completed ? [pageType] : [];
        var doneList = pageType !== '' && completed ? [pageType] : [];
        var pendingCount = Math.max(0, total - doneCount - runningList.length - failed.length);
        details = [];
        if (pageType !== '') {
            details.push({
                page_type: pageType,
                status: completed ? 'done' : 'running',
                message: text
            });
        }
        return {
            total: total,
            done: doneList,
            done_count: doneCount,
            running: runningList,
            failed: [],
            pending: new Array(pendingCount).fill('pending'),
            details: details
        };
    }

    function renderPlanQueueTaskDetails(details) {
        var rows = Array.isArray(details) ? details : [];
        if (rows.length === 0) {
            return '';
        }
        return '<div class="border-top pt-2 mt-2">'
            + '<div class="fw-semibold mb-1">Task details</div>'
            + rows.slice(0, 24).map(function (row) {
                row = row && typeof row === 'object' ? row : {};
                var status = String(row.status || '').trim() || 'pending';
                var pageType = String(row.page_type || '').trim() || '-';
                var message = String(row.error_message || row.message || '').trim();
                var badge = status === 'done' || status === 'passed' || status === 'checkpoint'
                    ? 'success'
                    : (status === 'failed' || status === 'error' || status === 'retryable_failure' ? 'danger' : (status === 'running' || status === 'retrying' ? 'info' : 'secondary'));
                return '<div class="d-flex flex-wrap align-items-start gap-2 py-1 border-bottom">'
                    + '<span class="badge text-bg-' + badge + '">' + escapeHtml(status) + '</span>'
                    + '<code class="small">' + escapeHtml(pageType) + '</code>'
                    + '<span class="text-muted flex-grow-1">' + escapeHtml(message || '-') + '</span>'
                    + '</div>';
            }).join('')
            + '</div>';
    }

    function publishPlanQueueLatestPageProgress(progress, fallbackMessage) {
        var latestEl = document.getElementById('pb-ai-plan-queue-latest-message');
        if (!latestEl) {
            return false;
        }
        var normalized = normalizePlanQueuePageProgress(progress, fallbackMessage);
        if (!normalized) {
            return false;
        }
        var total = Math.max(1, parseInt(String(normalized.total || 0), 10) || 0);
        var running = Array.isArray(normalized.running) ? normalized.running : [];
        var done = Array.isArray(normalized.done) ? normalized.done : [];
        var failed = Array.isArray(normalized.failed) ? normalized.failed : [];
        var pending = Array.isArray(normalized.pending) ? normalized.pending : [];
        var doneCount = parseInt(String(normalized.done_count != null ? normalized.done_count : done.length), 10) || 0;
        var failedCount = parseInt(String(normalized.failed_count != null ? normalized.failed_count : failed.length), 10) || 0;
        var runningCount = parseInt(String(normalized.running_count != null ? normalized.running_count : running.length), 10) || 0;
        var remainingCount = parseInt(String(normalized.remaining_count != null ? normalized.remaining_count : Math.max(0, total - doneCount - failedCount)), 10) || 0;
        latestEl.innerHTML = '<div class="d-flex align-items-center justify-content-between gap-2 mb-2">'
            + '<span class="fw-semibold">Stage 1 page fanout</span>'
            + '<span class="text-muted">total ' + total + ' · done ' + doneCount + ' · remaining ' + remainingCount + '</span>'
            + '</div>'
            + '<div class="mb-2">' + escapeHtml(String(fallbackMessage || '').trim()) + '</div>'
            + renderPlanQueueProgressBar('Running', runningCount, total, 'info', running)
            + renderPlanQueueProgressBar('Done', doneCount, total, 'success', done)
            + renderPlanQueueProgressBar('Failed', failedCount, total, 'danger', failed)
            + renderPlanQueueProgressBar('Pending', pending.length, total, 'secondary', pending)
            + renderPlanQueueTaskDetails(normalized.details);
        latestEl.classList.remove('d-none');
        return true;
    }

    function publishPlanQueueLatestMessage(message) {
        if (window.__pbUpdatePlanQueueLatestMessage && typeof window.__pbUpdatePlanQueueLatestMessage === 'function') {
            window.__pbUpdatePlanQueueLatestMessage(message);
            return;
        }
        var latestEl = document.getElementById('pb-ai-plan-queue-latest-message');
        if (!latestEl) {
            return;
        }
        var text = String(message || '').replace(/\r\n|\r/g, '\n').trim();
        var lines = text.split('\n').map(function (line) {
            return String(line || '').trim();
        }).filter(Boolean);
        text = lines.length > 0 ? lines[lines.length - 1] : text;
        latestEl.textContent = text;
        latestEl.classList.toggle('d-none', text === '');
    }

    function resolvePlanQueueLatestMessage(info) {
        var queueInfo = info && typeof info === 'object' ? info : {};
        var snapshot = queueInfo.snapshot && typeof queueInfo.snapshot === 'object' ? queueInfo.snapshot : {};
        var candidates = [
            queueInfo.latest_message,
            queueInfo.process,
            queueInfo.terminal_summary,
            queueInfo.message,
            snapshot.process,
            snapshot.message,
            snapshot.result_tail,
            snapshot.result
        ];
        for (var i = 0; i < candidates.length; i += 1) {
            var text = String(candidates[i] || '').trim();
            if (text !== '') {
                return text;
            }
        }
        return '';
    }

    function resolvePlanQueueLatestPageProgress(info) {
        var queueInfo = info && typeof info === 'object' ? info : {};
        if (queueInfo.stage1_page_progress && typeof queueInfo.stage1_page_progress === 'object') {
            return queueInfo.stage1_page_progress;
        }
        var snapshot = queueInfo.snapshot && typeof queueInfo.snapshot === 'object' ? queueInfo.snapshot : {};
        if (snapshot.stage1_page_progress && typeof snapshot.stage1_page_progress === 'object') {
            return snapshot.stage1_page_progress;
        }
        return null;
    }

    function renderPlanQueueInfoPanel(workspaceState) {
        var metaEl = document.getElementById('pb-ai-plan-queue-info-meta');
        var procEl = document.getElementById('pb-ai-plan-queue-info-process');
        var resEl = document.getElementById('pb-ai-plan-queue-info-result');
        var statusEl = document.querySelector('[data-phase1-queue-status="plan"]');
        if (!metaEl || !procEl || !resEl) {
            return;
        }
        var info = workspaceState && workspaceState.plan_queue_info && typeof workspaceState.plan_queue_info === 'object'
            ? workspaceState.plan_queue_info
            : null;
        if (!info || !info.snapshot || typeof info.snapshot !== 'object') {
            metaEl.innerHTML = '<div class="alert alert-light border mb-0 small">' + escapeHtml(queueMessages.empty) + '</div>';
            procEl.textContent = '';
            resEl.textContent = '';
            if (statusEl) {
                statusEl.textContent = '';
            }
            publishPlanQueueLatestMessage('');
            return;
        }
        var snapJson = '';
        try {
            snapJson = JSON.stringify(info.snapshot, null, 2);
        } catch (e) {
            snapJson = String(info.snapshot);
        }
        var qidRaw = info.queue_id != null ? info.queue_id : (info.snapshot && info.snapshot.queue_id != null ? info.snapshot.queue_id : 0);
        var qid = parseInt(String(qidRaw), 10);
        if (!qid || qid < 1 || isNaN(qid)) {
            qid = 0;
        }
        var idDisplay = qid > 0 ? String(qid) : queueMessages.queueIdUnknown;
        var idRow = '<div class="d-flex flex-wrap align-items-center gap-2 mb-2">'
            + '<span class="text-muted small mb-0">' + escapeHtml(queueMessages.queueIdLabel) + '</span>'
            + '<code class="small mb-0">' + escapeHtml(idDisplay) + '</code>'
            + '</div>';
        metaEl.innerHTML = idRow
            + renderQueueInfoSummary(info)
            + '<pre class="small mb-0 border rounded p-2 bg-light text-break" style="white-space:pre-wrap;max-height:min(28vh,14rem);overflow:auto;">'
            + escapeHtml(snapJson)
            + '</pre>';
        procEl.textContent = String(info.process || '').trim() || '—';
        renderLiveLogSummary(String(info.terminal_summary || info.message || '').trim());
        var latestMessage = resolvePlanQueueLatestMessage(info);
        if (!publishPlanQueueLatestPageProgress(resolvePlanQueueLatestPageProgress(info), latestMessage)) {
            publishPlanQueueLatestMessage(latestMessage);
        }
        if (statusEl) {
            statusEl.textContent = String((info.snapshot && (info.snapshot.job_status || info.snapshot.status)) || '').trim();
        }
    }

    function getLastWorkspaceState() {
        try {
            return window.__pbLastWorkspaceState && typeof window.__pbLastWorkspaceState === 'object'
                ? window.__pbLastWorkspaceState
                : {};
        } catch (e) {
            return {};
        }
    }

    function rememberPlanQueueInfo(info) {
        var state = sanitizeWorkspaceStateForMemory(getLastWorkspaceState());
        state.plan_queue_info = sanitizeQueueInfoForMemory(info);
        var remembered = sanitizeWorkspaceStateForMemory(state);
        try {
            window.__pbLastWorkspaceState = remembered;
        } catch (e) {
            // ignore
        }
        return remembered;
    }

    function syncPanelOpenState(workspaceState) {
        var panelEl = document.getElementById('pb-ai-plan-queue-info-panel');
        if (!panelEl) {
            return;
        }
        var active = workspaceState && workspaceState.active_operation && typeof workspaceState.active_operation === 'object'
            ? workspaceState.active_operation
            : {};
        var op = String(active.operation || '').toLowerCase();
        var status = String(active.status || '').toLowerCase();
        var shouldOpen = op === 'plan' && (status === 'queued' || status === 'running');
        if (shouldOpen && panelEl.dataset.pbUserClosed !== '1') {
            panelEl.open = true;
        } else if (!shouldOpen) {
            panelEl.dataset.pbProgrammaticToggle = '1';
            panelEl.open = false;
            delete panelEl.dataset.pbProgrammaticToggle;
        }
    }

    function bindPanelManualToggle() {
        var panelEl = document.getElementById('pb-ai-plan-queue-info-panel');
        if (!panelEl || panelEl.dataset.pbManualToggleBound === '1') {
            return;
        }
        panelEl.dataset.pbManualToggleBound = '1';
        panelEl.addEventListener('toggle', function () {
            if (panelEl.dataset.pbProgrammaticToggle === '1') {
                return;
            }
            if (panelEl.open) {
                delete panelEl.dataset.pbUserClosed;
            } else {
                panelEl.dataset.pbUserClosed = '1';
                disposeLiveStream('');
            }
        });
    }

    function normalizeQueueId(value) {
        var qid = parseInt(String(value == null ? '' : value), 10);
        return qid > 0 && !isNaN(qid) ? qid : 0;
    }

    function sanitizeQueueInfoForMemory(info) {
        var safe = info && typeof info === 'object' ? Object.assign({}, info) : {};
        ['result_log', 'queue_result_delta', 'chunk', 'content', 'events', 'top_logs'].forEach(function (key) {
            delete safe[key];
        });
        if (safe.snapshot && typeof safe.snapshot === 'object') {
            safe.snapshot = Object.assign({}, safe.snapshot);
            ['result_log', 'queue_result_delta', 'chunk', 'content', 'events', 'top_logs'].forEach(function (key) {
                delete safe.snapshot[key];
            });
        }
        return safe;
    }

    function sanitizeWorkspaceStateForMemory(workspaceState) {
        var state = workspaceState && typeof workspaceState === 'object' ? Object.assign({}, workspaceState) : {};
        ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
            delete state[key];
        });
        if (state.scope && typeof state.scope === 'object') {
            state.scope = Object.assign({}, state.scope);
            ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
                delete state.scope[key];
            });
            if (state.scope.snapshot && typeof state.scope.snapshot === 'object') {
                state.scope.snapshot = Object.assign({}, state.scope.snapshot);
                ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
                    delete state.scope.snapshot[key];
                });
            }
            ['plan_queue_info', 'build_queue_info'].forEach(function (key) {
                if (state.scope[key] && typeof state.scope[key] === 'object') {
                    state.scope[key] = sanitizeQueueInfoForMemory(state.scope[key]);
                }
            });
        }
        if (state.snapshot && typeof state.snapshot === 'object') {
            state.snapshot = Object.assign({}, state.snapshot);
            ['events', 'top_logs', 'result_log', 'queue_result_delta', 'chunk', 'content'].forEach(function (key) {
                delete state.snapshot[key];
            });
        }
        if (state.plan_queue_info && typeof state.plan_queue_info === 'object') {
            state.plan_queue_info = sanitizeQueueInfoForMemory(state.plan_queue_info);
        }
        if (state.build_queue_info && typeof state.build_queue_info === 'object') {
            state.build_queue_info = sanitizeQueueInfoForMemory(state.build_queue_info);
        }
        return state;
    }

    function getLiveLogElement() {
        return document.getElementById('pb-ai-plan-queue-info-result');
    }

    function renderLiveLogSummary(summary) {
        var resEl = getLiveLogElement();
        if (!resEl) {
            return;
        }
        var text = String(summary || '').trim();
        if (text !== '') {
            resEl.dataset.pbLiveLog = '0';
            resEl.textContent = text;
            resEl.scrollTop = 0;
            return;
        }
        if (resEl.dataset.pbLiveLog === '1' && resEl.childNodes.length > 0) {
            return;
        }
        resEl.dataset.pbLiveLog = '0';
        resEl.textContent = '—';
    }

    function appendLiveQueueLog(delta) {
        var resEl = getLiveLogElement();
        var text = String(delta || '');
        if (!resEl || text === '') {
            return;
        }
        var panelEl = document.getElementById('pb-ai-plan-queue-info-panel');
        if (panelEl && !panelEl.open) {
            return;
        }
        if (resEl.dataset.pbLiveLog !== '1') {
            resEl.textContent = '';
            resEl.dataset.pbLiveLog = '1';
        }
        text.split(/\r\n|\n|\r/).forEach(function (line) {
            var item = String(line || '').trim();
            if (item === '') {
                return;
            }
            var node = document.createElement('div');
            node.textContent = item;
            resEl.appendChild(node);
            while (resEl.childNodes.length > LIVE_LOG_MAX_LINES) {
                resEl.removeChild(resEl.firstChild);
            }
        });
        resEl.scrollTop = resEl.scrollHeight;
    }

    function disposeLiveStream(summary) {
        var resEl = getLiveLogElement();
        if (!resEl) {
            return;
        }
        resEl.textContent = '';
        resEl.dataset.pbLiveLog = '0';
        renderLiveLogSummary(summary || '');
    }

    function isTerminalQueueStatus(status) {
        return ['done', 'complete', 'completed', 'success', 'error', 'failed', 'failure', 'stop', 'stopped', 'cancelled', 'canceled'].indexOf(String(status || '').toLowerCase()) >= 0;
    }

    function mergePlanQueueInfoFromSsePayload(payload, eventKind) {
        if (!payload || typeof payload !== 'object') {
            return null;
        }
        var progressKind = resolvePayloadProgressKind(payload);
        if (progressKind !== '' && progressKind !== 'queue_info') {
            return null;
        }
        if (payload.state && payload.state.plan_queue_info && typeof payload.state.plan_queue_info === 'object') {
            return sanitizeQueueInfoForMemory(payload.state.plan_queue_info);
        }
        if (payload.queue_info && typeof payload.queue_info === 'object') {
            return sanitizeQueueInfoForMemory(payload.queue_info);
        }

        var hasQueueSignal = !!(
            (payload.queue_snapshot && typeof payload.queue_snapshot === 'object')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_id')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_status')
            || Object.prototype.hasOwnProperty.call(payload, 'job_status')
            || Object.prototype.hasOwnProperty.call(payload, 'status')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_process')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_result_log')
            || Object.prototype.hasOwnProperty.call(payload, 'queue_result_delta')
            || Object.prototype.hasOwnProperty.call(payload, 'job_key')
            || Object.prototype.hasOwnProperty.call(payload, 'job_type')
            || Object.prototype.hasOwnProperty.call(payload, 'stage1_page_progress')
            || Object.prototype.hasOwnProperty.call(payload, 'token')
            || Object.prototype.hasOwnProperty.call(payload, 'execution_token')
            || Object.prototype.hasOwnProperty.call(payload, 'token_usage')
            || Object.prototype.hasOwnProperty.call(payload, 'input_tokens')
            || Object.prototype.hasOwnProperty.call(payload, 'output_tokens')
            || Object.prototype.hasOwnProperty.call(payload, 'total_tokens')
            || String(payload.progress_kind || '') === 'queue_info'
        );
        if (!hasQueueSignal) {
            return null;
        }

        var state = getLastWorkspaceState();
        var existing = state.plan_queue_info && typeof state.plan_queue_info === 'object'
            ? state.plan_queue_info
            : {};
        var existingSnapshot = existing.snapshot && typeof existing.snapshot === 'object' ? existing.snapshot : {};
        var snapshot = Object.assign({}, existingSnapshot);
        if (payload.queue_snapshot && typeof payload.queue_snapshot === 'object') {
            snapshot = Object.assign(snapshot, payload.queue_snapshot);
        }

        var payloadQueueId = normalizeQueueId(payload.queue_id);
        if (payloadQueueId > 0) {
            snapshot.queue_id = payloadQueueId;
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_status')) {
            snapshot.status = String(payload.queue_status || '');
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'status')) {
            snapshot.status = String(payload.status || '');
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'job_status')) {
            snapshot.job_status = String(payload.job_status || '');
        } else if (Object.prototype.hasOwnProperty.call(payload, 'status')) {
            snapshot.job_status = String(payload.status || '');
        }
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_pid')) {
            snapshot.pid = normalizeQueueId(payload.queue_pid);
        }
        ['job_key', 'job_type', 'token', 'execution_token', 'input_tokens', 'output_tokens', 'total_tokens', 'prompt_tokens', 'completion_tokens', 'prompt_eval_count', 'eval_count'].forEach(function (key) {
            if (Object.prototype.hasOwnProperty.call(payload, key)) {
                snapshot[key] = payload[key];
            }
        });
        if (payload.token_usage && typeof payload.token_usage === 'object') {
            snapshot.token_usage = Object.assign(
                {},
                snapshot.token_usage && typeof snapshot.token_usage === 'object' ? snapshot.token_usage : {},
                payload.token_usage
            );
        }
        var incomingUsage = mergeTokenUsageNumbers(
            toObjectSafe(snapshot.token_usage),
            mergeTokenUsageNumbers(
                toObjectSafe(payload.token_usage),
                toObjectSafe(payload.queue_snapshot && payload.queue_snapshot.token_usage)
            )
        );
        var textUsage = mergeTokenUsageNumbers(
            extractTokenUsageFromText(payload.queue_result_delta),
            mergeTokenUsageNumbers(
                extractTokenUsageFromText(payload.queue_process),
                extractTokenUsageFromText(payload.message || payload.chunk || payload.content)
            )
        );
        var mergedUsage = mergeTokenUsageNumbers(incomingUsage, textUsage);
        if (
            mergedUsage.input_tokens !== null
            || mergedUsage.output_tokens !== null
            || mergedUsage.total_tokens !== null
        ) {
            snapshot.token_usage = Object.assign(
                {},
                snapshot.token_usage && typeof snapshot.token_usage === 'object' ? snapshot.token_usage : {},
                mergedUsage
            );
            if (mergedUsage.input_tokens !== null) {
                snapshot.input_tokens = mergedUsage.input_tokens;
            }
            if (mergedUsage.output_tokens !== null) {
                snapshot.output_tokens = mergedUsage.output_tokens;
            }
            if (mergedUsage.total_tokens !== null) {
                snapshot.total_tokens = mergedUsage.total_tokens;
            }
        }

        var process = String(existing.process || '');
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_process')) {
            process = String(payload.queue_process || '');
        } else if (String(eventKind || '') === 'progress' && payloadQueueId > 0 && payload.message) {
            process = String(payload.message || '');
        }

        var delta = '';
        if (Object.prototype.hasOwnProperty.call(payload, 'queue_result_delta')) {
            delta = String(payload.queue_result_delta || '');
        } else if (String(eventKind || '') === 'chunk' && payloadQueueId > 0) {
            delta = String(payload.chunk || payload.content || payload.message || '');
        }
        appendLiveQueueLog(delta);
        var terminalStatus = String(payload.queue_status || payload.job_status || payload.status || snapshot.job_status || snapshot.status || '').toLowerCase();
        var terminalSummary = '';
        if (Object.prototype.hasOwnProperty.call(payload, 'terminal_summary')) {
            terminalSummary = String(payload.terminal_summary || '');
        } else if (isTerminalQueueStatus(terminalStatus)) {
            terminalSummary = String(payload.message || process || '').trim();
        }

        var queueId = normalizeQueueId(existing.queue_id || snapshot.queue_id || payloadQueueId);
        if (Object.keys(snapshot).length === 0 && queueId <= 0 && process === '' && terminalSummary === '') {
            return null;
        }
        var latestMessage = String(
            payload.queue_process
            || payload.message
            || process
            || terminalSummary
            || delta
            || ''
        ).trim();

        return {
            queue_id: queueId,
            snapshot: snapshot,
            process: process,
            terminal_summary: terminalSummary,
            latest_message: latestMessage,
            stage1_page_progress: payload.stage1_page_progress && typeof payload.stage1_page_progress === 'object'
                ? payload.stage1_page_progress
                : null
        };
    }

    function syncFromSsePayload(operation, payload, eventKind) {
        if (String(operation || '').toLowerCase() !== 'plan') {
            return;
        }
        var info = mergePlanQueueInfoFromSsePayload(payload, eventKind);
        if (!info || typeof info !== 'object') {
            return;
        }
        var state = rememberPlanQueueInfo(info);
        renderPlanQueueInfoPanel(state);
        var queueStatus = String(payload.queue_status || payload.job_status || payload.status || (info.snapshot && (info.snapshot.job_status || info.snapshot.status)) || '').toLowerCase();
        syncPanelOpenState(Object.assign({}, state, {
            active_operation: { operation: 'plan', status: queueStatus || 'running' }
        }));
        if (isTerminalQueueStatus(queueStatus)) {
            disposeLiveStream(info.terminal_summary || payload.terminal_summary || payload.message || '');
        }
    }

    function syncFromWorkspaceState(workspaceState) {
        if (!workspaceState || typeof workspaceState !== 'object') {
            return;
        }
        var safeState = sanitizeWorkspaceStateForMemory(workspaceState);
        try {
            window.__pbLastWorkspaceState = safeState;
        } catch (e) {
            // ignore
        }
        renderPlanQueueInfoPanel(safeState);
        syncPanelOpenState(safeState);
    }

    function bindPlanQueueInfoRefresh() {
        var btn = document.getElementById('pb-ai-plan-queue-info-refresh');
        if (!btn || btn.dataset.pbBound === '1') {
            return;
        }
        btn.dataset.pbBound = '1';
        btn.addEventListener('click', function () {
            btn.disabled = true;
            var refreshPromise = (window.__pbWorkspaceApi && typeof window.__pbWorkspaceApi.refreshWorkspaceStateFromCache === 'function')
                ? window.__pbWorkspaceApi.refreshWorkspaceStateFromCache()
                : Promise.reject(new Error('workspace cache refresh unavailable'));
            refreshPromise.then(function (data) {
                btn.disabled = false;
                if (data && data.success && data.data) {
                    if (typeof window.hydrateWorkspaceFromState === 'function') {
                        window.hydrateWorkspaceFromState(data.data);
                    }
                    toast('success', queueMessages.refreshed);
                    return;
                }
                toast('error', (data && data.message) ? String(data.message) : queueMessages.refreshFailed);
            }).catch(function () {
                btn.disabled = false;
                toast('error', queueMessages.refreshFailed);
            });
        });
    }

    window.__pbPhase1TaskProgress = {
        syncFromWorkspaceState: syncFromWorkspaceState,
        syncFromSsePayload: syncFromSsePayload,
        renderPlanQueueInfoPanel: renderPlanQueueInfoPanel,
        disposeLiveStream: disposeLiveStream,
        bindPlanQueueInfoRefresh: bindPlanQueueInfoRefresh
    };

    bindPanelManualToggle();
    bindPlanQueueInfoRefresh();
    var st = null;
    try {
        st = window.__pbLastWorkspaceState;
    } catch (e) {
        st = null;
    }
    if (st && typeof st === 'object') {
        syncFromWorkspaceState(st);
    }
})();
</script>
