<script>
// 消息类型映射
const MESSAGE_TYPE_MAP = {
    success: 'success',
    error: 'danger',
    warning: 'warning',
    info: 'info'
};

// 显示页面消息
function showPageMessage(type, message) {
    const container = document.getElementById('page-message-container');
    if (!container) {
        console.warn('page message container not found');
        alert(message);
        return;
    }
    const alertType = MESSAGE_TYPE_MAP[type] || 'info';
    const alertEl = document.createElement('div');
    alertEl.className = `alert alert-${alertType} alert-dismissible fade show`;
    alertEl.setAttribute('role', 'alert');
    alertEl.innerHTML = `
        <span>${message}</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    container.appendChild(alertEl);
    setTimeout(() => {
        try {
            const bsAlert = bootstrap.Alert.getOrCreateInstance(alertEl);
            bsAlert.close();
        } catch (e) {
            alertEl.remove();
        }
    }, 4000);
}

function saveConfig(event) {
    event.preventDefault();
    const form = document.getElementById('configForm');
    const formData = new FormData(form);
    
    // 处理复选框值
    const aiEnabled = document.getElementById('ai_enabled').checked ? '1' : '0';
    const i18nEnabled = document.getElementById('i18n_enabled').checked ? '1' : '0';
    formData.set('ai_enabled', aiEnabled);
    formData.set('i18n_enabled', i18nEnabled);
    
    const data = {};
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }
    
    fetch('<?= $this->getBackendUrl('pagebuilder/backend/config/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            // 延迟刷新页面以显示更新后的配置
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showPageMessage('error', '<?= __('保存失败') ?>');
    });
}

function resetForm() {
    if (confirm('<?= __('确定要重置表单吗？') ?>')) {
        document.getElementById('configForm').reset();
    }
}
</script>

