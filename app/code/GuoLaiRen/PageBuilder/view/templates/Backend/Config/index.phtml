<script>
(function() {
    'use strict';
    
    var MESSAGE_TYPE_MAP = {
        success: 'success',
        error: 'danger',
        warning: 'warning',
        info: 'info'
    };
    
    function showPageMessage(type, message) {
        var container = document.getElementById('pagebuilder-config-message-container');
        if (!container) {
            console.warn('page message container not found');
            if (typeof BackendToast !== 'undefined') {
                BackendToast[type] ? BackendToast[type](message) : BackendToast.info(message);
            } else {
                alert(message);
            }
            return;
        }
        var alertType = MESSAGE_TYPE_MAP[type] || 'info';
        var alertEl = document.createElement('div');
        alertEl.className = 'alert alert-' + alertType + ' alert-dismissible fade show';
        alertEl.setAttribute('role', 'alert');
        alertEl.innerHTML = '<span>' + message + '</span>' +
            '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
        container.appendChild(alertEl);
        setTimeout(function() {
            try {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(alertEl);
                bsAlert.close();
            } catch (e) {
                alertEl.remove();
            }
        }, 4000);
    }
    
    function saveConfig(event) {
        event.preventDefault();
        var form = document.getElementById('pagebuilderConfigForm');
        var formData = new FormData(form);
        
        var aiEnabled = document.getElementById('pagebuilder_ai_enabled').checked ? '1' : '0';
        var i18nEnabled = document.getElementById('pagebuilder_i18n_enabled').checked ? '1' : '0';
        formData.set('ai_enabled', aiEnabled);
        formData.set('i18n_enabled', i18nEnabled);
        
        var data = {};
        for (var pair of formData.entries()) {
            data[pair[0]] = pair[1];
        }
        
        var url = '<?= $this->getBackendUrl('pagebuilder/backend/config/save') ?>';
        var opts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: (new URLSearchParams(data)).toString()
        };
        window.Weline.Api.request(url, opts).then(function(res) {
            var payload = (res && res.data !== undefined) ? res.data : res;
            var msg = (payload && payload.message) ? payload.message : '';
            if (payload && payload.success) {
                showPageMessage('success', msg);
                setTimeout(function() { window.location.reload(); }, 1000);
            } else {
                showPageMessage('error', msg || '<?= __('保存失败') ?>');
            }
        }).catch(function(error) {
            console.error('Config save error:', error);
            showPageMessage('error', (error && error.message) ? error.message : '<?= __('保存失败') ?>');
        });
    }
    
    function resetForm() {
        if (typeof AdminConfirm !== 'undefined') {
            AdminConfirm.show('<?= __('确定要重置表单吗？') ?>').then(function(confirmed) {
                if (confirmed) {
                    document.getElementById('pagebuilderConfigForm').reset();
                }
            });
        } else if (confirm('<?= __('确定要重置表单吗？') ?>')) {
            document.getElementById('pagebuilderConfigForm').reset();
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('pagebuilderConfigForm');
        if (form) {
            form.addEventListener('submit', saveConfig);
        }
        
        var resetBtn = document.getElementById('pagebuilderConfigResetBtn');
        if (resetBtn) {
            resetBtn.addEventListener('click', resetForm);
        }
    });
})();
</script>
