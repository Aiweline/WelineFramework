<?php
/**
 * 模板配置预览页面（独立页面，避免内存问题）
 * 用于在 iframe 中加载，需要完整的 HTML 结构
 * @var \Weline\Framework\View\Template $this
 */
$page = $this->getData('page');
$pageId = $this->getData('visual_config_page_id') ?: ($page && $page->getId() ? $page->getId() : 0);
$styleCode = $this->request->getGet('style_code') ?: '';

?>
<!DOCTYPE html>
<html lang="zh-Hans">
<head>
    <base href="@backend-url('/')">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($this->getData('page_title') ?? __('模板配置预览')) ?></title>
    
    <?php
    /**@var \Weline\Backend\Block\ThemeConfig $themeConfig */
    $themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);
    ?>
    
    <!-- 加载必要的 CSS 和 JS（参考 head.phtml） -->
    <!-- Bootstrap CSS -->
    <link href="<?= $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/bootstrap' . ($themeConfig->getThemeModel() ? '-' . $themeConfig->getThemeModel() : '') . '.min.css') ?>" rel="stylesheet" type="text/css"/>
    
    <!-- Icons CSS -->
    <css>Weline_Admin::assets/css/icons.min.css</css>
    
    <!-- App CSS -->
    <link href="<?= $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/app' . ($themeConfig->getThemeModel() ? '-' . $themeConfig->getThemeModel() : '') . '.min.css') ?>" rel="stylesheet" type="text/css"/>
    
    <!-- Material Design Icons -->
    <link href="@static(Weline_Admin::libs/mdi/css/materialdesignicons.min.css)" rel="stylesheet">
    
    <!-- jQuery (必须在其他 JS 之前加载) -->
    <js>Weline_Backend::/backend/lib/jquery/3.6.0/jquery.js</js>
    
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            overflow: auto; /* 在独立页面中允许滚动，避免内容被遮挡 */
        }
        html, body {
            height: 100%;
            width: 100%;
        }
    </style>
</head>
<body>
    <?php
    // 设置模板配置模式
    $this->assign('is_template_config_mode', true);
    $this->assign('page', $page);
    $this->assign('visual_config_page_id', $pageId);
    ?>
    <w:template>GuoLaiRen_PageBuilder::Backend/Page/form_component/visual_config.phtml</w:template>
    
    <!-- 加载必要的 JS（参考 footer.phtml） -->
    <!-- Bootstrap JS Bundle -->
    <script src="@static(Weline_Admin::assets/libs/bootstrap/js/bootstrap.bundle.min.js)"></script>
    
    <!-- App JS -->
    <script src="@static(Weline_Admin::assets/js/app.js)"></script>
    
    <script>
    // 设置模板配置相关的全局变量
    window.isTemplateConfigMode = true;
    window.currentTemplateStyleCode = '<?= htmlspecialchars($styleCode ?? '') ?>';
    window.currentTemplatePageId = <?= $pageId ?: '0' ?>;
    window.visualPageId = <?= $pageId ?: '0' ?>;

    // 通知父页面：配置页面已就绪（用于隐藏 offcanvas 的 loading 遮罩）
    (function(){
        const notifyReady = function() {
            try {
                if (window.parent && window.parent !== window) {
                    window.parent.postMessage({ type: 'template-config-ready' }, '*');
                }
            } catch (e) {}
        };
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
            setTimeout(notifyReady, 0);
        } else {
            document.addEventListener('DOMContentLoaded', notifyReady);
        }
        // 兜底：5s 后仍未触发则再次通知一次
        setTimeout(notifyReady, 5000);
    })();

    // 如果可视化组件提供了延迟初始化方法，则主动触发（确保渲染出来）
    if (typeof window.visualConfigLazyInit === 'function') {
        try { window.visualConfigLazyInit(); } catch (e) {}
    }
    </script>
</body>
</html>

