<!-- html2canvas for screenshot功能 -->
<script src="@static(GuoLaiRen_PageBuilder::libs/html2canvas/html2canvas.min.js)"></script>

<script>
// API URLs
const API_URLS = {
    generatePreview: '<?= $this->getBackendUrl('*/backend/template/generatePreview') ?>',
    uploadPreview: '<?= $this->getBackendUrl('*/backend/template/uploadPreview') ?>',
    generateAllPreviews: '<?= $this->getBackendUrl('*/backend/template/generateAllPreviews') ?>',
    togglePublish: '<?= $this->getBackendUrl('*/backend/template/togglePublish') ?>',
    stylePreview: '<?= $this->getBackendUrl('pagebuilder/backend/preview/stylePreview') ?>'
};

// 切换发布状态
async function togglePublish(styleId, isPublished, skipPreviewCheck = false) {
    const confirmMsg = isPublished 
        ? '<?= __('确定要发布此模板吗？发布后，新建页面时将可以选择此模板。') ?>' 
        : '<?= __('确定要取消发布此模板吗？取消发布后，新建页面时将无法选择此模板。') ?>';
    
    const confirmed = await BackendConfirm.show(confirmMsg);
    if (!confirmed) return;
    
    try {
        var opts = {
            method: 'POST',
            body: JSON.stringify({ style_id: styleId, is_published: isPublished, skip_preview_check: skipPreviewCheck ? '1' : '0' }),
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        };
        var res = await window.Weline.Api.request(API_URLS.togglePublish, opts);
        const data = (res && res.data) || res;
        
        if (data.success) {
            location.reload();
        } else if (data.needs_preview && isPublished) {
            // 需要先生成预览图
            const confirmGenerate = await BackendConfirm.show('<?= __('此模板还没有预览图，发布前需要先生成预览图。是否立即生成？') ?>');
            
            if (confirmGenerate) {
                // 显示生成中提示
                const progressModal = window.WelineModal['previewProgressModal'];
                progressModal.showProgress({
                    title: '<?= __('正在生成预览图...') ?>',
                    subtitle: '<?= __('请稍候，正在自动生成模板预览图') ?>',
                    progress: 50
                });
                
                try {
                    // 生成预览图
                    await generatePreviewForPublish(data.style_code);
                    
                    // 预览图生成成功，重新发布
                    progressModal.hide();
                    BackendToast.success('<?= __('预览图生成成功，正在完成发布...') ?>');
                    
                    // 延迟后重新调用发布（跳过预览检查）
                    setTimeout(() => {
                        togglePublish(styleId, isPublished, true);
                    }, 1500);
                    
                } catch (error) {
                    progressModal.hide();
                    BackendToast.error('<?= __('预览图生成失败：') ?>' + (error.message || '<?= __('请手动生成预览图后再发布') ?>'));
                }
            }
        } else {
            BackendToast.error(data.message || '<?= __('操作失败') ?>');
        }
    } catch (error) {
        console.error('Error:', error);
        BackendToast.error('<?= __('操作失败，请稍后重试') ?>');
    }
}

// 为发布生成预览图
async function generatePreviewForPublish(styleCode) {
    console.log('🔄 为发布生成预览图:', styleCode);
    
    // 创建隐藏的 iframe 加载预览页面
    const iframe = document.createElement('iframe');
    iframe.style.cssText = 'position: absolute; left: -9999px; width: 1400px; height: 900px; border: none;';
    iframe.src = API_URLS.stylePreview + '?style_code=' + encodeURIComponent(styleCode);
    document.body.appendChild(iframe);
    
    try {
        // 等待 iframe 加载完成
        await new Promise((resolve, reject) => {
            iframe.onload = resolve;
            iframe.onerror = reject;
            setTimeout(resolve, 15000);
        });
        
        // 额外等待页面渲染
        await new Promise(resolve => setTimeout(resolve, 2000));
        
        // 使用 html2canvas 截图
        if (typeof html2canvas === 'undefined') {
            throw new Error('html2canvas 未加载');
        }
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问 iframe 内容');
        }
        
        console.log('📸 正在截图...');
        
        const canvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.5,
            width: 1400,
            height: 900,
            logging: false,
            backgroundColor: '#ffffff'
        });
        
        // 转换为 base64
        const imageData = canvas.toDataURL('image/png', 0.9);
        
        console.log('📤 正在上传预览图...');
        var opts = { method: 'POST', body: JSON.stringify({ style_code: styleCode, image_data: imageData }), headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
        var res = await window.Weline.Api.request(API_URLS.uploadPreview, opts);
        var result = (res && res.data) || res;
        if (!result.success) throw new Error(result.message || '上传失败');
        console.log('✅ 预览图生成成功');
        return result;
        
    } finally {
        // 移除 iframe
        iframe.remove();
    }
}

// 搜索功能 - 回车键搜索
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('templateSearchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const form = this.closest('form');
                if (form) {
                    form.submit();
                }
            }
        });
    }
});

// 配置预览 - 打开可视化配置界面
function openConfigPreview(styleCode) {
    const pageId = document.getElementById('previewPageSelect').value || 0;
    window.currentTemplateStyleCode = styleCode;
    window.currentTemplatePageId = parseInt(pageId) || 0;
    window.isTemplateConfigMode = true;
    openVisualConfig();
}

// 打开图片预览
function openImagePreview(imageSrc, title) {
    const modalHtml = `
        <div id="previewImageModal" style="
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
        " onclick="closePreviewImageModal()">
            <div style="max-width: 95%; max-height: 95%; position: relative;">
                <img src="${imageSrc}" alt="${title}" style="max-width: 100%; max-height: 95vh; object-fit: contain; border-radius: 8px; box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);">
                <button onclick="closePreviewImageModal()" style="position: absolute; top: -40px; right: 0; background: rgba(255, 255, 255, 0.9); border: none; border-radius: 50%; width: 36px; height: 36px; font-size: 20px; cursor: pointer; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);">×</button>
            </div>
        </div>
    `;
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    document.body.style.overflow = 'hidden';
}

function closePreviewImageModal() {
    const modal = document.getElementById('previewImageModal');
    if (modal) modal.remove();
    document.body.style.overflow = '';
}

// ESC键关闭模态框
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePreviewImageModal();
});

/**
 * 打开默认模板预览（新窗口）
 */
function openDefaultPreview(styleCode, styleName) {
    const previewUrl = API_URLS.stylePreview + '?style_code=' + encodeURIComponent(styleCode);
    window.open(previewUrl, '_blank');
}

/**
 * 处理预览图加载失败
 */
function handlePreviewImageError(imgEl, styleCode) {
    const previewContainer = imgEl.closest('.template-card-preview');
    if (previewContainer) {
        // 隐藏损坏的图片，显示占位符
        imgEl.style.display = 'none';
        const placeholder = document.createElement('div');
        placeholder.className = 'template-card-preview-placeholder';
        placeholder.innerHTML = `
            <div class="placeholder-icon">
                <i class="mdi mdi-image-broken"></i>
            </div>
            <div class="placeholder-text"><?= __('预览图加载失败') ?></div>
            <button type="button" class="btn-generate-preview" onclick="refreshSinglePreview('${styleCode}')">
                <i class="mdi mdi-refresh"></i> <?= __('重新生成') ?>
            </button>
        `;
        previewContainer.appendChild(placeholder);
    }
}

/**
 * 刷新单个模板的预览图
 */
async function refreshSinglePreview(styleCode) {
    console.log('🔄 开始生成预览图:', styleCode);
    
    const cardEl = document.querySelector(`[data-style-code="${styleCode}"]`);
    if (!cardEl) {
        console.error('找不到模板卡片:', styleCode);
        return;
    }
    
    const previewContainer = cardEl.querySelector('.template-card-preview');
    const loadingEl = previewContainer.querySelector('.template-card-preview-loading');
    
    // 显示加载状态
    if (loadingEl) loadingEl.style.display = 'flex';
    
    try {
        // 创建隐藏的 iframe 加载预览页面
        const iframe = document.createElement('iframe');
        iframe.style.cssText = 'position: absolute; left: -9999px; width: 1400px; height: 900px; border: none;';
        iframe.src = API_URLS.stylePreview + '?style_code=' + encodeURIComponent(styleCode);
        document.body.appendChild(iframe);
        
        // 等待 iframe 加载完成
        await new Promise((resolve, reject) => {
            iframe.onload = resolve;
            iframe.onerror = reject;
            // 超时处理
            setTimeout(resolve, 15000);
        });
        
        // 额外等待页面渲染
        await new Promise(resolve => setTimeout(resolve, 2000));
        
        // 使用 html2canvas 截图
        if (typeof html2canvas === 'undefined') {
            throw new Error('html2canvas 未加载');
        }
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问 iframe 内容');
        }
        
        console.log('📸 正在截图...');
        
        const canvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.5,
            width: 1400,
            height: 900,
            logging: false,
            backgroundColor: '#ffffff'
        });
        
        // 移除 iframe
        iframe.remove();
        
        // 转换为 base64
        const imageData = canvas.toDataURL('image/png', 0.9);
        
        console.log('📤 正在上传预览图...');
        var opts = { method: 'POST', body: JSON.stringify({ style_code: styleCode, image_data: imageData }), headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
        var res = await window.Weline.Api.request(API_URLS.uploadPreview, opts);
        var result = (res && res.data) || res;
        if (result.success) {
            console.log('✅ 预览图生成成功');
            
            // 更新卡片中的预览图
            updatePreviewImage(previewContainer, result.preview_url, styleCode);
        } else {
            throw new Error(result.message || '上传失败');
        }
        
    } catch (error) {
        console.error('❌ 生成预览图失败:', error);
        BackendToast.error('<?= __('生成预览图失败：') ?>' + error.message);
    } finally {
        // 隐藏加载状态
        if (loadingEl) loadingEl.style.display = 'none';
    }
}

/**
 * 更新预览图显示
 */
function updatePreviewImage(previewContainer, imageUrl, styleCode) {
    // 清除旧内容（保留加载遮罩）
    const loading = previewContainer.querySelector('.template-card-preview-loading');
    
    previewContainer.innerHTML = '';
    
    // 添加操作按钮
    const actionsHtml = `
        <div class="template-card-preview-actions">
            <button type="button" class="btn-action-icon" onclick="openImagePreview('${imageUrl}', '')" title="<?= __('放大预览图') ?>">
                <i class="mdi mdi-magnify-plus"></i>
            </button>
            <button type="button" class="btn-action-icon" onclick="refreshSinglePreview('${styleCode}')" title="<?= __('刷新预览图') ?>">
                <i class="mdi mdi-refresh"></i>
            </button>
            <button type="button" class="btn-action-icon" onclick="openDefaultPreview('${styleCode}', '')" title="<?= __('在新窗口预览') ?>">
                <i class="mdi mdi-open-in-new"></i>
            </button>
        </div>
    `;
    previewContainer.insertAdjacentHTML('beforeend', actionsHtml);
    
    // 添加图片
    const img = document.createElement('img');
    img.src = imageUrl;
    img.className = 'template-preview-img';
    img.onerror = function() { handlePreviewImageError(this, styleCode); };
    previewContainer.appendChild(img);
    
    // 恢复加载遮罩
    if (loading) previewContainer.appendChild(loading);
    
    // 更新元数据图标
    const cardEl = previewContainer.closest('.pagebuilder-template-card');
    if (cardEl) {
        const metaItem = cardEl.querySelector('.meta-item');
        if (metaItem) {
            metaItem.classList.remove('no-preview');
            metaItem.classList.add('has-preview');
            metaItem.innerHTML = '<i class="mdi mdi-image-check"></i> <?= __('有预览') ?>';
        }
    }
}

/**
 * 批量生成所有模板的预览图
 */
async function generateAllPreviews(force = false) {
    const confirmMsg = force 
        ? '<?= __('确定要强制刷新所有模板的预览图吗？这可能需要较长时间。') ?>'
        : '<?= __('确定要为缺少预览图的模板生成预览吗？') ?>';
    
    const confirmed = await BackendConfirm.show(confirmMsg);
    if (!confirmed) return;
    
    console.log('🚀 开始批量生成预览图, force:', force);
    
    try {
        // 获取需要生成预览的模板列表
        var opts = { method: 'POST', body: JSON.stringify({ force: force ? '1' : '0' }), headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
        var res = await window.Weline.Api.request(API_URLS.generateAllPreviews, opts);
        var result = (res && res.data) || res;
        
        if (!result.success) {
            throw new Error(result.message || '获取模板列表失败');
        }
        
        const templates = result.data.filter(t => t.needs_generate);
        
        if (templates.length === 0) {
            BackendToast.info('<?= __('所有模板都已有预览图，无需生成。') ?>');
            return;
        }
        
        // 获取进度模态框组件
        const progressModal = window.WelineModal['previewProgressModal'];
        progressModal.showProgress({
            title: '<?= __('正在生成预览图...') ?>',
            subtitle: '-',
            progress: 0,
            count: '0 / ' + templates.length
        });
        
        let completed = 0;
        let failed = 0;
        
        // 逐个生成预览图
        for (const template of templates) {
            try {
                progressModal.updateProgress({
                    subtitle: template.name,
                    progress: (completed / templates.length) * 100,
                    count: completed + ' / ' + templates.length
                });
                await refreshSinglePreview(template.code);
                completed++;
            } catch (error) {
                console.error(`生成 ${template.code} 预览失败:`, error);
                failed++;
            }
            
            // 间隔一下，避免太快
            await new Promise(resolve => setTimeout(resolve, 500));
        }
        
        // 完成后隐藏进度提示
        progressModal.hide();
        
        BackendToast.success('<?= __('批量生成完成！成功：') ?>' + completed + '<?= __('，失败：') ?>' + failed);
        
        // 刷新页面显示新预览图
        if (completed > 0) {
            location.reload();
        }
        
    } catch (error) {
        console.error('批量生成失败:', error);
        BackendToast.error('<?= __('批量生成失败：') ?>' + error.message);
    }
}
</script>

<!-- 可视化配置界面 - 使用 offcanvas iframe 按需加载，避免内存耗尽 -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="templateConfigOffcanvas" style="width: 90%; max-width: 1600px;">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="templateConfigOffcanvasLabel">
            <i class="mdi mdi-palette"></i> <?= __('模板配置预览') ?>
        </h5>
        <div class="d-flex gap-2 align-items-center">
            <button type="button" 
                    class="btn btn-sm btn-outline-primary" 
                    id="templateConfigRefreshBtn"
                    onclick="refreshTemplateConfigIframe()"
                    title="<?= __('刷新配置界面') ?>">
                <i class="mdi mdi-refresh"></i> <?= __('刷新') ?>
            </button>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="<?= __('关闭') ?>"></button>
        </div>
    </div>
    <div class="offcanvas-body p-0" style="height: calc(100vh - 60px);">
        <div class="position-relative w-100 h-100">
            <iframe id="templateConfigIframe" 
                    class="w-100 h-100 border-0" 
                    style="display: block;"
                    allowfullscreen></iframe>
        </div>
    </div>
</div>

<script>
// 修改 openConfigPreview 函数，使用 offcanvas 弹窗显示配置界面
window.openConfigPreview = function(styleCode) {
    const pageId = document.getElementById('previewPageSelect').value || <?= $testPageId ?: '0' ?>;
    
    // 构建配置界面的 URL（使用独立的配置页面）
    const configUrl = '<?= $this->getBackendUrl('*/backend/template/configPreview') ?>' +
        '?style_code=' + encodeURIComponent(styleCode) +
        '&page_id=' + pageId;
    
    // 获取 offcanvas 元素
    const offcanvasEl = document.getElementById('templateConfigOffcanvas');
    const iframe = document.getElementById('templateConfigIframe');
    // 不再使用加载遮罩
    const offcanvasTitle = document.getElementById('templateConfigOffcanvasLabel');
    
    if (!offcanvasEl || !iframe) {
        console.error('找不到 offcanvas 元素');
        return;
    }
    
    // 更新标题
    if (offcanvasTitle) {
        offcanvasTitle.innerHTML = '<i class="mdi mdi-palette"></i> <?= __('模板配置预览') ?> - ' + escapeHtml(styleCode);
    }
    
    // 显示加载状态
    // 直接显示 iframe，并在加载完成后同样保持显示
    if (iframe) iframe.style.display = 'block';
    
    // 先显示 offcanvas，然后在显示后再加载 iframe（避免隐藏时浏览器不加载 iframe）
    const bsOffcanvas = new bootstrap.Offcanvas(offcanvasEl);
    
    // 监听 offcanvas 显示事件，在显示后再加载 iframe
    const loadIframe = function() {
        // 设置 iframe 源（只有在 offcanvas 显示后才加载）
        iframe.src = configUrl;
        console.log('📡 开始加载配置界面:', configUrl);
        
        // 监听 iframe 加载完成（load）与父窗口 postMessage 的双保险
        const onIframeLoad = function() {
            console.log('✅ 配置界面加载完成(load)');
            if (iframe) iframe.style.display = 'block';
            iframe.removeEventListener('load', onIframeLoad);
        };
        iframe.addEventListener('load', onIframeLoad);
        
        // 监听 iframe 加载错误
        iframe.onerror = function() {
            console.error('❌ 配置界面加载失败');
            // 无遮罩，打印错误即可
        };
        
        // 移除事件监听器（只执行一次）
        offcanvasEl.removeEventListener('shown.bs.offcanvas', loadIframe);
    };
    
    // 在 offcanvas 显示后再加载 iframe
    offcanvasEl.addEventListener('shown.bs.offcanvas', loadIframe, { once: true });
    
    // 显示 offcanvas
    bsOffcanvas.show();
    
    // 接收 iframe 内页面的就绪通知，隐藏 loading（postMessage）
    const onMessage = function(event) {
        if (event && event.data && event.data.type === 'template-config-ready') {
            console.log('✅ 收到 iframe 就绪通知');
            if (iframe) iframe.style.display = 'block';
            window.removeEventListener('message', onMessage);
        }
    };
    window.addEventListener('message', onMessage);

    // 兜底：8 秒后仍未就绪则强制显示 iframe
    setTimeout(function() {
        console.warn('⏱️ 加载超时，强制显示 iframe');
        if (iframe) iframe.style.display = 'block';
    }, 8000);

    // 监听关闭事件，清空 iframe 内容释放内存
    offcanvasEl.addEventListener('hidden.bs.offcanvas', function() {
        console.log('🔒 清空 iframe 内容释放内存');
        iframe.src = '';
        if (iframe) {
            iframe.style.display = 'none';
        }
        window.removeEventListener('message', onMessage);
    }, { once: true });
};

// HTML 转义辅助函数
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// 刷新配置界面 iframe
function refreshTemplateConfigIframe() {
    const iframe = document.getElementById('templateConfigIframe');
    const refreshBtn = document.getElementById('templateConfigRefreshBtn');
    
    if (!iframe || !iframe.src) {
        console.warn('iframe 不存在或未加载');
        return;
    }
    
    // 显示加载状态
    if (iframe) iframe.style.display = 'none';
    
    // 禁用刷新按钮，显示加载状态
    if (refreshBtn) {
        refreshBtn.disabled = true;
        const icon = refreshBtn.querySelector('i');
        if (icon) {
            icon.className = 'mdi mdi-loading mdi-spin';
        }
    }
    
    // 重新加载 iframe：保留原有查询参数，仅更新/追加 t 避免缓存
    const originalSrc = iframe.src;
    let newSrc = originalSrc;
    try {
        const url = new URL(originalSrc, window.location.origin);
        url.searchParams.set('t', String(Date.now()));
        newSrc = url.toString();
    } catch (e) {
        // 兼容相对地址：用字符串方式替换/追加 t
        if (originalSrc.includes('t=')) {
            newSrc = originalSrc.replace(/([?&])t=[^&]*/, '$1t=' + Date.now());
        } else {
            newSrc = originalSrc + (originalSrc.includes('?') ? '&' : '?') + 't=' + Date.now();
        }
    }
    iframe.src = newSrc;
    
    // 监听加载完成
    const onLoad = function() {
        console.log('✅ 配置界面刷新完成');
        if (iframe) iframe.style.display = 'block';
        // 恢复刷新按钮
        if (refreshBtn) {
            refreshBtn.disabled = false;
            const icon = refreshBtn.querySelector('i');
            if (icon) {
                icon.className = 'mdi mdi-refresh';
            }
        }
        iframe.removeEventListener('load', onLoad);
    };
    
    iframe.addEventListener('load', onLoad);
    
    // 监听加载错误
    const onError = function() {
        console.error('❌ 配置界面刷新失败');
        // 无遮罩，打印错误
        // 恢复刷新按钮
        if (refreshBtn) {
            refreshBtn.disabled = false;
            const icon = refreshBtn.querySelector('i');
            if (icon) {
                icon.className = 'mdi mdi-refresh';
            }
        }
        iframe.removeEventListener('error', onError);
    };
    
    iframe.addEventListener('error', onError);
}
</script>
