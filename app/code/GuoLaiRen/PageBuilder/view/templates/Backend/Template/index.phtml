    </div>
</div>

<script>
// 修改 openConfigPreview 函数，使用 offcanvas 弹窗显示配置界面
window.openConfigPreview = function(styleCode) {
    const pageId = document.getElementById('previewPageSelect').value || <?= $testPageId ?: '0' ?>;
    
    // 构建配置界面的 URL（使用独立的配置页面）
    const configUrl = '<?= $this->getBackendUrl('*/backend/template/configPreview') ?>' +
        '?style_code=' + encodeURIComponent(styleCode) +
        '&page_id=' + pageId;
    
    // 获取 offcanvas 元素
    const offcanvasEl = document.getElementById('templateConfigOffcanvas');
    const iframe = document.getElementById('templateConfigIframe');
    // 不再使用加载遮罩
    const offcanvasTitle = document.getElementById('templateConfigOffcanvasLabel');
    
    if (!offcanvasEl || !iframe) {
        console.error('找不到 offcanvas 元素');
        return;
    }
    
    // 更新标题
    if (offcanvasTitle) {
        offcanvasTitle.innerHTML = '<i class="mdi mdi-palette"></i> <?= __('模板配置预览') ?> - ' + escapeHtml(styleCode);
    }
    
    // 显示加载状态
    // 直接显示 iframe，并在加载完成后同样保持显示
    if (iframe) iframe.style.display = 'block';
    
    // 先显示 offcanvas，然后在显示后再加载 iframe（避免隐藏时浏览器不加载 iframe）
    const bsOffcanvas = new bootstrap.Offcanvas(offcanvasEl);
    
    // 监听 offcanvas 显示事件，在显示后再加载 iframe
    const loadIframe = function() {
        // 设置 iframe 源（只有在 offcanvas 显示后才加载）
        iframe.src = configUrl;
        console.log('📡 开始加载配置界面:', configUrl);
        
        // 监听 iframe 加载完成（load）与父窗口 postMessage 的双保险
        const onIframeLoad = function() {
            console.log('✅ 配置界面加载完成(load)');
            if (iframe) iframe.style.display = 'block';
            iframe.removeEventListener('load', onIframeLoad);
        };
        iframe.addEventListener('load', onIframeLoad);
        
        // 监听 iframe 加载错误
        iframe.onerror = function() {
            console.error('❌ 配置界面加载失败');
            // 无遮罩，打印错误即可
        };
        
        // 移除事件监听器（只执行一次）
        offcanvasEl.removeEventListener('shown.bs.offcanvas', loadIframe);
    };
    
    // 在 offcanvas 显示后再加载 iframe
    offcanvasEl.addEventListener('shown.bs.offcanvas', loadIframe, { once: true });
    
    // 显示 offcanvas
    bsOffcanvas.show();
    
    // 接收 iframe 内页面的就绪通知，隐藏 loading（postMessage）
    const onMessage = function(event) {
        if (event && event.data && event.data.type === 'template-config-ready') {
            console.log('✅ 收到 iframe 就绪通知');
            if (iframe) iframe.style.display = 'block';
            window.removeEventListener('message', onMessage);
        }
    };
    window.addEventListener('message', onMessage);

    // 兜底：8 秒后仍未就绪则强制显示 iframe
    setTimeout(function() {
        console.warn('⏱️ 加载超时，强制显示 iframe');
        if (iframe) iframe.style.display = 'block';
    }, 8000);

    // 监听关闭事件，清空 iframe 内容释放内存
    offcanvasEl.addEventListener('hidden.bs.offcanvas', function() {
        console.log('🔒 清空 iframe 内容释放内存');
        iframe.src = '';
        if (iframe) {
            iframe.style.display = 'none';
        }
        window.removeEventListener('message', onMessage);
    }, { once: true });
};

// HTML 转义辅助函数
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// 刷新配置界面 iframe
function refreshTemplateConfigIframe() {
    const iframe = document.getElementById('templateConfigIframe');
    const refreshBtn = document.getElementById('templateConfigRefreshBtn');
    
    if (!iframe || !iframe.src) {
        console.warn('iframe 不存在或未加载');
        return;
    }
    
    // 显示加载状态
    if (iframe) iframe.style.display = 'none';
    
    // 禁用刷新按钮，显示加载状态
    if (refreshBtn) {
        refreshBtn.disabled = true;
        const icon = refreshBtn.querySelector('i');
        if (icon) {
            icon.className = 'mdi mdi-loading mdi-spin';
        }
    }
    
    // 重新加载 iframe：保留原有查询参数，仅更新/追加 t 避免缓存
    const originalSrc = iframe.src;
    let newSrc = originalSrc;
    try {
        const url = new URL(originalSrc, window.location.origin);
        url.searchParams.set('t', String(Date.now()));
        newSrc = url.toString();
    } catch (e) {
        // 兼容相对地址：用字符串方式替换/追加 t
        if (originalSrc.includes('t=')) {
            newSrc = originalSrc.replace(/([?&])t=[^&]*/, '$1t=' + Date.now());
        } else {
            newSrc = originalSrc + (originalSrc.includes('?') ? '&' : '?') + 't=' + Date.now();
        }
    }
    iframe.src = newSrc;
    
    // 监听加载完成
    const onLoad = function() {
        console.log('✅ 配置界面刷新完成');
        if (iframe) iframe.style.display = 'block';
        // 恢复刷新按钮
        if (refreshBtn) {
            refreshBtn.disabled = false;
            const icon = refreshBtn.querySelector('i');
            if (icon) {
                icon.className = 'mdi mdi-refresh';
            }
        }
        iframe.removeEventListener('load', onLoad);
    };
    
    iframe.addEventListener('load', onLoad);
    
    // 监听加载错误
    const onError = function() {
        console.error('❌ 配置界面刷新失败');
        // 无遮罩，打印错误
        // 恢复刷新按钮
        if (refreshBtn) {
            refreshBtn.disabled = false;
            const icon = refreshBtn.querySelector('i');
            if (icon) {
                icon.className = 'mdi mdi-refresh';
            }
        }
        iframe.removeEventListener('error', onError);
    };
    
    iframe.addEventListener('error', onError);
}
</script>
