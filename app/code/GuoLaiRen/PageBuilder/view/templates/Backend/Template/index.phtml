/**
 * 刷新单个模板的预览图
 */
async function refreshSinglePreview(styleCode) {
    console.log('🔄 开始生成预览图:', styleCode);
    
    const cardEl = document.querySelector(`[data-style-code="${styleCode}"]`);
    if (!cardEl) {
        console.error('找不到模板卡片:', styleCode);
        return;
    }
    
    const previewContainer = cardEl.querySelector('.style-card-preview');
    const loadingEl = previewContainer.querySelector('.style-card-preview-loading');
    
    // 显示加载状态
    if (loadingEl) loadingEl.style.display = 'flex';
    
    try {
        // 创建隐藏的 iframe 加载预览页面
        const iframe = document.createElement('iframe');
        iframe.style.cssText = 'position: absolute; left: -9999px; width: 1400px; height: 900px; border: none;';
        iframe.src = API_URLS.stylePreview + '?style_code=' + encodeURIComponent(styleCode);
        document.body.appendChild(iframe);
        
        // 等待 iframe 加载完成
        await new Promise((resolve, reject) => {
            iframe.onload = resolve;
            iframe.onerror = reject;
            // 超时处理
            setTimeout(resolve, 15000);
        });
        
        // 额外等待页面渲染
        await new Promise(resolve => setTimeout(resolve, 2000));
        
        // 使用 html2canvas 截图
        if (typeof html2canvas === 'undefined') {
            throw new Error('html2canvas 未加载');
        }
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问 iframe 内容');
        }
        
        console.log('📸 正在截图...');
        
        const canvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.5,
            width: 1400,
            height: 900,
            logging: false,
            backgroundColor: '#ffffff'
        });
        
        // 移除 iframe
        iframe.remove();
        
        // 转换为 base64
        const imageData = canvas.toDataURL('image/png', 0.9);
        
        console.log('📤 正在上传预览图...');
        var opts = { method: 'POST', body: JSON.stringify({ style_code: styleCode, image_data: imageData }), headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
        var res = await window.Weline.Api.request(API_URLS.uploadPreview, opts);
        var result = (res && res.data) || res;
        if (result.success) {
            console.log('✅ 预览图生成成功');
            
            // 更新卡片中的预览图
            updatePreviewImage(previewContainer, result.preview_url, styleCode);
        } else {
            throw new Error(result.message || '上传失败');
        }
        
    } catch (error) {
        console.error('❌ 生成预览图失败:', error);
        BackendToast.error('<?= __('生成预览图失败：') ?>' + error.message);
    } finally {
        // 隐藏加载状态
        if (loadingEl) loadingEl.style.display = 'none';
    }
}

/**
 * 更新预览图显示
 */
function updatePreviewImage(previewContainer, imageUrl, styleCode) {
    // 清除旧内容（保留加载遮罩和徽章）
    const loading = previewContainer.querySelector('.style-card-preview-loading');
    const badges = previewContainer.querySelectorAll('.position-absolute');
    
    previewContainer.innerHTML = '';
    
    // 添加操作按钮
    const actionsHtml = `
        <div class="style-card-preview-actions">
            <div class="style-card-preview-btn" onclick="openImagePreview('${imageUrl}', '')" title="<?= __('放大预览图') ?>">
                <i class="mdi mdi-magnify-plus"></i>
            </div>
            <div class="style-card-preview-btn" onclick="refreshSinglePreview('${styleCode}')" title="<?= __('刷新预览图') ?>">
                <i class="mdi mdi-refresh"></i>
            </div>
            <div class="style-card-preview-btn" onclick="openDefaultPreview('${styleCode}', '')" title="<?= __('在新窗口预览') ?>">
                <i class="mdi mdi-open-in-new"></i>
            </div>
        </div>
    `;
    previewContainer.insertAdjacentHTML('beforeend', actionsHtml);
    
    // 添加图片
    const img = document.createElement('img');
    img.src = imageUrl;
    img.className = 'style-preview-img';
    img.onerror = function() { handlePreviewImageError(this, styleCode); };
    previewContainer.appendChild(img);
    
    // 恢复加载遮罩
    if (loading) previewContainer.appendChild(loading);
    
    // 恢复徽章
    badges.forEach(badge => previewContainer.appendChild(badge));
    
    // 更新元数据图标
    const cardBody = previewContainer.closest('.style-card').querySelector('.style-card-body');
    const metaIcon = cardBody.querySelector('.style-card-meta i');
    if (metaIcon) {
        metaIcon.className = 'mdi mdi-image text-success';
        metaIcon.title = '<?= __('有预览图') ?>';
    }
}

/**
 * 批量生成所有模板的预览图
 */
async function generateAllPreviews(force = false) {
    const confirmMsg = force 
        ? '<?= __('确定要强制刷新所有模板的预览图吗？这可能需要较长时间。') ?>'
        : '<?= __('确定要为缺少预览图的模板生成预览吗？') ?>';
    
    const confirmed = await BackendConfirm.show(confirmMsg);
    if (!confirmed) return;
    
    console.log('🚀 开始批量生成预览图, force:', force);
    
    try {
        // 获取需要生成预览的模板列表
        var opts = { method: 'POST', body: JSON.stringify({ force: force ? '1' : '0' }), headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
        var res = await window.Weline.Api.request(API_URLS.generateAllPreviews, opts);
        var result = (res && res.data) || res;
        
        if (!result.success) {
            throw new Error(result.message || '获取模板列表失败');
        }
        
        const templates = result.data.filter(t => t.needs_generate);
        
        if (templates.length === 0) {
            BackendToast.info('<?= __('所有模板都已有预览图，无需生成。') ?>');
            return;
        }
        
        // 获取进度模态框组件
        const progressModal = window.WelineModal['previewProgressModal'];
        progressModal.showProgress({
            title: '<?= __('正在生成预览图...') ?>',
            subtitle: '-',
            progress: 0,
            count: '0 / ' + templates.length
        });
        
        let completed = 0;
        let failed = 0;
        
        // 逐个生成预览图
        for (const template of templates) {
            try {
                progressModal.updateProgress({
                    subtitle: template.name,
                    progress: (completed / templates.length) * 100,
                    count: completed + ' / ' + templates.length
                });
                await refreshSinglePreview(template.code);
                completed++;
            } catch (error) {
                console.error(`生成 ${template.code} 预览失败:`, error);
                failed++;
            }
            
            // 间隔一下，避免太快
            await new Promise(resolve => setTimeout(resolve, 500));
        }
        
        // 完成后隐藏进度提示
        progressModal.hide();
        
        BackendToast.success('<?= __('批量生成完成！成功：') ?>' + completed + '<?= __('，失败：') ?>' + failed);
        
        // 刷新页面显示新预览图
        if (completed > 0) {
            location.reload();
        }
        
    } catch (error) {
        console.error('批量生成失败:', error);
        BackendToast.error('<?= __('批量生成失败：') ?>' + error.message);
    }
}
</script>

