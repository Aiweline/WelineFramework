                                // 检查是否是完整路径还是相对路径
                                if (strpos($previewImage, 'pagebuilder/previews/') === 0) {
                                    $previewImageUrl = '/static/' . $previewImage . '?t=' . time();
                                } else {
                                    $previewImageUrl = '/static/pagebuilder/previews/' . preg_replace('/[^a-zA-Z0-9_-]/', '_', $styleCode) . '.png?t=' . time();
                                }
                                // 检查文件是否真实存在
                                $checkPath = BP . 'pub/static/' . ltrim($previewImage, '/');
                                if (!file_exists($checkPath)) {
                                    $previewImageUrl = ''; // 文件不存在，清空URL
                                }
                            }
                            
                            // 状态指示
                            $statusClass = 'status-default';
                            $statusTitle = '';
                            if (!$isActive) {
                                $statusClass = 'status-disabled';
                                $statusTitle = __('已禁用');
                            } elseif ($isPublished) {
                                $statusClass = 'status-published';
                                $statusTitle = __('已发布');
                            } else {
                                $statusClass = 'status-unpublished';
                                $statusTitle = __('未发布');
