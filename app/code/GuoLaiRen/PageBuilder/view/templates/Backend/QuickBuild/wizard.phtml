<script src="<?= $purchaseDialogJsUrl ?>"></script>
<script>
(function() {
    'use strict';

    var purchaseDialogPrimaryScriptUrl = '<?= $purchaseDialogJsUrl ?>';
    var purchaseDialogLoadingPromise = null;

    var checkUrl = '<backend-url>pagebuilder/backend/domain-management/check-availability</backend-url>';
    var purchaseUrl = '<backend-url>pagebuilder/backend/domain-management/purchase</backend-url>';
    var domainListUrl = '<backend-url>pagebuilder/backend/domain-management/get-domains</backend-url>';
    var domainPoolUrl = '<backend-url>pagebuilder/backend/domain-management/get-domain-pool</backend-url>';
    var provisionUrl = '<backend-url>pagebuilder/backend/quick-build/start-provisioning</backend-url>';

    function postForm(url, data) {
        var fd = new FormData();
        Object.keys(data).forEach(function(k) {
            fd.append(k, typeof data[k] === 'object' ? JSON.stringify(data[k]) : data[k]);
        });
        return window.Weline.Api.request(url, { method: 'POST', body: fd }).then(function(r) { return r.ok ? r.data : (r.data || {}); });
    }
    
    // 配置进度步骤定义
    var provisionSteps = [
        {key: 'purchase', label: '<?= __('域名') ?>', icon: 'mdi-cart'},
        {key: 'dns', label: '<?= __('DNS') ?>', icon: 'mdi-dns'},
        {key: 'cdn', label: '<?= __('CDN') ?>', icon: 'mdi-shield-check'},
        {key: 'resolve', label: '<?= __('解析') ?>', icon: 'mdi-earth'},
        {key: 'verify', label: '<?= __('验证') ?>', icon: 'mdi-check-network'},
        {key: 'ssl', label: '<?= __('SSL') ?>', icon: 'mdi-lock'}
    ];

    var currentStep = 1;
    var currentMode = 'new';
    var selectedDomain = '';
    var selectedAccountId = 0;
    var domainPurchased = false;
    var domainOwned = false;

    function goToStep(step) {
        currentStep = step;
        for (var i = 1; i <= 4; i++) {
            var panel = document.getElementById('pb-qb-step' + i);
            var stepEl = document.querySelector('.pb-qb-step[data-step="' + i + '"]');
            if (panel) panel.classList.toggle('active', i === step);
            if (stepEl) {
                stepEl.classList.toggle('active', i === step);
                stepEl.classList.toggle('completed', i < step);
            }
        }
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text || ''));
        return div.innerHTML;
    }

    function ensurePurchaseDialogLoaded() {
        if (window.WelineDomainPurchaseDialog) {
            return Promise.resolve(true);
        }
        if (purchaseDialogLoadingPromise) {
            return purchaseDialogLoadingPromise;
        }

        function getPurchaseDialogScriptCandidates() {
            var isDev = <?= (defined('DEV') && DEV) ? 'true' : 'false' ?>;
            var devUrl = '/Weline/Websites/view/statics/backend/domain-purchase-dialog.js';
            var prodUrl = '/static/Weline/Websites/backend/domain-purchase-dialog.js';
            var candidates = [purchaseDialogPrimaryScriptUrl];
            candidates.push(isDev ? devUrl : prodUrl);
            try {
                if (window.Weline && window.Weline.staticResourceResolver) {
                    candidates.push(window.Weline.staticResourceResolver.resolve('Weline_Websites::backend/domain-purchase-dialog.js'));
                }
            } catch (e) {}
            return candidates.filter(function(url, index, arr) {
                return !!url && arr.indexOf(url) === index;
            });
        }

        function loadScript(url) {
            var urlPath = (url.split('?')[0] || '').replace(/^https?:\/\/[^/]+/, '') || url;
            var scripts = document.querySelectorAll('script[src*="domain-purchase-dialog.js"]');
            for (var i = 0; i < scripts.length; i++) {
                var s = (scripts[i].src || '').split('?')[0];
                var existingPath = s.replace(/^https?:\/\/[^/]+/, '');
                if (existingPath && (existingPath === urlPath || existingPath.endsWith(urlPath) || urlPath.endsWith(existingPath))) {
                    return Promise.resolve(true);
                }
            }
            return new Promise(function(resolve, reject) {
                var script = document.createElement('script');
                script.src = url;
                script.async = true;
                script.dataset.domainPurchaseDialog = '1';
                var timer = setTimeout(function() {
                    reject(new Error('dialog-script-timeout:' + url));
                }, 10000);
                script.onload = function() {
                    clearTimeout(timer);
                    resolve(true);
                };
                script.onerror = function() {
                    clearTimeout(timer);
                    reject(new Error('dialog-script-load-failed:' + url));
                };
                document.head.appendChild(script);
            });
        }

        purchaseDialogLoadingPromise = new Promise(function(resolve, reject) {
            var candidates = getPurchaseDialogScriptCandidates();
            var index = 0;

            function tryNext(lastError) {
                if (window.WelineDomainPurchaseDialog) {
                    resolve(true);
                    return;
                }
                if (index >= candidates.length) {
                    reject(lastError || new Error('dialog-script-candidates-exhausted'));
                    return;
                }
                var url = candidates[index++];
                loadScript(url).then(function() {
                    if (window.WelineDomainPurchaseDialog) {
                        resolve(true);
                        return;
                    }
                    setTimeout(function() {
                        if (window.WelineDomainPurchaseDialog) {
                            resolve(true);
                            return;
                        }
                        tryNext(new Error('dialog-object-missing:' + url));
                    }, 0);
                }).catch(function(error) {
                    tryNext(error);
                });
            }

            tryNext();
        }).catch(function(error) {
            purchaseDialogLoadingPromise = null;
            throw error;
        });

        return purchaseDialogLoadingPromise;
    }

    function updateNextButtonState() {
        var btn = document.getElementById('pb-qb-next1');
        btn.disabled = !selectedDomain || !selectedAccountId;
    }

    // 建站描述折叠（默认收起）
    (function() {
        var desc = document.getElementById('pb-qb-desc');
        var toggle = document.getElementById('pb-qb-desc-toggle');
        var body = desc ? desc.querySelector('.pb-qb-desc-body') : null;
        if (!desc || !toggle || !body) return;
        function toggleDesc() {
            var expanded = desc.classList.toggle('expanded');
            toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            body.setAttribute('aria-hidden', expanded ? 'false' : 'true');
        }
        toggle.addEventListener('click', toggleDesc);
        toggle.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                toggleDesc();
            }
        });
    })();

    // 模式切换
    document.querySelectorAll('.pb-qb-mode-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            var mode = this.getAttribute('data-mode');
            currentMode = mode;
            document.querySelectorAll('.pb-qb-mode-tab').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.pb-qb-mode-panel').forEach(function(p) { p.classList.remove('active'); });
            this.classList.add('active');
            document.getElementById('pb-qb-mode-' + mode).classList.add('active');
            
            selectedDomain = '';
            selectedAccountId = 0;
            domainPurchased = false;
            domainOwned = false;
            updateNextButtonState();
        });
    });

    // 检查域名可用性
    document.getElementById('pb-qb-check-btn').addEventListener('click', function() {
        var acctId = document.getElementById('pb-qb-account').value;
        var domain = document.getElementById('pb-qb-domain').value.trim();
        if (!acctId) {
            AdminToast.warning('<?= __('请选择域名商账号') ?>');
            return;
        }
        if (!domain) {
            AdminToast.warning('<?= __('请输入域名') ?>');
            return;
        }
        this.disabled = true;
        this.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('检查中...') ?>';
        var btn = this;

        postForm(checkUrl, { account_id: acctId, domains: domain }).then(function(res) {
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>';
            var box = document.getElementById('pb-qb-check-result');
            
            if (!res.success) {
                box.innerHTML = '<div class="pb-qb-result-box" style="color:var(--backend-color-danger,#f46a6a);">' +
                    '<i class="mdi mdi-alert-circle"></i> ' + escapeHtml(res.msg || '<?= __('检查失败') ?>') + '</div>';
                return;
            }
            
            if (!res.data || !res.data.length) {
                box.innerHTML = '<div class="pb-qb-result-box"><?= __('无检测结果') ?></div>';
                return;
            }
            
            var item = res.data[0];
            if (item.available) {
                var priceText = item.price ? ' - ' + (item.currency || '¥') + item.price + '/<?= __('年') ?>' : '';
                box.innerHTML = '<div class="pb-qb-result-box">' +
                    '<span class="pb-qb-check-available"><i class="mdi mdi-check-circle"></i> ' + escapeHtml(item.domain) + ' <?= __('可注册') ?></span>' +
                    priceText +
                    ' <button class="pb-qb-btn pb-qb-btn-success" id="pb-qb-buy-btn" style="margin-left:12px;"><i class="mdi mdi-cart"></i> <?= __('购买') ?></button>' +
                    '</div>';
                selectedDomain = item.domain;
                selectedAccountId = acctId;
                domainOwned = false;
                document.getElementById('pb-qb-buy-btn').addEventListener('click', handleBuy);
                updateNextButtonState();
            } else {
                box.innerHTML = '<div class="pb-qb-result-box">' +
                    '<span class="pb-qb-check-unavailable"><i class="mdi mdi-close-circle"></i> ' + escapeHtml(item.domain) + ' <?= __('不可注册') ?></span>' +
                    (item.message ? '<div class="pb-qb-result-msg">' + escapeHtml(item.message) + '</div>' : '') +
                    '<div class="pb-qb-result-msg" style="margin-top:8px;">' +
                    '<i class="mdi mdi-information"></i> <?= __('如果您已拥有此域名，请切换到"使用已有域名"模式') ?>' +
                    '</div></div>';
                selectedDomain = '';
                updateNextButtonState();
            }
        }).catch(function(e) {
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>';
            AdminToast.error('<?= __('网络错误') ?>: ' + e.message);
        });
    });

    // 购买域名
    function handleBuy() {
        var btn = document.getElementById('pb-qb-buy-btn');
        if (!btn) return;

        ensurePurchaseDialogLoaded().then(function() {
            return window.WelineDomainPurchaseDialog.open({
                labels: {
                    title: '<?= __('购买域名') ?>',
                    description: '<?= __('确认购买后，系统会按所选策略处理 DNS、CDN、解析与后续状态跟踪。') ?>',
                    dnsChoice: '<?= __('DNS 策略') ?>',
                    dnsFollowRegistrar: '<?= __('跟随域名商') ?>',
                    dnsCustomNameservers: '<?= __('自定义 Nameserver') ?>',
                    dnsNameservers: '<?= __('Nameserver 列表') ?>',
                    dnsNameserversPlaceholder: '<?= __('ns1.example.com, ns2.example.com') ?>',
                    cdnChoice: '<?= __('CDN 策略') ?>',
                    cdnFollowRegistrar: '<?= __('跟随域名商') ?>',
                    cdnNone: '<?= __('暂不配置 CDN') ?>',
                    resolveToLocal: '<?= __('自动解析到本服务器') ?>',
                    resolveHint: '<?= __('默认会解析 @ 和 www，并持续检查域名状态。') ?>',
                    subdomains: '<?= __('自动解析子域名') ?>',
                    subdomainsPlaceholder: '<?= __('@, www') ?>',
                    startLifecycle: '<?= __('启动全流程状态跟踪') ?>',
                    startLifecycleHint: '<?= __('购买后自动跟踪购买、DNS、验证、HTTPS 等步骤。') ?>',
                    confirm: '<?= __('确认购买') ?>',
                    cancel: '<?= __('取消') ?>'
                },
                defaults: {
                    dnsChoice: 'follow_registrar',
                    cdnChoice: 'follow_registrar',
                    resolveToLocal: !!(document.getElementById('pb-qb-auto-resolve') && document.getElementById('pb-qb-auto-resolve').checked),
                    subdomains: '@,www',
                    startLifecycle: true
                }
            });
        }).then(function(dialogResult) {
            if (!dialogResult) {
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('购买中...') ?>';

            var autoResolve = dialogResult.resolve_to_local === 'yes' ? '1' : '0';
            postForm(purchaseUrl, {
                account_id: selectedAccountId,
                domain: selectedDomain,
                years: '1',
                auto_resolve: autoResolve,
                resolve_to_local: dialogResult.resolve_to_local || 'yes',
                subdomains: dialogResult.subdomains || '@,www',
                dns_choice: dialogResult.dns_choice || 'follow_registrar',
                dns_nameservers: dialogResult.dns_nameservers || '',
                cdn_choice: dialogResult.cdn_choice || 'follow_registrar',
                start_lifecycle: dialogResult.start_lifecycle || '1'
            }).then(function(res) {
                if (res.success) {
                    var msg = res.msg || res.message || '<?= __('购买请求已提交') ?>';
                    if (dialogResult.start_lifecycle === '1') {
                        msg += ' <?= __('请前往域名状态页搜索当前根域名查看进度。') ?>';
                    }
                    AdminToast.success(msg);
                    btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已购买') ?>';
                    btn.classList.remove('pb-qb-btn-success');
                    btn.classList.add('pb-qb-btn-secondary');
                    domainPurchased = true;
                    updateNextButtonState();
                } else {
                    AdminToast.error(
                        window.WelineDomainPurchaseDialog
                            ? window.WelineDomainPurchaseDialog.buildErrorMessage(res, '<?= __('购买失败') ?>')
                            : (res.msg || res.message || '<?= __('购买失败') ?>')
                    );
                    btn.disabled = false;
                    btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
                }
            }).catch(function(e) {
                AdminToast.error('<?= __('网络错误') ?>: ' + e.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
            });
        }).catch(function(error) {
            var detail = error && error.message ? (' ' + error.message) : '';
            AdminToast.error('<?= __('购买弹窗加载失败，请刷新页面后重试。若仍失败，请检查静态资源发布与网络连接。') ?>' + detail);
        });
    }

    // 加载已有域名列表（仅可建站域名池）
    document.getElementById('pb-qb-load-domains-btn').addEventListener('click', function() {
        var acctId = document.getElementById('pb-qb-account-existing').value;
        if (!acctId) {
            AdminToast.warning('<?= __('请选择域名商账号') ?>');
            return;
        }
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?>';

        postForm(domainPoolUrl, { site_ready_only: 'true', page: 1, limit: 500 })
            .then(function(res) {
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-refresh"></i> <?= __('加载可建站域名') ?>';
                var container = document.getElementById('pb-qb-domain-list-container');
                
                if (!res.success) {
                    container.innerHTML = '<div class="pb-qb-result-box">' +
                        '<i class="mdi mdi-alert-circle"></i> ' + escapeHtml(res.msg || '<?= __('加载失败') ?>') + '</div>';
                    return;
                }
                
                var domains = Array.isArray(res.data) ? res.data : [];
                
                if (domains.length === 0) {
                    container.innerHTML = '<div class="pb-qb-result-box">' +
                        '<i class="mdi mdi-information"></i> <?= __('暂无可建站域名，请先完成域名解析与HTTPS配置') ?></div>';
                    return;
                }
                
                // 渲染搜索框和域名列表
                var html = '<div class="pb-qb-domain-search-wrap" style="position:relative;">' +
                    '<i class="mdi mdi-magnify pb-qb-domain-search-icon"></i>' +
                    '<input type="text" class="pb-qb-domain-search" id="pb-qb-domain-filter" placeholder="<?= __('输入关键词筛选域名...') ?>">' +
                    '</div>' +
                    '<div class="pb-qb-domain-count" id="pb-qb-domain-count"><?= __('共') ?> ' + domains.length + ' <?= __('个域名') ?></div>' +
                    '<div class="pb-qb-domain-list" id="pb-qb-domain-list-inner">';
                
                domains.forEach(function(d, idx) {
                    var domainName = d.domain || d.full_domain || '';
                    var resolveStatus = String(d.resolve_status || '').toLowerCase();
                    var httpsStatus = String(d.https_status || '').toLowerCase();
                    var siteReady = String(d.site_ready || '0') === '1';
                    var statusParts = [];

                    if (resolveStatus === 'resolved') {
                        if (String(d.is_local_server || '0') === '1') {
                            statusParts.push('<span style="background:var(--backend-color-success,#34c38f);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('解析正常') ?></span>');
                        } else {
                            statusParts.push('<span style="background:var(--backend-color-warning,#f1b44c);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('指向外部') ?></span>');
                        }
                    } else {
                        statusParts.push('<span style="background:var(--backend-color-warning,#f1b44c);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('等待解析') ?></span>');
                    }

                    if (httpsStatus === 'valid') {
                        statusParts.push('<span style="background:var(--backend-color-success,#34c38f);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;">HTTPS</span>');
                    } else if (httpsStatus === 'pending') {
                        statusParts.push('<span style="background:var(--backend-color-warning,#f1b44c);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('HTTPS申请中') ?></span>');
                    } else {
                        statusParts.push('<span style="background:var(--backend-color-danger,#f46a6a);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('无HTTPS') ?></span>');
                    }

                    if (siteReady) {
                        statusParts.push('<span style="background:var(--backend-color-info,#50a5f1);color:var(--backend-color-text-inverse,#fff);padding:2px 6px;border-radius:3px;font-size:0.72rem;"><?= __('可建站') ?></span>');
                    }

                    html += '<div class="pb-qb-domain-item" data-domain="' + escapeHtml(domainName) + '" data-search="' + escapeHtml(domainName.toLowerCase()) + '">' +
                        '<input type="radio" name="pb-qb-existing-domain" id="pb-qb-ed-' + idx + '">' +
                        '<label for="pb-qb-ed-' + idx + '" style="cursor:pointer;flex:1;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">' +
                        '<strong>' + escapeHtml(domainName) + '</strong>' + statusParts.join('') + '</label>' +
                        '</div>';
                });
                html += '</div>';
                container.innerHTML = html;

                // 绑定域名选择事件
                function bindDomainClickEvents() {
                    container.querySelectorAll('.pb-qb-domain-item').forEach(function(item) {
                        item.addEventListener('click', function() {
                            container.querySelectorAll('.pb-qb-domain-item').forEach(function(i) { i.classList.remove('selected'); });
                            this.classList.add('selected');
                            this.querySelector('input[type="radio"]').checked = true;
                            selectedDomain = this.getAttribute('data-domain');
                            selectedAccountId = acctId;
                            domainOwned = true;
                            domainPurchased = false;
                            updateNextButtonState();
                        });
                    });
                }
                bindDomainClickEvents();
                
                // 实时筛选功能
                var filterInput = document.getElementById('pb-qb-domain-filter');
                var domainCountEl = document.getElementById('pb-qb-domain-count');
                var totalCount = domains.length;
                
                filterInput.addEventListener('input', function() {
                    var keyword = this.value.trim().toLowerCase();
                    var items = container.querySelectorAll('.pb-qb-domain-item');
                    var visibleCount = 0;
                    
                    items.forEach(function(item) {
                        var searchText = item.getAttribute('data-search') || '';
                        if (keyword === '' || searchText.indexOf(keyword) !== -1) {
                            item.style.display = '';
                            visibleCount++;
                        } else {
                            item.style.display = 'none';
                        }
                    });
                    
                    // 更新计数显示
                    if (keyword === '') {
                        domainCountEl.textContent = '<?= __('共') ?> ' + totalCount + ' <?= __('个域名') ?>';
                    } else {
                        domainCountEl.textContent = '<?= __('筛选结果') ?>: ' + visibleCount + ' / ' + totalCount;
                    }
                });
                
                // 自动聚焦搜索框
                filterInput.focus();
            })
            .catch(function(e) {
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-refresh"></i> <?= __('加载可建站域名') ?>';
                AdminToast.error('<?= __('网络错误') ?>: ' + e.message);
            });
    });

    // 步骤导航
    document.getElementById('pb-qb-next1').addEventListener('click', function() {
        if (!selectedDomain) {
            AdminToast.warning('<?= __('请先选择或购买域名') ?>');
            return;
        }
        goToStep(2);
    });

    document.getElementById('pb-qb-prev2').addEventListener('click', function() { goToStep(1); });
    document.getElementById('pb-qb-next2').addEventListener('click', function() {
        var applySsl = document.getElementById('pb-qb-apply-ssl').checked;
        var autoResolve = document.getElementById('pb-qb-auto-resolve').checked;
        var cdnVendor = document.getElementById('pb-qb-cdn-vendor').value;
        var cdnAccountId = document.getElementById('pb-qb-cdn-account').value;
        var cdnVendorText = document.getElementById('pb-qb-cdn-vendor').selectedOptions[0]?.text || '<?= __('跟随域名商') ?>';
        var cdnAccountText = document.getElementById('pb-qb-cdn-account').selectedOptions[0]?.text || '<?= __('默认账户') ?>';
        
        var html = '<div class="pb-qb-summary-item"><strong><?= __('域名') ?>:</strong><span>' + escapeHtml(selectedDomain) + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('域名商账号ID') ?>:</strong><span>#' + selectedAccountId + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('域名状态') ?>:</strong><span>' + (domainPurchased ? '<?= __('新购买') ?>' : (domainOwned ? '<?= __('已有域名') ?>' : '<?= __('待购买') ?>')) + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('CDN 服务商') ?>:</strong><span>' + escapeHtml(cdnVendorText) + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('CDN 账户') ?>:</strong><span>' + escapeHtml(cdnAccountText) + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('SSL证书') ?>:</strong><span>' + (applySsl ? '<?= __('自动申请') ?>' : '<?= __('不申请') ?>') + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('自动解析') ?>:</strong><span>' + (autoResolve ? '<?= __('是') ?>' : '<?= __('否') ?>') + '</span></div>' +
            '<div class="pb-qb-summary-item" style="margin-top:16px;padding-top:12px;border-top:1px dashed var(--backend-color-border-light,#e9ecef);">' +
            '<strong><?= __('执行流程') ?>:</strong><span style="display:block;margin-top:4px;color:var(--backend-color-text-secondary,#6c757d);">' +
            '<?= __('DNS配置 → CDN加速 → IP解析 → SSL证书') ?></span></div>';
        document.getElementById('pb-qb-summary').innerHTML = html;
        goToStep(3);
    });
    
    // CDN 服务商变化时，过滤账户列表
    document.getElementById('pb-qb-cdn-vendor').addEventListener('change', function() {
        var vendor = this.value;
        var accountSelect = document.getElementById('pb-qb-cdn-account');
        var options = accountSelect.querySelectorAll('option');
        
        options.forEach(function(opt) {
            if (opt.value === '0') {
                return;
            }
            var optAdapter = opt.getAttribute('data-adapter') || '';
            if (vendor === '' || optAdapter === vendor) {
                opt.style.display = '';
            } else {
                opt.style.display = 'none';
            }
        });
        
        // 如果当前选中的账户被隐藏了，重置为默认
        var currentOpt = accountSelect.selectedOptions[0];
        if (currentOpt && currentOpt.style.display === 'none') {
            accountSelect.value = '0';
        }
    });

    document.getElementById('pb-qb-prev3').addEventListener('click', function() { goToStep(2); });
    
    // 返回按钮
    document.getElementById('pb-qb-prev4').addEventListener('click', function() { 
        goToStep(3); 
        // 重置进度组件
        var progress = window.WelineSseProgress && window.WelineSseProgress['pb-qb-provision-progress'];
        if (progress) {
            progress.reset();
        }
        document.getElementById('pb-qb-provision-result').style.display = 'none';
        document.getElementById('pb-qb-view-orders').style.display = 'none';
        document.getElementById('pb-qb-prev4').style.display = 'none';
    });

    // 启动一站式配置（使用 SSE 实时进度）
    document.getElementById('pb-qb-start-btn').addEventListener('click', function() {
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('启动中...') ?>';

        var cdnVendor = document.getElementById('pb-qb-cdn-vendor').value;
        var cdnAccountId = document.getElementById('pb-qb-cdn-account').value;
        var applySsl = document.getElementById('pb-qb-apply-ssl').checked ? '1' : '0';
        var skipPurchase = domainOwned ? '1' : '0';

        // 跳转到进度页面
        goToStep(4);
        
        // 构建 SSE URL
        var sseBaseUrl = '<backend-url>saas/backend/api/provisioning/stream</backend-url>';
        var params = new URLSearchParams({
            domain: selectedDomain,
            registrar_account_id: selectedAccountId,
            cdn_vendor: cdnVendor,
            cdn_account_id: cdnAccountId,
            apply_ssl: applySsl,
            skip_purchase: skipPurchase
        });
        var sseUrl = sseBaseUrl + '?' + params.toString();
        
        // 获取 SSE 进度组件
        var progress = window.WelineSseProgress && window.WelineSseProgress['pb-qb-provision-progress'];
        if (!progress) {
            BackendToast.error('<?= __('进度组件未加载') ?>');
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
            goToStep(3);
            return;
        }
        
        // 设置步骤并重置
        progress.setSteps(provisionSteps);
        progress.reset();
        progress.setUrl(sseUrl);
        
        // 监听完成事件
        progress.on('done', function(e) {
            try {
                var data = JSON.parse(e.data || '{}');
                showResult(true, data.message || '<?= __('配置完成！') ?>', data.order_id);
            } catch (err) {
                showResult(true, '<?= __('配置完成！') ?>');
            }
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
        });
        
        // 监听失败事件
        progress.on('failed', function(e) {
            try {
                var data = JSON.parse(e.data || '{}');
                showResult(false, data.message || '<?= __('配置失败') ?>');
            } catch (err) {
                showResult(false, '<?= __('配置失败') ?>');
            }
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
        });
        
        // 监听连接错误
        progress.on('error', function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
            document.getElementById('pb-qb-prev4').style.display = '';
        });
        
        // 启动 SSE 连接
        progress.start();
    });
    
    // 显示结果
    function showResult(success, message, orderId) {
        var resultContainer = document.getElementById('pb-qb-provision-result');
        var resultContent = document.getElementById('pb-qb-provision-result-content');
        
        var icon = success ? 'mdi-check-circle' : 'mdi-alert-circle';
        var color = success ? 'var(--backend-color-success, #34c38f)' : 'var(--backend-color-danger, #f46a6a)';
        
        var html = '<i class="mdi ' + icon + '" style="font-size:3rem;color:' + color + ';"></i>' +
            '<p style="font-size:1.1rem;font-weight:500;color:' + color + ';margin-top:12px;">' + escapeHtml(message) + '</p>';
        
        if (orderId) {
            html += '<p style="color:var(--backend-color-text-secondary,#6c757d);margin-top:8px;"><?= __('订单号') ?>: #' + orderId + '</p>';
        }
        
        resultContent.innerHTML = html;
        resultContainer.style.display = 'block';
        document.getElementById('pb-qb-view-orders').style.display = '';
        document.getElementById('pb-qb-prev4').style.display = success ? 'none' : '';
    }
})();
</script>
