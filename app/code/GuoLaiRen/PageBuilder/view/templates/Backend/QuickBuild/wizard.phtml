<script>
(function() {
    'use strict';

    var checkUrl = '<backend-api>pagebuilder/backend/quickBuild/checkDomain</backend-api>';
    var purchaseUrl = '<backend-api>pagebuilder/backend/quickBuild/purchaseDomain</backend-api>';
    var provisionUrl = '<backend-api>pagebuilder/backend/quickBuild/startProvisioning</backend-api>';

    var currentStep = 1;
    var selectedDomain = '';
    var selectedAccountId = 0;
    var domainPurchased = false;

    function goToStep(step) {
        currentStep = step;
        for (var i = 1; i <= 4; i++) {
            var panel = document.getElementById('pb-qb-step' + i);
            var stepEl = document.querySelector('.pb-qb-step[data-step="' + i + '"]');
            if (panel) panel.classList.toggle('active', i === step);
            if (stepEl) {
                stepEl.classList.toggle('active', i === step);
                stepEl.classList.toggle('completed', i < step);
            }
        }
    }

    document.getElementById('pb-qb-check-btn').addEventListener('click', function() {
        var acctId = document.getElementById('pb-qb-account').value;
        var domain = document.getElementById('pb-qb-domain').value.trim();
        if (!acctId || !domain) {
            AdminToast.warning('<?= __('请选择域名商账号并输入域名') ?>');
            return;
        }
        this.disabled = true;
        this.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('检查中...') ?>';
        var btn = this;

        var fd = new FormData();
        fd.append('account_id', acctId);
        fd.append('domains', domain);

        fetch(checkUrl, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>';
                var box = document.getElementById('pb-qb-check-result');
                if (!res.success || !res.data || !res.data.length) {
                    box.innerHTML = '<div class="pb-qb-result-box"><?= __('无结果') ?></div>';
                    return;
                }
                var item = res.data[0];
                if (item.available) {
                    box.innerHTML = '<div class="pb-qb-result-box"><span class="pb-qb-check-available"><i class="mdi mdi-check-circle"></i> ' +
                        item.domain + ' <?= __('可注册') ?></span>' +
                        (item.price ? ' - ¥' + item.price : '') +
                        ' <button class="pb-qb-btn pb-qb-btn-success" id="pb-qb-buy-btn"><i class="mdi mdi-cart"></i> <?= __('购买') ?></button></div>';
                    selectedDomain = item.domain;
                    selectedAccountId = acctId;
                    document.getElementById('pb-qb-buy-btn').addEventListener('click', handleBuy);
                    document.getElementById('pb-qb-next1').disabled = false;
                } else {
                    box.innerHTML = '<div class="pb-qb-result-box"><span class="pb-qb-check-unavailable"><i class="mdi mdi-close-circle"></i> ' +
                        item.domain + ' <?= __('已被注册') ?></span></div>';
                    document.getElementById('pb-qb-next1').disabled = true;
                }
            })
            .catch(function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>';
                AdminToast.error('<?= __('网络错误') ?>');
            });
    });

    function handleBuy() {
        var btn = document.getElementById('pb-qb-buy-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('购买中...') ?>';

        var fd = new FormData();
        fd.append('account_id', selectedAccountId);
        fd.append('domain', selectedDomain);
        fd.append('years', '1');

        fetch(purchaseUrl, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    AdminToast.success(res.msg || res.message || '<?= __('购买成功') ?>');
                    btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已购买') ?>';
                    domainPurchased = true;
                    document.getElementById('pb-qb-next1').disabled = false;
                } else {
                    AdminToast.error(res.msg || res.message || '<?= __('购买失败') ?>');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
                }
            })
            .catch(function() {
                AdminToast.error('<?= __('网络错误') ?>');
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
            });
    }

    document.getElementById('pb-qb-next1').addEventListener('click', function() {
        if (!selectedDomain) { AdminToast.warning('<?= __('请先选择域名') ?>'); return; }
        goToStep(2);
    });

    document.getElementById('pb-qb-prev2').addEventListener('click', function() { goToStep(1); });
    document.getElementById('pb-qb-next2').addEventListener('click', function() {
        var summary = '<p><strong><?= __('域名') ?>:</strong> ' + selectedDomain + '</p>' +
            '<p><strong><?= __('域名商账号') ?>:</strong> #' + selectedAccountId + '</p>' +
            '<p><strong><?= __('SSL 证书') ?>:</strong> ' + (document.getElementById('pb-qb-apply-ssl').checked ? '<?= __('自动申请') ?>' : '<?= __('不申请') ?>') + '</p>' +
            '<p><strong><?= __('流程') ?>:</strong> <?= __('购买域名 → DNS 切换 → CDN 配置 → IP 解析 → SSL 证书') ?></p>';
        document.getElementById('pb-qb-summary').innerHTML = summary;
        goToStep(3);
    });

    document.getElementById('pb-qb-prev3').addEventListener('click', function() { goToStep(2); });

    document.getElementById('pb-qb-start-btn').addEventListener('click', function() {
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('启动中...') ?>';

        var fd = new FormData();
        fd.append('domain', selectedDomain);
        fd.append('registrar_account_id', selectedAccountId);
        fd.append('apply_ssl', document.getElementById('pb-qb-apply-ssl').checked ? '1' : '0');

        fetch(provisionUrl, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    document.getElementById('pb-qb-final-result').innerHTML =
                        '<p style="color:var(--backend-color-success,#34c38f);font-size:1.1rem;">' +
                        '<i class="mdi mdi-check-circle"></i> ' + (res.msg || res.message || '<?= __('配置流程已启动') ?>') + '</p>' +
                        (res.order_id ? '<p><?= __('订单号') ?>: #' + res.order_id + '</p>' : '');
                    goToStep(4);
                } else {
                    AdminToast.error(res.msg || res.message || '<?= __('启动失败') ?>');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
                }
            })
            .catch(function() {
                AdminToast.error('<?= __('网络错误') ?>');
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
            });
    });
})();
</script>
