    function resolveCurrentRegistrarCode() {
        if (!selectedAccountId) return '';
        var id = String(selectedAccountId);
        var selectors = ['pb-qb-account', 'pb-qb-account-existing'];
        for (var i = 0; i < selectors.length; i++) {
            var sel = document.getElementById(selectors[i]);
            if (!sel) continue;
            var opts = sel.querySelectorAll('option');
            for (var j = 0; j < opts.length; j++) {
                var opt = opts[j];
                if (String(opt.value) === id) {
                    return (opt.getAttribute('data-code') || '').trim();
                }
            }
        }
        return '';
    }

    function updateFollowRegistrarLabels() {
        var registrarCode = resolveCurrentRegistrarCode();
        var text = registrarCode
            ? '<?= __('跟随域名商（默认：') ?>' + registrarCode + '）'
            : '<?= __('跟随域名商（默认）') ?>';
        ['pb-qb-dns-vendor', 'pb-qb-cdn-vendor'].forEach(function(selectId) {
            var select = document.getElementById(selectId);
            if (!select) return;
            var opt = select.querySelector('option[value="follow_registrar"]');
            if (opt) opt.textContent = text;
        });
    }

    function getFollowAccountLabel() {
        var registrarCode = resolveCurrentRegistrarCode();
        if (registrarCode && selectedAccountId) {
            return '<?= __('跟随域名商账号（') ?>' + registrarCode + ' #' + selectedAccountId + '）';
        }
        if (registrarCode) {
            return '<?= __('跟随域名商账号（') ?>' + registrarCode + '）';
        }
        return '<?= __('跟随域名商账号（默认）') ?>';
    }

    function ensureFollowRegistrarOption(accountSelect) {
        if (!accountSelect) return null;
        var followOpt = accountSelect.querySelector('option[data-follow-registrar="1"]');
        if (!followOpt) {
            followOpt = document.createElement('option');
            followOpt.setAttribute('data-follow-registrar', '1');
            followOpt.value = '__follow_registrar__';
            accountSelect.insertBefore(followOpt, accountSelect.firstChild || null);
        }
        followOpt.textContent = getFollowAccountLabel();
        followOpt.style.display = '';
        return followOpt;
    }

