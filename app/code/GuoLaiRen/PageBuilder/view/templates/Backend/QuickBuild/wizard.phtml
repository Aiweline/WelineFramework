                            : (res.msg || res.message || '<?= __('购买失败') ?>')
                    );
                    btn.disabled = false;
                    btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
                }
            }).catch(function(e) {
                BackendToast.error('<?= __('网络错误') ?>: ' + e.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-cart"></i> <?= __('购买') ?>';
