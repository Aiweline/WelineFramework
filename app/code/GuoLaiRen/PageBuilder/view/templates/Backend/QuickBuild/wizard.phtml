                    cdnFollowRegistrar: '<?= __('跟随域名商') ?>',
                    cdnNone: '<?= __('暂不配置 CDN') ?>',
                    resolveToLocal: '<?= __('自动解析到本服务器') ?>',
                    resolveHint: '<?= __('默认会解析 @ 和 www，并持续检查域名状态。') ?>',
                    subdomains: '<?= __('自动解析子域名') ?>',
                    subdomainsPlaceholder: '<?= __('@, www') ?>',
                    startLifecycle: '<?= __('启动全流程状态跟踪') ?>',
                    startLifecycleHint: '<?= __('购买后自动跟踪购买、DNS、验证、HTTPS 等步骤。') ?>',
                    confirm: '<?= __('确认购买') ?>',
                    cancel: '<?= __('取消') ?>'
                },
                defaults: {
                    dnsChoice: 'follow_registrar',
                    cdnChoice: 'follow_registrar',
