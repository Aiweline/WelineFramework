    function syncProviderAccountSelection(vendorSelectId, accountSelectId) {
        var vendorSelect = document.getElementById(vendorSelectId);
        var accountSelect = document.getElementById(accountSelectId);
        if (!vendorSelect || !accountSelect) return;

        var vendor = vendorSelect.value;
        var options = Array.prototype.slice.call(accountSelect.querySelectorAll('option'));
        var currentRegistrarCode = resolveCurrentRegistrarCode();
        var visibleOptions = [];
        var followOpt = ensureFollowRegistrarOption(accountSelect);

        options.forEach(function(opt) {
            if (opt.getAttribute('data-follow-registrar') === '1') {
                return;
            }
            var optAdapter = opt.getAttribute('data-adapter') || '';
            var visible;
            if (vendor === 'follow_registrar') {
                // 跟随域名商：仅展示当前域名商账户（若未识别到则兜底展示全部）
                visible = currentRegistrarCode ? (optAdapter === currentRegistrarCode) : true;
            } else {
                visible = (optAdapter === vendor);
            }
            opt.style.display = visible ? '' : 'none';
            if (visible) {
                visibleOptions.push(opt);
            }
        });

        if (followOpt) {
            followOpt.style.display = vendor === 'follow_registrar' ? '' : 'none';
        }

        var target = null;

        if (vendor === 'follow_registrar') {
            // 切回默认时，账户回到当前域名商账号（显式标注）
            target = followOpt;
            // 若有当前域名商的真实账户，则优先定位默认账户（供后续切供应商时保留合理顺序）
            var fallback = visibleOptions.find(function(opt) {
                return opt.getAttribute('data-is-default') === '1';
            }) || null;
            if (!fallback && currentRegistrarCode) {
                fallback = visibleOptions.find(function(opt) {
                    return (opt.getAttribute('data-adapter') || '') === currentRegistrarCode;
                }) || null;
            }
            if (!fallback && visibleOptions.length) {
                fallback = visibleOptions[0];
            }
            if (!target) {
                target = fallback;
            }
        } else {
            if (!visibleOptions.length) {
                return;
            }
            // 选择具体供应商时，优先该供应商默认账户
            target = visibleOptions.find(function(opt) { return opt.getAttribute('data-is-default') === '1'; }) || null;
            if (!target) {
                target = visibleOptions[0];
            }
        }

        if (target) {
            target.selected = true;
        }
    }

    document.getElementById('pb-qb-dns-vendor').addEventListener('change', function() {
        syncProviderAccountSelection('pb-qb-dns-vendor', 'pb-qb-dns-account');
    });

    document.getElementById('pb-qb-cdn-vendor').addEventListener('change', function() {
        syncProviderAccountSelection('pb-qb-cdn-vendor', 'pb-qb-cdn-account');
    });

    // 页面初始化：两组默认按“跟随域名商”选择默认供应商账户
    updateFollowRegistrarLabels();
    syncProviderAccountSelection('pb-qb-dns-vendor', 'pb-qb-dns-account');
    syncProviderAccountSelection('pb-qb-cdn-vendor', 'pb-qb-cdn-account');
    // 监听容器内变化，自动持久化当前向导状态
    var scopeContainer = document.getElementById('pb-qb-container');
    if (scopeContainer) {
        scopeContainer.addEventListener('input', schedulePersistWizardState, true);
        scopeContainer.addEventListener('change', schedulePersistWizardState, true);
        scopeContainer.addEventListener('click', schedulePersistWizardState, true);
    }
    window.addEventListener('beforeunload', function() {
        persistWizardState();
    });
    loadWizardState();

    document.getElementById('pb-qb-prev3').addEventListener('click', function() { goToStep(2); });
    document.getElementById('pb-qb-next3').addEventListener('click', function() { goToStep(4); });
    
    // 返回按钮
    document.getElementById('pb-qb-prev4').addEventListener('click', function() { 
        isProvisionRunning = false;
        goToStep(3); 
        // 重置进度组件
        var progress = window.WelineSseProgress && window.WelineSseProgress['pb-qb-provision-progress'];
        if (progress) {
            progress.reset();
        }
        document.getElementById('pb-qb-provision-result').style.display = 'none';
        document.getElementById('pb-qb-view-orders').style.display = 'none';
        var gotoBind = document.getElementById('pb-qb-goto-bind-template');
        if (gotoBind) gotoBind.style.display = 'none';
        var step4HintBack = document.getElementById('pb-qb-step4-running-hint');
        if (step4HintBack) step4HintBack.style.display = 'none';
    });
    document.getElementById('pb-qb-next4').addEventListener('click', function() {
        if (!isProvisionFinished) {
            BackendToast.warning('<?= __('请先完成SSE配置执行') ?>');
            return;
        }
        goToStep(5);
    });
    document.getElementById('pb-qb-prev5').addEventListener('click', function() {
        goToStep(4);
    });

    // 启动一站式配置（使用 SSE 实时进度）
    document.getElementById('pb-qb-start-btn').addEventListener('click', function() {
        var btn = this;
        if (isProvisionRunning) {
            BackendToast.info('<?= __('当前正在执行，请稍候') ?>');
            return;
        }
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('启动中...') ?>';
        var core = getEffectiveCoreState();
        selectedDomain = core.domain || selectedDomain;
        selectedAccountId = core.accountId || selectedAccountId;

        var dnsVendor = document.getElementById('pb-qb-dns-vendor').value;
        var dnsAccountIdRaw = document.getElementById('pb-qb-dns-account').value;
        var dnsAccountId = dnsAccountIdRaw === '__follow_registrar__' ? String(selectedAccountId || 0) : dnsAccountIdRaw;
        var cdnVendor = document.getElementById('pb-qb-cdn-vendor').value;
        var cdnAccountIdRaw = document.getElementById('pb-qb-cdn-account').value;
        var cdnAccountId = cdnAccountIdRaw === '__follow_registrar__' ? String(selectedAccountId || 0) : cdnAccountIdRaw;
        var applySsl = document.getElementById('pb-qb-apply-ssl').checked ? '1' : '0';
        var skipPurchase = domainOwned ? '1' : '0';

        // 跳转到进度页面
        goToStep(4);
        isProvisionRunning = true;
        isProvisionFinished = false;
        var next4Btn = document.getElementById('pb-qb-next4');
        if (next4Btn) next4Btn.disabled = true;
        var step4Hint = document.getElementById('pb-qb-step4-running-hint');
        if (step4Hint) step4Hint.style.display = '';
        
        // 使用框架生成的完整后台 URL，避免“当前路由路径拼接”导致 404
        var sseBaseUrl = '<?= addslashes($this->getBackendUrl('saas/backend/api/provisioning/stream')) ?>';
        var params = new URLSearchParams({
            domain: selectedDomain,
            registrar_account_id: selectedAccountId,
            dns_vendor: dnsVendor,
            dns_account_id: dnsAccountId,
            cdn_vendor: cdnVendor,
            cdn_account_id: cdnAccountId,
            apply_ssl: applySsl,
            skip_purchase: skipPurchase
        });
        var sseUrl = sseBaseUrl + '?' + params.toString();
        
        // 获取 SSE 进度组件
        var progress = window.WelineSseProgress && window.WelineSseProgress['pb-qb-provision-progress'];
        if (!progress) {
            BackendToast.error('<?= __('进度组件未加载') ?>');
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动一站式配置') ?>';
            goToStep(3);
            return;
        }
        
        // 设置步骤并重置
        progress.setSteps(provisionSteps);
        progress.reset();
        progress.setUrl(sseUrl);
        
        // 监听完成事件
        progress.on('done', function(e) {
            isProvisionRunning = false;
            isProvisionFinished = true;
            var step4HintDone = document.getElementById('pb-qb-step4-running-hint');
            if (step4HintDone) step4HintDone.style.display = 'none';
            var next4Done = document.getElementById('pb-qb-next4');
            if (next4Done) next4Done.disabled = false;
            try {
                var data = JSON.parse(e.data || '{}');
                var websiteId = (data.website_id != null && data.website_id !== '') ? (data.website_id | 0) : 0;
                showResult(true, data.message || '<?= __('配置完成！') ?>', data.order_id, websiteId);
            } catch (err) {
                showResult(true, '<?= __('配置完成！') ?>', undefined, 0);
            }
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('重新执行SSE配置') ?>';
        });
        
        // 监听失败事件
        progress.on('failed', function(e) {
            isProvisionRunning = false;
            isProvisionFinished = true;
            var step4HintFailed = document.getElementById('pb-qb-step4-running-hint');
            if (step4HintFailed) step4HintFailed.style.display = 'none';
            var next4Failed = document.getElementById('pb-qb-next4');
            if (next4Failed) next4Failed.disabled = false;
            try {
                var data = JSON.parse(e.data || '{}');
                showResult(false, data.message || '<?= __('配置失败') ?>');
            } catch (err) {
                showResult(false, '<?= __('配置失败') ?>');
            }
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('重新执行SSE配置') ?>';
        });
        
        // 监听连接错误
        progress.on('error', function() {
            isProvisionRunning = false;
            isProvisionFinished = false;
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-rocket-launch"></i> <?= __('启动SSE配置') ?>';
            var step4HintError = document.getElementById('pb-qb-step4-running-hint');
            if (step4HintError) step4HintError.style.display = 'none';
            var next4Error = document.getElementById('pb-qb-next4');
            if (next4Error) next4Error.disabled = true;
        });
        
        // 启动 SSE 连接
        progress.start();
    });
    
    // 显示结果
    function showResult(success, message, orderId, websiteId) {
        var resultContainer = document.getElementById('pb-qb-provision-result');
        var resultContent = document.getElementById('pb-qb-provision-result-content');
        
        var icon = success ? 'mdi-check-circle' : 'mdi-alert-circle';
        var color = success ? 'var(--backend-color-success, #34c38f)' : 'var(--backend-color-danger, #f46a6a)';
        
        var html = '<i class="mdi ' + icon + '" style="font-size:3rem;color:' + color + ';"></i>' +
            '<p style="font-size:1.1rem;font-weight:500;color:' + color + ';margin-top:12px;">' + escapeHtml(message) + '</p>';
        
        if (orderId) {
            html += '<p style="color:var(--backend-color-text-secondary,#6c757d);margin-top:8px;"><?= __('订单号') ?>: #' + orderId + '</p>';
        }
        
        resultContent.innerHTML = html;
        resultContainer.style.display = 'block';
        document.getElementById('pb-qb-view-orders').style.display = '';

        var gotoBind = document.getElementById('pb-qb-goto-bind-template');
        if (success && gotoBind) {
            var pageIndexUrl = '<?= addslashes($this->getBackendUrl('pagebuilder/backend/page/index')) ?>';
            gotoBind.href = pageIndexUrl + '?open_quick_site=1'
                + (websiteId ? '&website_id=' + websiteId : '')
                + (selectedDomain ? '&domain=' + encodeURIComponent(selectedDomain) : '');
            gotoBind.style.display = '';
        }
    }
})();
</script>
<w:scope url="@backend-url('taglib/backend/scope')" container-id="pb-qb-container" event="input change click"/>
