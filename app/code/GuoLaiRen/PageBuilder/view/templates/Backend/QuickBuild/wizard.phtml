<script src="<?= $purchaseDialogJsUrl ?>"></script>
<!-- 与当前页同源的配置进度 SSE 地址，避免 302（未带 cookie 被重定向到登录） -->
<meta name="pb-qb-backend-base" content="<?= htmlspecialchars(rtrim($this->getBackendUrl(''), '/'), ENT_QUOTES, 'UTF-8') ?>">
<script>
(function() {
    'use strict';

    var purchaseDialogLoadingPromise = null;

    var checkUrl = '<backend-url>pagebuilder/backend/domain-management/check-availability</backend-url>';
    var purchaseUrl = '<backend-url>pagebuilder/backend/domain-management/purchase</backend-url>';
    var domainListUrl = '<backend-url>pagebuilder/backend/domain-management/get-domains</backend-url>';
    var domainPoolUrl = '<backend-url>pagebuilder/backend/domain-management/get-domain-pool</backend-url>';
    var provisionUrl = '<backend-url>pagebuilder/backend/quick-build/start-provisioning</backend-url>';
    var userDataUrl = '<backend-url>taglib/backend/scope</backend-url>';
    var scopeKey = 'pagebuilder_quick_build_wizard';

    function postForm(url, data) {
        var fd = new FormData();
        Object.keys(data).forEach(function(k) {
            fd.append(k, typeof data[k] === 'object' ? JSON.stringify(data[k]) : data[k]);
        });
        return window.Weline.Api.request(url, { method: 'POST', body: fd }).then(function(r) { return r.ok ? r.data : (r.data || {}); });
    }

    function debounce(fn, wait) {
        var t = null;
        return function() {
            var args = arguments;
            var self = this;
            if (t) clearTimeout(t);
            t = setTimeout(function() {
                fn.apply(self, args);
            }, wait);
        };
    }
    
    // 配置进度步骤定义
    var provisionSteps = [
        {key: 'purchase', label: '<?= __('域名') ?>', icon: 'mdi-cart'},
        {key: 'dns', label: '<?= __('DNS') ?>', icon: 'mdi-dns'},
        {key: 'cdn', label: '<?= __('CDN') ?>', icon: 'mdi-shield-check'},
        {key: 'resolve', label: '<?= __('解析') ?>', icon: 'mdi-earth'},
        {key: 'verify', label: '<?= __('验证') ?>', icon: 'mdi-check-network'},
        {key: 'ssl', label: '<?= __('SSL') ?>', icon: 'mdi-lock'}
    ];

    var currentStep = 1;
    var currentMode = 'new';
    var selectedDomain = '';
    var selectedAccountId = 0;
    var domainPurchased = false;
    var domainOwned = false;
    var isProvisionRunning = false;
    var isProvisionFinished = false;
    var restoreStatePending = null;

    function setScopeState(name, value) {
        var el = document.querySelector('input[scope="pagebuilder_quick_build_wizard"][name="' + name + '"]');
        if (!el) return;
        el.value = value == null ? '' : String(value);
        el.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function collectWizardState() {
        return {
            step: currentStep,
            mode: currentMode,
            selected_domain: selectedDomain || '',
            selected_account_id: selectedAccountId || 0,
            registrar_account_id_new: document.getElementById('pb-qb-account') ? (document.getElementById('pb-qb-account').value || '') : '',
            registrar_account_id_existing: document.getElementById('pb-qb-account-existing') ? (document.getElementById('pb-qb-account-existing').value || '') : '',
            domain_input: document.getElementById('pb-qb-domain') ? (document.getElementById('pb-qb-domain').value || '') : '',
            dns_vendor: document.getElementById('pb-qb-dns-vendor') ? (document.getElementById('pb-qb-dns-vendor').value || 'follow_registrar') : 'follow_registrar',
            dns_account_id: document.getElementById('pb-qb-dns-account') ? (document.getElementById('pb-qb-dns-account').value || '') : '',
            cdn_vendor: document.getElementById('pb-qb-cdn-vendor') ? (document.getElementById('pb-qb-cdn-vendor').value || 'follow_registrar') : 'follow_registrar',
            cdn_account_id: document.getElementById('pb-qb-cdn-account') ? (document.getElementById('pb-qb-cdn-account').value || '') : '',
            apply_ssl: document.getElementById('pb-qb-apply-ssl') && document.getElementById('pb-qb-apply-ssl').checked ? '1' : '0',
            auto_resolve: document.getElementById('pb-qb-auto-resolve') && document.getElementById('pb-qb-auto-resolve').checked ? '1' : '0'
        };
    }

    function persistWizardState() {
        var fd = new FormData();
        fd.append('scope', scopeKey);
        fd.append('data', JSON.stringify(collectWizardState()));
        return window.Weline.Api.request(userDataUrl, { method: 'POST', body: fd });
    }

    var schedulePersistWizardState = debounce(function() {
        persistWizardState();
    }, 400);

    function applyWizardState(state) {
        if (!state || typeof state !== 'object') return;

        function setValueIfExists(id, value) {
            var el = document.getElementById(id);
            if (!el || value == null || value === '') return;
            if (el.tagName && el.tagName.toLowerCase() === 'select') {
                var exists = !!el.querySelector('option[value="' + String(value).replace(/"/g, '\\"') + '"]');
                if (!exists) return;
            }
            el.value = String(value);
            el.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // 先切模式，避免后续被 mode click 重置
        if (state.mode && state.mode !== currentMode) {
            var modeTab = document.querySelector('.pb-qb-mode-tab[data-mode="' + state.mode + '"]');
            if (modeTab) modeTab.click();
        }

        setValueIfExists('pb-qb-account', state.registrar_account_id_new);
        setValueIfExists('pb-qb-account-existing', state.registrar_account_id_existing);
        setValueIfExists('pb-qb-domain', state.domain_input);
        setValueIfExists('pb-qb-dns-vendor', state.dns_vendor);
        setValueIfExists('pb-qb-cdn-vendor', state.cdn_vendor);
        setValueIfExists('pb-qb-dns-account', state.dns_account_id);
        setValueIfExists('pb-qb-cdn-account', state.cdn_account_id);

        var applySsl = document.getElementById('pb-qb-apply-ssl');
        if (applySsl && state.apply_ssl != null) {
            applySsl.checked = String(state.apply_ssl) === '1';
            applySsl.dispatchEvent(new Event('change', { bubbles: true }));
        }
        var autoResolve = document.getElementById('pb-qb-auto-resolve');
        if (autoResolve && state.auto_resolve != null) {
            autoResolve.checked = String(state.auto_resolve) === '1';
            autoResolve.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // 再恢复运行态变量（这是 next2/next1/start 使用的关键）
        selectedDomain = state.selected_domain ? String(state.selected_domain) : '';
        selectedAccountId = state.selected_account_id ? (parseInt(state.selected_account_id, 10) || 0) : 0;
        if (!selectedAccountId) {
            var idFromSelect = currentMode === 'existing'
                ? (document.getElementById('pb-qb-account-existing') ? document.getElementById('pb-qb-account-existing').value : '')
                : (document.getElementById('pb-qb-account') ? document.getElementById('pb-qb-account').value : '');
            selectedAccountId = parseInt(idFromSelect || '0', 10) || 0;
        }
        if (!selectedDomain && currentMode === 'new') {
            var domainInputVal = document.getElementById('pb-qb-domain') ? document.getElementById('pb-qb-domain').value.trim() : '';
            if (domainInputVal) selectedDomain = domainInputVal;
        }

        // 已有域名模式：加载列表后自动回选上次域名
        if (currentMode === 'existing' && selectedAccountId > 0 && selectedDomain) {
            restoreStatePending = {
                domain: selectedDomain,
                accountId: String(selectedAccountId)
            };
            var existingAccountSelect = document.getElementById('pb-qb-account-existing');
            if (existingAccountSelect) {
                existingAccountSelect.value = String(selectedAccountId);
                existingAccountSelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
            var loadBtn = document.getElementById('pb-qb-load-domains-btn');
            if (loadBtn) {
                setTimeout(function() { loadBtn.click(); }, 50);
            }
        }
        updateFollowRegistrarLabels();
        syncProviderAccountSelection('pb-qb-dns-vendor', 'pb-qb-dns-account');
        syncProviderAccountSelection('pb-qb-cdn-vendor', 'pb-qb-cdn-account');
        updateNextButtonState();
        if (state.step) {
            var step = parseInt(state.step, 10);
            if (step >= 1 && step <= 4) {
                goToStep(step);
                if (step >= 3) {
                    renderStep3Summary();
                }
            }
        }
    }

    function loadWizardState() {
        return window.Weline.Api.request(userDataUrl + '?scope=' + encodeURIComponent(scopeKey), { method: 'GET' })
            .then(function(r) {
                var payload = r && r.data ? r.data : {};
                var state = payload.json || payload.data || {};
                if (typeof state === 'string') {
                    try { state = JSON.parse(state); } catch (e) { state = {}; }
                }
                applyWizardState(state);
            })
            .catch(function() {
                // ignore restore failure
            });
    }

    function goToStep(step) {
        currentStep = step;
        setScopeState('step', step);
        schedulePersistWizardState();
        for (var i = 1; i <= 5; i++) {
            var panel = document.getElementById('pb-qb-step' + i);
            var stepEl = document.querySelector('.pb-qb-step[data-step="' + i + '"]');
            if (panel) panel.classList.toggle('active', i === step);
            if (stepEl) {
                stepEl.classList.toggle('active', i === step);
                stepEl.classList.toggle('completed', i < step);
            }
        }
        // 仅在真正执行中显示“正在执行”提示，避免误导
        var runningHint = document.getElementById('pb-qb-step4-running-hint');
        if (runningHint) {
            runningHint.style.display = (step === 4 && isProvisionRunning) ? '' : 'none';
        }
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text || ''));
        return div.innerHTML;
    }

    function ensurePurchaseDialogLoaded() {
        if (window.WelineDomainPurchaseDialog) {
            return Promise.resolve(true);
        }
        if (purchaseDialogLoadingPromise) {
            return purchaseDialogLoadingPromise;
        }

        purchaseDialogLoadingPromise = new Promise(function(resolve, reject) {
            var waited = 0;
            var maxWait = 3000;
            var step = 50;
            function check() {
                if (window.WelineDomainPurchaseDialog) {
                    resolve(true);
                    return;
                }
                if (waited >= maxWait) {
                    purchaseDialogLoadingPromise = null;
                    reject(new Error('dialog-script-load-failed:<?= __('购买弹窗脚本未就绪，请刷新页面后重试') ?>'));
                    return;
                }
                waited += step;
                setTimeout(check, step);
            }
            check();
        });

        return purchaseDialogLoadingPromise;
    }

    function updateNextButtonState() {
        var btn = document.getElementById('pb-qb-next1');
        btn.disabled = !selectedDomain || !selectedAccountId;
    }

    function getEffectiveCoreState() {
        var stateDomainInput = document.getElementById('pb-qb-state-selected-domain');
        var stateAccountInput = document.getElementById('pb-qb-state-selected-account-id');
        var domainInput = document.getElementById('pb-qb-domain');
        var accountNew = document.getElementById('pb-qb-account');
        var accountExisting = document.getElementById('pb-qb-account-existing');

        var domain = selectedDomain || '';
        if (!domain && stateDomainInput && stateDomainInput.value) {
            domain = stateDomainInput.value;
        }
        if (!domain && domainInput && domainInput.value) {
            domain = domainInput.value.trim();
        }

        var accountId = selectedAccountId || 0;
        if (!accountId && stateAccountInput && stateAccountInput.value) {
            accountId = parseInt(stateAccountInput.value || '0', 10) || 0;
        }
        if (!accountId && accountNew && accountNew.value) {
            accountId = parseInt(accountNew.value || '0', 10) || 0;
        }
        if (!accountId && accountExisting && accountExisting.value) {
            accountId = parseInt(accountExisting.value || '0', 10) || 0;
        }

        return { domain: domain, accountId: accountId };
    }

    function renderStep3Summary() {
        var core = getEffectiveCoreState();
        var applySsl = document.getElementById('pb-qb-apply-ssl').checked;
        var autoResolve = document.getElementById('pb-qb-auto-resolve').checked;
        var dnsVendorText = document.getElementById('pb-qb-dns-vendor').selectedOptions[0]?.text || '<?= __('跟随域名商') ?>';
        var dnsAccountText = document.getElementById('pb-qb-dns-account').selectedOptions[0]?.text || '<?= __('默认账户') ?>';
        var cdnVendorText = document.getElementById('pb-qb-cdn-vendor').selectedOptions[0]?.text || '<?= __('跟随域名商') ?>';
        var cdnAccountText = document.getElementById('pb-qb-cdn-account').selectedOptions[0]?.text || '<?= __('默认账户') ?>';

        var html = '<div class="pb-qb-summary-item"><strong><?= __('域名') ?>:</strong><span>' + escapeHtml(core.domain || '<?= __('未选择') ?>') + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('域名商账号ID') ?>:</strong><span>' + (core.accountId ? ('#' + core.accountId) : '<?= __('未选择') ?>') + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('域名状态') ?>:</strong><span>' + (domainPurchased ? '<?= __('新购买') ?>' : (domainOwned ? '<?= __('已有域名') ?>' : '<?= __('待购买') ?>')) + '</span></div>' +
            '<div class="pb-qb-summary-item"><strong><?= __('DNS 服务商') ?>:</strong><span>' + escapeHtml(dnsVendorText) + '</span></div>' +
