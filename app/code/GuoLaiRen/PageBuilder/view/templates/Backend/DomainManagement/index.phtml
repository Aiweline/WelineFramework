    function onPbDmNsProviderChange() {
        var provider = document.getElementById('pb-dm-batch-ns-provider').value;
        var customWrap = document.getElementById('pb-dm-batch-ns-custom-wrap');
        var cloudflareTip = document.getElementById('pb-dm-batch-ns-cloudflare-tip');

