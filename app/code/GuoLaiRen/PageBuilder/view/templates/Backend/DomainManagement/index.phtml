    document.getElementById('pb-dm-pool-batch-check-btn').addEventListener('click', function() {
        var items = poolState.items || [];
        if (items.length === 0) {
            BackendToast.warning('<?= __('当前页无域名可检查') ?>');
            return;
        }
        var btn = this;
        btn.disabled = true;
        var origHtml = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('检查中') ?>';
        var total = items.length;
        var done = 0;
        var ok = 0;
        var err = 0;
        items.forEach(function(item) {
            var poolId = item.pool_id || 0;
            if (poolId <= 0) { done++; return; }
            postForm(API.checkResolve, { pool_id: poolId }).then(function(res) {
                done++;
                if (res.success && (res.data && res.data.resolved)) ok++; else err++;
                if (done >= total) {
                    btn.disabled = false;
                    btn.innerHTML = origHtml;
                    BackendToast.success('<?= __('批量检查完成') ?>：<?= __('解析正常') ?> ' + ok + '，<?= __('异常') ?> ' + err + ' / ' + total);
                    loadDomainPool(poolState.page);
                }
            }).catch(function() {
                done++;
                err++;
                if (done >= total) {
                    btn.disabled = false;
                    btn.innerHTML = origHtml;
                    BackendToast.success('<?= __('批量检查完成') ?>：<?= __('解析正常') ?> ' + ok + '，<?= __('异常') ?> ' + err + ' / ' + total);
