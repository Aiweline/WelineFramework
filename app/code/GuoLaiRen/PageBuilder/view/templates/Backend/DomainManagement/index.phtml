                                <button class="pb-dm-btn pb-dm-btn-success pb-dm-btn-sm" onclick="autoResolveDnsForCurrentDomain()">\
                                    <i class="mdi mdi-auto-fix"></i> <?= __('自动解析到本服务器') ?>\
                                </button>\
                                <button class="pb-dm-btn pb-dm-btn-primary pb-dm-btn-sm" onclick="showAddDnsRecordForm()">\
                                    <i class="mdi mdi-plus"></i> <?= __('添加记录') ?>\
