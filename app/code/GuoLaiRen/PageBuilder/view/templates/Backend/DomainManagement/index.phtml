    function doBatchChangeNs() {
        if (!pbDmBatchNsSelectedIds || pbDmBatchNsSelectedIds.length === 0) {
            BackendToast.warning('<?= __('请选择要切换DNS的域名') ?>');
            return;
        }

        var mode = document.querySelector('input[name="pb-dm-ns-mode"]:checked');
        mode = mode ? mode.value : 'account';
        var submitBtn = document.getElementById('pb-dm-batch-ns-submit');

        if (mode === 'account') {
            var accountId = document.getElementById('pb-dm-batch-ns-account').value;
            if (!accountId) {
                BackendToast.warning('<?= __('请选择目标账户') ?>');
                return;
            }

            BackendToast.info('<?= __('正在批量切换DNS服务器...') ?>');
            if (submitBtn) submitBtn.disabled = true;

            postForm(API.batchSwitchToAccount, {
                domain_ids: JSON.stringify(pbDmBatchNsSelectedIds),
                target_account_id: accountId
            }).then(function(res) {
                if (submitBtn) submitBtn.disabled = false;
                closeBatchNsModal();
                
                if (res.success) {
                    var successCount = res.data && res.data.success || 0;
                    var failedCount = res.data && res.data.failed || 0;
                    var errors = res.data && res.data.errors || [];
                    
                    if (failedCount === 0) {
                        BackendToast.success('<?= __('DNS 切换成功') ?>：' + successCount + ' <?= __('个域名') ?>');
                    } else if (successCount > 0) {
                        BackendToast.warning('<?= __('DNS 切换部分完成') ?>：<?= __('成功') ?> ' + successCount + ' <?= __('个') ?>，<?= __('失败') ?> ' + failedCount + ' <?= __('个') ?>');
                        showDnsSwitchErrors(errors);
                    } else {
                        BackendToast.error('<?= __('DNS 切换失败') ?>：' + failedCount + ' <?= __('个域名') ?>');
                        showDnsSwitchErrors(errors);
                    }
                } else {
                    BackendToast.error(res.msg || res.message || '<?= __('切换失败') ?>');
                }
            }).catch(function() {
                if (submitBtn) submitBtn.disabled = false;
                BackendToast.error('<?= __('网络错误，请检查网络连接后重试') ?>');
            });
            return;
        }

        var provider = document.getElementById('pb-dm-batch-ns-provider').value;
        var customNs = document.getElementById('pb-dm-batch-ns-custom').value.trim();

        if (!provider) {
            BackendToast.warning('<?= __('请选择DNS服务商') ?>');
            return;
        }

        if (provider === 'custom' && !customNs) {
            BackendToast.warning('<?= __('请输入自定义Nameserver') ?>');
            return;
        }

        if (provider === 'cloudflare') {
            BackendToast.warning('<?= __('Cloudflare 需要为每个域名分配独立的 Nameserver，请先在「供应商账户」中添加 Cloudflare 账户，然后使用「选择账户」模式切换。') ?>');
            return;
        }

        BackendToast.info('<?= __('正在批量切换DNS服务器...') ?>');
        if (submitBtn) submitBtn.disabled = true;

        var params = { domain_ids: JSON.stringify(pbDmBatchNsSelectedIds) };
        if (provider === 'custom') {
            params.nameservers = customNs;
        } else {
            params.target_provider = provider;
        }

        postForm(API.batchChangeNameservers, params).then(function(res) {
            if (submitBtn) submitBtn.disabled = false;
            closeBatchNsModal();
            
            if (res.success) {
                var successCount = res.data && res.data.success || 0;
                var failedCount = res.data && res.data.failed || 0;
                var errors = res.data && res.data.errors || [];
                
                if (failedCount === 0) {
                    BackendToast.success('<?= __('DNS 切换成功') ?>：' + successCount + ' <?= __('个域名') ?>');
                } else if (successCount > 0) {
                    BackendToast.warning('<?= __('DNS 切换部分完成') ?>：<?= __('成功') ?> ' + successCount + ' <?= __('个') ?>，<?= __('失败') ?> ' + failedCount + ' <?= __('个') ?>');
                    showDnsSwitchErrors(errors);
                } else {
                    BackendToast.error('<?= __('DNS 切换失败') ?>：' + failedCount + ' <?= __('个域名') ?>');
                    showDnsSwitchErrors(errors);
                }
            } else {
                BackendToast.error(res.msg || res.message || '<?= __('切换失败') ?>');
            }
        }).catch(function() {
            if (submitBtn) submitBtn.disabled = false;
            BackendToast.error('<?= __('网络错误，请检查网络连接后重试') ?>');
        });
    }

