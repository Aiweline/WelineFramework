    var httpsRequestPending = { poolId: 0, domain: '', btnEl: null };
    var httpsRequestPort = 80;

    function openHttpsRequestModal(poolId, domain, btnEl) {
        var modal = document.getElementById('pb-dm-https-request-modal');
        var domainInput = document.getElementById('pb-dm-https-domain');
        var providerSelect = document.getElementById('pb-dm-https-provider');
        var challengeSelect = document.getElementById('pb-dm-https-challenge');
        var alertEl = document.getElementById('pb-dm-https-port-alert');
        var alertText = document.getElementById('pb-dm-https-port-alert-text');
        if (!modal || !domainInput || !providerSelect) return;
        httpsRequestPending = { poolId: poolId, domain: domain, btnEl: btnEl };
        domainInput.value = domain || '';
        providerSelect.value = 'letsencrypt';
        if (challengeSelect) challengeSelect.value = 'auto';
        if (alertText) alertText.textContent = '<?= __('加载中...') ?>';
        modal.classList.add('pb-dm-form-modal--open');
        fetch(API.getServerPort).then(function(r) { return r.json(); }).then(function(res) {
            var port = (res.port !== undefined) ? parseInt(res.port, 10) : 80;
            httpsRequestPort = port;
            if (alertEl && alertText) {
                if (port !== 80) {
                    alertEl.className = 'pb-dm-alert pb-dm-alert-warning';
                    alertText.textContent = '<?= __('当前服务运行在非80端口，只能通过 DNS 验证方式申请证书。请确保域名已关联 DNS 管理账户。') ?>';
                } else {
                    alertEl.className = 'pb-dm-alert pb-dm-alert-info';
                    alertText.textContent = '<?= __('将自动尝试文件验证（HTTP-01）。请确保域名已正确解析到本服务器。') ?>';
                }
            }
        }).catch(function() {
            httpsRequestPort = 80;
            if (alertText) alertText.textContent = '<?= __('请确保域名已正确解析到本服务器') ?>';
        });
    }

    function closeHttpsRequestModal() {
        var modal = document.getElementById('pb-dm-https-request-modal');
        if (modal) modal.classList.remove('pb-dm-form-modal--open');
        httpsRequestPending = { poolId: 0, domain: '', btnEl: null };
