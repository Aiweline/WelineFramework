        closeModal();
        pendingEditData = null;
        openModal(false);
    });

    /* 域名商类型变更 → 加载配置字段、默认值和帮助信息 */
    formRegistrar.addEventListener('change', function() {
        var code = formRegistrar.value;
        dynamicFieldsDiv.innerHTML = '';
        configHelpDiv.innerHTML = '';
        configHelpDiv.style.display = 'none';
        currentConfigFields = [];
        if (!code) return;

        postForm(API.getRegistrarInfo, { registrar_code: code }).then(function(res) {
            if (!res.success || !res.data) return;

            var info = res.data;
            var fields = info.config_fields || [];
            var help = info.config_help || {};

            // 保存配置字段定义
            currentConfigFields = fields;
            
            // 判断是否为编辑模式
            var isEditMode = parseInt(formId.value) > 0;

            /* 动态字段渲染 */
            var html = '';
            fields.forEach(function(field) {
                var fieldId = 'pb-dm-field-' + field.name;
                var mapping = field.mapping || field.name;
                var isRequired = field.required === true;
                var isPassword = field.type === 'password';
                
                html += '<div class="pb-dm-fg" style="margin-bottom:12px;">';
                html += '<label>' + (field.label || field.name);
                
                // 编辑模式下，密码字段标注为可选（不修改留空）
                if (isEditMode && isPassword) {
                    html += ' <span style="color:var(--backend-color-text-muted,#6c757d);font-size:0.85em;"><?= __('（不修改请留空）') ?></span>';
                } else if (isRequired) {
                    html += ' <span style="color:var(--backend-color-danger,#f46a6a);">*</span>';
                }
                html += '</label>';
                
                if (field.type === 'select' && field.options) {
                    html += '<select id="' + fieldId + '" class="pb-dm-config-input" data-field="' + field.name + '" data-mapping="' + mapping + '" data-required="' + isRequired + '">';
                    field.options.forEach(function(opt) {
                        var selected = (field.default && field.default === opt.value) ? ' selected' : '';
                        html += '<option value="' + (opt.value || '') + '"' + selected + '>' + (opt.label || opt.value || '') + '</option>';
                    });
                    html += '</select>';
                } else {
                    var inputType = field.type === 'password' ? 'password' : 'text';
                    var defaultVal = field.default || '';
                    
                    // 编辑模式下，密码字段显示占位符；api_key 类（如 APP ID）留空表示保持原值
                    var placeholder = field.placeholder || '';
                    if (isEditMode && isPassword) {
                        placeholder = '••••••••••••••••<?= __('（留空不修改）') ?>';
                    } else if (isEditMode && mapping === 'api_key') {
                        if (placeholder) placeholder += ' ';
                        placeholder += '<?= __('（编辑时留空则保持原值）') ?>';
                    }
                    var requiredInEdit = isRequired && !(isEditMode && (isPassword || mapping === 'api_key'));
                    html += '<input type="' + inputType + '" id="' + fieldId + '" class="pb-dm-config-input" data-field="' + field.name + '" data-mapping="' + mapping + '" data-required="' + (requiredInEdit ? 'true' : 'false') + '"';
                    if (placeholder) html += ' placeholder="' + placeholder + '"';
                    if (defaultVal && !isPassword) html += ' value="' + defaultVal + '"';
                    html += '>';
                }
                html += '</div>';
            });
            dynamicFieldsDiv.innerHTML = html;
            
            // 编辑模式下，回填已保存的值
            if (isEditMode && pendingEditData) {
                dynamicFieldsDiv.querySelectorAll('.pb-dm-config-input').forEach(function(el) {
                    var mapping = el.dataset.mapping || el.dataset.field;
                    var fieldName = el.dataset.field;
                    var isPassword = el.type === 'password';
                    var value = '';
                    
                    // 根据 mapping 获取值
                    if (mapping === 'region') {
                        value = pendingEditData.region || '';
                    } else if (mapping.indexOf('extra_config.') === 0) {
                        var extraKey = mapping.replace('extra_config.', '');
                        value = pendingEditData.extra_config[extraKey] || '';
                    } else if (pendingEditData.extra_config[fieldName]) {
                        value = pendingEditData.extra_config[fieldName];
                    }
                    
                    // 密码字段不回填（保持空白，表示不修改）
                    if (!isPassword && value) {
                        el.value = value;
                    }
                });
                pendingEditData = null;
            }

            /* 帮助信息渲染 */
            if (help.help_steps && help.help_steps.length) {
                var helpHtml = '<div class="pb-dm-help-title"><i class="mdi mdi-information-outline"></i>';
                if (help.help_url) {
                    helpHtml += '<a href="' + help.help_url + '" target="_blank">' + (help.help_title || '<?= __('配置获取指南') ?>') + ' <i class="mdi mdi-open-in-new" style="font-size:0.85em;"></i></a>';
                } else {
                    helpHtml += '<span>' + (help.help_title || '<?= __('配置获取指南') ?>') + '</span>';
                }
                helpHtml += '</div><ol class="pb-dm-help-steps">';
                help.help_steps.forEach(function(step) {
                    helpHtml += '<li>' + step + '</li>';
                });
                helpHtml += '</ol>';
                configHelpDiv.innerHTML = helpHtml;
                configHelpDiv.style.display = 'block';
            }
        });
    });

    /* 保存账户 */
    document.getElementById('pb-dm-modal-save').addEventListener('click', function() {
        var btn = this;
        var regCode = formRegistrar.value;
        var name = formName.value.trim();
        if (!regCode || !name) {
            BackendToast.warning('<?= __('请填写域名商类型和账户名称') ?>');
            return;
        }

        // 校验必填字段
        var isEditMode = parseInt(formId.value) > 0;
        var hasError = false;
        var missingFields = [];
        dynamicFieldsDiv.querySelectorAll('.pb-dm-config-input').forEach(function(el) {
            var isRequired = el.dataset.required === 'true';
            var value = el.value.trim();
            var fieldName = el.dataset.field;
            var isPassword = el.type === 'password';
            
            // 查找字段配置
            var fieldConfig = null;
            var label = fieldName;
            currentConfigFields.forEach(function(f) {
                if (f.name === fieldName) {
                    label = f.label || fieldName;
                    fieldConfig = f;
                }
            });
            
            // 编辑模式下，密码类字段允许为空（表示不修改）
            // 但其他必填字段（如 account_id）仍需校验
            var skipValidation = isEditMode && isPassword;
            
            if (isRequired && !value && !skipValidation) {
                hasError = true;
                missingFields.push(label);
                el.style.borderColor = 'var(--backend-color-danger, #f46a6a)';
            } else {
                el.style.borderColor = '';
            }
        });
        
        if (hasError) {
            BackendToast.error('<?= __('请填写必填字段') ?>: ' + missingFields.join(', '));
            return;
        }

        // 收集所有配置字段数据
        var configData = {};
        var extraConfig = {};
        dynamicFieldsDiv.querySelectorAll('.pb-dm-config-input').forEach(function(el) {
            var value = el.value.trim();
            var mapping = el.dataset.mapping || el.dataset.field;
            
            // 根据 mapping 决定存储位置
            if (mapping === 'api_key') {
                configData.api_key = value;
            } else if (mapping === 'api_secret') {
                configData.api_secret = value;
            } else if (mapping === 'region') {
                configData.region = value;
            } else if (mapping.startsWith('extra_config.')) {
                // extra_config.xxx 格式
                var extraKey = mapping.replace('extra_config.', '');
                if (value) extraConfig[extraKey] = value;
            } else {
                // 其他字段存入 extra_config
                if (value) extraConfig[el.dataset.field] = value;
            }
        });

        var data = {
            account_id: formId.value,
            registrar_code: regCode,
            account_name: name,
            api_key: configData.api_key || '',
            api_secret: configData.api_secret || '',
            region: configData.region || '',
            status: formStatus.value,
            extra_config: extraConfig
        };

        setBtnLoading(btn, true);
        postForm(API.saveAccount, data).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-check"></i> <?= __('保存') ?>');
            if (res.success) {
                BackendToast.success(res.message || '<?= __('保存成功') ?>');
                closeModal();
                location.reload();
            } else {
                BackendToast.error(res.message || res.msg || '<?= __('保存失败') ?>');
            }
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-check"></i> <?= __('保存') ?>');
            BackendToast.error('<?= __('网络错误') ?>');
        });
    });

    /* 编辑账户 */
    document.querySelectorAll('.pb-dm-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            closeModal();
            formId.value = btn.dataset.id;
            formRegistrar.value = btn.dataset.code;
            formName.value = btn.dataset.name;
            formStatus.value = btn.dataset.status || 'active';
            
            // 保存待填充的数据
            var extraConfigStr = btn.dataset.extraConfig || '{}';
            var extraConfig = {};
            try {
                extraConfig = JSON.parse(extraConfigStr);
            } catch (e) {}
            
            pendingEditData = {
                region: btn.dataset.region || '',
                extra_config: extraConfig
            };
            
            // 触发 change 事件以加载适配器配置字段
            formRegistrar.dispatchEvent(new Event('change'));
            openModal(true);
        });
    });

