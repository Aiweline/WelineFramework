    /* ========== 域名列表（本地分页） ========== */
    var domainContainer = document.getElementById('pb-dm-domains-result');
    var paginationEl = document.getElementById('pb-dm-pagination');
    var batchCountNum = document.getElementById('pb-dm-batch-count-num');
    var pagePrev = document.getElementById('pb-dm-page-prev');
    var pageNext = document.getElementById('pb-dm-page-next');
