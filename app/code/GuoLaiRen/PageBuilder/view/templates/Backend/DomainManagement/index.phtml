    /* ========== 工具函数 ========== */
    function postForm(url, data) {
        var fd = new FormData();
        Object.keys(data).forEach(function(k) {
            fd.append(k, typeof data[k] === 'object' ? JSON.stringify(data[k]) : data[k]);
        });
        var opts = { method: 'POST', body: fd };
        var req = window.Weline.Api.request(url, opts);
        return req.then(function(res) { return (res && res.data) !== undefined ? res.data : res; });
    }

    function ensurePurchaseDialogLoaded() {
        if (window.WelineDomainPurchaseDialog) {
            return Promise.resolve(true);
        }
        return Promise.reject(new Error('<?= __('购买弹窗脚本未就绪，请刷新页面后重试') ?>'));
    }

