    function doPoolRequestHttps(poolId, domain, provider, btnEl) {
        if (btnEl) {
            btnEl.disabled = true;
            btnEl.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
        }
        postForm(API.requestHttps, { pool_id: poolId, provider: provider || 'letsencrypt' }).then(function(res) {
            if (btnEl) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-certificate"></i> <?= __('申请HTTPS') ?>';
            }
            if (res.success) {
                BackendToast.success(res.msg || '<?= __('证书申请成功') ?>');
                loadDomainPool(poolState.page);
            } else {
                BackendToast.error(res.msg || '<?= __('证书申请失败') ?>');
            }
        }).catch(function() {
            if (btnEl) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-certificate"></i> <?= __('申请HTTPS') ?>';
            }
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function doPoolDelete(poolId, domain, btnEl) {
        BackendConfirm.show('<?= __('确定要从域名池删除 %{1} 吗？删除后需重新转存方可再次入池。') ?>'.replace('%{1}', domain || '')).then(function(confirmed) {
            if (!confirmed) return;
            if (btnEl) btnEl.disabled = true;
            postForm(API.deletePoolDomain, { pool_id: poolId }).then(function(res) {
                if (res.success) {
                    BackendToast.success(res.msg || '<?= __('删除成功') ?>');
                    loadDomainPool(poolState.page);
                } else {
                    BackendToast.error(res.msg || '<?= __('删除失败') ?>');
                    if (btnEl) btnEl.disabled = false;
                }
            }).catch(function() {
                BackendToast.error('<?= __('网络错误') ?>');
                if (btnEl) btnEl.disabled = false;
            });
        });
    }

    function doPoolCheckResolve(poolId, btnEl) {
        if (btnEl) {
            btnEl.disabled = true;
            btnEl.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('检查中') ?>';
        }
        postForm(API.checkResolve, { pool_id: poolId }).then(function(res) {
            if (btnEl) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-dns"></i> <?= __('检查状态') ?>';
            }
            if (res.success) {
                var msg = res.msg || res.message || (res.data && res.data.resolved ? '<?= __('解析正常') ?>' : '<?= __('解析异常') ?>');
                if (res.data && res.data.ipv4) msg += ' (IP: ' + res.data.ipv4 + ')';
                BackendToast.success(msg);
                loadDomainPool(poolState.page);
            } else {
                BackendToast.error(res.msg || res.message || '<?= __('检测失败') ?>');
            }
        }).catch(function() {
            if (btnEl) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-dns"></i> <?= __('检查状态') ?>';
            }
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function updatePoolPagination() {
        var info = document.getElementById('pb-dm-pool-pagination-info');
        var pageInfo = document.getElementById('pb-dm-pool-page-info');
        var prevBtn = document.getElementById('pb-dm-pool-prev');
        var nextBtn = document.getElementById('pb-dm-pool-next');

        var from = poolState.total > 0 ? ((poolState.page - 1) * poolState.limit + 1) : 0;
        var to = Math.min(poolState.page * poolState.limit, poolState.total);
        info.textContent = poolState.total > 0 ? '<?= __('显示') ?> ' + from + '-' + to + ' / <?= __('共') ?> ' + poolState.total + ' <?= __('条') ?>' : '';
        pageInfo.textContent = poolState.pages > 0 ? poolState.page + ' / ' + poolState.pages : '';

        prevBtn.disabled = poolState.page <= 1;
        nextBtn.disabled = poolState.page >= poolState.pages;
    }

    (function initHttpsRequestModal() {
        var modal = document.getElementById('pb-dm-https-request-modal');
        var closeBtn = document.getElementById('pb-dm-https-request-close');
        var cancelBtn = document.getElementById('pb-dm-https-request-cancel');
        var submitBtn = document.getElementById('pb-dm-https-request-submit');
        if (!modal) return;
        function closeIt() { closeHttpsRequestModal(); }
        if (closeBtn) closeBtn.addEventListener('click', closeIt);
        if (cancelBtn) cancelBtn.addEventListener('click', closeIt);
        modal.addEventListener('click', function(e) { if (e.target === modal) closeIt(); });
        if (submitBtn) {
            submitBtn.addEventListener('click', function() {
                var providerEl = document.getElementById('pb-dm-https-provider');
                var provider = (providerEl && providerEl.value) ? providerEl.value : 'letsencrypt';
                var p = httpsRequestPending;
                if (p.poolId <= 0) { closeIt(); return; }
                postForm(API.checkResolve, { pool_id: p.poolId }).then(function(res) {
                    var d = res.data || {};
                    var ok = res.success && d.resolved && d.is_local;
                    if (!ok) {
                        var msg = '<?= __('DNS 解析异常，不能进行申请。请等待解析正常后再试。') ?>\n\n<?= __('解析需指向本服务器公网 IP 方可申请证书。') ?>';
                        if (d.resolved && d.ipv4 && d.server_ipv4 && d.ipv4 !== d.server_ipv4) {
                            msg += '\n\n<?= __('域名解析到：%{1}') ?>'.replace('%{1}', d.ipv4);
                            msg += '\n<?= __('系统检测本机公网 IP：%{1}') ?>'.replace('%{1}', d.server_ipv4);
                            msg += '\n\n<?= __('如您已确认解析正确，可能是公网 IP 检测不准。可在 env.php 中设置 server.public_ip 为您的服务器公网 IP。') ?>';
                        }
                        BackendConfirm.show(msg, {
                            title: '<?= __('无法申请') ?>',
                            type: 'warning',
                            confirmText: '<?= __('我知道了') ?>',
                            cancelText: '<?= __('关闭') ?>'
                        }).then(function() {});
                        return;
                    }
                    closeIt();
                    var domainInput = document.getElementById('pb-dm-https-domain');
                    var domainVal = (domainInput && domainInput.value) ? String(domainInput.value).trim() : (p.domain || '');
                    openHttpsSseModalAndStart(p.poolId, domainVal || p.domain, provider, p.btnEl);
                });
            });
        }
    })();

    function openHttpsSseModalAndStart(poolId, domain, provider, btnEl) {
        var sseModal = document.getElementById('pb-dm-https-sse-modal');
        var challengeEl = document.getElementById('pb-dm-https-challenge');
        var strategyRaw = (challengeEl && challengeEl.value) ? challengeEl.value : 'auto';
        var challenge;
        if (strategyRaw === 'http01' || strategyRaw === 'dns01') {
            challenge = strategyRaw;
        } else {
            challenge = 'dns01';
        }
        var streamUrl = API.requestHttpsStream + '?pool_id=' + encodeURIComponent(poolId) + '&provider=' + encodeURIComponent(provider) + '&domain=' + encodeURIComponent(domain) + '&challenge_strategy=' + encodeURIComponent(challenge);
        var terminal = window.WelineSseTerminal && window.WelineSseTerminal['pb-dm-https-sse-terminal'];
        var doneBtn = document.getElementById('pb-dm-https-sse-done-btn');
        if (!sseModal) return;
        if (doneBtn) doneBtn.style.display = 'none';
        sseModal.classList.add('pb-dm-form-modal--open');
        if (terminal) {
            terminal.setUrl(streamUrl);
            terminal.clear && terminal.clear();
            terminal.on('done', function() {
                if (doneBtn) { doneBtn.style.display = ''; doneBtn.onclick = function() { closeHttpsSseModal(); loadDomainPool(poolState.page); }; }
                if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<i class="mdi mdi-certificate"></i> <?= __('申请HTTPS') ?>'; }
            });
            terminal.on('failed', function(e) {
                try {
                    var d = (e && e.data) ? JSON.parse(e.data) : {};
                    if (d.message && terminal.log) terminal.log(d.message, 'error');
                } catch (err) {}
                if (doneBtn) { doneBtn.style.display = ''; doneBtn.onclick = function() { closeHttpsSseModal(); loadDomainPool(poolState.page); }; }
                if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<i class="mdi mdi-certificate"></i> <?= __('申请HTTPS') ?>'; }
            });
            setTimeout(function() { terminal.start(streamUrl); }, 100);
        } else {
            BackendToast.warning('<?= __('SSE 组件未就绪，将使用普通模式') ?>');
            closeHttpsSseModal();
            doPoolRequestHttps(poolId, domain, provider, btnEl);
        }
    }

