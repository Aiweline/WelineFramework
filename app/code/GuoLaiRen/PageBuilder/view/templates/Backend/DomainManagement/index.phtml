                '<div class="pb-dm-accordion-actions">' +
                    '<button class="pb-dm-btn pb-dm-btn-success pb-dm-btn-sm pb-dm-pull-all-btn" data-account-id="' + group.account_id + '" title="<?= __('拉取全部未拉取域名') ?>">' +
                        '<i class="mdi mdi-download-multiple"></i>' +
