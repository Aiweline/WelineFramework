    function closeDnsManageModal() {
        var modal = document.getElementById('pb-dm-dns-manage-modal');
        if (modal) modal.remove();
    }

    function loadDnsRecords() {
        var container = document.getElementById('pb-dm-dns-records-container');
        if (!container) return;

        container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--backend-color-text-tertiary);"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></div>';

        var url = API.getDnsRecords + '?domain_id=' + currentDnsManageDomainId;
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function(res) {
                var res = (res && res.data) !== undefined ? res.data : res;
                if (res.success) {
                    var dnsData = res.data || {};
                    currentDnsManageProviderName = dnsData.dns_provider_name || dnsData.dns_provider || '-';
                    currentDnsManageServerIp = dnsData.server_ip || '-';
                    renderDnsManageHeader(currentDnsManageProviderName, currentDnsManageServerIp);
                    renderDnsRecords(res.data.records || []);
                } else {
                    container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--backend-color-danger);">' + (res.msg || '<?= __('获取失败') ?>') + '</div>';
                }
            })
            .catch(function() {
                container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--backend-color-danger);"><?= __('网络错误') ?></div>';
            });
    }

    function refreshDnsRecords() {
        loadDnsRecords();
        BackendToast.info('<?= __('已刷新') ?>');
    }

    function renderDnsManageHeader(providerName, serverIp) {
        var providerEl = document.getElementById('pb-dm-dns-provider-badge');
        if (providerEl) {
            providerEl.textContent = providerName || '-';
        }
        var ipEl = document.getElementById('pb-dm-dns-server-ip-display');
        if (ipEl) {
            ipEl.textContent = serverIp || '-';
        }
    }

    function autoResolveDnsForCurrentDomain() {
        if (!currentDnsManageDomainId) {
            BackendToast.warning('<?= __('域名 ID 无效') ?>');
            return;
        }

        BackendToast.info('<?= __('正在自动解析到本服务器并写入域名池...') ?>');
        postForm(API.batchResolveToLocal, {
            domain_ids: JSON.stringify([currentDnsManageDomainId]),
            auto_transfer_to_pool: '1',
            prefixes: JSON.stringify(['@', 'www'])
        }).then(function(res) {
            if (res.success) {
                BackendToast.success(res.msg || '<?= __('解析成功') ?>');
                loadDnsRecords();
                loadDomainList();
            } else {
                BackendToast.error(res.msg || '<?= __('解析失败') ?>');
            }
        }).catch(function() {
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function renderDnsRecords(records) {
        var container = document.getElementById('pb-dm-dns-records-container');
        if (!container) return;

        if (!records || records.length === 0) {
            container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--backend-color-text-tertiary);"><?= __('暂无DNS记录') ?></div>';
            return;
        }

        var html = '<table class="pb-dm-table" style="width:100%;font-size:0.9rem;">' +
            '<thead><tr>' +
            '<th><?= __('类型') ?></th>' +
            '<th><?= __('主机记录') ?></th>' +
            '<th><?= __('记录值') ?></th>' +
            '<th>TTL</th>' +
            '<th><?= __('操作') ?></th>' +
            '</tr></thead><tbody>';

        records.forEach(function(rec) {
            html += '<tr>' +
                '<td><code>' + escapeHtml(rec.type || '-') + '</code></td>' +
                '<td>' + escapeHtml(rec.host || rec.name || '@') + '</td>' +
                '<td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;" title="' + escapeHtml(rec.value || rec.data || '') + '">' + escapeHtml(rec.value || rec.data || '-') + '</td>' +
                '<td>' + (rec.ttl || '-') + '</td>' +
                '<td><button class="pb-dm-btn pb-dm-btn-danger pb-dm-btn-sm" onclick="deleteDnsRecord(\'' + escapeHtml(rec.record_id || rec.id || '') + '\')" title="<?= __('删除') ?>"><i class="mdi mdi-delete"></i></button></td>' +
                '</tr>';
        });

        html += '</tbody></table>';
        container.innerHTML = html;
    }

    function showAddDnsRecordForm() {
        document.getElementById('pb-dm-add-dns-form').style.display = 'block';
        document.getElementById('pb-dm-dns-add-type').value = 'A';
        document.getElementById('pb-dm-dns-add-host').value = '@';
        document.getElementById('pb-dm-dns-add-value').value = '';
        document.getElementById('pb-dm-dns-add-ttl').value = '600';
    }

    function hideAddDnsRecordForm() {
        document.getElementById('pb-dm-add-dns-form').style.display = 'none';
    }

    function saveNewDnsRecord() {
        var type = document.getElementById('pb-dm-dns-add-type').value;
        var host = document.getElementById('pb-dm-dns-add-host').value || '@';
        var value = document.getElementById('pb-dm-dns-add-value').value.trim();
        var ttl = document.getElementById('pb-dm-dns-add-ttl').value || 600;

        if (!value) {
            BackendToast.warning('<?= __('请输入记录值') ?>');
            return;
        }

        BackendToast.info('<?= __('正在添加...') ?>');

        postForm(API.addDnsRecord, {
            domain_id: currentDnsManageDomainId,
            type: type,
            host: host,
            value: value,
            ttl: ttl
        }).then(function(res) {
            if (res.success) {
                BackendToast.success(res.msg || '<?= __('添加成功') ?>');
                hideAddDnsRecordForm();
                loadDnsRecords();
            } else {
                BackendToast.error(res.msg || '<?= __('添加失败') ?>');
            }
        }).catch(function() {
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function showSwitchDnsProviderModal() {
        if (!currentDnsManageDomainId) {
            BackendToast.warning('<?= __('域名 ID 无效') ?>');
            return;
        }
        var inner = '<div class="pb-dm-modal-overlay" id="pb-dm-switch-dns-provider-modal" onclick="if(event.target===this)closeSwitchDnsProviderModal()">' +
            '<div class="pb-dm-modal pb-dm-modal-sm">' +
            '<div class="pb-dm-modal-header">' +
            '<h3><i class="mdi mdi-swap-horizontal"></i> <?= __('切换DNS供应商') ?></h3>' +
            '<button class="pb-dm-modal-close" onclick="closeSwitchDnsProviderModal()">&times;</button>' +
            '</div>' +
            '<div class="pb-dm-modal-body">' +
            '<div class="pb-dm-alert pb-dm-alert-info" style="margin-bottom:12px;">' +
            '<i class="mdi mdi-information-outline"></i> ' +
            '<?= __('切换后，当前域名的 Nameserver 将指向目标账户，并自动将现有 DNS 记录提交到该供应商。') ?>' +
            '</div>' +
            '<div class="pb-dm-form-group">' +
            '<label><?= __('选择目标账户') ?></label>' +
            '<select id="pb-dm-switch-dns-account">' +
            '<option value=""><?= __('-- 加载中... --') ?></option>' +
            '</select>' +
            '</div>' +
            '</div>' +
            '<div class="pb-dm-modal-footer">' +
            '<button class="pb-dm-btn pb-dm-btn-outline" onclick="closeSwitchDnsProviderModal()"><?= __('取消') ?></button>' +
            '<button class="pb-dm-btn pb-dm-btn-primary" id="pb-dm-switch-dns-submit" onclick="doSwitchDnsProvider()"><i class="mdi mdi-swap-horizontal"></i> <?= __('确认切换') ?></button>' +
            '</div></div></div>';
        var existing = document.getElementById('pb-dm-switch-dns-provider-modal');
        if (existing) existing.remove();
        document.body.insertAdjacentHTML('beforeend', inner);

        var select = document.getElementById('pb-dm-switch-dns-account');
        var url = API.getRegistrarAccounts + (API.getRegistrarAccounts.indexOf('?') >= 0 ? '&' : '?') + 'active_only=1';
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function(res) {
            var res = (res && res.data) !== undefined ? res.data : res;
            var accounts = (res.data && res.data.accounts) ? res.data.accounts : [];
            if ((res.success || res.code === 200) && accounts.length > 0) {
                var html = '<option value=""><?= __('-- 请选择目标账户 --') ?></option>';
                accounts.forEach(function(acc) {
                    html += '<option value="' + acc.id + '">' + escapeHtml(acc.name) + ' (' + escapeHtml(acc.registrar_name || acc.registrar_code) + ')</option>';
                });
                select.innerHTML = html;
            } else {
                select.innerHTML = '<option value=""><?= __('暂无可用账户') ?></option>';
            }
        }).catch(function() {
            select.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
        });
    }

    function closeSwitchDnsProviderModal() {
        var m = document.getElementById('pb-dm-switch-dns-provider-modal');
        if (m) m.remove();
    }

    function doSwitchDnsProvider() {
        var accountId = document.getElementById('pb-dm-switch-dns-account') && document.getElementById('pb-dm-switch-dns-account').value;
        if (!accountId) {
            BackendToast.warning('<?= __('请选择目标账户') ?>');
            return;
        }
        var btn = document.getElementById('pb-dm-switch-dns-submit');
        if (btn) btn.disabled = true;
        BackendToast.info('<?= __('正在切换DNS并提交记录...') ?>');

        postForm(API.batchSwitchToAccount, {
            domain_ids: JSON.stringify([currentDnsManageDomainId]),
            target_account_id: accountId
        }).then(function(res) {
            if (btn) btn.disabled = false;
            closeSwitchDnsProviderModal();
            if (res.success) {
                var errs = (res.data && res.data.auto_sync_errors) ? res.data.auto_sync_errors : [];
                if (errs.length > 0) {
                    BackendToast.warning(res.msg + ' ' + errs[0]);
                } else {
                    BackendToast.success('<?= __('DNS 切换成功，记录已提交到目标供应商') ?>');
                }
                loadDnsRecords();
                closeDnsManageModal();
                loadDomainList();
            } else {
                BackendToast.error(res.msg || '<?= __('切换失败') ?>');
            }
        }).catch(function() {
            if (btn) btn.disabled = false;
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function deleteDnsRecord(recordId) {
        if (!recordId) {
            BackendToast.warning('<?= __('记录ID无效') ?>');
            return;
        }

        BackendConfirm.show('<?= __('确定要删除这条DNS记录吗？') ?>', {
            title: '<?= __('删除确认') ?>',
            confirmText: '<?= __('确认删除') ?>',
            cancelText: '<?= __('取消') ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;

            BackendToast.info('<?= __('正在删除...') ?>');

            postForm(API.deleteDnsRecord, {
                domain_id: currentDnsManageDomainId,
                record_id: recordId
            }).then(function(res) {
                if (res.success) {
                    BackendToast.success(res.msg || '<?= __('删除成功') ?>');
                    loadDnsRecords();
                } else {
                    BackendToast.error(res.msg || '<?= __('删除失败') ?>');
                }
            }).catch(function() {
                BackendToast.error('<?= __('网络错误') ?>');
            });
        });
    }

    /* 搜索按钮 */
    document.getElementById('pb-dm-search-btn').addEventListener('click', function() {
        domainListState.page = 1;
        loadDomainList();
    });

    /* 回车搜索 */
    document.getElementById('pb-dm-domain-search').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            domainListState.page = 1;
            loadDomainList();
        }
    });

    /* 筛选变更 */
    document.getElementById('pb-dm-domain-acct').addEventListener('change', function() {
        domainListState.page = 1;
        loadDomainList();
    });
    document.getElementById('pb-dm-domain-status').addEventListener('change', function() {
        domainListState.page = 1;
        loadDomainList();
    });

    /* 分页 */
    pagePrev.addEventListener('click', function() {
        if (domainListState.page > 1) {
            domainListState.page--;
            loadDomainList();
        }
    });
    pageNext.addEventListener('click', function() {
        if (domainListState.page < domainListState.pages) {
            domainListState.page++;
            loadDomainList();
        }
    });
    pageSizeSelect.addEventListener('change', function() {
        domainListState.page = 1;
        loadDomainList();
    });

    /* 拉取选中域名 */
    document.getElementById('pb-dm-pull-domains-btn').addEventListener('click', function() {
        pullDomains(domainListState.selectedDomains, this, 0);
    });

    /* 批量拉取 */
    document.getElementById('pb-dm-batch-pull-btn').addEventListener('click', function() {
        pullDomains(domainListState.selectedDomains, this, 0);
    });

    /* 批量转存子域名（仅解析到本服务器的域名） */
    document.getElementById('pb-dm-batch-transfer-pool-btn').addEventListener('click', function() {
        var selected = domainListState.items.filter(function(d) {
            return d.is_pulled && d.domain_id > 0;
        }).filter(function(d) {
            var checkbox = domainContainer.querySelector('.pb-dm-domain-select[data-domain="' + d.domain + '"]');
            return checkbox && checkbox.checked;
        });

        if (selected.length === 0) {
            BackendToast.warning('<?= __('请选择已拉取的域名进行转存') ?>');
            return;
        }

        var btn = this;
        var domainIds = selected.map(function(d) { return d.domain_id; });

        BackendConfirm.show('<?= __('确定批量转存') ?> ' + selected.length + ' <?= __('个域名到域名池？') ?>\n\n<?= __('注意：只有解析到本服务器IP的域名才会被转存，其他将跳过。') ?>', {
            title: '<?= __('批量转存确认') ?>',
            confirmText: '<?= __('确认转存') ?>',
            cancelText: '<?= __('取消') ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;

            setBtnLoading(btn, true);

            postForm(API.batchTransferToPool, { domain_ids: JSON.stringify(domainIds) }).then(function(res) {
                setBtnLoading(btn, false, '<i class="mdi mdi-folder-move"></i> <?= __('批量转存') ?>');
                if (res.success) {
                    var msg = res.msg || res.message || '<?= __('转存完成') ?>';
                    if (res.data && res.data.skipped_domains && res.data.skipped_domains.length > 0) {
                        BackendToast.success(msg);
                        console.log('<?= __('跳过的域名（IP不匹配）') ?>:', res.data.skipped_domains);
                    } else {
                        BackendToast.success(msg);
                    }
                } else {
                    BackendToast.error(res.msg || res.message || '<?= __('转存失败') ?>');
                }
            }).catch(function(err) {
                setBtnLoading(btn, false, '<i class="mdi mdi-folder-move"></i> <?= __('批量转存') ?>');
                BackendToast.error('<?= __('网络错误') ?>');
            });
        });
    });

    /* 批量删除根域（含子域名与池记录） */
    document.getElementById('pb-dm-batch-delete-root-btn').addEventListener('click', function() {
        var selected = domainListState.items.filter(function(d) {
            return d.is_pulled && d.domain_id > 0;
        }).filter(function(d) {
            var checkbox = domainContainer.querySelector('.pb-dm-domain-select[data-domain="' + d.domain + '"]');
            return checkbox && checkbox.checked;
        });
        if (selected.length === 0) {
            BackendToast.warning('<?= __('请选择要删除的已拉取域名') ?>');
            return;
        }
        var domainIds = selected.map(function(d) { return d.domain_id; });
        var msg = '<?= __('确定要删除选中的 %{1} 个根域吗？每个根域下的所有子域名（域名池记录）和 DNS 解析记录将一并删除，且不可恢复。') ?>'.replace('%{1}', selected.length);
        BackendConfirm.show(msg).then(function(confirmed) {
            if (!confirmed) return;
            var btn = document.getElementById('pb-dm-batch-delete-root-btn');
            if (btn) btn.disabled = true;
            postForm(API.batchRemoveSync, { domain_ids: JSON.stringify(domainIds) }).then(function(res) {
                if (btn) btn.disabled = false;
                if (res.success) {
                    BackendToast.success(res.msg || '<?= __('删除成功') ?>');
                    loadDomainList();
                } else {
                    BackendToast.error(res.msg || '<?= __('删除失败') ?>');
                }
            }).catch(function() {
                if (btn) btn.disabled = false;
                BackendToast.error('<?= __('网络错误') ?>');
            });
        });
    });

    /* 批量解析到本地服务器 */
    document.getElementById('pb-dm-batch-resolve-to-local-btn').addEventListener('click', function() {
        var selected = domainListState.items.filter(function(d) {
            return d.is_pulled && d.domain_id > 0;
        }).filter(function(d) {
            var checkbox = domainContainer.querySelector('.pb-dm-domain-select[data-domain="' + d.domain + '"]');
            return checkbox && checkbox.checked;
        });

        if (selected.length === 0) {
            BackendToast.warning('<?= __('请选择已拉取的域名') ?>');
            return;
        }

        var btn = this;
        var domainIds = selected.map(function(d) { return d.domain_id; });
        var domainNames = selected.map(function(d) { return d.domain; }).join(', ');

        BackendConfirm.show('<?= __('确定将') ?> ' + selected.length + ' <?= __('个域名解析到本服务器？') ?>\n\n<?= __('将为每个域名添加 @ 和 www 的A记录指向本服务器公网IP。') ?>', {
            title: '<?= __('批量解析到本地') ?>',
            confirmText: '<?= __('确认解析') ?>',
            cancelText: '<?= __('取消') ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;

            setBtnLoading(btn, true);

            postForm(API.batchResolveToLocal, { domain_ids: JSON.stringify(domainIds) }).then(function(res) {
                setBtnLoading(btn, false, '<i class="mdi mdi-server"></i> <?= __('批量解析到本地') ?>');
                if (res.success) {
                    var msg = res.msg || res.message || '<?= __('解析完成') ?>';
                    BackendToast.success(msg);
                    if (res.data && res.data.errors && res.data.errors.length > 0) {
                        console.log('<?= __('解析错误') ?>:', res.data.errors);
                    }
                    loadDomainList();
                } else {
                    BackendToast.error(res.msg || res.message || '<?= __('解析失败') ?>');
                }
            }).catch(function(err) {
                setBtnLoading(btn, false, '<i class="mdi mdi-server"></i> <?= __('批量解析到本地') ?>');
                BackendToast.error('<?= __('网络错误') ?>');
            });
        });
    });

    /* 批量解析检测（仅已拉取的域名可操作） */
    document.getElementById('pb-dm-batch-resolve-btn').addEventListener('click', function() {
        var selected = domainListState.items.filter(function(d) {
            return d.is_pulled && d.domain_id > 0;
        }).filter(function(d) {
            var checkbox = domainContainer.querySelector('.pb-dm-domain-select[data-domain="' + d.domain + '"]');
            return checkbox && checkbox.checked;
        });

        if (selected.length === 0) {
            BackendToast.warning('<?= __('请选择已拉取的域名进行检测') ?>');
            return;
        }

        var btn = this;
        setBtnLoading(btn, true);

        var processed = 0;
        var successCount = 0;
        var total = selected.length;

        selected.forEach(function(d) {
            postForm(API.checkResolve, { domain_id: d.domain_id }).then(function(res) {
                processed++;
                if (res.success) successCount++;
                if (processed >= total) {
                    setBtnLoading(btn, false, '<i class="mdi mdi-dns"></i> <?= __('批量解析检测') ?>');
                    BackendToast.success('<?= __('批量检测完成') ?>：' + successCount + '/' + total);
                }
            }).catch(function() {
                processed++;
                if (processed >= total) {
                    setBtnLoading(btn, false, '<i class="mdi mdi-dns"></i> <?= __('批量解析检测') ?>');
                    BackendToast.success('<?= __('批量检测完成') ?>：' + successCount + '/' + total);
                }
            });
        });
    });

