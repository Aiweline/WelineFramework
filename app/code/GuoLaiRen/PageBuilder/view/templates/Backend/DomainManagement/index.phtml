            }
            html += '</div>';

            html += '</div>';
        });

        domainContainer.innerHTML = html;
        paginationEl.style.display = 'none';

        bindAccordionEvents();
        bindDomainSelectEvents();
    }

    function bindAccordionEvents() {
        domainContainer.querySelectorAll('.pb-dm-accordion-header').forEach(function(header) {
            header.addEventListener('click', function(e) {
                if (e.target.closest('.pb-dm-accordion-actions')) return;
                var accordion = header.closest('.pb-dm-accordion');
                accordion.classList.toggle('pb-dm-accordion--open');
            });
        });

        domainContainer.querySelectorAll('.pb-dm-pull-all-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var accountId = parseInt(btn.dataset.accountId);
                var group = domainListState.groups.find(function(g) { return g.account_id === accountId; });
                if (!group) return;

                var notPulledDomains = group.items.filter(function(d) { return !d.is_pulled; }).map(function(d) { return d.domain; });
                if (notPulledDomains.length === 0) {
                    BackendToast.info('<?= __('该账户所有域名都已拉取') ?>');
                    return;
                }

                setBtnLoading(btn, true);
                postForm(API.pullDomains, {
                    account_id: accountId,
                    domains: notPulledDomains
                }).then(function(res) {
                    setBtnLoading(btn, false, '<i class="mdi mdi-download-multiple"></i>');
                    if (res.success) {
                        BackendToast.success(res.message || '<?= __('拉取成功') ?>');
                        loadDomainList();
                    } else {
                        BackendToast.error(res.message || res.msg || '<?= __('拉取失败') ?>');
                    }
                }).catch(function() {
                    setBtnLoading(btn, false, '<i class="mdi mdi-download-multiple"></i>');
                    BackendToast.error('<?= __('网络错误') ?>');
                });
            });
        });

        domainContainer.querySelectorAll('.pb-dm-select-all-group').forEach(function(chk) {
            chk.addEventListener('change', function() {
                var accountId = chk.dataset.accountId;
                var accordion = chk.closest('.pb-dm-accordion');
                var checkboxes = accordion.querySelectorAll('.pb-dm-domain-select:not(:disabled)');

                checkboxes.forEach(function(cb) {
                    cb.checked = chk.checked;
                    var domain = cb.dataset.domain;
                    if (chk.checked) {
                        if (domainListState.selectedDomains.indexOf(domain) === -1) {
                            domainListState.selectedDomains.push(domain);
                        }
                    } else {
                        var idx = domainListState.selectedDomains.indexOf(domain);
                        if (idx >= 0) domainListState.selectedDomains.splice(idx, 1);
                    }
                });
                updateBatchBar();
            });
        });
    }

    function escapeHtml(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    function updatePagination() {
        pageInfo.textContent = domainListState.page + ' / ' + Math.max(1, domainListState.pages) +
            ' (<?= __('共') ?> ' + domainListState.total + ' <?= __('条') ?>)';
        pagePrev.disabled = domainListState.page <= 1;
        pageNext.disabled = domainListState.page >= domainListState.pages;
    }

    function updateBatchBar() {
        var count = domainListState.selectedDomains.length;
        batchCountNum.textContent = count;

        var pullBtn = document.getElementById('pb-dm-pull-domains-btn');
        if (pullBtn) {
            pullBtn.disabled = count === 0;
        }
    }

    var selectAllDomainCheckbox = document.getElementById('pb-dm-select-all-domain');
    if (selectAllDomainCheckbox) {
        selectAllDomainCheckbox.addEventListener('change', function() {
            var checked = selectAllDomainCheckbox.checked;
            var checkboxes = domainContainer.querySelectorAll('.pb-dm-domain-select:not(:disabled)');
            domainListState.selectedDomains = [];
            checkboxes.forEach(function(cb) {
                cb.checked = checked;
                if (checked) {
                    domainListState.selectedDomains.push(cb.dataset.domain);
                }
            });
            updateBatchBar();
        });
    }

    function bindDomainSelectEvents() {
        var checkboxes = domainContainer.querySelectorAll('.pb-dm-domain-select:not(:disabled)');

        if (selectAllDomainCheckbox) {
            selectAllDomainCheckbox.checked = false;
        }
        domainListState.selectedDomains = [];
        updateBatchBar();

        checkboxes.forEach(function(cb) {
            cb.addEventListener('change', function() {
                var domain = cb.dataset.domain;
                if (cb.checked) {
                    if (domainListState.selectedDomains.indexOf(domain) === -1) {
                        domainListState.selectedDomains.push(domain);
                    }
                } else {
                    var idx = domainListState.selectedDomains.indexOf(domain);
                    if (idx >= 0) domainListState.selectedDomains.splice(idx, 1);
                }
                updateBatchBar();
            });
        });

        domainContainer.querySelectorAll('.pb-dm-pull-single-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var domain = btn.dataset.domain;
                var accountId = parseInt(btn.dataset.accountId) || 0;
                pullDomains([domain], btn, accountId);
            });
        });

        domainContainer.querySelectorAll('.pb-dm-resolve-dns-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var domainId = parseInt(btn.dataset.domainId);
                var domain = btn.dataset.domain;
                resolveDns(domainId, domain, btn);
            });
        });

        domainContainer.querySelectorAll('.pb-dm-manage-dns-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var domainId = parseInt(btn.dataset.domainId);
                var domain = btn.dataset.domain;
                showDnsManageModal(domainId, domain);
            });
        });

        domainContainer.querySelectorAll('.pb-dm-root-switch-dns-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var domainId = parseInt(btn.dataset.domainId) || 0;
                var domain = btn.dataset.domain || '';
                var accountId = parseInt(btn.dataset.accountId) || 0;
                showRootDnsSwitchModal(domainId, domain, accountId);
            });
        });

        domainContainer.querySelectorAll('.pb-dm-root-delete-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var domainId = parseInt(btn.dataset.domainId, 10) || 0;
                var domain = btn.dataset.domain || '';
                if (domainId <= 0) return;
                var msg = '<?= __('确定要删除根域「%{1}」吗？该根域下的所有子域名（域名池记录）和 DNS 解析记录将一并删除，且不可恢复。') ?>'.replace('%{1}', domain.replace(/</g, '&lt;').replace(/>/g, '&gt;'));
                BackendConfirm.show(msg).then(function(confirmed) {
                    if (!confirmed) return;
                    btn.disabled = true;
                    postForm(API.batchRemoveSync, { domain_ids: JSON.stringify([domainId]) }).then(function(res) {
                        if (res.success) {
                            BackendToast.success(res.msg || '<?= __('删除成功') ?>');
                            loadDomainList();
                        } else {
                            BackendToast.error(res.msg || '<?= __('删除失败') ?>');
                            btn.disabled = false;
                        }
                    }).catch(function() {
                        BackendToast.error('<?= __('请求失败') ?>');
                        btn.disabled = false;
                    });
                });
            });
        });
    }

    function pullDomains(domainList, btn, accountId, autoResolve) {
        if (!domainList || domainList.length === 0) {
            BackendToast.warning('<?= __('请选择要拉取的域名') ?>');
            return;
        }

        accountId = accountId || domainListState.accountId || 0;
        autoResolve = autoResolve !== false;

        if (btn) setBtnLoading(btn, true);

        postForm(API.pullDomains, {
            account_id: accountId,
            domains: domainList,
            auto_resolve: autoResolve ? '1' : '0'
        }).then(function(res) {
            if (res.success) {
                var msg = res.message || '<?= __('拉取成功') ?>';
                if (autoResolve && res.auto_resolve_queued) {
                    msg += ' <?= __('（自动解析任务已创建）') ?>';
                }
                BackendToast.success(msg);
                if (btn && res.domains && domainList.length === 1) {
                    var domain = domainList[0];
                    var domainId = res.domains[domain] || 0;
                    if (domainId > 0) {
                        btn.className = 'pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-resolve-dns-btn';
                        btn.setAttribute('data-domain-id', domainId);
                        btn.setAttribute('data-domain', domain);
                        btn.setAttribute('title', '<?= __('解析到本地') ?>');
                        btn.innerHTML = '<i class="mdi mdi-dns"></i>';
                        btn.onclick = function(e) {
                            e.stopPropagation();
                            resolveDns(domainId, domain, btn);
                        };
                        var row = btn.closest('tr');
                        if (row) {
                            var pullBadge = row.querySelector('.pb-dm-badge--warn');
                            if (pullBadge) {
                                pullBadge.className = 'pb-dm-badge pb-dm-badge--ok';
                                pullBadge.textContent = '<?= __('已拉取') ?>';
                            }
                            var checkbox = row.querySelector('.pb-dm-domain-select');
                            if (checkbox) {
                                checkbox.checked = false;
                            }
                        }
                    } else {
                        setBtnLoading(btn, false, '<i class="mdi mdi-check"></i>');
                    }
                } else if (btn) {
                    setBtnLoading(btn, false, '<i class="mdi mdi-check"></i>');
                }
            } else {
                if (btn) setBtnLoading(btn, false, '<i class="mdi mdi-download"></i>');
                BackendToast.error(res.message || res.msg || '<?= __('拉取失败') ?>');
            }
        }).catch(function() {
            if (btn) setBtnLoading(btn, false, '<i class="mdi mdi-download"></i>');
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function resolveDns(domainId, domainName, btn) {
        if (domainId <= 0) {
            BackendToast.warning('<?= __('域名 ID 无效') ?>');
            return;
        }

        setBtnLoading(btn, true);

        postForm(API.batchResolveToLocal, {
            domain_ids: JSON.stringify([domainId]),
            auto_transfer_to_pool: '1',
            prefixes: JSON.stringify(['@', 'www'])
        }).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-dns"></i>');
            if (res.success) {
                BackendToast.success(res.msg || ('<?= __('已将') ?> ' + domainName + ' <?= __('的 @、www 解析到本机') ?>'));
                loadDomainList();
                if (currentDnsManageDomainId === domainId && document.getElementById('pb-dm-dns-manage-modal')) {
                    loadDnsRecords();
                }
            } else {
                BackendToast.error(res.msg || '<?= __('解析到本地失败') ?>');
            }
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-dns"></i>');
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    /* ========== 单条域名DNS记录管理 ========== */
    var currentDnsManageDomainId = 0;
    var currentDnsManageDomainName = '';
    var currentDnsManageServerIp = '';
    var currentDnsManageProviderName = '-';

