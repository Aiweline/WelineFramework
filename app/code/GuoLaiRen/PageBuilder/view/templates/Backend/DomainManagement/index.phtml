                        setBtnLoading(btn, false, '<i class="mdi mdi-delete"></i> <?= __('删除') ?>');
                        BackendToast.error(res.message || res.msg || '<?= __('删除失败') ?>');
                    }
                }).catch(function() {
                    setBtnLoading(btn, false, '<i class="mdi mdi-delete"></i> <?= __('删除') ?>');
