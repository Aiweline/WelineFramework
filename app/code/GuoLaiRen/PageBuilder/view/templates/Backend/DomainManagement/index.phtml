<script>
(function() {
    'use strict';

    var API = {
        getRegistrars:    '<backend-url>pagebuilder/backend/domain-management/get-registrars</backend-url>',
        getConfigFields:  '<backend-url>pagebuilder/backend/domain-management/get-config-fields</backend-url>',
        getRegistrarInfo: '<backend-url>pagebuilder/backend/domain-management/get-registrar-info</backend-url>',
        saveAccount:      '<backend-url>pagebuilder/backend/domain-management/save-account</backend-url>',
        deleteAccount:    '<backend-url>pagebuilder/backend/domain-management/delete-account</backend-url>',
        testConnection:   '<backend-url>pagebuilder/backend/domain-management/test-connection</backend-url>',
        getDomains:       '<backend-url>pagebuilder/backend/domain-management/get-domains</backend-url>',
        checkAvail:       '<backend-url>pagebuilder/backend/domain-management/check-availability</backend-url>',
        purchase:         '<backend-url>pagebuilder/backend/domain-management/purchase</backend-url>',
        batchPurchase:    '<backend-url>pagebuilder/backend/domain-management/batch-purchase</backend-url>'
    };

    /* ========== Tab 切换 ========== */
    document.querySelectorAll('.pb-dm-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.pb-dm-tab').forEach(function(t) { t.classList.remove('pb-dm-tab--active'); });
            document.querySelectorAll('.pb-dm-panel').forEach(function(p) { p.classList.remove('pb-dm-panel--active'); });
            tab.classList.add('pb-dm-tab--active');
            var panel = document.getElementById('pb-dm-tab-' + tab.dataset.tab);
            if (panel) panel.classList.add('pb-dm-panel--active');
        });
    });

    /* ========== 工具函数 ========== */
    function postForm(url, data) {
        var fd = new FormData();
        Object.keys(data).forEach(function(k) {
            fd.append(k, typeof data[k] === 'object' ? JSON.stringify(data[k]) : data[k]);
        });
        return fetch(url, { method: 'POST', body: fd }).then(function(r) { return r.json(); });
    }

    function setBtnLoading(btn, loading, originalHtml) {
        if (loading) {
            btn.dataset.origHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
        } else {
            btn.disabled = false;
            btn.innerHTML = originalHtml || btn.dataset.origHtml || '';
        }
    }

    /* ========== 账户管理 - 弹窗 ========== */
    var modal = document.getElementById('pb-dm-account-modal');
    var formId = document.getElementById('pb-dm-form-id');
    var formRegistrar = document.getElementById('pb-dm-form-registrar');
    var formName = document.getElementById('pb-dm-form-name');
    var formApiKey = document.getElementById('pb-dm-form-apikey');
    var formApiSecret = document.getElementById('pb-dm-form-apisecret');
    var formRegion = document.getElementById('pb-dm-form-region');
    var formStatus = document.getElementById('pb-dm-form-status');
    var extraFieldsDiv = document.getElementById('pb-dm-extra-fields');

    var configHelpDiv = document.getElementById('pb-dm-config-help');

    function openModal(isEdit) {
        document.getElementById('pb-dm-modal-title').textContent = isEdit
            ? '<?= __('编辑域名商账户') ?>'
            : '<?= __('添加域名商账户') ?>';
        modal.classList.add('pb-dm-form-modal--open');
    }
    function closeModal() {
        modal.classList.remove('pb-dm-form-modal--open');
        formId.value = '0';
        formRegistrar.value = '';
        formName.value = '';
        formApiKey.value = '';
        formApiSecret.value = '';
        formRegion.value = '';
        formStatus.value = 'active';
        extraFieldsDiv.innerHTML = '';
        configHelpDiv.innerHTML = '';
        configHelpDiv.style.display = 'none';
    }

    document.getElementById('pb-dm-modal-close').addEventListener('click', closeModal);
    document.getElementById('pb-dm-modal-cancel').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    /* 添加账户 */
    document.getElementById('pb-dm-add-account-btn').addEventListener('click', function() {
        closeModal();
        openModal(false);
    });

    /* 域名商类型变更 → 加载配置字段、默认值和帮助信息 */
    formRegistrar.addEventListener('change', function() {
        var code = formRegistrar.value;
        extraFieldsDiv.innerHTML = '';
        configHelpDiv.innerHTML = '';
        configHelpDiv.style.display = 'none';
        if (!code) return;

        postForm(API.getRegistrarInfo, { registrar_code: code }).then(function(res) {
            if (!res.success || !res.data) return;

            var info = res.data;
            var fields = info.config_fields || [];
            var help = info.config_help || {};

            /* 主字段默认值填充 */
            fields.forEach(function(field) {
                if (field.name === 'api_key' && field.default && !formApiKey.value) {
                    formApiKey.value = field.default;
                }
                if ((field.name === 'region' || field.name === 'api_host') && field.default && !formRegion.value) {
                    formRegion.value = field.default;
                }
            });

            /* 额外字段渲染 */
            var skip = ['appid', 'appkey', 'api_key', 'api_secret', 'region'];
            var html = '';
            fields.forEach(function(field) {
                if (skip.indexOf(field.name) >= 0) return;
                html += '<div class="pb-dm-fg" style="margin-bottom:12px;">';
                html += '<label>' + (field.label || field.name) + (field.required ? ' <span style="color:var(--backend-color-danger,#f46a6a)">*</span>' : '') + '</label>';
                if (field.type === 'select' && field.options) {
                    html += '<select class="pb-dm-extra-input" data-field="' + field.name + '"' + (field.mapping ? ' data-mapping="' + field.mapping + '"' : '') + '>';
                    field.options.forEach(function(opt) {
                        var selected = (field.default && field.default === opt.value) ? ' selected' : '';
                        html += '<option value="' + (opt.value || '') + '"' + selected + '>' + (opt.label || opt.value || '') + '</option>';
                    });
                    html += '</select>';
                } else {
                    var inputType = field.type === 'password' ? 'password' : 'text';
                    var defaultVal = field.default || '';
                    html += '<input type="' + inputType + '" class="pb-dm-extra-input" data-field="' + field.name + '"';
                    if (field.mapping) html += ' data-mapping="' + field.mapping + '"';
                    if (field.placeholder) html += ' placeholder="' + field.placeholder + '"';
                    if (defaultVal) html += ' value="' + defaultVal + '"';
                    html += '>';
                }
                html += '</div>';
            });
            extraFieldsDiv.innerHTML = html;

            /* 帮助信息渲染 */
            if (help.help_steps && help.help_steps.length) {
                var helpHtml = '<div class="pb-dm-help-title"><i class="mdi mdi-information-outline"></i>';
                if (help.help_url) {
                    helpHtml += '<a href="' + help.help_url + '" target="_blank">' + (help.help_title || '<?= __('配置获取指南') ?>') + ' <i class="mdi mdi-open-in-new" style="font-size:0.85em;"></i></a>';
                } else {
                    helpHtml += '<span>' + (help.help_title || '<?= __('配置获取指南') ?>') + '</span>';
                }
                helpHtml += '</div><ol class="pb-dm-help-steps">';
                help.help_steps.forEach(function(step) {
                    helpHtml += '<li>' + step + '</li>';
                });
                helpHtml += '</ol>';
                configHelpDiv.innerHTML = helpHtml;
                configHelpDiv.style.display = 'block';
            }
        });
    });

    /* 保存账户 */
    document.getElementById('pb-dm-modal-save').addEventListener('click', function() {
        var btn = this;
        var regCode = formRegistrar.value;
        var name = formName.value.trim();
        if (!regCode || !name) {
            AdminToast.warning('<?= __('请填写域名商类型和账户名称') ?>');
            return;
        }

        var extra = {};
        extraFieldsDiv.querySelectorAll('.pb-dm-extra-input').forEach(function(el) {
            var v = el.value.trim();
            if (v) extra[el.dataset.field] = v;
        });

        var data = {
            account_id: formId.value,
            registrar_code: regCode,
            account_name: name,
            api_key: formApiKey.value.trim(),
            api_secret: formApiSecret.value.trim(),
            region: formRegion.value.trim(),
            status: formStatus.value,
            extra_config: extra
        };

        setBtnLoading(btn, true);
        postForm(API.saveAccount, data).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-check"></i> <?= __('保存') ?>');
            if (res.success) {
                AdminToast.success(res.message || '<?= __('保存成功') ?>');
                closeModal();
                location.reload();
            } else {
                AdminToast.error(res.message || res.msg || '<?= __('保存失败') ?>');
            }
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-check"></i> <?= __('保存') ?>');
            AdminToast.error('<?= __('网络错误') ?>');
        });
    });

    /* 编辑账户 */
    document.querySelectorAll('.pb-dm-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            closeModal();
            formId.value = btn.dataset.id;
            formRegistrar.value = btn.dataset.code;
            formName.value = btn.dataset.name;
            formStatus.value = btn.dataset.status || 'active';
            formApiKey.value = '';
            formApiSecret.value = '';
            formRegistrar.dispatchEvent(new Event('change'));
            openModal(true);
        });
    });

    /* 删除账户 */
    document.querySelectorAll('.pb-dm-del-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = btn.dataset.id;
            var name = btn.dataset.name;
            AdminConfirm.show('<?= __('确定要删除账户') ?> "' + name + '" <?= __('吗？此操作不可恢复。') ?>', {
                title: '<?= __('确认删除') ?>',
                confirmText: '<?= __('确认删除') ?>',
                cancelText: '<?= __('取消') ?>'
            }).then(function(confirmed) {
                if (!confirmed) return;
                setBtnLoading(btn, true);
                postForm(API.deleteAccount, { account_id: id }).then(function(res) {
                    if (res.success) {
                        AdminToast.success(res.message || '<?= __('已删除') ?>');
                        location.reload();
                    } else {
                        setBtnLoading(btn, false, '<i class="mdi mdi-delete"></i> <?= __('删除') ?>');
                        AdminToast.error(res.message || res.msg || '<?= __('删除失败') ?>');
                    }
                }).catch(function() {
                    setBtnLoading(btn, false, '<i class="mdi mdi-delete"></i> <?= __('删除') ?>');
                    AdminToast.error('<?= __('网络错误') ?>');
                });
            });
        });
    });

    /* 测试连接 */
    document.querySelectorAll('.pb-dm-test-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = btn.dataset.id;
            setBtnLoading(btn, true);
            postForm(API.testConnection, { account_id: id }).then(function(res) {
                setBtnLoading(btn, false, '<i class="mdi mdi-connection"></i> <?= __('测试') ?>');
                if (res.success) {
                    AdminToast.success(res.message || '<?= __('连接成功') ?>');
                } else {
                    AdminToast.error(res.message || res.msg || '<?= __('连接失败') ?>');
                }
            }).catch(function() {
                setBtnLoading(btn, false, '<i class="mdi mdi-connection"></i> <?= __('测试') ?>');
                AdminToast.error('<?= __('网络错误') ?>');
            });
        });
    });

    /* ========== 域名列表 ========== */
    document.getElementById('pb-dm-load-domains-btn').addEventListener('click', function() {
        var btn = this;
        var accountId = document.getElementById('pb-dm-domain-acct').value;
        if (!accountId) {
            AdminToast.warning('<?= __('请选择域名商账户') ?>');
            return;
        }
        setBtnLoading(btn, true);
        postForm(API.getDomains, { account_id: accountId }).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-refresh"></i> <?= __('加载域名') ?>');
            var container = document.getElementById('pb-dm-domains-result');
            if (!res.success) {
                AdminToast.error(res.msg || '<?= __('加载失败') ?>');
                return;
            }
            var list = res.data || [];
            if (!list.length) {
                container.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-domain"></i><p><?= __('该账户下暂无域名') ?></p></div>';
                return;
            }
            var statusMap = {
                'active': ['<?= __('正常') ?>', 'pb-dm-badge--ok'],
                'pending': ['<?= __('处理中') ?>', 'pb-dm-badge--warn'],
                'expired': ['<?= __('已过期') ?>', 'pb-dm-badge--no'],
                'suspended': ['<?= __('已暂停') ?>', 'pb-dm-badge--no']
            };
            var html = '<table class="pb-dm-table"><thead><tr>' +
                '<th><?= __('域名') ?></th><th><?= __('状态') ?></th><th><?= __('过期时间') ?></th>' +
                '</tr></thead><tbody>';
            list.forEach(function(d) {
                var st = statusMap[d.status] || [d.status, 'pb-dm-badge--info'];
                html += '<tr><td>' + d.domain + '</td>' +
                    '<td><span class="pb-dm-badge ' + st[1] + '">' + st[0] + '</span></td>' +
                    '<td>' + (d.expires_at || '-') + '</td></tr>';
            });
            html += '</tbody></table>';
            container.innerHTML = html;
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-refresh"></i> <?= __('加载域名') ?>');
            AdminToast.error('<?= __('网络错误') ?>');
        });
    });

    /* ========== 域名注册 ========== */
    var checkResults = document.getElementById('pb-dm-check-results');

    document.getElementById('pb-dm-check-btn').addEventListener('click', function() {
        var btn = this;
        var accountId = document.getElementById('pb-dm-reg-acct').value;
        var domainsText = document.getElementById('pb-dm-reg-domains').value.trim();
        if (!accountId || !domainsText) {
            AdminToast.warning('<?= __('请选择账户并输入域名') ?>');
            return;
        }
        setBtnLoading(btn, true);
        postForm(API.checkAvail, { account_id: accountId, domains: domainsText }).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>');
            if (!res.success) {
                AdminToast.error(res.msg || '<?= __('检查失败') ?>');
                return;
            }
            renderCheckResults(res.data || [], accountId);
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>');
            AdminToast.error('<?= __('网络错误') ?>');
        });
    });

    function renderCheckResults(results, accountId) {
        if (!results.length) {
            checkResults.innerHTML = '<div class="pb-dm-empty"><p><?= __('无检查结果') ?></p></div>';
            return;
        }

        var availCount = results.filter(function(r) { return r.available; }).length;
        var html = '<div style="margin:12px 0;display:flex;align-items:center;justify-content:space-between;">' +
            '<span style="color:var(--backend-color-text-secondary,#6c757d);font-size:0.9rem;">' +
            '<?= __('共') ?> ' + results.length + ' <?= __('个域名，') ?>' +
            '<strong style="color:var(--backend-color-success,#34c38f)">' + availCount + '</strong> <?= __('个可注册') ?></span>';

        if (availCount > 0) {
            html += '<button class="pb-dm-btn pb-dm-btn-success" id="pb-dm-batch-buy-btn">' +
                '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?> (' + availCount + ')</button>';
        }
        html += '</div>';

        html += '<table class="pb-dm-table"><thead><tr>' +
            '<th><input type="checkbox" id="pb-dm-select-all"></th>' +
            '<th><?= __('域名') ?></th><th><?= __('状态') ?></th><th><?= __('价格') ?></th><th><?= __('操作') ?></th>' +
            '</tr></thead><tbody>';

        results.forEach(function(item, idx) {
            var badge = item.available
                ? '<span class="pb-dm-badge pb-dm-badge--ok">' + (item.premium ? '<?= __('溢价可注册') ?>' : '<?= __('可注册') ?>') + '</span>'
                : '<span class="pb-dm-badge pb-dm-badge--no"><?= __('已注册') ?></span>';
            var price = item.price ? ('$' + parseFloat(item.price).toFixed(2)) : '-';
            var action = item.available
                ? '<button class="pb-dm-btn pb-dm-btn-success pb-dm-btn-sm pb-dm-buy-one" ' +
                  'data-domain="' + item.domain + '" data-account="' + accountId + '">' +
                  '<i class="mdi mdi-cart"></i> <?= __('购买') ?></button>'
                : '-';
            var chk = item.available
                ? '<input type="checkbox" class="pb-dm-domain-chk" data-domain="' + item.domain + '" checked>'
                : '<input type="checkbox" disabled>';
            html += '<tr><td>' + chk + '</td><td>' + item.domain + '</td><td>' + badge + '</td><td>' + price + '</td><td>' + action + '</td></tr>';
        });
        html += '</tbody></table>';
        checkResults.innerHTML = html;

        /* 全选 */
        var selectAll = document.getElementById('pb-dm-select-all');
        if (selectAll) {
            selectAll.addEventListener('change', function() {
                var checked = selectAll.checked;
                checkResults.querySelectorAll('.pb-dm-domain-chk').forEach(function(c) { c.checked = checked; });
            });
        }

        /* 单个购买 */
        checkResults.querySelectorAll('.pb-dm-buy-one').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var domain = btn.dataset.domain;
                var acctId = btn.dataset.account;
                AdminConfirm.show('<?= __('确定购买') ?> ' + domain + ' <?= __('吗？') ?>', {
                    title: '<?= __('确认购买') ?>',
                    confirmText: '<?= __('确认') ?>',
                    cancelText: '<?= __('取消') ?>'
                }).then(function(ok) {
                    if (!ok) return;
                    setBtnLoading(btn, true);
                    postForm(API.purchase, { account_id: acctId, domain: domain, years: '1' }).then(function(res) {
                        if (res.success) {
                            AdminToast.success(res.message || res.msg || '<?= __('购买成功') ?>');
                            btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已购买') ?>';
                            btn.disabled = true;
                        } else {
                            setBtnLoading(btn, false, '<i class="mdi mdi-cart"></i> <?= __('购买') ?>');
                            AdminToast.error(res.message || res.msg || '<?= __('购买失败') ?>');
                        }
                    }).catch(function() {
                        setBtnLoading(btn, false, '<i class="mdi mdi-cart"></i> <?= __('购买') ?>');
                        AdminToast.error('<?= __('网络错误') ?>');
                    });
                });
            });
        });

        /* 批量购买 */
        var batchBtn = document.getElementById('pb-dm-batch-buy-btn');
        if (batchBtn) {
            batchBtn.addEventListener('click', function() {
                var selected = [];
                checkResults.querySelectorAll('.pb-dm-domain-chk:checked').forEach(function(c) {
                    selected.push({ domain: c.dataset.domain, years: 1 });
                });
                if (!selected.length) {
                    AdminToast.warning('<?= __('请勾选要购买的域名') ?>');
                    return;
                }
                AdminConfirm.show('<?= __('确定批量购买') ?> ' + selected.length + ' <?= __('个域名吗？') ?>', {
                    title: '<?= __('批量购买确认') ?>',
                    confirmText: '<?= __('确认购买') ?>',
                    cancelText: '<?= __('取消') ?>'
                }).then(function(ok) {
                    if (!ok) return;
                    setBtnLoading(batchBtn, true);
                    postForm(API.batchPurchase, { account_id: accountId, domains: selected }).then(function(res) {
                        setBtnLoading(batchBtn, false, '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?>');
                        if (res.success) {
                            AdminToast.success(res.message || res.msg || '<?= __('批量购买已提交') ?>');
                        } else {
                            AdminToast.error(res.message || res.msg || '<?= __('购买失败') ?>');
                        }
                    }).catch(function() {
                        setBtnLoading(batchBtn, false, '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?>');
                        AdminToast.error('<?= __('网络错误') ?>');
                    });
                });
            });
        }
    }

})();
</script>
