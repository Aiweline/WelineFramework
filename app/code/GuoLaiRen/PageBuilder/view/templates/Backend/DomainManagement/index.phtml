    function loadPbDmRegistrarAccounts() {
        var select = document.getElementById('pb-dm-batch-ns-account');
        if (!select) return;

        var accountModeRadio = document.getElementById('pb-dm-ns-mode-account');
        var manualModeRadio = document.getElementById('pb-dm-ns-mode-manual');
        var accountNoDataTip = document.getElementById('pb-dm-ns-account-no-data');
        
        select.innerHTML = '<option value=""><?= __('-- 加载中... --') ?></option>';
        if (accountNoDataTip) accountNoDataTip.style.display = 'none';

        var req = window.Weline.Api.get(API.getRegistrarAccounts, { silent: true });
        req.then(function(res) {
                var res = (res && res.data) !== undefined ? res.data : res;
                var accounts = (res.data && res.data.accounts) ? res.data.accounts : [];
                if ((res.success || res.code === 200) && accounts.length > 0) {
                    pbDmRegistrarAccounts = accounts;
                    select.disabled = false;
                    if (accountModeRadio) accountModeRadio.disabled = false;
                    var html = '<option value=""><?= __('-- 请选择目标账户 --') ?></option>';
                    accounts.forEach(function(acc) {
                        html += '<option value="' + acc.id + '" data-registrar="' + acc.registrar_code + '">' +
                                acc.name + ' (' + acc.registrar_name + ')' +
                                '</option>';
                    });
                    select.innerHTML = html;
                } else if ((res.success || res.code === 200) && accounts.length === 0) {
                    pbDmRegistrarAccounts = [];
                    select.innerHTML = '<option value=""><?= __('-- 暂无可用账户 --') ?></option>';
                    select.disabled = true;
                    if (accountModeRadio) accountModeRadio.disabled = true;
                    if (accountNoDataTip) accountNoDataTip.style.display = 'block';
                    if (manualModeRadio) {
                        manualModeRadio.checked = true;
                        onPbDmNsModeChange();
                    }
                } else {
                    select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
                }
            }).catch(function() {
                select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
            });
    }

    function onPbDmNsModeChange() {
        var mode = document.querySelector('input[name="pb-dm-ns-mode"]:checked').value;
        var accountMode = document.getElementById('pb-dm-ns-account-mode');
        var manualMode = document.getElementById('pb-dm-ns-manual-mode');
        if (accountMode) accountMode.style.display = (mode === 'account') ? 'block' : 'none';
        if (manualMode) manualMode.style.display = (mode === 'manual') ? 'block' : 'none';
    }

    function onPbDmNsAccountChange() {
        var select = document.getElementById('pb-dm-batch-ns-account');
        var accountId = select ? select.value : '';
        var infoDiv = document.getElementById('pb-dm-ns-account-info');
        var nsSpan = document.getElementById('pb-dm-ns-account-ns');

        if (!accountId) {
            if (infoDiv) infoDiv.style.display = 'none';
            return;
        }

        if (infoDiv) infoDiv.style.display = 'block';
        if (nsSpan) nsSpan.textContent = '<?= __('正在获取DNS服务器...') ?>';

        postForm(API.getAccountNameservers, {
            account_id: accountId,
            domains: JSON.stringify(pbDmBatchNsSelectedDomains.slice(0, 1))
        }).then(function(res) {
            if (res.success && res.data) {
                if (res.data.per_domain) {
                    if (nsSpan) nsSpan.textContent = '<?= __('Cloudflare 将为每个域名分配独立的 Nameserver') ?>';
                } else if (res.data.nameservers && res.data.nameservers.length > 0) {
                    if (nsSpan) nsSpan.textContent = '<?= __('目标DNS') ?>: ' + res.data.nameservers.join(', ');
                } else {
                    if (nsSpan) nsSpan.textContent = res.msg || res.message || '<?= __('该账户暂无可用DNS服务器') ?>';
                    if (infoDiv) infoDiv.className = 'pb-dm-alert pb-dm-alert-warning';
                }
            } else {
                if (nsSpan) nsSpan.textContent = res.msg || res.message || '<?= __('获取失败') ?>';
                if (infoDiv) infoDiv.className = 'pb-dm-alert pb-dm-alert-warning';
            }
        }).catch(function() {
            if (nsSpan) nsSpan.textContent = '<?= __('获取失败') ?>';
            if (infoDiv) infoDiv.className = 'pb-dm-alert pb-dm-alert-warning';
        });
    }

