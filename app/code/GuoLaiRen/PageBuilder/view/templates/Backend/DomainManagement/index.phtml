    function showDnsSwitchErrors(errors) {
        if (!errors || errors.length === 0) return;
        
        var errorHtml = '<div class="pb-dm-modal-overlay" id="pb-dm-dns-switch-errors-modal" onclick="if(event.target===this)closeDnsSwitchErrorsModal()">' +
            '<div class="pb-dm-modal pb-dm-modal-md">' +
            '<div class="pb-dm-modal-header">' +
            '<h3 style="color:var(--backend-color-danger,#f46a6a);"><i class="mdi mdi-alert-circle"></i> <?= __('DNS 切换失败详情') ?></h3>' +
            '<button class="pb-dm-modal-close" onclick="closeDnsSwitchErrorsModal()">&times;</button>' +
            '</div>' +
            '<div class="pb-dm-modal-body" style="max-height:60vh;overflow-y:auto;">' +
            '<div class="pb-dm-alert pb-dm-alert-warning" style="margin-bottom:16px;">' +
            '<i class="mdi mdi-information-outline"></i> ' +
            '<?= __('以下域名切换 DNS 服务器时发生错误，请根据提示修正后重试。') ?>' +
            '</div>' +
            '<div class="pb-dm-error-list">';
        
        errors.forEach(function(err, idx) {
            var parts = err.split(': ');
            var domain = parts[0] || '';
            var message = parts.slice(1).join(': ') || err;
            
            errorHtml += '<div class="pb-dm-error-item" style="padding:12px;background:var(--backend-color-bg-secondary,#f8f9fa);border-radius:8px;margin-bottom:8px;border-left:4px solid var(--backend-color-danger,#f46a6a);">';
            if (domain && domain !== message) {
                errorHtml += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">' +
                    '<i class="mdi mdi-domain" style="color:var(--backend-color-primary,#556ee6);"></i>' +
                    '<strong style="color:var(--backend-color-text-primary,#212529);">' + escapeHtml(domain) + '</strong>' +
                    '</div>';
            }
            errorHtml += '<p style="margin:0;font-size:0.9rem;color:var(--backend-color-text-secondary,#6c757d);line-height:1.5;">' +
                '<i class="mdi mdi-alert" style="color:var(--backend-color-danger,#f46a6a);"></i> ' +
                escapeHtml(message) +
                '</p>';
            errorHtml += '</div>';
        });
        
        errorHtml += '</div>' +
            '</div>' +
            '<div class="pb-dm-modal-footer" style="padding:12px 24px;border-top:1px solid var(--backend-color-border-default,#dee2e6);display:flex;justify-content:flex-end;">' +
            '<button class="pb-dm-btn pb-dm-btn-outline" onclick="closeDnsSwitchErrorsModal()">' +
            '<i class="mdi mdi-close"></i> <?= __('关闭') ?>' +
            '</button>' +
            '</div>' +
            '</div>' +
            '</div>';
        
        var existing = document.getElementById('pb-dm-dns-switch-errors-modal');
        if (existing) existing.remove();
        document.body.insertAdjacentHTML('beforeend', errorHtml);
    }
    
    function closeDnsSwitchErrorsModal() {
        var modal = document.getElementById('pb-dm-dns-switch-errors-modal');
        if (modal) modal.remove();
    }

    /* 暴露批量切换DNS相关函数到全局，供 onclick 调用 */
    window.closeBatchNsModal = closeBatchNsModal;
    window.showDnsSwitchErrors = showDnsSwitchErrors;
    window.closeDnsSwitchErrorsModal = closeDnsSwitchErrorsModal;
    window.onPbDmNsModeChange = onPbDmNsModeChange;
    window.onPbDmNsAccountChange = onPbDmNsAccountChange;
    window.onPbDmNsProviderChange = onPbDmNsProviderChange;
    window.doBatchChangeNs = doBatchChangeNs;

    /* 暴露批量添加DNS记录相关函数到全局 */
    window.closeBatchAddDnsModal = closeBatchAddDnsModal;
    window.onBatchAddDnsUseServerIpChange = onBatchAddDnsUseServerIpChange;
    window.doBatchAddDnsRecords = doBatchAddDnsRecords;
    window.showBatchAddDnsErrors = showBatchAddDnsErrors;
    window.closeDnsErrorsModal = closeDnsErrorsModal;
    window.switchToAccountTab = switchToAccountTab;

    /* ========== 批量设置账户 ========== */
    var pbDmBatchSetAccountsSelectedIds = [];

    document.getElementById('pb-dm-batch-set-accounts-btn').addEventListener('click', function() {
        var selected = domainListState.items.filter(function(d) {
            return d.is_pulled && d.domain_id > 0;
        }).filter(function(d) {
            return domainListState.selectedDomains.indexOf(String(d.domain_id)) !== -1
                || domainListState.selectedDomains.indexOf(d.domain) !== -1;
        });

        if (selected.length === 0) {
            BackendToast.warning('<?= __('请选择要设置的已拉取域名') ?>');
            return;
        }

        pbDmBatchSetAccountsSelectedIds = selected.map(function(d) { return d.domain_id; });
        showBatchSetAccountsModal(selected.length);
    });

    function showBatchSetAccountsModal(count) {
        var html = '\
            <div class="pb-dm-modal-overlay" id="pb-dm-batch-set-accounts-modal">\
                <div class="pb-dm-modal pb-dm-modal-sm">\
                    <div class="pb-dm-modal-header">\
                        <h3><i class="mdi mdi-account-cog"></i> <?= __('批量设置账户') ?></h3>\
                        <button class="pb-dm-modal-close" onclick="closeBatchSetAccountsModal()">&times;</button>\
                    </div>\
                    <div class="pb-dm-modal-body">\
                        <div class="pb-dm-alert pb-dm-alert-info">\
                            <i class="mdi mdi-information-outline"></i>\
                            <?= __('为选中域名设置 DNS/CDN 管理账户。留空表示不修改该项。') ?>\
                        </div>\
                        <p class="pb-dm-text-muted"><?= __('已选择') ?> ' + count + ' <?= __('个域名') ?></p>\
                        \
                        <div class="pb-dm-form-group">\
                            <label class="pb-dm-label"><?= __('DNS 管理账户') ?></label>\
                            <select class="pb-dm-select" id="pb-dm-batch-set-dns-account">\
                                <option value=""><?= __('-- 不修改 --') ?></option>\
                                <option value="0"><?= __('清除（使用注册商账户）') ?></option>\
                            </select>\
                            <small class="pb-dm-text-muted"><?= __('用于管理 DNS 解析记录的账户') ?></small>\
                        </div>\
                        \
                        <div class="pb-dm-form-group">\
                            <label class="pb-dm-label"><?= __('CDN 管理账户') ?></label>\
                            <select class="pb-dm-select" id="pb-dm-batch-set-cdn-account">\
                                <option value=""><?= __('-- 不修改 --') ?></option>\
                                <option value="0"><?= __('清除') ?></option>\
                            </select>\
                            <small class="pb-dm-text-muted"><?= __('CDN 服务商账户（如 Cloudflare）') ?></small>\
                        </div>\
                    </div>\
                    <div class="pb-dm-modal-footer">\
                        <button class="pb-dm-btn pb-dm-btn-outline" onclick="closeBatchSetAccountsModal()"><?= __('取消') ?></button>\
                        <button class="pb-dm-btn pb-dm-btn-primary" id="pb-dm-batch-set-accounts-submit" onclick="doBatchSetAccounts()">\
                            <i class="mdi mdi-check"></i> <?= __('确认设置') ?>\
                        </button>\
                    </div>\
                </div>\
            </div>';

        document.body.insertAdjacentHTML('beforeend', html);
        loadDnsAccountsForBatchSet();
    }

    function closeBatchSetAccountsModal() {
        var modal = document.getElementById('pb-dm-batch-set-accounts-modal');
        if (modal) modal.remove();
    }

    function loadDnsAccountsForBatchSet() {
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' } };
        var req = window.Weline.Api.request(API.getDnsAccounts, opts);
        req.then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success && data.data) {
                    var dnsSelect = document.getElementById('pb-dm-batch-set-dns-account');
                    var cdnSelect = document.getElementById('pb-dm-batch-set-cdn-account');

                    if (dnsSelect) {
                        (data.data.dns_accounts || []).forEach(function(acc) {
                            var opt = document.createElement('option');
                            opt.value = acc.account_id;
                            opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                            dnsSelect.appendChild(opt);
                        });
                    }

                    if (cdnSelect) {
                        (data.data.cdn_accounts || []).forEach(function(acc) {
                            var opt = document.createElement('option');
                            opt.value = acc.account_id;
                            opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                            cdnSelect.appendChild(opt);
                        });
                    }
                }
            })
            .catch(function() {
                BackendToast.error('<?= __('加载账户列表失败') ?>');
            });
    }

    function doBatchSetAccounts() {
        if (pbDmBatchSetAccountsSelectedIds.length === 0) {
            BackendToast.warning('<?= __('请选择要设置的域名') ?>');
            return;
        }

        var dnsAccountId = document.getElementById('pb-dm-batch-set-dns-account').value;
        var cdnAccountId = document.getElementById('pb-dm-batch-set-cdn-account').value;

        if (dnsAccountId === '' && cdnAccountId === '') {
            BackendToast.warning('<?= __('请至少选择一个账户进行设置') ?>');
            return;
        }

        var submitBtn = document.getElementById('pb-dm-batch-set-accounts-submit');
        var params = { domain_ids: JSON.stringify(pbDmBatchSetAccountsSelectedIds) };
        if (dnsAccountId !== '') params.dns_account_id = dnsAccountId;
        if (cdnAccountId !== '') params.cdn_account_id = cdnAccountId;

        BackendToast.info('<?= __('正在设置账户...') ?>');
        if (submitBtn) submitBtn.disabled = true;

        postForm(API.batchSetAccounts, params).then(function(res) {
            if (submitBtn) submitBtn.disabled = false;
            if (res.success) {
                BackendToast.success(res.msg || '<?= __('设置成功') ?>');
                closeBatchSetAccountsModal();
                loadDomainList();
            } else {
                BackendToast.error(res.msg || '<?= __('设置失败') ?>');
            }
        }).catch(function() {
            if (submitBtn) submitBtn.disabled = false;
            BackendToast.error('<?= __('请求失败') ?>');
        });
    }

    /* 暴露批量设置账户相关函数到全局 */
    window.closeBatchSetAccountsModal = closeBatchSetAccountsModal;
    window.doBatchSetAccounts = doBatchSetAccounts;

    /* 暴露单条DNS记录管理相关函数到全局 */
    window.closeDnsManageModal = closeDnsManageModal;
    window.refreshDnsRecords = refreshDnsRecords;
    window.autoResolveDnsForCurrentDomain = autoResolveDnsForCurrentDomain;
    window.showAddDnsRecordForm = showAddDnsRecordForm;
    window.hideAddDnsRecordForm = hideAddDnsRecordForm;
    window.saveNewDnsRecord = saveNewDnsRecord;
    window.deleteDnsRecord = deleteDnsRecord;

})();
</script>
