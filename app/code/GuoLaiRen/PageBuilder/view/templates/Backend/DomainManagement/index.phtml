    var pageSizeSelect = document.getElementById('pb-dm-page-size');

    function loadDomainList() {
        domainListState.accountId = parseInt(document.getElementById('pb-dm-domain-acct').value) || 0;
        domainListState.status = document.getElementById('pb-dm-domain-status').value;
        domainListState.search = document.getElementById('pb-dm-domain-search').value.trim();
        domainListState.limit = parseInt(pageSizeSelect.value) || 20;

        domainContainer.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-loading mdi-spin"></i><p><?= __('正在从域名商获取数据...') ?></p></div>';

        var data = {
            account_id: domainListState.accountId,
            status: domainListState.status,
            search: domainListState.search,
            page: domainListState.page,
            limit: domainListState.limit
        };

        postForm(API.getDomains, data).then(function(res) {
            if (!res.success) {
                BackendToast.error(res.msg || '<?= __('加载失败') ?>');
                domainContainer.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-alert-circle-outline"></i><p>' + (res.msg || '<?= __('加载失败') ?>') + '</p></div>';
                return;
            }
            var result = res.data || {};
            domainListState.total = result.total || 0;
            domainListState.pages = result.pages || 0;
            domainListState.page = result.page || 1;
            domainListState.accounts = result.accounts || {};
            domainListState.items = result.items || [];
            domainListState.groups = result.groups || [];
            domainListState.selectedDomains = [];

            renderDomainAccordion(domainListState.groups);
            updatePagination();
            updateBatchBar();
        }).catch(function() {
            BackendToast.error('<?= __('网络错误') ?>');
            domainContainer.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-alert-circle-outline"></i><p><?= __('网络错误') ?></p></div>';
        });
    }

    function renderPulledStatusBadge(isPulled) {
        if (isPulled) {
            return '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('已拉取') ?></span>';
        }
        return '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('未拉取') ?></span>';
    }

    function renderDomainStatusBadge(status) {
        var statusMap = {
            'active': ['<?= __('正常') ?>', 'pb-dm-badge--ok'],
            'pending': ['<?= __('处理中') ?>', 'pb-dm-badge--warn'],
            'expired': ['<?= __('已过期') ?>', 'pb-dm-badge--no'],
            'suspended': ['<?= __('已暂停') ?>', 'pb-dm-badge--no']
        };
        var key = status ? String(status).toLowerCase() : '';
        var mapped = statusMap[key] || [status || '-', 'pb-dm-badge--info'];
        return '<span class="pb-dm-badge ' + mapped[1] + '">' + mapped[0] + '</span>';
    }

    function renderDomainAccordion(groups) {
        if (!groups || groups.length === 0) {
            domainContainer.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-domain"></i><p><?= __('暂无域名数据') ?></p></div>';
            paginationEl.style.display = 'none';
            return;
        }

        var html = '';

        groups.forEach(function(group, gIdx) {
