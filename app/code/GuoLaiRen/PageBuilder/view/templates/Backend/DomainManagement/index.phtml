    function doBatchAddDnsRecords() {
        if (pbDmBatchAddDnsSelectedIds.length === 0) {
            BackendToast.warning('<?= __('请选择要添加DNS记录的域名') ?>');
            return;
        }

        var useServerIp = document.getElementById('pb-dm-batch-add-dns-use-server-ip').checked;
        var submitBtn = document.getElementById('pb-dm-batch-add-dns-submit');
        var params = {
            domain_ids: JSON.stringify(pbDmBatchAddDnsSelectedIds),
            use_server_ip: useServerIp ? '1' : '0'
        };

        if (useServerIp) {
            params.host = document.getElementById('pb-dm-batch-add-dns-host-server').value || '@';
            params.ttl = document.getElementById('pb-dm-batch-add-dns-ttl-server').value || 600;
        } else {
            var value = document.getElementById('pb-dm-batch-add-dns-value').value.trim();
            if (!value) {
                BackendToast.warning('<?= __('请输入记录值') ?>');
                return;
            }
            params.type = document.getElementById('pb-dm-batch-add-dns-type').value;
            params.host = document.getElementById('pb-dm-batch-add-dns-host').value || '@';
            params.value = value;
            params.ttl = document.getElementById('pb-dm-batch-add-dns-ttl').value || 600;
        }

        BackendToast.info('<?= __('正在批量添加DNS记录...') ?>');
        if (submitBtn) submitBtn.disabled = true;

        postForm(API.batchAddDnsRecords, params).then(function(res) {
            if (submitBtn) submitBtn.disabled = false;
            var code = res.code || (res.success ? 200 : 400);
            var msg = res.msg || res.message || '<?= __('添加完成') ?>';
            var hasErrors = res.data && res.data.errors && res.data.errors.length > 0;
            var dnsHints = res.data && res.data.dns_provider_hints ? res.data.dns_provider_hints : {};
            
            if (code === 200) {
                BackendToast.success(msg);
                closeBatchAddDnsModal();
                loadDomainList();
            } else if (code === 206) {
                // 部分成功
                BackendToast.warning(msg);
                closeBatchAddDnsModal();
                if (hasErrors) {
                    showBatchAddDnsErrors(res.data.errors, dnsHints);
                }
                loadDomainList();
            } else {
                // 全部失败
                BackendToast.error(msg);
                closeBatchAddDnsModal();
                if (hasErrors) {
                    showBatchAddDnsErrors(res.data.errors, dnsHints);
                }
            }
        }).catch(function() {
            if (submitBtn) submitBtn.disabled = false;
            BackendToast.error('<?= __('网络错误') ?>');
        });
    }

    function showBatchAddDnsErrors(errors, dnsProviderHints) {
        if (!errors || errors.length === 0) return;
        
        dnsProviderHints = dnsProviderHints || {};
        var hasHints = Object.keys(dnsProviderHints).length > 0;
        
        var errorHtml = '<div class="pb-dm-modal-overlay" id="pb-dm-dns-errors-modal" onclick="if(event.target===this)closeDnsErrorsModal()">' +
            '<div class="pb-dm-modal pb-dm-modal-md">' +
            '<div class="pb-dm-modal-header">' +
            '<h3><i class="mdi mdi-alert-circle" style="color:var(--backend-color-danger,#f46a6a);"></i> <?= __('DNS 添加失败详情') ?></h3>' +
            '<button class="pb-dm-modal-close" onclick="closeDnsErrorsModal()">&times;</button>' +
            '</div>' +
            '<div class="pb-dm-modal-body" style="max-height:500px;overflow-y:auto;">';
        
        // 显示 DNS 服务商提示（如果有）
        if (hasHints) {
            errorHtml += '<div class="pb-dm-dns-hints" style="margin-bottom:16px;">';
            for (var domain in dnsProviderHints) {
                var hint = dnsProviderHints[domain];
                var iconClass = hint.has_account ? 'mdi-swap-horizontal' : 'mdi-plus-circle';
                var badgeClass = hint.provider === 'cloudflare' ? 'pb-dm-badge--cf' : 'pb-dm-badge--info';
                
                errorHtml += '<div class="pb-dm-dns-hint-item" style="padding:12px;background:var(--backend-color-bg-secondary,#f8f9fa);border-radius:8px;margin-bottom:8px;border-left:4px solid var(--backend-color-warning,#f1b44c);">' +
                    '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">' +
                    '<i class="mdi mdi-domain" style="color:var(--backend-color-primary,#556ee6);"></i>' +
                    '<strong style="color:var(--backend-color-text-primary,#212529);">' + escapeHtml(domain) + '</strong>' +
                    '<span class="pb-dm-badge ' + badgeClass + '" style="font-size:0.75rem;">' + escapeHtml(hint.provider_name) + '</span>' +
                    '</div>' +
                    '<p style="margin:0 0 8px 0;font-size:0.9rem;color:var(--backend-color-text-secondary,#6c757d);">' + escapeHtml(hint.message) + '</p>';
                
                if (hint.nameservers && hint.nameservers.length > 0) {
                    errorHtml += '<div style="font-size:0.8rem;color:var(--backend-color-text-tertiary,#adb5bd);">' +
                        '<i class="mdi mdi-dns"></i> Nameservers: <code style="font-size:0.75rem;">' + escapeHtml(hint.nameservers.join(', ')) + '</code>' +
                        '</div>';
                }
                
                if (!hint.has_account && hint.action === 'add_account') {
                    errorHtml += '<div style="margin-top:8px;">' +
                        '<button class="pb-dm-btn pb-dm-btn-sm pb-dm-btn-warning" onclick="closeDnsErrorsModal();switchToAccountTab(\'' + escapeHtml(hint.provider) + '\')">' +
                        '<i class="mdi ' + iconClass + '"></i> <?= __('添加') ?> ' + escapeHtml(hint.provider_name) + ' <?= __('账户') ?>' +
                        '</button>' +
                        '</div>';
                }
                
                errorHtml += '</div>';
            }
            errorHtml += '</div>';
        } else {
            errorHtml += '<div class="pb-dm-alert pb-dm-alert-warning" style="margin-bottom:12px;">' +
                '<i class="mdi mdi-information-outline"></i>' +
                '<div><?= __('以下域名的 DNS 记录添加失败，可能原因：域名 DNS 已切换到其他服务商，需要到对应服务商处添加解析记录。') ?></div>' +
                '</div>';
        }
        
        // 显示错误列表
        errorHtml += '<div style="margin-top:12px;">' +
            '<p style="font-weight:500;color:var(--backend-color-text-primary,#212529);margin-bottom:8px;"><?= __('错误详情') ?>:</p>' +
            '<ul style="margin:0;padding-left:20px;color:var(--backend-color-text-secondary,#6c757d);font-size:0.85rem;line-height:1.8;">';
        
        errors.forEach(function(err) {
            errorHtml += '<li style="word-break:break-all;">' + escapeHtml(err) + '</li>';
        });
        
        errorHtml += '</ul></div></div>' +
            '<div class="pb-dm-modal-footer">' +
            '<button class="pb-dm-btn pb-dm-btn-primary" onclick="closeDnsErrorsModal()"><?= __('我知道了') ?></button>' +
            '</div></div></div>';
        
        document.body.insertAdjacentHTML('beforeend', errorHtml);
    }
    
    function switchToAccountTab(providerCode) {
        // 切换到供应商账户 Tab 并打开添加弹窗
        var accountTab = document.querySelector('[data-tab="accounts"]');
        if (accountTab) {
            accountTab.click();
            setTimeout(function() {
                // 查找添加账户按钮（ID 为 pb-dm-add-account-btn）
                var addBtn = document.getElementById('pb-dm-add-account-btn');
                if (addBtn) {
                    addBtn.click();
                    // 预选供应商类型
                    setTimeout(function() {
                        var registrarSelect = document.getElementById('pb-dm-registrar');
                        if (registrarSelect && providerCode) {
                            // 尝试设置供应商类型
                            var options = registrarSelect.options;
                            for (var i = 0; i < options.length; i++) {
                                if (options[i].value.toLowerCase() === providerCode.toLowerCase()) {
                                    registrarSelect.value = options[i].value;
                                    registrarSelect.dispatchEvent(new Event('change'));
                                    break;
                                }
                            }
                        }
                    }, 300);
                } else {
                    // 如果找不到按钮，显示提示
                    BackendToast.info('<?= __('请点击"添加账户"按钮添加') ?> ' + providerCode.toUpperCase() + ' <?= __('供应商账户') ?>');
                }
            }, 200);
        }
    }

    function closeDnsErrorsModal() {
        var modal = document.getElementById('pb-dm-dns-errors-modal');
        if (modal) modal.remove();
    }

    /* 页面加载时自动加载域名列表 */
    document.addEventListener('DOMContentLoaded', function() {
        setTimeout(function() { loadDomainList(); }, 300);
    });

    /* ========== 批量搜索 ========== */
    var batchSearchModal = document.getElementById('pb-dm-batch-search-modal');
    var batchSearchInput = document.getElementById('pb-dm-batch-search-input');
    var batchSearchResult = document.getElementById('pb-dm-batch-search-result');
    var batchSearchList = document.getElementById('pb-dm-batch-search-list');
    var batchFoundCount = document.getElementById('pb-dm-batch-found-count');
    var batchTotalCount = document.getElementById('pb-dm-batch-total-count');
    var batchSearchPullBtn = document.getElementById('pb-dm-batch-search-pull');
    var batchSearchExecBtn = document.getElementById('pb-dm-batch-search-exec');
    var batchSearchFoundDomains = [];

    function openBatchSearchModal() {
        batchSearchInput.value = '';
        batchSearchResult.style.display = 'none';
        batchSearchList.innerHTML = '';
        batchSearchPullBtn.style.display = 'none';
        batchSearchExecBtn.style.display = '';
        batchSearchFoundDomains = [];
        batchSearchModal.classList.add('pb-dm-form-modal--open');
    }

    function closeBatchSearchModal() {
        batchSearchModal.classList.remove('pb-dm-form-modal--open');
    }

    document.getElementById('pb-dm-batch-search-btn').addEventListener('click', function() {
        openBatchSearchModal();
    });

    document.getElementById('pb-dm-batch-search-close').addEventListener('click', closeBatchSearchModal);
    document.getElementById('pb-dm-batch-search-cancel').addEventListener('click', closeBatchSearchModal);
    batchSearchModal.addEventListener('click', function(e) { if (e.target === batchSearchModal) closeBatchSearchModal(); });

    batchSearchExecBtn.addEventListener('click', function() {
        var rawText = batchSearchInput.value.trim();
        if (!rawText) {
            BackendToast.warning('<?= __('请输入要搜索的域名') ?>');
            return;
        }

        var searchDomains = rawText.split(/[\r\n,;]+/).map(function(s) { return s.trim().toLowerCase(); }).filter(function(s) { return s.length > 0; });
        searchDomains = [...new Set(searchDomains)];

        if (searchDomains.length === 0) {
            BackendToast.warning('<?= __('请输入有效的域名') ?>');
            return;
        }

        batchTotalCount.textContent = searchDomains.length;
        setBtnLoading(batchSearchExecBtn, true);

        fetchAllRemoteDomains(domainListState.accountId).then(function(remoteItems) {
            setBtnLoading(batchSearchExecBtn, false, '<i class="mdi mdi-magnify"></i> <?= __('搜索') ?>');

            var remoteMap = {};
            remoteItems.forEach(function(item) {
                remoteMap[item.domain.toLowerCase()] = item;
            });

            batchSearchFoundDomains = [];
            var notFound = [];
            searchDomains.forEach(function(d) {
                if (remoteMap[d]) {
                    batchSearchFoundDomains.push(remoteMap[d]);
                } else {
                    notFound.push(d);
                }
            });

            batchFoundCount.textContent = batchSearchFoundDomains.length;
            renderBatchSearchList(batchSearchFoundDomains, notFound);
            batchSearchResult.style.display = 'block';

            if (batchSearchFoundDomains.length > 0) {
                batchSearchPullBtn.style.display = '';
                batchSearchExecBtn.style.display = 'none';
            }
        }).catch(function(err) {
            setBtnLoading(batchSearchExecBtn, false, '<i class="mdi mdi-magnify"></i> <?= __('搜索') ?>');
            BackendToast.error(err || '<?= __('网络错误') ?>');
        });
    });

    function fetchAllRemoteDomains(accountId) {
        return new Promise(function(resolve, reject) {
            var allItems = [];
            var page = 1;
            var pageSize = 500;

            function fetchPage() {
                postForm(API.getDomains, {
                    account_id: accountId,
                    page: page,
                    limit: pageSize
                }).then(function(res) {
                    if (!res.success) {
                        reject(res.msg || '<?= __('获取域名列表失败') ?>');
                        return;
                    }

                    var items = res.data.items || [];
                    allItems = allItems.concat(items);

                    var totalPages = res.data.pages || 1;
                    if (page < totalPages) {
                        page++;
                        fetchPage();
                    } else {
                        resolve(allItems);
                    }
                }).catch(function() {
                    reject('<?= __('网络错误') ?>');
                });
            }

            fetchPage();
        });
    }

    function renderBatchSearchList(foundList, notFoundList) {
        var html = '<table class="pb-dm-table" style="margin:0;"><thead><tr>' +
            '<th style="width:40px;"><input type="checkbox" id="pb-dm-batch-chk-all" checked></th>' +
            '<th><?= __('域名') ?></th>' +
            '<th><?= __('本地状态') ?></th>' +
            '<th><?= __('域名状态') ?></th>' +
            '</tr></thead><tbody>';

        foundList.forEach(function(d) {
            var isPulled = d.is_pulled === true || d.is_pulled === 1;
            var pullBadge = renderPulledStatusBadge(isPulled);
            var checkboxDisabled = isPulled ? ' disabled' : '';
            var checkboxChecked = isPulled ? '' : ' checked';

            html += '<tr>' +
                '<td><input type="checkbox" class="pb-dm-batch-chk" data-domain="' + escapeHtml(d.domain) + '" data-pulled="' + (isPulled ? '1' : '0') + '"' + checkboxDisabled + checkboxChecked + '></td>' +
                '<td><strong>' + escapeHtml(d.domain) + '</strong></td>' +
                '<td>' + pullBadge + '</td>' +
                '<td><span class="pb-dm-badge pb-dm-badge--ok"><?= __('存在') ?></span></td>' +
                '</tr>';
        });

        notFoundList.forEach(function(d) {
            html += '<tr style="opacity:0.5;">' +
                '<td><input type="checkbox" disabled></td>' +
                '<td>' + escapeHtml(d) + '</td>' +
                '<td>-</td>' +
                '<td><span class="pb-dm-badge pb-dm-badge--no"><?= __('不存在') ?></span></td>' +
                '</tr>';
        });

        html += '</tbody></table>';
        batchSearchList.innerHTML = html;

        var chkAll = document.getElementById('pb-dm-batch-chk-all');
        var chks = batchSearchList.querySelectorAll('.pb-dm-batch-chk:not(:disabled)');

        if (chkAll) {
            chkAll.addEventListener('change', function() {
                chks.forEach(function(c) { c.checked = chkAll.checked; });
            });
        }
    }

    document.getElementById('pb-dm-batch-select-all-found').addEventListener('change', function() {
        var checked = this.checked;
        batchSearchList.querySelectorAll('.pb-dm-batch-chk:not(:disabled)').forEach(function(c) {
            c.checked = checked;
        });
        var chkAll = document.getElementById('pb-dm-batch-chk-all');
        if (chkAll) chkAll.checked = checked;
    });

    batchSearchPullBtn.addEventListener('click', function() {
        var selectedDomains = [];
        batchSearchList.querySelectorAll('.pb-dm-batch-chk:checked').forEach(function(c) {
            selectedDomains.push(c.dataset.domain);
        });

        if (selectedDomains.length === 0) {
            BackendToast.warning('<?= __('请选择要拉取的域名') ?>');
            return;
        }

        var autoResolveCheckbox = document.getElementById('pb-dm-batch-pull-auto-resolve');
        var autoResolve = autoResolveCheckbox ? autoResolveCheckbox.checked : true;

        setBtnLoading(batchSearchPullBtn, true);

        postForm(API.pullDomains, {
            account_id: domainListState.accountId,
            domains: selectedDomains,
            auto_resolve: autoResolve ? '1' : '0'
        }).then(function(res) {
            setBtnLoading(batchSearchPullBtn, false, '<i class="mdi mdi-download"></i> <?= __('拉取选中') ?>');
            if (res.success) {
                var msg = res.message || '<?= __('拉取成功') ?>';
                if (autoResolve && res.auto_resolve_queued) {
                    msg += ' <?= __('（自动解析任务已创建）') ?>';
                }
                BackendToast.success(msg);
                closeBatchSearchModal();
                loadDomainList();
            } else {
                BackendToast.error(res.message || res.msg || '<?= __('拉取失败') ?>');
            }
        }).catch(function() {
            setBtnLoading(batchSearchPullBtn, false, '<i class="mdi mdi-download"></i> <?= __('拉取选中') ?>');
            BackendToast.error('<?= __('网络错误') ?>');
        });
    });

    /* ========== 域名注册 ========== */
    var checkResults = document.getElementById('pb-dm-check-results');

    document.getElementById('pb-dm-check-btn').addEventListener('click', function() {
        var btn = this;
        var accountId = document.getElementById('pb-dm-reg-acct').value;
        var domainsText = document.getElementById('pb-dm-reg-domains').value.trim();
        if (!accountId || !domainsText) {
            BackendToast.warning('<?= __('请选择账户并输入域名') ?>');
            return;
        }
        setBtnLoading(btn, true);
        postForm(API.checkAvail, { account_id: accountId, domains: domainsText }).then(function(res) {
            setBtnLoading(btn, false, '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>');
            if (!res.success) {
                BackendToast.error(res.msg || '<?= __('检查失败') ?>');
                return;
            }
            renderCheckResults(res.data || [], accountId);
        }).catch(function() {
            setBtnLoading(btn, false, '<i class="mdi mdi-magnify"></i> <?= __('检查可用性') ?>');
            BackendToast.error('<?= __('网络错误') ?>');
        });
    });

    function renderCheckResults(results, accountId) {
        if (!results.length) {
            checkResults.innerHTML = '<div class="pb-dm-empty"><p><?= __('无检查结果') ?></p></div>';
            return;
        }

        var availCount = results.filter(function(r) { return r.available; }).length;
        var html = '<div style="margin:12px 0;display:flex;align-items:center;justify-content:space-between;">' +
            '<span style="color:var(--backend-color-text-secondary,#6c757d);font-size:0.9rem;">' +
            '<?= __('共') ?> ' + results.length + ' <?= __('个域名，') ?>' +
            '<strong style="color:var(--backend-color-success,#34c38f)">' + availCount + '</strong> <?= __('个可注册') ?></span>';

        if (availCount > 0) {
            html += '<button class="pb-dm-btn pb-dm-btn-success" id="pb-dm-batch-buy-btn">' +
                '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?> (' + availCount + ')</button>';
        }
        html += '</div>';

        html += '<table class="pb-dm-table"><thead><tr>' +
            '<th><input type="checkbox" id="pb-dm-select-all"></th>' +
            '<th><?= __('域名') ?></th><th><?= __('状态') ?></th><th><?= __('价格') ?></th><th><?= __('操作') ?></th>' +
            '</tr></thead><tbody>';

        results.forEach(function(item, idx) {
            var badge;
            if (item.available) {
                badge = '<span class="pb-dm-badge pb-dm-badge--ok">' + (item.premium ? '<?= __('溢价可注册') ?>' : '<?= __('可注册') ?>') + '</span>';
            } else if (item.message) {
                badge = '<span class="pb-dm-badge pb-dm-badge--error" title="' + item.message.replace(/"/g, '&quot;') + '">' +
                    '<i class="mdi mdi-alert-circle"></i> <?= __('查询失败') ?></span>' +
                    '<div class="pb-dm-error-detail">' + item.message + '</div>';
            } else {
                badge = '<span class="pb-dm-badge pb-dm-badge--no"><?= __('已注册') ?></span>';
            }
            var price = item.price ? ('$' + parseFloat(item.price).toFixed(2)) : '-';
            var action = item.available
                ? '<button class="pb-dm-btn pb-dm-btn-success pb-dm-btn-sm pb-dm-buy-one" ' +
                  'data-domain="' + item.domain + '" data-account="' + accountId + '">' +
                  '<i class="mdi mdi-cart"></i> <?= __('购买') ?></button>'
                : '-';
            var chk = item.available
                ? '<input type="checkbox" class="pb-dm-domain-chk" data-domain="' + item.domain + '" checked>'
                : '<input type="checkbox" disabled>';
            html += '<tr><td>' + chk + '</td><td>' + item.domain + '</td><td>' + badge + '</td><td>' + price + '</td><td>' + action + '</td></tr>';
        });
        html += '</tbody></table>';
        checkResults.innerHTML = html;

        /* 全选 */
        var selectAll = document.getElementById('pb-dm-select-all');
        if (selectAll) {
            selectAll.addEventListener('change', function() {
                var checked = selectAll.checked;
                checkResults.querySelectorAll('.pb-dm-domain-chk').forEach(function(c) { c.checked = checked; });
            });
        }

        /* 单个购买 */
        checkResults.querySelectorAll('.pb-dm-buy-one').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var domain = btn.dataset.domain;
                var acctId = btn.dataset.account;
                openPurchaseDialog({
                    dnsChoice: 'follow_registrar',
                    cdnChoice: 'follow_registrar',
                    resolveToLocal: !!(document.getElementById('pb-dm-auto-resolve') && document.getElementById('pb-dm-auto-resolve').checked),
                    subdomains: '@,www',
                    startLifecycle: true
                }).then(function(dialogResult) {
                    if (!dialogResult) return;
                    setBtnLoading(btn, true);
                    var autoResolve = dialogResult.resolve_to_local === 'yes' ? '1' : '0';
                    postForm(API.purchase, {
                        account_id: acctId,
                        domain: domain,
                        years: '1',
                        auto_resolve: autoResolve,
                        resolve_to_local: dialogResult.resolve_to_local || 'yes',
                        subdomains: dialogResult.subdomains || '@,www',
                        dns_choice: dialogResult.dns_choice || 'follow_registrar',
                        dns_provider: dialogResult.dns_provider || '',
                        dns_account_id: dialogResult.dns_account_id || '',
                        dns_nameservers: dialogResult.dns_nameservers || '',
                        cdn_choice: dialogResult.cdn_choice || 'follow_registrar',
                        cdn_provider: dialogResult.cdn_provider || '',
                        cdn_account_id: dialogResult.cdn_account_id || '',
                        start_lifecycle: dialogResult.start_lifecycle || '1'
                    }).then(function(res) {
                        if (res.success) {
                            var msg = res.message || res.msg || '<?= __('购买成功') ?>';
                            if (autoResolve === '1') {
                                msg += ' <?= __('（自动解析任务已创建）') ?>';
                            }
                            if (dialogResult.start_lifecycle === '1') {
                                msg += ' <?= __('请前往域名状态页搜索当前根域名查看进度。') ?>';
                            }
                            BackendToast.success(msg);
                            var results = (res.results || []);
                            var lifecycleFails = results.filter(function(r) {
                                return r && r.success && r.lifecycle && r.lifecycle.attempted && !r.lifecycle.success;
                            });
                            if (lifecycleFails.length > 0) {
                                BackendToast.warning(
                                    '<?= __('%{count} 个域名未成功创建生命周期订单，请确认 Weline_Saas 已启用，或前往「域名状态」页使用补建功能。') ?>'.replace('%{count}', lifecycleFails.length)
                                );
                            }
                            btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已购买') ?>';
                            btn.disabled = true;
                            /* 购买成功后自动拉取到本地 */
                            postForm(API.pullDomains, {
                                account_id: acctId,
                                domains: [domain],
                                auto_resolve: autoResolve
                            }).then(function(pullRes) {
                                if (pullRes && pullRes.success) {
                                    loadDomainList();
                                }
                            }).catch(function() {});
                        } else {
                            setBtnLoading(btn, false, '<i class="mdi mdi-cart"></i> <?= __('购买') ?>');
                            BackendToast.error(getPurchaseErrorMsg(res));
                        }
                    }).catch(function() {
                        setBtnLoading(btn, false, '<i class="mdi mdi-cart"></i> <?= __('购买') ?>');
                        BackendToast.error('<?= __('网络错误') ?>');
                    });
                });
            });
        });

        /* 批量购买 */
        var batchBtn = document.getElementById('pb-dm-batch-buy-btn');
        if (batchBtn) {
            batchBtn.addEventListener('click', function() {
                var selected = [];
                checkResults.querySelectorAll('.pb-dm-domain-chk:checked').forEach(function(c) {
                    selected.push({ domain: c.dataset.domain, years: 1 });
                });
                if (!selected.length) {
                    BackendToast.warning('<?= __('请勾选要购买的域名') ?>');
                    return;
                }
                openPurchaseDialog({
                    dnsChoice: 'follow_registrar',
                    cdnChoice: 'follow_registrar',
                    resolveToLocal: !!(document.getElementById('pb-dm-auto-resolve') && document.getElementById('pb-dm-auto-resolve').checked),
                    subdomains: '@,www',
                    startLifecycle: true
                }).then(function(dialogResult) {
                    if (!dialogResult) return;
                    setBtnLoading(batchBtn, true);
                    var autoResolve = dialogResult.resolve_to_local === 'yes' ? '1' : '0';
                    postForm(API.batchPurchase, {
                        account_id: accountId,
                        domains: selected,
                        auto_resolve: autoResolve,
                        resolve_to_local: dialogResult.resolve_to_local || 'yes',
                        subdomains: dialogResult.subdomains || '@,www',
                        dns_choice: dialogResult.dns_choice || 'follow_registrar',
                        dns_provider: dialogResult.dns_provider || '',
                        dns_account_id: dialogResult.dns_account_id || '',
                        dns_nameservers: dialogResult.dns_nameservers || '',
                        cdn_choice: dialogResult.cdn_choice || 'follow_registrar',
                        cdn_provider: dialogResult.cdn_provider || '',
                        cdn_account_id: dialogResult.cdn_account_id || '',
                        start_lifecycle: dialogResult.start_lifecycle || '1'
                    }).then(function(res) {
                        setBtnLoading(batchBtn, false, '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?>');
                        if (res.success) {
                            var msg = res.message || res.msg || '<?= __('批量购买已提交') ?>';
                            if (autoResolve === '1') {
                                msg += ' <?= __('（自动解析任务已创建）') ?>';
                            }
                            if (dialogResult.start_lifecycle === '1') {
                                msg += ' <?= __('请前往域名状态页搜索当前根域名查看进度。') ?>';
                            }
                            BackendToast.success(msg);
                            var results = (res.results || []);
                            var lifecycleFails = results.filter(function(r) {
                                return r && r.success && r.lifecycle && r.lifecycle.attempted && !r.lifecycle.success;
                            });
                            if (lifecycleFails.length > 0) {
                                BackendToast.warning(
                                    '<?= __('%{count} 个域名未成功创建生命周期订单，请确认 Weline_Saas 已启用，或前往「域名状态」页使用补建功能。') ?>'.replace('%{count}', lifecycleFails.length)
                                );
                            }
                            /* 购买成功后自动拉取到本地 */
                            var successfulDomains = results.filter(function(r) { return r && r.success && r.domain; }).map(function(r) { return r.domain; });
                            if (successfulDomains.length > 0) {
                                postForm(API.pullDomains, {
                                    account_id: accountId,
                                    domains: successfulDomains,
                                    auto_resolve: autoResolve
                                }).then(function(pullRes) {
                                    if (pullRes && pullRes.success) {
                                        loadDomainList();
                                    }
                                }).catch(function() {});
                            }
                        } else {
                            BackendToast.error(getPurchaseErrorMsg(res));
                        }
                    }).catch(function() {
                        setBtnLoading(batchBtn, false, '<i class="mdi mdi-cart-arrow-down"></i> <?= __('一键购买全部可用域名') ?>');
                        BackendToast.error('<?= __('网络错误') ?>');
                    });
                });
            });
        }
    }

    /* ========== 域名池功能 ========== */
    var poolState = {
        page: 1,
        limit: 20,
        total: 0,
        pages: 0,
        search: '',
        status: '',
        resolve: '',
        items: []
    };

    function loadDomainPool(page) {
        poolState.page = page || 1;
        poolState.search = document.getElementById('pb-dm-pool-search').value.trim();
        poolState.status = document.getElementById('pb-dm-pool-status').value;
        poolState.resolve = document.getElementById('pb-dm-pool-resolve').value;
        poolState.limit = parseInt(document.getElementById('pb-dm-pool-page-size').value) || 20;

        var container = document.getElementById('pb-dm-pool-container');
        container.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-loading mdi-spin" style="font-size:2rem;"></i><p><?= __('加载中...') ?></p></div>';

        postForm(API.getDomainPool, {
            page: poolState.page,
            limit: poolState.limit,
            search: poolState.search,
            status: poolState.status,
            resolve_status: poolState.resolve,
            // 域名刚入池时通常还未达到可建站状态，默认先展示全部，避免看起来“空池子”。
            site_ready_only: 'false'
        }).then(function(res) {
            if (res.success && res.data) {
                var items = Array.isArray(res.data) ? res.data : (res.data.items || []);
                var total = (typeof res.total === 'number') ? res.total : (res.data.total || items.length || 0);
                var pages = (typeof res.pages === 'number') ? res.pages : (res.data.pages || Math.ceil(total / poolState.limit) || 0);

                poolState.total = total;
                poolState.pages = pages;
                poolState.items = items;
                renderDomainPool(items);
                updatePoolPagination();
            } else {
                container.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-alert-circle" style="font-size:2rem;color:var(--backend-color-danger);"></i><p>' + (res.msg || '<?= __('加载失败') ?>') + '</p></div>';
            }
        }).catch(function() {
            container.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-alert-circle" style="font-size:2rem;color:var(--backend-color-danger);"></i><p><?= __('网络错误') ?></p></div>';
        });
    }

    function renderResolveStatusBadge(item) {
        var status = (item && item.resolve_status) ? String(item.resolve_status).toLowerCase() : '';
        var isLocal = String((item && item.is_local_server) ? item.is_local_server : '0') === '1';

        if (status === 'resolved') {
            if (isLocal) {
                return '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('解析正常') ?></span>';
            }
            return '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('指向外部') ?></span>';
        }
        if (status === 'error') {
            return '<span class="pb-dm-badge pb-dm-badge--no"><?= __('解析失败') ?></span>';
        }
        return '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('等待解析') ?></span>';
    }

    function renderHttpsStatusBadge(item) {
        var status = (item && item.https_status) ? String(item.https_status).toLowerCase() : '';
        if (status === 'valid') {
            return '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('有效') ?></span>';
        }
        if (status === 'pending') {
            return '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('申请中') ?></span>';
        }
        return '<span class="pb-dm-badge pb-dm-badge--no"><?= __('无') ?></span>';
    }

    function renderSiteReadyBadge(item) {
        var status = (item && item.status) ? String(item.status).toLowerCase() : '';
        var siteReady = String((item && item.site_ready) ? item.site_ready : '0') === '1';

        if (siteReady) {
            return '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('可建站') ?></span>';
        }
        if (status !== '' && status !== 'active') {
            return '<span class="pb-dm-badge pb-dm-badge--no"><?= __('不可用') ?></span>';
        }
        return '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('等待中') ?></span>';
    }

    function renderSiteCreatedBadge(item) {
        var siteCreated = String((item && item.site_created) ? item.site_created : '0') === '1';

        if (siteCreated) {
            return '<span class="pb-dm-badge pb-dm-badge--info"><?= __('已建站') ?></span>';
        }
        return '<span class="pb-dm-badge pb-dm-badge--no"><?= __('未使用') ?></span>';
    }

    function renderLifecycleStepBadge(step) {
        var status = step && step.status ? String(step.status).toLowerCase() : 'pending';
        var label = step && step.step_name ? String(step.step_name) : 'pending';

        if (status === 'success') {
            return '<span class="pb-dm-badge pb-dm-badge--ok">' + escapeHtml(label) + '</span>';
        }
        if (status === 'failed') {
            return '<span class="pb-dm-badge pb-dm-badge--error">' + escapeHtml(label) + '</span>';
        }
        if (status === 'running') {
            return '<span class="pb-dm-badge pb-dm-badge--warn">' + escapeHtml(label) + '</span>';
        }
        if (status === 'skipped') {
            return '<span class="pb-dm-badge pb-dm-badge--info">' + escapeHtml(label) + '</span>';
        }
        return '<span class="pb-dm-badge">' + escapeHtml(label) + '</span>';
    }

    function renderLifecycleStatus(data) {
        var container = document.getElementById('pb-dm-lifecycle-result');
        if (!data || !data.order) {
            container.innerHTML = '<div class="pb-dm-empty"><?= __('未找到生命周期数据') ?></div>';
            return;
        }

        var steps = {};
        (data.steps || []).forEach(function(step) {
            if (!step || !step.step_name || step.step_name === 'lifecycle_options') {
                return;
            }
            steps[step.step_name] = step;
        });

        var html = '<div class="pb-dm-lifecycle-grid">';
        html += '<div class="pb-dm-lifecycle-item">' +
            '<div><strong><?= __('根域') ?>:</strong> ' + escapeHtml(data.order.domain || '') + '</div>' +
            '<div style="margin-top:6px;"><strong><?= __('当前步骤') ?>:</strong> ' + escapeHtml(data.order.current_step || '-') + '</div>' +
            '<div style="margin-top:6px;"><strong><?= __('订单状态') ?>:</strong> ' + escapeHtml(data.order.status || '-') + '</div>' +
            (data.order.error_message ? '<div style="margin-top:6px;color:var(--backend-color-danger,#f46a6a);"><strong><?= __('异常') ?>:</strong> ' + escapeHtml(data.order.error_message) + '</div>' : '') +
            '</div>';

        (data.pool || []).forEach(function(item) {
            var fullDomain = item.domain || '';
            var root = data.order.domain || '';
            var displayName = fullDomain === root ? '@' : fullDomain.replace('.' + root, '');
            html += '<div class="pb-dm-lifecycle-item">' +
                '<div><strong>' + escapeHtml(displayName || fullDomain) + '</strong></div>' +
                '<div style="margin-top:6px;">' + renderResolveStatusBadge(item) + ' ' + renderHttpsStatusBadge(item) + ' ' + renderSiteReadyBadge(item) + '</div>' +
                '<div style="margin-top:6px;"><strong><?= __('解析IP') ?>:</strong> ' + escapeHtml(item.resolved_ip || '-') + '</div>' +
                '</div>';
        });

        html += '</div>';
        html += '<div class="pb-dm-lifecycle-steps">';
        ['purchase', 'dns', 'resolve', 'verify', 'ssl'].forEach(function(stepName) {
            html += renderLifecycleStepBadge(steps[stepName] || { step_name: stepName, status: 'pending' });
        });
        html += '</div>';
        container.innerHTML = html;
    }

    function renderLifecycleNotFound(container, targetDomain, message) {
        var html = '<div class="pb-dm-empty" style="color:var(--backend-color-text-secondary,#6c757d);">' +
            '<p style="margin-bottom:12px;">' + escapeHtml(message) + '</p>' +
            '<p class="small" style="margin-bottom:12px;"><?= __('若已通过域名购买功能购买，可在此补建生命周期订单以便后续跟踪。') ?></p>' +
            '<div class="pb-dm-repair-lifecycle-form" style="margin-top:12px;">' +
            '<label class="form-label small"><?= __('选择购买时使用的域名商账号') ?></label>' +
            '<select class="form-select form-select-sm pb-dm-repair-account" style="max-width:280px;margin-bottom:8px;">' +
            '<option value=""><?= __('加载中...') ?></option></select>' +
            '<button type="button" class="pb-dm-btn pb-dm-btn-primary pb-dm-btn-sm pb-dm-repair-btn" disabled><i class="mdi mdi-wrench"></i> <?= __('补建生命周期订单') ?></button>' +
            '</div></div>';
        container.innerHTML = html;
        var selectEl = container.querySelector('.pb-dm-repair-account');
        var btnEl = container.querySelector('.pb-dm-repair-btn');
        var req = window.Weline && window.Weline.Api ? window.Weline.Api.get(API.getRegistrarAccounts, { silent: true }) : fetch(API.getRegistrarAccounts);
        var handleAccounts = function(raw) {
            var inner = (raw && raw.data) !== undefined ? raw.data : raw;
            var accounts = (inner && inner.accounts) ? inner.accounts : (Array.isArray(inner) ? inner : []);
            var active = accounts.filter(function(a) { return (a.status || '') !== 'inactive'; });
            selectEl.innerHTML = '<option value=""><?= __('请选择域名商账号') ?></option>';
            active.forEach(function(a) {
                var id = a.account_id || a.id;
                var label = (a.registrar_name || a.registrarName || '') + ' - ' + (a.account_name || a.name || id);
                selectEl.innerHTML += '<option value="' + id + '">' + escapeHtml(label) + '</option>';
            });
            btnEl.disabled = active.length === 0;
        };
        if (req && typeof req.then === 'function') {
            req.then(function(r) { handleAccounts(r && r.data ? r.data : r); }).catch(function() {
                selectEl.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
            });
        } else {
            handleAccounts([]);
        }
        btnEl.addEventListener('click', function() {
            var acctId = parseInt(selectEl.value, 10);
            if (!acctId) {
                BackendToast.warning('<?= __('请选择域名商账号') ?>');
                return;
            }
            btnEl.disabled = true;
            btnEl.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('补建中...') ?>';
            postForm(API.repairLifecycleOrder, { domain: targetDomain, account_id: acctId }).then(function(res) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-wrench"></i> <?= __('补建生命周期订单') ?>';
                if (res.success) {
                    BackendToast.success('<?= __('补建成功') ?>');
                    loadLifecycleStatus(targetDomain);
                } else {
                    BackendToast.error(res.message || '<?= __('补建失败') ?>');
                }
            }).catch(function(e) {
                btnEl.disabled = false;
                btnEl.innerHTML = '<i class="mdi mdi-wrench"></i> <?= __('补建生命周期订单') ?>';
                BackendToast.error('<?= __('补建失败') ?>: ' + (e.message || e));
            });
        });
    }

    function loadLifecycleStatus(domain) {
        var targetDomain = (domain || (document.getElementById('pb-dm-lifecycle-domain') || {}).value || '').trim().toLowerCase();
        var container = document.getElementById('pb-dm-lifecycle-result');
        if (!targetDomain) {
            BackendToast.warning('<?= __('请输入根域名') ?>');
            return;
        }

        container.innerHTML = '<div class="pb-dm-empty"><i class="mdi mdi-loading mdi-spin" style="font-size:1.4rem;"></i><p><?= __('正在查询生命周期状态...') ?></p></div>';
        postForm(API.getLifecycleStatus, { domain: targetDomain }).then(function(res) {
            if (!res.success) {
                renderLifecycleNotFound(container, targetDomain, res.message || '<?= __('查询失败') ?>');
                return;
            }
            renderLifecycleStatus(res.data || {});
        }).catch(function(e) {
            container.innerHTML = '<div class="pb-dm-empty" style="color:var(--backend-color-danger,#f46a6a);"><?= __('查询失败') ?>: ' + escapeHtml(e.message) + '</div>';
        });
    }

    function renderDomainPool(items) {
        var container = document.getElementById('pb-dm-pool-container');
        if (!items || items.length === 0) {
            container.innerHTML = '<div class="pb-dm-empty">' +
                '<i class="mdi mdi-database-off" style="font-size:2rem;color:var(--backend-color-text-secondary,#6c757d);"></i>' +
                '<p><?= __('暂无域名池数据') ?></p>' +
                '<p style="font-size:0.85rem;color:var(--backend-color-text-secondary,#6c757d);">' +
                '<?= __('请先在「根域列表」中拉取域名，然后转存到域名池') ?></p>' +
                '<button class="pb-dm-btn pb-dm-btn-primary pb-dm-btn-sm" style="margin-top:8px;" onclick="document.querySelector(\'.pb-dm-tab[data-tab=domains]\').click();">' +
                '<i class="mdi mdi-earth"></i> <?= __('前往根域列表') ?></button>' +
                '</div>';
            return;
        }

        var html = '<table class="pb-dm-table" id="pb-dm-pool-table"><thead><tr>' +
            '<th class="pb-dm-col-domain"><?= __('域名') ?></th>' +
            '<th class="pb-dm-col-type"><?= __('类型') ?></th>' +
            '<th class="pb-dm-col-provider"><?= __('服务商') ?></th>' +
            '<th class="pb-dm-col-status"><?= __('状态') ?></th>' +
            '<th class="pb-dm-col-resolve"><?= __('解析状态') ?></th>' +
            '<th class="pb-dm-col-https"><?= __('HTTPS') ?></th>' +
            '<th class="pb-dm-col-site-ready"><?= __('可建站') ?></th>' +
            '<th class="pb-dm-col-site-created"><?= __('已建站') ?></th>' +
            '<th class="pb-dm-col-ip"><?= __('解析IP') ?></th>' +
            '<th class="pb-dm-col-time"><?= __('入池时间') ?></th>' +
            '<th class="pb-dm-col-ops"><?= __('操作') ?></th>' +
            '</tr></thead><tbody>';

        items.forEach(function(item) {
            var statusBadge = '';
            if (item.status === 'available') {
                statusBadge = '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('可用') ?></span>';
            } else if (item.status === 'allocated') {
                statusBadge = '<span class="pb-dm-badge pb-dm-badge--info"><?= __('已分配') ?></span>';
            } else if (item.status === 'reserved') {
                statusBadge = '<span class="pb-dm-badge pb-dm-badge--warn"><?= __('预留') ?></span>';
            } else {
                statusBadge = '<span class="pb-dm-badge">' + (item.status || '-') + '</span>';
            }

            var resolveBadge = renderResolveStatusBadge(item);
            var httpsBadge = renderHttpsStatusBadge(item);
            var siteReadyBadge = renderSiteReadyBadge(item);
            var siteCreatedBadge = renderSiteCreatedBadge(item);

            var typeText = item.subdomain ? '<?= __('子域名') ?>' : '<?= __('根域') ?>';
            var registrarName = item.registrar_name || '-';
            var dnsName = item.dns_provider_name || '-';
            var cdnName = item.cdn_provider_name || '-';
            var providerCell = '<div class="pb-dm-provider-cell">' +
                '<div class="pb-dm-provider-row"><span class="pb-dm-provider-label"><?= __('注册') ?></span><span class="pb-dm-provider-badge ' + (registrarName !== '-' ? 'pb-dm-provider--registrar' : 'pb-dm-provider--none') + '">' + escapeHtml(registrarName) + '</span></div>' +
                '<div class="pb-dm-provider-row"><span class="pb-dm-provider-label">DNS</span><span class="pb-dm-provider-badge ' + (dnsName !== '-' ? 'pb-dm-provider--dns' : 'pb-dm-provider--none') + '">' + escapeHtml(dnsName) + '</span></div>' +
                '<div class="pb-dm-provider-row"><span class="pb-dm-provider-label">CDN</span><span class="pb-dm-provider-badge ' + (cdnName !== '-' ? 'pb-dm-provider--cdn' : 'pb-dm-provider--none') + '">' + escapeHtml(cdnName) + '</span></div>' +
                '</div>';
            var criticalOffLocal = String(item.resolve_status || '').toLowerCase() === 'resolved' && String(item.is_local_server || '0') !== '1';
            var isRegistering = !!(item.is_registering);

            var poolId = item.pool_id || 0;
            var resolvedDisplay = (item.resolved_ip || '-');
            if (item.resolved_ipv6 && item.resolved_ipv6 !== item.resolved_ip) {
                resolvedDisplay += ' / ' + item.resolved_ipv6;
            }
            var registeringTitle = '<?= __('正在注册中') ?>';
            var checkBtn = poolId > 0
                ? (isRegistering
                    ? '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-check-btn pb-dm-btn--disabled" disabled title="' + registeringTitle + '"><i class="mdi mdi-dns"></i> <?= __('检查') ?></button>'
                    : '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-check-btn" data-pool-id="' + poolId + '" title="<?= __('快速查询解析并更新状态') ?>"><i class="mdi mdi-dns"></i> <?= __('检查') ?></button>')
                : '';
            var needCert = String(item.https_status || '').toLowerCase() !== 'valid';
            var httpsBtn = poolId > 0
                ? (isRegistering
                    ? '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-https-btn pb-dm-btn--disabled" disabled title="' + registeringTitle + '"><i class="mdi mdi-certificate"></i> <?= __('申请证书') ?></button>'
                    : '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-https-btn' + (needCert ? '' : ' pb-dm-btn--disabled') + '" data-pool-id="' + poolId + '" data-domain="' + escapeHtml(item.domain || '') + '" ' + (needCert ? '' : ' disabled title="<?= __('证书有效，无需申请') ?>"') + (needCert ? ' title="<?= __('手动申请 HTTPS 证书') ?>"' : '') + '><i class="mdi mdi-certificate"></i> <?= __('申请证书') ?></button>')
                : '';
            var delBtn = poolId > 0
                ? (isRegistering
                    ? '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-delete-btn pb-dm-btn--disabled" disabled title="' + registeringTitle + '"><i class="mdi mdi-delete-outline"></i></button>'
                    : '<button type="button" class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-pool-delete-btn" data-pool-id="' + poolId + '" data-domain="' + escapeHtml(item.domain || '') + '" title="<?= __('从域名池删除') ?>"><i class="mdi mdi-delete-outline"></i></button>')
                : '';
            var opHtml = '<div class="pb-dm-pool-ops">' + [checkBtn, httpsBtn, delBtn].filter(Boolean).join('') + '</div>';

            html += '<tr class="' + (criticalOffLocal ? 'pb-dm-row--critical' : '') + '">' +
                '<td class="pb-dm-col-domain"><strong>' + escapeHtml(item.full_domain || item.domain || '') + '</strong></td>' +
                '<td class="pb-dm-col-type">' + typeText + '</td>' +
                '<td class="pb-dm-col-provider">' + providerCell + '</td>' +
                '<td class="pb-dm-col-status">' + statusBadge + '</td>' +
                '<td class="pb-dm-col-resolve">' + resolveBadge + '</td>' +
                '<td class="pb-dm-col-https">' + httpsBadge + '</td>' +
                '<td class="pb-dm-col-site-ready">' + siteReadyBadge + '</td>' +
                '<td class="pb-dm-col-site-created">' + siteCreatedBadge + '</td>' +
                '<td class="pb-dm-col-ip">' + resolvedDisplay + '</td>' +
                '<td class="pb-dm-col-time">' + (item.allocated_at || '-') + '</td>' +
                '<td class="pb-dm-col-ops">' + opHtml + '</td>' +
                '</tr>';
        });

        html += '</tbody></table>';
        container.innerHTML = html;

        container.querySelectorAll('.pb-dm-pool-check-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var poolId = parseInt(this.getAttribute('data-pool-id') || '0', 10);
