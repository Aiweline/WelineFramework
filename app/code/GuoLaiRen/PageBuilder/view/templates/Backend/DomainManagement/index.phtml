                                <button class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm" onclick="showSwitchDnsProviderModal()" title="<?= __('切换DNS供应商并自动提交记录') ?>">\
                                    <i class="mdi mdi-swap-horizontal"></i> <?= __('切换DNS供应商') ?>\
