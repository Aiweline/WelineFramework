            '</div>';

            html += '<div class="pb-dm-accordion-body">';
            if (group.items && group.items.length > 0) {
                html += '<table class="pb-dm-table" style="margin:0;border-radius:0;"><thead><tr>' +
                    '<th style="width:40px;"><input type="checkbox" class="pb-dm-select-all-group" data-account-id="' + group.account_id + '"></th>' +
                    '<th><?= __('域名') ?></th>' +
                    '<th><?= __('服务商') ?></th>' +
                    '<th><?= __('可建站') ?></th>' +
                    '<th><?= __('已建站') ?></th>' +
                    '<th><?= __('本地状态') ?></th>' +
                    '<th><?= __('域名状态') ?></th>' +
                    '<th><?= __('过期时间') ?></th>' +
                    '<th><?= __('操作') ?></th>' +
                    '</tr></thead><tbody>';

                group.items.forEach(function(d) {
                    var isPulled = d.is_pulled === true || d.is_pulled === 1;
                    var pullBadge = renderPulledStatusBadge(isPulled);

                    var checkboxDisabled = '';

                    var actions = isPulled
                        ? '<button class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-resolve-dns-btn" data-domain-id="' + d.domain_id + '" data-domain="' + escapeHtml(d.domain) + '" title="<?= __('解析到本地') ?>">' +
                          '<i class="mdi mdi-dns"></i></button>' +
                          '<button class="pb-dm-btn pb-dm-btn-primary pb-dm-btn-sm pb-dm-manage-dns-btn" data-domain-id="' + d.domain_id + '" data-domain="' + escapeHtml(d.domain) + '" title="<?= __('管理DNS记录') ?>" style="margin-left:4px;">' +
                          '<i class="mdi mdi-playlist-plus"></i></button>' +
                          '<button class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-root-switch-dns-btn" data-domain-id="' + d.domain_id + '" data-domain="' + escapeHtml(d.domain) + '" data-account-id="' + group.account_id + '" title="<?= __('切换DNS/CDN') ?>" style="margin-left:4px;">' +
                          '<i class="mdi mdi-swap-horizontal"></i></button>' +
                          '<button class="pb-dm-btn pb-dm-btn-outline pb-dm-btn-sm pb-dm-root-delete-btn" data-domain-id="' + d.domain_id + '" data-domain="' + escapeHtml(d.domain) + '" title="<?= __('删除根域（含子域名与池记录）') ?>" style="margin-left:4px;"><i class="mdi mdi-delete-outline"></i></button>'
                        : '<button class="pb-dm-btn pb-dm-btn-success pb-dm-btn-sm pb-dm-pull-single-btn" data-domain="' + escapeHtml(d.domain) + '" data-account-id="' + group.account_id + '" title="<?= __('拉取并入池') ?>">' +
                          '<i class="mdi mdi-download"></i></button>';

                    // 构建服务商列（三行：注册商、DNS、CDN）
                    var registrarName = d.registrar_name || group.registrar_name || '-';
                    var dnsName = d.dns_provider_name || d.dns_provider || '-';
                    var cdnName = d.cdn_provider_name || d.cdn_provider || '-';

                    var registrarClass = registrarName !== '-' ? 'pb-dm-provider--registrar' : 'pb-dm-provider--none';
                    var dnsClass = dnsName !== '-' ? 'pb-dm-provider--dns' : 'pb-dm-provider--none';
                    var cdnClass = cdnName !== '-' ? 'pb-dm-provider--cdn' : 'pb-dm-provider--none';

                    var providerCell = '<div class="pb-dm-provider-cell">' +
                        '<div class="pb-dm-provider-row">' +
                            '<span class="pb-dm-provider-label"><?= __('注册') ?></span>' +
                            '<span class="pb-dm-provider-badge ' + registrarClass + '">' + escapeHtml(registrarName) + '</span>' +
                        '</div>' +
                        '<div class="pb-dm-provider-row">' +
                            '<span class="pb-dm-provider-label">DNS</span>' +
                            '<span class="pb-dm-provider-badge ' + dnsClass + '">' + escapeHtml(dnsName) + '</span>' +
                        '</div>' +
                        '<div class="pb-dm-provider-row">' +
                            '<span class="pb-dm-provider-label">CDN</span>' +
                            '<span class="pb-dm-provider-badge ' + cdnClass + '">' + escapeHtml(cdnName) + '</span>' +
                        '</div>' +
                    '</div>';

                    var siteReadyBadge = (d.site_ready === 1 || d.site_ready === true) ? '<span class="pb-dm-badge pb-dm-badge--ok"><?= __('可建站') ?></span>' : '<span class="pb-dm-badge pb-dm-badge--no"><?= __('否') ?></span>';
                    var siteCreatedBadge = (d.site_created === 1 || d.site_created === true) ? '<span class="pb-dm-badge pb-dm-badge--info"><?= __('已建站') ?></span>' : '<span class="pb-dm-badge pb-dm-badge--no"><?= __('未使用') ?></span>';
                    html += '<tr data-domain="' + escapeHtml(d.domain) + '" data-account-id="' + group.account_id + '">' +
                        '<td><input type="checkbox" class="pb-dm-domain-select" data-domain="' + escapeHtml(d.domain) + '" data-account-id="' + group.account_id + '" data-pulled="' + (isPulled ? '1' : '0') + '"' + checkboxDisabled + '></td>' +
                        '<td><strong>' + escapeHtml(d.domain) + '</strong></td>' +
                        '<td>' + providerCell + '</td>' +
                        '<td>' + siteReadyBadge + '</td>' +
                        '<td>' + siteCreatedBadge + '</td>' +
                        '<td>' + pullBadge + '</td>' +
                        '<td>' + renderDomainStatusBadge(d.status) + '</td>' +
                        '<td>' + (d.expires_at || '-') + '</td>' +
                        '<td>' + actions + '</td>' +
                        '</tr>';
                });

                html += '</tbody></table>';
            } else if (group.fetch_error) {
                html += '<div class="pb-dm-empty" style="padding:20px;">' +
                    '<i class="mdi mdi-alert-circle-outline" style="font-size:1.5rem;color:var(--backend-color-danger,#f46a6a);"></i>' +
                    '<p style="color:var(--backend-color-danger,#f46a6a);"><?= __('拉取失败') ?>: ' + escapeHtml(group.fetch_error) + '</p>' +
                    '<p style="font-size:0.85rem;color:var(--backend-color-text-secondary,#6c757d);"><?= __('请检查账户 API 凭据，或点击「测试」按钮验证连接。') ?></p>' +
                '</div>';
            } else if (group.is_dns_only) {
                html += '<div class="pb-dm-empty" style="padding:20px;">' +
                    '<i class="mdi mdi-dns" style="font-size:1.5rem;color:var(--backend-color-warning,#f1b44c);"></i>' +
                    '<p style="color:var(--backend-color-warning,#f1b44c);">' + escapeHtml(group.registrar_name || '') + ' <?= __('是 DNS 服务商，不是域名注册商。域名归属以实际注册商为准。') ?></p>' +
                '</div>';
            } else {
                // 根据当前筛选状态显示不同的提示
                if (domainListState.status === 'pulled') {
                    html += '<div class="pb-dm-empty" style="padding:20px;">' +
                        '<i class="mdi mdi-cloud-download-outline" style="font-size:1.5rem;color:var(--backend-color-primary,#556ee6);"></i>' +
                        '<p><?= __('该账户下尚无已拉取的域名') ?></p>' +
                        '<p style="font-size:0.85rem;color:var(--backend-color-text-secondary,#6c757d);">' +
                        '<?= __('请切换上方「状态」为「全部状态」或「未拉取」，从线上选择域名拉取到本地') ?></p>' +
                        '<button class="pb-dm-btn pb-dm-btn-primary pb-dm-btn-sm" style="margin-top:8px;" onclick="document.getElementById(\'pb-dm-domain-status\').value=\'\';document.getElementById(\'pb-dm-domain-status\').dispatchEvent(new Event(\'change\'));">' +
                        '<i class="mdi mdi-filter-off"></i> <?= __('查看全部状态') ?></button>' +
                        '</div>';
