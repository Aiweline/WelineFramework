        <?= $headerCustomCode ?>
    <?php endif; ?>
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <?php if ($page && $page->getData('gtm_id')): ?>
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=<?= htmlspecialchars((($page->getData('gtm_id') ?? '')) ?? '') ?>"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <?php endif; ?>
    
    <div class="default-page-container">
        <?php if ($page && $page->getData('logo')): ?>
            <div class="page-logo">
                <img src="<?= htmlspecialchars((($page->getData('logo') ?? '')) ?? '') ?>" alt="Logo">
            </div>
        <?php endif; ?>
        
        <div class="page-header">
            <h1><?= htmlspecialchars($content['title'] ?? '') ?></h1>
            <?php if ($page && $page->getData('create_time')): ?>
                <div class="page-meta">
                    <span><?= __('发布时间：') ?><?= htmlspecialchars((($page->getData('create_time') ?? '')) ?? '') ?></span>
                </div>
            <?php endif; ?>
        </div>
        
        <?php if (!$this->getData('has_translation') && $this->getData('is_locale_supported')): ?>
            <div class="translation-notice">
                <strong>⚠️ <?= __('注意：') ?></strong>
                <?= __('此页面还没有当前语言的翻译版本，显示的是默认语言内容。') ?>
            </div>
        <?php endif; ?>
        
        <div class="page-content">
            <?= $content['content'] ?? '' ?>
        </div>
        
        <?php 
        $availableLocales = $this->getData('available_locales');
        $currentLocale = $this->getData('current_locale');
        ?>
        <?php if (!empty($availableLocales) && count($availableLocales) > 1): ?>
            <div class="language-switcher">
                <strong><?= __('切换语言：') ?></strong>
                <div class="language-options">
                    <?php foreach ($availableLocales as $locale): ?>
                        <?php 
                        $isCurrent = ($locale['code'] ?? '') === $currentLocale;
                        $hasTranslation = $locale['has_translation'] ?? false;
                        ?>
                        <a href="<?= htmlspecialchars($locale['url'] ?? '#') ?>" 
                           class="language-option <?= $isCurrent ? 'active' : '' ?>">
                            <?= htmlspecialchars($locale['name'] ?? '') ?>
                            <?php if (!$hasTranslation): ?>
                                <span class="untranslated-badge" title="<?= __('未翻译') ?>">⚠️</span>
                            <?php endif; ?>
                            <?php if ($isCurrent): ?>
                                <span class="current-badge">✓</span>
                            <?php endif; ?>
                        </a>
                    <?php endforeach; ?>
                </div>
                <div class="language-help">
                    <?= __('⚠️ 表示该语言版本尚未翻译') ?>
                </div>
            </div>
        <?php endif; ?>
    </div>
    
    <!-- Footer 自定义代码 -->
