 */
$page = $this->getData('page');
$content = $this->getData('content');
$seo = $this->getData('seo');
$currentLocale = $this->getData('current_locale');
?>
<!DOCTYPE html>
<html lang="<?= htmlspecialchars($currentLocale ?: 'zh_Hans_CN') ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO Meta -->
    <title><?= htmlspecialchars($seo['title'] ?? $content['title'] ?? '') ?></title>
    <?php if (!empty($seo['description'])): ?>
    <meta name="description" content="<?= htmlspecialchars($seo['description'] ?? '') ?>">
    <?php endif; ?>
    <?php if (!empty($seo['keywords'])): ?>
    <meta name="keywords" content="<?= htmlspecialchars($seo['keywords'] ?? '') ?>">
    <?php endif; ?>
    
    <!-- Open Graph -->
    <?php if (!empty($seo['og_title'])): ?>
    <meta property="og:title" content="<?= htmlspecialchars($seo['og_title'] ?? '') ?>">
    <?php endif; ?>
    <?php if (!empty($seo['og_description'])): ?>
    <meta property="og:description" content="<?= htmlspecialchars($seo['og_description'] ?? '') ?>">
    <?php endif; ?>
    
    <!-- Hreflang for multilingual SEO -->
    <?php if (!empty($seo['hreflangs'])): ?>
        <?php 
        $i18nEnabled = $seo['i18n_enabled'] ?? '0';
        foreach ($seo['hreflangs'] as $hreflang): 
        ?>
            <link rel="alternate" 
                  hreflang="<?= htmlspecialchars($hreflang['locale'] ?? '') ?>" 
                  href="<?= htmlspecialchars($hreflang['url'] ?? '') ?>" 
                  data-i18n-enabled="<?= htmlspecialchars($i18nEnabled) ?>" 
                  class="hreflang-link" />
        <?php endforeach; ?>
    <?php endif; ?>
    
    <!-- CSS控制hreflang标签显示 -->
    <style>
        /* 当多语言功能关闭时，隐藏所有hreflang标签 */
        link.hreflang-link[data-i18n-enabled="0"] {
            display: none !important;
            visibility: hidden !important;
        }
        /* 当多语言功能开启时，正常显示 */
        link.hreflang-link[data-i18n-enabled="1"] {
            display: inline !important;
            visibility: visible !important;
        }
    </style>
    
    <!-- Google Tag Manager -->
    <?php if ($page && $page->getData('gtm_id')): ?>
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','<?= htmlspecialchars((($page->getData('gtm_id') ?? '')) ?? '') ?>');</script>
    <?php endif; ?>
    
    <!-- Google Analytics 4 -->
    <?php if ($page && $page->getData('ga4_id')): ?>
        <script async src="https://www.googletagmanager.com/gtag/js?id=<?= htmlspecialchars((($page->getData('ga4_id') ?? '')) ?? '') ?>"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '<?= htmlspecialchars((($page->getData('ga4_id') ?? '')) ?? '') ?>');
        </script>
    <?php endif; ?>
    
    <!-- Facebook Pixel -->
    <?php if ($page && $page->getData('fb_pixel_id')): ?>
        <script>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '<?= htmlspecialchars((($page->getData('fb_pixel_id') ?? '')) ?? '') ?>');
        fbq('track', 'PageView');
        </script>
        <noscript><img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=<?= htmlspecialchars((($page->getData('fb_pixel_id') ?? '')) ?? '') ?>&ev=PageView&noscript=1"
        /></noscript>
    <?php endif; ?>
    
    <!-- Favicon -->
    <?php if ($page && $page->getData('icon')): ?>
        <link rel="icon" href="<?= htmlspecialchars((($page->getData('icon') ?? '')) ?? '') ?>">
    <?php endif; ?>
    
