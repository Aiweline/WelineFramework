<script>
// 模型数据存储
let allModels = [];

// Debounce实现
function debounce(func, delay) {
    let timeoutId;
    return function (...args) {
        if (timeoutId) {
            clearTimeout(timeoutId);
        }
        timeoutId = setTimeout(() => {
            func.apply(this, args);
            timeoutId = null;
        }, delay);
    };
}

// 加载AI模型列表
function loadModels() {
    const modelList = document.getElementById('model_list');
    const loadingDiv = document.getElementById('model_loading');
    const modelContainer = document.getElementById('model_container');
    const modelTrigger = document.getElementById('model_trigger');
    
    modelTrigger.style.display = 'none';
    modelContainer.style.display = 'block';
    loadingDiv.style.display = 'block';
    modelList.innerHTML = '';
    
    fetch('<?= $this->getBackendUrl('*/backend/detect/models') ?>', {
        method: 'GET',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        loadingDiv.style.display = 'none';
        if (!response.ok) {
            throw new Error('网络请求失败: ' + response.status);
        }
        return response.json();
    })
    .then(result => {
        if (result.success && result.data && result.data.length > 0) {
            allModels = result.data;
            console.log('AI模型加载成功，共加载', result.data.length, '个模型');
            displayModels(allModels);
        } else {
            modelList.innerHTML = '<div class="p-2 text-danger">⚠️ 未找到可用的AI模型</div>';
            console.warn('未获取到AI模型数据');
        }
    })
    .catch(error => {
        loadingDiv.style.display = 'none';
        modelList.innerHTML = '<div class="p-2 text-danger">❌ 加载失败: ' + (error.message || error) + '</div>';
        console.error('加载AI模型失败:', error);
    });
}

// 显示模型列表
function displayModels(models) {
    const modelList = document.getElementById('model_list');
    
    if (models.length === 0) {
        modelList.innerHTML = '<div class="p-2 text-muted">未找到匹配的模型</div>';
        return;
    }
    
    let html = '';
    html += models.map(model => {
        const displayText = `${model.name} (${model.supplier}) - ${model.version}`;
        return `<div class="p-2 border-bottom" style="cursor: pointer;" data-code="${model.code}" data-text="${displayText}" onmouseover="this.style.backgroundColor='#f8f9fa'" onmouseout="this.style.backgroundColor='white'">${displayText}</div>`;
    }).join('');
    
    modelList.innerHTML = html;
    
    // 为每个选项添加点击事件
    modelList.querySelectorAll('[data-code]').forEach(item => {
        item.addEventListener('click', function() {
            const code = this.dataset.code;
            const text = this.dataset.text;
            
            // 设置隐藏字段
            document.getElementById('default_model').value = code;
            
            // 更新显示
            const modelTrigger = document.getElementById('model_trigger');
            const modelDisplay = document.getElementById('model_display');
            const modelContainer = document.getElementById('model_container');
            
            modelDisplay.textContent = text;
            modelTrigger.style.display = 'block';
            modelContainer.style.display = 'none';
        });
    });
}

// 搜索模型（使用debounce）
const debouncedSearch = debounce(function(searchTerm) {
    if (!searchTerm.trim()) {
        displayModels(allModels);
        return;
    }
    
    const searchLower = searchTerm.toLowerCase();
    const filtered = allModels.filter(model => {
        const searchText = `${model.name} ${model.supplier} ${model.version}`.toLowerCase();
        return searchText.includes(searchLower);
    });
    
    displayModels(filtered);
}, 800);

// 初始化模型选择器
document.addEventListener('DOMContentLoaded', function() {
    const modelTrigger = document.getElementById('model_trigger');
    const searchInput = document.getElementById('model_search');
    const modelContainer = document.getElementById('model_container');
    
    // 从页面获取模型数据
    const modelList = document.getElementById('model_list');
    const existingModels = [];
    modelList.querySelectorAll('[data-code]:not([data-code=""])').forEach(item => {
        const code = item.dataset.code;
        const text = item.dataset.text;
        const parts = text.match(/(.+?)\s*\((.+?)\)\s*-\s*(.+)/);
        if (parts) {
            existingModels.push({
                code: code,
                name: parts[1].trim(),
                supplier: parts[2].trim(),
                version: parts[3].trim()
            });
        }
    });
    allModels = existingModels;
    
    // 初始化显示选中的模型
    const defaultModelValue = document.getElementById('default_model').value;
    if (defaultModelValue) {
        const selected = modelList.querySelector('[data-code="' + defaultModelValue + '"]');
        if (selected && selected.dataset.text) {
            document.getElementById('model_display').textContent = selected.dataset.text;
        } else {
            // 回退到服务器渲染的显示文本
            const serverDisplay = document.getElementById('default_model').dataset.display || '';
            if (serverDisplay) {
                document.getElementById('model_display').textContent = serverDisplay;
            }
        }
    }
    
    // 点击触发按钮，显示/隐藏模型列表
    modelTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        loadModels();
        setTimeout(() => searchInput.focus(), 100);
    });
    
    // 监听搜索输入
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value;
        debouncedSearch(searchTerm);
    });
});

function saveConfig() {
    const desensitizationForm = document.getElementById('desensitizationForm');
    const rewriteForm = document.getElementById('rewriteForm');
    
    const desensitizationFormData = new FormData(desensitizationForm);
    const rewriteFormData = new FormData(rewriteForm);
    
    const data = {
        desensitization_params: {
            mode: desensitizationFormData.get('mode'),
            level: desensitizationFormData.get('level'),
            enable_strict_check: desensitizationFormData.get('enable_strict_check') === 'on' ? true : false,
            default_model: document.getElementById('default_model').value
        },
        rewrite_params: {
            style: rewriteFormData.get('style'),
            preserve_format: rewriteFormData.get('preserve_format') === 'on' ? true : false,
            enhance_readability: rewriteFormData.get('enhance_readability') === 'on' ? true : false
        },
        meta_rules: document.getElementById('meta_rules').value,
        google_rules: document.getElementById('google_rules').value
    };

    fetch('<?= $this->getBackendUrl('*/backend/config/save') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert('配置保存成功');
            location.reload();
        } else {
            alert('保存失败: ' + result.message);
        }
    })
    .catch(error => {
        alert('保存失败: ' + error.message);
    });
}

function resetAdapter(adapterType) {
    if (!confirm('确定要重置' + (adapterType === 'desensitization' ? '脱敏适配器' : '重写适配器') + '的配置为默认值吗？')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/config/reset') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({adapter_type: adapterType})
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert('配置已重置');
            location.reload();
        } else {
            alert('重置失败: ' + result.message);
        }
    })
    .catch(error => {
        alert('重置失败: ' + error.message);
    });
}

// 等待弹窗工具方法
let updateRulesModalInstance = null;
function showUpdateRulesModal(message) {
    try {
        const modalEl = document.getElementById('updateRulesModal');
        if (!updateRulesModalInstance) {
            updateRulesModalInstance = new bootstrap.Modal(modalEl, {backdrop: 'static', keyboard: false});
        }
        if (message) {
            document.getElementById('updateRulesModalMessage').textContent = message;
        }
        updateRulesModalInstance.show();
    } catch (e) {
        console.warn('showUpdateRulesModal failed:', e);
    }
}
function hideUpdateRulesModal() {
    try {
        updateRulesModalInstance?.hide();
    } catch (e) {
        console.warn('hideUpdateRulesModal failed:', e);
    }
}

function updateRules(platform) {
    console.log('updateRules called with platform:', platform);
    const platformName = platform === 'meta' ? 'Meta' : 'Google';

    // 前置检查：默认AI模型是否配置
    const defaultModel = (document.getElementById('default_model')?.value || '').trim();
    console.log('defaultModel value:', defaultModel);
    if (!defaultModel) {
        alert('请先在"默认AI模型"中选择一个模型后再更新规则');
        return;
    }

    if (!confirm(`确定要从${platformName}更新敏感词规则吗？这可能需要一些时间。`)) {
        return;
    }

    console.log('Starting update process...');

    // 弹出等待模态框
    showUpdateRulesModal('正在从' + platformName + '获取网页并提取敏感词，请稍候...');

    const url = '<?= $this->getBackendUrl('*/backend/config/saveRules') ?>';
    console.log('Making request to:', url);
    
    fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({platform: platform})
    })
    .then(response => {
        console.log('Response received:', response.status, response.statusText);
        // 检查响应是否为HTML，如果是，尝试解析为JSON，否则抛出错误
        const contentType = response.headers.get("content-type");
        if (contentType && contentType.indexOf("application/json") !== -1) {
            return response.json();
        } else {
            // 如果不是JSON，尝试读取文本并抛出错误
            return response.text().then(text => {
                throw new Error('服务器返回非JSON内容: ' + text);
            });
        }
    })
    .then(result => {
        console.log('Result:', result);
        const msgEl = document.getElementById('updateRulesModalMessage');
        if (result.success) {
            // 将获取到的规则填入对应的textarea
            if (platform === 'meta' && result.data) {
                document.getElementById('meta_rules').value = result.data;
            } else if (platform === 'google' && result.data) {
                document.getElementById('google_rules').value = result.data;
            }
            msgEl.classList.remove('text-danger');
            msgEl.classList.add('text-success');
            msgEl.textContent = '更新成功！规则已合并并回填。';
            // 成功后延迟关闭
            setTimeout(() => hideUpdateRulesModal(), 800);
        } else {
            msgEl.classList.remove('text-success');
            msgEl.classList.add('text-danger');
            msgEl.textContent = '更新失败: ' + (result.message || '未知错误');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        const msgEl = document.getElementById('updateRulesModalMessage');
        msgEl.classList.remove('text-success');
        msgEl.classList.add('text-danger');
        msgEl.textContent = '更新失败: ' + (error && error.message ? error.message : String(error));
        // 不中途关闭，保留给用户查看
    });
}
</script>

</body>
</html>

