<script>
(function() {
    'use strict';
    
    document.getElementById('desens-log-filter-btn').addEventListener('click', function() {
        var form = document.getElementById('filterForm');
        var formData = new FormData(form);
        var params = new URLSearchParams(formData).toString();
        window.location.href = window.location.pathname + '?' + params;
    });
    
    document.querySelectorAll('.desens-log-view-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var logId = this.getAttribute('data-id');
            if (typeof BackendToast !== 'undefined') {
                BackendToast.info('<?= __('详情功能待实现') ?>: ' + logId);
            } else {
                console.log('详情功能待实现: ' + logId);
            }
        });
    });
})();
</script>
