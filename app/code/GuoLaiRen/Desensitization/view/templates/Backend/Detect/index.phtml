<script>
// 全局变量
let allModels = [];
let detectionData = null;
let rewriteData = null;

// Debounce实现
function debounce(func, delay) {
    let timeoutId;
    return function (...args) {
        if (timeoutId) {
            clearTimeout(timeoutId);
        }
        timeoutId = setTimeout(() => {
            func.apply(this, args);
            timeoutId = null;
        }, delay);
    };
}

// 加载AI模型列表
function loadModels() {
    const modelList = document.getElementById('model_list');
    const loadingDiv = document.getElementById('model_loading');
    const modelContainer = document.getElementById('model_container');
    const modelTrigger = document.getElementById('model_trigger');
    
    modelTrigger.style.display = 'none';
    modelContainer.style.display = 'block';
    loadingDiv.style.display = 'block';
    modelList.innerHTML = '';
    
    fetch('<?= $this->getBackendUrl('*/backend/detect/models') ?>', {
        method: 'GET',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        loadingDiv.style.display = 'none';
        if (!response.ok) {
            throw new Error('网络请求失败: ' + response.status);
        }
        return response.json();
    })
    .then(result => {
        if (result.success && result.data && result.data.length > 0) {
            allModels = result.data;
            console.log('AI模型加载成功，共加载', result.data.length, '个模型');
            displayModels(allModels);
        } else {
            modelList.innerHTML = '<div class="p-2 text-danger">⚠️ 未找到可用的AI模型</div>';
            console.warn('未获取到AI模型数据');
        }
    })
    .catch(error => {
        loadingDiv.style.display = 'none';
        modelList.innerHTML = '<div class="p-2 text-danger">❌ 加载失败: ' + (error.message || error) + '</div>';
        console.error('加载AI模型失败:', error);
    });
}

// 显示模型列表
function displayModels(models) {
    const modelList = document.getElementById('model_list');
    
    if (models.length === 0) {
        modelList.innerHTML = '<div class="p-2 text-muted">未找到匹配的模型</div>';
        return;
    }
    
    modelList.innerHTML = models.map(model => {
        const displayText = `${model.name} (${model.supplier}) - ${model.version}`;
        return `<div class="p-2 border-bottom" style="cursor: pointer;" data-code="${model.code}" data-text="${displayText}" 
                 onmouseover="this.style.backgroundColor='#f8f9fa'" 
                 onmouseout="this.style.backgroundColor='white'">
                 ${displayText}
                </div>`;
    }).join('');
    
    modelList.querySelectorAll('[data-code]').forEach(item => {
        item.addEventListener('click', function() {
            const code = this.dataset.code;
            const text = this.dataset.text;
            
            document.getElementById('model_code').value = code;
            
            const modelTrigger = document.getElementById('model_trigger');
            const modelDisplay = document.getElementById('model_display');
            const modelContainer = document.getElementById('model_container');
            
            modelDisplay.textContent = text;
            modelTrigger.style.display = 'block';
            modelContainer.style.display = 'none';
        });
    });
}

// 搜索模型（使用debounce）
const debouncedSearch = debounce(function(searchTerm) {
    if (!searchTerm.trim()) {
        displayModels(allModels);
        return;
    }
    
    const searchLower = searchTerm.toLowerCase();
    const filtered = allModels.filter(model => {
        const searchText = `${model.name} ${model.supplier} ${model.version}`.toLowerCase();
        return searchText.includes(searchLower);
    });
    
    displayModels(filtered);
}, 800);

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    const modelTrigger = document.getElementById('model_trigger');
    const searchInput = document.getElementById('model_search');
    
    modelTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        loadModels();
        setTimeout(() => searchInput.focus(), 100);
    });
    
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value;
        debouncedSearch(searchTerm);
    });
});

// 全局变量存储检测弹窗实例
let detectLoadingModalInstance = null;

function executeDetect() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入检测内容');
        return;
    }

    // 显示"检测中"弹窗 - 确保弹窗不能被手动关闭
    const modalElement = document.getElementById('detectLoadingModal');
    
    // 移除所有事件监听器，防止手动关闭
    modalElement.removeEventListener('click', handleModalClick);
    modalElement.addEventListener('click', handleModalClick);
    
    // 禁用ESC键关闭
    modalElement.setAttribute('data-bs-keyboard', 'false');
    modalElement.setAttribute('data-bs-backdrop', 'static');
    
    detectLoadingModalInstance = new bootstrap.Modal(modalElement, {
        keyboard: false,
        backdrop: 'static'
    });
    detectLoadingModalInstance.show();

    const form = document.getElementById('detectForm');
    const formData = new FormData(form);
    const data = {};
    formData.forEach((value, key) => {
        if (key === 'rule_types[]') {
            if (!data.rule_types) data.rule_types = [];
            data.rule_types.push(value);
        } else {
            data[key] = value;
        }
    });

    const detectionContent = document.getElementById('detectionContent');
    const resultFooter = document.getElementById('resultFooter');
    
    detectionContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>正在检测...</div>';
    resultFooter.style.display = 'none';

    fetch('<?= $this->getBackendUrl('*/backend/detect/execute') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        // 确保弹窗被正确关闭
        if (detectLoadingModalInstance) {
            detectLoadingModalInstance.hide();
            detectLoadingModalInstance = null;
        }
        
        if (data.success) {
            detectionData = data.data;
            displayDetectionResult(data.data);
            
            if (data.data.detection.has_sensitive) {
                resultFooter.style.display = 'block';
            }
        } else {
            detectionContent.innerHTML = `<div class="alert alert-danger">检测失败: ${data.message}</div>`;
        }
    })
    .catch(error => {
        // 确保弹窗被正确关闭
        if (detectLoadingModalInstance) {
            detectLoadingModalInstance.hide();
            detectLoadingModalInstance = null;
        }
        detectionContent.innerHTML = `<div class="alert alert-danger">检测失败: ${error.message}</div>`;
    });
}

// 处理弹窗点击事件，防止意外关闭
function handleModalClick(event) {
    // 阻止点击弹窗背景关闭弹窗
    if (event.target === event.currentTarget) {
        event.preventDefault();
        event.stopPropagation();
        return false;
    }
}

// 显示检测结果
function displayDetectionResult(result) {
    const detectionContent = document.getElementById('detectionContent');
    
    let html = `
        <div class="alert alert-info">
            <strong>检测完成</strong> - 执行时间: ${result.execution_time}
        </div>
    `;
    
    if (result.detection.has_sensitive) {
        html += `
            <div class="alert alert-warning">
                <h5><i class="mdi mdi-alert me-2"></i>发现敏感内容</h5>
                <strong>敏感类型：</strong> ${result.detection.sensitive_types.join(', ')}<br>
                <strong>发现 ${result.detection.positions.length} 处敏感信息</strong>
            </div>
        `;
        
        const markedContent = markSensitiveContent(result.original, result.detection.positions);
        html += `
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">标记后的内容</h5>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap;">${markedContent}</div>
                </div>
            </div>
        `;
        
        if (result.detection.positions && result.detection.positions.length > 0) {
            html += '<div class="table-responsive"><table class="table table-sm table-bordered"><thead><tr><th>类型</th><th>内容</th><th>位置</th></tr></thead><tbody>';
            result.detection.positions.forEach(pos => {
                html += `<tr><td><span class="badge bg-danger">${pos.type}</span></td><td><code>${pos.match}</code></td><td>${pos.start}-${pos.end}</td></tr>`;
            });
            html += '</tbody></table></div>';
        }
    } else {
        html += '<div class="alert alert-success"><i class="mdi mdi-check me-2"></i>未发现敏感内容</div>';
    }
    
    detectionContent.innerHTML = html;
    
    // 展开检测结果手风琴
    new bootstrap.Collapse(document.getElementById('collapseDetection'), {toggle: true});
}

// 标记敏感内容
function markSensitiveContent(content, positions) {
    if (!positions || positions.length === 0) {
        return content;
    }
    
    // 按起始位置排序，从后往前处理避免位置偏移
    const sortedPositions = positions.sort((a, b) => b.start - a.start);
    
    let markedContent = content;
    sortedPositions.forEach(pos => {
        if (pos.start >= 0 && pos.end <= markedContent.length && pos.start < pos.end) {
            const before = markedContent.substring(0, pos.start);
            // 使用检测到的实际内容，如果没有则从原文中提取
            const matchText = pos.match || markedContent.substring(pos.start, pos.end);
            const marked = `<span class="highlight-marked" data-type="${pos.type || ''}" title="${pos.type || '敏感内容'}">${matchText}</span>`;
            const after = markedContent.substring(pos.end);
            markedContent = before + marked + after;
        }
    });
    
    return markedContent;
}

// 润色内容
function rewriteContent() {
    if (!detectionData || !detectionData.detection.has_sensitive) {
        alert('没有需要润色的内容');
        return;
    }

    const rewriteContentDiv = document.getElementById('rewriteContent');
    const resultFooter = document.getElementById('resultFooter');
    
    const rewriteBtn = resultFooter.querySelector('button');
    const originalText = rewriteBtn.textContent;
    rewriteBtn.disabled = true;
    rewriteBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>正在润色...';
    
    const formData = new FormData(document.getElementById('detectForm'));
    const modelCode = formData.get('model_code') || '';
    
    const data = {
        content: detectionData.original,
        positions: detectionData.detection.positions,
        model_code: modelCode
    };

    fetch('<?= $this->getBackendUrl('*/backend/detect/rewrite') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        rewriteBtn.disabled = false;
        rewriteBtn.textContent = originalText;
        
        if (data.success) {
            rewriteData = data.data;
            displayRewriteResult();
        } else {
            alert('润色失败: ' + data.message);
        }
    })
    .catch(error => {
        rewriteBtn.disabled = false;
        rewriteBtn.textContent = originalText;
        alert('润色失败: ' + error.message);
    });
}

// 显示润色结果
function displayRewriteResult() {
    const rewriteContentDiv = document.getElementById('rewriteContent');
    const rewriteFooter = document.getElementById('rewriteFooter');
    const compareContentDiv = document.getElementById('compareContent');
    
    rewriteContentDiv.innerHTML = `<div style="white-space: pre-wrap;" id="polishedContent">${rewriteData.content}</div>`;
    compareContentDiv.innerHTML = generateComparisonContent();
    
    // 显示润色后的操作按钮
    rewriteFooter.style.display = 'block';
    
    // 展开润色结果手风琴
    new bootstrap.Collapse(document.getElementById('collapseRewrite'), {toggle: true});
}

// 生成对比内容
function generateComparisonContent() {
    if (!detectionData || !rewriteData) {
        return '<div class="text-muted">暂无对比数据</div>';
    }
    
    const markedOriginal = markSensitiveContent(detectionData.original, detectionData.detection.positions);
    
    return `
        <div class="row">
            <div class="col-md-6">
                <h6 class="text-danger"><i class="mdi mdi-alert me-1"></i>原内容（标记敏感部分）</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${markedOriginal}
                </div>
            </div>
            <div class="col-md-6">
                <h6 class="text-success"><i class="mdi mdi-auto-fix me-1"></i>润色后内容</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${rewriteData.content}
                </div>
            </div>
        </div>
    `;
}

// 历史记录数组
let historyList = [];

// 再次检测润色后的内容
function reDetectPolishedContent() {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可检测的润色内容');
        return;
    }
    
    // 保存当前内容到历史记录
    const timestamp = new Date().toLocaleString('zh-CN');
    historyList.unshift({
        content: detectionData ? detectionData.original : '',
        timestamp: timestamp,
        type: 'original',
        detection: detectionData ? detectionData.detection : null
    });
    
    // 显示历史版本区域
    document.getElementById('historyAccordionItem').style.display = 'block';
    updateHistoryDisplay();
    
    // 将润色后的内容填入检测输入框
    document.getElementById('content').value = rewriteData.content;
    
    // 自动执行检测
    executeDetect();
}

// 更新历史版本显示
function updateHistoryDisplay() {
    const historyContent = document.getElementById('historyContent');
    
    if (historyList.length === 0) {
        historyContent.innerHTML = '<div class="text-muted text-center py-4">暂无历史记录...</div>';
        return;
    }
    
    let html = '<div class="history-list">';
    historyList.forEach((item, index) => {
        html += `
            <div class="card mb-3">
                <div class="card-header py-2">
                    <small class="text-muted">
                        <i class="mdi mdi-clock-outline me-1"></i>${item.timestamp}
                        ${item.type === 'original' ? '<span class="badge bg-secondary ms-2">原始内容</span>' : '<span class="badge bg-info ms-2">润色内容</span>'}
                    </small>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">${item.content}</div>
                    ${item.detection && item.detection.has_sensitive ? 
                        `<div class="mt-2 text-danger"><small>包含敏感内容: ${item.detection.sensitive_types.join(', ')}</small></div>` : 
                        ''}
                </div>
            </div>
        `;
    });
    html += '</div>';
    
    historyContent.innerHTML = html;
}

// 复制润色后的内容
function copyPolishedContent() {
    const polishedText = document.getElementById('polishedContent').innerText;
    
    // 创建临时文本框
    const tempInput = document.createElement('textarea');
    tempInput.value = polishedText;
    document.body.appendChild(tempInput);
    tempInput.select();
    
    try {
        document.execCommand('copy');
        
        // 显示成功提示
        const btn = event.target.closest('button');
        const originalHtml = btn.innerHTML;
        const originalClasses = btn.className;
        btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已复制';
        btn.className = 'btn btn-primary btn-sm ms-2';
        
        setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.className = originalClasses;
        }, 2000);
    } catch (err) {
        alert('复制失败，请手动选择文本复制');
    }
    
    document.body.removeChild(tempInput);
}

// 导出润色后的内容
function exportPolishedContent(format) {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可导出的内容');
        return;
    }
    
    const polishedText = rewriteData.content;
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
    let filename, content, mimeType;
    
    if (format === 'html') {
        filename = `polished_content_${timestamp}.html`;
        content = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>润色后的内容 - ${timestamp}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.6;
        }
        .content {
            white-space: pre-wrap;
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }
        .header {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #dee2e6;
        }
        .timestamp {
            color: #6c757d;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>润色后的内容</h1>
        <p class="timestamp">导出时间: ${new Date().toLocaleString('zh-CN')}</p>
    </div>
    <div class="content">${polishedText}</div>
</body>
</html>`;
        mimeType = 'text/html';
    } else if (format === 'txt') {
        filename = `polished_content_${timestamp}.txt`;
        content = polishedText;
        mimeType = 'text/plain';
    } else {
        alert('不支持的导出格式');
        return;
    }
    
    // 创建下载链接
    const blob = new Blob([content], { type: mimeType + ';charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    // 显示成功提示
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已导出';
    
    setTimeout(() => {
        btn.innerHTML = originalHtml;
    }, 2000);
}

