<script>
// 全局变量
let allModels = [];
let detectionData = null;
let rewriteData = null;

// Debounce实现
function debounce(func, delay) {
    let timeoutId;
    return function (...args) {
        if (timeoutId) {
            clearTimeout(timeoutId);
        }
        timeoutId = setTimeout(() => {
            func.apply(this, args);
            timeoutId = null;
        }, delay);
    };
}

// 加载AI模型列表
function loadModels() {
    const modelList = document.getElementById('model_list');
    const loadingDiv = document.getElementById('model_loading');
    const modelContainer = document.getElementById('model_container');
    const modelTrigger = document.getElementById('model_trigger');
    
    modelTrigger.style.display = 'none';
    modelContainer.style.display = 'block';
    loadingDiv.style.display = 'block';
    modelList.innerHTML = '';
    
    fetch('<?= $this->getBackendUrl('*/backend/detect/models') ?>', {
        method: 'GET',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        loadingDiv.style.display = 'none';
        if (!response.ok) {
            throw new Error('网络请求失败: ' + response.status);
        }
        return response.json();
    })
    .then(result => {
        if (result.success && result.data && result.data.length > 0) {
            allModels = result.data;
            console.log('AI模型加载成功，共加载', result.data.length, '个模型');
            displayModels(allModels);
        } else {
            modelList.innerHTML = '<div class="p-2 text-danger">⚠️ 未找到可用的AI模型</div>';
            console.warn('未获取到AI模型数据');
        }
    })
    .catch(error => {
        loadingDiv.style.display = 'none';
        modelList.innerHTML = '<div class="p-2 text-danger">❌ 加载失败: ' + (error.message || error) + '</div>';
        console.error('加载AI模型失败:', error);
    });
}

// 显示模型列表
function displayModels(models) {
    const modelList = document.getElementById('model_list');
    
    if (models.length === 0) {
        modelList.innerHTML = '<div class="p-2 text-muted">未找到匹配的模型</div>';
        return;
    }
    
    modelList.innerHTML = models.map(model => {
        const displayText = `${model.name} (${model.supplier}) - ${model.version}`;
        return `<div class="p-2 border-bottom" style="cursor: pointer;" data-code="${model.code}" data-text="${displayText}" 
                 onmouseover="this.style.backgroundColor='#f8f9fa'" 
                 onmouseout="this.style.backgroundColor='white'">
                 ${displayText}
                </div>`;
    }).join('');
    
    modelList.querySelectorAll('[data-code]').forEach(item => {
        item.addEventListener('click', function() {
            const code = this.dataset.code;
            const text = this.dataset.text;
            
            document.getElementById('model_code').value = code;
            
            const modelTrigger = document.getElementById('model_trigger');
            const modelDisplay = document.getElementById('model_display');
            const modelContainer = document.getElementById('model_container');
            
            modelDisplay.textContent = text;
            modelTrigger.style.display = 'block';
            modelContainer.style.display = 'none';
        });
    });
}

// 搜索模型（使用debounce）
const debouncedSearch = debounce(function(searchTerm) {
    if (!searchTerm.trim()) {
        displayModels(allModels);
        return;
    }
    
    const searchLower = searchTerm.toLowerCase();
    const filtered = allModels.filter(model => {
        const searchText = `${model.name} ${model.supplier} ${model.version}`.toLowerCase();
        return searchText.includes(searchLower);
    });
    
    displayModels(filtered);
}, 800);

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    const modelTrigger = document.getElementById('model_trigger');
    const searchInput = document.getElementById('model_search');
    
    modelTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        loadModels();
        setTimeout(() => searchInput.focus(), 100);
    });
    
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value;
        debouncedSearch(searchTerm);
    });
});

function executeDetect() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入检测内容');
        return;
    }

    // 显示“检测中”弹窗
    const detectLoadingModal = new bootstrap.Modal(document.getElementById('detectLoadingModal'));
    detectLoadingModal.show();

    const form = document.getElementById('detectForm');
    const formData = new FormData(form);
    const data = {};
    formData.forEach((value, key) => {
        if (key === 'rule_types[]') {
            if (!data.rule_types) data.rule_types = [];
            data.rule_types.push(value);
        } else {
            data[key] = value;
        }
    });

    const detectionContent = document.getElementById('detectionContent');
    const resultFooter = document.getElementById('resultFooter');
    
    detectionContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>正在检测...</div>';
    resultFooter.style.display = 'none';

    fetch('<?= $this->getBackendUrl('*/backend/detect/execute') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        detectLoadingModal.hide();
        if (data.success) {
            detectionData = data.data;
            displayDetectionResult(data.data);
            
            if (data.data.detection.has_sensitive) {
                resultFooter.style.display = 'block';
            }
        } else {
            detectionContent.innerHTML = `<div class="alert alert-danger">检测失败: ${data.message}</div>`;
        }
    })
    .catch(error => {
        detectLoadingModal.hide();
        detectionContent.innerHTML = `<div class="alert alert-danger">检测失败: ${error.message}</div>`;
    });
}

// 显示检测结果
function displayDetectionResult(result) {
    const detectionContent = document.getElementById('detectionContent');
    
    let html = `
        <div class="alert alert-info">
            <strong>检测完成</strong> - 执行时间: ${result.execution_time}
        </div>
    `;
    
    if (result.detection.has_sensitive) {
        html += `
            <div class="alert alert-warning">
                <h5><i class="mdi mdi-alert me-2"></i>发现敏感内容</h5>
                <strong>敏感类型：</strong> ${result.detection.sensitive_types.join(', ')}<br>
                <strong>发现 ${result.detection.positions.length} 处敏感信息</strong>
            </div>
        `;
        
        const markedContent = markSensitiveContent(result.original, result.detection.positions);
        html += `
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">标记后的内容</h5>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap;">${markedContent}</div>
                </div>
            </div>
        `;
        
        if (result.detection.positions && result.detection.positions.length > 0) {
            html += '<div class="table-responsive"><table class="table table-sm table-bordered"><thead><tr><th>类型</th><th>内容</th><th>位置</th></tr></thead><tbody>';
            result.detection.positions.forEach(pos => {
                html += `<tr><td><span class="badge bg-danger">${pos.type}</span></td><td><code>${pos.match}</code></td><td>${pos.start}-${pos.end}</td></tr>`;
            });
            html += '</tbody></table></div>';
        }
    } else {
        html += '<div class="alert alert-success"><i class="mdi mdi-check me-2"></i>未发现敏感内容</div>';
    }
    
    detectionContent.innerHTML = html;
    
    // 展开检测结果手风琴
    new bootstrap.Collapse(document.getElementById('collapseDetection'), {toggle: true});
}

// 标记敏感内容
function markSensitiveContent(content, positions) {
    if (!positions || positions.length === 0) {
        return content;
    }
    
    const sortedPositions = positions.sort((a, b) => b.start - a.start);
    
    let markedContent = content;
    sortedPositions.forEach(pos => {
        const before = markedContent.substring(0, pos.start);
        const marked = `<span class="highlight-marked">${pos.match}</span>`;
        const after = markedContent.substring(pos.end);
        markedContent = before + marked + after;
    });
    
    return markedContent;
}

// 润色内容
function rewriteContent() {
    if (!detectionData || !detectionData.detection.has_sensitive) {
        alert('没有需要润色的内容');
        return;
    }

    const rewriteContentDiv = document.getElementById('rewriteContent');
    const resultFooter = document.getElementById('resultFooter');
    
    const rewriteBtn = resultFooter.querySelector('button');
    const originalText = rewriteBtn.textContent;
    rewriteBtn.disabled = true;
    rewriteBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>正在润色...';
    
    const formData = new FormData(document.getElementById('detectForm'));
    const modelCode = formData.get('model_code') || '';
    
    const data = {
        content: detectionData.original,
        positions: detectionData.detection.positions,
        model_code: modelCode
    };

    fetch('<?= $this->getBackendUrl('*/backend/detect/rewrite') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        rewriteBtn.disabled = false;
        rewriteBtn.textContent = originalText;
        
        if (data.success) {
            rewriteData = data.data;
            displayRewriteResult();
        } else {
            alert('润色失败: ' + data.message);
        }
    })
    .catch(error => {
        rewriteBtn.disabled = false;
        rewriteBtn.textContent = originalText;
        alert('润色失败: ' + error.message);
    });
}

// 显示润色结果
function displayRewriteResult() {
    const rewriteContentDiv = document.getElementById('rewriteContent');
    const compareContentDiv = document.getElementById('compareContent');
    
    rewriteContentDiv.innerHTML = `<div style="white-space: pre-wrap;">${rewriteData.content}</div>`;
    compareContentDiv.innerHTML = generateComparisonContent();
    
    // 展开润色结果手风琴
    new bootstrap.Collapse(document.getElementById('collapseRewrite'), {toggle: true});
}

// 生成对比内容
function generateComparisonContent() {
    if (!detectionData || !rewriteData) {
        return '<div class="text-muted">暂无对比数据</div>';
    }
    
    const markedOriginal = markSensitiveContent(detectionData.original, detectionData.detection.positions);
    
    return `
        <div class="row">
            <div class="col-md-6">
                <h6 class="text-danger"><i class="mdi mdi-alert me-1"></i>原内容（标记敏感部分）</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${markedOriginal}
                </div>
            </div>
            <div class="col-md-6">
                <h6 class="text-success"><i class="mdi mdi-auto-fix me-1"></i>润色后内容</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${rewriteData.content}
                </div>
            </div>
        </div>
    `;
}
</script>

</body>
</html>
