// 生成对比内容
function generateComparisonContent() {
    if (!detectionData || !rewriteData) {
        return '<div class="text-muted">暂无对比数据</div>';
    }
    
    const markedOriginal = markSensitiveContent(detectionData.original, detectionData.detection.positions);
    
    return `
        <div class="row">
            <div class="col-md-6">
                <h6 class="text-danger"><i class="mdi mdi-alert me-1"></i>原内容（标记敏感部分）</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${markedOriginal}
                </div>
            </div>
            <div class="col-md-6">
                <h6 class="text-success"><i class="mdi mdi-auto-fix me-1"></i>润色后内容</h6>
                <div class="border rounded p-3" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                    ${rewriteData.content}
                </div>
            </div>
        </div>
    `;
}

// 历史记录数组
let historyList = [];

// 再次检测润色后的内容
function reDetectPolishedContent() {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可检测的润色内容');
        return;
    }
    
    // 保存当前内容到历史记录
    const timestamp = new Date().toLocaleString('zh-CN');
    historyList.unshift({
        content: detectionData ? detectionData.original : '',
        timestamp: timestamp,
        type: 'original',
        detection: detectionData ? detectionData.detection : null
    });
    
    // 显示历史版本区域
    document.getElementById('historyAccordionItem').style.display = 'block';
    updateHistoryDisplay();
    
    // 将润色后的内容填入检测输入框
    document.getElementById('content').value = rewriteData.content;
    
    // 自动执行检测
    executeDetect();
}

// 更新历史版本显示
function updateHistoryDisplay() {
    const historyContent = document.getElementById('historyContent');
    
    if (historyList.length === 0) {
        historyContent.innerHTML = '<div class="text-muted text-center py-4">暂无历史记录...</div>';
        return;
    }
    
    let html = '<div class="history-list">';
    historyList.forEach((item, index) => {
        html += `
            <div class="card mb-3">
                <div class="card-header py-2">
                    <small class="text-muted">
                        <i class="mdi mdi-clock-outline me-1"></i>${item.timestamp}
                        ${item.type === 'original' ? '<span class="badge bg-secondary ms-2">原始内容</span>' : '<span class="badge bg-info ms-2">润色内容</span>'}
                    </small>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">${item.content}</div>
                    ${item.detection && item.detection.has_sensitive ? 
                        `<div class="mt-2 text-danger"><small>包含敏感内容: ${item.detection.sensitive_types.join(', ')}</small></div>` : 
                        ''}
                </div>
            </div>
        `;
    });
    html += '</div>';
    
    historyContent.innerHTML = html;
}

// 复制润色后的内容
function copyPolishedContent() {
    const rewriteTextArea = document.getElementById('rewriteTextArea');
    const polishedText = rewriteTextArea ? rewriteTextArea.value : '';
    
    if (!polishedText) {
        alert('没有可复制的内容');
        return;
    }
    
    // 创建临时文本框
    const tempInput = document.createElement('textarea');
    tempInput.value = polishedText;
    document.body.appendChild(tempInput);
    tempInput.select();
    
    try {
        document.execCommand('copy');
        
        // 显示成功提示
        const btn = event.target.closest('button');
        const originalHtml = btn.innerHTML;
        const originalClasses = btn.className;
        btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已复制';
        btn.className = 'btn btn-primary btn-sm ms-2';
        
        setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.className = originalClasses;
        }, 2000);
    } catch (err) {
        alert('复制失败，请手动选择文本复制');
    }
    
    document.body.removeChild(tempInput);
}

// 导出润色后的内容
function exportPolishedContent(format) {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可导出的内容');
        return;
    }
    
    const polishedText = rewriteData.content;
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
    let filename, content, mimeType;
    
    if (format === 'html') {
        filename = `polished_content_${timestamp}.html`;
        content = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>润色后的内容 - ${timestamp}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.6;
        }
        .content {
            white-space: pre-wrap;
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }
        .header {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #dee2e6;
        }
        .timestamp {
            color: #6c757d;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>润色后的内容</h1>
        <p class="timestamp">导出时间: ${new Date().toLocaleString('zh-CN')}</p>
    </div>
    <div class="content">${polishedText}</div>
</body>
</html>`;
        mimeType = 'text/html';
    } else if (format === 'txt') {
        filename = `polished_content_${timestamp}.txt`;
        content = polishedText;
        mimeType = 'text/plain';
    } else {
        alert('不支持的导出格式');
        return;
    }
    
    // 创建下载链接
    const blob = new Blob([content], { type: mimeType + ';charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    // 显示成功提示
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已导出';
    
    setTimeout(() => {
        btn.innerHTML = originalHtml;
    }, 2000);
}

// 回退到正则检测
function fallbackToRegexDetection() {
    // 清除模型选择
    document.getElementById('model_code').value = '';
    document.getElementById('model_display').textContent = '使用默认模型';
    
    // 关闭弹窗
    hideLoadingModal();
    
    // 重新执行检测
    executeDetect();
}

// 在弹窗中显示错误
function showErrorInModal(errorMessage, showFallbackOption = false) {
    // 隐藏加载内容，显示错误内容
    document.getElementById('detectLoadingContent').style.display = 'none';
    document.getElementById('detectErrorContent').style.display = 'block';
    document.getElementById('detectLoadingHeader').style.display = 'block';
    
    // 构建错误内容
    let errorHtml = `
        <div class="text-center">
            <div class="mb-3">
                <i class="mdi mdi-alert-circle text-danger" style="font-size: 48px;"></i>
            </div>
            <h5 class="text-danger">检测失败</h5>
            <p class="text-muted">${errorMessage}</p>
    `;
    
    if (showFallbackOption) {
        errorHtml += `
            <div class="mt-3">
                <button type="button" class="btn btn-secondary btn-sm" onclick="fallbackToRegexDetection()">
                    <i class="mdi mdi-regex me-1"></i>
                    使用正则检测
                </button>
            </div>
        `;
    }
    
    errorHtml += `</div>`;
    
    // 设置错误内容
    document.getElementById('detectErrorContent').innerHTML = errorHtml;
    
    // 允许通过ESC键或点击背景关闭弹窗
    if (detectLoadingModalInstance) {
        detectLoadingModalInstance._config.keyboard = true;
        detectLoadingModalInstance._config.backdrop = true;
    }
}

