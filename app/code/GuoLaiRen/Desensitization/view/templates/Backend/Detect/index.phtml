<script>
// 全局变量
let allModels = [];
let detectionData = null;
let rewriteData = null;
let defaultModelCode = '<?= $this->getData('defaultModel') ?? '' ?>';

// Debounce实现
function debounce(func, delay) {
    let timeoutId;
    return function (...args) {
        if (timeoutId) {
            clearTimeout(timeoutId);
        }
        timeoutId = setTimeout(() => {
            func.apply(this, args);
            timeoutId = null;
        }, delay);
    };
}

// 加载AI模型列表
function loadModels() {
    const modelList = document.getElementById('model_list');
    const loadingDiv = document.getElementById('model_loading');
    const modelContainer = document.getElementById('model_container');
    const modelTrigger = document.getElementById('model_trigger');
    
    modelTrigger.style.display = 'none';
    modelContainer.style.display = 'block';
    loadingDiv.style.display = 'block';
    modelList.innerHTML = '';
    
    fetch('<?= $this->getBackendUrl('*/backend/detect/models') ?>', {
        method: 'GET',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        loadingDiv.style.display = 'none';
        if (!response.ok) {
            throw new Error('网络请求失败: ' + response.status);
        }
        return response.json();
    })
    .then(result => {
        if (result.success && result.data && result.data.length > 0) {
            allModels = result.data;
            console.log('AI模型加载成功，共加载', result.data.length, '个模型');
            displayModels(allModels);
        } else {
            modelList.innerHTML = '<div class="p-2 text-danger">⚠️ 未找到可用的AI模型</div>';
            console.warn('未获取到AI模型数据');
        }
    })
    .catch(error => {
        loadingDiv.style.display = 'none';
        modelList.innerHTML = '<div class="p-2 text-danger">❌ 加载失败: ' + (error.message || error) + '</div>';
        console.error('加载AI模型失败:', error);
    });
}

// 显示模型列表
function displayModels(models) {
    const modelList = document.getElementById('model_list');
    
    if (models.length === 0) {
        modelList.innerHTML = '<div class="p-2 text-muted">未找到匹配的模型</div>';
        return;
    }
    
    modelList.innerHTML = models.map(model => {
        const displayText = `${model.name} (${model.supplier}) - ${model.version}`;
        return `<div class="p-2 border-bottom" style="cursor: pointer;" data-code="${model.code}" data-text="${displayText}" 
                 onmouseover="this.style.backgroundColor='#f8f9fa'" 
                 onmouseout="this.style.backgroundColor='white'">
                 ${displayText}
                </div>`;
    }).join('');
    
    modelList.querySelectorAll('[data-code]').forEach(item => {
        item.addEventListener('click', function() {
            const code = this.dataset.code;
            const text = this.dataset.text;
            
            document.getElementById('model_code').value = code;
            
            const modelTrigger = document.getElementById('model_trigger');
            const modelDisplay = document.getElementById('model_display');
            const modelContainer = document.getElementById('model_container');
            
            modelDisplay.textContent = text;
            modelTrigger.style.display = 'block';
            modelContainer.style.display = 'none';
        });
    });
}

// 搜索模型（使用debounce）
const debouncedSearch = debounce(function(searchTerm) {
    if (!searchTerm.trim()) {
        displayModels(allModels);
        return;
    }
    
    const searchLower = searchTerm.toLowerCase();
    const filtered = allModels.filter(model => {
        const searchText = `${model.name} ${model.supplier} ${model.version}`.toLowerCase();
        return searchText.includes(searchLower);
    });
    
    displayModels(filtered);
}, 800);

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    const modelTrigger = document.getElementById('model_trigger');
    const searchInput = document.getElementById('model_search');
    // 初始化检测弹窗（单例）
    initDetectModal();
    
    // 如果有默认模型，设置隐藏字段的值
    if (defaultModelCode) {
        document.getElementById('model_code').value = defaultModelCode;
        // 可选：加载模型列表以显示默认模型名称
        loadDefaultModelInfo();
    }
    
    modelTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        loadModels();
        setTimeout(() => searchInput.focus(), 100);
    });
    
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value;
        debouncedSearch(searchTerm);
    });
});

// 加载默认模型信息
function loadDefaultModelInfo() {
    if (!defaultModelCode) return;
    
    fetch('<?= $this->getBackendUrl('*/backend/detect/models') ?>', {
        method: 'GET',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => response.json())
    .then(result => {
        if (result.success && result.data && result.data.length > 0) {
            const defaultModel = result.data.find(model => model.code === defaultModelCode);
            if (defaultModel) {
                const displayText = `${defaultModel.name} (${defaultModel.supplier}) - ${defaultModel.version}`;
                document.getElementById('model_display').textContent = displayText;
            }
        }
    })
    .catch(error => {
        console.error('加载默认模型信息失败:', error);
    });
}

// 全局变量存储检测弹窗实例（单例）
let detectLoadingModalInstance = null;
let detectLoadingModalEl = null;

function initDetectModal() {
    if (detectLoadingModalInstance) return;
    detectLoadingModalEl = document.getElementById('detectLoadingModal');
    if (!detectLoadingModalEl) return;

    // 初始化为不可通过键盘/点击关闭
    detectLoadingModalInstance = new bootstrap.Modal(detectLoadingModalEl, {
        keyboard: false,
        backdrop: 'static'
    });

    // 隐藏后仅在无其它可见弹窗时清理 body 状态，避免与 Bootstrap 的销毁流程冲突
    detectLoadingModalEl.addEventListener('hidden.bs.modal', () => {
        const anyModalShown = document.querySelector('.modal.show');
        if (!anyModalShown) {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('overflow');
            document.body.style.removeProperty('padding-right');
            // 若仍有遗留 backdrop 且没有可见弹窗，再做兜底清理
            const backdrops = document.querySelectorAll('.modal-backdrop');
            if (backdrops.length) {
                backdrops.forEach(b => b.parentNode && b.parentNode.removeChild(b));
            }
        }
    });
}

function showLoadingModal() {
    initDetectModal();
    if (!detectLoadingModalInstance || !detectLoadingModalEl) return;

    // 强制设为不可关闭（加载态）
    detectLoadingModalEl.setAttribute('data-bs-keyboard', 'false');
    detectLoadingModalEl.setAttribute('data-bs-backdrop', 'static');
    detectLoadingModalInstance._config.keyboard = false;
    detectLoadingModalInstance._config.backdrop = 'static';

    // 重置为加载内容
    document.getElementById('detectLoadingContent').style.display = 'block';
    document.getElementById('detectErrorContent').style.display = 'none';
    document.getElementById('detectLoadingHeader').style.display = 'none';

    detectLoadingModalInstance.show();
}

function hideLoadingModal() {
    if (!detectLoadingModalInstance) return;
    detectLoadingModalInstance.hide();
    // 兜底：仅当没有其它弹窗时再清理 body 与遗留 backdrop
    setTimeout(() => {
        const anyModalShown = document.querySelector('.modal.show');
        if (!anyModalShown) {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('overflow');
            document.body.style.removeProperty('padding-right');
            const backdrops = document.querySelectorAll('.modal-backdrop');
            if (backdrops.length) {
                backdrops.forEach(b => b.parentNode && b.parentNode.removeChild(b));
            }
        }
    }, 300);
}

function executeDetect() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入检测内容');
        return;
    }

    // 显示统一的加载弹窗
    showLoadingModal();

    const form = document.getElementById('detectForm');
    const formData = new FormData(form);
    const data = {};
    formData.forEach((value, key) => {
        if (key === 'rule_types[]') {
            if (!data.rule_types) data.rule_types = [];
            data.rule_types.push(value);
        } else {
            data[key] = value;
        }
    });
    
    // 如果没有选择模型，使用默认模型
    if (!data.model_code && defaultModelCode) {
        data.model_code = defaultModelCode;
    }

    const detectionContent = document.getElementById('detectionContent');
    const resultFooter = document.getElementById('resultFooter');
    
    detectionContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>正在检测...</div>';
    if (resultFooter) resultFooter.style.display = 'none';

    fetch('<?= $this->getBackendUrl('*/backend/detect/execute') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 成功才关闭加载弹窗
            hideLoadingModal();
            detectionData = data.data;
            displayDetectionResult(data.data);
            
        } else {
            // 不关闭弹窗，直接切换为错误内容，避免隐藏/显示竞态
            const isAIError = data.message && data.message.includes('AI');
            showErrorInModal(data.message, isAIError);
            
            // 同时在页面上显示错误信息
            detectionContent.innerHTML = `<div class="alert alert-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                <strong>检测失败</strong><br>
                ${data.message}
            </div>`;
            
            // 如果是AI相关错误，显示提示和回退选项
            if (isAIError) {
                detectionContent.innerHTML += `
                    <div class="alert alert-warning mt-3">
                        <i class="mdi mdi-information me-2"></i>
                        <strong>提示</strong><br>
                        • 请检查AI模型配置是否正确<br>
                        • 确保供应商账户已配置并激活<br>
                        • 您也可以取消选择模型，使用正则检测
                    </div>
                    <div class="text-center mt-3">
                        <button type="button" class="btn btn-secondary" onclick="fallbackToRegexDetection()">
                            <i class="mdi mdi-regex me-1"></i>
                            使用正则检测
                        </button>
                    </div>
                `;
            }
        }
    })
    .catch(error => {
        // 在弹窗中显示错误
        showErrorInModal(error.message || '网络错误或服务器异常', false);
        
        // 同时在页面上显示错误信息
        detectionContent.innerHTML = `<div class="alert alert-danger">
            <i class="mdi mdi-alert-circle me-2"></i>
            <strong>检测失败</strong><br>
            ${error.message || '网络错误或服务器异常'}
        </div>`;
    });
}

// 处理弹窗点击事件，防止意外关闭
function handleModalClick(event) {
    // 阻止点击弹窗背景关闭弹窗
    if (event.target === event.currentTarget) {
        event.preventDefault();
        event.stopPropagation();
        return false;
    }
}

// 显示检测结果
function displayDetectionResult(result) {
    const detectionContent = document.getElementById('detectionContent');
    
    let html = `
        <div class="alert alert-info">
            <strong>检测完成</strong> - 执行时间: ${result.execution_time}
        </div>
    `;
    
    if (result.detection.has_sensitive) {
        html += `
            <div class="alert alert-warning">
                <h5><i class="mdi mdi-alert me-2"></i>发现敏感内容</h5>
                <strong>敏感类型：</strong> ${result.detection.sensitive_types.join(', ')}<br>
                <strong>发现 ${result.detection.positions.length} 处敏感信息</strong>
            </div>
        `;
        
        // 在原文拷贝上进行高亮标记
        const originalCopy = result.original;
        const markedContent = markSensitiveContent(originalCopy, result.detection.positions);
        html += `
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">检测结果（原文标记）</h5>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap; word-wrap: break-word;" id="markedContentDisplay">${markedContent}</div>
                </div>
            </div>
        `;
        
        if (result.detection.positions && result.detection.positions.length > 0) {
            html += '<div class="table-responsive"><table class="table table-sm table-bordered"><thead><tr><th>类型</th><th>内容</th><th>位置</th></tr></thead><tbody>';
            result.detection.positions.forEach(pos => {
                html += `<tr><td><span class="badge bg-danger">${pos.type}</span></td><td><code>${pos.match}</code></td><td>${pos.start}-${pos.end}</td></tr>`;
            });
            html += '</tbody></table></div>';
        }
    } else {
        html += '<div class="alert alert-success"><i class="mdi mdi-check me-2"></i>未发现敏感内容</div>';
    }
    
    detectionContent.innerHTML = html;
    
    // 自动展开检测结果手风琴
    const detectionCollapseEl = document.getElementById('collapseDetection');
    const detectionCollapse = new bootstrap.Collapse(detectionCollapseEl, {
        toggle: true
    });
    // 确保展开
    setTimeout(() => {
        if (!detectionCollapseEl.classList.contains('show')) {
            detectionCollapse.show();
        }
    }, 100);
    
    // 如果有敏感内容，显示开始润色按钮
    if (result.detection.has_sensitive) {
        const startRewriteBtn = document.getElementById('startRewriteBtn');
        if (startRewriteBtn) {
            startRewriteBtn.style.display = 'inline-block';
        }
    }
}

// 标记敏感内容
function markSensitiveContent(content, positions) {
    if (!positions || positions.length === 0) return content;

    // —————————— 通用偏移标注方案 ——————————
    // 1) Grapheme/码点到 UTF-16 码元索引映射
    const useGrapheme = (typeof Intl !== 'undefined' && Intl.Segmenter);
    let units = [];
    if (useGrapheme) {
        const seg = new Intl.Segmenter('zh-CN', { granularity: 'grapheme' });
        for (const s of seg.segment(content)) units.push(s.segment);
    } else {
        units = Array.from(content); // 按码点
    }
    const uToCu = [0];
    for (let i = 0, cu = 0; i < units.length; i++) {
        uToCu[i] = cu;
        const code = units[i].codePointAt(0);
        cu += (code > 0xFFFF) ? 2 : 1;
    }
    const totalCu = [...content].length === units.length ? content.length : content.length; // 安全使用原 length
    uToCu[units.length] = totalCu;
    const toCu = (uIdx) => {
        if (uIdx <= 0) return 0;
        if (uIdx >= uToCu.length) return totalCu;
        return uToCu[uIdx];
    };

    // 2) 区间标准化与就近纠偏（利用 match 文本）
    const norm = positions
        .map(p => ({
            start: Math.max(0, Number(p.start ?? 0)),
            end: Math.max(0, Number(p.end ?? 0)),
            type: p.type || '',
            match: p.match || ''
        }))
        .filter(p => p.end > p.start);

    const adjustByMatch = (p) => {
        if (!p.match) return p;
        // 在 ±128 个“单位”(码点/字素)窗口内就近搜寻 match
        const win = 128;
        const startU = Math.max(0, p.start - win);
        const endU = Math.min(units.length, p.end + win);
        const windowText = content.substring(toCu(startU), toCu(endU));
        let idxCu = windowText.indexOf(p.match);
        if (idxCu >= 0) {
            // 将窗口内的 CU 位置映射回全局 CU，再反推 U 索引
            const baseCu = toCu(startU);
            const absStartCu = baseCu + idxCu;
            const absEndCu = absStartCu + p.match.length;
            // 通过二分查找找到最接近的 U 边界
            const toU = (cu) => {
                let lo = 0, hi = uToCu.length - 1;
                while (lo < hi) {
                    const mid = (lo + hi) >> 1;
                    if (uToCu[mid] <= cu) lo = mid + 1; else hi = mid;
                }
                return Math.max(0, lo - 1);
            };
            const newStartU = toU(absStartCu);
            const newEndU = toU(absEndCu);
            return { ...p, start: newStartU, end: Math.max(newStartU + 1, newEndU) };
        }
        // 路径2：忽略空白进行匹配（处理 AI 返回忽略空格/换行导致的偏移）
        const stripWs = (s) => s.replace(/[\s\u00A0\u200B\u202F\u3000]+/g, '');
        const windowUnits = Array.from(windowText);
        const compactChars = [];
        const compactMap = []; // 紧凑索引 -> 原窗口内 CU 起始
        let cuOffset = 0;
        for (let i = 0; i < windowUnits.length; i++) {
            const ch = windowUnits[i];
            const code = ch.codePointAt(0);
            const cuLen = (code > 0xFFFF) ? 2 : 1;
            const isWs = /[\s\u00A0\u200B\u202F\u3000]/.test(ch);
            if (!isWs) {
                compactChars.push(ch);
                compactMap.push(cuOffset);
            }
            cuOffset += cuLen;
        }
        const compactWindow = compactChars.join('');
        const compactMatch = stripWs(p.match);
        const idxCompact = compactWindow.indexOf(compactMatch);
        if (idxCompact >= 0) {
            const baseCu = toCu(startU);
            const startCuInWindow = compactMap[idxCompact] || 0;
            // 估算结束 CU：累加紧凑匹配长度对应的 CU（取末尾映射或末尾）
            const endIndexCompact = idxCompact + compactMatch.length;
            const endCuInWindow = endIndexCompact < compactMap.length
                ? compactMap[endIndexCompact]
                : (windowText.length);
            const absStartCu = baseCu + startCuInWindow;
            const absEndCu = baseCu + endCuInWindow;
            const toU = (cu) => {
                let lo = 0, hi = uToCu.length - 1;
                while (lo < hi) {
                    const mid = (lo + hi) >> 1;
                    if (uToCu[mid] <= cu) lo = mid + 1; else hi = mid;
                }
                return Math.max(0, lo - 1);
            };
            const newStartU = toU(absStartCu);
            const newEndU = toU(absEndCu);
            return { ...p, start: newStartU, end: Math.max(newStartU + 1, newEndU) };
        }
        return p;
    };

    let adjusted = norm.map(adjustByMatch);

    // 3) 合并重叠/相邻区间（按开始升序）
    adjusted.sort((a, b) => a.start - b.start || a.end - b.end);
    const merged = [];
    for (const cur of adjusted) {
        if (!merged.length) { merged.push({ ...cur }); continue; }
        const last = merged[merged.length - 1];
        if (cur.start <= last.end) {
            last.end = Math.max(last.end, cur.end);
            // 类型优先保留风险更高的一类，或拼接
            last.type = last.type || cur.type;
        } else {
            merged.push({ ...cur });
        }
    }

    // 4) 用文本节点分割+包裹，避免偏移
    const container = document.createElement('div');
    const textNode = document.createTextNode(content);
    container.appendChild(textNode);

    // 从后往前，依据 U 索引转换到 CU
    for (let i = merged.length - 1; i >= 0; i--) {
        const seg = merged[i];
        const startCu = toCu(seg.start);
        const endCu = toCu(seg.end);
        if (startCu >= endCu || startCu < 0 || endCu > textNode.length) continue;
        const tail = textNode.splitText(endCu);
        const middle = textNode.splitText(startCu);
        const span = document.createElement('span');
        span.className = 'highlight-marked';
        if (seg.type) span.setAttribute('data-type', String(seg.type));
        span.title = String(seg.type || '敏感内容');
        span.appendChild(middle);
        textNode.parentNode.insertBefore(span, tail);
    }

    return container.innerHTML;
}

// 开始润色
function startRewrite() {
    if (!detectionData || !detectionData.detection.has_sensitive) {
        alert('没有需要润色的内容');
        return;
    }

    // 隐藏等待区域，显示结果区域
    document.getElementById('rewriteWaiting').style.display = 'none';
    document.getElementById('rewriteResult').style.display = 'block';
    
    const rewriteTextArea = document.getElementById('rewriteTextArea');
    const startRewriteBtn = document.getElementById('startRewriteBtn');
    
    const originalHtml = startRewriteBtn.innerHTML;
    startRewriteBtn.disabled = true;
    startRewriteBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>正在润色...';
    
    rewriteTextArea.value = '正在润色，请稍候...';
    rewriteTextArea.disabled = true;
    
    // 展开润色手风琴
    const rewriteCollapseEl = document.getElementById('collapseRewrite');
    const rewriteCollapse = new bootstrap.Collapse(rewriteCollapseEl, {
        toggle: true
    });
    
    const formData = new FormData(document.getElementById('detectForm'));
    let modelCode = formData.get('model_code') || '';
    
    // 如果没有选择模型，使用默认模型
    if (!modelCode && defaultModelCode) {
        modelCode = defaultModelCode;
    }
    
    const data = {
        content: detectionData.original,
        positions: detectionData.detection.positions,
        model_code: modelCode
    };

    fetch('<?= $this->getBackendUrl('*/backend/detect/rewrite') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        startRewriteBtn.disabled = false;
        startRewriteBtn.innerHTML = originalHtml;
        
        if (data.success) {
            rewriteData = data.data;
            // 将润色后的内容放入文本域
            rewriteTextArea.value = rewriteData.content || '';
            rewriteTextArea.disabled = false;
            startRewriteBtn.style.display = 'none';
        } else {
            rewriteTextArea.value = '润色失败: ' + data.message;
            rewriteTextArea.disabled = false;
            // 复用全局弹窗并显示错误
            initDetectModal();
            showErrorInModal('润色失败: ' + data.message, data.message && data.message.includes('AI'));
            if (detectLoadingModalInstance) detectLoadingModalInstance.show();
        }
    })
    .catch(error => {
        startRewriteBtn.disabled = false;
        startRewriteBtn.innerHTML = originalHtml;
        rewriteTextArea.value = '润色失败: ' + (error.message || '网络错误或服务器异常');
        rewriteTextArea.disabled = false;
        // 复用全局弹窗并显示错误
        initDetectModal();
        showErrorInModal('润色失败: ' + (error.message || '网络错误或服务器异常'), false);
        if (detectLoadingModalInstance) detectLoadingModalInstance.show();
    });
}

