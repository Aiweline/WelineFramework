<script>
(function() {
    'use strict';
    
    // 模块内变量
let allModels = [];
let detectionData = null;
let rewriteData = null;
let defaultModelCode = '<?= $this->getData('defaultModel') ?? '' ?>';

// Debounce实现
function debounce(func, delay) {
    let timeoutId;
    return function (...args) {
        if (timeoutId) {
            clearTimeout(timeoutId);
        }
        timeoutId = setTimeout(() => {
            func.apply(this, args);
            timeoutId = null;
        }, delay);
    };
}

// 加载AI模型列表
function loadModels() {
    const modelList = document.getElementById('model_list');
    const loadingDiv = document.getElementById('model_loading');
    const modelContainer = document.getElementById('model_container');
    const modelTrigger = document.getElementById('model_trigger');
    
    modelTrigger.style.display = 'none';
    modelContainer.style.display = 'block';
    loadingDiv.style.display = 'block';
    modelList.innerHTML = '';
    
    var detectModelsUrl = '<?= $this->getBackendUrl('*/backend/detect/models') ?>';
    var detectOpts = { method: 'GET', headers: {'Content-Type': 'application/json'} };
    window.Weline.Api.get(detectModelsUrl, { silent: true })
    .then(function(res) {
        loadingDiv.style.display = 'none';
        if (!res || res.ok === false) {
            throw new Error('网络请求失败: ' + (res && res.status || 500));
        }
        return (res && res.data) !== undefined ? res.data : res;
    })
    .then(function(result) {
        if (result.success && result.data && result.data.length > 0) {
            allModels = result.data;
            console.log('AI模型加载成功，共加载', result.data.length, '个模型');
            displayModels(allModels);
        } else {
            modelList.innerHTML = '<div class="p-2 text-danger">⚠️ 未找到可用的AI模型</div>';
            console.warn('未获取到AI模型数据');
        }
    })
    .catch(error => {
        loadingDiv.style.display = 'none';
        modelList.innerHTML = '<div class="p-2 text-danger">❌ 加载失败: ' + (error.message || error) + '</div>';
        console.error('加载AI模型失败:', error);
    });
}

// 显示模型列表
function displayModels(models) {
    const modelList = document.getElementById('model_list');
    
    if (models.length === 0) {
        modelList.innerHTML = '<div class="p-2 text-muted">未找到匹配的模型</div>';
        return;
    }
    
    modelList.innerHTML = models.map(model => {
        const displayText = `${model.name} (${model.supplier}) - ${model.version}`;
        return `<div class="p-2 border-bottom" style="cursor: pointer;" data-code="${model.code}" data-text="${displayText}" 
                 onmouseover="this.style.backgroundColor='#f8f9fa'" 
                 onmouseout="this.style.backgroundColor='white'">
                 ${displayText}
                </div>`;
    }).join('');
    
    modelList.querySelectorAll('[data-code]').forEach(item => {
        item.addEventListener('click', function() {
            const code = this.dataset.code;
            const text = this.dataset.text;
            
            document.getElementById('model_code').value = code;
            
            const modelTrigger = document.getElementById('model_trigger');
            const modelDisplay = document.getElementById('model_display');
            const modelContainer = document.getElementById('model_container');
            
            modelDisplay.textContent = text;
            modelTrigger.style.display = 'block';
            modelContainer.style.display = 'none';
        });
    });
}

// 搜索模型（使用debounce）
const debouncedSearch = debounce(function(searchTerm) {
    if (!searchTerm.trim()) {
        displayModels(allModels);
        return;
    }
    
    const searchLower = searchTerm.toLowerCase();
    const filtered = allModels.filter(model => {
        const searchText = `${model.name} ${model.supplier} ${model.version}`.toLowerCase();
        return searchText.includes(searchLower);
    });
    
    displayModels(filtered);
}, 800);

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    const modelTrigger = document.getElementById('model_trigger');
    const searchInput = document.getElementById('model_search');
    // 初始化检测弹窗（单例）
    initDetectModal();
    
    // 如果有默认模型，设置隐藏字段的值
    if (defaultModelCode) {
        document.getElementById('model_code').value = defaultModelCode;
        // 可选：加载模型列表以显示默认模型名称
        loadDefaultModelInfo();
    }
    
    modelTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        loadModels();
        setTimeout(() => searchInput.focus(), 100);
    });
    
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value;
        debouncedSearch(searchTerm);
    });
});

// 加载默认模型信息
function loadDefaultModelInfo() {
    if (!defaultModelCode) return;
    
    var opts = { method: 'GET', headers: {'Content-Type': 'application/json'} };
    window.Weline.Api.get('<?= $this->getBackendUrl('*/backend/detect/models') ?>', { silent: true })
    .then(function(res) {
        var result = (res && res.data) !== undefined ? res.data : res;
        if (result.success && result.data && result.data.length > 0) {
            const defaultModel = result.data.find(model => model.code === defaultModelCode);
            if (defaultModel) {
                const displayText = `${defaultModel.name} (${defaultModel.supplier}) - ${defaultModel.version}`;
                document.getElementById('model_display').textContent = displayText;
            }
        }
    })
    .catch(error => {
        console.error('加载默认模型信息失败:', error);
    });
}

// 全局变量存储检测弹窗实例（单例）
let detectLoadingModalInstance = null;
let detectLoadingModalEl = null;

function initDetectModal() {
    if (detectLoadingModalInstance) return;
    detectLoadingModalEl = document.getElementById('detectLoadingModal');
    if (!detectLoadingModalEl) return;

    // 初始化为不可通过键盘/点击关闭
    detectLoadingModalInstance = new bootstrap.Modal(detectLoadingModalEl, {
        keyboard: false,
        backdrop: 'static'
    });

    // 交由 Bootstrap 自身处理销毁与 backdrop 清理，避免双重清理导致的空指针
    detectLoadingModalEl.addEventListener('hidden.bs.modal', () => {});
}

function showLoadingModal() {
    initDetectModal();
    if (!detectLoadingModalInstance || !detectLoadingModalEl) return;

    // 强制设为不可关闭（加载态）
    detectLoadingModalEl.setAttribute('data-bs-keyboard', 'false');
    detectLoadingModalEl.setAttribute('data-bs-backdrop', 'static');
    detectLoadingModalInstance._config.keyboard = false;
    detectLoadingModalInstance._config.backdrop = 'static';

    // 重置为加载内容
    document.getElementById('detectLoadingContent').style.display = 'block';
    document.getElementById('detectErrorContent').style.display = 'none';
    document.getElementById('detectLoadingHeader').style.display = 'none';

    detectLoadingModalInstance.show();
}

function hideLoadingModal() {
    if (!detectLoadingModalInstance) return;
    // 仅调用 Bootstrap 的 hide，避免手动移除 backdrop 造成引用失效
    detectLoadingModalInstance.hide();
}

function executeDetect() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入检测内容');
        return;
    }

    // 显示统一的加载弹窗
    showLoadingModal();

    const form = document.getElementById('detectForm');
    const formData = new FormData(form);
    const data = {};
    formData.forEach((value, key) => {
        if (key === 'rule_types[]') {
            if (!data.rule_types) data.rule_types = [];
            data.rule_types.push(value);
        } else {
            data[key] = value;
        }
    });
    
    // 如果没有选择模型，使用默认模型
    if (!data.model_code && defaultModelCode) {
        data.model_code = defaultModelCode;
    }

    const detectionContent = document.getElementById('detectionContent');
    const resultFooter = document.getElementById('resultFooter');
    
    detectionContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>正在检测...</div>';
    if (resultFooter) resultFooter.style.display = 'none';

    var execUrl = '<?= $this->getBackendUrl('*/backend/detect/execute') ?>';
    var execOpts = { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) };
    window.Weline.Api.request(execUrl, execOpts)
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        if (data.success) {
            // 成功才关闭加载弹窗
            hideLoadingModal();
            detectionData = data.data;
            displayDetectionResult(data.data);
            
        } else {
            // 不关闭弹窗，直接切换为错误内容，避免隐藏/显示竞态
            const isAIError = data.message && data.message.includes('AI');
            showErrorInModal(data.message, isAIError);
            
            // 同时在页面上显示错误信息
            detectionContent.innerHTML = `<div class="alert alert-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                <strong>检测失败</strong><br>
                ${data.message}
            </div>`;
            
            // 如果是AI相关错误，显示提示和回退选项
            if (isAIError) {
                detectionContent.innerHTML += `
                    <div class="alert alert-warning mt-3">
                        <i class="mdi mdi-information me-2"></i>
                        <strong>提示</strong><br>
                        • 请检查AI模型配置是否正确<br>
                        • 确保供应商账户已配置并激活<br>
                        • 您也可以取消选择模型，使用正则检测
                    </div>
                    <div class="text-center mt-3">
                        <button type="button" class="btn btn-secondary" onclick="fallbackToRegexDetection()">
                            <i class="mdi mdi-regex me-1"></i>
                            使用正则检测
                        </button>
                    </div>
                `;
            }
        }
    })
    .catch(error => {
        // 在弹窗中显示错误
        showErrorInModal(error.message || '网络错误或服务器异常', false);
        
        // 同时在页面上显示错误信息
        detectionContent.innerHTML = `<div class="alert alert-danger">
            <i class="mdi mdi-alert-circle me-2"></i>
            <strong>检测失败</strong><br>
            ${error.message || '网络错误或服务器异常'}
        </div>`;
    });
}

// 处理弹窗点击事件，防止意外关闭
function handleModalClick(event) {
    // 阻止点击弹窗背景关闭弹窗
    if (event.target === event.currentTarget) {
        event.preventDefault();
        event.stopPropagation();
        return false;
    }
}

// 显示检测结果
function displayDetectionResult(result) {
    const detectionContent = document.getElementById('detectionContent');
    
    let html = `
        <div class="alert alert-info">
            <strong>检测完成</strong> - 执行时间: ${result.execution_time}
        </div>
    `;
    
    if (result.detection.has_sensitive) {
        html += `
            <div class="alert alert-warning">
                <h5><i class="mdi mdi-alert me-2"></i>发现敏感内容</h5>
                <strong>敏感类型：</strong> ${result.detection.sensitive_types.join(', ')}<br>
                <strong>发现 ${result.detection.positions.length} 处敏感信息</strong>
            </div>
        `;
        
        // 在原文拷贝上进行高亮标记
        const originalCopy = result.original;
        const terms = (result.detection && Array.isArray(result.detection.terms)) ? result.detection.terms : [];
        const markedContent = markSensitiveContent(originalCopy, result.detection.positions, terms);
        html += `
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">检测结果（原文标记）</h5>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap; word-wrap: break-word;" id="markedContentDisplay">${markedContent}</div>
                </div>
            </div>
        `;
        
        if (result.detection.positions && result.detection.positions.length > 0) {
            html += '<div class="table-responsive"><table class="table table-sm table-bordered"><thead><tr><th>类型</th><th>内容</th><th>位置</th></tr></thead><tbody>';
            result.detection.positions.forEach(pos => {
                html += `<tr><td><span class="badge bg-danger">${pos.type}</span></td><td><code>${pos.match}</code></td><td>${pos.start}-${pos.end}</td></tr>`;
            });
            html += '</tbody></table></div>';
        }
    } else {
        html += '<div class="alert alert-success"><i class="mdi mdi-check me-2"></i>未发现敏感内容</div>';
    }
    
    detectionContent.innerHTML = html;
    
    // 自动展开检测结果手风琴
    const detectionCollapseEl = document.getElementById('collapseDetection');
    const detectionCollapse = new bootstrap.Collapse(detectionCollapseEl, {
        toggle: true
    });
    // 确保展开
    setTimeout(() => {
        if (!detectionCollapseEl.classList.contains('show')) {
            detectionCollapse.show();
        }
    }, 100);
    
    // 如果有敏感内容，显示开始润色按钮
    if (result.detection.has_sensitive) {
        const startRewriteBtn = document.getElementById('startRewriteBtn');
        if (startRewriteBtn) {
            startRewriteBtn.style.display = 'inline-block';
        }
    }
}

// 标记敏感内容
function markSensitiveContent(content, positions, terms = []) {
    if (!positions || positions.length === 0) return content;

    // —————————— 通用偏移标注方案 ——————————
    // 1) Grapheme/码点到 UTF-16 码元索引映射
    const useGrapheme = (typeof Intl !== 'undefined' && Intl.Segmenter);
    let units = [];
    if (useGrapheme) {
        const seg = new Intl.Segmenter('zh-CN', { granularity: 'grapheme' });
        for (const s of seg.segment(content)) units.push(s.segment);
    } else {
        units = Array.from(content); // 按码点
    }
    const uToCu = [0];
    for (let i = 0, cu = 0; i < units.length; i++) {
        uToCu[i] = cu;
        const code = units[i].codePointAt(0);
        cu += (code > 0xFFFF) ? 2 : 1;
    }
    const totalCu = [...content].length === units.length ? content.length : content.length; // 安全使用原 length
    uToCu[units.length] = totalCu;
    const toCu = (uIdx) => {
        if (uIdx <= 0) return 0;
        if (uIdx >= uToCu.length) return totalCu;
        return uToCu[uIdx];
    };

    // 2) 区间标准化与就近纠偏（利用 match 文本）
    const norm = positions
        .map(p => ({
            start: Math.max(0, Number(p.start ?? 0)),
            end: Math.max(0, Number(p.end ?? 0)),
            type: p.type || '',
            match: p.match || ''
        }))
        .filter(p => p.end > p.start);

    const adjustByMatch = (p) => {
        if (!p.match) return p;
        // 在 ±128 个“单位”(码点/字素)窗口内就近搜寻 match
        const win = 128;
        const startU = Math.max(0, p.start - win);
        const endU = Math.min(units.length, p.end + win);
        const windowText = content.substring(toCu(startU), toCu(endU));
        let idxCu = windowText.indexOf(p.match);
        if (idxCu >= 0) {
            // 将窗口内的 CU 位置映射回全局 CU，再反推 U 索引
            const baseCu = toCu(startU);
            const absStartCu = baseCu + idxCu;
            const absEndCu = absStartCu + p.match.length;
            // 通过二分查找找到最接近的 U 边界
            const toU = (cu) => {
                let lo = 0, hi = uToCu.length - 1;
                while (lo < hi) {
                    const mid = (lo + hi) >> 1;
                    if (uToCu[mid] <= cu) lo = mid + 1; else hi = mid;
                }
                return Math.max(0, lo - 1);
            };
            const newStartU = toU(absStartCu);
            const newEndU = toU(absEndCu);
            return { ...p, start: newStartU, end: Math.max(newStartU + 1, newEndU) };
        }
        // 不再进行空白忽略纠偏：要求AI返回的片段必须与原文逐字符一致
        return p;
    };

    let adjusted = norm.map(adjustByMatch);

    // 3) 位置校验与“片段优先”的回退：
    // 若给定 pos 与原文不一致，则用片段在原文中搜索定位；
    // 多次出现时，优先选择距离原 pos.start 最近且不与已选区间重叠的那个。
    const taken = [];
    const occIndexOfAll = (text, needle) => {
        const out = [];
        if (!needle) return out;
        let from = 0;
        while (from <= text.length) {
            const idx = text.indexOf(needle, from);
            if (idx === -1) break;
            out.push({ start: idx, end: idx + needle.length });
            from = idx + Math.max(1, needle.length);
        }
        return out;
    };
    const overlap = (a, b) => !(a.end <= b.start || b.end <= a.start);
    const pickNearestFree = (candidates, hintStart) => {
        // 先过滤与已占用区间重叠的
        const free = candidates.filter(c => !taken.some(t => overlap(t, c)));
        if (free.length === 0) return null;
        // 选距离 hintStart 最近者
        free.sort((x, y) => Math.abs(x.start - hintStart) - Math.abs(y.start - hintStart));
        return free[0];
    };

    const resolved = [];
    adjusted.forEach(seg => {
        const expected = content.substring(toCu(seg.start), toCu(seg.end));
        if (expected && seg.match && expected === seg.match) {
            const startCu = toCu(seg.start);
            const endCu = toCu(seg.end);
            resolved.push({ startCu, endCu, type: seg.type, match: seg.match });
            taken.push({ start: startCu, end: endCu });
            return;
        }
        // 片段优先搜索
        const all = occIndexOfAll(content, seg.match);
        if (all.length) {
            const hintCu = toCu(seg.start);
            const pick = pickNearestFree(all, hintCu) || all[0];
            if (pick) {
                resolved.push({ startCu: pick.start, endCu: pick.end, type: seg.type, match: seg.match });
                taken.push({ start: pick.start, end: pick.end });
                return;
            }
        }
        // 最后兜底：放弃该标记（保证不错误着色）
    });

    // 额外路径：若提供了 terms，则基于原文中“逐字匹配”的全部命中构造高亮区间
    if (terms && terms.length > 0) {
        const ranges = [];
        const uniq = new Set();
        terms.forEach(t => {
            const term = String(t || '').trim();
            if (!term) return;
            let from = 0;
            while (from <= content.length) {
                const idx = content.indexOf(term, from);
                if (idx === -1) break;
                const key = idx + ':' + (idx + term.length);
                if (!uniq.has(key)) {
                    uniq.add(key);
                    ranges.push({ startCu: idx, endCu: idx + term.length, type: 'term', match: term });
                }
                from = idx + Math.max(1, term.length);
            }
        });
        if (ranges.length > 0) {
            // 用 terms 的结果替换之前的 resolved
            resolved = ranges;
        }
    }

    // 4) 用文本节点分割+包裹，避免偏移
    const container = document.createElement('div');
    const textNode = document.createTextNode(content);
    container.appendChild(textNode);

    // 从后往前，依据已解析的 CU 区间切分
    resolved.sort((a, b) => b.startCu - a.startCu);
    for (let i = 0; i < resolved.length; i++) {
        const seg = resolved[i];
        const startCu = seg.startCu;
        const endCu = seg.endCu;
        if (startCu >= endCu || startCu < 0 || endCu > textNode.length) continue;
        const tail = textNode.splitText(endCu);
        const middle = textNode.splitText(startCu);
        const span = document.createElement('span');
        span.className = 'highlight-marked';
        if (seg.type) span.setAttribute('data-type', String(seg.type));
        span.title = String(seg.type || '敏感内容');
        span.appendChild(middle);
        textNode.parentNode.insertBefore(span, tail);
    }

    return container.innerHTML;
}

// 开始润色
function startRewrite() {
    if (!detectionData || !detectionData.detection.has_sensitive) {
        alert('没有需要润色的内容');
        return;
    }

    // 隐藏等待区域，显示结果区域
    document.getElementById('rewriteWaiting').style.display = 'none';
    document.getElementById('rewriteResult').style.display = 'block';
    
    const rewriteTextArea = document.getElementById('rewriteTextArea');
    const startRewriteBtn = document.getElementById('startRewriteBtn');
    
    const originalHtml = startRewriteBtn.innerHTML;
    startRewriteBtn.disabled = true;
    startRewriteBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>正在润色...';
    
    rewriteTextArea.value = '正在润色，请稍候...';
    rewriteTextArea.disabled = true;
    
    // 展开并保持润色手风琴不被收起
    const rewriteCollapseEl = document.getElementById('collapseRewrite');
    let isRewriting = true;
    // 防止重入绑定多次
    rewriteCollapseEl.removeEventListener('hide.bs.collapse', window.__preventRewriteHide);
    window.__preventRewriteHide = function (e) {
        if (isRewriting) {
            e.preventDefault();
        }
    };
    rewriteCollapseEl.addEventListener('hide.bs.collapse', window.__preventRewriteHide);
    const rewriteCollapse = new bootstrap.Collapse(rewriteCollapseEl, { toggle: true });
    // 确保显示
    setTimeout(() => {
        if (!rewriteCollapseEl.classList.contains('show')) {
            rewriteCollapse.show();
        }
    }, 50);
    
    const formData = new FormData(document.getElementById('detectForm'));
    let modelCode = formData.get('model_code') || '';
    
    // 如果没有选择模型，使用默认模型
    if (!modelCode && defaultModelCode) {
        modelCode = defaultModelCode;
    }
    
    // 主语言探测（英文/中文占比）
    const detectDominantLang = (text) => {
        let en = 0, zh = 0;
        for (const ch of text) {
            const code = ch.codePointAt(0);
            if ((code >= 0x0041 && code <= 0x007A) || (code >= 0x0030 && code <= 0x0039)) en++;
            else if (code >= 0x4E00 && code <= 0x9FFF) zh++;
        }
        return zh > en ? 'zh-CN' : 'en';
    };
    const dominantLang = detectDominantLang(detectionData.original || '');

    const data = {
        content: detectionData.original,
        positions: detectionData.detection.positions,
        model_code: modelCode,
        lang: dominantLang
    };

    var rewriteUrl = '<?= $this->getBackendUrl('*/backend/detect/rewrite') ?>';
    var rewriteOpts = { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) };
    window.Weline.Api.request(rewriteUrl, rewriteOpts)
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        startRewriteBtn.disabled = false;
        startRewriteBtn.innerHTML = originalHtml;
        
        if (data.success) {
            rewriteData = data.data;
            // 将润色后的内容放入文本域
            rewriteTextArea.value = rewriteData.content || '';
            rewriteTextArea.disabled = false;
            startRewriteBtn.style.display = 'none';

            // 新旧对比功能已移除
        } else {
            rewriteTextArea.value = '润色失败: ' + data.message;
            rewriteTextArea.disabled = false;
            // 复用全局弹窗并显示错误
            initDetectModal();
            showErrorInModal('润色失败: ' + data.message, data.message && data.message.includes('AI'));
            if (detectLoadingModalInstance) detectLoadingModalInstance.show();
        }
        // 结束阶段允许手风琴关闭
        isRewriting = false;
    })
    .catch(error => {
        startRewriteBtn.disabled = false;
        startRewriteBtn.innerHTML = originalHtml;
        rewriteTextArea.value = '润色失败: ' + (error.message || '网络错误或服务器异常');
        rewriteTextArea.disabled = false;
        // 复用全局弹窗并显示错误
        initDetectModal();
        showErrorInModal('润色失败: ' + (error.message || '网络错误或服务器异常'), false);
        if (detectLoadingModalInstance) detectLoadingModalInstance.show();
        isRewriting = false;
    });
}

// 兼容旧函数名（保留）
function rewriteContent() {
    startRewrite();
}

// 显示润色结果（已废弃，现在直接在startRewrite中处理）
function displayRewriteResult() {
    // 这个函数保留以兼容旧代码，但实际上不再使用
    // 现在润色结果直接在startRewrite中显示到文本域
}

// 生成对比内容
// 新旧对比功能已移除

// 历史记录数组
let historyList = [];

// 再次检测润色后的内容
function reDetectPolishedContent() {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可检测的润色内容');
        return;
    }
    
    // 保存当前内容到历史记录
    const timestamp = new Date().toLocaleString('zh-CN');
    historyList.unshift({
        content: detectionData ? detectionData.original : '',
        timestamp: timestamp,
        type: 'original',
        detection: detectionData ? detectionData.detection : null
    });
    
    // 显示历史版本区域
    document.getElementById('historyAccordionItem').style.display = 'block';
    updateHistoryDisplay();
    
    // 将润色后的内容填入检测输入框
    document.getElementById('content').value = rewriteData.content;
    
    // 自动执行检测
    executeDetect();
}

// 更新历史版本显示
function updateHistoryDisplay() {
    const historyContent = document.getElementById('historyContent');
    
    if (historyList.length === 0) {
        historyContent.innerHTML = '<div class="text-muted text-center py-4">暂无历史记录...</div>';
        return;
    }
    
    let html = '<div class="history-list">';
    historyList.forEach((item, index) => {
        html += `
            <div class="card mb-3">
                <div class="card-header py-2">
                    <small class="text-muted">
                        <i class="mdi mdi-clock-outline me-1"></i>${item.timestamp}
                        ${item.type === 'original' ? '<span class="badge bg-secondary ms-2">原始内容</span>' : '<span class="badge bg-info ms-2">润色内容</span>'}
                    </small>
                </div>
                <div class="card-body">
                    <div style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">${item.content}</div>
                    ${item.detection && item.detection.has_sensitive ? 
                        `<div class="mt-2 text-danger"><small>包含敏感内容: ${item.detection.sensitive_types.join(', ')}</small></div>` : 
                        ''}
                </div>
            </div>
        `;
    });
    html += '</div>';
    
    historyContent.innerHTML = html;
}

// 复制润色后的内容
function copyPolishedContent() {
    const rewriteTextArea = document.getElementById('rewriteTextArea');
    const polishedText = rewriteTextArea ? rewriteTextArea.value : '';
    
    if (!polishedText) {
        alert('没有可复制的内容');
        return;
    }
    
    // 创建临时文本框
    const tempInput = document.createElement('textarea');
    tempInput.value = polishedText;
    document.body.appendChild(tempInput);
    tempInput.select();
    
    try {
        document.execCommand('copy');
        
        // 显示成功提示
        const btn = event.target.closest('button');
        const originalHtml = btn.innerHTML;
        const originalClasses = btn.className;
        btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已复制';
        btn.className = 'btn btn-primary btn-sm ms-2';
        
        setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.className = originalClasses;
        }, 2000);
    } catch (err) {
        alert('复制失败，请手动选择文本复制');
    }
    
    document.body.removeChild(tempInput);
}

// 导出润色后的内容
function exportPolishedContent(format) {
    if (!rewriteData || !rewriteData.content) {
        alert('没有可导出的内容');
        return;
    }
    
    const polishedText = rewriteData.content;
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
    let filename, content, mimeType;
    
    if (format === 'html') {
        filename = `polished_content_${timestamp}.html`;
        content = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>润色后的内容 - ${timestamp}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.6;
        }
        .content {
            white-space: pre-wrap;
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }
        .header {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #dee2e6;
        }
        .timestamp {
            color: #6c757d;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>润色后的内容</h1>
        <p class="timestamp">导出时间: ${new Date().toLocaleString('zh-CN')}</p>
    </div>
    <div class="content">${polishedText}</div>
</body>
</html>`;
        mimeType = 'text/html';
    } else if (format === 'txt') {
        filename = `polished_content_${timestamp}.txt`;
        content = polishedText;
        mimeType = 'text/plain';
    } else {
        alert('不支持的导出格式');
        return;
    }
    
    // 创建下载链接
    const blob = new Blob([content], { type: mimeType + ';charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    // 显示成功提示
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-check me-1"></i>已导出';
    
    setTimeout(() => {
        btn.innerHTML = originalHtml;
    }, 2000);
}

// 回退到正则检测
function fallbackToRegexDetection() {
    // 清除模型选择
    document.getElementById('model_code').value = '';
    document.getElementById('model_display').textContent = '使用默认模型';
    
    // 关闭弹窗
    hideLoadingModal();
    
    // 重新执行检测
    executeDetect();
}

// 在弹窗中显示错误
function showErrorInModal(errorMessage, showFallbackOption = false) {
    // 隐藏加载内容，显示错误内容（容错：元素可能不存在）
    var _lc = document.getElementById('detectLoadingContent');
    if (_lc) _lc.style.display = 'none';
    var _ec = document.getElementById('detectErrorContent');
    if (_ec) _ec.style.display = 'block';
    var _lh = document.getElementById('detectLoadingHeader');
    if (_lh) _lh.style.display = 'block';
    
    // 构建错误内容
    let errorHtml = `
        <div class="text-center">
            <div class="mb-3">
                <i class="mdi mdi-alert-circle text-danger" style="font-size: 48px;"></i>
            </div>
            <h5 class="text-danger">检测失败</h5>
            <p class="text-muted">${errorMessage}</p>
    `;
    
    if (showFallbackOption) {
        errorHtml += `
            <div class="mt-3">
                <button type="button" class="btn btn-secondary btn-sm" onclick="fallbackToRegexDetection()">
                    <i class="mdi mdi-regex me-1"></i>
                    使用正则检测
                </button>
            </div>
        `;
    }
    
    errorHtml += `</div>`;
    
    // 设置错误内容
    if (_ec) _ec.innerHTML = errorHtml;
    
    // 允许通过ESC键或点击背景关闭弹窗
    try {
        if (detectLoadingModalInstance && detectLoadingModalInstance._config) {
            detectLoadingModalInstance._config.keyboard = true;
            detectLoadingModalInstance._config.backdrop = true;
        }
    } catch(e) {}
}

})();
