<!-- 测试结果 -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card" id="desens-test-result-card" style="display: none;">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="mdi mdi-check-circle me-2"></i>
                    <lang>测试结果</lang>
                </h3>
            </div>
            <div class="card-body" id="desens-test-result-content">
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var methodSelect = document.getElementById('desens-test-method');
    var modelOptions = document.getElementById('desens-test-model-options');
    
    function toggleAIOptions() {
        if (methodSelect.value === 'ai') {
            modelOptions.style.display = 'block';
        } else {
            modelOptions.style.display = 'none';
        }
    }
    
    methodSelect.addEventListener('change', toggleAIOptions);
    
    document.getElementById('desens-test-execute-btn').addEventListener('click', function() {
        var content = document.getElementById('desens-test-content').value;
        if (!content) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.warning('<?= __('请输入测试内容') ?>');
            }
            return;
        }

        var form = document.getElementById('desensTestForm');
        var formData = new FormData(form);
        var method = formData.get('method');
        
        var data = {
            content: content,
            method: method
        };

        var ruleTypes = [];
        formData.getAll('rule_types[]').forEach(function(type) {
            ruleTypes.push(type);
        });
        if (ruleTypes.length > 0) {
            data.options = {rule_types: ruleTypes};
        }

        if (method === 'ai') {
            data.model_code = formData.get('model_code');
        }

        var resultCard = document.getElementById('desens-test-result-card');
        var resultContent = document.getElementById('desens-test-result-content');
        
        resultContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i><?= __('正在测试...') ?></div>';
        resultCard.style.display = 'block';

        window.Weline.Api.request('<?= $this->getBackendUrl('*/backend/test/execute') ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(data)
        })
        .then(function(response) {
            var data = response.data;
            if (response.ok && data && data.success) {
                var result = data.data;
                resultContent.innerHTML = 
                    '<div class="alert alert-success">' +
                        '<strong><?= __('测试完成') ?></strong> - <?= __('执行时间') ?>: ' + result.execution_time +
                    '</div>' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<h5><i class="mdi mdi-file-document me-2"></i><?= __('原内容') ?></h5>' +
                            '<div class="p-3 bg-light rounded">' +
                                '<pre style="white-space: pre-wrap; word-wrap: break-word;">' + result.original + '</pre>' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<h5><i class="mdi mdi-shield-lock me-2"></i><?= __('脱敏后') ?></h5>' +
                            '<div class="p-3 bg-success bg-opacity-10 rounded">' +
                                '<pre style="white-space: pre-wrap; word-wrap: break-word;">' + result.desensitized + '</pre>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            } else {
                resultContent.innerHTML = '<div class="alert alert-danger"><?= __('测试失败') ?>: ' + (data && (data.message || data.msg)) + '</div>';
            }
        })
        .catch(function(error) {
            resultContent.innerHTML = '<div class="alert alert-danger"><?= __('测试失败') ?>: ' + (error && error.message ? error.message : '') + '</div>';
        });
    });
})();
</script>
