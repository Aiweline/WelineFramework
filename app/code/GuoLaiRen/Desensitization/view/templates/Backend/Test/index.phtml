<script>
function toggleAIOptions() {
    const method = document.getElementById('method').value;
    const modelOptions = document.getElementById('modelOptions');
    if (method === 'ai') {
        modelOptions.style.display = 'block';
    } else {
        modelOptions.style.display = 'none';
    }
}

function executeTest() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入测试内容');
        return;
    }

    const form = document.getElementById('testForm');
    const formData = new FormData(form);
    const method = formData.get('method');
    
    const data = {
        content: content,
        method: method
    };

    // 添加选中的规则类型
    const ruleTypes = [];
    formData.getAll('rule_types[]').forEach(type => ruleTypes.push(type));
    if (ruleTypes.length > 0) {
        data.options = {rule_types: ruleTypes};
    }

    // 如果是AI方法，添加model_code
    if (method === 'ai') {
        data.model_code = formData.get('model_code');
    }

    const resultCard = document.getElementById('resultCard');
    const resultContent = document.getElementById('resultContent');
    
    resultContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>正在测试...</div>';
    resultCard.style.display = 'block';

    fetch('<?= $this->getBackendUrl('*/backend/test/execute') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const result = data.data;
            const html = `
                <div class="alert alert-success">
                    <strong>测试完成</strong> - 执行时间: ${result.execution_time}
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <h5><i class="mdi mdi-file-document me-2"></i>原内容</h5>
                        <div class="p-3 bg-light rounded">
                            <pre style="white-space: pre-wrap; word-wrap: break-word;">${result.original}</pre>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h5><i class="mdi mdi-shield-lock me-2"></i>脱敏后</h5>
                        <div class="p-3 bg-success bg-opacity-10 rounded">
                            <pre style="white-space: pre-wrap; word-wrap: break-word;">${result.desensitized}</pre>
                        </div>
                    </div>
                </div>
            `;
            resultContent.innerHTML = html;
        } else {
            resultContent.innerHTML = `<div class="alert alert-danger">测试失败: ${data.message}</div>`;
        }
    })
    .catch(error => {
        resultContent.innerHTML = `<div class="alert alert-danger">测试失败: ${error.message}</div>`;
    });
}
</script>

