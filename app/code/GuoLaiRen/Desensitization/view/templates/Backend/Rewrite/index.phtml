<script>
function executeRewrite() {
    const content = document.getElementById('content').value;
    if (!content) {
        alert('请输入内容');
        return;
    }

    const form = document.getElementById('rewriteForm');
    const formData = new FormData(form);
    const data = {
        content: formData.get('content'),
        model_code: formData.get('model_code'),
        rewrite_style: formData.get('rewrite_style'),
        preserve_format: document.getElementById('preserve_format').checked ? 1 : 0
    };

    const resultCard = document.getElementById('resultCard');
    const resultContent = document.getElementById('resultContent');
    
    resultContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i>AI正在润色中，请稍候...</div>';
    resultCard.style.display = 'block';

    fetch('<?= $this->getBackendUrl('*/backend/rewrite/execute') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const result = data.data;
            const html = `
                <div class="alert alert-success">
                    <strong>润色完成</strong> - 执行时间: ${result.execution_time}
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <h5><i class="mdi mdi-file-document me-2"></i>原内容</h5>
                        <div class="p-3 bg-light rounded">
                            <pre style="white-space: pre-wrap; word-wrap: break-word;">${result.original}</pre>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h5><i class="mdi mdi-auto-fix me-2"></i>润色后</h5>
                        <div class="p-3 bg-success bg-opacity-10 rounded">
                            <pre style="white-space: pre-wrap; word-wrap: break-word;">${result.rewritten}</pre>
                        </div>
                    </div>
                </div>
            `;
            resultContent.innerHTML = html;
        } else {
            resultContent.innerHTML = `<div class="alert alert-danger">润色失败: ${data.message}</div>`;
        }
    })
    .catch(error => {
        resultContent.innerHTML = `<div class="alert alert-danger">润色失败: ${error.message}</div>`;
    });
}
</script>

