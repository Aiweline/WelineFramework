<!-- 润色结果 -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card" id="desens-rewrite-result-card" style="display: none;">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="mdi mdi-check-circle me-2"></i>
                    <lang>润色结果</lang>
                </h3>
            </div>
            <div class="card-body" id="desens-rewrite-result-content">
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    document.getElementById('desens-rewrite-execute-btn').addEventListener('click', function() {
        var content = document.getElementById('desens-rewrite-content').value;
        if (!content) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.warning('<?= __('请输入内容') ?>');
            }
            return;
        }

        var form = document.getElementById('desensRewriteForm');
        var formData = new FormData(form);
        var data = {
            content: formData.get('content'),
            model_code: formData.get('model_code'),
            rewrite_style: formData.get('rewrite_style'),
            preserve_format: document.getElementById('desens-rewrite-preserve-format').checked ? 1 : 0
        };

        var resultCard = document.getElementById('desens-rewrite-result-card');
        var resultContent = document.getElementById('desens-rewrite-result-content');
        
        resultContent.innerHTML = '<div class="text-center py-4"><i class="mdi mdi-loading mdi-spin me-2"></i><?= __('AI正在润色中，请稍候...') ?></div>';
        resultCard.style.display = 'block';

        fetch('<?= $this->getBackendUrl('*/backend/rewrite/execute') ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(data)
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                var result = data.data;
                resultContent.innerHTML = 
                    '<div class="alert alert-success">' +
                        '<strong><?= __('润色完成') ?></strong> - <?= __('执行时间') ?>: ' + result.execution_time +
                    '</div>' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<h5><i class="mdi mdi-file-document me-2"></i><?= __('原内容') ?></h5>' +
                            '<div class="p-3 bg-light rounded">' +
                                '<pre style="white-space: pre-wrap; word-wrap: break-word;">' + result.original + '</pre>' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<h5><i class="mdi mdi-auto-fix me-2"></i><?= __('润色后') ?></h5>' +
                            '<div class="p-3 bg-success bg-opacity-10 rounded">' +
                                '<pre style="white-space: pre-wrap; word-wrap: break-word;">' + result.rewritten + '</pre>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            } else {
                resultContent.innerHTML = '<div class="alert alert-danger"><?= __('润色失败') ?>: ' + data.message + '</div>';
            }
        })
        .catch(function(error) {
            resultContent.innerHTML = '<div class="alert alert-danger"><?= __('润色失败') ?>: ' + error.message + '</div>';
        });
    });
})();
</script>
