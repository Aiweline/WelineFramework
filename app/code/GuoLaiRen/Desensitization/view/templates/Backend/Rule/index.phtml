<!-- 测试规则模态框 -->
<div class="modal fade" id="desensTestModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><lang>测试规则</lang></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="desens-test-content" class="form-label"><lang>测试内容</lang> <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="desens-test-content" rows="3" placeholder="<?= __('请输入要测试的内容') ?>"></textarea>
                </div>
                <div id="desensTestResult" class="mt-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><lang>关闭</lang></button>
                <button type="button" class="btn btn-primary" id="desens-execute-test-btn"><lang>执行测试</lang></button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var currentPattern = '';
    var currentReplacement = '';
    var ruleModal = null;
    var testModal = null;
    
    function initModals() {
        var ruleModalEl = document.getElementById('desensRuleModal');
        var testModalEl = document.getElementById('desensTestModal');
        if (ruleModalEl) {
            ruleModal = new bootstrap.Modal(ruleModalEl);
        }
        if (testModalEl) {
            testModal = new bootstrap.Modal(testModalEl);
        }
    }
    
    function showAddModal() {
        document.getElementById('desensRuleForm').reset();
        document.getElementById('desens-rule-id').value = '';
        document.getElementById('desensRuleModalLabel').textContent = '<?= __('添加脱敏规则') ?>';
        ruleModal.show();
    }
    
    function editRule(ruleId) {
        var url = '<?= $this->getBackendUrl('*/backend/rule/edit') ?>?rule_id=' + ruleId;
        window.Weline.Api.get(url, { silent: true })
            .then(function(response) {
                var data = (response && response.data) || response;
                if (data.success) {
                    var rule = data.data;
                    document.getElementById('desens-rule-id').value = rule.rule_id;
                    document.getElementById('desens-rule-name').value = rule.name;
                    document.getElementById('desens-rule-type').value = rule.type;
                    document.getElementById('desens-rule-pattern').value = rule.pattern;
                    document.getElementById('desens-rule-replacement').value = rule.replacement;
                    document.getElementById('desens-rule-description').value = rule.description || '';
                    document.getElementById('desens-rule-priority').value = rule.priority || 0;
                    document.getElementById('desens-rule-is-active').checked = rule.is_active == 1;
                    document.getElementById('desensRuleModalLabel').textContent = '<?= __('编辑脱敏规则') ?>';
                    ruleModal.show();
                } else {
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.error(data.message || '<?= __('加载规则失败') ?>');
                    }
                }
            });
    }
    
    function saveRule() {
        var form = document.getElementById('desensRuleForm');
        var formData = new FormData(form);
        var ruleId = formData.get('rule_id');
        var url = ruleId ? 
            '<?= $this->getBackendUrl('*/backend/rule/edit') ?>' : 
            '<?= $this->getBackendUrl('*/backend/rule/add') ?>';
        
        window.Weline.Api.request(url, { method: 'POST', body: formData })
        .then(function(response) {
            var data = (response && response.data) || response;
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __('保存成功') ?>');
                }
                location.reload();
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('保存失败') ?>');
                }
            }
        });
    }
    
    function deleteRule(ruleId) {
        if (typeof AdminConfirm !== 'undefined') {
            AdminConfirm.show('<?= __('确定要删除这条规则吗？') ?>', function() {
                doDeleteRule(ruleId);
            });
        } else if (confirm('<?= __('确定要删除这条规则吗？') ?>')) {
            doDeleteRule(ruleId);
        }
    }
    
    function doDeleteRule(ruleId) {
        var url = '<?= $this->getBackendUrl('*/backend/rule/delete') ?>';
        var body = { rule_id: ruleId };
        window.Weline.Api.post(url, body)
        .then(function(response) {
            var data = (response && response.data) || response;
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __('删除成功') ?>');
                }
                location.reload();
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('删除失败') ?>');
                }
            }
        });
    }
    
    function toggleRule(ruleId) {
        var url = '<?= $this->getBackendUrl('*/backend/rule/toggle') ?>?rule_id=' + ruleId;
        window.Weline.Api.get(url)
            .then(function(response) {
                var data = (response && response.data) || response;
                if (data.success) {
                    location.reload();
                } else {
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.error(data.message || '<?= __('操作失败') ?>');
                    }
                }
            });
    }
    
    function showTestModal(pattern, replacement) {
        currentPattern = pattern;
        currentReplacement = replacement;
        document.getElementById('desens-test-content').value = '';
        document.getElementById('desensTestResult').innerHTML = '';
        testModal.show();
    }
    
    function executeTest() {
        var testContent = document.getElementById('desens-test-content').value;
        if (!testContent) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.warning('<?= __('请输入测试内容') ?>');
            }
            return;
        }
        
        var url = '<?= $this->getBackendUrl('*/backend/rule/test') ?>';
        var body = { pattern: currentPattern, replacement: currentReplacement, test_content: testContent };
        window.Weline.Api.post(url, body)
        .then(function(response) {
            var data = (response && response.data) || response;
            var resultDiv = document.getElementById('desensTestResult');
            if (data.success) {
                resultDiv.innerHTML = 
                    '<div class="alert alert-success">' +
                        '<strong><?= __('测试成功') ?></strong>' +
                        '<div class="mt-2">' +
                            '<strong><?= __('结果') ?>：</strong><br>' +
                            '<code class="d-block bg-light p-2 mt-1">' + data.data.result + '</code>' +
                        '</div>' +
                    '</div>';
            } else {
                resultDiv.innerHTML = 
                    '<div class="alert alert-danger">' +
                        '<strong><?= __('测试失败') ?></strong><br>' +
                        (data.message || '<?= __('未知错误') ?>') +
                    '</div>';
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        initModals();
        
        document.getElementById('desens-rule-add-btn').addEventListener('click', showAddModal);
        document.getElementById('desens-rule-save-btn').addEventListener('click', saveRule);
        document.getElementById('desens-execute-test-btn').addEventListener('click', executeTest);
        
        document.querySelectorAll('.desens-rule-edit-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                editRule(this.getAttribute('data-id'));
            });
        });
        
        document.querySelectorAll('.desens-rule-delete-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                deleteRule(this.getAttribute('data-id'));
            });
        });
        
        document.querySelectorAll('.desens-rule-toggle-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                toggleRule(this.getAttribute('data-id'));
            });
        });
        
        document.querySelectorAll('.desens-rule-test-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                showTestModal(this.getAttribute('data-pattern'), this.getAttribute('data-replacement'));
            });
        });
    });
})();
</script>
