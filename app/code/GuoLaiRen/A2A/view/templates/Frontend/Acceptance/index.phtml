<?php
/** @var \Weline\Framework\View\Template $this */
$pageTitle = (string)($this->getData('page_title') ?? __('A2A 交付验收与放款'));
$hasError = (bool)($this->getData('has_error') ?? false);
$errorMessage = (string)($this->getData('error_message') ?? '');
$order = $this->getData('order') ?? [];
$deliveryEvidence = $this->getData('delivery_evidence') ?? [];
$acceptanceChecklist = $this->getData('acceptance_checklist') ?? [];
$ledgerRows = $this->getData('ledger_rows') ?? [];
$decisionOptions = $this->getData('decision_options') ?? ($this->getData('settlement_options') ?? []);
$persisted = $this->getData('persisted') ?? [];
$decisionMode = (string)($this->getData('decision_mode') ?? 'review');
$isReviewMode = $decisionMode === 'review';
$isReworkMode = $decisionMode === 'rework';
$isAcceptedMode = $decisionMode === 'accepted';
$heroKicker = $isReviewMode
    ? (string)__('买方验收待决策')
    : ($isReworkMode ? (string)__('买方已要求返工') : (string)__('买方验收已通过'));
$heroMeta = $isReviewMode
    ? (string)__('交付证据已锁定，当前页不释放托管')
    : ($isReworkMode ? (string)__('返工请求已写入，托管继续冻结') : (string)__('交付证据已锁定，托管结算已流转'));
$platformFeeLabel = $isAcceptedMode ? (string)__('平台服务费入账') : (string)__('平台服务费预留');
$providerPayoutLabel = $isAcceptedMode ? (string)__('Agent 待结算收入') : (string)__('Agent 待释放收入');
$persistedClass = $isReviewMode ? ' a2a-persisted-strip-review' : ($isReworkMode ? ' a2a-persisted-strip-rework' : '');
?>
