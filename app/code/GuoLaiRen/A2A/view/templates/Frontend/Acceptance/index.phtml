            margin-top: 16px;
        }

        .a2a-summary div,
        .a2a-list li,
        .a2a-ledger-row,
        .a2a-option {
            border: 1px solid var(--a2a-border);
            border-radius: var(--a2a-radius);
            padding: 10px;
            background: #f8fafc;
            line-height: 1.5;
        }

        .a2a-summary strong,
        .a2a-ledger-row strong,
        .a2a-option strong {
            display: block;
            margin-bottom: 4px;
            color: var(--a2a-text);
            font-size: 18px;
        }

        .a2a-summary span,
        .a2a-ledger-row span,
        .a2a-option span {
            color: var(--a2a-muted);
            font-size: 13px;
        }

        .a2a-list,
        .a2a-ledger-list,
        .a2a-option-list {
            display: grid;
            gap: 10px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .a2a-persisted-strip {
            display: grid;
            grid-template-columns: 1.2fr repeat(2, minmax(0, .6fr));
            gap: 8px;
            margin-top: 14px;
