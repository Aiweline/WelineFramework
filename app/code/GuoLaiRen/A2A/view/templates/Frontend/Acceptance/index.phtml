            border: 1px solid #bbf7d0;
            border-radius: var(--a2a-radius);
            background: #f0fdf4;
        }

        .a2a-persisted-strip strong {
            display: block;
            margin-bottom: 2px;
            color: var(--a2a-success);
            font-size: 14px;
        }

        .a2a-persisted-strip span {
            color: var(--a2a-muted);
            font-size: 12px;
        }

        .a2a-persisted-strip-review {
            border-color: #bae6fd;
            background: #f0f9ff;
        }

        .a2a-persisted-strip-rework {
            border-color: #fde68a;
            background: #fffbeb;
        }

        .a2a-decision-note {
            margin-top: 14px;
            border: 1px solid #bae6fd;
            border-radius: var(--a2a-radius);
            padding: 10px 12px;
            background: #f0f9ff;
            color: #0f172a;
            line-height: 1.55;
        }

        .a2a-decision-note strong {
            color: var(--a2a-primary-strong);
        }

        .a2a-option {
            display: grid;
            gap: 8px;
        }

        .a2a-option[data-decision-type="accept"] {
            border-color: #bbf7d0;
            background: #f0fdf4;
        }

        .a2a-option[data-decision-type="rework"] {
            border-color: #fde68a;
            background: #fffbeb;
        }

        .a2a-option[data-decision-type="refund"],
        .a2a-option[data-decision-type="dispute"] {
            border-color: #cbd5e1;
            background: #f8fafc;
        }

        .a2a-option-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }

        .a2a-option-locked {
            color: var(--a2a-muted);
            font-size: 13px;
            font-weight: 700;
        }

        .a2a-error {
            border-color: #fecaca;
            background: #fff1f2;
            color: var(--a2a-danger);
        }

        @media (max-width: 860px) {
            .a2a-accept-grid,
            .a2a-summary,
            .a2a-persisted-strip {
                grid-template-columns: 1fr;
            }

            .a2a-accept-nav {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <main class="a2a-accept-shell">
        <nav class="a2a-accept-nav" aria-label="<?= __('A2A 验收导航') ?>">
            <a href="/a2a/frontend#orders"><?= __('返回订单工作台') ?></a>
            <?php if (!$hasError): ?>
                <a class="a2a-button a2a-button-primary" href="/a2a/frontend/confirm?draft=<?= urlencode((string)str_replace('A2A-ORDER-', 'A2A-DRAFT-', (string)$this->getData('order_id'))) ?>"><?= __('查看正式订单状态') ?></a>
            <?php endif; ?>
        </nav>

        <?php if ($hasError): ?>
            <section class="a2a-panel a2a-error">
                <span class="a2a-kicker"><?= __('无法进入验收放款') ?></span>
                <h1><?= __('交付验收不可执行') ?></h1>
                <p><?= htmlspecialchars($errorMessage) ?></p>
                <a class="a2a-button" href="/a2a/frontend#orders"><?= __('返回订单工作台') ?></a>
            </section>
        <?php else: ?>
            <section class="a2a-panel">
                <span class="a2a-kicker"><?= htmlspecialchars($heroKicker) ?></span>
                <h1><?= htmlspecialchars((string)$order['sku_title']) ?></h1>
                <p class="a2a-muted">
                    <?= htmlspecialchars((string)$order['provider']) ?> · <?= htmlspecialchars($heroMeta) ?>
                </p>
                <div class="a2a-id-stack">
                    <span class="a2a-public-id"><?= htmlspecialchars((string)$this->getData('order_id')) ?></span>
                    <span class="a2a-public-id"><?= htmlspecialchars((string)$this->getData('scope_id')) ?></span>
                    <span class="a2a-public-id"><?= htmlspecialchars((string)$this->getData('acceptance_id')) ?></span>
                    <span class="a2a-state-pill"><?= htmlspecialchars((string)$this->getData('status')) ?></span>
                </div>
                <div class="a2a-summary">
                    <div><strong><?= htmlspecialchars((string)$order['amount']) ?></strong><span><?= __('托管金额') ?></span></div>
                    <div><strong><?= htmlspecialchars((string)$order['platform_fee']) ?></strong><span><?= htmlspecialchars($platformFeeLabel) ?></span></div>
                    <div><strong><?= htmlspecialchars((string)$order['provider_payout']) ?></strong><span><?= htmlspecialchars($providerPayoutLabel) ?></span></div>
                </div>
                <?php if ($isReviewMode): ?>
                    <div class="a2a-decision-note">
                        <strong><?= __('验收门禁') ?></strong>
                        <?= __('打开本页只审阅交付证据，不会释放托管；只有点击“确认验收并放款”才会写入放款账本。') ?>
                    </div>
                <?php endif; ?>
                <?php if (is_array($persisted) && $persisted): ?>
                    <div class="a2a-persisted-strip<?= $persistedClass ?>" aria-label="<?= __('持久化状态') ?>">
                        <div><strong><?= htmlspecialchars((string)$persisted['status']) ?></strong><span><?= __('持久化状态') ?></span></div>
                        <div><strong><?= htmlspecialchars((string)$persisted['delivery_acceptance_id']) ?></strong><span><?= __('验收主键') ?></span></div>
                        <div><strong><?= htmlspecialchars((string)$persisted['ledger_rows']) ?></strong><span><?= __('账本行') ?></span></div>
                    </div>
                <?php endif; ?>
            </section>

            <div class="a2a-accept-grid">
                <section class="a2a-panel">
                    <h2><?= __('交付证据包') ?></h2>
                    <p class="a2a-muted"><?= __('验收依据必须来自范围、日志、哈希、质量摘要和审核标签，不接受纯口头完成声明。') ?></p>
                    <ul class="a2a-list">
                        <?php foreach ($deliveryEvidence as $item): ?>
                            <li><?= htmlspecialchars((string)$item) ?></li>
                        <?php endforeach; ?>
                    </ul>
                </section>
                <aside>
                    <section class="a2a-panel">
                        <h2><?= __('买方验收清单') ?></h2>
                        <ul class="a2a-list">
                            <?php foreach ($acceptanceChecklist as $item): ?>
                                <li><?= htmlspecialchars((string)$item) ?></li>
                            <?php endforeach; ?>
                        </ul>
                    </section>
                    <section class="a2a-panel">
                        <h2><?= __('结算账本') ?></h2>
                        <div class="a2a-ledger-list">
                            <?php foreach ($ledgerRows as $row): ?>
                                <div class="a2a-ledger-row">
                                    <strong><?= htmlspecialchars((string)$row['amount']) ?></strong>
                                    <span><?= htmlspecialchars((string)$row['label']) ?> · <?= htmlspecialchars((string)$row['status_label']) ?></span>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    </section>
                    <section class="a2a-panel">
                        <h2><?= __('验收决策') ?></h2>
                        <p class="a2a-muted"><?= __('买方必须基于证据选择下一步：通过验收、要求返工，或在形成快照后进入退款/争议分支。') ?></p>
                        <div class="a2a-option-list">
                            <?php foreach ($decisionOptions as $option): ?>
                                <?php
                                $decisionType = (string)($option['decision_type'] ?? '');
                                $buttonClass = 'a2a-button';
                                if ($decisionType === 'accept' && $isReviewMode) {
                                    $buttonClass .= ' a2a-button-primary';
                                } elseif ($decisionType === 'rework' && $isReviewMode) {
                                    $buttonClass .= ' a2a-button-warning';
                                } elseif ($decisionType === 'dispute') {
                                    $buttonClass .= ' a2a-button-danger';
                                }
                                ?>
                                <div class="a2a-option" data-decision-type="<?= htmlspecialchars($decisionType) ?>">
                                    <strong><?= htmlspecialchars((string)$option['label']) ?></strong>
                                    <span><?= htmlspecialchars((string)$option['status']) ?> · <?= htmlspecialchars((string)$option['description']) ?></span>
                                    <div class="a2a-option-actions">
                                        <?php if (!empty($option['url'])): ?>
                                            <a class="<?= htmlspecialchars($buttonClass) ?>" href="<?= htmlspecialchars((string)$option['url']) ?>">
                                                <?= $decisionType === 'accept' ? __('执行验收') : ($decisionType === 'rework' ? __('要求返工') : __('进入分支')) ?>
                                            </a>
                                        <?php else: ?>
                                            <span class="a2a-option-locked"><?= __('当前不可直接执行') ?></span>
                                        <?php endif; ?>
                                    </div>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    </section>
                </aside>
            </div>
        <?php endif; ?>
    </main>
</body>
</html>
