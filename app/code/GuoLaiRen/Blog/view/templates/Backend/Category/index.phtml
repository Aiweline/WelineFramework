<!-- 删除确认弹窗（替代原生 confirm，符合友好通知规范；使用主题变量以适配暗色/亮色；role/aria 便于无障碍） -->
<div id="blogDeleteConfirmModal" role="dialog" aria-modal="true" aria-labelledby="blogDeleteConfirmMsg" style="display:none; position:fixed; inset:0; z-index:9999; background:var(--backend-color-bg-overlay, rgba(0,0,0,0.5)); align-items:center; justify-content:center;">
    <div style="background:var(--backend-color-bg-surface, #fff); padding:var(--backend-padding-modal, 1.5rem); border-radius:8px; max-width:400px; box-shadow:var(--backend-modal-shadow, 0 4px 12px rgba(0,0,0,0.15)); color:var(--backend-color-text-primary, #212529);">
        <p id="blogDeleteConfirmMsg" style="margin-bottom:1rem;"></p>
        <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
            <button type="button" class="btn btn-secondary" id="blogDeleteCancelBtn"><lang>取消</lang></button>
            <button type="button" class="btn btn-danger" id="blogDeleteConfirmBtn"><lang>确定</lang></button>
        </div>
    </div>
</div>
<script>
(function(){
    var modal = document.getElementById('blogDeleteConfirmModal');
    var msgEl = document.getElementById('blogDeleteConfirmMsg');
    var confirmBtn = document.getElementById('blogDeleteConfirmBtn');
    var cancelBtn = document.getElementById('blogDeleteCancelBtn');
    var deleteHref = '';
    if (!modal || !msgEl) return;
    modal.style.display = 'flex';
    modal.style.display = 'none';
    document.querySelectorAll('.blog-delete-confirm').forEach(function(a){
        a.addEventListener('click', function(e){ e.preventDefault(); deleteHref = this.getAttribute('href'); msgEl.textContent = this.getAttribute('data-msg') || ''; modal.style.display = 'flex'; });
    });
    confirmBtn.addEventListener('click', function(){ if(deleteHref) window.location = deleteHref; });
    cancelBtn.addEventListener('click', function(){ modal.style.display = 'none'; deleteHref = ''; });
})();
</script>
<script>
/* Offcanvas 关闭后自动刷新主页面列表 */
(function(){
    document.querySelectorAll('.offcanvas').forEach(function(el){
        el.addEventListener('hidden.bs.offcanvas', function(){ window.location.reload(); });
    });
})();
</script>

