<!-- start page message -->
<div class='row'>
    <template>Weline_Component::message.phtml</template>
</div>
<!-- end message -->

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">
                    <lang>分类列表</lang>
                </h4>
                <div class="d-flex gap-2">
                    <form class="d-flex" method="get">
                        <input type="text" name="search" class="form-control form-control-sm me-2"
                               placeholder="<?= __('搜索分类...') ?>"
                               value="<?= htmlspecialchars($this->request->getGet('search', '')) ?>">
                        <button type="submit" class="btn btn-sm btn-outline-primary">
                            <i class="mdi mdi-magnify"></i>
                        </button>
                    </form>
                    <a href="<?= $this->getUrl('blog/backend/category/create') ?>" class="btn btn-sm btn-primary">
                        <i class="mdi mdi-plus"></i> <lang>新建分类</lang>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <?php if (empty($categories)): ?>
                    <div class="alert alert-info mb-0">
                        <i class="mdi mdi-information-outline"></i>
                        <?= __('暂无分类，请点击右上角按钮创建') ?>
                    </div>
                <?php else: ?>
                    <div class="table-responsive">
                        <table class="table table-hover table-centered mb-0">
                            <thead>
                                <tr>
                                    <th width="60">ID</th>
                                    <th><?= __('分类名称') ?></th>
                                    <th><?= __('URL别名') ?></th>
                                    <th width="80"><?= __('文章数') ?></th>
                                    <th width="80"><?= __('排序') ?></th>
                                    <th width="80"><?= __('状态') ?></th>
                                    <th width="150"><?= __('操作') ?></th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($categories as $category): ?>
                                    <?php
                                    $parentName = '';
                                    if ($category->getData(Category::fields_PARENT_ID) > 0) {
                                        $parent = $category->getParentCategory();
                                        $parentName = $parent ? $parent->getData(Category::fields_NAME) : '';
                                    }
                                    ?>
                                    <tr>
                                        <td><?= (int)$category->getId() ?></td>
                                        <td>
                                            <?php if ($parentName): ?>
                                                <small class="text-muted"><?= htmlspecialchars($parentName) ?> / </small>
                                            <?php endif; ?>
                                            <strong><?= htmlspecialchars($category->getData(Category::fields_NAME)) ?></strong>
                                        </td>
                                        <td>
                                            <code><?= htmlspecialchars($category->getData(Category::fields_SLUG)) ?></code>
                                        </td>
                                        <td>
                                            <span class="badge bg-info"><?= $category->getPostCount() ?></span>
                                        </td>
                                        <td><?= (int)$category->getData(Category::fields_SORT_ORDER) ?></td>
                                        <td>
                                            <?php if ($category->getData(Category::fields_STATUS) == Category::STATUS_ENABLED): ?>
                                                <span class="badge bg-success"><?= __('启用') ?></span>
                                            <?php else: ?>
                                                <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                            <?php endif; ?>
                                        </td>
                                        <td>
                                            <a href="<?= $this->getUrl('blog/backend/category/edit', ['id' => $category->getId()]) ?>"
                                               class="btn btn-sm btn-outline-primary" title="<?= __('编辑') ?>">
                                                <i class="mdi mdi-pencil"></i>
                                            </a>
                                            <a href="<?= $this->getUrl('blog/backend/category/delete', ['id' => $category->getId()]) ?>"
                                               class="btn btn-sm btn-outline-danger"
                                               title="<?= __('删除') ?>"
                                               onclick="return confirm('<?= __('确定要删除这个分类吗？') ?>')">
                                                <i class="mdi mdi-delete"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <?php endforeach; ?>
                            </tbody>
                        </table>
                    </div>

                    <?php if ($pagination): ?>
                        <div class="mt-3">
                            <?= $pagination ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<w:template>Weline_Admin::Backend/page-layout/main-content-after.phtml</w:template>
