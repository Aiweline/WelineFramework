?>
<w:template>Weline_Admin::Backend/page-layout/main-content-before.phtml</w:template>

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= __('博客分类管理') ?></h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<?= $this->getBackendUrl('') ?>"><?= __('首页') ?></a></li>
                    <li class="breadcrumb-item active"><?= __('博客分类') ?></li>
                </ol>
            </div>
        </div>
