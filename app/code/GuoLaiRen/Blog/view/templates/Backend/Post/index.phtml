<!-- 手动触发 AI 生成 SEO 文章（使用 SSE 终端组件） -->
<script>
(function(){
    'use strict';
    
    var btn = document.getElementById('btnTriggerAi');
    var modal = document.getElementById('blogSseTerminalModal');
    var closeBtn = document.getElementById('blogSseTerminalClose');
    var closeBtnFooter = document.getElementById('blogSseTerminalCloseBtn');
    var hintEl = document.getElementById('blogSseTerminalHint');
    var backdrop = modal ? modal.querySelector('.blog-sse-modal-backdrop') : null;
    
    if (!btn || !modal) return;
    
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['blog-ai-terminal'] : null;
    var isRunning = false;
    
    function showModal() {
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    
    function hideModal() {
        if (isRunning) {
            if (!confirm('<?= __('任务正在执行中，确定要关闭吗？') ?>')) {
                return;
            }
            if (terminal) terminal.stop();
        }
        modal.style.display = 'none';
        document.body.style.overflow = '';
    }
    
    function updateHint(text, type) {
        if (hintEl) {
            hintEl.textContent = text;
            hintEl.className = 'blog-sse-modal-hint' + (type ? ' ' + type : '');
        }
    }
    
    btn.addEventListener('click', function() {
        if (!terminal) {
            console.error('SSE Terminal not initialized');
            return;
        }
        
        terminal.clear();
        updateHint('');
        showModal();
        
        var origText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('生成中...') ?>';
        isRunning = true;
        
        terminal.on('done', function(e) {
            isRunning = false;
            btn.disabled = false;
            btn.innerHTML = origText;
            
            try {
                var d = JSON.parse(e.data || '{}');
                var published = parseInt(d.published, 10) || 0;
                if (d.result && terminal.log) {
                    var lines = String(d.result).split('\n').filter(Boolean);
                    terminal.log(lines[0], published > 0 ? 'success' : 'info');
                    var skipAlreadyLogged = published === 0 && d.skip_reasons && d.skip_reasons.length > 0;
                    if (lines.length > 1 && !skipAlreadyLogged) {
                        for (var li = 1; li < lines.length; li++) {
                            terminal.log(lines[li], 'warning');
                        }
                    }
                }
                if (published > 0) {
                    updateHint('<?= __('成功生成') ?> ' + published + ' <?= __('篇文章，即将刷新页面...') ?>', 'success');
                    setTimeout(function() { window.location.reload(); }, 2000);
                } else {
                    var foot = (d.hint || '').trim() || (d.skip_reasons && d.skip_reasons.join('；')) || '';
                    updateHint(foot || '<?= __('未生成文章，请查看终端内具体原因。') ?>', 'error');
                }
            } catch (err) {
                updateHint('<?= __('执行完成') ?>', 'success');
            }
        });
        
        terminal.on('error', function(e) {
            isRunning = false;
            btn.disabled = false;
            btn.innerHTML = origText;
            var hintMsg = '<?= addslashes(__('连接失败或执行出错，请查看下方终端输出。')) ?>';
            try {
                if (e && e.data) {
                    var d = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
                    if (d) {
                        if (d.detail) hintMsg = d.detail;
                        else if (d.message) hintMsg = d.message;
                        if (d.file && d.line) hintMsg += ' (' + String(d.file).split('/').pop() + ':' + d.line + ')';
                    }
                }
            } catch (err) {}
            updateHint(hintMsg, 'error');
        });
        
        terminal.on('stop', function() {
            isRunning = false;
            btn.disabled = false;
            btn.innerHTML = origText;
        });
        
        terminal.on('article_start', function(e) {
            try {
                var d = JSON.parse(e.data || '{}');
                var msg = (d.index || 0) + '/' + (d.total || 0) + ': ' + (d.keyword || '');
                if (terminal.log) terminal.log(msg, 'progress');
            } catch (err) {}
        });
        terminal.on('article_done', function(e) {
            try {
                var d = JSON.parse(e.data || '{}');
                var msg = (d.keyword || '') + ' ✓';
                if (terminal.log) terminal.log(msg, 'success');
            } catch (err) {}
        });
        terminal.on('article_error', function(e) {
            try {
                var d = JSON.parse(e.data || '{}');
                var msg = (d.keyword || '') + ': ' + (d.error || '');
                if (terminal.log) terminal.log(msg, 'error');
            } catch (err) {}
        });
        terminal.start();
    });
    
    closeBtn.addEventListener('click', hideModal);
    closeBtnFooter.addEventListener('click', hideModal);
    backdrop.addEventListener('click', hideModal);
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.style.display === 'flex') {
            hideModal();
        }
    });
})();
</script>
