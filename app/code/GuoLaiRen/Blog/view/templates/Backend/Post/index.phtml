                            <ul class="pagination justify-content-center mb-0">
                                <?php 
                                $currentPage = (int)($pagination['currentPage'] ?? $pagination['page'] ?? 1);
                                $totalPages = (int)($pagination['totalPages'] ?? $pagination['lastPage'] ?? 1);
                                $baseUrl = $this->getBackendUrl('blog/backend/post/index');
                                $search = $this->request->getGet('search', '');
                                
                                // 构建URL参数
                                $buildUrl = function($page) use ($baseUrl, $search) {
                                    $params = ['page' => $page];
                                    if ($search) $params['search'] = $search;
                                    return $baseUrl . '?' . http_build_query($params);
                                };
                                ?>
                                
                                <!-- 上一页 -->
                                <li class="page-item <?= $currentPage <= 1 ? 'disabled' : '' ?>">
                                    <a class="page-link" href="<?= $currentPage > 1 ? $buildUrl($currentPage - 1) : '#' ?>">
                                        <i class="mdi mdi-chevron-left"></i>
                                    </a>
                                </li>
                                
                                <?php
                                // 计算显示的页码范围
                                $startPage = max(1, $currentPage - 2);
                                $endPage = min($totalPages, $currentPage + 2);
                                
                                // 确保显示至少5个页码
                                if ($endPage - $startPage < 4) {
                                    if ($startPage == 1) {
                                        $endPage = min($totalPages, 5);
                                    } else {
                                        $startPage = max(1, $totalPages - 4);
                                    }
                                }
                                
                                // 显示第一页
                                if ($startPage > 1): ?>
                                    <li class="page-item">
                                        <a class="page-link" href="<?= $buildUrl(1) ?>">1</a>
                                    </li>
                                    <?php if ($startPage > 2): ?>
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    <?php endif; ?>
                                <?php endif; ?>
                                
                                <?php for ($i = $startPage; $i <= $endPage; $i++): ?>
                                    <li class="page-item <?= $i == $currentPage ? 'active' : '' ?>">
                                        <a class="page-link" href="<?= $buildUrl($i) ?>"><?= $i ?></a>
                                    </li>
                                <?php endfor; ?>
                                
                                <?php // 显示最后一页
                                if ($endPage < $totalPages): ?>
                                    <?php if ($endPage < $totalPages - 1): ?>
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    <?php endif; ?>
                                    <li class="page-item">
                                        <a class="page-link" href="<?= $buildUrl($totalPages) ?>"><?= $totalPages ?></a>
                                    </li>
                                <?php endif; ?>
                                
                                <!-- 下一页 -->
                                <li class="page-item <?= $currentPage >= $totalPages ? 'disabled' : '' ?>">
                                    <a class="page-link" href="<?= $currentPage < $totalPages ? $buildUrl($currentPage + 1) : '#' ?>">
                                        <i class="mdi mdi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                            <div class="text-center mt-2 text-muted small">
                                <?= __('共 %{total} 条记录，第 %{page}/%{pages} 页', [
                                    'total' => $pagination['totalRecords'] ?? $pagination['total'] ?? 0,
                                    'page'  => $currentPage,
                                    'pages' => $totalPages,
                                ]) ?>
                            </div>
                        </nav>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<!-- 删除确认弹窗（替代原生 confirm，符合友好通知规范；使用主题变量以适配暗色/亮色；role/aria 便于无障碍） -->
<div id="blogDeleteConfirmModal" role="dialog" aria-modal="true" aria-labelledby="blogDeleteConfirmMsg" style="display:none; position:fixed; inset:0; z-index:9999; background:var(--backend-color-bg-overlay, rgba(0,0,0,0.5)); align-items:center; justify-content:center;">
    <div style="background:var(--backend-color-bg-surface, #fff); padding:var(--backend-padding-modal, 1.5rem); border-radius:8px; max-width:400px; box-shadow:var(--backend-modal-shadow, 0 4px 12px rgba(0,0,0,0.15)); color:var(--backend-color-text-primary, #212529);">
        <p id="blogDeleteConfirmMsg" style="margin-bottom:1rem;"></p>
        <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
            <button type="button" class="btn btn-secondary" id="blogDeleteCancelBtn"><lang>取消</lang></button>
            <button type="button" class="btn btn-danger" id="blogDeleteConfirmBtn"><lang>确定</lang></button>
        </div>
    </div>
</div>
<script>
(function(){
    'use strict';
    var modal = document.getElementById('blogDeleteConfirmModal');
    var msgEl = document.getElementById('blogDeleteConfirmMsg');
    var confirmBtn = document.getElementById('blogDeleteConfirmBtn');
    var cancelBtn = document.getElementById('blogDeleteCancelBtn');
    var deleteHref = '';
    var pendingBatchSubmit = null;
    var TEXT_CONFIRM = '<?= addslashes(__('确定')) ?>';
    var TEXT_CONFIRM_PUBLISH = '<?= addslashes(__('确定发布')) ?>';
    var batchPublishUrl = <?= json_encode($batchPublishUrl) ?>;
    var batchRemoveUrl = <?= json_encode($batchRemoveUrl) ?>;
    var returnSearch = <?= json_encode($returnSearch) ?>;
    var returnPage = <?= json_encode($returnPage) ?>;

    function resetConfirmButtonForDelete() {
        confirmBtn.className = 'btn btn-danger';
        confirmBtn.textContent = TEXT_CONFIRM;
    }
    function setConfirmButtonForPublish() {
        confirmBtn.className = 'btn btn-success';
        confirmBtn.textContent = TEXT_CONFIRM_PUBLISH;
    }
    function closeModal() {
        modal.style.display = 'none';
        deleteHref = '';
        pendingBatchSubmit = null;
        resetConfirmButtonForDelete();
    }

    if (!modal || !msgEl) return;
    modal.style.display = 'none';

    document.querySelectorAll('.blog-delete-confirm').forEach(function(a){
        a.addEventListener('click', function(e){
            e.preventDefault();
            pendingBatchSubmit = null;
            deleteHref = this.getAttribute('href');
            msgEl.textContent = this.getAttribute('data-msg') || '';
            resetConfirmButtonForDelete();
            modal.style.display = 'flex';
        });
    });

    confirmBtn.addEventListener('click', function(){
        if (typeof pendingBatchSubmit === 'function') {
            pendingBatchSubmit();
            closeModal();
            return;
        }
        if (deleteHref) window.location = deleteHref;
    });
    cancelBtn.addEventListener('click', closeModal);

    document.querySelectorAll('.blog-publish-confirm').forEach(function(a){
        a.addEventListener('click', function(e){
            e.preventDefault();
            pendingBatchSubmit = null;
            deleteHref = this.getAttribute('href');
            msgEl.textContent = this.getAttribute('data-msg') || '';
            setConfirmButtonForPublish();
            modal.style.display = 'flex';
        });
    });

    function getSelectedIds() {
        var ids = [];
        document.querySelectorAll('.blog-row-check:checked').forEach(function(cb){
            var v = parseInt(cb.value, 10);
            if (v > 0) ids.push(v);
        });
        return ids;
    }
    function appendRedirectFields(form) {
        var rs = document.createElement('input');
        rs.type = 'hidden';
        rs.name = 'redirect_search';
        rs.value = returnSearch || '';
        form.appendChild(rs);
        var rp = document.createElement('input');
        rp.type = 'hidden';
        rp.name = 'redirect_page';
        rp.value = returnPage || '';
        form.appendChild(rp);
    }
    function submitBatchPost(url, ids) {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        ids.forEach(function(id){
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'ids[]';
            input.value = String(id);
            form.appendChild(input);
        });
        appendRedirectFields(form);
        document.body.appendChild(form);
        form.submit();
    }

    var batchBar = document.getElementById('blogBatchBar');
    var batchCountEl = document.getElementById('blogBatchCount');
    var checkAll = document.getElementById('blogCheckAll');
    var batchPublishBtn = document.getElementById('blogBatchPublishBtn');
    var batchRemoveBtn = document.getElementById('blogBatchRemoveBtn');
    var batchClearBtn = document.getElementById('blogBatchClearBtn');

    function updateBatchUi() {
        var ids = getSelectedIds();
        var n = ids.length;
        if (!batchBar || !batchCountEl) return;
        if (n > 0) {
            batchBar.style.display = 'flex';
            batchCountEl.textContent = '<?= addslashes(__('已选')) ?> ' + n + ' <?= addslashes(__('篇')) ?>';
        } else {
            batchBar.style.display = 'none';
        }
        if (checkAll) {
            var rowChecks = document.querySelectorAll('.blog-row-check');
            checkAll.indeterminate = n > 0 && n < rowChecks.length;
            checkAll.checked = rowChecks.length > 0 && n === rowChecks.length;
        }
    }

    if (checkAll) {
        checkAll.addEventListener('change', function(){
            document.querySelectorAll('.blog-row-check').forEach(function(cb){
                cb.checked = checkAll.checked;
            });
            updateBatchUi();
        });
    }
    document.querySelectorAll('.blog-row-check').forEach(function(cb){
        cb.addEventListener('change', updateBatchUi);
    });

    if (batchClearBtn) {
        batchClearBtn.addEventListener('click', function(){
            document.querySelectorAll('.blog-row-check').forEach(function(cb){ cb.checked = false; });
            if (checkAll) checkAll.checked = false;
            updateBatchUi();
        });
    }

    var MSG_BATCH_PUBLISH = '<?= addslashes(__('确定将选中的 %{n} 篇草稿审批发布吗？', ['n' => '{n}'])) ?>';
    var MSG_BATCH_REMOVE = '<?= addslashes(__('确定删除选中的 %{n} 篇文章？此操作不可恢复。', ['n' => '{n}'])) ?>';

    if (batchPublishBtn) {
        batchPublishBtn.addEventListener('click', function(){
            var ids = getSelectedIds();
            if (!ids.length) return;
            pendingBatchSubmit = null;
            deleteHref = '';
            msgEl.textContent = MSG_BATCH_PUBLISH.replace('{n}', String(ids.length));
            setConfirmButtonForPublish();
            pendingBatchSubmit = function(){ submitBatchPost(batchPublishUrl, ids); };
            modal.style.display = 'flex';
        });
    }
    if (batchRemoveBtn) {
        batchRemoveBtn.addEventListener('click', function(){
            var ids = getSelectedIds();
            if (!ids.length) return;
            pendingBatchSubmit = null;
            deleteHref = '';
            msgEl.textContent = '<?= addslashes(__('确定删除选中的')) ?> ' + ids.length + ' <?= addslashes(__('篇文章？此操作不可恢复。')) ?>';
            resetConfirmButtonForDelete();
            pendingBatchSubmit = function(){ submitBatchPost(batchRemoveUrl, ids); };
            modal.style.display = 'flex';
        });
    }
    updateBatchUi();
})();
</script>

