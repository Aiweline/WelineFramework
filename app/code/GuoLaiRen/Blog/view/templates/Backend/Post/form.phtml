<script>
// 自动生成URL别名（基于标题）
document.getElementById('title')?.addEventListener('input', function() {
    const slugInput = document.getElementById('slug');
    if (slugInput && !slugInput.value) {
        const title = this.value;
        const slug = title.toLowerCase()
            .replace(/[^\w\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .trim();
        slugInput.value = slug;
    }
});

// 生成随机密钥
function generateSecretKey() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let key = '';
    for (let i = 0; i < 32; i++) {
        key += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById('new_secret_key').value = key;
}

// 页面加载时自动生成密钥
document.addEventListener('DOMContentLoaded', function() {
    generateSecretKey();
});

// 快速创建站点表单提交
document.getElementById('quickSiteForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    e.stopPropagation();
    
    const form = this;
    const alertDiv = document.getElementById('siteFormAlert');
    const submitBtn = document.getElementById('btnSaveSite');
    
    // 表单验证
    if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
    }
    
    // 禁用按钮，显示加载状态
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("保存中...") ?>';
    
    try {
        const formData = new FormData(form);
        
        // 发送AJAX请求
        const response = await fetch('<?= $this->getBackendUrl("multipass/backend/site/quickSave") ?>', {
            method: 'POST',
            body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
            // 显示成功提示
            alertDiv.innerHTML = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                '<i class="mdi mdi-check-circle me-1"></i>' + result.message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            alertDiv.style.display = 'block';
            
            // 将新站点添加到下拉列表并选中
            const siteSelect = document.getElementById('site_id');
            const option = new Option(result.site.site_name, result.site.site_id, true, true);
            siteSelect.add(option);
            
            // 重置表单并生成新密钥
            form.reset();
            form.classList.remove('was-validated');
            generateSecretKey();
            
            // 2秒后关闭offcanvas
            setTimeout(() => {
                const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('offcanvasNewSite'));
                offcanvas?.hide();
                alertDiv.style.display = 'none';
            }, 1500);
        } else {
            // 显示错误提示
            alertDiv.innerHTML = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="mdi mdi-alert-circle me-1"></i>' + (result.message || '<?= __("保存失败") ?>') +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            alertDiv.style.display = 'block';
        }
    } catch (error) {
        console.error('Error:', error);
        alertDiv.innerHTML = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
            '<i class="mdi mdi-alert-circle me-1"></i><?= __("网络错误，请重试") ?>' +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
        alertDiv.style.display = 'block';
    } finally {
        // 恢复按钮状态
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="mdi mdi-content-save"></i> <?= __("保存站点") ?>';
    }
});
</script>

