</style>

<script>
// 检测后端主题是否为暗色模式
function isDarkMode() {
    const body = document.body;
    const html = document.documentElement;
    
    // 检查多种可能的主题标识方式
    return (
        body.getAttribute('data-theme-mode') === 'dark' ||
        body.getAttribute('data-layout-mode') === 'dark' ||
        body.getAttribute('data-sidebar') === 'dark' ||
        body.getAttribute('data-topbar') === 'dark' ||
        body.classList.contains('dark-mode') ||
        body.classList.contains('theme-dark') ||
        html.getAttribute('data-theme') === 'dark' ||
        html.getAttribute('data-bs-theme') === 'dark'
    );
}

// CKEditor 初始化
document.addEventListener('DOMContentLoaded', function() {
    // 存储编辑器实例
    window.blogContentEditor = null;
    
    // 检测当前主题模式
    const darkMode = isDarkMode();
    
    // 初始化文章内容编辑器
    const contentTextarea = document.getElementById('content');
    if (contentTextarea && typeof ClassicEditor !== 'undefined') {
        ClassicEditor
            .create(contentTextarea, {
                language: 'zh-cn',
                // 根据主题模式设置 UI 主题
                ui: {
                    viewportOffset: {
                        top: 0
                    }
                },
                // 暗色模式配置
                ...(darkMode ? {
                    // CKEditor 5 暗色模式配置
                    // 注意：CKEditor 5 的暗色模式需要通过 CSS 变量或自定义样式实现
                    // 这里我们通过 CSS 变量和样式来实现
                } : {}),
                minHeight: '500px',
                toolbar: [
                    'heading', '|',
                    'bold', 'italic', 'underline', 'strikethrough', '|',
                    'link', 'blockQuote', 'code', 'codeBlock', '|',
                    'bulletedList', 'numberedList', 'todoList', '|',
                    'outdent', 'indent', '|',
                    'insertTable', 'mediaEmbed', '|',
                    'imageUpload', '|',
                    'horizontalLine', '|',
                    'undo', 'redo', '|',
                    'sourceEditing', '|',
                    'removeFormat'
                ],
                heading: {
                    options: [
                        { model: 'paragraph', title: '段落', class: 'ck-heading_paragraph' },
                        { model: 'heading1', view: 'h1', title: '标题 1', class: 'ck-heading_heading1' },
                        { model: 'heading2', view: 'h2', title: '标题 2', class: 'ck-heading_heading2' },
                        { model: 'heading3', view: 'h3', title: '标题 3', class: 'ck-heading_heading3' },
                        { model: 'heading4', view: 'h4', title: '标题 4', class: 'ck-heading_heading4' }
                    ]
                },
                image: {
                    toolbar: [
                        'imageTextAlternative', 'imageStyle:inline', 'imageStyle:block', 'imageStyle:side'
                    ]
                },
                table: {
                    contentToolbar: [
                        'tableColumn', 'tableRow', 'mergeTableCells'
                    ]
                },
                codeBlock: {
                    languages: [
                        { language: 'plaintext', label: '纯文本' },
                        { language: 'css', label: 'CSS' },
                        { language: 'html', label: 'HTML' },
                        { language: 'javascript', label: 'JavaScript' },
                        { language: 'php', label: 'PHP' },
                        { language: 'python', label: 'Python' },
                        { language: 'java', label: 'Java' },
                        { language: 'json', label: 'JSON' },
                        { language: 'markdown', label: 'Markdown' },
                        { language: 'sql', label: 'SQL' },
                        { language: 'xml', label: 'XML' }
                    ]
                },
                link: {
                    decorators: {
                        openInNewTab: {
                            mode: 'manual',
                            label: '在新标签页打开',
                            attributes: {
                                target: '_blank',
                                rel: 'noopener noreferrer'
                            }
                        }
                    }
                }
            })
            .then(editor => {
                // 保存编辑器实例
                window.blogContentEditor = editor;
                
                // 设置编辑器最小高度
                const editableElement = editor.ui.view.editable.element;
                if (editableElement) {
                    editableElement.style.minHeight = '500px';
                }
                
                // 应用暗色模式样式
                if (darkMode) {
                    applyDarkModeStyles(editor);
                }
                
                console.log('博客内容编辑器初始化成功', darkMode ? '(暗色模式)' : '(亮色模式)');
            })
            .catch(error => {
                console.error('博客内容编辑器初始化失败:', error);
            });
    } else if (contentTextarea) {
        console.warn('CKEditor 未加载，使用普通文本域');
    }
    
    // 监听主题切换（如果后端主题支持动态切换）
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && 
                (mutation.attributeName === 'data-theme-mode' || 
                 mutation.attributeName === 'data-layout-mode' ||
                 mutation.attributeName === 'data-theme' ||
                 mutation.attributeName === 'data-bs-theme' ||
                 mutation.attributeName === 'class')) {
                const newDarkMode = isDarkMode();
                if (window.blogContentEditor && newDarkMode !== darkMode) {
                    // 主题切换了，重新应用样式
                    if (newDarkMode) {
                        applyDarkModeStyles(window.blogContentEditor);
                    } else {
                        removeDarkModeStyles(window.blogContentEditor);
                    }
                }
            }
        });
    });
    
    // 监听 body 和 html 的属性变化
    observer.observe(document.body, {
        attributes: true,
        attributeFilter: ['data-theme-mode', 'data-layout-mode', 'data-sidebar', 'data-topbar', 'class']
    });
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme', 'data-bs-theme', 'class']
    });
    
    // 表单提交前，确保编辑器内容同步到 textarea
    const form = document.querySelector('form.needs-validation');
    if (form && window.blogContentEditor) {
        form.addEventListener('submit', function(e) {
            // CKEditor 会自动同步内容到 textarea，但为了确保，我们手动同步一次
            if (window.blogContentEditor) {
                window.blogContentEditor.updateSourceElement();
            }
        });
    }
});

// 应用暗色模式样式
function applyDarkModeStyles(editor) {
    const editorElement = editor.ui.getEditableElement().closest('.ck-editor');
    if (editorElement) {
        editorElement.classList.add('ck-editor-dark');
    }
}

// 移除暗色模式样式
function removeDarkModeStyles(editor) {
    const editorElement = editor.ui.getEditableElement().closest('.ck-editor');
    if (editorElement) {
        editorElement.classList.remove('ck-editor-dark');
    }
}
</script>
