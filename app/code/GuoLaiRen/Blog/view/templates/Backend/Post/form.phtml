<script>
// 自动生成URL别名（基于标题）
document.getElementById('title')?.addEventListener('input', function() {
    const slugInput = document.getElementById('slug');
    if (slugInput && !slugInput.value) {
        const title = this.value;
        const slug = title.toLowerCase()
            .replace(/[^\w\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .trim();
        slugInput.value = slug;
    }
});

// 快速创建站点表单提交（与 add 一致：address_lines + pool_ids）
document.getElementById('quickSiteForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    e.stopPropagation();
    
    const form = this;
    const alertDiv = document.getElementById('siteFormAlert');
    const submitBtn = document.getElementById('btnSaveSite');
    
    if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
    }
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("保存中...") ?>';
    
    try {
        const formData = new FormData(form);
        formData.append('default_timezone', 'Asia/Shanghai');
        
        // 发送到 Websites 的 quickSave 接口（与 PageBuilder 一键建站保持一致）
        var url = '<?= $this->getBackendUrl("websites/admin/website/quickSave") ?>';
        var opts = { method: 'POST', body: formData };
        var response = await window.Weline.Api.request(url, opts);
        var result = (response && response.data) !== undefined ? response.data : response;
        
        if (result.success && result.website) {
            var w = result.website;
            // 显示成功提示
            alertDiv.innerHTML = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                '<i class="mdi mdi-check-circle me-1"></i>' + (result.message || '<?= __("站点创建成功") ?>') +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            alertDiv.style.display = 'block';
            
            // 将新站点添加到下拉列表并选中（Blog 使用 website_id 作为 site_id）
            const siteSelect = document.getElementById('site_id');
            const option = new Option(w.name || w.site_name, w.website_id, true, true);
            siteSelect.add(option);
            
            // 重置表单
            form.reset();
            form.classList.remove('was-validated');
            
            // 2秒后关闭 offcanvas
            setTimeout(function() {
                var oc = document.getElementById('offcanvasNewSite');
                if (oc && bootstrap.Offcanvas.getInstance(oc)) {
                    bootstrap.Offcanvas.getInstance(oc).hide();
                }
                alertDiv.style.display = 'none';
            }, 1500);
        } else {
            // 显示错误提示
            alertDiv.innerHTML = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="mdi mdi-alert-circle me-1"></i>' + (result.message || '<?= __("保存失败") ?>') +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            alertDiv.style.display = 'block';
        }
    } catch (error) {
        console.error('Error:', error);
        alertDiv.innerHTML = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
            '<i class="mdi mdi-alert-circle me-1"></i><?= __("网络错误，请重试") ?>' +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
        alertDiv.style.display = 'block';
    } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="mdi mdi-content-save"></i> <?= __("保存站点") ?>';
    }
});
</script>

