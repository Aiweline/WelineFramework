<!-- 确认弹窗 -->
<div id="blogConfirmModal" role="dialog" aria-modal="true" aria-labelledby="blogConfirmMsg" style="display:none; position:fixed; inset:0; z-index:9999; background:var(--backend-color-bg-overlay, rgba(0,0,0,0.5)); align-items:center; justify-content:center;">
    <div style="background:var(--backend-color-bg-surface, #fff); padding:var(--backend-padding-modal, 1.5rem); border-radius:8px; max-width:400px; box-shadow:var(--backend-modal-shadow, 0 4px 12px rgba(0,0,0,0.15)); color:var(--backend-color-text-primary, #212529);">
        <p id="blogConfirmMsg" style="margin-bottom:1rem;"></p>
        <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
            <button type="button" class="btn btn-secondary" id="blogConfirmCancelBtn"><lang>取消</lang></button>
            <button type="button" class="btn btn-danger" id="blogConfirmOkBtn"><lang>确定</lang></button>
        </div>
    </div>
</div>
<script>
(function(){
    var modal = document.getElementById('blogConfirmModal');
    var msgEl = document.getElementById('blogConfirmMsg');
    var okBtn = document.getElementById('blogConfirmOkBtn');
    var cancelBtn = document.getElementById('blogConfirmCancelBtn');
    var actionHref = '';
    if (!modal || !msgEl) return;
    modal.style.display = 'flex';
    modal.style.display = 'none';
    document.querySelectorAll('.blog-confirm-action').forEach(function(a){
        a.addEventListener('click', function(e){ e.preventDefault(); actionHref = this.getAttribute('href'); msgEl.textContent = this.getAttribute('data-msg') || ''; modal.style.display = 'flex'; });
    });
    okBtn.addEventListener('click', function(){ if(actionHref) window.location = actionHref; });
    cancelBtn.addEventListener('click', function(){ modal.style.display = 'none'; actionHref = ''; });
})();
</script>

<w:template>Weline_Admin::Backend/page-layout/main-content-after.phtml</w:template>
