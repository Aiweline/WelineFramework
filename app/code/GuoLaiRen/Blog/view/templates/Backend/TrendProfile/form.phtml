<?php
/**
 * 关键词画像表单 - 内容模板
 * 由布局系统自动包裹
 *
 * @var \Weline\Framework\View\Template $this
 * @var \GuoLaiRen\Blog\Model\TrendProfile|null $profile
 */
$profile = $this->getData('profile');
$action = $this->getData('action');
$isEdit = $profile && $profile->getId();
$keywordsStr = $profile ? implode(', ', $profile->getKeywordsArray()) : '';
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= $this->getData('page_title') ?></h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<?= $this->getBackendUrl('blog/backend/trend-profile/index') ?>"><?= __('关键词画像') ?></a></li>
                    <li class="breadcrumb-item active"><?= $isEdit ? __('编辑') : __('新建') ?></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class='row'>
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form action="<?= htmlspecialchars($action) ?>" method="post">
                    <div class="mb-3">
                        <label for="name" class="form-label"><?= __('画像名称') ?> <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" required
                               value="<?= $profile ? htmlspecialchars($profile->getData('name')) : '' ?>"
                               placeholder="<?= __('例如：棋牌') ?>">
                    </div>
                    <div class="mb-3">
                        <label for="keywords" class="form-label"><?= __('关键词') ?></label>
                        <textarea class="form-control" id="keywords" name="keywords" rows="3"
                                  placeholder="<?= __('多个关键词用英文逗号分隔，如：棋牌, 赌博, 博彩') ?>"><?= htmlspecialchars($keywordsStr) ?></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="sort" class="form-label"><?= __('排序') ?></label>
                        <input type="number" class="form-control" id="sort" name="sort" value="<?= $profile ? (int)$profile->getData('sort') : 0 ?>">
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="is_active" id="is_active" value="1"
                                   <?= (!$profile || (int)$profile->getData('is_active') === 1) ? 'checked' : '' ?>>
                            <label class="form-check-label" for="is_active"><?= __('启用') ?></label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary"><?= $isEdit ? __('保存') : __('创建') ?></button>
                    <a href="<?= $this->getBackendUrl('blog/backend/trend-profile/index') ?>" class="btn btn-secondary"><?= __('返回列表') ?></a>
                </form>
            </div>
        </div>
    </div>
