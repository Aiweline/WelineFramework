<script>
(function() {
    var form = document.getElementById('trendsConfigForm');
    var apiTypeInput = document.getElementById('api_type');
    var growthComparisonInput = document.getElementById('growth_comparison');
    var serpapiBlock = document.getElementById('serpapi_block');
    var officialBlock = document.getElementById('official_block');
    var publishDraft = document.getElementById('publish_as_draft');
    var publishDraftValue = document.getElementById('publish_as_draft_value');

    document.querySelectorAll('input[name="api_type_radio"]').forEach(function(r) {
        r.addEventListener('change', function() {
            apiTypeInput.value = this.value;
            serpapiBlock.style.display = this.value === 'serpapi' ? '' : 'none';
            officialBlock.style.display = this.value === 'official' ? '' : 'none';
        });
    });
    document.querySelectorAll('input[name="growth_comparison_radio"]').forEach(function(r) {
        r.addEventListener('change', function() { growthComparisonInput.value = this.value; });
    });
    publishDraft.addEventListener('change', function() {
        publishDraftValue.value = this.checked ? '1' : '0';
    });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = document.getElementById('btnSave');
        btn.disabled = true;
        var fd = new FormData(form);
        var config = {};
        fd.forEach(function(v, k) {
            if (k.indexOf('config[') === 0) config[k] = v;
        });
        fetch('<?= $this->getUrl('blog/backend/trends-config/save') ?>', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(fd)
        }).then(function(r) { return r.json(); }).then(function(res) {
            var msg = res.success ? (res.message || '') : (res.message || 'Error');
            if (typeof AdminToast !== 'undefined') {
                if (res.success) AdminToast.success(msg); else AdminToast.error(msg);
            } else {
                var el = document.getElementById('trends-config-msg');
                if (el) { el.textContent = msg; el.className = 'alert alert-' + (res.success ? 'success' : 'danger'); el.style.display = 'block'; }
            }
        }).catch(function() {
            var errMsg = '<?= __('保存失败，请重试') ?>';
            if (typeof AdminToast !== 'undefined') AdminToast.error(errMsg);
            else {
                var el = document.getElementById('trends-config-msg');
                if (el) { el.textContent = errMsg; el.className = 'alert alert-danger'; el.style.display = 'block'; }
            }
        }).finally(function() { btn.disabled = false; });
    });
})();
</script>

