<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:weline:framework:etc/routes.xsd">
    
    <!-- DataTable 测试路由 -->
    <router id="datatable_test">
        <route id="datatable_test_index" path="/datatable/test" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::execute</controller>
        </route>
        
        <route id="datatable_test_basic" path="/datatable/test/basic" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::basic</controller>
        </route>
        
        <route id="datatable_test_join" path="/datatable/test/join" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::join</controller>
        </route>
        
        <route id="datatable_test_form" path="/datatable/test/form" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::form</controller>
        </route>
        
        <route id="datatable_test_upload" path="/datatable/test/upload" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::upload</controller>
        </route>
        
        <route id="datatable_test_transaction" path="/datatable/test/transaction" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::transaction</controller>
        </route>
        
        <route id="datatable_test_dependency" path="/datatable/test/dependency" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::dependency</controller>
        </route>
        
        <route id="datatable_test_cascade" path="/datatable/test/cascade" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::cascade</controller>
        </route>
        
        <route id="datatable_test_performance" path="/datatable/test/performance" method="GET">
            <controller>Weline\DataTable\Controller\Test\Index::performance</controller>
        </route>
        
        <!-- 数据管理路由 -->
        <route id="datatable_test_init_data" path="/datatable/test/initData" method="POST">
            <controller>Weline\DataTable\Controller\Test\Index::initData</controller>
        </route>
        
        <route id="datatable_test_clear_data" path="/datatable/test/clearData" method="POST">
            <controller>Weline\DataTable\Controller\Test\Index::clearData</controller>
        </route>
    </router>
</routes>
