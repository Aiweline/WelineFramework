    .dt-inheritance-note{padding:18px;border-radius:18px;background:#eef6ff;border:1px solid #d6e8fb}
    .dt-inheritance-output{white-space:pre-wrap;background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:18px}
</style>

<div class="dt-inheritance-page" data-testid="datatable-inheritance-page">
    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
        <div>
            <h1><?= __('Attribute Inheritance Verification') ?></h1>
            <p><?= __('This backend route focuses on the inherited table attributes and scope generation checks that were previously hidden inside the broken legacy template set.') ?></p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="<?= $comprehensiveUrl ?>"><?= __('Back') ?></a>
            <a class="btn btn-outline-secondary" href="<?= $tagTestUrl ?>?focus=attribute_inheritance"><?= __('Open Full Tag Report') ?></a>
        </div>
    </div>

    <?= $this->fetch('Weline_DataTable::backend/templates/test/layout-switcher.phtml') ?>

    <section class="dt-inheritance-note">
        <?= __('The verification endpoint exercises inherited model, sortable, and searchable attributes through TableContext::inheritTableAttributes(). This page isolates that result so we can keep the compatibility route working while avoiding the old broken page shell.') ?>
    </section>

    <section class="dt-inheritance-card">
        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
            <h2 class="mb-0"><?= __('Run Verification') ?></h2>
            <button type="button" class="btn btn-primary" data-testid="datatable-inheritance-run" data-datatable-test-action="load-inheritance-verification"><?= __('Run Now') ?></button>
        </div>
        <div id="datatable-inheritance-output" class="dt-inheritance-output" data-testid="datatable-inheritance-output"><?= __('No verification run yet.') ?></div>
    </section>
</div>

<script>
    function resolveInheritanceBackendRoute(route) {
        var normalizedRoute = String(route || '').replace(/^\/+/, '');
        var currentPath = String(window.location && window.location.pathname || '');
        var basePath = '<?= htmlspecialchars((string) ($backendBasePath ?? ''), ENT_QUOTES, 'UTF-8') ?>'.replace(/\/+$/, '');

        if (currentPath.indexOf('/@backend') === 0) {
            return '/@backend/' + normalizedRoute;
        }

        return basePath + '/' + normalizedRoute;
    }

    async function loadInheritanceVerification() {
        const host = document.getElementById('datatable-inheritance-output');
        host.textContent = 'Working...';
        try {
            const response = await fetch(resolveInheritanceBackendRoute('<?= htmlspecialchars((string) $verifyTagsUrl, ENT_QUOTES, 'UTF-8') ?>'), {
                method: 'GET',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin'
            });
            const payload = await response.json();
            const section = payload && payload.data && payload.data.sections
                ? payload.data.sections.attribute_inheritance || payload.data.attribute_inheritance || {}
                : {};
            host.textContent = JSON.stringify(section, null, 2);
        } catch (error) {
            host.textContent = error.message || 'Verification failed';
        }
    }

    document.addEventListener('click', function (event) {
        const trigger = event.target.closest('[data-datatable-test-action="load-inheritance-verification"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        loadInheritanceVerification();
    });
</script>
