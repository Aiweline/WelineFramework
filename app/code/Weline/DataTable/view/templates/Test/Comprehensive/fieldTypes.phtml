        <?php
        // 计算主题色的深色版本
        $themeColorValue = $themeColor ?? '#667eea';
        $themeColorDark = $themeColorValue;
        if (preg_match('/^#([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i', $themeColorValue, $matches)) {
            $r = max(0, min(255, hexdec($matches[1]) - 20));
            $g = max(0, min(255, hexdec($matches[2]) - 20));
            $b = max(0, min(255, hexdec($matches[3]) - 20));
            $themeColorDark = sprintf('#%02x%02x%02x', $r, $g, $b);
        }
        $isDark = ($themeMode ?? '') === 'dark';
        ?>
        :root {
            --theme-color: <?= htmlspecialchars($themeColorValue, ENT_QUOTES, 'UTF-8') ?>;
            --theme-color-dark: <?= htmlspecialchars($themeColorDark, ENT_QUOTES, 'UTF-8') ?>;
        }
        body {
            background-color: <?= $isDark ? '#1a1a1a' : '#f8f9fa' ?>;
            color: <?= $isDark ? '#ffffff' : '#333333' ?>;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .demo-section {
            background: <?= $isDark ? '#2d2d2d' : '#ffffff' ?>;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, <?= $isDark ? '0.5' : '0.1' ?>);
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid <?= $isDark ? '#404040' : '#dee2e6' ?>;
        }
        .code-block {
            background: <?= $isDark ? '#1e1e1e' : '#f8f9fa' ?>;
            border: 1px solid <?= $isDark ? '#404040' : '#dee2e6' ?>;
            border-radius: 5px;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            margin: 15px 0;
            color: <?= $isDark ? '#d4d4d4' : '#333333' ?>;
