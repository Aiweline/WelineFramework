<script>
    function resolveBackendRoute(route) {
        var normalizedRoute = String(route || '').replace(/^\/+/, '');
        var currentPath = String(window.location && window.location.pathname || '');
        var basePath = '<?= htmlspecialchars((string) ($backendBasePath ?? ''), ENT_QUOTES, 'UTF-8') ?>'.replace(/\/+$/, '');

        if (currentPath.indexOf('/@backend') === 0) {
            return '/@backend/' + normalizedRoute;
        }

        return basePath + '/' + normalizedRoute;
    }

    async function runBackendDemoAction(route) {
        const status = document.getElementById('backend-demo-status');
        status.textContent = 'Working...';
        try {
            const endpoint = typeof window.frontend_api === 'function' ? window.frontend_api(route) : route;
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin',
                body: JSON.stringify({})
            });
            const payload = await response.json();
            status.textContent = payload.message || payload.msg || 'Done';
        } catch (error) {
            status.textContent = error.message || 'Request failed';
        }
    }

    async function verifyBackendTags() {
        const output = document.getElementById('backend-verify-output');
        output.textContent = 'Working...';
        try {
            const response = await fetch(resolveBackendRoute('<?= htmlspecialchars((string) $verifyTagsUrl, ENT_QUOTES, 'UTF-8') ?>'), {
                method: 'GET',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin'
            });
            const payload = await response.json();
            output.textContent = JSON.stringify(payload, null, 2);
        } catch (error) {
            output.textContent = error.message || 'Verification request failed';
        }
    }
</script>
