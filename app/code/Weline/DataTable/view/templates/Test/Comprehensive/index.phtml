    <script>
        function verifyTags() {
            const btn = document.getElementById('verifyTagsBtn');
            const output = document.getElementById('verificationOutput');
            const content = document.getElementById('verificationContent');
            
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>验证中...';
            btn.disabled = true;
            
            fetch('<?= $this->getUrl("datatable/test/comprehensive/verifyTags") ?>')
                .then(response => response.json())
                .then(data => {
                    let html = '<div class="row">';
                    
                    Object.keys(data.data).forEach(category => {
                        html += '<div class="col-md-6 mb-3">';
                        html += '<div class="card">';
                        html += '<div class="card-header"><h6>' + category + '</h6></div>';
                        html += '<div class="card-body">';
                        
                        Object.keys(data.data[category]).forEach(test => {
                            const result = data.data[category][test];
                            const statusClass = result.status === 'success' ? 'text-success' : 'text-danger';
                            const icon = result.status === 'success' ? 'fa-check-circle' : 'fa-times-circle';
                            
                            html += '<div class="mb-2">';
                            html += '<i class="fas ' + icon + ' ' + statusClass + ' me-2"></i>';
                            html += '<strong>' + test + ':</strong> ' + result.message;
                            html += '</div>';
                        });
                        
                        html += '</div></div></div>';
                    });
                    
                    html += '</div>';
                    content.innerHTML = html;
                    output.style.display = 'block';
                    
                })
                .catch(error => {
                    content.innerHTML = '<div class="alert alert-danger">验证失败：' + error.message + '</div>';
                    output.style.display = 'block';
                })
                .finally(() => {
                    btn.innerHTML = '<i class="fas fa-vial me-2"></i>重新验证';
                    btn.disabled = false;
                });
        }
    </script>
