<script>
    let demoApiPromise = null;

    function getDemoApi() {
        if (demoApiPromise) {
            return demoApiPromise;
        }
        demoApiPromise = Promise.resolve().then(function () {
            if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
                throw new Error('Weline.Api.resource is not available');
            }
            return window.Weline.Api.resource('datatable');
        });
        return demoApiPromise;
    }

    async function demoBootstrap(action) {
        const status = document.getElementById('demo-status');
        status.textContent = 'Working...';
        try {
            const api = await getDemoApi();
            const operation = action === 'init-data' ? 'initData' : 'clearData';
            const payload = await api[operation]({}, {silent: true});
            status.textContent = payload.message || payload.msg || 'Done';
        } catch (error) {
            status.textContent = error.message || 'Request failed';
        }
    }

    document.addEventListener('click', function (event) {
        const trigger = event.target.closest('[data-datatable-test-action="demo-bootstrap"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        demoBootstrap(trigger.getAttribute('data-demo-action') || '');
    });
</script>
