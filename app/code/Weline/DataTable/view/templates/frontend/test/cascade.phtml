<script>
    function refreshCascadeTables() {
        if (!window.DataTableManager || !window.DataTableManager.instances) {
            return;
        }

        ['demo-cascade-users', 'demo-cascade-orders'].forEach(function (tableId) {
            const instance = window.DataTableManager.instances[tableId];
            if (instance && typeof window.DataTableManager.loadData === 'function') {
                window.DataTableManager.loadData(instance);
            }
        });
    }
</script>
