                    <?php $success = (string) ($result['status'] ?? '') === 'success'; ?>
                    <div class="dt-tag-item">
                        <i class="mdi <?= $success ? 'mdi-check-circle dt-tag-icon-success' : 'mdi-alert-circle dt-tag-icon-error' ?>"></i>
                        <div>
                            <strong><?= htmlspecialchars((string) $checkKey, ENT_QUOTES, 'UTF-8') ?></strong>
                            <div><?= htmlspecialchars((string) ($result['message'] ?? ''), ENT_QUOTES, 'UTF-8') ?></div>
                        </div>
