<script>
    async function reloadTagVerification() {
        const response = await fetch('<?= $verifyUrl ?>', {
            method: 'GET',
            headers: {'X-Requested-With': 'XMLHttpRequest'}
        });
        const payload = await response.json();
        if (payload && payload.success) {
            window.location.reload();
        }
    }

    document.addEventListener('click', function (event) {
        const trigger = event.target.closest('[data-datatable-test-action="reload-tag-verification"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        reloadTagVerification();
    });

    (function () {
        const host = document.getElementById('datatable-tag-sections');
        if (!host) {
            return;
        }
        const focus = String(host.dataset.focus || '').trim();
        if (!focus) {
            return;
        }

        const target = document.getElementById('section-' + focus);
        if (target && typeof target.scrollIntoView === 'function') {
            target.scrollIntoView({behavior: 'smooth', block: 'start'});
        }
    })();
</script>
