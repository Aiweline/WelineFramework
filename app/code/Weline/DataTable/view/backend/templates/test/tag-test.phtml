    <?= $this->fetch('Weline_DataTable::backend/templates/test/layout-switcher.phtml') ?>

    <section id="datatable-tag-sections" class="dt-tag-grid" data-focus="<?= htmlspecialchars((string) ($focusSection ?? ''), ENT_QUOTES, 'UTF-8') ?>">
        <?php foreach (($report['sections'] ?? []) as $sectionKey => $sectionResults): ?>
            <article class="dt-tag-card" id="section-<?= htmlspecialchars((string) $sectionKey, ENT_QUOTES, 'UTF-8') ?>" data-testid="datatable-tag-section-<?= htmlspecialchars((string) $sectionKey, ENT_QUOTES, 'UTF-8') ?>">
                <h3><?= htmlspecialchars((string) $sectionKey, ENT_QUOTES, 'UTF-8') ?></h3>
