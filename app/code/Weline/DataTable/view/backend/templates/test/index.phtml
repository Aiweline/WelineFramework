<script>
    function resolveDemoAdminApiUrl(route) {
        var normalizedRoute = String(route || '').replace(/^\/+/, '');
        var currentPath = String(window.location && window.location.pathname || '');
        var origin = String(window.location && window.location.origin || '').replace(/\/+$/, '');
        var basePath = '<?= htmlspecialchars((string) ($frontendApiBasePath ?? ''), ENT_QUOTES, 'UTF-8') ?>'.replace(/\/+$/, '');
        var prefix = currentPath.indexOf('/@backend') === 0 ? '/@api' : basePath;

        return origin + prefix + '/' + normalizedRoute;
    }

    async function runDemoAdminAction(url, statusId) {
        const status = document.getElementById(statusId);
        if (!status) {
            return;
        }

        status.textContent = 'Working...';
        try {
            const response = await fetch(resolveDemoAdminApiUrl(url), {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin',
                body: JSON.stringify({})
            });
            const payload = await response.json();
            status.textContent = payload.message || payload.msg || 'Done';
        } catch (error) {
            status.textContent = error.message || 'Request failed';
        }
    }
</script>
