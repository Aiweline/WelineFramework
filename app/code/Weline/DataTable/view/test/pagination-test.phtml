    <script>
        function applyPaginationSettings() {
            const pageSize = document.getElementById('page-size-selector').value;
            const paginationStyle = document.getElementById('pagination-style').value;
            const showTotal = document.getElementById('show-total').checked;
            const showPageInfo = document.getElementById('show-page-info').checked;
            
            console.log('应用分页设置:', { pageSize, paginationStyle, showTotal, showPageInfo });
            
            // 这里可以调用DataTable的分页设置方法
            if (window.customPaginationTable) {
                window.customPaginationTable.updatePagination({
                    page_size: parseInt(pageSize),
                    pagination_style: paginationStyle,
                    show_total: showTotal,
                    show_page_info: showPageInfo
                });
            }
        }

        function onPageChange(page, pageSize) {
            const eventLog = document.getElementById('pagination-events');
            const timestamp = new Date().toLocaleTimeString();
            eventLog.innerHTML += `<div>[${timestamp}] 页面改变: 第${page}页, 每页${pageSize}条</div>`;
            eventLog.scrollTop = eventLog.scrollHeight;
        }

        function onPageSizeChange(pageSize) {
            const eventLog = document.getElementById('pagination-events');
            const timestamp = new Date().toLocaleTimeString();
            eventLog.innerHTML += `<div>[${timestamp}] 页面大小改变: 每页${pageSize}条</div>`;
            eventLog.scrollTop = eventLog.scrollHeight;
        }
    </script>
