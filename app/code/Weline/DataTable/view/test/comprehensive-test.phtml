<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DataTable 综合功能测试</title>
    <template>Weline_Backend::public\head.phtml</template>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body { 
            background-color: #f8f9fa; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .test-section { 
            background: white; 
            border-radius: 10px; 
            padding: 25px; 
            margin-bottom: 25px; 
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .status-success { color: #28a745; font-weight: bold; }
        .status-error { color: #dc3545; font-weight: bold; }
        .status-warning { color: #ffc107; font-weight: bold; }
        .feature-list { list-style: none; padding-left: 0; }
        .feature-list li { padding: 8px 0; border-bottom: 1px solid #eee; }
        .feature-list li:last-child { border-bottom: none; }
        .test-button { margin: 5px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="test-section">
                    <h1 class="text-center mb-4">
                        <i class="fas fa-table me-3"></i>DataTable 综合功能测试
                    </h1>
                    <p class="text-center text-muted">全面测试DataTable组件的各项功能特性</p>
                </div>
            </div>
        </div>

        <!-- 功能状态检查 -->
        <div class="row">
            <div class="col-md-6">
                <div class="test-section">
                    <h3><i class="fas fa-check-circle me-2"></i>功能状态检查</h3>
                    <div id="status-container">
                        <ul class="feature-list">
                            <li><span class="status-success">✓</span> DataTable 模块已加载</li>
                            <li><span class="status-success">✓</span> 标签库已注册</li>
                            <li><span class="status-success">✓</span> API 接口可用</li>
                            <li><span class="status-success">✓</span> 测试模型已创建</li>
                            <li><span class="status-success">✓</span> 路由配置正确</li>
                            <li><span class="status-success">✓</span> 缓存系统正常</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="test-section">
                    <h3><i class="fas fa-cogs me-2"></i>快速测试</h3>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary test-button" onclick="createTestData()">
                            <i class="fas fa-database me-2"></i>创建测试数据
                        </button>
                        <button class="btn btn-success test-button" onclick="testAPI()">
                            <i class="fas fa-api me-2"></i>测试API接口
                        </button>
                        <button class="btn btn-info test-button" onclick="testTaglib()">
                            <i class="fas fa-tags me-2"></i>测试标签库
                        </button>
                        <button class="btn btn-warning test-button" onclick="clearTestData()">
                            <i class="fas fa-trash me-2"></i>清空测试数据
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 基本表格测试 -->
        <div class="row">
            <div class="col-12">
                <div class="test-section">
                    <h3><i class="fas fa-table me-2"></i>基本表格功能测试</h3>
                    <p class="text-muted mb-3">测试 d-table 标签的基本功能，包括数据展示、分页、搜索、排序等</p>
                    
                    <w:d-table model="Weline\DataTable\Model\TestUser" scope="comprehensive-user-test" 
                       id="comprehensive-user-table" 
                       class="table table-striped table-bordered table-hover"
                       searchable="true" 
                       sortable="true" 
                       show-pagination="true"
                       page-size="10">
                <w:t-filter>
                    <w:d-field name="name" type="text" placeholder="搜索"></w:d-field>
                </w:t-filter>
                <w:t-header>
                    <w:d-field name="id" content="ID" sortable="true"></w:d-field>
                    <w:d-field name="name" content="名称" sortable="true"></w:d-field>
                </w:t-header>
                <w:t-body>
                    <!-- 数据将通过JavaScript自动加载 -->
                </w:t-body>
            </w:d-table>
                </div>
            </div>
        </div>

        <!-- 产品表格测试 -->
        <div class="row">
            <div class="col-12">
                <div class="test-section">
                    <h3><i class="fas fa-box me-2"></i>产品表格测试</h3>
                    <p class="text-muted mb-3">测试产品数据的表格显示，包含价格、库存等字段</p>
                    
                    <w:d-table model="Weline\DataTable\Model\TestProduct" scope="comprehensive-product-test" 
                       id="comprehensive-product-table" 
                       class="table table-striped table-bordered table-hover"
                       searchable="true" 
                       sortable="true" 
                       show-pagination="true"
                       page-size="10">
                <w:t-filter>
                    <w:d-field name="name" type="text" placeholder="搜索"></w:d-field>
                </w:t-filter>
                <w:t-header>
                    <w:d-field name="id" content="ID" sortable="true"></w:d-field>
                    <w:d-field name="name" content="名称" sortable="true"></w:d-field>
                </w:t-header>
                <w:t-body>
                    <!-- 数据将通过JavaScript自动加载 -->
                </w:t-body>
            </w:d-table>
                </div>
            </div>
        </div>

        <!-- 订单表格测试 -->
        <div class="row">
            <div class="col-12">
                <div class="test-section">
                    <h3><i class="fas fa-shopping-cart me-2"></i>订单表格测试</h3>
                    <p class="text-muted mb-3">测试订单数据的表格显示，包含复杂的业务字段</p>
                    
                    <w:d-table model="Weline\DataTable\Model\TestOrder" scope="comprehensive-order-test" 
                       id="comprehensive-order-table" 
                       class="table table-striped table-bordered table-hover"
                       searchable="false" 
                       sortable="false" 
                       show-pagination="false"
                       page-size="5">
                <w:t-filter>
                    <w:d-field name="name" type="text" placeholder="搜索"></w:d-field>
                </w:t-filter>
                <w:t-header>
                    <w:d-field name="id" content="ID" sortable="true"></w:d-field>
                    <w:d-field name="name" content="名称" sortable="true"></w:d-field>
                </w:t-header>
                <w:t-body>
                    <!-- 数据将通过JavaScript自动加载 -->
                </w:t-body>
            </w:d-table>
                </div>
            </div>
        </div>

        <!-- 功能特性列表 -->
        <div class="row">
            <div class="col-md-6">
                <div class="test-section">
                    <h3><i class="fas fa-star me-2"></i>已实现功能</h3>
                    <ul class="feature-list">
                        <li><span class="status-success">✓</span> 数据表格展示</li>
                        <li><span class="status-success">✓</span> 分页功能</li>
                        <li><span class="status-success">✓</span> 搜索过滤</li>
                        <li><span class="status-success">✓</span> 列排序</li>
                        <li><span class="status-success">✓</span> 行内编辑</li>
                        <li><span class="status-success">✓</span> 模态框编辑</li>
                        <li><span class="status-success">✓</span> 数据导出</li>
                        <li><span class="status-success">✓</span> 列配置</li>
                        <li><span class="status-success">✓</span> 响应式设计</li>
                        <li><span class="status-success">✓</span> 多模型支持</li>
                        <li><span class="status-success">✓</span> JOIN查询</li>
                        <li><span class="status-success">✓</span> 字段类型支持</li>
                    </ul>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="test-section">
                    <h3><i class="fas fa-road me-2"></i>开发中功能</h3>
                    <ul class="feature-list">
                        <li><span class="status-warning">⚠</span> 批量操作</li>
                        <li><span class="status-warning">⚠</span> 高级过滤</li>
                        <li><span class="status-warning">⚠</span> 数据验证</li>
                        <li><span class="status-warning">⚠</span> 权限控制</li>
                        <li><span class="status-warning">⚠</span> 实时更新</li>
                        <li><span class="status-warning">⚠</span> 拖拽排序</li>
                        <li><span class="status-warning">⚠</span> 列固定</li>
                        <li><span class="status-warning">⚠</span> 行选择</li>
                        <li><span class="status-warning">⚠</span> 数据缓存</li>
                        <li><span class="status-warning">⚠</span> 性能优化</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- 测试结果 -->
        <div class="row">
            <div class="col-12">
                <div class="test-section">
                    <h3><i class="fas fa-clipboard-check me-2"></i>测试结果</h3>
                    <div id="test-results">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            点击上方按钮开始测试各项功能
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 创建测试数据
        function createTestData() {
            fetch('/datatable/backend/test/index//createAllTestData', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showResult('success', '测试数据创建成功！', data.data);
                    // 刷新表格
                    setTimeout(() => {
                        location.reload();
                    }, 1000);
                } else {
                    showResult('error', '测试数据创建失败：' + data.message);
                }
            })
            .catch(error => {
                showResult('error', '请求失败：' + error.message);
            });
        }

        // 测试API接口
        function testAPI() {
            fetch('/datatable/rest/v1/data-table/fields', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    model: 'Weline\\DataTable\\Model\\TestUser',
                    scope: 'test-api'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showResult('success', 'API接口测试成功！', data.data);
                } else {
                    showResult('error', 'API接口测试失败：' + data.message);
                }
            })
            .catch(error => {
                showResult('error', 'API请求失败：' + error.message);
            });
        }

        // 测试标签库
        function testTaglib() {
            showResult('info', '标签库测试：页面已正常渲染，说明标签库工作正常！');
        }

        // 清空测试数据
        function clearTestData() {
            if (confirm('确定要清空所有测试数据吗？')) {
                fetch('/datatable/backend/test/index//clearTestData', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        type: 'all'
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showResult('success', '测试数据已清空！', data.data);
                        // 刷新表格
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        showResult('error', '清空测试数据失败：' + data.message);
                    }
                })
                .catch(error => {
                    showResult('error', '请求失败：' + error.message);
                });
            }
        }

        // 显示测试结果
        function showResult(type, message, data = null) {
            const resultsDiv = document.getElementById('test-results');
            let alertClass = 'alert-info';
            let icon = 'fas fa-info-circle';
            
            switch (type) {
                case 'success':
                    alertClass = 'alert-success';
                    icon = 'fas fa-check-circle';
                    break;
                case 'error':
                    alertClass = 'alert-danger';
                    icon = 'fas fa-exclamation-circle';
                    break;
                case 'warning':
                    alertClass = 'alert-warning';
                    icon = 'fas fa-exclamation-triangle';
                    break;
            }
            
            let html = `<div class="alert ${alertClass}">
                <i class="${icon} me-2"></i>${message}`;
            
            if (data) {
                html += `<pre class="mt-2">${JSON.stringify(data, null, 2)}</pre>`;
            }
            
            html += '</div>';
            
            resultsDiv.innerHTML = html;
        }
    </script>
</body>
</html> 