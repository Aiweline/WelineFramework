    <script>
        function exportData(format) {
            const status = document.getElementById('export-status');
            status.textContent = `正在导出${format.toUpperCase()}格式...`;
            
            // 模拟导出过程
            setTimeout(() => {
                status.textContent = `${format.toUpperCase()}导出完成！`;
                addExportHistory(format, `用户数据.${format}`, 5, '成功');
            }, 2000);
        }

        function exportWithCustomSettings() {
            const status = document.getElementById('custom-export-status');
            const filename = document.getElementById('export-filename').value;
            const includeHeader = document.getElementById('export-header').checked;
            const exportRange = document.getElementById('export-range').value;
            
            status.textContent = `正在导出: ${filename}, 包含表头: ${includeHeader}, 范围: ${exportRange}`;
            
            setTimeout(() => {
                status.textContent = '自定义导出完成！';
                addExportHistory('excel', `${filename}.xlsx`, 5, '成功');
            }, 2000);
        }

        function batchExport() {
            const status = document.getElementById('batch-export-status');
            const formats = [];
            
            if (document.getElementById('batch-excel').checked) formats.push('excel');
            if (document.getElementById('batch-csv').checked) formats.push('csv');
            if (document.getElementById('batch-pdf').checked) formats.push('pdf');
            if (document.getElementById('batch-json').checked) formats.push('json');
            
            const useZip = document.getElementById('batch-zip').checked;
            
            status.textContent = `正在批量导出: ${formats.join(', ')}, 打包: ${useZip}`;
            
            setTimeout(() => {
                status.textContent = '批量导出完成！';
                formats.forEach(format => {
                    addExportHistory(format, `用户数据.${format}`, 5, '成功');
                });
            }, 3000);
        }

        function addExportHistory(format, filename, count, status) {
            const history = document.getElementById('export-history');
            const timestamp = new Date().toLocaleString();
            
            if (history.children.length === 1 && history.children[0].children.length === 1) {
                history.innerHTML = '';
            }
            
            const row = document.createElement('tr');
            row.innerHTML = `
                <td>${timestamp}</td>
                <td>${format.toUpperCase()}</td>
                <td>${filename}</td>
                <td>${count}</td>
                <td><span class="badge bg-success">${status}</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary" onclick="downloadFile('${filename}')">
                        <i class="fas fa-download"></i>
                    </button>
                </td>
            `;
            history.appendChild(row);
        }

        function downloadFile(filename) {
            // 模拟文件下载
            console.log('下载文件:', filename);
            alert(`开始下载: ${filename}`);
        }
    </script>
