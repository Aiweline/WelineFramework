                            <strong>示例：</strong> type="select" options="1:启用,0:禁用"
                        </div>
                        <ul class="list-unstyled ms-4 mt-2">
                            <li>• text: 文本搜索</li>
                            <li>• email: 邮箱格式验证</li>
                            <li>• select: 下拉选择</li>
                            <li>• date: 日期选择</li>
                            <li>• number: 数字输入</li>
                        </ul>
                    </div>
                </div>
