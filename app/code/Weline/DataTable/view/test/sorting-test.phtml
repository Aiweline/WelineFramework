    <script>
        function applySortingRules() {
            const statusRule = document.getElementById('status-sort-rule').value;
            const dateFormat = document.getElementById('date-sort-format').value;
            
            console.log('应用排序规则:', { statusRule, dateFormat });
            
            // 这里可以调用DataTable的排序规则设置方法
            if (window.customSortingTable) {
                window.customSortingTable.updateSortingRules({
                    status: statusRule,
                    date_format: dateFormat
                });
            }
        }

        function onSort(field, order) {
            const eventLog = document.getElementById('sorting-events');
            const timestamp = new Date().toLocaleTimeString();
            eventLog.innerHTML += `<div>[${timestamp}] 排序: ${field} ${order}</div>`;
            eventLog.scrollTop = eventLog.scrollHeight;
            
            updateSortStatus(field, order);
        }

        function onSortChange(sortFields) {
            const eventLog = document.getElementById('sorting-events');
            const timestamp = new Date().toLocaleTimeString();
            eventLog.innerHTML += `<div>[${timestamp}] 排序改变: ${JSON.stringify(sortFields)}</div>`;
            eventLog.scrollTop = eventLog.scrollHeight;
            
            updateSortHistory(sortFields);
        }

        function updateSortStatus(field, order) {
            document.getElementById('current-sort-fields').textContent = field;
            document.getElementById('current-sort-orders').textContent = order;
        }

        function updateSortHistory(sortFields) {
            const history = document.getElementById('sort-history');
            const timestamp = new Date().toLocaleTimeString();
            const historyItem = `<div>[${timestamp}] ${JSON.stringify(sortFields)}</div>`;
            
            if (history.children.length > 10) {
                history.removeChild(history.firstChild);
            }
            history.innerHTML += historyItem;
            history.scrollTop = history.scrollHeight;
        }
    </script>
