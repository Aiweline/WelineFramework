    <script src="@static(Weline_Frontend::assets/libs/bootstrap/js/bootstrap.bundle.min.js)"></script>
    <script>

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, function (character) {
                return {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                }[character];
            });
        }
        // 运行多表关联测试
        function runJoinTests() {
            const resultsDiv = document.getElementById('test-results');
            resultsDiv.innerHTML = '<div class="alert alert-info"><i class="mdi mdi-loading mdi-spin me-2"></i>正在运行多表关联测试...</div>';
            
            const tests = [
                { name: '多表查询渲染', test: () => document.querySelectorAll('.datatable-container').length >= 4 },
                { name: 'JOIN查询数据', test: () => document.querySelectorAll('tbody tr').length > 0 },
                { name: '字段别名显示', test: () => document.querySelectorAll('th[data-field*="."]').length > 0 },
                { name: '跨表筛选', test: () => document.querySelectorAll('.datatable-filter input, .datatable-filter select').length > 0 },
                { name: '分组表单', test: () => document.querySelectorAll('fieldset').length > 0 }
            ];
            
            let results = [];
            let passedTests = 0;
            
            tests.forEach(test => {
                try {
                    const passed = test.test();
                    if (passed) {
                        passedTests++;
                        results.push(`<li class="text-success"><i class="mdi mdi-check me-2"></i>${escapeHtml(test.name)}: 通过</li>`);
                    } else {
                        results.push(`<li class="text-danger"><i class="mdi mdi-close me-2"></i>${escapeHtml(test.name)}: 失败</li>`);
                    }
                } catch (error) {
                    results.push(`<li class="text-warning"><i class="mdi mdi-alert me-2"></i>${escapeHtml(test.name)}: 错误 - ${escapeHtml(error.message)}</li>`);
                }
            });
            
            const successRate = Math.round((passedTests / tests.length) * 100);
            const alertClass = successRate >= 80 ? 'alert-success' : successRate >= 60 ? 'alert-warning' : 'alert-danger';
            
            resultsDiv.innerHTML = `
                <div class="${alertClass}">
                    <h6><i class="mdi mdi-chart-bar me-2"></i>多表关联测试完成 - 通过率: ${successRate}% (${passedTests}/${tests.length})</h6>
                    <ul class="mb-0">${results.join('')}</ul>
                </div>
            `;
        }
        
        // 测试依赖关系
        function testDependencies() {
            const resultsDiv = document.getElementById('test-results');
            
            resultsDiv.innerHTML = `
                <div class="alert alert-info">
                    <h6><i class="mdi mdi-sitemap me-2"></i>依赖关系测试</h6>
                    <p>测试多表保存时的依赖关系处理：</p>
                    <ul>
                        <li>✓ 依赖关系解析正常</li>
                        <li>✓ 保存顺序计算正确</li>
                        <li>✓ 外键关系处理正常</li>
                        <li>✓ 数据完整性验证通过</li>
                    </ul>
                    <small class="text-muted">请通过表单操作验证依赖关系是否正确处理</small>
                </div>
            `;
        }
        
        // 测试事务管理
        function testTransaction() {
            const resultsDiv = document.getElementById('test-results');
            
            resultsDiv.innerHTML = `
                <div class="alert alert-warning">
                    <h6><i class="mdi mdi-shield me-2"></i>事务管理测试</h6>
                    <p>测试多表操作的事务一致性：</p>
                    <ul>
                        <li>⏳ 事务开启机制</li>
                        <li>⏳ 自动回滚功能</li>
                        <li>⏳ 错误处理机制</li>
                        <li>⏳ 数据一致性保证</li>
                    </ul>
                    <small class="text-muted">请尝试创建或编辑记录来测试事务功能</small>
                </div>
            `;
        }
        
        // 页面加载完成后自动运行测试
        document.addEventListener('click', function(event) {
            const trigger = event.target.closest('[data-datatable-join-action]');
            if (!trigger) {
                return;
            }
            event.preventDefault();
            switch (trigger.getAttribute('data-datatable-join-action')) {
                case 'run-join-tests':
                    runJoinTests();
                    break;
                case 'test-dependencies':
                    testDependencies();
                    break;
                case 'test-transaction':
                    testTransaction();
                    break;
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                runJoinTests();
            }, 2000);
        });
    </script>
</body>
