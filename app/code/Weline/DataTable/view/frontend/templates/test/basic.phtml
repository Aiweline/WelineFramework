    <script>
        // 运行基础功能测试
        function runBasicTests() {
            const resultsDiv = document.getElementById('test-results');
            resultsDiv.innerHTML = '<div class="alert alert-info"><i class="fas fa-spinner fa-spin me-2"></i>正在运行测试...</div>';
            
            const tests = [
                { name: '表格渲染', test: () => document.querySelectorAll('.datatable-container').length > 0 },
                { name: '表头显示', test: () => document.querySelectorAll('thead th').length > 0 },
                { name: '数据行显示', test: () => document.querySelectorAll('tbody tr').length > 0 },
                { name: '分页组件', test: () => document.querySelectorAll('.pagination').length > 0 },
                { name: '筛选器', test: () => document.querySelectorAll('.datatable-filter').length > 0 }
            ];
            
            let results = [];
            let passedTests = 0;
            
            tests.forEach(test => {
                try {
                    const passed = test.test();
                    if (passed) {
                        passedTests++;
                        results.push(`<li class="text-success"><i class="fas fa-check me-2"></i>${test.name}: 通过</li>`);
                    } else {
                        results.push(`<li class="text-danger"><i class="fas fa-times me-2"></i>${test.name}: 失败</li>`);
                    }
                } catch (error) {
                    results.push(`<li class="text-warning"><i class="fas fa-exclamation-triangle me-2"></i>${test.name}: 错误 - ${error.message}</li>`);
                }
            });
            
            const successRate = Math.round((passedTests / tests.length) * 100);
            const alertClass = successRate >= 80 ? 'alert-success' : successRate >= 60 ? 'alert-warning' : 'alert-danger';
            
            resultsDiv.innerHTML = `
                <div class="${alertClass}">
                    <h6><i class="fas fa-chart-bar me-2"></i>测试完成 - 通过率: ${successRate}% (${passedTests}/${tests.length})</h6>
                    <ul class="mb-0">${results.join('')}</ul>
                </div>
            `;
        }
        
        // 检查表格功能
        function checkTableFeatures() {
            const resultsDiv = document.getElementById('test-results');
            
            const features = [
                '✓ 自动字段生成功能正常',
                '✓ 分页功能正常工作',
                '✓ 排序功能可以使用',
                '✓ 筛选功能可以使用',
                '✓ 表格响应式布局正常',
                '✓ 数据加载正常'
            ];
            
            resultsDiv.innerHTML = `
                <div class="alert alert-success">
                    <h6><i class="fas fa-list-check me-2"></i>功能检查清单</h6>
                    <ul class="mb-0">
                        ${features.map(feature => `<li>${feature}</li>`).join('')}
                    </ul>
                    <hr>
                    <small class="text-muted">请手动验证上述功能是否正常工作</small>
                </div>
            `;
        }
        
        // 页面加载完成后自动运行测试
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                runBasicTests();
            }, 2000);
        });
    </script>
