    <script src="@static(Weline_Frontend::assets/libs/bootstrap/js/bootstrap.bundle.min.js)"></script>
    <script>
        const dataTableTestMessages = {
            clearConfirm: <?= json_encode((string)__('确定要清理所有测试数据吗？此操作不可恢复！'), $jsonForScriptFlags) ?>,
            clearData: <?= json_encode((string)__('清理测试数据'), $jsonForScriptFlags) ?>,
            cancel: <?= json_encode((string)__('取消'), $jsonForScriptFlags) ?>
        };

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, function (character) {
                return {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                }[character];
            });
        }

        function requestClearDataConfirmation(onConfirm) {
            const statusDiv = document.getElementById('data-status');
            if (!statusDiv) {
                console.error(dataTableTestMessages.clearConfirm);
                return;
            }

            statusDiv.innerHTML = '';

            const alertBox = document.createElement('div');
            alertBox.className = 'alert alert-warning d-flex flex-column flex-md-row gap-2 justify-content-between align-items-md-center';
            alertBox.setAttribute('role', 'status');

            const message = document.createElement('span');
            const icon = document.createElement('i');
            icon.className = 'mdi mdi-alert me-2';
            message.appendChild(icon);
            message.appendChild(document.createTextNode(dataTableTestMessages.clearConfirm));

            const actions = document.createElement('div');
            actions.className = 'd-flex gap-2';

            const confirmButton = document.createElement('button');
            confirmButton.type = 'button';
            confirmButton.className = 'btn btn-danger btn-sm';
            confirmButton.textContent = dataTableTestMessages.clearData;

            const cancelButton = document.createElement('button');
            cancelButton.type = 'button';
            cancelButton.className = 'btn btn-outline-secondary btn-sm';
            cancelButton.textContent = dataTableTestMessages.cancel;

            confirmButton.addEventListener('click', function () {
                statusDiv.innerHTML = '';
                onConfirm();
            });
            cancelButton.addEventListener('click', function () {
                statusDiv.innerHTML = '';
            });

            actions.appendChild(confirmButton);
            actions.appendChild(cancelButton);
            alertBox.appendChild(message);
            alertBox.appendChild(actions);
            statusDiv.appendChild(alertBox);
            cancelButton.focus();
        }

        // 初始化测试数据
        function initTestData() {
            const statusDiv = document.getElementById('data-status');
            statusDiv.innerHTML = '<div class="alert alert-info"><i class="mdi mdi-loading mdi-spin me-2"></i>正在初始化测试数据...</div>';
            
            fetch('/datatable/test/initData', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    statusDiv.innerHTML = `
                        <div class="alert alert-success">
                            <i class="mdi mdi-check me-2"></i>${escapeHtml(data.message)}
                            <br><small>用户: ${escapeHtml(data?.data?.users)} 条，产品: ${escapeHtml(data?.data?.products)} 条，订单: ${escapeHtml(data?.data?.orders)} 条</small>
                        </div>
                    `;
                } else {
                    statusDiv.innerHTML = `<div class="alert alert-danger"><i class="mdi mdi-close me-2"></i>${escapeHtml(data.message)}</div>`;
                }
            })
            .catch(error => {
                statusDiv.innerHTML = `<div class="alert alert-danger"><i class="mdi mdi-close me-2"></i>请求失败: ${escapeHtml(error.message)}</div>`;
            });
        }

        // 清理测试数据
        function clearTestData() {
            requestClearDataConfirmation(function () {
                const statusDiv = document.getElementById('data-status');
                statusDiv.innerHTML = '<div class="alert alert-warning"><i class="mdi mdi-loading mdi-spin me-2"></i>正在清理测试数据...</div>';

                fetch('/datatable/test/clearData', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        statusDiv.innerHTML = `<div class="alert alert-success"><i class="mdi mdi-check me-2"></i>${escapeHtml(data.message)}</div>`;
                    } else {
                        statusDiv.innerHTML = `<div class="alert alert-danger"><i class="mdi mdi-close me-2"></i>${escapeHtml(data.message)}</div>`;
                    }
                })
                .catch(error => {
                    statusDiv.innerHTML = `<div class="alert alert-danger"><i class="mdi mdi-close me-2"></i>请求失败: ${escapeHtml(error.message)}</div>`;
                });
            });
        }
        function openTestCard(card) {
            const href = card.getAttribute('data-datatable-test-href') || '';
            if (href) {
                window.location.href = href;
            }
        }

        document.addEventListener('click', function(event) {
            const actionTrigger = event.target.closest('[data-datatable-test-action]');
            if (actionTrigger) {
                event.preventDefault();
                switch (actionTrigger.getAttribute('data-datatable-test-action')) {
                    case 'init-data':
                        initTestData();
                        break;
                    case 'clear-data':
                        clearTestData();
                        break;
                }
                return;
            }

            const card = event.target.closest('[data-datatable-test-href]');
            if (card) {
                event.preventDefault();
                openTestCard(card);
            }
        });

        document.addEventListener('keydown', function(event) {
            if (event.key !== 'Enter' && event.key !== ' ') {
                return;
            }

            const card = event.target.closest('[data-datatable-test-href]');
            if (!card) {
                return;
            }

            event.preventDefault();
            openTestCard(card);
        });
    </script>
