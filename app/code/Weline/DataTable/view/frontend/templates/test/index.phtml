    <script>
        // 初始化测试数据
        function initTestData() {
            const statusDiv = document.getElementById('data-status');
            statusDiv.innerHTML = '<div class="alert alert-info"><i class="fas fa-spinner fa-spin me-2"></i>正在初始化测试数据...</div>';
            
            fetch('/datatable/test/initData', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    statusDiv.innerHTML = `
                        <div class="alert alert-success">
                            <i class="fas fa-check me-2"></i>${data.message}
                            <br><small>用户: ${data.data.users} 条，产品: ${data.data.products} 条，订单: ${data.data.orders} 条</small>
                        </div>
                    `;
                } else {
                    statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-times me-2"></i>${data.message}</div>`;
                }
            })
            .catch(error => {
                statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-times me-2"></i>请求失败: ${error.message}</div>`;
            });
        }

        // 清理测试数据
        function clearTestData() {
            if (!confirm('确定要清理所有测试数据吗？此操作不可恢复！')) {
                return;
            }
            
            const statusDiv = document.getElementById('data-status');
            statusDiv.innerHTML = '<div class="alert alert-warning"><i class="fas fa-spinner fa-spin me-2"></i>正在清理测试数据...</div>';
            
            fetch('/datatable/test/clearData', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    statusDiv.innerHTML = `<div class="alert alert-success"><i class="fas fa-check me-2"></i>${data.message}</div>`;
                } else {
                    statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-times me-2"></i>${data.message}</div>`;
                }
            })
            .catch(error => {
                statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-times me-2"></i>请求失败: ${error.message}</div>`;
            });
        }
    </script>
