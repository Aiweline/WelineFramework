<script>
function createBackup(event) {
    event.preventDefault();
    
    const submitBtn = document.getElementById('submitBtn');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-2"></i><?= __('创建中...') ?>';

    const formData = new FormData(event.target);
    
    fetch('<?= $this->getBackendUrl('maintenance/backend/backup/create') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            setTimeout(() => {
                location.href = '<?= $this->getBackendUrl('maintenance/backend/backup/index') ?>';
            }, 1500);
        } else {
            showPageMessage('error', data.message);
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('创建备份失败') ?>');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    });
}
</script>

</body>
