<?php
/**
 * 创建备份页面（内容模板）
 *
 * @var \Weline\Framework\View\Template $this
 */
?>
<!-- 页面标题 -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18"><lang>创建备份</lang></h4>
        </div>
    </div>
</div>

<!-- 消息提示区域 -->
<div class='row'>
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<!-- 创建备份表单 -->
<div class="row">
    <div class="col-xl-8">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4"><lang>备份设置</lang></h4>
                
                <form id="backupForm" onsubmit="MaintenanceBackup.createBackup(event)">
                    <div class="mb-3">
                        <label class="form-label"><lang>备份类型</lang></label>
                        <select class="form-select" id="backup_type" name="type" required>
                            <option value="full"><lang>完整备份（数据库+代码）</lang></option>
                            <option value="database"><lang>数据库备份</lang></option>
                            <option value="code"><lang>代码备份</lang></option>
                            <option value="config"><lang>配置文件备份</lang></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <div class="alert alert-info">
                            <i class="mdi mdi-information me-2"></i>
                            <lang>创建备份可能需要几分钟时间，请耐心等待。</lang>
                        </div>
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="mdi mdi-content-save me-2"></i><lang>创建备份</lang>
                        </button>
                        <a href="<?= $this->getBackendUrl('maintenance/backend/backup/index') ?>" class="btn btn-secondary ms-2">
                            <lang>返回列表</lang>
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    window.MaintenanceBackup = window.MaintenanceBackup || {};
    
    MaintenanceBackup.createBackup = function(event) {
        event.preventDefault();
        
        var submitBtn = document.getElementById('submitBtn');
        var originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-2"></i><?= __('创建中...') ?>';

        var formData = new FormData(event.target);
        
        var createUrl = '<?= $this->getBackendUrl('maintenance/backend/backup/create') ?>';
        var createOpts = { method: 'POST', body: formData };
        window.Weline.Api.request(createUrl, createOpts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            if (data.success) {
                AdminToast.success(data.message);
                setTimeout(function() {
                    location.href = '<?= $this->getBackendUrl('maintenance/backend/backup/index') ?>';
                }, 1500);
            } else {
                AdminToast.error(data.message);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        })
        .catch(function(error) {
            AdminToast.error('<?= __('创建备份失败') ?>');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    };
})();
</script>
