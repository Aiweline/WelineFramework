</div>

<script>
(function() {
    'use strict';
    
    window.MaintenanceBackup = {
        formatBytes: function(bytes) {
            if (bytes === 0) return '0 B';
            var k = 1024;
            var sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            var i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        },
        
        deleteBackup: function(backupId) {
            AdminConfirm.show('<?= __('确定要删除此备份吗？') ?>').then(function(confirmed) {
                if (!confirmed) return;
                
                var formData = new FormData();
                formData.append('id', backupId);
                
                var url = '<?= $this->getBackendUrl('maintenance/backend/backup/delete') ?>';
                var opts = { method: 'POST', body: formData };
                window.Weline.Api.request(url, opts)
                .then(function(res) {
                    var data = (res && res.data) !== undefined ? res.data : res;
                    if (data.success) {
                        AdminToast.success(data.message);
                        setTimeout(function() { location.reload(); }, 1000);
                    } else {
                        AdminToast.error(data.message);
                    }
                })
                .catch(function(error) {
                    AdminToast.error('<?= __('操作失败') ?>');
                });
            });
        }
    };
})();
</script>
