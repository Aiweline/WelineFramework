                                            echo $statusMap[$backup['status'] ?? 'pending'] ?? $backup['status'] ?? '';
                                            ?>
                                        </td>
                                        <td><?= $backup['created_at'] ?? '' ?></td>
                                        <td>
                                            <a href="<?= $this->getBackendUrl('maintenance/backend/backup/download', ['id' => $backup['backup_id'] ?? 0]) ?>" 
                                               class="btn btn-sm btn-primary me-1">
                                                <i class="mdi mdi-download"></i> <lang>下载</lang>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger" 
                                                    onclick="MaintenanceBackup.deleteBackup(<?= $backup['backup_id'] ?? 0 ?>)">
                                                <i class="mdi mdi-delete"></i> <lang>删除</lang>
                                            </button>
