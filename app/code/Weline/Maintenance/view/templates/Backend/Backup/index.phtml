<script>
function formatBytes(bytes) {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
}

function deleteBackup(backupId) {
    if (!confirm('<?= __('确定要删除此备份吗？') ?>')) {
        return;
    }

    const formData = new FormData();
    formData.append('id', backupId);

    fetch('<?= $this->getBackendUrl('maintenance/backend/backup/delete') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('操作失败') ?>');
    });
}
</script>

