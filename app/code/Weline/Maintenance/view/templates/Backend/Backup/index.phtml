                                                'full' => __('完整备份'),
                                                'database' => __('数据库备份'),
                                                'code' => __('代码备份'),
                                                'config' => __('配置文件备份'),
                                            ];
                                            echo $typeMap[$backup['backup_type'] ?? ''] ?? $backup['backup_type'] ?? '';
                                            ?>
                                        </td>
                                        <td><?= htmlspecialchars($backup['backup_name'] ?? '') ?></td>
                                        <td>
                                            <?php
                                            $size = (int)($backup['file_size'] ?? 0);
                                            if ($size === 0) {
                                                echo '0 B';
                                            } else {
                                                $units = ['B', 'KB', 'MB', 'GB', 'TB'];
                                                $i = floor(log($size) / log(1024));
                                                $i = min($i, count($units) - 1);
                                                echo round($size / pow(1024, $i), 2) . ' ' . $units[$i];
                                            }
                                            ?>
                                        </td>
                                        <td>
                                            <?php
                                            $statusMap = [
                                                'completed' => '<span class="badge bg-success">' . __('已完成') . '</span>',
