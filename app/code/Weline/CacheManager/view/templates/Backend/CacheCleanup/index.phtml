<script>
(function() {
    'use strict';
    
    function executeCleanup() {
        if (window.AdminConfirm) {
            AdminConfirm.show({
                title: '<?= __('确认清理') ?>',
                message: '<?= __('确定要执行缓存清理吗？这将删除所有过期的缓存文件。') ?>',
                confirmText: '<?= __('确认') ?>',
                cancelText: '<?= __('取消') ?>',
                onConfirm: function() {
                    doCleanup();
                }
            });
        } else if (confirm('<?= __('确定要执行缓存清理吗？这将删除所有过期的缓存文件。') ?>')) {
            doCleanup();
        }
    }
    
    function doCleanup() {
        fetch('<?= $this->getUrl("*/cachecleanup/executecleanup") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (window.AdminToast) {
                    AdminToast.success('<?= __('缓存清理完成！') ?>');
                }
                setTimeout(function() { location.reload(); }, 2000);
            } else {
                if (window.AdminToast) {
                    AdminToast.error('<?= __('缓存清理失败') ?>: ' + (data.message || '<?= __('未知错误') ?>'));
                }
            }
        })
        .catch(function(error) {
            if (window.AdminToast) {
                AdminToast.error('<?= __('请求失败') ?>: ' + error.message);
            }
        });
    }

    function runCronTask() {
        if (window.AdminConfirm) {
            AdminConfirm.show({
                title: '<?= __('确认执行') ?>',
                message: '<?= __('确定要手动执行定时任务吗？') ?>',
                confirmText: '<?= __('确认') ?>',
                cancelText: '<?= __('取消') ?>',
                onConfirm: function() {
                    doCronTask();
                }
            });
        } else if (confirm('<?= __('确定要手动执行定时任务吗？') ?>')) {
            doCronTask();
        }
    }
    
    function doCronTask() {
        fetch('<?= $this->getUrl("*/cachecleanup/runcrontask") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (window.AdminToast) {
                    AdminToast.success('<?= __('定时任务执行完成！') ?>');
                }
                setTimeout(function() { location.reload(); }, 2000);
            } else {
                if (window.AdminToast) {
                    AdminToast.error('<?= __('定时任务执行失败') ?>: ' + (data.message || '<?= __('未知错误') ?>'));
                }
            }
        })
        .catch(function(error) {
            if (window.AdminToast) {
                AdminToast.error('<?= __('请求失败') ?>: ' + error.message);
            }
        });
    }

    function refreshStats() {
        fetch('<?= $this->getUrl("*/cachecleanup/getstats") ?>')
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    console.log('<?= __('缓存统计更新') ?>:', data.data);
                }
            })
            .catch(function(error) {
                console.error('<?= __('获取统计信息失败') ?>:', error);
            });
    }

    // 绑定事件
    document.getElementById('executeCleanupBtn').addEventListener('click', executeCleanup);
    document.getElementById('runCronTaskBtn').addEventListener('click', runCronTask);
    
    // 每30秒刷新一次统计信息
    setInterval(refreshStats, 30000);
})();
</script>
