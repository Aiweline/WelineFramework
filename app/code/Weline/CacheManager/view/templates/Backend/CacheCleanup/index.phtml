<script>
(function() {
    'use strict';
    
    var config = {
        executeCleanupUrl: '<?= $this->getBackendUrl("*/cachecleanup/execute-cleanup") ?>',
        runCronTaskUrl: '<?= $this->getBackendUrl("*/cachecleanup/run-cron-task") ?>',
        getStatsUrl: '<?= $this->getBackendUrl("*/cachecleanup/get-stats") ?>',
        clearTypeUrl: '<?= $this->getBackendUrl("*/cachecleanup/clear-type") ?>',
        texts: {
            confirmCleanup: '<?= __("确定要清理所有缓存吗？这将删除 var/cache 目录下的所有缓存文件和编译的模板文件。") ?>',
            confirmCron: '<?= __("确定要手动执行缓存清理定时任务吗？这将清理过期的缓存文件。") ?>',
            confirmClearType: '<?= __("确定要清理缓存类型：%{type} 吗？") ?>',
            cleaning: '<?= __("正在清理缓存，请稍候...") ?>',
            refreshing: '<?= __("正在刷新统计数据...") ?>',
            success: '<?= __("操作成功") ?>',
            error: '<?= __("操作失败") ?>'
        }
    };
    
    function executeCleanup() {
        BackendConfirm.show(config.texts.confirmCleanup, {
            title: '<?= __("清理缓存") ?>',
            type: 'warning',
            confirmText: '<?= __("确认清理") ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            BackendToast.info(config.texts.cleaning, 0);
            
            fetch(config.executeCleanupUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    BackendToast.success(data.message || config.texts.success);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(data.message || config.texts.error);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.texts.error + ': ' + error.message);
            });
        });
    }
    
    function runCronTask() {
        BackendConfirm.show(config.texts.confirmCron, {
            title: '<?= __("执行定时任务") ?>',
            type: 'info',
            confirmText: '<?= __("确认执行") ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            BackendToast.info(config.texts.cleaning, 0);
            
            fetch(config.runCronTaskUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    BackendToast.success(data.message || config.texts.success);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(data.message || config.texts.error);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.texts.error + ': ' + error.message);
            });
        });
    }
    
    function refreshStats() {
        BackendToast.info(config.texts.refreshing, 2000);
        
        fetch(config.getStatsUrl, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success && data.data) {
                document.getElementById('stat-total-files').textContent = data.data.total_files;
                document.getElementById('stat-total-size').textContent = data.data.total_size;
                document.getElementById('stat-expired-files').textContent = data.data.expired_files;
                document.getElementById('stat-expired-size').textContent = data.data.expired_size;
                BackendToast.success('<?= __("统计数据已刷新") ?>');
            } else {
                BackendToast.error(data.message || config.texts.error);
            }
        })
        .catch(function(error) {
            BackendToast.error(config.texts.error + ': ' + error.message);
        });
    }
    
    function clearCacheType(type, name) {
        var msg = config.texts.confirmClearType.replace('%{type}', name);
        
        BackendConfirm.show(msg, {
            title: '<?= __("清理缓存") ?>',
            type: 'danger',
            confirmText: '<?= __("确认清理") ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            BackendToast.info(config.texts.cleaning, 0);
            
            var formData = new FormData();
            formData.append('type', type);
            
            fetch(config.clearTypeUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    BackendToast.success(data.message || config.texts.success);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(data.message || config.texts.error);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.texts.error + ': ' + error.message);
            });
        });
    }
    
    function init() {
        var cleanupBtn = document.getElementById('weline-cache-cleanup-btn');
        if (cleanupBtn) {
            cleanupBtn.addEventListener('click', executeCleanup);
        }
        
        var cronBtn = document.getElementById('weline-cache-cron-btn');
        if (cronBtn) {
            cronBtn.addEventListener('click', runCronTask);
        }
        
        var refreshBtn = document.getElementById('weline-cache-refresh-btn');
        if (refreshBtn) {
            refreshBtn.addEventListener('click', refreshStats);
        }
        
        var clearTypeBtns = document.querySelectorAll('.weline-cache-clear-type-btn');
        clearTypeBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
                var type = this.getAttribute('data-type');
                var name = this.getAttribute('data-name');
                clearCacheType(type, name);
            });
        });
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
