<script>
(function() {
    'use strict';
    
    var statusUrl = '@admin-url("admin/system/cache/status")';
    var clearUrl = '@admin-url("admin/system/cache/clear")';
    var clearAllUrl = '@admin-url("admin/system/cache/clearAll")';
    
    function updateStats() {
        var rows = document.querySelectorAll('.weline-cache-table tbody tr');
        var enabled = 0;
        var disabled = 0;
        var permanent = 0;
        
        rows.forEach(function(row) {
            var isPermanent = row.dataset.permanent === '1';
            var switchEl = row.querySelector('.weline-cache-switch');
            var isEnabled = switchEl ? switchEl.checked : false;
            
            if (isPermanent) {
                permanent++;
                enabled++;
            } else if (isEnabled) {
                enabled++;
            } else {
                disabled++;
            }
        });
        
        var totalEl = document.getElementById('weline-cache-stat-total');
        var enabledEl = document.getElementById('weline-cache-stat-enabled');
        var disabledEl = document.getElementById('weline-cache-stat-disabled');
        var permanentEl = document.getElementById('weline-cache-stat-permanent');
        
        if (enabledEl) enabledEl.textContent = enabled;
        if (disabledEl) disabledEl.textContent = disabled;
        if (permanentEl) permanentEl.textContent = permanent;
    }
    
    function updateSwitch(input, isChecked) {
        var labelEl = input.parentElement.querySelector('.weline-cache-switch-label');
        if (labelEl) {
            labelEl.textContent = isChecked ? '<?= __("开启") ?>' : '<?= __("关闭") ?>';
            labelEl.className = 'weline-cache-switch-label ' + (isChecked ? 'weline-cache-switch-label--on' : 'weline-cache-switch-label--off');
        }
        var row = input.closest('tr');
        if (row) {
            row.dataset.status = isChecked ? '1' : '0';
        }
        updateStats();
    }
    
    function toggleCache(identity, value, input) {
        fetch(statusUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'identity=' + encodeURIComponent(identity) + '&cache=' + value
        })
        .then(function(response) { return response.json(); })
        .then(function(res) {
            if (res.code === 200) {
                input.checked = !!res.data;
                updateSwitch(input, !!res.data);
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.success('<?= __("缓存状态已更新") ?>');
                }
            } else {
                input.checked = !value;
                updateSwitch(input, !value);
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error(res.message || '<?= __("操作失败") ?>');
                }
            }
        })
        .catch(function(error) {
            input.checked = !value;
            updateSwitch(input, !value);
            if (typeof BackendToast !== 'undefined') {
                BackendToast.error('<?= __("请求失败") ?>');
            }
        });
    }
    
    document.querySelectorAll('.weline-cache-switch').forEach(function(input) {
        input.addEventListener('change', function(e) {
            var identity = this.id.replace('weline-cache-', '');
            toggleCache(identity, this.checked, this);
        });
    });
    
    var enableAllBtn = document.getElementById('weline-cache-enable-all');
    if (enableAllBtn) {
        enableAllBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show('<?= __("确定要启用所有非持久化缓存吗？") ?>', {
                    title: '<?= __("批量启用") ?>',
                    confirmText: '<?= __("确定") ?>',
                    cancelText: '<?= __("取消") ?>'
                }).then(function(confirmed) {
                    if (confirmed) {
                        batchToggle(true);
                    }
                });
            } else {
                batchToggle(true);
            }
        });
    }
    
    var disableAllBtn = document.getElementById('weline-cache-disable-all');
    if (disableAllBtn) {
        disableAllBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show('<?= __("确定要禁用所有非持久化缓存吗？这可能会影响系统性能。") ?>', {
                    title: '<?= __("批量禁用") ?>',
                    confirmText: '<?= __("确定") ?>',
                    cancelText: '<?= __("取消") ?>',
                    type: 'warning'
                }).then(function(confirmed) {
                    if (confirmed) {
                        batchToggle(false);
                    }
                });
            } else {
                batchToggle(false);
            }
        });
    }
    
    function batchToggle(enable) {
        var switches = document.querySelectorAll('.weline-cache-switch:not(:disabled)');
        var promises = [];
        var successCount = 0;
        var failCount = 0;
        
        switches.forEach(function(input) {
            if (input.checked !== enable) {
                var identity = input.id.replace('weline-cache-', '');
                promises.push(
                    fetch(statusUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'identity=' + encodeURIComponent(identity) + '&cache=' + enable
                    })
                    .then(function(response) { return response.json(); })
                    .then(function(res) {
                        if (res.code === 200) {
                            input.checked = !!res.data;
                            updateSwitch(input, !!res.data);
                            successCount++;
                        } else {
                            failCount++;
                        }
                    })
                    .catch(function() {
                        failCount++;
                    })
                );
            }
        });
        
        if (promises.length === 0) {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.info('<?= __("没有需要更改的缓存项") ?>');
            }
            return;
        }
        
        Promise.all(promises).then(function() {
            if (typeof BackendToast !== 'undefined') {
                if (failCount === 0) {
                    BackendToast.success('<?= __("成功更新") ?> ' + successCount + ' <?= __("个缓存项") ?>');
                } else {
                    BackendToast.warning('<?= __("成功") ?> ' + successCount + '<?= __(", 失败") ?> ' + failCount);
                }
            }
            updateStats();
        });
    }
    
    var refreshBtn = document.getElementById('weline-cache-refresh');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
            window.location.reload();
        });
    }
    
    var clearAllBtn = document.getElementById('weline-cache-clear-all');
    if (clearAllBtn) {
        clearAllBtn.addEventListener('click', function() {
            if (typeof BackendConfirm !== 'undefined') {
                BackendConfirm.show('<?= __("确定要清理所有缓存吗？这将清除所有非持久缓存数据。") ?>', {
                    title: '<?= __("清理缓存") ?>',
                    confirmText: '<?= __("清理") ?>',
                    cancelText: '<?= __("取消") ?>',
                    type: 'warning'
                }).then(function(confirmed) {
                    if (confirmed) {
                        clearAllCaches(false);
                    }
                });
            } else {
                clearAllCaches(false);
            }
        });
    }
    
    function clearAllCaches(force) {
        fetch(clearAllUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'force=' + (force ? '1' : '0')
        })
        .then(function(response) { return response.json(); })
        .then(function(res) {
            if (res.code === 200) {
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.success(res.msg || '<?= __("缓存已清理") ?>');
                }
            } else {
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error(res.msg || '<?= __("清理失败") ?>');
                }
            }
        })
        .catch(function(error) {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.error('<?= __("请求失败") ?>');
            }
        });
    }
    
    updateStats();
})();
</script>
