<?php
/**
 * 缓存管理页面（内容模板）
 *
 * @var \Weline\Framework\View\Template $this
 */
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= __('缓存管理') ?></h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);"><?= __('系统') ?></a></li>
                    <li class="breadcrumb-item active"><?= __('缓存管理') ?></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class='row'>
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title"><?= __('缓存控制器') ?>:
                    <lang>一共有</lang>
                    <var>total</var>
                    <lang>条数据</lang>
                </h4>

                <div class='table-responsive'>
                    <table class="table table-editable table-nowrap align-middle table-edits">
                        <thead>
                        <tr>
                            <th><lang>标志</lang></th>
                            <th><lang>说明</lang></th>
                            <th><lang>类型</lang></th>
                            <th><lang>模组</lang></th>
                            <th><lang>类</lang></th>
                            <th><lang>是否持久化</lang></th>
                            <th><?= __('操作') ?></th>
                        </tr>
                        </thead>
                        <tbody>
                        <foreach name="caches" item="cache">
                            <tr @if{$cache->getPermanently()=>"style='background:var(--backend-color-card-bg-secondary)'"}>
                                <td><var>$cache->getIdentity()</var></td>
                                <td><var>$cache->getDescription()</var></td>
                                <td><var>$cache->getType()?__('app'):__('system')</var></td>
                                <td><var>$cache->getModule()</var></td>
                                <td><var>$cache->getName()</var></td>
                                <td><var>$cache->getPermanently()?__('是'):__('否')</var></td>
                                <td style='width: 100px'>
                                    <input class='form-check form-switch weline-cache-switch' type='checkbox'
                                           alt="@php{echo $cache->isKeep()?__('系统持久缓存无法操作'):'状态开关'}"
                                           id='@var{$cache->getIdentity()}' switch='bool' @if{$cache->getPermanently()=>'checked
                                    disabled'} @if{$cache->getStatus()=>'checked'}>
                                    <label class='form-label' for='@var{$cache->getIdentity()}'
                                           data-on-label='<?= __('开启') ?>'
                                           data-off-label='<?= __('关闭') ?>'></label>
                                </td>
                            </tr>
                        </foreach>
                        </tbody>
                    </table>
                    <div>
                        <var>pagination</var>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    document.querySelectorAll('.weline-cache-switch').forEach(function(input) {
        input.addEventListener('change', function(e) {
            var id = this.id;
            var value = this.checked;
            var url = '@admin-url("admin/system/cache/status")';
            
            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'identity=' + encodeURIComponent(id) + '&cache=' + value
            })
            .then(function(response) { return response.json(); })
            .then(function(res) {
                if (res.code === 200) {
                    input.checked = res.data;
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.success('<?= __("缓存状态已更新") ?>');
                    }
                } else {
                    input.checked = !res.data;
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.error(res.message || '<?= __("操作失败") ?>');
                    }
                }
            })
            .catch(function(error) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error('<?= __("请求失败") ?>');
                }
            });
        });
    });
})();
</script>
