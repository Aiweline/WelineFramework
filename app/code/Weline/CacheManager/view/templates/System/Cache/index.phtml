$formatCount = static fn(mixed $value): string => \number_format((int)$value);
$formatPercent = static fn(mixed $value): string => \number_format((float)$value, 2) . '%';
$formatTtl = static function (mixed $value): string {
    $ttl = (int)$value;
    if ($ttl <= 0) {
        return (string)__('永久');
    }
    if ($ttl < 60) {
        return (string)__('约 %{1} 秒', $ttl);
    }
    if ($ttl < 3600) {
        return (string)__('约 %{1} 分钟', (int)\floor($ttl / 60));
    }
    if ($ttl < 86400) {
        return (string)__('约 %{1} 小时', (int)\floor($ttl / 3600));
    }
    return (string)__('约 %{1} 天', (int)\floor($ttl / 86400));
};
$formatBytes = static function (mixed $value): string {
    $size = (float)$value;
    if ($size <= 0) {
        return '0 B';
    }
    $units = ['B', 'KB', 'MB', 'GB', 'TB'];
    $index = 0;
    while ($size >= 1024 && $index < \count($units) - 1) {
        $size /= 1024;
        $index++;
    }
    return \number_format($size, $index === 0 ? 0 : 1) . ' ' . $units[$index];
};

