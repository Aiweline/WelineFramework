<script>
    (function () {
        var form = document.getElementById('cache-policy-form');
        var button = document.getElementById('cache-policy-submit');
        var message = document.getElementById('cache-policy-message');
        if (!form || !button || !message) {
            return;
        }
        form.addEventListener('submit', function (event) {
            event.preventDefault();
            button.disabled = true;
            message.className = 'cache-policy-message';
            message.textContent = '<?= __('正在保存...') ?>';
            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                credentials: 'same-origin',
                headers: {'X-Requested-With': 'XMLHttpRequest'}
            }).then(function (response) {
                return response.json();
            }).then(function (payload) {
                if (!payload || Number(payload.code) !== 200) {
                    throw new Error(payload && payload.msg ? payload.msg : '<?= __('保存失败') ?>');
                }
                message.textContent = payload.msg || '<?= __('保存成功') ?>';
            }).catch(function (error) {
                message.className = 'cache-policy-message is-error';
                message.textContent = error && error.message ? error.message : '<?= __('保存失败') ?>';
            }).finally(function () {
                button.disabled = false;
            });
        });
    })();
</script>
