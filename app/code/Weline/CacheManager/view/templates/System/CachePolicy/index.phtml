$config = \is_array($config ?? null) ? $config : [];
$defaults = \is_array($defaults ?? null) ? $defaults : [];

$value = static function (array $data, string $path, mixed $fallback = ''): mixed {
    $cursor = $data;
    foreach (\explode('.', $path) as $segment) {
        if (!\is_array($cursor) || !\array_key_exists($segment, $cursor)) {
            return $fallback;
        }
        $cursor = $cursor[$segment];
    }

    return $cursor;
};

$field = function (string $path, string $label, string $unit, string $help, string $step = '1') use ($config, $defaults, $value): void {
    $name = 'config[' . \str_replace('.', '][', $path) . ']';
    $id = 'cache-policy-' . \str_replace(['.', '_'], '-', $path);
    $current = $value($config, $path, $value($defaults, $path, ''));
    $default = $value($defaults, $path, '');
    ?>
    <div class="cache-policy-field">
        <label for="<?= htmlspecialchars($id) ?>"><?= __($label) ?></label>
        <div class="cache-policy-input-row">
            <input id="<?= htmlspecialchars($id) ?>" type="number" min="0" step="<?= htmlspecialchars($step) ?>"
                   name="<?= htmlspecialchars($name) ?>" value="<?= htmlspecialchars((string)$current) ?>">
            <span><?= __($unit) ?></span>
        </div>
        <p><?= __($help) ?> <?= __('默认值：%{1}', $default) ?></p>
    </div>
    <?php
};

