<css>jquery-ui.min.css</css>
<js>jquery-ui.min.js</js>
<script defer>
    $(function () {
        let can_run = true
        if (!window.debounce) {
            console.error('@lang{w-check: debounce method is missing.}')
            can_run = false;
        }
        if (!$) {
            console.error('@lang{w-check: jQuery is missing.}')
            can_run = false;
        }
        if (!can_run) {
            return
        }

        const welineJsonRequest = function (url) {
            if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.request !== 'function') {
                return Promise.reject(new Error('Weline.Api.request is unavailable.'));
            }
            return Promise.resolve(window.Weline.Api.request(url, {
                method: 'GET',
                headers: {'Accept': 'application/json'},
                silent: true
            })).then(function (res) {
                if (res && typeof res.json === 'function') {
                    return res.json();
                }
                return res;
            });
        };

        $('[w-check="true"]').each(function () {
            let checkInput = $(this)
            let url = checkInput.attr('w-check-url') ?? checkInput.attr('w-url') ?? '';
            let type = checkInput.attr('w-check-type') ?? '';
            if (!type) {
                confirm('@lang{w-check: w-check-type is required.}')
                return
            }
            let field = checkInput.attr('w-check-field') ?? 'name';
            let id = checkInput.attr('w-check-id') ?? '';
            let id_field = checkInput.attr('w-check-id-field') ?? '';
            if (!id_field) {
                console.info(checkInput)
                confirm('@lang{w-check: w-check-id-field is required.}')
                return
            }
            let invalid_class = checkInput.attr('w-invalid-class') ?? 'is-invalid';
            let valid_class = checkInput.attr('w-valid-class') ?? 'is-valid';
            if (!url) {
                console.log('w-check @lang{element w-url is missing.}')
                return
            }
            checkInput.change(debounce(function () {
                let input = $(this)
                if(!input.val() && input.attr('required')){
                    input.removeClass(valid_class).addClass(invalid_class);
                    return
                }
                welineJsonRequest(url + "?q=" + encodeURIComponent(input.val())).then(function (data) {
                    data = Array.isArray(data) ? data : [];
                    if (type === 'unique') {
                        for (let i = 0; i < data.length; i++) {
                            if (data[i][field] === input.val()) {
                                if(id != data[i][id_field]){
                                    input.removeClass(valid_class).addClass(invalid_class);
                                    return
                                }
                                input.removeClass(id ? invalid_class : valid_class).addClass(id ? valid_class : invalid_class);
                                return
                            }
                        }
                        input.removeClass(invalid_class).addClass(valid_class);
                    } else {
                        for (let i = 0; i < data.length; i++) {
                            const currentValue = data[i] && data[i][field] ? String(data[i][field]) : '';
                            if (currentValue.indexOf(input.val()) !== -1 ) {
                                if(id != data[i][id_field]){
                                    input.removeClass(valid_class).addClass(invalid_class);
                                    return
                                }
                                input.removeClass(id ? invalid_class : valid_class).addClass(id ? valid_class : invalid_class);
                                return
                            }
                        }
                        input.removeClass(id ? invalid_class : valid_class).addClass(id ? valid_class : invalid_class);
                    }
                }).catch(function () {
                    input.removeClass(valid_class).addClass(invalid_class);
                });
            }, 500));
        });
    })
</script>
