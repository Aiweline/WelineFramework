<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- Feed条目添加事件 -->
    <event name="Weline_Geo::feed_item_add">
        <observer name="Weline_Geo::feed_item_add_observer" 
                  instance="Weline\Geo\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- Feed条目更新事件 -->
    <event name="Weline_Geo::feed_item_update">
        <observer name="Weline_Geo::feed_item_update_observer" 
                  instance="Weline\Geo\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- Feed条目删除事件 -->
    <event name="Weline_Geo::feed_item_delete">
        <observer name="Weline_Geo::feed_item_delete_observer" 
                  instance="Weline\Geo\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>

    <!-- GEO 统一 feed 提交入口 -->
    <event name="Weline_Geo::integration::feed_submit_request">
        <observer name="Weline_Geo::feed_submit_request" 
                  instance="Weline\Geo\Observer\FeedSubmitRequest" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>

    <!-- 复用 SEO URL 提交流：新 URL 自动同步到 GEO feed -->
    <event name="Weline_Seo::integration::url_submit_request">
        <observer name="Weline_Geo::seo_url_submit_to_geo" 
                  instance="Weline\Geo\Observer\SeoUrlSubmitObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="20"/>
    </event>

    <!-- 根协议文件：/llms.txt、/llms-full.txt、/geo-feed.json、/geo-feed.xml -->
    <event name="Weline_Websites::website_save_after">
        <observer name="Weline_Geo::website_save_after" 
                  instance="Weline\Geo\Observer\WebsiteSaveAfter" 
                  disabled="false" 
                  shared="true" 
                  sort="30"/>
    </event>

    <event name="Weline_Framework_Router::process_uri_before">
        <observer name="Weline_Geo::protocol_route_rewrite" 
                  instance="Weline\Geo\Observer\ProtocolRouteRewrite" 
                  disabled="false" 
                  shared="true" 
                  sort="-90"/>
    </event>
</config>
