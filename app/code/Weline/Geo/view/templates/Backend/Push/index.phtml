<?php
/**
 * @var \Weline\Framework\View\Template $this
 * @var \Weline\Framework\DataObject\DataObject $logs
 * @var \Weline\Framework\DataObject\DataObject $pagination
 */
?>
<div class="content-header">
    <h1><?= __('推送历史') ?></h1>
    <div class="action-bar">
        <a href="<?= $this->getUrl('geo/backend/push/push') ?>" class="btn btn-primary">
            <i class="mdi mdi-send"></i> <?= __('一键推送') ?>
        </a>
    </div>
</div>

<div class="content-body">
    <table class="table table-striped">
        <thead>
            <tr>
                <th><?= __('ID') ?></th>
                <th><?= __('Feed ID') ?></th>
                <th><?= __('平台 ID') ?></th>
                <th><?= __('推送类型') ?></th>
                <th><?= __('状态') ?></th>
                <th><?= __('条目数') ?></th>
                <th><?= __('推送时间') ?></th>
                <th><?= __('操作') ?></th>
            </tr>
        </thead>
        <tbody>
            <?php if (empty($logs)): ?>
                <tr>
                    <td colspan="8" class="text-center"><?= __('暂无数据') ?></td>
                </tr>
            <?php else: ?>
                <?php foreach ($logs as $log): ?>
                    <tr>
                        <td><?= $log['id'] ?></td>
                        <td><?= $log['feed_id'] ?></td>
                        <td><?= $log['platform_id'] ?></td>
                        <td><?= htmlspecialchars($log['push_type']) ?></td>
                        <td>
                            <?php if ($log['status'] === 'success'): ?>
                                <span class="badge badge-success"><?= __('成功') ?></span>
                            <?php elseif ($log['status'] === 'failed'): ?>
                                <span class="badge badge-danger"><?= __('失败') ?></span>
                            <?php else: ?>
                                <span class="badge badge-warning"><?= __('待处理') ?></span>
                            <?php endif; ?>
                        </td>
                        <td><?= $log['items_count'] ?></td>
                        <td><?= $log['pushed_at'] ? date('Y-m-d H:i:s', $log['pushed_at']) : '-' ?></td>
                        <td>
                            <?php if ($log['error_message']): ?>
                                <button class="btn btn-sm btn-danger" onclick="if(typeof Swal!=='undefined'){Swal.fire({icon:'error',title:'<?= __('错误信息') ?>',text:'<?= htmlspecialchars(addslashes($log['error_message'])) ?>',confirmButtonText:'<?= __('确定') ?>'});}else{console.error('<?= htmlspecialchars(addslashes($log['error_message'])) ?>');}">
                                    <i class="mdi mdi-alert"></i> <?= __('查看错误') ?>
                                </button>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
            <?php endif; ?>
        </tbody>
    </table>

    <?php if ($pagination && $pagination->getTotalPages() > 1): ?>
        <div class="pagination">
            <?= $this->getPaginationHtml($pagination) ?>
        </div>
    <?php endif; ?>
</div>

