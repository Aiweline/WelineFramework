<js:part>
(function() {
    'use strict';
    
    var form = $('#set-edit');
    
    form.on('submit', function(event) {
        event.preventDefault();
        var action = form.attr('action');
        $.post(action, form.serializeArray(), function (data) {
            if (data['id']) {
                Swal.fire({
                    icon: 'success',
                    title: data.msg,
                    confirmButtonText: '@lang{好的}',
                }).then(function(){
                    window.parent.location.reload();
                });
            } else if (data['msg']) {
                Swal.fire({
                    icon: 'error',
                    title: '@lang{修改通知}',
                    text: data.msg,
                    confirmButtonText: '@lang{好的}',
                });
            }
        });
    });
})();
</js:part>
