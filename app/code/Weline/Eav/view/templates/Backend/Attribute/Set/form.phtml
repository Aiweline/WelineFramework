                                    <lang>填写正确！</lang>
                                </div>
                            </div>
                        </div>
                        <div class='col-md-4'>
                            <div class='mb-3'>
                                <label class='form-label' for='validationCode'>
                                    <lang>属性集代码</lang>
                                </label>
                                <input type='text' class='form-control' maxlength='60' data-parsley-minlength='3'
                                       id='validationCode' placeholder='@lang{属性集代码}'
