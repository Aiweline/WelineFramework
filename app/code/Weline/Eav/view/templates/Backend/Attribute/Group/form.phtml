<js:part>
(function() {
    'use strict';
    
    var validationEntity = $('#validationEntity');
    var validationSet = $('#validationSet');
    
    validationEntity.change(function () {
        var selectedOption = $(this).find(':selected').val();
        renderAttributeSet(selectedOption);
    });
    
    var initSelected = validationEntity.find(':selected').val();
    if(!validationSet.find(':selected').val()){
        renderAttributeSet(initSelected);
    }

    function renderAttributeSet(eav_entity_id) {
        $.get("@backend-url('*/backend/attribute/set/api-search')?eav_entity_id=" + eav_entity_id).then(function(res) {
            var items = res['items'];
            validationSet.empty();
            for (var itemsKey in items) {
                var item = items[itemsKey];
                var selected = '';
                if (validationSet.attr('data-selected') === item.set_id) {
                    selected = 'selected';
                }
                validationSet.append("<option value='" + item.set_id + "' " + selected + ">" + window.lang(item.name) + "</option>");
            }
        });
    }
})();
</js:part>
