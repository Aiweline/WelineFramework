                                                class="text-danger"><lang>（双击选中图片）最大支持100kb</lang></span>
                                    </h5>
                                    <button type="button" data-bs-dismiss="modal" aria-label="Close"
                                            class="btn-close"></button>
                                </div>
                                <div class="modal-body">
                                    <iframe class="w-100 h-100"
                                            src="@file-manager-connector{target='#callBackImg' close='#closeImgModel' path='media/store/logo/' multi='0' ext='png,jpeg,jpg,webp,svg,ico' size='102400'}"
                                            frameborder="0"></iframe>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary waves-effect"
                                            @click="closeImgModel">
                                        <lang>关闭</lang>
                                    </button>
                                    <button type="button" data-bs-dismiss="modal" id="closeImgModel"
                                            class="btn btn-primary waves-effect waves-light" @click="closeImgModel">
                                        <lang>确定</lang>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div v-if="(activeName=='progress-attribute-details'&&params.data_has_option!=1)||activeName=='progress-attribute-option'">
                    <button class="btn btn-primary pull-right" @click="submitAttr">
                        <lang>提交</lang>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<js:part name="debounce"/>
<js:part>
(function() {
    'use strict';
    
    window.AttributePage = new Vue({
        el: '#AttributePage',
        data: {
            chooseImgModel: false,
            params: {
                attribute_id: '{{attribute.attribute_id}}',
                eav_entity_id: '{{attribute.eav_entity_id}}',
                set_id: '{{attribute.set_id}}',
                group_id: '{{attribute.group_id}}',
                code: '{{attribute.code}}',
                name: '{{attribute.name}}',
                type_id: '{{attribute.type_id|0}}',
                basic_is_enable: '{{attribute.basic_is_enable|1}}',
                data_has_option: '{{attribute.data_has_option|0}}',
                is_system: '{{attribute.is_system|0}}',
                data_is_multiple: '{{attribute.data_is_multiple|0}}'
            },
            addParams: {
                option_id: 0,
                value: '',
                code: '',
                swatch_color: '',
                swatch_image: '',
                swatch_text: ''
            },
            stopable: 0,
            EntitiesVal: '',
            entityNameGroup: '',
            entityGroup: '',
            entities: <?= isset($entities) ? json_encode($entities) : '[]' ?>,
            sets: [],
            groups: [],
            types: <?= isset($types) ? json_encode($types) : '[]' ?>,
            activeName: '{{attribute.progress|"progress-select-entity"}}',
            tableData: <?= isset($attribute['options']) ? json_encode($attribute['options']) : '[]' ?>,
            activeAttrItem: {
                swatch_color: 0,
                swatch_image: 0,
                swatch_text: 0
            },
            offRow: '',
            EditIndex: 0,
            totalOptions: 0
        },
        mounted: function() {
            var self = this;
            this.activeName = '{{attribute.progress|"progress-select-entity"}}';
            if (this.params.eav_entity_id) {
                this.renderSearchEntityAttributeSet();
            }
            if (this.params.set_id) {
                this.renderSearchEntityAttributeSetGroup();
            }
            if ('{{entity_type}}' && '{{entity_type}}' !== '') {
                var entity = this.entities.find(function(e) { return e.code === '{{entity_type}}'; });
                if (entity) {
                    this.params.eav_entity_id = entity.eav_entity_id;
                    this.renderSearchEntityAttributeSet();
                }
                this.activeName = 'progress-select-set';
                this.$nextTick(function() {
                    $(".twitter-bs-wizard-nav li").eq(0).addClass('disabled').css({'pointer-events':'none','opacity':0.5});
                });
            }
            for (var i = 0; i < this.types.length; i++) {
                var type = this.types[i];
                if (type.type_id == this.params.type_id && type.is_swatch == 1) {
                    this.stopable = 1;
                    this.activeAttrItem.swatch_color = type.swatch_color;
                    this.activeAttrItem.swatch_image = type.swatch_image;
                    this.activeAttrItem.swatch_text = type.swatch_text;
                }
            }
        },
        methods: {
            submitAttr: function() {
                var self = this;
                if (!this.params.name) {
                    Swal.fire({
                        title: '@lang{请先创建属性名再操作！}',
                        text: '@lang{当前属性名为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-attribute-details';
                        }
                    });
                    return false;
                }
                if (!this.params.code) {
                    Swal.fire({
                        title: '@lang{请先创建属性再操作！}',
                        text: '@lang{当前属性代码为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-attribute-details';
                        }
                    });
                    return false;
                }
                if (!this.params.type_id) {
                    Swal.fire({
                        title: '@lang{请先选择属性类型再操作！}',
                        text: '@lang{当前属性类型为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-attribute-details';
                            $('.btn-close').click();
                        }
                    });
                    return false;
                }
                if (!this.params.eav_entity_id) {
                    Swal.fire({
                        title: '@lang{请先选择实体再操作！}',
                        text: '@lang{当前实体为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-entity';
                        }
                    });
                    return false;
                }
                if (!this.params.set_id) {
                    Swal.fire({
                        title: '@lang{请先创建属性集再操作！}',
                        text: '@lang{当前属性集代码为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-set';
                        }
                    });
                    return false;
                }
                if (!this.params.group_id) {
                    Swal.fire({
                        title: '@lang{请先创建属性组再操作！}',
                        text: '@lang{当前属性组代码为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-group';
                        }
                    });
                    return false;
                }
                console.log(this.params, '@lang{获取已填写数据}', this.tableData, '@lang{第5部分的数据}');
                $.ajax({
                    type: 'POST',
                    url: "@backend-url('*/backend/attribute/save')",
                    data: {
                        'base': this.params,
                        'option': this.tableData
                    },
                    success: function (res) {
                        if (res.code == 0) {
                            Swal.fire({
                                title: res.msg,
                                icon: 'success',
                                confirmButtonText: '@lang{好的}'
                            }).then(function(result) {
                                if (result.isConfirmed) {
                                    showLoading();
                                    window.parent.location.reload();
                                }
                            });
                        }
                    }
                });
            },
            closeImgModel: function() {
                console.log($('#callBackImg').val(), '图片回显的值');
                this.chooseImgModel = false;
                this.addParams.swatch_image = decodeURIComponent($('#callBackImg').val());
                this.offRow = '';
            },
            debounceChange: debounce(function (code, eav_entity_id, set_id, group_id) {
                var self = this;
                if (!eav_entity_id) {
                    Swal.fire({
                        title: '@lang{请先选择实体再操作！}',
                        text: '@lang{当前实体为空！无法创建属性！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-select-entity';
                        }
                    });
                    return false;
                }
                if (!set_id) {
                    Swal.fire({
                        title: '@lang{请先创建属性集再操作！}',
                        text: '@lang{当前属性集代码为空！无法创建属性！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-select-set';
                        }
                    });
                    return false;
                }
                if (!group_id) {
                    Swal.fire({
                        title: '@lang{请先选择属性组再操作！}',
                        text: '@lang{当前属性组代码为空！无法创建属性！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-select-group';
                        }
                    });
                    return false;
                }
                $.ajax({
                    type: "get",
                    url: '@backend-url("*/backend/attribute/search")?field=code&limit=1&search=' + code + '&eav_entity_id=' + eav_entity_id + '&set_id=' + set_id + '&group_id=' + group_id,
                    dataType: "json",
                    success: function(res) {
                        if (res.items.length > 0) {
                            Swal.fire({
                                title: '@lang{属性已存在！}',
                                text: '@lang{该属性已存在！}',
                                icon: 'warning',
                                confirmButtonText: '@lang{好的}'
                            }).then(function (result) {
                                if (result.isConfirmed) {
                                    $('#progress-attribute-code').css({border: 'red 1px solid'});
                                }
                            });
                        } else {
                            $('#progress-attribute-code').css({border: 'green 1px solid'});
                        }
                    },
                    error: function(res) {
                        console.log(res);
                    }
                });
            }, 500),
            debounceSaveType: debounce(function (type) {
                var data_has_option = 0;
                if (type.is_swatch == 1) {
                    data_has_option = 1;
                    this.params.data_has_option = data_has_option;
                }
                $.ajax({
                    type: "post",
                    url: "@backend-url('backend/user-data')",
                    dataType: "json",
                    data: {
                        scope: 'attribute',
                        name: 'data_has_option',
                        value: data_has_option
                    },
                    success: function(res) {},
                    error: function(res) {
                        console.log(res, '保存失败');
                    }
                });
            }, 500),
            checkCode: function(e) {
                this.debounceChange(this.params.code, this.params.eav_entity_id, this.params.set_id, this.params.group_id);
            },
            editRow: function(row, index) {
                var self = this;
                $('#addOption').click();
                if (this.activeAttrItem.swatch_color) {
                    $('#swatch_color_picker').colorpicker();
                    $('#swatch_color_picker').on('change', function(event) {
                        self.addParams.swatch_color = event.value;
                    });
                }
                this.addParams = JSON.parse(JSON.stringify(row));
                this.offRow = row;
                this.EditIndex = index;
            },
            deleteRow: function(row, index) {
                var self = this;
                Swal.fire({
                    title: '@lang{提示}',
                    text: '@lang{确认删除当前列吗？}',
                    icon: 'info',
                    confirmButtonText: '@lang{确定}',
                    cancelButtonText: '@lang{取消}',
                    showConfirmButton: true,
                    showCancelButton: true
                }).then(function(result) {
                    if (result.isConfirmed) {
                        self.tableData.splice(index, 1);
                        if (row.option_id) {
                            $.ajax({
                                type: "post",
                                url: "@backend-url('*/backend/attribute/option/delete')",
                                data: {
                                    id: row.option_id
                                },
                                dataType: "json"
                            });
                        }
                    }
                });
            },
            showAddOff: function() {
                var self = this;
                console.log('监听点击了显示添加弹窗');
                this.addParams = {
                    value: '',
                    code: '',
                    swatch_color: '',
                    swatch_image: '',
                    swatch_text: ''
                };
                if (this.activeAttrItem.swatch_color) {
                    $('#swatch_color_picker').colorpicker();
                    $('#swatch_color_picker').on('change', function(event) {
                        self.addParams.swatch_color = event.value;
                    });
                }
                this.offRow = '';
            },
            addRow: function() {
                var self = this;
                if (!this.stopable) {
                    Swal.fire({
                        title: '@lang{请先选择属性类型再操作！}',
                        text: '@lang{当前属性类型为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-attribute-details';
                            $('.btn-close').click();
                        }
                    });
                    return false;
                }
                if (!this.params.eav_entity_id) {
                    Swal.fire({
                        title: '@lang{请先选择实体再操作！}',
                        text: '@lang{当前实体为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-entity';
                        }
                    });
                    return false;
                }
                if (!this.params.set_id) {
                    Swal.fire({
                        title: '@lang{请先创建属性集再操作！}',
                        text: '@lang{当前属性集代码为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-set';
                        }
                    });
                    return false;
                }
                if (!this.params.group_id) {
                    Swal.fire({
                        title: '@lang{请先创建属性组再操作！}',
                        text: '@lang{当前属性组代码为空！无法创建属性配置项！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $('.btn-close').click();
                            self.activeName = 'progress-select-group';
                        }
                    });
                    return false;
                }
                if (!this.addParams.value || !this.addParams.code) {
                    Swal.fire({
                        title: '@lang{请先填写配置项和代码再操作！}',
                        text: '@lang{当前属性配置项或代码为空！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    });
                    return false;
                }
                if (this.activeAttrItem.swatch_color && !this.addParams.swatch_color) {
                    Swal.fire({
                        title: '@lang{请先选择颜色再操作！}',
                        text: '@lang{当前属性颜色为空！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    });
                    return false;
                }
                if (this.activeAttrItem.swatch_image && !this.addParams.swatch_image) {
                    Swal.fire({
                        title: '@lang{请先选择图片再操作！}',
                        text: '@lang{当前属性图片为空！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    });
                    return false;
                }
                if (this.activeAttrItem.swatch_text && !this.addParams.swatch_text) {
                    Swal.fire({
                        title: '@lang{请先填写文本再操作！}',
                        text: '@lang{当前属性文本为空！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    });
                    return false;
                }
                var params = JSON.parse(JSON.stringify(this.addParams));
                if (this.offRow) {
                    params.update_time = new Date().toLocaleString();
                    this.tableData.splice(this.EditIndex, 1, params);
                } else {
                    params.create_time = new Date().toLocaleString();
                    params.update_time = new Date().toLocaleString();
                    this.tableData.push(params);
                }
                $('.btn-close').click();
            },
            renderSearchEntities: function(e) {
                var self = this;
                $.ajax({
                    url: '@backend-url("*/backend/entity/search")?search=' + this.EntitiesVal,
                    success: function(res) {
                        self.entities = res['items'];
                        self.EntitiesVal = '';
                    }
                });
            },
            renderSearchEntityAttributeSet: function(e) {
                var self = this;
                $.ajax({
                    url: '@backend-url("*/backend/attribute/set/search")?search=' + this.entityGroup + '&eav_entity_id=' +
                        this.params.eav_entity_id,
                    success: function(res) {
                        if (res['msg']) {
                            Swal.fire({
                                title: '警告！',
                                text: res['msg'],
                                icon: 'error',
                                dangerMode: true,
                                confirmButtonText: '@lang{好的}'
                            });
                            return false;
                        }
                        self.sets = res['items'];
                        self.entityGroup = '';
                    }
                });
            },
            renderSearchEntityAttributeSetGroup: function(e) {
                var self = this;
                $.ajax({
                    url: '@backend-url("*/backend/attribute/group/search")?search=' + this.entityNameGroup +
                        '&eav_entity_id=' + this.params.eav_entity_id + '&set_id=' + this.params.set_id,
                    success: function(res) {
                        if (res['msg']) {
                            Swal.fire({
                                title: '警告！',
                                text: res['msg'],
                                icon: 'error',
                                dangerMode: true,
                                confirmButtonText: '@lang{好的}'
                            });
                            return false;
                        }
                        self.groups = res['items'];
                        self.entityNameGroup = '';
                    }
                });
            },
            findLabel: function(arr, id, key, name) {
                var label = '';
                arr.forEach(function(item) {
                    if (item[key] == id) {
                        label = item[name];
                    }
                });
                return label;
            },
            changeType: function(arr, id) {
                var self = this;
                var find_item = {};
                arr.forEach(function(item) {
                    if (item.type_id == Number(id)) {
                        self.params.data_has_option = item.is_swatch;
                        self.stopable = item.is_swatch;
                        find_item = item;
                    }
                });
                this.debounceSaveType(find_item);
                this.activeAttrItem = find_item;
                console.log(find_item);
            },
            changeNav: function(name) {
                this.activeName = name;
                console.log(this.activeName);
                if (this.params.eav_entity_id) {
                    this.renderSearchEntityAttributeSet();
                }
                if (this.params.set_id) {
                    this.renderSearchEntityAttributeSetGroup();
                }
            }
        }
    });
})();
</js:part>
<w:scope url="@backend-url('backend/user-data')" container-id="product" event="input change click"/>

<style>
.input-group-addon {
    display: inline-block;
    width: 40px;
    height: 38px;
    border: 1px solid #ced4da;
    border-radius: 4px;
}
</style>
