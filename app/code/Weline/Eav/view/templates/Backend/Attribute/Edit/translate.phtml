<js:part>
(function() {
    'use strict';
    
    var attributeOptions = $('#attributeOptions');
    var offcanvasOptionAdd = $('#offcanvasOptionAdd');
    
    var getAllOptionCodesData = function () {
        var data = [];
        attributeOptions.find('tr[data-id]').each(function (index, el) {
            data.push({
                code: $(el).attr('data-id'),
                name: $(el).find("td[data-field='name']").text(),
                update_time: $(el).find("td[data-field='update_time']").text(),
                create_time: $(el).find("td[data-field='create_time']").text()
            });
        });
        return data;
    };

    var renderEditTable = function() {
        var editTable = $('.table-edits tr');
        editTable.off();
        var pickers = {};
        editTable.editable({
            edit: function (values) {
                $('.edit i', this)
                    .removeClass('fa-pencil-alt')
                    .addClass('fa-save')
                    .attr('title', '@lang{保存}');
            },
            save: function (values) {
                $('.edit i', this)
                    .removeClass('fa-save')
                    .addClass('fa-pencil-alt')
                    .attr('title', '@lang{编辑}');

                if (this in pickers) {
                    pickers[this].destroy();
                    delete pickers[this];
                }
                var dataTr = $(this);
                console.log('使用ajax将配置项保存到数据库');
                console.log(dataTr);
                var editData = Object.assign({}, values, {
                    attribute_code:'{{attribute.code}}',
                    eav_entity_id:'{{attribute.eav_entity_id}}',
                    origin_code:dataTr.attr('data-id')
                });
                var editUrl = '@backend-url("*/backend/attribute/option/edit")';
                var editBody = Object.keys(editData).map(function(k){ return encodeURIComponent(k)+'='+encodeURIComponent(editData[k]); }).join('&');
                var req = window.Weline.Api.request(editUrl, { method: 'POST', headers: {'Content-Type': 'application/x-www-form-urlencoded'}, body: editBody });
                req.then(function(res) {
                    var data = (res && res.data) || res;
                    if(data && data['code']===1){
                            Swal.fire({
                                title: '@lang{修改提示}',
                                text: data['msg'],
                                icon:'success',
                                confirmButtonColor: '#3085d6',
                                confirmButtonText: '@lang{好的}'
                            });
                        }else{
                            Swal.fire({
                                title: '@lang{编辑提示}',
                                text: data['msg'],
                                icon:'error',
                                confirmButtonColor: '#d33',
                                confirmButtonText: '@lang{重试}'
                            });
                        }
                }).catch(function() {});
            },
            cancel: function (values) {
                $('.edit i', this)
                    .removeClass('fa-save')
                    .addClass('fa-pencil-alt')
                    .attr('title', '@lang{编辑}');

                if (this in pickers) {
                    pickers[this].destroy();
                    delete pickers[this];
                }
            }
        });
    };
    renderEditTable();

    var editRowEvent = function (event) {
        attributeOptions.find('a.delete').off();
        attributeOptions.find('a.delete').on('click', function(e) {
            var target = $(e.currentTarget);
            var parent = target.parent().parent();
            Swal.fire({
                title: '@lang{通知}',
                text: '@lang{你确定要删除这个配置项么?}',
                icon: 'warning',
                confirmButtonText: '@lang{好的}',
                cancelButtonText: '@lang{取消}',
                showCancelButton: true
            }).then(function (result) {
                if (result.isConfirmed) {
                    var delData = {code: parent.attr('data-id'), attribute_code: '{{attribute.code}}', eav_entity_id: '{{attribute.eav_entity_id}}'};
                    var delBody = Object.keys(delData).map(function(k){ return encodeURIComponent(k)+'='+encodeURIComponent(delData[k]); }).join('&');
                    var delUrl = '@backend-url("*/backend/attribute/option/delete")?isAjax=1';
                    var req = window.Weline.Api.request(delUrl, { method: 'POST', headers: {'Content-Type': 'application/x-www-form-urlencoded'}, body: delBody });
                    req.then(function (res) {
                        var result = (res && res.data) || res;
                        if (result && result.code === 1) {
                                Swal.fire({
                                    title: '@lang{通知}',
                                    text: result.msg,
                                    icon: 'success',
                                    confirmButtonText: '@lang{好的}'
                                });
                                parent.remove();
                            } else if (result.code === 0) {
                                Swal.fire({
                                    title: '@lang{通知}',
                                    text: result.msg,
                                    icon: 'warning',
                                    confirmButtonText: '@lang{好的}'
                                });
                            }
                    }).catch(function() {});
                }
            });
            renderEditTable();
        });
    };
    editRowEvent();

    var debounce = function(func, delay) {
        var timeoutId;
        return function () {
            var args = arguments;
            var context = this;
            if (timeoutId) {
                clearTimeout(timeoutId);
            }
            timeoutId = setTimeout(function() {
                func.apply(context, args);
                timeoutId = null;
            }, delay);
        };
    };

    var throttle = function(func, delay) {
        var timeoutId;
        var lastExecTime = 0;
        return function () {
            var args = arguments;
            var context = this;
            var elapsedTime = new Date().getTime() - lastExecTime;
            if (elapsedTime > delay) {
                lastExecTime = new Date().getTime();
                func.apply(context, args);
            } else {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function() {
                    lastExecTime = new Date().getTime();
                    func.apply(context, args);
                    timeoutId = null;
                }, delay - elapsedTime);
            }
        };
    };

    var codeInput = offcanvasOptionAdd.find('#option-code');
    var nameInput = offcanvasOptionAdd.find('#option-name');
    
    var debounceInputOptionCode = debounce(function(e) {
        var search = $(e.target).val();
        var url = '@backend-url("*/backend/attribute/option/search")?field=code&limit=1&search=' + encodeURIComponent(search) + '&eav_entity_id={{attribute.eav_entity_id}}&attribute_code={{attribute.code}}';
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function (res) {
            var resData = (res && res.data) || res;
            if (resData && resData['msg']) {
                    Swal.fire({
                        title: '警告！',
                        text: res['msg'],
                        icon: 'error',
                        dangerMode: true,
                        confirmButtonText: '@lang{好的}'
                    });
                    return;
                }
                var items = (resData && resData['items']) || [];
                if (items.length) {
                    codeInput.removeClass('border-success');
                    codeInput.addClass('border-danger');
                } else {
                    codeInput.removeClass('border-danger');
                    codeInput.addClass('border-success');
                }
        }).catch(function() {});
    }, 500);
    codeInput.on('input', debounceInputOptionCode);
    
    var debounceInputOptionName = debounce(function(e) {
        var search = $(e.target).val();
        var url = '@backend-url("*/backend/attribute/option/search")?field=name&limit=1&search=' + encodeURIComponent(search) + '&eav_entity_id={{attribute.eav_entity_id}}&attribute_code={{attribute.code}}';
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function (res) {
            var resData = (res && res.data) || res;
            if (resData && resData['msg']) {
                    Swal.fire({
                        title: '警告！',
                        text: res['msg'],
                        icon: 'error',
                        dangerMode: true,
                        confirmButtonText: '@lang{好的}'
                    });
                    return;
                }
                var items = (resData && resData['items']) || [];
                if (items.length) {
                    nameInput.removeClass('border-success');
                    nameInput.addClass('border-danger');
                } else {
                    nameInput.removeClass('border-danger');
                    nameInput.addClass('border-success');
                }
        }).catch(function() {});
    }, 500);
    nameInput.on('input', debounceInputOptionName);

    $('#btn-add-row').on('click', function(event) {
        event.preventDefault();
        var code = offcanvasOptionAdd.find('#option-code').val();
        var all_options = getAllOptionCodesData();
        var breakFlag = false;
        
        var checkAndAdd = function() {
            for (var i = 0; i < all_options.length; i++) {
                if (all_options[i].code === code) {
                    Swal.fire({
                        title: '@lang{数据校验}',
                        text: '@lang{填写的配置项已经存在，需要替换么！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{替换}',
                        cancelButtonText: '@lang{再次编辑}',
                        showCancelButton: true
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            attributeOptions.find('tr[data-id="' + code + '"]').remove();
                            doAdd();
                        }
                    });
                    return;
                }
            }
            doAdd();
        };
        
        var doAdd = function() {
            var name = offcanvasOptionAdd.find('#option-name').val();
            var data = {
                'code': code,
                'name': name,
                'eav_entity_id':'{{attribute.eav_entity_id}}',
                'attribute_code':'{{attribute.code}}'
            };
            var addBody = Object.keys(data).map(function(k){ return encodeURIComponent(k)+'='+encodeURIComponent(data[k]); }).join('&');
            var addUrl = '@backend-url("*/backend/attribute/option/add")';
            var req = window.Weline.Api.request(addUrl, { method: 'POST', headers: {'Content-Type': 'application/x-www-form-urlencoded'}, body: addBody });
            req.then(function (res) {
                var resData = (res && res.data) || res;
                if(resData && resData['code']===0){
                        Swal.fire({
                            title: '@lang{操作失败}',
                            text: resData['msg'],
                            icon: 'error',
                            confirmButtonText: '@lang{重新编辑}'
                        });
                    }else{
                        offcanvasOptionAdd.find('#option-code').val('');
                        offcanvasOptionAdd.find('#option-name').val('');
                        var create_time = new Date().toLocaleString();
                        var $row = $('<tr data-id="' + code + '" style="cursor: pointer;">' +
                            '<td data-field="code" style="width: 80px">' + code + '</td>' +
                            '<td data-field="name">' + name + '</td>' +
                            '<td data-field="update_time">' + create_time + '</td>' +
                            '<td data-field="create_time">' + create_time + '</td>' +
                            '<td style="width: 100px">' +
                            '<a class="btn btn-outline-secondary btn-sm edit" title="Edit">' +
                            '<i class="fas fa-pencil-alt"></i></a>' +
                            '<a class="btn btn-outline-secondary btn-sm delete" title="@lang{删除}">' +
                            '<i class="mdi mdi-delete text-danger"></i></a>' +
                            '</td></tr>');
                        attributeOptions.append($row);
                        editRowEvent();
                        renderEditTable();
                    }
                }
            }).catch(function() {});
        };
        
        checkAndAdd();
    });
})();
</js:part>
