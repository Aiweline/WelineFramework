<!-- EAV管理器脚本 -->
<script src="@static(Weline_Eav::js/eav-manager/eav-manager.js)"></script>
<script>
    // 初始化EAV管理器
    $(document).ready(function() {
        EavManager.init({
            apiBase: '@backend-url("eav/backend/manager")',
            treeContainer: '#eav-tree',
            detailContainer: '#detail-form',
            searchInput: '#tree-search'
        });
        
        // 处理下拉菜单点击后关闭
        $('#addNewDropdown').on('click', function(e) {
            e.stopPropagation();
        });
        
        // 点击下拉菜单项后关闭下拉菜单
        $('.eav-tree-actions .dropdown-item').on('click', function() {
            const dropdown = bootstrap.Dropdown.getInstance($('#addNewDropdown')[0]);
            if (dropdown) {
                dropdown.hide();
            }
        });
    });
</script>

