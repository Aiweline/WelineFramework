<js:part>
(function() {
    'use strict';
    
    var EavManager = {
        config: {
            apiBase: '@backend-url("eav/backend/manager")',
            treeContainer: '#eav-tree',
            detailContainer: '#detail-form',
            searchInput: '#tree-search'
        },
        
        init: function(options) {
            var self = this;
            if (options) {
                Object.assign(this.config, options);
            }
            this.loadTree();
            this.bindEvents();
        },
        
        loadTree: function() {
            var self = this;
            var container = $(this.config.treeContainer);
            container.html('<div class="tree-loading"><i class="mdi mdi-loading mdi-spin me-2"></i>加载中...</div>');
            var req = window.Weline.Api.get(this.config.apiBase + '/tree', { silent: true });
            req.then(function(res) {
                var data = res && res.data;
                if (res && res.ok && data && (data.code === 0 || data.items)) {
                    self.renderTree(data.items || data.data || []);
                } else {
                    container.html('<div class="text-danger p-3">加载失败</div>');
                }
            }).catch(function() {
                container.html('<div class="text-danger p-3">加载失败</div>');
            });
        },
        
        renderTree: function(data) {
            var container = $(this.config.treeContainer);
            if (!data || data.length === 0) {
                container.html('<div class="text-muted p-3 text-center">暂无数据</div>');
                return;
            }
            var html = this.buildTreeHtml(data);
            container.html(html);
        },
        
        buildTreeHtml: function(items, level) {
            var self = this;
            level = level || 0;
            var html = '';
            
            items.forEach(function(item) {
                var hasChildren = item.children && item.children.length > 0;
                var nodeClass = 'tree-node node-' + item.type;
                var toggleClass = hasChildren ? 'tree-node-toggle' : 'tree-node-toggle empty';
                var icon = self.getNodeIcon(item.type);
                
                html += '<div class="' + nodeClass + '" data-type="' + item.type + '" data-id="' + item.id + '">';
                html += '<span class="' + toggleClass + '">';
                if (hasChildren) {
                    html += '<i class="mdi mdi-chevron-right"></i>';
                }
                html += '</span>';
                html += '<i class="tree-node-icon ' + icon + '"></i>';
                html += '<span class="tree-node-label">' + item.name + '</span>';
                if (item.code) {
                    html += '<span class="tree-node-code">(' + item.code + ')</span>';
                }
                html += '</div>';
                
                if (hasChildren) {
                    html += '<div class="tree-children">';
                    html += self.buildTreeHtml(item.children, level + 1);
                    html += '</div>';
                }
            });
            
            return html;
        },
        
        getNodeIcon: function(type) {
            var icons = {
                'entity': 'mdi mdi-cube-outline',
                'set': 'mdi mdi-folder-outline',
                'group': 'mdi mdi-folder-multiple-outline',
                'attribute': 'mdi mdi-tag-outline'
            };
            return icons[type] || 'mdi mdi-file-outline';
        },
        
        bindEvents: function() {
            var self = this;
            
            $(document).on('click', '.tree-node', function(e) {
                e.stopPropagation();
                var $node = $(this);
                var $toggle = $node.find('.tree-node-toggle');
                var $children = $node.next('.tree-children');
                
                $('.tree-node').removeClass('active');
                $node.addClass('active');
                
                if ($children.length) {
                    $children.toggleClass('expanded');
                    $toggle.find('i').toggleClass('mdi-chevron-right mdi-chevron-down');
                }
                
                self.loadDetail($node.data('type'), $node.data('id'));
            });
            
            $(this.config.searchInput).on('input', debounce(function() {
                var keyword = $(this).val().toLowerCase();
                self.filterTree(keyword);
            }, 300));
            
            $('#add-entity-btn').on('click', function(e) {
                e.preventDefault();
                self.addNode('entity');
            });
            
            $('#add-set-btn').on('click', function(e) {
                e.preventDefault();
                self.addNode('set');
            });
            
            $('#add-group-btn').on('click', function(e) {
                e.preventDefault();
                self.addNode('group');
            });
            
            $('#add-attribute-btn').on('click', function(e) {
                e.preventDefault();
                self.addNode('attribute');
            });
        },
        
        filterTree: function(keyword) {
            if (!keyword) {
                $('.tree-node').show();
                return;
            }
            
            $('.tree-node').each(function() {
                var text = $(this).text().toLowerCase();
                if (text.indexOf(keyword) > -1) {
                    $(this).show();
                    $(this).parents('.tree-children').addClass('expanded');
                } else {
                    $(this).hide();
                }
            });
        },
        
        loadDetail: function(type, id) {
            var self = this;
            $('#detail-placeholder').hide();
            $('#detail-form').show().html('<div class="text-center p-5"><i class="mdi mdi-loading mdi-spin fs-3"></i></div>');
            $('#detail-header').show();
            var url = this.config.apiBase + '/detail?type=' + encodeURIComponent(type) + '&id=' + encodeURIComponent(id);
            var req = window.Weline.Api.get(url, { silent: true });
            req.then(function(res) {
                var data = res && res.data;
                if (res && res.ok && data && (data.code === 0 || data.data)) {
                    self.renderDetail(data.data || data || {});
                } else {
                    $('#detail-form').html('<div class="text-danger p-3">加载失败</div>');
                }
            }).catch(function() {
                $('#detail-form').html('<div class="text-danger p-3">加载失败</div>');
            });
        },
        
        renderDetail: function(data) {
            $('#detail-title').text(data.name || '详情');
            $('#detail-subtitle').text(data.code || '');
            $('#detail-form').html(data.html || '<div class="text-muted">暂无详情</div>');
        },
        
        addNode: function(type) {
            console.log('Add node:', type);
            Swal.fire({
                title: '新建' + this.getTypeName(type),
                text: '即将打开新建表单',
                icon: 'info',
                confirmButtonText: '确定'
            });
        },
        
        getTypeName: function(type) {
            var names = {
                'entity': '实体',
                'set': '属性集',
                'group': '属性组',
                'attribute': '属性'
            };
            return names[type] || type;
        }
    };
    
    window.EavManager = EavManager;
    
    $(document).ready(function() {
        EavManager.init();
        
        $('#addNewDropdown').on('click', function(e) {
            e.stopPropagation();
        });
        
        $('.eav-tree-actions .dropdown-item').on('click', function() {
            var dropdown = bootstrap.Dropdown.getInstance($('#addNewDropdown')[0]);
            if (dropdown) {
                dropdown.hide();
            }
        });
    });
})();
</js:part>
