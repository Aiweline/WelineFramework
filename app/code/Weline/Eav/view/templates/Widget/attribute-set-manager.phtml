<?php if ($isManageMode): ?>
<script>
window.EavSetManagerI18n = window.EavSetManagerI18n || <?= json_encode($eavSetManagerI18n, $jsonForScriptFlags) ?>;

// 属性集管理器
window.EavSetManager = window.EavSetManager || {
    escapeHtml: function(value) {
        const div = document.createElement('div');
        div.textContent = value === null || value === undefined ? '' : String(value);
        return div.innerHTML;
    },

    escapeAttr: function(value) {
        return this.escapeHtml(value).replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    },

    getText: function(key) {
        const words = window.EavSetManagerI18n || {};
        return words[key] || '';
    },

    notify: function(widgetId, type, message) {
        const toast = window.BackendToast || window.FrontendToast || null;
        const toastType = type === 'error' ? 'error' : type;

        if (toast && typeof toast[toastType] === 'function') {
            toast[toastType](message);
            return;
        }

        if (toast && type === 'error' && typeof toast.danger === 'function') {
            toast.danger(message);
            return;
        }

        const notice = document.getElementById(widgetId + '-notice');
        if (!notice) {
            if (window.console) {
                (type === 'error' && console.error ? console.error : console.log).call(console, message);
            }
            return;
        }

        const alertType = type === 'error' ? 'danger' : type;
        notice.className = 'eav-set-manager-notice alert mb-0 alert-' + alertType;
        notice.textContent = message;
        notice.style.display = 'block';
    },

    clearNotice: function(widgetId) {
        const notice = document.getElementById(widgetId + '-notice');
        if (notice) {
            notice.textContent = '';
            notice.style.display = 'none';
        }
    },
    
    selectSet: function(widgetId, setId) {
        const container = document.getElementById(widgetId);
        const apiBase = container.dataset.apiBase;
        const detailEl = document.getElementById(widgetId + '-detail');
        const contentEl = document.getElementById(widgetId + '-detail-content');
        
        // 高亮选中项
        container.querySelectorAll('.list-group-item').forEach(el => {
            el.classList.remove('active');
            if (el.dataset.setId == setId) {
                el.classList.add('active');
            }
        });
        
        // 显示详情区域
        detailEl.style.display = 'block';
        contentEl.innerHTML = '<div class="text-center py-3"><i class="mdi mdi-loading mdi-spin"></i> ' + this.escapeHtml(this.getText('loading')) + '</div>';
        
        // 加载属性集详情
        var url = apiBase + '/set/detail?id=' + setId;
        var req = window.Weline.Api.get(url, { silent: true });
        req.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                this.renderSetDetail(widgetId, data.data);
            } else {
                contentEl.innerHTML = '<div class="alert alert-danger">' + this.escapeHtml((data && data.message) || this.getText('loadFailed')) + '</div>';
            }
        }.bind(this)).catch(function(error) {
            contentEl.innerHTML = '<div class="alert alert-danger">' + this.escapeHtml(this.getText('networkError') + ': ' + (error && error.message || '')) + '</div>';
        }.bind(this));
    },
    
    renderSetDetail: function(widgetId, setData) {
        const contentEl = document.getElementById(widgetId + '-detail-content');
        const titleEl = document.getElementById(widgetId + '-detail-title');
        
        titleEl.textContent = setData.local_name || setData.name || setData.code;
        
        const setId = parseInt(setData.set_id, 10) || 0;
        let html = `
            <div class="mb-3">
                <label class="form-label">${this.escapeHtml(this.getText('setCode'))}</label>
                <input type="text" class="form-control" value="${this.escapeAttr(setData.code || '')}" readonly>
            </div>
            <div class="mb-3">
                <label class="form-label">${this.escapeHtml(this.getText('setName'))}</label>
                <input type="text" class="form-control" value="${this.escapeAttr(setData.name || '')}" id="${widgetId}-set-name">
            </div>
            <button type="button" class="btn btn-primary" data-eav-set-action="save" data-widget-id="${this.escapeAttr(widgetId)}" data-set-id="${setId}">
                <i class="mdi mdi-content-save me-1"></i> ${this.escapeHtml(this.getText('save'))}
            </button>
        `;
        
        contentEl.innerHTML = html;
    },
    
    addSet: function(widgetId) {
        this.clearNotice(widgetId);
        this.cancelInlineDelete(widgetId);
        const formEl = document.getElementById(widgetId + '-new-set-form');
        const inputEl = document.getElementById(widgetId + '-new-set-name');
        const errorEl = document.getElementById(widgetId + '-new-set-error');
        if (!formEl || !inputEl) {
            this.notify(widgetId, 'error', this.getText('enterSetName'));
            return;
        }

        formEl.style.display = 'block';
        inputEl.value = '';
        inputEl.classList.remove('is-invalid');
        if (errorEl) {
            errorEl.textContent = '';
            errorEl.style.display = 'none';
        }
        inputEl.focus();
    },

    handleNewSetKey: function(event, widgetId) {
        if (event.key === 'Enter') {
            event.preventDefault();
            this.submitNewSet(widgetId);
        } else if (event.key === 'Escape') {
            event.preventDefault();
            this.cancelAddSet(widgetId);
        }
    },

    cancelAddSet: function(widgetId) {
        const formEl = document.getElementById(widgetId + '-new-set-form');
        const inputEl = document.getElementById(widgetId + '-new-set-name');
        const errorEl = document.getElementById(widgetId + '-new-set-error');
        if (formEl) {
            formEl.style.display = 'none';
        }
        if (inputEl) {
            inputEl.value = '';
            inputEl.classList.remove('is-invalid');
        }
        if (errorEl) {
            errorEl.textContent = '';
            errorEl.style.display = 'none';
        }
    },

    submitNewSet: function(widgetId) {
        const container = document.getElementById(widgetId);
        const inputEl = document.getElementById(widgetId + '-new-set-name');
        const errorEl = document.getElementById(widgetId + '-new-set-error');
        if (!container || !inputEl) {
            return;
        }

        const entityId = container.dataset.entityId;
        const name = inputEl.value.trim();

        if (!name) {
            inputEl.classList.add('is-invalid');
            if (errorEl) {
                errorEl.textContent = this.getText('enterSetName');
                errorEl.style.display = 'block';
            }
            this.notify(widgetId, 'warning', this.getText('enterSetName'));
            inputEl.focus();
            return;
        }
        
        const code = name.toLowerCase().replace(/[^a-z0-9]/g, '_');
        
        this.doSaveSet(widgetId, {
            eav_entity_id: entityId,
            code: code,
            name: name
        });
    },
    
    editSet: function(widgetId, setId) {
        this.selectSet(widgetId, setId);
    },
    
    saveSet: function(widgetId, setId) {
        const container = document.getElementById(widgetId);
        const nameEl = document.getElementById(widgetId + '-set-name');
        const name = nameEl ? nameEl.value.trim() : '';
        const entityId = container.dataset.entityId;

        if (!name) {
            this.notify(widgetId, 'warning', this.getText('enterSetName'));
            if (nameEl) {
                nameEl.focus();
            }
            return;
        }
        
        this.doSaveSet(widgetId, {
            set_id: setId,
            eav_entity_id: entityId,
            name: name
        });
    },
    
    doSaveSet: function(widgetId, data) {
        const container = document.getElementById(widgetId);
        const apiBase = container.dataset.apiBase;
        
        const formData = new FormData();
        for (const key in data) {
            formData.append(key, data[key]);
        }
        
        var req = window.Weline.Api.request(apiBase + '/set/save', { method: 'POST', body: formData, silent: true });
        req.then(function(res) {
            var result = (res && res.data) || res;
            if (result && result.success) {
                this.notify(widgetId, 'success', result.message || this.getText('saveSuccess'));
                location.reload();
            } else {
                this.notify(widgetId, 'error', (result && result.message) || this.getText('saveFailed'));
            }
        }.bind(this)).catch(function(error) {
            var msg = this.getText('networkError') + ': ' + (error && error.message || '');
            this.notify(widgetId, 'error', msg);
        }.bind(this));
    },

    doDeleteSet: function(widgetId, setId) {
        const container = document.getElementById(widgetId);
        const apiBase = container.dataset.apiBase;
        const formData = new FormData();
        formData.append('id', setId);
        var req = window.Weline.Api.request(apiBase + '/set/delete', { method: 'POST', body: formData, silent: true });
        req.then(function(res) {
            var result = (res && res.data) || res;
            if (result && result.success) {
                this.notify(widgetId, 'success', result.message || this.getText('deleteSuccess'));
                location.reload();
            } else {
                this.notify(widgetId, 'error', (result && result.message) || this.getText('deleteFailed'));
            }
        }.bind(this)).catch(function(error) {
            var msg = this.getText('networkError') + ': ' + (error && error.message || '');
            this.notify(widgetId, 'error', msg);
        }.bind(this));
    },

    showInlineDeleteConfirm: function(widgetId, setId) {
        this.cancelAddSet(widgetId);
        const confirmEl = document.getElementById(widgetId + '-delete-confirm');
        if (!confirmEl) {
            this.notify(widgetId, 'warning', this.getText('deleteConfirm'));
            return;
        }
        confirmEl.dataset.setId = setId;
        confirmEl.style.display = 'flex';
        const button = confirmEl.querySelector('.btn-danger');
        if (button) {
            button.focus();
        }
    },

    cancelInlineDelete: function(widgetId) {
        const confirmEl = document.getElementById(widgetId + '-delete-confirm');
        if (confirmEl) {
            confirmEl.dataset.setId = '';
            confirmEl.style.display = 'none';
        }
    },

    confirmInlineDelete: function(widgetId) {
        const confirmEl = document.getElementById(widgetId + '-delete-confirm');
        if (!confirmEl || !confirmEl.dataset.setId) {
            return;
        }
        const setId = confirmEl.dataset.setId;
        this.cancelInlineDelete(widgetId);
        this.doDeleteSet(widgetId, setId);
    },
    
    deleteSet: function(widgetId, setId) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(this.getText('deleteConfirm'), {
                type: 'danger',
                confirmText: this.getText('delete'),
                cancelText: this.getText('cancel')
            }).then(function(ok) {
                if (ok) {
                    this.doDeleteSet(widgetId, setId);
                }
            }.bind(this));
            return;
        }

        this.showInlineDeleteConfirm(widgetId, setId);
    }
};

document.addEventListener('keydown', function(event) {
    const input = event.target.closest('[data-eav-new-set-key]');
    if (!input) {
        return;
    }

    EavSetManager.handleNewSetKey(event, input.getAttribute('data-widget-id') || '');
});

document.addEventListener('click', function(event) {
    const trigger = event.target.closest('[data-eav-set-action]');
    if (!trigger) {
        return;
    }

    const action = trigger.getAttribute('data-eav-set-action') || '';
    const widgetId = trigger.getAttribute('data-widget-id') || '';
    const setId = parseInt(trigger.getAttribute('data-set-id') || '0', 10);

    if (action === 'edit' || action === 'delete') {
        event.stopPropagation();
    }
    event.preventDefault();

    switch (action) {
        case 'add':
            EavSetManager.addSet(widgetId);
            break;
        case 'submit-new':
            EavSetManager.submitNewSet(widgetId);
            break;
        case 'cancel-add':
            EavSetManager.cancelAddSet(widgetId);
            break;
        case 'confirm-inline-delete':
            EavSetManager.confirmInlineDelete(widgetId);
            break;
        case 'cancel-inline-delete':
            EavSetManager.cancelInlineDelete(widgetId);
            break;
        case 'select':
            EavSetManager.selectSet(widgetId, setId);
            break;
        case 'edit':
            EavSetManager.editSet(widgetId, setId);
            break;
        case 'delete':
            EavSetManager.deleteSet(widgetId, setId);
            break;
        case 'save':
            EavSetManager.saveSet(widgetId, setId);
            break;
    }
});
</script>
<?php endif; ?>
