<script>
(function() {
    'use strict';
    
    var WelineCurrencyConfig = {
        changeModalInstance: null,
        progressModalInstance: null,
        
        init: function() {
            var self = this;
            var changeModal = document.getElementById('baseCurrencyChangeModal');
            var progressModal = document.getElementById('currencyUpdateProgressModal');
            
            if (changeModal && typeof bootstrap !== 'undefined') {
                this.changeModalInstance = new bootstrap.Modal(changeModal);
            }
            if (progressModal && typeof bootstrap !== 'undefined') {
                this.progressModalInstance = new bootstrap.Modal(progressModal);
            }
            
            // 初始化工具提示
            if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
                var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                tooltipTriggerList.map(function(tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl);
                });
            }
            
            // 监听表单提交
            var form = document.querySelector('form.needs-validation');
            var baseCurrencySelect = document.getElementById('base_currency');
            
            if (form) {
                form.addEventListener('submit', function(e) {
                    var originalValue = baseCurrencySelect.getAttribute('data-original-value');
                    var newValue = baseCurrencySelect.value;
                    
                    if (newValue !== originalValue) {
                        if (!form.dataset.baseCurrencyConfirmed) {
                            e.preventDefault();
                            e.stopPropagation();
                            
                            document.getElementById('modal_old_base_currency').textContent = originalValue;
                            document.getElementById('modal_new_base_currency').textContent = newValue;
                            
                            if (self.changeModalInstance) {
                                self.changeModalInstance.show();
                            }
                        } else {
                            e.preventDefault();
                            e.stopPropagation();
                            self.submitFormWithCurrencyUpdate(originalValue, newValue, form);
                        }
                    }
                });
                
                // 确认切换按钮事件
                var confirmModalBtn = document.getElementById('confirmBaseCurrencyChangeBtn');
                if (confirmModalBtn) {
                    confirmModalBtn.addEventListener('click', function() {
                        var originalValue = baseCurrencySelect.getAttribute('data-original-value');
                        var newValue = baseCurrencySelect.value;
                        
                        form.dataset.baseCurrencyConfirmed = 'true';
                        
                        if (self.changeModalInstance) {
                            self.changeModalInstance.hide();
                        }
                        
                        self.submitFormWithCurrencyUpdate(originalValue, newValue, form);
                    });
                }
                
                var confirmBtn = document.getElementById('confirm_base_currency_change');
                if (confirmBtn) {
                    confirmBtn.addEventListener('click', function() {
                        var originalValue = baseCurrencySelect.getAttribute('data-original-value');
                        var newValue = baseCurrencySelect.value;
                        
                        document.getElementById('modal_old_base_currency').textContent = originalValue;
                        document.getElementById('modal_new_base_currency').textContent = newValue;
                        
                        if (self.changeModalInstance) {
                            self.changeModalInstance.show();
                        }
                    });
                }
            }
            
            // 频率改变事件
            document.getElementById('cron_frequency').addEventListener('change', function() {
                var frequency = this.value;
                
                document.getElementById('time_selector').style.display = 
                    (frequency === 'daily' || frequency === 'weekly' || frequency === 'monthly') ? 'block' : 'none';
                document.getElementById('weekday_selector').style.display = 
                    (frequency === 'weekly') ? 'block' : 'none';
                document.getElementById('day_selector').style.display = 
                    (frequency === 'monthly') ? 'block' : 'none';
                document.getElementById('custom_selector').style.display = 
                    (frequency === 'custom') ? 'block' : 'none';
                
                self.updateCronExpression();
            });
            
            // 解析现有 Cron 表达式
            var currentCron = document.getElementById('import_cron_time').value;
            this.parseCronExpression(currentCron);
        },
        
        parseCronExpression: function(cronExpr) {
            if (!cronExpr) cronExpr = '0 2 * * *';
            
            var parts = cronExpr.trim().split(/\s+/);
            if (parts.length !== 5) {
                document.getElementById('cron_frequency').value = 'custom';
                document.getElementById('cron_custom').value = cronExpr;
                document.getElementById('custom_selector').style.display = 'block';
                document.getElementById('time_selector').style.display = 'none';
                this.updateCronExpression();
                return;
            }
            
            var minute = parts[0], hour = parts[1], day = parts[2], month = parts[3], weekday = parts[4];
            
            if (minute !== '*' && hour === '*' && day === '*' && month === '*' && weekday === '*') {
                document.getElementById('cron_frequency').value = 'hourly';
                document.getElementById('cron_minute').value = minute;
                document.getElementById('time_selector').style.display = 'none';
            } else if (day === '*' && month === '*' && weekday === '*') {
                document.getElementById('cron_frequency').value = 'daily';
                document.getElementById('cron_hour').value = hour;
                document.getElementById('cron_minute').value = minute;
                document.getElementById('time_selector').style.display = 'block';
            } else if (day === '*' && month === '*' && weekday !== '*') {
                document.getElementById('cron_frequency').value = 'weekly';
                document.getElementById('cron_hour').value = hour;
                document.getElementById('cron_minute').value = minute;
                document.getElementById('cron_weekday').value = weekday;
                document.getElementById('time_selector').style.display = 'block';
                document.getElementById('weekday_selector').style.display = 'block';
            } else if (day !== '*' && month === '*' && weekday === '*') {
                document.getElementById('cron_frequency').value = 'monthly';
                document.getElementById('cron_hour').value = hour;
                document.getElementById('cron_minute').value = minute;
                document.getElementById('cron_day').value = day;
                document.getElementById('time_selector').style.display = 'block';
                document.getElementById('day_selector').style.display = 'block';
            } else {
                document.getElementById('cron_frequency').value = 'custom';
                document.getElementById('cron_custom').value = cronExpr;
                document.getElementById('time_selector').style.display = 'none';
                document.getElementById('custom_selector').style.display = 'block';
            }
            
            this.updateCronExpression();
        },
        
        updateCronExpression: function() {
            var frequency = document.getElementById('cron_frequency').value;
            var cronExpr = '', preview = '';
            var weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            
            switch (frequency) {
                case 'hourly':
                    var minute = document.getElementById('cron_minute').value;
                    cronExpr = minute + ' * * * *';
                    preview = '每小时的第 ' + minute + ' 分钟执行';
                    break;
                case 'daily':
                    var hour = document.getElementById('cron_hour').value;
                    var min = document.getElementById('cron_minute').value;
                    cronExpr = min + ' ' + hour + ' * * *';
                    preview = '每天 ' + String(hour).padStart(2, '0') + ':' + String(min).padStart(2, '0') + ' 执行';
                    break;
                case 'weekly':
                    var wHour = document.getElementById('cron_hour').value;
                    var wMin = document.getElementById('cron_minute').value;
                    var weekday = document.getElementById('cron_weekday').value;
                    cronExpr = wMin + ' ' + wHour + ' * * ' + weekday;
                    preview = '每周 ' + weekdays[weekday] + ' ' + String(wHour).padStart(2, '0') + ':' + String(wMin).padStart(2, '0') + ' 执行';
                    break;
                case 'monthly':
                    var mHour = document.getElementById('cron_hour').value;
                    var mMin = document.getElementById('cron_minute').value;
                    var day = document.getElementById('cron_day').value;
                    cronExpr = mMin + ' ' + mHour + ' ' + day + ' * *';
                    preview = '每月第 ' + day + ' 天 ' + String(mHour).padStart(2, '0') + ':' + String(mMin).padStart(2, '0') + ' 执行';
                    break;
                case 'custom':
                    cronExpr = document.getElementById('cron_custom').value || '0 2 * * *';
                    preview = '自定义：' + cronExpr;
                    break;
            }
            
            document.getElementById('import_cron_time').value = cronExpr;
            document.getElementById('cron_expression_display').textContent = cronExpr;
            document.getElementById('cron_preview').textContent = preview;
        },
        
        checkBaseCurrencyChange: function(selectElement) {
            var originalValue = selectElement.getAttribute('data-original-value');
            var newValue = selectElement.value;
            var warningDiv = document.getElementById('base_currency_warning');
            var form = document.querySelector('form.needs-validation');
            
            if (newValue !== originalValue) {
                warningDiv.style.display = 'block';
                if (form) delete form.dataset.baseCurrencyConfirmed;
                warningDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                warningDiv.style.display = 'none';
                if (form) delete form.dataset.baseCurrencyConfirmed;
            }
        },
        
        resetBaseCurrency: function() {
            var baseCurrencySelect = document.getElementById('base_currency');
            var originalValue = baseCurrencySelect.getAttribute('data-original-value');
            baseCurrencySelect.value = originalValue;
            document.getElementById('base_currency_warning').style.display = 'none';
            
            var form = document.querySelector('form.needs-validation');
            if (form) delete form.dataset.baseCurrencyConfirmed;
        },
        
        submitFormWithCurrencyUpdate: function(oldBaseCurrency, newBaseCurrency, form) {
            var self = this;
            var baseCurrencySelect = document.getElementById('base_currency');
            
            if (this.progressModalInstance) {
                this.progressModalInstance.show();
            }
            
            this.resetProgress();
            
            var formData = new FormData(form);
            formData.append('isAjax', '1');
            
            fetch(form.action || window.location.href, {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success && data.base_currency_changed) {
                    self.updateCurrencyRates(oldBaseCurrency, newBaseCurrency, form);
                } else if (data.success) {
                    if (self.progressModalInstance) {
                        self.progressModalInstance.hide();
                    }
                    BackendToast.success(data.message || '<?= __('配置保存成功！') ?>');
                    baseCurrencySelect.setAttribute('data-original-value', newBaseCurrency);
                    form.dataset.baseCurrencyConfirmed = '';
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else {
                    if (self.progressModalInstance) {
                        self.progressModalInstance.hide();
                    }
                    BackendToast.error(data.message || '<?= __('配置保存失败') ?>');
                    form.dataset.baseCurrencyConfirmed = '';
                }
            })
            .catch(function(error) {
                if (self.progressModalInstance) {
                    self.progressModalInstance.hide();
                }
                BackendToast.error('<?= __('请求失败') ?>');
                form.dataset.baseCurrencyConfirmed = '';
            });
        },
        
        updateCurrencyRates: function(oldBaseCurrency, newBaseCurrency, form) {
            var self = this;
            var baseCurrencySelect = document.getElementById('base_currency');
            var updateUrl = '<?= $this->getBackendUrl("currency/backend/config/post-update-rates") ?>';
            
            fetch(updateUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    old_base_currency: oldBaseCurrency,
                    new_base_currency: newBaseCurrency,
                    current: 0
                })
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    self.updateProgress(data.total_count, data.success_count, data.fail_count, data.errors);
                    
                    document.getElementById('update_progress_bar').classList.remove('progress-bar-animated');
                    document.getElementById('update_progress_bar').style.width = '100%';
                    document.getElementById('update_progress_text').textContent = '100%';
                    document.getElementById('update_progress_footer').style.display = 'block';
                    
                    baseCurrencySelect.setAttribute('data-original-value', newBaseCurrency);
                    form.dataset.baseCurrencyConfirmed = '';
                    
                    BackendToast.success(data.message || '<?= __('货币汇率更新完成') ?>');
                } else {
                    if (self.progressModalInstance) {
                        self.progressModalInstance.hide();
                    }
                    BackendToast.error(data.message || '<?= __('货币汇率更新失败') ?>');
                    form.dataset.baseCurrencyConfirmed = '';
                }
            })
            .catch(function(error) {
                if (self.progressModalInstance) {
                    self.progressModalInstance.hide();
                }
                BackendToast.error('<?= __('更新失败') ?>');
                form.dataset.baseCurrencyConfirmed = '';
            });
        },
        
        resetProgress: function() {
            document.getElementById('update_progress_bar').style.width = '0%';
            document.getElementById('update_progress_text').textContent = '0%';
            document.getElementById('update_progress_bar').classList.add('progress-bar-animated');
            document.getElementById('update_current_currency').textContent = '-';
            document.getElementById('update_total_count').textContent = '0';
            document.getElementById('update_success_count').textContent = '0';
            document.getElementById('update_fail_count').textContent = '0';
            document.getElementById('update_errors').style.display = 'none';
            document.getElementById('update_errors_list').innerHTML = '';
            document.getElementById('update_progress_footer').style.display = 'none';
        },
        
        updateProgress: function(total, success, fail, errors) {
            var percentage = total > 0 ? Math.round((success + fail) / total * 100) : 0;
            
            document.getElementById('update_progress_bar').style.width = percentage + '%';
            document.getElementById('update_progress_text').textContent = percentage + '%';
            document.getElementById('update_total_count').textContent = total;
            document.getElementById('update_success_count').textContent = success;
            document.getElementById('update_fail_count').textContent = fail;
            
            if (errors && errors.length > 0) {
                var errorsList = document.getElementById('update_errors_list');
                errorsList.innerHTML = '';
                errors.forEach(function(error) {
                    var li = document.createElement('li');
                    li.textContent = error.currency + ': ' + error.error;
                    errorsList.appendChild(li);
                });
                document.getElementById('update_errors').style.display = 'block';
            }
        },
        
        testApi: function(event) {
            var apiKey = document.getElementById('import_api_key').value;
            var btn = event.target;
            var originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<?= __('测试中...') ?>';
            
            var testApiUrl = '<?= $this->getBackendUrl("currency/backend/config/testApi") ?>';
            var testApiOpts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'api_key=' + encodeURIComponent(apiKey) };
            window.Weline.Api.request(testApiUrl, testApiOpts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('API连接测试成功') ?>');
                } else {
                    BackendToast.error(data.message || '<?= __('API连接测试失败') ?>');
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('请求失败') ?>');
            })
            .finally(function() {
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        },
        
        manualImport: function(event) {
            var btn = event.target;
            var originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<?= __('导入中...') ?>';
            
            var importUrl = '<?= $this->getBackendUrl("currency/backend/config/import") ?>';
            var importOpts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' } };
            window.Weline.Api.request(importUrl, importOpts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('导入成功') ?>');
                    setTimeout(function() { location.reload(); }, 2000);
                } else {
                    BackendToast.error(data.message || '<?= __('导入失败') ?>');
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('请求失败') ?>');
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        }
    };
    
    window.WelineCurrencyConfig = WelineCurrencyConfig;
    
    document.addEventListener('DOMContentLoaded', function() {
        WelineCurrencyConfig.init();
    });
})();
</script>
