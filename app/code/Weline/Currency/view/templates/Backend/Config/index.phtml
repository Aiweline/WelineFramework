<script>
// 解析 Cron 表达式并填充表单
function parseCronExpression(cronExpr) {
    if (!cronExpr) {
        cronExpr = '0 2 * * *';
    }
    
    const parts = cronExpr.trim().split(/\s+/);
    if (parts.length !== 5) {
        // 如果不是标准格式，使用自定义模式
        document.getElementById('cron_frequency').value = 'custom';
        document.getElementById('cron_custom').value = cronExpr;
        document.getElementById('custom_selector').style.display = 'block';
        document.getElementById('time_selector').style.display = 'none';
        document.getElementById('weekday_selector').style.display = 'none';
        document.getElementById('day_selector').style.display = 'none';
        updateCronExpression();
        return;
    }
    
    const [minute, hour, day, month, weekday] = parts;
    
    // 判断频率类型
    if (minute !== '*' && hour === '*' && day === '*' && month === '*' && weekday === '*') {
        // 每小时
        document.getElementById('cron_frequency').value = 'hourly';
        document.getElementById('cron_minute').value = minute;
        document.getElementById('time_selector').style.display = 'none';
        document.getElementById('weekday_selector').style.display = 'none';
        document.getElementById('day_selector').style.display = 'none';
        document.getElementById('custom_selector').style.display = 'none';
    } else if (day === '*' && month === '*' && weekday === '*') {
        // 每天
        document.getElementById('cron_frequency').value = 'daily';
        document.getElementById('cron_hour').value = hour;
        document.getElementById('cron_minute').value = minute;
        document.getElementById('time_selector').style.display = 'block';
        document.getElementById('weekday_selector').style.display = 'none';
        document.getElementById('day_selector').style.display = 'none';
        document.getElementById('custom_selector').style.display = 'none';
    } else if (day === '*' && month === '*' && weekday !== '*') {
        // 每周
        document.getElementById('cron_frequency').value = 'weekly';
        document.getElementById('cron_hour').value = hour;
        document.getElementById('cron_minute').value = minute;
        document.getElementById('cron_weekday').value = weekday;
        document.getElementById('time_selector').style.display = 'block';
        document.getElementById('weekday_selector').style.display = 'block';
        document.getElementById('day_selector').style.display = 'none';
        document.getElementById('custom_selector').style.display = 'none';
    } else if (day !== '*' && month === '*' && weekday === '*') {
        // 每月
        document.getElementById('cron_frequency').value = 'monthly';
        document.getElementById('cron_hour').value = hour;
        document.getElementById('cron_minute').value = minute;
        document.getElementById('cron_day').value = day;
        document.getElementById('time_selector').style.display = 'block';
        document.getElementById('weekday_selector').style.display = 'none';
        document.getElementById('day_selector').style.display = 'block';
        document.getElementById('custom_selector').style.display = 'none';
    } else {
        // 自定义
        document.getElementById('cron_frequency').value = 'custom';
        document.getElementById('cron_custom').value = cronExpr;
        document.getElementById('time_selector').style.display = 'none';
        document.getElementById('weekday_selector').style.display = 'none';
        document.getElementById('day_selector').style.display = 'none';
        document.getElementById('custom_selector').style.display = 'block';
    }
    
    updateCronExpression();
}

// 更新 Cron 表达式
function updateCronExpression() {
    const frequency = document.getElementById('cron_frequency').value;
    let cronExpr = '';
    let preview = '';
    
    switch (frequency) {
        case 'hourly':
            const minute = document.getElementById('cron_minute').value;
            cronExpr = `${minute} * * * *`;
            preview = `每小时的第 ${minute} 分钟执行`;
            break;
            
        case 'daily':
            const hour = document.getElementById('cron_hour').value;
            const min = document.getElementById('cron_minute').value;
            cronExpr = `${min} ${hour} * * *`;
            const hourStr = String(hour).padStart(2, '0');
            const minStr = String(min).padStart(2, '0');
            preview = `每天 ${hourStr}:${minStr} 执行`;
            break;
            
        case 'weekly':
            const wHour = document.getElementById('cron_hour').value;
            const wMin = document.getElementById('cron_minute').value;
            const weekday = document.getElementById('cron_weekday').value;
            cronExpr = `${wMin} ${wHour} * * ${weekday}`;
            const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            const wHourStr = String(wHour).padStart(2, '0');
            const wMinStr = String(wMin).padStart(2, '0');
            preview = `每周 ${weekdays[weekday]} ${wHourStr}:${wMinStr} 执行`;
            break;
            
        case 'monthly':
            const mHour = document.getElementById('cron_hour').value;
            const mMin = document.getElementById('cron_minute').value;
            const day = document.getElementById('cron_day').value;
            cronExpr = `${mMin} ${mHour} ${day} * *`;
            const mHourStr = String(mHour).padStart(2, '0');
            const mMinStr = String(mMin).padStart(2, '0');
            preview = `每月第 ${day} 天 ${mHourStr}:${mMinStr} 执行`;
            break;
            
        case 'custom':
            cronExpr = document.getElementById('cron_custom').value || '0 2 * * *';
            preview = `自定义：${cronExpr}`;
            break;
    }
    
    // 更新隐藏输入框
    document.getElementById('import_cron_time').value = cronExpr;
    
    // 更新预览
    document.getElementById('cron_expression_display').textContent = cronExpr;
    document.getElementById('cron_preview').textContent = preview;
}

// 检查基准货币变更
function checkBaseCurrencyChange(selectElement) {
    const originalValue = selectElement.getAttribute('data-original-value');
    const newValue = selectElement.value;
    const warningDiv = document.getElementById('base_currency_warning');
    const form = document.querySelector('form.needs-validation');
    
    if (newValue !== originalValue) {
        // 显示警告
        warningDiv.style.display = 'block';
        // 清除确认标记
        if (form) {
            delete form.dataset.baseCurrencyConfirmed;
        }
        // 滚动到警告位置
        warningDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } else {
        // 隐藏警告
        warningDiv.style.display = 'none';
        // 清除确认标记
        if (form) {
            delete form.dataset.baseCurrencyConfirmed;
        }
    }
}

// 重置基准货币到原值
function resetBaseCurrency() {
    const baseCurrencySelect = document.getElementById('base_currency');
    const originalValue = baseCurrencySelect.getAttribute('data-original-value');
    baseCurrencySelect.value = originalValue;
    document.getElementById('base_currency_warning').style.display = 'none';
    
    const form = document.querySelector('form.needs-validation');
    if (form) {
        delete form.dataset.baseCurrencyConfirmed;
    }
}

// 频率改变时的处理
document.addEventListener('DOMContentLoaded', function() {
    // 初始化 Bootstrap 工具提示
    if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    }
    
    // 监听表单提交，如果基准货币改变了，显示确认模态框
    const form = document.querySelector('form.needs-validation');
    const baseCurrencySelect = document.getElementById('base_currency');
    const changeModal = document.getElementById('baseCurrencyChangeModal');
    const progressModal = document.getElementById('currencyUpdateProgressModal');
    let changeModalInstance = null;
    let progressModalInstance = null;
    
    if (changeModal && typeof bootstrap !== 'undefined') {
        changeModalInstance = new bootstrap.Modal(changeModal);
    }
    if (progressModal && typeof bootstrap !== 'undefined') {
        progressModalInstance = new bootstrap.Modal(progressModal);
    }
    
    if (form) {
        form.addEventListener('submit', function(e) {
            const originalValue = baseCurrencySelect.getAttribute('data-original-value');
            const newValue = baseCurrencySelect.value;
            
            if (newValue !== originalValue) {
                // 检查是否已经确认过
                if (!form.dataset.baseCurrencyConfirmed) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // 显示确认模态框
                    document.getElementById('modal_old_base_currency').textContent = originalValue;
                    document.getElementById('modal_new_base_currency').textContent = newValue;
                    
                    if (changeModalInstance) {
                        changeModalInstance.show();
                    }
                } else {
                    // 已确认，使用AJAX提交
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // 使用AJAX提交表单
                    submitFormWithCurrencyUpdate(originalValue, newValue);
                }
            }
        });
        
        // 确认切换基准货币按钮（模态框中的按钮）
        const confirmModalBtn = document.getElementById('confirmBaseCurrencyChangeBtn');
        if (confirmModalBtn) {
            confirmModalBtn.addEventListener('click', function() {
                const originalValue = baseCurrencySelect.getAttribute('data-original-value');
                const newValue = baseCurrencySelect.value;
                
                // 标记已确认
                form.dataset.baseCurrencyConfirmed = 'true';
                
                // 关闭确认模态框
                if (changeModalInstance) {
                    changeModalInstance.hide();
                }
                
                // 提交表单并更新货币
                submitFormWithCurrencyUpdate(originalValue, newValue);
            });
        }
        
        // 确认切换基准货币按钮（警告框中的按钮）
        const confirmBtn = document.getElementById('confirm_base_currency_change');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', function() {
                const originalValue = baseCurrencySelect.getAttribute('data-original-value');
                const newValue = baseCurrencySelect.value;
                
                // 显示确认模态框
                document.getElementById('modal_old_base_currency').textContent = originalValue;
                document.getElementById('modal_new_base_currency').textContent = newValue;
                
                if (changeModalInstance) {
                    changeModalInstance.show();
                }
            });
        }
    }
    
    // 提交表单并更新货币汇率
    function submitFormWithCurrencyUpdate(oldBaseCurrency, newBaseCurrency) {
        // 显示进度模态框
        if (progressModalInstance) {
            progressModalInstance.show();
        }
        
        // 重置进度
        resetProgress();
        
        // 准备表单数据
        const formData = new FormData(form);
        formData.append('isAjax', '1');
        
        // 提交配置
        fetch(form.action || window.location.href, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success && data.base_currency_changed) {
                // 开始更新货币汇率
                updateCurrencyRates(oldBaseCurrency, newBaseCurrency);
            } else if (data.success) {
                // 没有改变基准货币，直接完成
                if (progressModalInstance) {
                    progressModalInstance.hide();
                }
                showMessage('success', data.message || '<?= __('配置保存成功！') ?>');
                // 更新原值
                baseCurrencySelect.setAttribute('data-original-value', newBaseCurrency);
                form.dataset.baseCurrencyConfirmed = '';
                // 刷新页面
                setTimeout(() => window.location.reload(), 1000);
            } else {
                // 保存失败
                if (progressModalInstance) {
                    progressModalInstance.hide();
                }
                showMessage('error', data.message || '<?= __('配置保存失败') ?>');
                form.dataset.baseCurrencyConfirmed = '';
            }
        })
        .catch(error => {
            if (progressModalInstance) {
                progressModalInstance.hide();
            }
            showMessage('error', '<?= __('请求失败: %{1}', '') ?>' + error.message);
            form.dataset.baseCurrencyConfirmed = '';
        });
    }
    
    // 更新货币汇率
    function updateCurrencyRates(oldBaseCurrency, newBaseCurrency) {
        // 使用PHP生成URL（方法名改为postUpdateRates以支持POST请求）
        const updateUrl = '<?= $this->getBackendUrl("currency/backend/config/post-update-rates") ?>';
        
        fetch(updateUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                old_base_currency: oldBaseCurrency,
                new_base_currency: newBaseCurrency,
                current: 0
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // 更新进度条
                updateProgress(data.total_count, data.success_count, data.fail_count, data.errors);
                
                // 显示完成
                document.getElementById('update_progress_bar').classList.remove('progress-bar-animated');
                document.getElementById('update_progress_bar').style.width = '100%';
                document.getElementById('update_progress_text').textContent = '100%';
                document.getElementById('update_progress_footer').style.display = 'block';
                
                // 更新原值
                baseCurrencySelect.setAttribute('data-original-value', newBaseCurrency);
                form.dataset.baseCurrencyConfirmed = '';
                
                // 显示成功消息
                showMessage('success', data.message || '<?= __('货币汇率更新完成') ?>');
            } else {
                // 更新失败
                if (progressModalInstance) {
                    progressModalInstance.hide();
                }
                showMessage('error', data.message || '<?= __('货币汇率更新失败') ?>');
                form.dataset.baseCurrencyConfirmed = '';
            }
        })
        .catch(error => {
            if (progressModalInstance) {
                progressModalInstance.hide();
            }
            showMessage('error', '<?= __('更新失败: %{1}', '') ?>' + error.message);
            form.dataset.baseCurrencyConfirmed = '';
        });
    }
    
    // 重置进度
    function resetProgress() {
        document.getElementById('update_progress_bar').style.width = '0%';
        document.getElementById('update_progress_text').textContent = '0%';
        document.getElementById('update_progress_bar').classList.add('progress-bar-animated');
        document.getElementById('update_current_currency').textContent = '-';
        document.getElementById('update_total_count').textContent = '0';
        document.getElementById('update_success_count').textContent = '0';
        document.getElementById('update_fail_count').textContent = '0';
        document.getElementById('update_errors').style.display = 'none';
        document.getElementById('update_errors_list').innerHTML = '';
        document.getElementById('update_progress_footer').style.display = 'none';
    }
    
    // 更新进度
    function updateProgress(total, success, fail, errors) {
        const percentage = total > 0 ? Math.round((success + fail) / total * 100) : 0;
        
        document.getElementById('update_progress_bar').style.width = percentage + '%';
        document.getElementById('update_progress_text').textContent = percentage + '%';
        document.getElementById('update_total_count').textContent = total;
        document.getElementById('update_success_count').textContent = success;
        document.getElementById('update_fail_count').textContent = fail;
        
        // 显示错误信息
        if (errors && errors.length > 0) {
            const errorsList = document.getElementById('update_errors_list');
            errorsList.innerHTML = '';
            errors.forEach(error => {
                const li = document.createElement('li');
                li.textContent = error.currency + ': ' + error.error;
                errorsList.appendChild(li);
            });
            document.getElementById('update_errors').style.display = 'block';
        }
    }
    
    // 频率改变事件
    document.getElementById('cron_frequency').addEventListener('change', function() {
        const frequency = this.value;
        
        // 显示/隐藏相应的选择器
        document.getElementById('time_selector').style.display = 
            (frequency === 'daily' || frequency === 'weekly' || frequency === 'monthly') ? 'block' : 'none';
        document.getElementById('weekday_selector').style.display = 
            (frequency === 'weekly') ? 'block' : 'none';
        document.getElementById('day_selector').style.display = 
            (frequency === 'monthly') ? 'block' : 'none';
        document.getElementById('custom_selector').style.display = 
            (frequency === 'custom') ? 'block' : 'none';
        
        updateCronExpression();
    });
    
    // 页面加载时解析现有的 Cron 表达式
    const currentCron = document.getElementById('import_cron_time').value;
    parseCronExpression(currentCron);
});

// 显示消息提示
function showMessage(type, message) {
    // 查找页面头部容器
    let headerContainer = document.querySelector('.card-header') || 
                         document.querySelector('.page-header') ||
                         document.querySelector('.container-fluid');
    
    // 如果没有找到合适的头部容器，使用页面顶部
    if (!headerContainer) {
        headerContainer = document.querySelector('body');
    }
    
    // 确定图标和样式
    let icon = 'check-circle';
    let alertClass = 'success';
    if (type === 'error' || type === 'danger') {
        icon = 'alert-circle';
        alertClass = 'danger';
    } else if (type === 'warning') {
        icon = 'alert-outline';
        alertClass = 'warning';
    } else if (type === 'info') {
        icon = 'information-outline';
        alertClass = 'info';
    }
    
    // 创建提示元素
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${alertClass} alert-dismissible fade show message-toast`;
    alertDiv.style.marginBottom = '15px';
    alertDiv.style.borderRadius = '8px';
    alertDiv.style.boxShadow = '0 2px 8px rgba(0,0,0,0.1)';
    alertDiv.innerHTML = `
        <i class="mdi mdi-${icon} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    // 移除现有的消息提示
    const existingMessages = headerContainer.querySelectorAll('.message-toast');
    existingMessages.forEach(msg => msg.remove());
    
    // 在头部容器顶部插入提示
    if (headerContainer === document.body) {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    } else {
        headerContainer.insertBefore(alertDiv, headerContainer.firstChild);
    }
    
    // 自动移除提示
    setTimeout(() => {
        if (alertDiv.parentNode) {
            alertDiv.classList.remove('show');
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.parentNode.removeChild(alertDiv);
                }
            }, 300);
        }
    }, 4000);
    
    // 滚动到提示位置
    alertDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function testApi() {
    const apiKey = document.getElementById('import_api_key').value;
    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<?= __('测试中...') ?>';
    
    fetch('@backend-url("currency/backend/config/testApi")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'api_key=' + encodeURIComponent(apiKey)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('HTTP ' + response.status);
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            showMessage('success', data.message || '<?= __('API连接测试成功') ?>');
        } else {
            // data.message 已经包含了完整的错误信息，直接使用
            showMessage('error', data.message || '<?= __('API连接测试失败') ?>');
        }
    })
    .catch(error => {
        // 网络错误或其他异常
        showMessage('error', '<?= __('请求失败') ?>: ' + error.message);
    })
    .finally(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
}

function manualImport() {
    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<?= __('导入中...') ?>';
    
    fetch('@backend-url("currency/backend/config/import")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showMessage('success', data.message || '<?= __('导入成功') ?>');
            // 延迟刷新页面，让用户看到成功提示
            setTimeout(() => {
                location.reload();
            }, 2000);
        } else {
            showMessage('error', '<?= __('导入失败') ?>: ' + (data.message || '<?= __('未知错误') ?>'));
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    })
    .catch(error => {
        showMessage('error', '<?= __('请求失败') ?>: ' + error.message);
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
}
