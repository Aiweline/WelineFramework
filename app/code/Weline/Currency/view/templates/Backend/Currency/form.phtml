<script>
(function() {
    'use strict';
    
    window.WelineCurrencyForm = {
        updatePreview: function() {
            var amount = parseFloat(document.getElementById('previewAmount').value) || 0;
            var symbol = document.querySelector('[name="symbol"]').value || '';
            var position = document.querySelector('[name="position"]').value || 'left';
            var icon = document.querySelector('[name="icon"]').value || symbol;
            var thousandSep = document.querySelector('[name="thousand_separator"]').value || ',';
            var decimalSep = document.querySelector('[name="decimal_separator"]').value || '.';
            var format = document.querySelector('[name="format"]').value || '2,0';
            
            var formats = format.split(',');
            var decimals = parseInt(formats[0]) || 2;
            
            var formatted = amount.toFixed(decimals).replace('.', decimalSep).replace(/\B(?=(\d{3})+(?!\d))/g, thousandSep);
            var display = position === 'right' ? formatted + icon : icon + formatted;
            
            document.getElementById('formatPreview').textContent = display;
        }
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        WelineCurrencyForm.updatePreview();
        
        ['symbol', 'position', 'icon', 'thousand_separator', 'decimal_separator', 'format'].forEach(function(field) {
            var input = document.querySelector('[name="' + field + '"]');
            if (input) {
                input.addEventListener('input', WelineCurrencyForm.updatePreview);
                input.addEventListener('change', WelineCurrencyForm.updatePreview);
            }
        });
    });
})();
</script>
