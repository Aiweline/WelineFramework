<script>
function updatePreview() {
    const amount = parseFloat(document.getElementById('previewAmount').value) || 0;
    const symbol = document.querySelector('[name="symbol"]').value || '';
    const position = document.querySelector('[name="position"]').value || 'left';
    const icon = document.querySelector('[name="icon"]').value || symbol;
    const thousandSep = document.querySelector('[name="thousand_separator"]').value || ',';
    const decimalSep = document.querySelector('[name="decimal_separator"]').value || '.';
    const format = document.querySelector('[name="format"]').value || '2,0';
    
    const formats = format.split(',');
    const decimals = parseInt(formats[0]) || 2;
    
    const formatted = amount.toFixed(decimals).replace('.', decimalSep).replace(/\B(?=(\d{3})+(?!\d))/g, thousandSep);
    const display = position === 'right' ? formatted + icon : icon + formatted;
    
    document.getElementById('formatPreview').textContent = display;
}

// 页面加载时更新预览
document.addEventListener('DOMContentLoaded', function() {
    updatePreview();
    
    // 监听相关字段变化
    ['symbol', 'position', 'icon', 'thousand_separator', 'decimal_separator', 'format'].forEach(function(field) {
        const input = document.querySelector('[name="' + field + '"]');
        if (input) {
            input.addEventListener('input', updatePreview);
            input.addEventListener('change', updatePreview);
        }
    });
});
</script>

