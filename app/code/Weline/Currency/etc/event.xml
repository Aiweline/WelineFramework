<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- Controller attribute observer -->
    <event name="Weline_Framework_Url::detect_currency">
        <observer name="Weline_Currency::detect_currency" instance="Weline\Currency\Observer\DetectCurrency"
                  disabled="false"
                  shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Currency::setup_upgrade_after" instance="Weline\Currency\Observer\SetupUpgradeAfter"
                  disabled="false"
                  shared="true" sort="120"/>
    </event>
</config>
