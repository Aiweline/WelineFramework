<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 系统升级后扫描数据库适配器（只在系统升级完成后扫描一次，避免重复扫描） -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Framework_Database::setup_upgrade_adapter_scan" instance="Weline\Framework\Database\Observer\ModuleUpgradeAdapterScanObserver" disabled="false" shared="true" sort="100"/>
    </event>

    <!-- 维护模式：API 请求统一JSON 响应 -->
    <event name="Weline_Maintenance::maintenance">
        <observer name="Weline_Framework_Api::maintenance_response" instance="Weline\Framework\Api\Observer\Maintenance" disabled="false" shared="true" sort="-100"/>
    </event>
    
    <!-- App 运行前检查全页缓存（URL 解析之前，仅做后端判断） -->
    <event name="Weline_Framework::App::run_before">
        <observer name="Weline_Framework_Router::check_full_page_cache" instance="Weline\Framework\Router\Observer\CheckFullPageCache" disabled="false" shared="true" sort="100"/>
    </event>
    
    <!-- URL 解析后检查全页缓存（此时可以生成正确的缓存键） -->
    <event name="Weline_Framework::App::url_parsed_after">
        <observer name="Weline_Framework_Router::check_full_page_cache_after_parse" instance="Weline\Framework\Router\Observer\CheckFullPageCache" disabled="false" shared="true" sort="100"/>
    </event>
    
    <!-- 控制器属性事件：API规范验证 -->
    <event name="Weline_Framework_Module::controller_attributes">
        <observer name="Weline_Framework_Api::validate_api_spec" instance="Weline\Framework\Api\Observer\ControllerAttributes" disabled="false" shared="true" sort="10"/>
    </event>
    
    <!-- 卸载通知事件：其他模块通过此事件通知卸载服务执行卸载操作 -->
    <event name="Weline_Framework_UninstallService::uninstall">
        <observer name="Weline_Weline_Framework_UninstallService::uninstall_observer" instance="Weline\Framework\Uninstall\Observer\UninstallObserver" disabled="false" shared="true" sort="10"/>
    </event>
    
    <!-- 注册安装器事件：确保 Router 使用 app/code 下的类 -->
    <event name="Weline_Framework_Register::register_installer">
        <observer name="Weline_Framework_Router::register_installer" instance="Weline\Framework\Router\Observer\RegisterInstaller" disabled="false" shared="true" sort="0"/>
    </event>

    <!-- URI 处理前：剥离路径开头的 货币/语言 前缀，确保前端路由能匹配（兜底） -->
    <event name="Weline_Framework_Router::process_uri_before">
        <observer name="Weline_Framework_Router::strip_currency_locale_prefix" instance="Weline\Framework\Router\Observer\StripCurrencyLocalePrefix" disabled="false" shared="true" sort="-10"/>
    </event>

    <!-- 路由开始前：URL Guard 越界检查（max id 越界、参数白名单等），命中即抛 NoRouterException 并触发 guard::overflow 事件 -->
    <event name="Weline_Framework_Router::before_start">
        <observer name="Weline_Framework_Router::url_guard" instance="Weline\Framework\Router\Observer\UrlGuardObserver" disabled="false" shared="true" sort="-50"/>
    </event>

    <!-- 动态模块查询：任意 {Module}::query 自动路由到 FrameworkQueryService，由 QueryProviderRegistry 中已注册的查询器处理 -->
    <event name="{Module}::query">
        <observer name="Weline_Framework_Query::module_query_dispatcher" instance="Weline\Framework\Service\Query\Observer\ModuleQueryDispatcher" disabled="false" shared="true" sort="0"/>
    </event>

    <!-- Schema DDL 成功后清理数据库相关缓存 -->
    <event name="Weline_Framework_Schema::table_ddl_after">
        <observer name="Weline_Framework_Database::schema_change_clear_cache" instance="Weline\Framework\Database\Observer\SchemaChangeClearCacheObserver" disabled="false" shared="true" sort="100"/>
    </event>

    <!-- 响应重定向前：若有 ResultManager 结果且为后台 iframe，通过事件取桥接页 URL 并替换重定向目标 -->
    <event name="Framework_Http::response_redirect_before">
        <observer name="Weline_Framework_Manager::result_bridge_redirect" instance="Weline\Framework\Http\Observer\ResultBridgeRedirect" disabled="false" shared="true" sort="50"/>
    </event>

    <!-- 日志运行模式解析：默认来自配置 log.runtime，观察者可改为 wls（如 WLS 进程内由 Weline_Server 设置） -->
    <event name="Weline_Framework_Log::resolve_runtime">
        <observer name="Weline_Framework_Log::resolve_runtime_default" instance="Weline\Framework\Log\Observer\ResolveRuntimeDefaultObserver" disabled="false" shared="true" sort="100"/>
    </event>

</config>
