<script>
function retryInstall(type, name, btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> <?= __('安装中...') ?>';

    var retryUrl = '<?= $this->getBackendUrl('weline_framework/backend/env-manager/retry-install') ?>';
    var retryOpts = { method: 'POST', headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'}, body: 'type=' + encodeURIComponent(type) + '&name=' + encodeURIComponent(name) };
    window.Weline.Api.request(retryUrl, retryOpts)
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        if (data.code === 200) {
            AdminToast ? AdminToast.success(data.msg) : alert(data.msg);
        } else {
            AdminToast ? AdminToast.warning(data.msg) : alert(data.msg);
        }
        setTimeout(() => location.reload(), 1500);
    })
    .catch(err => {
        AdminToast ? AdminToast.error('<?= __('请求失败') ?>: ' + err.message) : alert(err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-download"></i> <?= __('尝试安装') ?>';
    });
}

function resetAllStatuses() {
    if (!confirm('<?= __('确定要重置所有安装记录吗？下次 env:install 将重新尝试所有推荐项。') ?>')) return;

    var resetUrl = '<?= $this->getBackendUrl('weline_framework/backend/env-manager/reset-all') ?>';
    var resetOpts = { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} };
    window.Weline.Api.request(resetUrl, resetOpts)
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        AdminToast ? AdminToast.success(data.msg) : alert(data.msg);
        setTimeout(() => location.reload(), 1000);
    });
}

function toggleGuide(id) {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('active');
}

function showGuideTab(btn, contentId) {
    const parent = btn.closest('td');
    parent.querySelectorAll('.guide-tab').forEach(t => t.classList.remove('active'));
    parent.querySelectorAll('.guide-content').forEach(c => c.style.display = 'none');
    btn.classList.add('active');
    const content = document.getElementById(contentId);
    if (content) content.style.display = '';
}
</script>
