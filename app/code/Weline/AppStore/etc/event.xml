<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">

    <!-- 模块下载完成事件 -->
    <event name="Weline_AppStore::download_complete">
        <observer name="installable_module_check"
                  instance="Weline\AppStore\Observer\DownloadCompleteObserver"/>
    </event>

    <!-- 模块安装后事件 -->
    <event name="Weline_Framework_Module::module_install_after">
        <observer name="appstore_module_installed"
                  instance="Weline\AppStore\Observer\ModuleInstalledObserver"/>
    </event>

    <event name="Weline_Database_ModuleArtifact::collect">
        <observer name="appstore_module_artifact_provider"
                  instance="Weline\AppStore\Observer\CollectModuleArtifactProvider"/>
    </event>
</config>
