<?php
$modules = is_iterable($modules ?? null) ? $modules : [];
$systemModules = is_array($system_modules ?? null) ? $system_modules : [];
$moduleManagerUrl = (string)($module_manager_url ?? '');

$rows = [];
foreach ($modules as $module) {
    $data = is_object($module) && method_exists($module, 'getData') ? $module->getData() : (array)$module;
    $moduleName = (string)($data['module_name'] ?? '');
    $rows[] = [
        'module_name' => $moduleName,
        'display_name' => (string)($data['display_name'] ?? $moduleName),
        'version' => (string)($data['version'] ?? ''),
        'platform_module_id' => (int)($data['platform_module_id'] ?? 0),
        'installed_at' => (string)($data['installed_at'] ?? ''),
        'registered' => $moduleName !== '' && isset($systemModules[$moduleName]),
        'enabled' => $moduleName !== '' && !empty($systemModules[$moduleName]['status']),
        'command' => $moduleName !== '' ? 'php bin/w module:remove ' . $moduleName : '',
        'readme_path' => $moduleName !== '' ? APP_CODE_PATH . str_replace('_', DS, $moduleName) . DS . '商城应用.md' : '',
    ];
}
?>
<div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1"><?= __('我的模块') ?></h1>
            <div class="text-muted small"><?= __('这里仅记录 App 商城安装来源；卸载走系统模块管理，数据备份由系统卸载流程自动处理。') ?></div>
        </div>
        <?php if ($moduleManagerUrl !== ''): ?>
            <a class="btn btn-outline-primary" href="<?= htmlspecialchars($moduleManagerUrl, ENT_QUOTES, 'UTF-8') ?>">
                <i class="bi bi-box-arrow-up-right me-1"></i><?= __('系统模块管理') ?>
            </a>
        <?php endif; ?>
    </div>

    <?php if ($rows): ?>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                <tr>
                    <th><?= __('模块') ?></th>
                    <th><?= __('版本') ?></th>
                    <th><?= __('来源') ?></th>
                    <th><?= __('系统状态') ?></th>
                    <th><?= __('安装时间') ?></th>
                    <th><?= __('系统卸载') ?></th>
                </tr>
                </thead>
                <tbody>
                <?php foreach ($rows as $row): ?>
                    <tr>
                        <td>
                            <div class="fw-semibold"><?= htmlspecialchars($row['display_name'], ENT_QUOTES, 'UTF-8') ?></div>
                            <div class="text-muted small"><?= htmlspecialchars($row['module_name'], ENT_QUOTES, 'UTF-8') ?></div>
                            <?php if ($row['readme_path'] !== ''): ?>
                                <div class="text-muted small"><?= __('说明：') ?><code><?= htmlspecialchars($row['readme_path'], ENT_QUOTES, 'UTF-8') ?></code></div>
                            <?php endif; ?>
                        </td>
                        <td><?= htmlspecialchars($row['version'], ENT_QUOTES, 'UTF-8') ?></td>
                        <td>
                            <span class="badge bg-info"><?= __('官方商城') ?></span>
                            <?php if ($row['platform_module_id'] > 0): ?>
                                <div class="text-muted small">#<?= (int)$row['platform_module_id'] ?></div>
                            <?php endif; ?>
                        </td>
                        <td>
                            <?php if ($row['enabled']): ?>
                                <span class="badge bg-success"><?= __('已启用') ?></span>
                            <?php elseif ($row['registered']): ?>
                                <span class="badge bg-secondary"><?= __('已注册未启用') ?></span>
                            <?php else: ?>
                                <span class="badge bg-warning text-dark"><?= __('系统中已不存在') ?></span>
                            <?php endif; ?>
                        </td>
                        <td><?= htmlspecialchars($row['installed_at'], ENT_QUOTES, 'UTF-8') ?></td>
                        <td>
                            <?php if ($row['command'] !== ''): ?>
                                <code><?= htmlspecialchars($row['command'], ENT_QUOTES, 'UTF-8') ?></code>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    <?php else: ?>
        <div class="alert alert-info" role="alert">
            <?= __('暂无 App 商城安装记录。') ?>
        </div>
    <?php endif; ?>
</div>
