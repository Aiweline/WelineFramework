<script>
(() => {
    const pending = document.querySelector('[data-appstore-uninstall-pending]');
    const runningLabel = '<?= $runningLabel ?>';
    document.querySelectorAll('[data-appstore-uninstall-form]').forEach((form) => {
        form.addEventListener('submit', () => {
            const moduleName = form.dataset.moduleName || '';
            if (pending) {
                pending.classList.remove('d-none');
                const nameNode = pending.querySelector('[data-appstore-uninstall-pending-name]');
                if (nameNode) {
                    nameNode.textContent = moduleName;
                }
                pending.scrollIntoView({ block: 'start', behavior: 'smooth' });
            }

            document.querySelectorAll('[data-appstore-uninstall-button]').forEach((button) => {
                button.disabled = true;
            });

            const button = form.querySelector('[data-appstore-uninstall-button]');
            if (!button) {
                return;
            }
            const spinner = button.querySelector('[data-appstore-uninstall-spinner]');
            const icon = button.querySelector('[data-appstore-uninstall-icon]');
            const label = button.querySelector('[data-appstore-uninstall-label]');
            if (spinner) {
                spinner.classList.remove('d-none');
            }
            if (icon) {
                icon.classList.add('d-none');
            }
            if (label) {
                label.textContent = runningLabel;
            }
        });
    });
})();
</script>
