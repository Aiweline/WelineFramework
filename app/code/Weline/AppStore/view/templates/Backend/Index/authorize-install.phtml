<?php
$module = is_array($module ?? null) ? $module : [];
$permissions = is_array($required_permissions ?? null) ? $required_permissions : [];
$licenseKey = (string)($license_key ?? '');
$version = (string)($version ?? '');
$installAction = (string)($install_action ?? '');
$storeUrl = (string)($store_url ?? '');
$installedUrl = (string)($installed_url ?? '');
$wlsPanelReturn = !empty($wls_panel_return);
$wlsPanelUrl = (string)($wls_panel_url ?? '');
$authorizeError = trim((string)($authorize_error ?? ''));
$installedState = is_array($installed_state ?? null) ? $installed_state : [];
$isInstalled = !empty($installedState['is_installed']);
$updateAvailable = !empty($installedState['update_available']);
$installedVersion = (string)($installedState['installed_version'] ?? '');
$esc = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$moduleId = (int)($module['module_id'] ?? 0);
$displayName = (string)($module['display_name'] ?? $module['name'] ?? '');
?>
<div class="appstore-install-authorization">
    <?php if ($authorizeError !== ''): ?>
        <div class="alert alert-danger" role="alert">
            <div class="fw-semibold"><?= __('安装授权未完成') ?></div>
            <div class="small mt-1"><?= $esc($authorizeError) ?></div>
        </div>
    <?php endif; ?>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                <div>
                    <div class="text-muted small mb-1"><?= __('应用安装授权') ?></div>
                    <h2 class="h4 mb-2"><?= $esc($displayName ?: __('待安装应用')) ?></h2>
                    <div class="d-flex flex-wrap gap-2 text-muted small">
                        <span><?= __('模块') ?>: <?= $esc($module['name'] ?? '') ?></span>
                        <span><?= __('版本') ?>: <?= $esc($version) ?></span>
                        <span><?= __('当前终端') ?>: <?= $esc($store_domain ?? \w_env('server.http_host', 'localhost')) ?></span>
                    </div>
                </div>
                <a class="btn btn-outline-secondary" href="<?= $esc($storeUrl) ?>">
                    <i class="bi bi-arrow-left me-1"></i><?= __('返回应用商城') ?>
                </a>
                <?php if ($wlsPanelReturn && $wlsPanelUrl !== ''): ?>
                    <a class="btn btn-outline-primary" href="<?= $esc($wlsPanelUrl) ?>">
                        <i class="bi bi-diagram-3 me-1"></i><?= __('Back To WLS Panel') ?>
                    </a>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <?php if ($moduleId > 0 && $licenseKey !== '' && $isInstalled): ?>
        <div class="card border-success-subtle">
            <div class="card-body d-flex align-items-center justify-content-between gap-3 flex-wrap">
                <div>
                    <div class="fw-semibold text-success">
                        <i class="bi bi-check2-circle me-1"></i><?= __('该应用已安装') ?>
                    </div>
                    <div class="text-muted small mt-1">
                        <?= __('当前终端已安装该应用，不需要重复执行安装授权。') ?>
                        <?php if ($installedVersion !== ''): ?>
                            <?= __('本地版本：') ?><?= $esc($installedVersion) ?>
                        <?php endif; ?>
                    </div>
                    <?php if ($updateAvailable): ?>
                        <div class="text-muted small mt-1"><?= __('检测到商城存在新版本，请进入我的模块走更新流程。') ?></div>
                    <?php endif; ?>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-outline-secondary" href="<?= $esc($storeUrl) ?>">
                        <i class="bi bi-bag me-1"></i><?= __('返回应用商城') ?>
                    </a>
                    <a class="btn <?= $updateAvailable ? 'btn-primary' : 'btn-outline-primary' ?>" href="<?= $esc($installedUrl ?: $storeUrl) ?>">
                        <i class="bi <?= $updateAvailable ? 'bi-arrow-repeat' : 'bi-puzzle' ?> me-1"></i><?= $updateAvailable ? __('去更新') : __('我的模块') ?>
                    </a>
                </div>
            </div>
        </div>
    <?php elseif ($moduleId > 0 && $licenseKey !== ''): ?>
        <form method="post" action="<?= $esc($installAction) ?>">
            <?php if ($wlsPanelReturn): ?>
                <input type="hidden" name="wls_panel_return" value="1">
            <?php endif; ?>
            <input type="hidden" name="module_id" value="<?= $moduleId ?>">
            <input type="hidden" name="license_key" value="<?= $esc($licenseKey) ?>">
            <input type="hidden" name="version" value="<?= $esc($version) ?>">
            <input type="hidden" name="permission_consent" value="1">

            <div class="card mb-3">
                <div class="card-header bg-white">
                    <div class="fw-semibold"><?= __('该应用请求访问以下资源') ?></div>
                    <div class="text-muted small"><?= __('勾选全部必需权限后，终端才会下载安装到本系统。') ?></div>
                </div>
                <div class="list-group list-group-flush">
                    <?php foreach ($permissions as $permission): ?>
                        <?php
                        if (!is_array($permission)) {
                            continue;
                        }
                        $code = (string)($permission['code'] ?? '');
                        if ($code === '') {
                            continue;
                        }
                        ?>
                        <label class="list-group-item d-flex align-items-start gap-3">
                            <input class="form-check-input mt-1" type="checkbox" name="permissions[]" value="<?= $esc($code) ?>" required>
                            <span class="d-grid gap-1">
                                <span class="fw-semibold"><?= $esc($permission['label'] ?? $code) ?></span>
                                <?php if (!empty($permission['description'])): ?>
                                    <span class="text-muted small"><?= $esc($permission['description']) ?></span>
                                <?php endif; ?>
                                <code class="small"><?= $esc($code) ?></code>
                            </span>
                        </label>
                    <?php endforeach; ?>
                    <?php if (!$permissions): ?>
                        <div class="list-group-item text-muted">
                            <?= __('该应用未声明额外资源权限，将只执行模块包下载、校验和安装。') ?>
                        </div>
                    <?php endif; ?>
                </div>
            </div>

            <div class="card">
                <div class="card-body d-flex align-items-center justify-content-between gap-3 flex-wrap">
                    <div>
                        <div class="fw-semibold"><?= __('确认授权并安装') ?></div>
                        <div class="text-muted small"><?= __('授权记录与安装记录会保留在当前终端，用于后续更新、卸载和审计。') ?></div>
                    </div>
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-shield-check me-1"></i><?= __('授权并安装') ?>
                    </button>
                </div>
            </div>
        </form>
    <?php endif; ?>
</div>
