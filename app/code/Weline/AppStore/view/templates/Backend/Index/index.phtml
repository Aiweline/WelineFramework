<script>
(function () {
    var form = document.getElementById('appstore-search-form');
    var keyword = document.getElementById('appstore-search');
    var pricing = document.getElementById('appstore-pricing');
    var tag = document.getElementById('appstore-tag');
    var surface = document.getElementById('appstore-surface');
    var cards = Array.prototype.slice.call(document.querySelectorAll('.appstore-module-card'));
    var empty = document.getElementById('appstore-empty');
    if (!form || !keyword || !pricing || !tag || !surface || !cards.length) {
        return;
    }

    function applyFilter(event) {
        if (event && event.preventDefault) {
            event.preventDefault();
        }
        var q = keyword.value.trim().toLowerCase();
        var price = pricing.value;
        var tagValue = tag.value.trim().toLowerCase();
        var surfaceValue = normalizeSurface(surface.value);
        var visible = 0;
        cards.forEach(function (card) {
            var tagTokens = tokens(card.getAttribute('data-tags') || '');
            var surfaceTokens = tokens(card.getAttribute('data-surfaces') || '');
            var matchKeyword = q === '' || (card.getAttribute('data-search') || '').indexOf(q) !== -1;
            var matchPricing = price === '' || card.getAttribute('data-pricing') === price;
            var matchTag = tagValue === '' || tagTokens.indexOf(tagValue) !== -1;
            var matchSurface = surfaceValue === '' || surfaceTokens.indexOf(surfaceValue) !== -1;
            var show = matchKeyword && matchPricing && matchTag && matchSurface;
            card.classList.toggle('d-none', !show);
            if (show) {
                visible++;
            }
        });
        if (empty) {
            empty.classList.toggle('d-none', visible > 0);
        }
    }

    function tokens(value) {
        return value.trim().toLowerCase().split(/\s+/).filter(Boolean);
    }

    function normalizeSurface(value) {
        value = value.trim().toLowerCase();
        if (value.indexOf('surface:') === 0 || value.indexOf('surface.') === 0) {
            return value.substring(8);
        }
        return value;
    }

    applyFilter();
    form.addEventListener('submit', applyFilter);
    keyword.addEventListener('input', applyFilter);
    pricing.addEventListener('change', applyFilter);
    tag.addEventListener('input', applyFilter);
    surface.addEventListener('input', applyFilter);
})();
</script>
