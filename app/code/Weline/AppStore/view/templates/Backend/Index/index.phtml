$moduleTags = static function (array $module): array {
    $tags = [];
    $seen = [];
    $resolveLabel = static function (mixed $value, string $code): string {
        if (is_string($value) || is_numeric($value)) {
            $label = trim((string)$value);
            return $label !== '' ? $label : $code;
        }

        if (is_array($value)) {
            foreach (['zh_Hans_CN', 'en_US', 'default', 'label', 'name', 'title'] as $key) {
                if (is_string($value[$key] ?? null) || is_numeric($value[$key] ?? null)) {
                    $label = trim((string)$value[$key]);
                    return $label !== '' ? $label : $code;
                }
            }
            foreach ($value as $item) {
                if (is_string($item) || is_numeric($item)) {
                    $label = trim((string)$item);
                    return $label !== '' ? $label : $code;
                }
            }
        }

        return $code;
    };

    $appendTag = static function (mixed $tag) use (&$tags, &$seen, $resolveLabel): void {
        if (is_string($tag) || is_numeric($tag) || is_bool($tag)) {
            $code = \Weline\Framework\MarketplaceMeta\MarketplaceTag::normalizeCode((string)$tag);
            if ($code !== '' && !isset($seen[$code])) {
                $seen[$code] = true;
                $tags[] = ['code' => $code, 'label' => $code];
            }
            return;
        }

        if (!is_array($tag)) {
            return;
        }

        $code = (string)($tag['code'] ?? $tag['tag_code'] ?? $tag['tag'] ?? '');
        if ($code === '' && (is_string($tag['type'] ?? null) || is_numeric($tag['type'] ?? null))
            && (is_string($tag['value'] ?? null) || is_numeric($tag['value'] ?? null) || is_bool($tag['value'] ?? null))
        ) {
            $code = (string)$tag['type'] . ':' . (string)$tag['value'];
        }

        $code = \Weline\Framework\MarketplaceMeta\MarketplaceTag::normalizeCode($code);
        if ($code === '' || isset($seen[$code])) {
            return;
        }

        $seen[$code] = true;
        $tags[] = [
            'code' => $code,
            'label' => $resolveLabel($tag['label'] ?? $tag['labels'] ?? $tag['name'] ?? $code, $code),
        ];
    };

    $walkTags = static function (mixed $value) use (&$walkTags, $appendTag): void {
        if (is_string($value) || is_numeric($value) || is_bool($value)) {
            $appendTag($value);
            return;
        }

        if (!is_array($value)) {
            return;
        }

        if (array_key_exists('code', $value)
            || array_key_exists('tag_code', $value)
            || array_key_exists('tag', $value)
            || (array_key_exists('type', $value) && array_key_exists('value', $value))
        ) {
            $appendTag($value);
            return;
        }

        foreach ($value as $item) {
            $walkTags($item);
        }
    };

    $walkTags($module['tags_resolved'] ?? []);
    $walkTags($module['tags'] ?? []);
    if (is_array($module['marketplace_meta'] ?? null)) {
        $walkTags($module['marketplace_meta']['tags'] ?? []);
        $walkTags($module['marketplace_meta']['tags_resolved'] ?? []);
    }

    return $tags;
};
$moduleSurfaces = static function (array $module, array $tags): array {
    $surfaces = [];
    foreach ((array)($module['surfaces'] ?? []) as $surface) {
        $surface = trim((string)$surface);
        if ($surface !== '') {
            $surfaces[$surface] = true;
        }
    }
    $surface = trim((string)($module['surface'] ?? ''));
    if ($surface !== '') {
        $surfaces[$surface] = true;
    }
    if (is_array($module['marketplace_meta'] ?? null)) {
        foreach ((array)($module['marketplace_meta']['surfaces'] ?? []) as $surface) {
            $surface = trim((string)$surface);
            if ($surface !== '') {
                $surfaces[$surface] = true;
            }
        }
        $surface = trim((string)($module['marketplace_meta']['surface'] ?? ''));
        if ($surface !== '') {
            $surfaces[$surface] = true;
        }
    }
    $hasWlsTag = false;
    foreach ($tags as $tag) {
        $code = strtolower(trim((string)($tag['code'] ?? '')));
        if ($code === 'module:wls') {
            $hasWlsTag = true;
        }
        if (str_starts_with($code, 'surface.')) {
            $surfaces[substr($code, strlen('surface.'))] = true;
        } elseif (str_starts_with($code, 'surface:')) {
            $surface = substr($code, strlen('surface:'));
            if ($surface !== '') {
                $surfaces[$surface] = true;
            }
        }
    }
    if (!$surfaces && $hasWlsTag) {
        $surfaces['backend'] = true;
    }
    return array_keys($surfaces);
};
