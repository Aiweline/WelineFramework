<?php
$isBound = !empty($is_bound);
$licenses = is_iterable($licenses ?? null) ? $licenses : [];
$rows = [];
$pick = static function (array $row, array $keys, string $default = ''): string {
    foreach ($keys as $key) {
        if (isset($row[$key]) && trim((string)$row[$key]) !== '') {
            return trim((string)$row[$key]);
        }
    }

    return $default;
};
$statusLabels = [
    'active' => __('有效'),
    'valid' => __('有效'),
    'inactive' => __('未激活'),
    'not_activated' => __('未激活'),
    'pending' => __('待激活'),
    'expired' => __('已过期'),
    'revoked' => __('已撤销'),
];
$statusClasses = [
    'active' => 'bg-success',
    'valid' => 'bg-success',
    'inactive' => 'bg-secondary',
    'not_activated' => 'bg-secondary',
    'pending' => 'bg-warning text-dark',
    'expired' => 'bg-danger',
    'revoked' => 'bg-dark',
];

foreach ($licenses as $license) {
    $row = is_object($license) && method_exists($license, 'getData') ? $license->getData() : (array)$license;
    $status = strtolower($pick($row, ['status', 'license_status'], 'inactive'));
    $rows[] = [
        'license_key' => $pick($row, ['license_key', 'key']),
        'module_id' => (int)($row['module_id'] ?? $row['platform_module_id'] ?? 0),
        'module_name' => $pick($row, ['module_name', 'name', 'module']),
        'module_title' => $pick($row, ['module_display_name', 'display_name', 'title']),
        'status' => $status,
        'status_label' => $statusLabels[$status] ?? $pick($row, ['status_label'], __('未知')),
        'status_class' => $statusClasses[$status] ?? 'bg-secondary',
        'domain' => $pick($row, ['bound_domain', 'domain', 'store_domain']),
        'expires_at' => $pick($row, ['expires_at', 'license_expires_at', 'expired_at']),
        'checked_at' => $pick($row, ['last_checked_at', 'last_validate_at', 'last_validated_at', 'validated_at', 'checked_at']),
        'activated_at' => $pick($row, ['activated_at']),
    ];
}

$totalCount = count($rows);
$activeCount = 0;
$attentionCount = 0;
foreach ($rows as $row) {
    if (in_array($row['status'], ['active', 'valid'], true)) {
        $activeCount++;
        continue;
    }
    $attentionCount++;
}

$accountUrl = $this->getBackendUrl('*/backend/account');
$storeUrl = $this->getBackendUrl('*/backend/index');
$activateAction = $this->getBackendUrl('*/backend/license/activate');
$validateAction = $this->getBackendUrl('*/backend/license/validate');
$renewAction = $this->getBackendUrl('*/backend/license/renew');
?>
<div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1"><?= __('许可证管理') ?></h1>
            <div class="text-muted small"><?= __('统一查看官网账户下发到当前后台的模块许可证。') ?></div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-primary" href="<?= htmlspecialchars($storeUrl, ENT_QUOTES, 'UTF-8') ?>">
                <i class="bi bi-bag me-1"></i><?= __('应用商城') ?>
            </a>
            <a class="btn btn-outline-secondary" href="<?= htmlspecialchars($accountUrl, ENT_QUOTES, 'UTF-8') ?>">
                <i class="bi bi-person-check me-1"></i><?= __('账户授权') ?>
            </a>
        </div>
    </div>

    <?php if (!$isBound): ?>
        <div class="alert alert-warning" role="alert">
            <?= __('请先绑定官网账户后再管理许可证。') ?>
        </div>
    <?php else: ?>
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small"><?= __('许可证总数') ?></div>
                        <div class="display-6 mb-0"><?= (int)$totalCount ?></div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small"><?= __('有效许可证') ?></div>
                        <div class="display-6 mb-0"><?= (int)$activeCount ?></div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="text-muted small"><?= __('需处理许可证') ?></div>
                        <div class="display-6 mb-0"><?= (int)$attentionCount ?></div>
                    </div>
                </div>
            </div>
        </div>
    <?php endif; ?>

    <?php if ($isBound && $rows): ?>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                <tr>
                    <th><?= __('许可证 Key') ?></th>
                    <th><?= __('模块/标题') ?></th>
                    <th><?= __('状态') ?></th>
                    <th><?= __('绑定域名/店铺域名') ?></th>
                    <th><?= __('过期时间') ?></th>
                    <th><?= __('最近校验时间') ?></th>
                    <th><?= __('操作') ?></th>
                </tr>
                </thead>
                <tbody>
                <?php foreach ($rows as $row): ?>
                    <tr>
                        <td>
                            <?php if ($row['license_key'] !== ''): ?>
                                <code><?= htmlspecialchars($row['license_key'], ENT_QUOTES, 'UTF-8') ?></code>
                            <?php else: ?>
                                <span class="text-muted"><?= __('未返回') ?></span>
                            <?php endif; ?>
                        </td>
                        <td>
                            <div class="fw-semibold">
                                <?= htmlspecialchars((string)($row['module_title'] !== '' ? $row['module_title'] : ($row['module_name'] ?: __('未命名模块'))), ENT_QUOTES, 'UTF-8') ?>
                            </div>
                            <?php if ($row['module_name'] !== ''): ?>
                                <div class="text-muted small"><?= htmlspecialchars($row['module_name'], ENT_QUOTES, 'UTF-8') ?></div>
                            <?php endif; ?>
                            <?php if ($row['module_id'] > 0): ?>
                                <div class="text-muted small">#<?= (int)$row['module_id'] ?></div>
                            <?php endif; ?>
                        </td>
                        <td>
                            <span class="badge <?= htmlspecialchars($row['status_class'], ENT_QUOTES, 'UTF-8') ?>">
                                <?= htmlspecialchars((string)$row['status_label'], ENT_QUOTES, 'UTF-8') ?>
                            </span>
                            <?php if ($row['activated_at'] !== ''): ?>
                                <div class="text-muted small mt-1"><?= __('激活：') ?><?= htmlspecialchars($row['activated_at'], ENT_QUOTES, 'UTF-8') ?></div>
                            <?php endif; ?>
                        </td>
                        <td>
                            <?= $row['domain'] !== '' ? htmlspecialchars($row['domain'], ENT_QUOTES, 'UTF-8') : __('未绑定') ?>
                        </td>
                        <td>
                            <?= $row['expires_at'] !== '' ? htmlspecialchars($row['expires_at'], ENT_QUOTES, 'UTF-8') : __('长期有效或未返回') ?>
                        </td>
                        <td>
                            <?= $row['checked_at'] !== '' ? htmlspecialchars($row['checked_at'], ENT_QUOTES, 'UTF-8') : __('未校验') ?>
                        </td>
                        <td>
                            <?php if ($row['license_key'] !== ''): ?>
                                <div class="d-flex flex-wrap gap-2">
                                    <form method="post" action="<?= htmlspecialchars($validateAction, ENT_QUOTES, 'UTF-8') ?>">
                                        <input type="hidden" name="license_key" value="<?= htmlspecialchars($row['license_key'], ENT_QUOTES, 'UTF-8') ?>">
                                        <button class="btn btn-sm btn-outline-primary" type="submit">
                                            <i class="bi bi-shield-check me-1"></i><?= __('校验') ?>
                                        </button>
                                    </form>
                                    <?php if (!in_array($row['status'], ['active', 'valid'], true)): ?>
                                        <form method="post" action="<?= htmlspecialchars($activateAction, ENT_QUOTES, 'UTF-8') ?>">
                                            <input type="hidden" name="license_key" value="<?= htmlspecialchars($row['license_key'], ENT_QUOTES, 'UTF-8') ?>">
                                            <?php if ($row['domain'] !== ''): ?>
                                                <input type="hidden" name="domain" value="<?= htmlspecialchars($row['domain'], ENT_QUOTES, 'UTF-8') ?>">
                                            <?php endif; ?>
                                            <button class="btn btn-sm btn-primary" type="submit">
                                                <i class="bi bi-check-circle me-1"></i><?= __('激活') ?>
                                            </button>
                                        </form>
                                    <?php endif; ?>
                                    <form method="post" action="<?= htmlspecialchars($renewAction, ENT_QUOTES, 'UTF-8') ?>">
                                        <input type="hidden" name="license_key" value="<?= htmlspecialchars($row['license_key'], ENT_QUOTES, 'UTF-8') ?>">
                                        <button class="btn btn-sm btn-outline-secondary" type="submit">
                                            <i class="bi bi-arrow-repeat me-1"></i><?= __('续订') ?>
                                        </button>
                                    </form>
                                </div>
                            <?php else: ?>
                                <span class="text-muted small"><?= __('缺少许可证 Key，无法操作') ?></span>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    <?php elseif ($isBound): ?>
        <div class="card">
            <div class="card-body text-center py-5">
                <h2 class="h5 mb-2"><?= __('暂无许可证') ?></h2>
                <p class="text-muted mb-3"><?= __('当前官网账户还没有返回可管理的许可证。安装免费应用或购买付费应用后刷新本页。') ?></p>
                <a class="btn btn-primary" href="<?= htmlspecialchars($storeUrl, ENT_QUOTES, 'UTF-8') ?>">
                    <i class="bi bi-bag me-1"></i><?= __('去应用商城') ?>
                </a>
            </div>
        </div>
    <?php endif; ?>
</div>
