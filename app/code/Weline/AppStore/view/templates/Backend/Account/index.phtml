<?php
$account = $account ?? null;
$isBound = !empty($is_bound);
$authorizeUrl = (string)($authorize_url ?? '');
$redirectUri = trim((string)($redirect_uri ?? ''));
$platformUrl = trim((string)($platform_url ?? ''));
$bindResult = is_array($bind_result ?? null) ? $bind_result : null;

if (($platformUrl === '' || $redirectUri === '') && $authorizeUrl !== '') {
    $authorizeParts = parse_url($authorizeUrl);
    if ($platformUrl === '' && is_array($authorizeParts) && !empty($authorizeParts['scheme']) && !empty($authorizeParts['host'])) {
        $platformUrl = $authorizeParts['scheme'] . '://' . $authorizeParts['host'];
        if (!empty($authorizeParts['port'])) {
            $platformUrl .= ':' . $authorizeParts['port'];
        }
    }
    if ($redirectUri === '' && is_array($authorizeParts) && !empty($authorizeParts['query'])) {
        parse_str((string)$authorizeParts['query'], $authorizeQuery);
        $redirectUri = trim((string)($authorizeQuery['redirect_uri'] ?? ''));
    }
}
?>
<div class="appstore-backend-page">
    <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mb-3">
        <?php if ($authorizeUrl): ?>
            <a class="btn btn-primary" href="<?= htmlspecialchars($authorizeUrl, ENT_QUOTES, 'UTF-8') ?>" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-shield-check me-1"></i><?= __('去官网授权') ?>
            </a>
        <?php endif; ?>
    </div>

    <?php if ($bindResult): ?>
        <div class="alert <?= !empty($bindResult['success']) ? 'alert-success' : 'alert-danger' ?>" role="alert">
            <?= htmlspecialchars((string)($bindResult['message'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
        </div>
    <?php endif; ?>

    <?php if ($isBound && $account): ?>
        <div class="alert alert-success" role="alert">
            <div class="fw-semibold"><?= __('当前终端已绑定官方账户') ?></div>
            <div><?= __('邮箱：') ?><?= htmlspecialchars((string)($account->getPlatformEmail() ?: __('未知邮箱')), ENT_QUOTES, 'UTF-8') ?></div>
            <div><?= __('名称：') ?><?= htmlspecialchars((string)($account->getPlatformUsername() ?: __('未设置')), ENT_QUOTES, 'UTF-8') ?></div>
            <?php if ($account->getBoundDomain()): ?>
                <div><?= __('店铺域名：') ?><?= htmlspecialchars((string)$account->getBoundDomain(), ENT_QUOTES, 'UTF-8') ?></div>
            <?php endif; ?>
        </div>
    <?php else: ?>
        <div class="alert alert-warning" role="alert">
            <?= __('当前终端尚未绑定官方账户。请点击“去官网授权”，在官网注册或登录后自动回到当前终端。') ?>
        </div>
    <?php endif; ?>

    <div class="card">
        <div class="card-body">
            <h2 class="h6 mb-3"><?= __('授权配置') ?></h2>
            <div class="row gy-2 mb-0">
                <div class="col-sm-2 fw-semibold"><?= __('官网地址') ?></div>
                <div class="col-sm-10">
                    <span class="font-monospace text-break"><?= htmlspecialchars($platformUrl !== '' ? $platformUrl : '-', ENT_QUOTES, 'UTF-8') ?></span>
                </div>
                <div class="col-sm-2 fw-semibold"><?= __('回调地址') ?></div>
                <div class="col-sm-10">
                    <span class="font-monospace text-break"><?= htmlspecialchars($redirectUri !== '' ? $redirectUri : '-', ENT_QUOTES, 'UTF-8') ?></span>
                </div>
            </div>
        </div>
    </div>
</div>
