<?php
/**
 * 订单列表页面
 */
$orders = $this->getData('orders') ?: [];
$page = $this->getData('page') ?: 1;
$pageSize = $this->getData('page_size') ?: 20;
?>
<div class="order-list-page">
    <h1><?= __('我的订单') ?></h1>
    
    <?php if (empty($orders)): ?>
    <div class="empty-state">
        <p><?= __('暂无订单') ?></p>
    </div>
    <?php else: ?>
    <div class="order-list">
        <?php foreach ($orders as $order): ?>
        <div class="order-item">
            <div class="order-header">
                <div class="order-number">
                    <span><?= __('订单号') ?>: <?= $this->escapeHtml($order['order_number']) ?></span>
                </div>
                <div class="order-status">
                    <span class="status-badge status-<?= $this->escapeHtml($order['status']) ?>">
                        <?= $this->escapeHtml($order['status_text'] ?? $order['status']) ?>
                    </span>
                </div>
            </div>
            
            <div class="order-body">
                <div class="order-info">
                    <div class="info-item">
                        <span><?= __('订单总额') ?>:</span>
                        <strong><?= $this->escapeHtml($order['currency']) ?> <?= number_format($order['total_amount'], 2) ?></strong>
                    </div>
                    <div class="info-item">
                        <span><?= __('支付状态') ?>:</span>
                        <span><?= $this->escapeHtml($order['payment_status_text'] ?? $order['payment_status']) ?></span>
                    </div>
                    <div class="info-item">
                        <span><?= __('创建时间') ?>:</span>
                        <span><?= $this->escapeHtml($order['created_time']) ?></span>
                    </div>
                </div>
                
                <div class="order-actions">
                    <a href="<?= $this->getUrl('weline_checkout/frontend/order/view', ['order_id' => $order['order_id']]) ?>" class="btn btn-sm btn-primary">
                        <?= __('查看详情') ?>
                    </a>
                    <?php if ($order['status'] === 'pending' || $order['status'] === 'processing'): ?>
                    <button type="button" class="btn btn-sm btn-danger cancel-order" data-order-id="<?= $order['order_id'] ?>">
                        <?= __('取消订单') ?>
                    </button>
                    <?php endif; ?>
                </div>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>
</div>

<?php
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
?>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var orderApiPromise = null;
    var cancelOrderConfirmMessage = <?= json_encode((string)__('确定要取消此订单吗？'), $jsonForScriptFlags) ?>;
    var cancelOrderConfirmText = <?= json_encode((string)__('确定取消'), $jsonForScriptFlags) ?>;
    var cancelOrderDismissText = <?= json_encode((string)__('保留订单'), $jsonForScriptFlags) ?>;
    var cancelOrderFailedMessage = <?= json_encode((string)__('取消订单失败，请稍后重试'), $jsonForScriptFlags) ?>;

    function getOrderApi() {
        if (!orderApiPromise) {
            orderApiPromise = Promise.resolve(window.Weline.Api.resource('order'));
        }

        return orderApiPromise;
    }

    function showOrderMessage(type, message) {
        var toast = window.FrontendToast || window.BackendToast || null;
        if (toast && typeof toast[type] === 'function') {
            toast[type](message);
            return;
        }
        if (type === 'error') {
            console.error(message);
        } else {
            console.log(message);
        }
    }

    function confirmCancelOrder(button, message) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            return window.BackendConfirm.show(message);
        }

        return new Promise(function(resolve) {
            var existing = document.querySelector('.cancel-order-confirm');
            if (existing) {
                existing.remove();
            }

            var panel = document.createElement('div');
            panel.className = 'alert alert-warning mt-2 mb-0 cancel-order-confirm';

            var text = document.createElement('span');
            text.textContent = message;

            var actions = document.createElement('span');
            actions.className = 'd-inline-flex gap-2 ms-2';

            var confirmButton = document.createElement('button');
            confirmButton.type = 'button';
            confirmButton.className = 'btn btn-sm btn-danger';
            confirmButton.textContent = cancelOrderConfirmText;

            var cancelButton = document.createElement('button');
            cancelButton.type = 'button';
            cancelButton.className = 'btn btn-sm btn-outline-secondary';
            cancelButton.textContent = cancelOrderDismissText;

            confirmButton.addEventListener('click', function() {
                panel.remove();
                resolve(true);
            });
            cancelButton.addEventListener('click', function() {
                panel.remove();
                resolve(false);
            });

            actions.appendChild(confirmButton);
            actions.appendChild(cancelButton);
            panel.appendChild(text);
            panel.appendChild(actions);
            button.insertAdjacentElement('afterend', panel);
        });
    }

    // 取消订单
    document.querySelectorAll('.cancel-order').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const orderId = this.getAttribute('data-order-id');
            confirmCancelOrder(this, cancelOrderConfirmMessage).then(function(confirmed) {
                if (!confirmed) {
                    return;
                }
                // 发送取消请求
                getOrderApi()
                .then(OrderApi => OrderApi.cancel({order_id: parseInt(orderId, 10)}, {silent: true}))
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        showOrderMessage('error', data.message || cancelOrderFailedMessage);
                    }
                })
                .catch(error => {
                    showOrderMessage('error', (error && error.message) || cancelOrderFailedMessage);
                });
            });
        });
    });
});
</script>
