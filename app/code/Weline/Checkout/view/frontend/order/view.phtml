<?php
/**
 * 订单详情页面
 */
$order = $this->getData('order');
if (!$order) {
    return;
}
$items = $order->getItems();
?>
<div class="order-view-page">
    <h1><?= __('订单详情') ?></h1>
    
    <div class="order-info-section">
        <h2><?= __('订单信息') ?></h2>
        <div class="info-grid">
            <div class="info-item">
                <span class="label"><?= __('订单号') ?>:</span>
                <span class="value"><?= $this->escapeHtml($order->getOrderNumber()) ?></span>
            </div>
            <div class="info-item">
                <span class="label"><?= __('订单状态') ?>:</span>
                <span class="value"><?= $order->getStatusText() ?></span>
            </div>
            <div class="info-item">
                <span class="label"><?= __('支付状态') ?>:</span>
                <span class="value"><?= $order->getPaymentStatusText() ?></span>
            </div>
            <div class="info-item">
                <span class="label"><?= __('配送状态') ?>:</span>
                <span class="value"><?= $order->getShippingStatusText() ?></span>
            </div>
            <div class="info-item">
                <span class="label"><?= __('创建时间') ?>:</span>
                <span class="value"><?= $this->escapeHtml($order->getCreatedTime()) ?></span>
            </div>
        </div>
    </div>
    
    <div class="order-items-section">
        <h2><?= __('订单项') ?></h2>
        <table class="order-items-table">
            <thead>
                <tr>
                    <th><?= __('产品名称') ?></th>
                    <th><?= __('SKU') ?></th>
                    <th><?= __('数量') ?></th>
                    <th><?= __('单价') ?></th>
                    <th><?= __('总价') ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($items as $item): ?>
                <tr>
                    <td><?= $this->escapeHtml($item['product_name']) ?></td>
                    <td><?= $this->escapeHtml($item['product_sku']) ?></td>
                    <td><?= $this->escapeHtml($item['quantity']) ?></td>
                    <td><?= number_format($item['price'], 2) ?></td>
                    <td><?= number_format($item['total_price'], 2) ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    
    <div class="order-totals-section">
        <h2><?= __('费用明细') ?></h2>
        <div class="totals">
            <div class="total-row">
                <span><?= __('商品小计') ?>:</span>
                <span><?= $this->escapeHtml($order->getCurrency()) ?> <?= number_format($order->getSubtotal(), 2) ?></span>
            </div>
            <div class="total-row">
                <span><?= __('运费') ?>:</span>
                <span><?= $this->escapeHtml($order->getCurrency()) ?> <?= number_format($order->getShippingAmount(), 2) ?></span>
            </div>
            <div class="total-row">
                <span><?= __('税费') ?>:</span>
                <span><?= $this->escapeHtml($order->getCurrency()) ?> <?= number_format($order->getTaxAmount(), 2) ?></span>
            </div>
            <div class="total-row">
                <span><?= __('折扣') ?>:</span>
                <span>-<?= $this->escapeHtml($order->getCurrency()) ?> <?= number_format($order->getDiscountAmount(), 2) ?></span>
            </div>
            <div class="total-row total">
                <span><?= __('订单总额') ?>:</span>
                <strong><?= $this->escapeHtml($order->getCurrency()) ?> <?= number_format($order->getTotalAmount(), 2) ?></strong>
            </div>
        </div>
    </div>
    
    <div class="order-actions">
        <a href="<?= $this->getUrl('weline_checkout/frontend/order/list') ?>" class="btn btn-secondary">
