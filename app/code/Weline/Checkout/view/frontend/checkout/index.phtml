<script>
(function () {
    'use strict';

    const copy = <?= json_encode($copy, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    const root = document.querySelector('[data-weline-checkout]');
    if (!root) {
        return;
    }

    const form = root.querySelector('[data-checkout-form]');
    const message = root.querySelector('[data-checkout-message]');
    const submitButton = root.querySelector('[data-submit]');
    const shippingBox = root.querySelector('[data-shipping-methods]');
    const paymentBox = root.querySelector('[data-payment-methods]');
    const itemsBox = root.querySelector('[data-cart-items]');
    const subtotalNode = root.querySelector('[data-subtotal]');
    const shippingAmountNode = root.querySelector('[data-shipping-amount]');
    const grandTotalNode = root.querySelector('[data-grand-total]');

    let checkoutApi = null;
    let checkoutState = {
        currency: 'CNY',
        cart: {},
        shippingMethods: [],
        paymentMethods: [],
    };

    function text(value) {
        return value == null ? '' : String(value);
    }

    function setMessage(value, type) {
        message.textContent = text(value);
        message.classList.toggle('is-error', type === 'error');
        message.classList.toggle('is-success', type === 'success');
    }

    function money(amount) {
        const currency = checkoutState.currency || 'CNY';
        return currency + ' ' + Number(amount || 0).toFixed(2);
    }

    function formAddress() {
        const data = new FormData(form);
        return {
            name: text(data.get('name')).trim(),
            phone: text(data.get('phone')).trim(),
            email: text(data.get('email')).trim(),
            country_code: text(data.get('country_code')).trim().toUpperCase() || 'CN',
            province: text(data.get('province')).trim(),
            city: text(data.get('city')).trim(),
            address1: text(data.get('address1')).trim(),
            postal_code: text(data.get('postal_code')).trim(),
        };
    }

    function selectedValue(name) {
        const checked = form.querySelector('input[name="' + name + '"]:checked');
        return checked ? checked.value : '';
    }

    function selectedShippingAmount() {
        const code = selectedValue('shipping_method');
        const method = checkoutState.shippingMethods.find(function (entry) {
            return entry && entry.code === code;
        });
        return method ? Number(method.amount || method.fee || 0) : 0;
    }

    function renderItems(items) {
        itemsBox.innerHTML = '';
        if (!items.length) {
            const empty = document.createElement('p');
            empty.textContent = copy.empty_cart;
            itemsBox.appendChild(empty);
            return;
        }
        items.forEach(function (item) {
            const row = document.createElement('div');
            row.className = 'weline-checkout__item';
            const info = document.createElement('div');
            const title = document.createElement('strong');
            title.textContent = text(item.name || item.product_name);
            const meta = document.createElement('small');
            meta.textContent = 'x' + Number(item.qty || item.quantity || 1);
            info.appendChild(title);
            info.appendChild(meta);
            const total = document.createElement('span');
            total.textContent = money(item.row_total || (Number(item.price || 0) * Number(item.qty || item.quantity || 1)));
            row.appendChild(info);
            row.appendChild(total);
            itemsBox.appendChild(row);
        });
    }

    function renderMethods(container, methods, name) {
        container.innerHTML = '';
        if (!methods.length) {
            const empty = document.createElement('p');
            empty.textContent = name === 'shipping_method'
                ? '<?= __('暂无可用配送方式。') ?>'
                : '<?= __('暂无可用支付方式。') ?>';
            container.appendChild(empty);
            return;
        }
        methods.forEach(function (method, index) {
            const label = document.createElement('label');
            label.className = 'weline-checkout__option';
            const input = document.createElement('input');
            input.type = 'radio';
            input.name = name;
            input.value = text(method.code);
            input.checked = index === 0;
            const body = document.createElement('span');
            const title = document.createElement('strong');
            title.textContent = text(method.label || method.title || method.code);
            const meta = document.createElement('small');
            meta.textContent = text(method.description || method.eta_label || method.source || '');
            body.appendChild(title);
            if (meta.textContent) {
                body.appendChild(meta);
            }
            const price = document.createElement('span');
            price.textContent = name === 'shipping_method' ? money(method.amount || method.fee || 0) : '';
            label.appendChild(input);
            label.appendChild(body);
            label.appendChild(price);
            container.appendChild(label);
        });
    }

    function renderTotals() {
        const subtotal = Number(checkoutState.cart.subtotal || 0);
        const shipping = selectedShippingAmount();
        subtotalNode.textContent = money(subtotal);
        shippingAmountNode.textContent = money(shipping);
        grandTotalNode.textContent = money(subtotal + shipping);
    }

    function render(data) {
        checkoutState.currency = text(data.currency || data.cart && data.cart.currency || 'CNY') || 'CNY';
        checkoutState.cart = data.cart || {};
        checkoutState.shippingMethods = Array.isArray(data.shipping_methods) ? data.shipping_methods : [];
        checkoutState.paymentMethods = Array.isArray(data.payment_methods) ? data.payment_methods : [];
        renderItems(Array.isArray(data.items) ? data.items : []);
        renderMethods(shippingBox, checkoutState.shippingMethods, 'shipping_method');
        renderMethods(paymentBox, checkoutState.paymentMethods, 'payment_method');
        renderTotals();
        submitButton.disabled = Boolean(checkoutState.cart.is_empty) || !checkoutState.shippingMethods.length || !checkoutState.paymentMethods.length;
        if (checkoutState.cart.is_empty) {
            setMessage(copy.empty_cart, 'error');
        } else {
            setMessage('<?= __('请确认收货信息、配送方式和支付方式。') ?>', 'success');
        }
    }

    async function getApi() {
        if (checkoutApi) {
            return checkoutApi;
        }
        if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
            throw new Error(copy.api_missing);
        }
        checkoutApi = await window.Weline.Api.resource('checkout');
        return checkoutApi;
    }

    async function loadCheckout() {
        const api = await getApi();
        const data = await api.getData({ shipping_address: formAddress() });
        render(data || {});
    }

    let reloadTimer = null;
    function scheduleReload() {
        window.clearTimeout(reloadTimer);
        reloadTimer = window.setTimeout(function () {
            loadCheckout().catch(function (error) {
                setMessage(error.message || copy.load_failed, 'error');
            });
        }, 350);
    }

    form.addEventListener('change', function (event) {
        if (event.target && event.target.name === 'shipping_method') {
            renderTotals();
            return;
        }
        if (event.target && ['country_code', 'province', 'city', 'postal_code'].indexOf(event.target.name) !== -1) {
            scheduleReload();
        }
    });

    form.addEventListener('submit', async function (event) {
        event.preventDefault();
        if (!form.reportValidity()) {
            setMessage(copy.required, 'error');
            return;
        }
        const shippingMethod = selectedValue('shipping_method');
        const paymentMethod = selectedValue('payment_method');
        if (!shippingMethod || !paymentMethod) {
            setMessage(copy.required, 'error');
            return;
        }
        submitButton.disabled = true;
        submitButton.textContent = copy.submitting;
        setMessage(copy.submitting, '');
        try {
            const api = await getApi();
            const result = await api.placeOrder({
                shipping_address: formAddress(),
                shipping_method: shippingMethod,
                payment_method: paymentMethod,
            });
            const redirect = text(result && result.redirect);
            if (redirect) {
                setMessage(result.requires_action ? copy.payment_redirect : copy.payment_pending, 'success');
                window.location.href = redirect;
                return;
            }
            setMessage(copy.payment_pending, 'success');
        } catch (error) {
            setMessage(error.message || copy.load_failed, 'error');
            submitButton.disabled = false;
            submitButton.textContent = copy.submit;
        }
    });

    shippingBox.addEventListener('change', renderTotals);

    loadCheckout().catch(function (error) {
        setMessage(error.message || copy.load_failed, 'error');
        submitButton.disabled = true;
    });
})();
</script>
