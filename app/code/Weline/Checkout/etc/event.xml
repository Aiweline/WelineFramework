<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 订单创建后观察者示例 -->
    <event name="Weline_Checkout::checkout::create_order::after">
        <observer name="Weline_Checkout::checkout_order_created_observer" 
                  instance="Weline\Checkout\Observer\CheckoutOrderCreatedObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- 订单状态变更后观察者示例 -->
    <event name="Weline_Checkout::order::status::change::after">
        <observer name="Weline_Checkout::order_status_changed_observer" 
                  instance="Weline\Checkout\Observer\OrderStatusChangedObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
</config>

