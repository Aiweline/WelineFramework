    <script src="/static/Weline_Frontend/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="/static/Weline_Frontend/libs/bootstrap-5.1.3-dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            // 侧边栏导航
            $('.sidebar .nav-link[data-section]').on('click', function(e) {
                e.preventDefault();
                const section = $(this).data('section');
                
                // 更新激活状态
                $('.sidebar .nav-link').removeClass('active');
                $(this).addClass('active');
                
                // 切换内容区
                $('.content-section').addClass('d-none');
                $(`#${section}-section`).removeClass('d-none');
            });

            // 个人资料表单提交
            $('#profileForm').on('submit', function(e) {
                e.preventDefault();
                
                const $successMsg = $('#profileSuccessMsg');
                const $errorMsg = $('#profileErrorMsg');
                
                $successMsg.addClass('d-none');
                $errorMsg.addClass('d-none');

                $.ajax({
                    url: '/frontend/account/update',
                    method: 'POST',
                    data: $(this).serialize(),
                    dataType: 'json',
                    success: function(response) {
                        if (response.success) {
                            $successMsg.text(response.message).removeClass('d-none');
                            setTimeout(() => $successMsg.addClass('d-none'), 3000);
                        } else {
                            $errorMsg.text(response.message).removeClass('d-none');
                        }
                    },
                    error: function() {
                        $errorMsg.text('更新失败，请稍后重试').removeClass('d-none');
                    }
                });
            });

            // 安全设置表单提交
            $('#securityForm').on('submit', function(e) {
                e.preventDefault();
                
                const $successMsg = $('#securitySuccessMsg');
                const $errorMsg = $('#securityErrorMsg');
                const newPassword = $('#new_password').val();
                const confirmPassword = $('#confirm_password').val();
                
                $successMsg.addClass('d-none');
                $errorMsg.addClass('d-none');

                // 验证密码
                if (newPassword !== confirmPassword) {
                    $errorMsg.text('两次输入的新密码不一致').removeClass('d-none');
                    return;
                }

                $.ajax({
                    url: '/frontend/account/update',
                    method: 'POST',
                    data: $(this).serialize(),
                    dataType: 'json',
                    success: function(response) {
                        if (response.success) {
                            $successMsg.text(response.message).removeClass('d-none');
                            $('#securityForm')[0].reset();
                            setTimeout(() => $successMsg.addClass('d-none'), 3000);
                        } else {
                            $errorMsg.text(response.message).removeClass('d-none');
                        }
                    },
                    error: function() {
                        $errorMsg.text('修改失败，请稍后重试').removeClass('d-none');
                    }
                });
            });
        });
    </script>
