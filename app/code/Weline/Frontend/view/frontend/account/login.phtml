<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>用户登录 - Weline Framework</title>
    <link href="/static/Weline_Frontend/libs/bootstrap-5.1.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/static/Weline_Frontend/assets/css/icons.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #5156be;
            --primary-dark: #3f44a8;
            --success-color: #34c38f;
            --danger-color: #f46a6a;
            --body-bg: #f8f9fa;
            --card-shadow: 0 0.75rem 1.5rem rgba(18,38,63,.03);
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .auth-card {
            max-width: 450px;
            width: 100%;
            margin: 2rem;
        }

        .card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0,0,0,.15);
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem;
            border: none;
            text-align: center;
        }

        .card-header h4 {
            margin: 0;
            font-weight: 600;
            font-size: 1.5rem;
        }

        .card-header p {
            margin: 0.5rem 0 0;
            opacity: 0.9;
            font-size: 0.9rem;
        }

        .card-body {
            padding: 2.5rem;
        }

        .form-label {
            font-weight: 500;
            color: #495057;
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            border: 1px solid #e0e6ed;
            transition: all 0.3s ease;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(81,86,190,.15);
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102,126,234,.4);
        }

        .form-check-input:checked {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .text-link {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .text-link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        .alert {
            border-radius: 0.5rem;
            border: none;
        }

        .logo-section {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .logo-section img {
            max-width: 80px;
            margin-bottom: 1rem;
        }

        @media (max-width: 576px) {
            .card-body {
                padding: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <h4>欢迎回来</h4>
                <p>登录您的账户</p>
            </div>
            <div class="card-body">
                <div class="alert alert-danger d-none" id="errorMessage" role="alert"></div>

                <form id="loginForm">
                    <div class="mb-3">
                        <label for="username" class="form-label">用户名</label>
                        <input type="text" class="form-control" id="username" name="username" 
                               placeholder="请输入用户名" required autocomplete="username">
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">密码</label>
                        <input type="password" class="form-control" id="password" name="password" 
                               placeholder="请输入密码" required autocomplete="current-password">
                    </div>

                    <div class="mb-3">
                        <label for="remember_duration" class="form-label">记住登录状态</label>
                        <select class="form-select" id="remember_duration" name="remember_duration">
                            <option value="0">本次会话（关闭浏览器后失效）</option>
                            <option value="21600">6小时</option>
                            <option value="86400">1天</option>
                            <option value="604800" selected>1周</option>
                            <option value="2592000">1个月</option>
                        </select>
                        <small class="text-muted">选择自动登录的有效期</small>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg" id="loginBtn">
                            <span id="loginText">登录</span>
                            <span id="loginSpinner" class="spinner-border spinner-border-sm d-none" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </span>
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="mb-0">还没有账户？ <a href="/frontend/account/register" class="text-link">立即注册</a></p>
                </div>
            </div>
        </div>

        <div class="text-center mt-3">
            <p class="text-white mb-0" style="text-shadow: 0 2px 4px rgba(0,0,0,.2);">
                <small>&copy; 2025 Weline Framework. All rights reserved.</small>
            </p>
        </div>
    </div>

    <script src="/static/Weline_Frontend/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="/static/Weline_Frontend/libs/bootstrap-5.1.3-dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#loginForm').on('submit', function(e) {
                e.preventDefault();

                const $form = $(this);
                const $errorMsg = $('#errorMessage');
                const $loginBtn = $('#loginBtn');
                const $loginText = $('#loginText');
                const $loginSpinner = $('#loginSpinner');

                // 隐藏错误信息
                $errorMsg.addClass('d-none');

                // 显示加载状态
                $loginBtn.prop('disabled', true);
                $loginText.addClass('d-none');
                $loginSpinner.removeClass('d-none');

                $.ajax({
                    url: '/frontend/account/login',
                    method: 'POST',
                    data: $form.serialize(),
                    dataType: 'json',
                    success: function(response) {
                        if (response.success) {
                            // 登录成功
                            window.location.href = response.redirect || '/frontend/account';
                        } else {
                            // 显示错误信息
                            $errorMsg.text(response.message).removeClass('d-none');
                            $loginBtn.prop('disabled', false);
                            $loginText.removeClass('d-none');
                            $loginSpinner.addClass('d-none');
                        }
                    },
                    error: function() {
                        $errorMsg.text('登录请求失败，请稍后重试').removeClass('d-none');
                        $loginBtn.prop('disabled', false);
                        $loginText.removeClass('d-none');
                        $loginSpinner.addClass('d-none');
                    }
                });
            });

            // 回车提交
            $('#username, #password').on('keypress', function(e) {
                if (e.which === 13) {
                    $('#loginForm').submit();
                }
            });
        });
    </script>
</body>
</html>

