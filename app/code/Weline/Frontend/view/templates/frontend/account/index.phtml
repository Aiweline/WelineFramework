<script>
$(document).ready(function() {
    // 侧边栏导航
    $('.account-sidebar .nav-link[data-section]').on('click', function(e) {
        e.preventDefault();
        const section = $(this).data('section');
        
        // 更新激活状态
        $('.account-sidebar .nav-link').removeClass('active');
        $(this).addClass('active');
        
        // 切换内容区
        $('.content-section').addClass('d-none');
        $(`#${section}-section`).removeClass('d-none');
    });

    // 个人资料表单提交
    $('#profileForm').on('submit', function(e) {
        e.preventDefault();
        
        const $successMsg = $('#profileSuccessMsg');
        const $errorMsg = $('#profileErrorMsg');
        
        $successMsg.addClass('d-none');
        $errorMsg.addClass('d-none');

        $.ajax({
            url: '/frontend/account/update',
            method: 'POST',
            data: $(this).serialize(),
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    $successMsg.text(response.message).removeClass('d-none');
                    setTimeout(() => $successMsg.addClass('d-none'), 3000);
                } else {
                    $errorMsg.text(response.message).removeClass('d-none');
                }
            },
            error: function() {
                $errorMsg.text('<?= __('更新失败，请稍后重试') ?>').removeClass('d-none');
            }
        });
    });

    // 安全设置表单提交
    $('#securityForm').on('submit', function(e) {
        e.preventDefault();
        
        const $successMsg = $('#securitySuccessMsg');
        const $errorMsg = $('#securityErrorMsg');
        const newPassword = $('#new_password').val();
        const confirmPassword = $('#confirm_password').val();
        
        $successMsg.addClass('d-none');
        $errorMsg.addClass('d-none');

        // 验证密码
        if (newPassword !== confirmPassword) {
            $errorMsg.text('<?= __('两次输入的新密码不一致') ?>').removeClass('d-none');
            return;
        }

        $.ajax({
            url: '/frontend/account/update',
            method: 'POST',
            data: $(this).serialize(),
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    $successMsg.text(response.message).removeClass('d-none');
                    $('#securityForm')[0].reset();
                    setTimeout(() => $successMsg.addClass('d-none'), 3000);
                } else {
                    $errorMsg.text(response.message).removeClass('d-none');
                }
            },
            error: function() {
                $errorMsg.text('<?= __('修改失败，请稍后重试') ?>').removeClass('d-none');
            }
        });
    });
    
    // 头像预览功能
    $('#previewAvatarBtn').on('click', function() {
        const avatarUrl = $('#avatar').val();
        if (!avatarUrl) {
            alert('<?= __('请输入头像URL') ?>');
            return;
        }
        
        // 验证URL格式
        try {
            new URL(avatarUrl);
        } catch (e) {
            alert('<?= __('请输入有效的URL地址') ?>');
            return;
        }
        
        // 更新预览
        const $preview = $('#avatarPreview');
        const $fallback = $('#avatarFallback');
        
        $preview.attr('src', avatarUrl);
        $preview.css('display', 'block');
        $fallback.css('display', 'none');
        
        // 如果图片加载失败，显示回退
        $preview.on('error', function() {
            $(this).css('display', 'none');
            $fallback.css('display', 'flex');
        });
    });
    
    // 头像输入框变化时自动更新预览
    $('#avatar').on('blur', function() {
        const avatarUrl = $(this).val();
        if (avatarUrl) {
            try {
                new URL(avatarUrl);
                $('#previewAvatarBtn').click();
            } catch (e) {
                // URL格式无效，不更新预览
            }
        }
    });
});
</script>

