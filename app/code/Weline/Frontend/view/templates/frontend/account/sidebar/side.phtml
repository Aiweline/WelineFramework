<?php
/**@var \Weline\Framework\View\Template $this */
/**@var \Weline\Frontend\Model\FrontendUser $user */
$avatar = $user->getAvatar();
$username = $user->getUsername();
$email = $user->getEmail();
$avatarInitial = strtoupper(mb_substr($username, 0, 1));
?>
<!-- 侧边栏导航 -->
<div class="sidebar-header">
        <div class="sidebar-avatar">
            <?php if ($avatar): ?>
                <img src="<?= htmlspecialchars($avatar) ?>" alt="<?= htmlspecialchars($username) ?>" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="avatar-fallback"><?= $avatarInitial ?></div>
            <?php else: ?>
                <div class="avatar-fallback"><?= $avatarInitial ?></div>
            <?php endif; ?>
        </div>
        <div class="sidebar-user-info">
            <h4><?= htmlspecialchars($username) ?></h4>
            <?php if ($email): ?>
                <p class="text-muted"><?= htmlspecialchars($email) ?></p>
            <?php endif; ?>
        </div>
    </div>
    <nav class="nav flex-column">
        <a class="nav-link active" href="#profile" data-section="profile">
            <i class="ri-user-line"></i> <span><?= __('个人资料') ?></span>
