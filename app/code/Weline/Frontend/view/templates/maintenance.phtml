<div class='py-5'>
    <!-- 版心容器 -->
    <div class='maintenance-wrapper'>
        <!-- 右上角语言选择器Hook -->
        <div class='maintenance-header'>
            <div class='maintenance-language-switcher'>
                <?php
                // 尝试渲染hook - 使用 try-catch 避免报错
                try {
                    $hookContent = '';
                    if (isset($this) && is_object($this) && method_exists($this, 'getHook')) {
                        $hookContent = $this->getHook('header-language-switcher') ?? '';
                    }
                    
                    if (!empty(trim($hookContent))) {
                        echo $hookContent;
                    } else {
                        // 如果没有hook实现，显示简单的语言选择器
                        $currentLang = 'zh_Hans_CN';
                        try {
                            if (class_exists('\Weline\Framework\App\State')) {
                                $currentLang = \Weline\Framework\App\State::getLang() ?? 'zh_Hans_CN';
                            }
                        } catch (\Exception $e) {
                            // 忽略错误，使用默认值
                        }
                        
                        $langParts = explode('_', $currentLang);
                        $langDisplay = strtoupper($langParts[0] ?? 'ZH');
                        if ($langDisplay === 'ZH' && isset($langParts[1]) && $langParts[1] === 'Hant') {
                            $langDisplay = 'TW';
                        }
                        ?>
                        <div class="language-switcher" role="button" tabindex="0">
                            <span class="action-line-2">
                                <i class="fas fa-globe" aria-hidden="true"></i>
                                <span class="current-language"><?= htmlspecialchars($langDisplay) ?></span>
                                <i class="fas fa-chevron-down" aria-hidden="true"></i>
                            </span>
                            <div class="language-options" role="menu">
                                <a href="?lang=zh_Hans_CN" class="language-option <?= $currentLang === 'zh_Hans_CN' ? 'active' : '' ?>" data-lang="zh_Hans_CN">
                                    <span>简体中文</span>
                                    <i class="fas fa-check" aria-hidden="true"></i>
                                </a>
                                <a href="?lang=en_US" class="language-option <?= $currentLang === 'en_US' ? 'active' : '' ?>" data-lang="en_US">
                                    <span>English</span>
                                    <i class="fas fa-check" aria-hidden="true"></i>
                                </a>
                                <a href="?lang=zh_Hant_TW" class="language-option <?= $currentLang === 'zh_Hant_TW' ? 'active' : '' ?>" data-lang="zh_Hant_TW">
                                    <span>繁體中文</span>
                                    <i class="fas fa-check" aria-hidden="true"></i>
                                </a>
                            </div>
                        </div>
                        <?php
                    }
                } catch (\Exception $e) {
                    // 如果所有方法都失败，显示最简单的语言选择器
                    ?>
                    <div class="language-switcher" role="button" tabindex="0">
                        <span class="action-line-2">
                            <i class="fas fa-globe" aria-hidden="true"></i>
                            <span class="current-language">ZH</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </span>
                        <div class="language-options" role="menu">
                            <a href="?lang=zh_Hans_CN" class="language-option active" data-lang="zh_Hans_CN">
                                <span>简体中文</span>
                                <i class="fas fa-check" aria-hidden="true"></i>
                            </a>
                            <a href="?lang=en_US" class="language-option" data-lang="en_US">
                                <span>English</span>
                                <i class="fas fa-check" aria-hidden="true"></i>
                            </a>
                            <a href="?lang=zh_Hant_TW" class="language-option" data-lang="zh_Hant_TW">
                                <span>繁體中文</span>
                                <i class="fas fa-check" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                    <?php
                }
                ?>
