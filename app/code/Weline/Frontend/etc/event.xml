<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <event name="Framework_View::header">
        <observer name="Weline_Frontend::header" instance="Weline\Frontend\Observer\Header" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Framework_View::footer">
        <observer name="Weline_Frontend::footer" instance="Weline\Frontend\Observer\Footer" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Resource::compiler">
        <observer name="Weline_Frontend::compiler" instance="Weline\Frontend\Observer\Compiler" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Maintenance::maintenance">
        <observer name="Weline_Frontend::maintenance" instance="Weline\Frontend\Observer\Maintenance" disabled="false" shared="true" sort="0"/>
    </event>
    <!-- Framework_Http::response_redirect_before -->
    <event name="Framework_Http::response_redirect_before">
        <observer name="Weline_Frontend::response_redirect_before" instance="Weline\Frontend\Observer\ResponseRedirectBefore" disabled="false" shared="true" sort="0"/>
    </event>
    <!-- 前端控制器初始化之前自动登录 -->
    <event name="Weline_Framework_FrontendController::init_before">
        <observer name="Weline_Frontend::auto_login" instance="Weline\Frontend\Observer\AutoLogin" disabled="false" shared="true" sort="0"/>
    </event>
</config>