    <script>
    (function() {
        const formKey = '<?= $form_key ?>';
        const baseUrl = '<?= $this->getUrl('install') ?>';
        let currentStep = 'env';
        let envPassed = false;
        
        // DOM 元素
        const terminal = document.getElementById('terminal');
        const btnCheckEnv = document.getElementById('btn-check-env');
        const btnFixEnv = document.getElementById('btn-fix-env');
        const btnNextDb = document.getElementById('btn-next-db');
        const btnTestDb = document.getElementById('btn-test-db');
        const btnNextAdmin = document.getElementById('btn-next-admin');
        const btnComplete = document.getElementById('btn-complete');
        const dbType = document.getElementById('db-type');
        const dbMessage = document.getElementById('db-message');
        const installMessage = document.getElementById('install-message');
        const messages = {
            startEnvCheck: <?= json_encode((string)__('开始环境检测...'), $jsonForScriptFlags) ?>,
            envPassed: <?= json_encode((string)__('环境检测通过 ✓'), $jsonForScriptFlags) ?>,
            envFailed: <?= json_encode((string)__('环境检测未通过'), $jsonForScriptFlags) ?>,
            passed: <?= json_encode((string)__('通过'), $jsonForScriptFlags) ?>,
            failed: <?= json_encode((string)__('未通过'), $jsonForScriptFlags) ?>,
            missingExtensions: <?= json_encode((string)__('缺失扩展'), $jsonForScriptFlags) ?>,
            disabledFunctions: <?= json_encode((string)__('被禁用函数'), $jsonForScriptFlags) ?>,
            checkFailed: <?= json_encode((string)__('检测失败'), $jsonForScriptFlags) ?>,
            requestFailed: <?= json_encode((string)__('请求失败'), $jsonForScriptFlags) ?>,
            startEnvFix: <?= json_encode((string)__('开始环境修复...'), $jsonForScriptFlags) ?>,
            guideLocation: <?= json_encode((string)__('位置'), $jsonForScriptFlags) ?>,
            guideAction: <?= json_encode((string)__('操作'), $jsonForScriptFlags) ?>,
            fixCompleted: <?= json_encode((string)__('修复完成'), $jsonForScriptFlags) ?>,
            manualFixNeeded: <?= json_encode((string)__('部分问题仍需手动处理'), $jsonForScriptFlags) ?>,
            streamInterrupted: <?= json_encode((string)__('连接中断'), $jsonForScriptFlags) ?>,
            testing: <?= json_encode((string)__('测试中...'), $jsonForScriptFlags) ?>,
            testConnection: <?= json_encode((string)__('测试连接'), $jsonForScriptFlags) ?>,
            connectionSuccess: <?= json_encode((string)__('连接成功！'), $jsonForScriptFlags) ?>,
            connectionFailed: <?= json_encode((string)__('连接失败'), $jsonForScriptFlags) ?>,
            installing: <?= json_encode((string)__('安装中...'), $jsonForScriptFlags) ?>,
            installFailed: <?= json_encode((string)__('安装失败'), $jsonForScriptFlags) ?>,
            completeInstall: <?= json_encode((string)__('完成安装'), $jsonForScriptFlags) ?>,
            adminKey: <?= json_encode((string)__('后台入口密钥'), $jsonForScriptFlags) ?>,
            apiAdminKey: <?= json_encode((string)__('API 后台密钥'), $jsonForScriptFlags) ?>,
            adminUrl: <?= json_encode((string)__('后台地址'), $jsonForScriptFlags) ?>
        };
        
        // 终端输出
        function terminalLog(msg, type = 'info') {
            const line = document.createElement('div');
            line.className = 'terminal-line ' + type;
            line.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;
            terminal.appendChild(line);
            terminal.scrollTop = terminal.scrollHeight;
        }

        function setInlineMessage(element, message, type = 'info') {
            if (!element) {
                return;
            }

            element.textContent = message || '';
            element.className = 'inline-message ' + type;
            element.hidden = !message;
            element.setAttribute('role', type === 'error' ? 'alert' : 'status');
        }

        function appendErrorDetail(prefix, detail) {
            return detail ? prefix + ': ' + detail : prefix;
        }

        function setEnvStatus(label, type, mark) {
            const envStatus = document.getElementById('env-status');
            if (!envStatus) {
                return;
            }

            envStatus.innerHTML = '';
            const badge = document.createElement('span');
            badge.className = 'status-badge ' + type;
            badge.textContent = mark + ' ' + label;
            envStatus.appendChild(badge);
        }

        function renderCompleteInfo(info) {
            const completeInfo = document.getElementById('complete-info');
            if (!completeInfo) {
                return;
            }

            completeInfo.innerHTML = '';
            [
                [messages.adminKey, info.admin_key],
                [messages.apiAdminKey, info.api_admin_key],
                [messages.adminUrl, info.admin_url]
            ].forEach(function(item) {
                const row = document.createElement('div');
                const label = document.createElement('span');
                const value = document.createElement('span');
                row.className = 'complete-info-item';
                value.className = 'complete-info-value';
                label.textContent = item[0];
                value.textContent = item[1] || '';
                row.appendChild(label);
                row.appendChild(value);
                completeInfo.appendChild(row);
            });
        }
        
        // 切换步骤
        function goToStep(step) {
            currentStep = step;
            document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('panel-' + step).classList.add('active');
            
            document.querySelectorAll('.step').forEach((s, i) => {
                const stepId = s.dataset.step;
                s.classList.remove('active', 'completed');
                if (stepId === step) {
                    s.classList.add('active');
                } else if (['env', 'db', 'admin', 'complete'].indexOf(stepId) < ['env', 'db', 'admin', 'complete'].indexOf(step)) {
                    s.classList.add('completed');
                }
            });
        }
        
        // 环境检测
        btnCheckEnv.addEventListener('click', async function() {
            this.disabled = true;
            terminal.innerHTML = '';
            terminalLog(messages.startEnvCheck);
            
            try {
                const res = await fetch(baseUrl + '/envCheck');
                const data = await res.json();
                
                if (data.code === 200) {
                    const result = data.data.result;
                    const requirements = data.data.requirements;
                    
                    // 显示 PHP 版本
                    terminalLog('PHP ' + result.php_version, 'success');
                    
                    // 显示检测详情
                    for (const [key, detail] of Object.entries(result.details)) {
                        terminalLog(key + ': ' + detail.status, detail.passed ? 'success' : 'error');
                    }
                    
                    if (data.data.passed) {
                        terminalLog(messages.envPassed, 'success');
                        setEnvStatus(messages.passed, 'success', '✓');
                        envPassed = true;
                        btnNextDb.style.display = 'inline-flex';
                        btnFixEnv.style.display = 'none';
                    } else {
                        terminalLog(messages.envFailed, 'error');
                        setEnvStatus(messages.failed, 'error', '✗');
                        
                        // 显示问题
                        if (result.missing_extensions.length > 0) {
                            terminalLog(messages.missingExtensions + ': ' + result.missing_extensions.join(', '), 'error');
                        }
                        if (result.disabled_functions.length > 0) {
                            terminalLog(messages.disabledFunctions + ': ' + result.disabled_functions.join(', '), 'error');
                        }
                        
                        btnFixEnv.style.display = 'inline-flex';
                    }
                } else {
                    terminalLog(data.msg || messages.checkFailed, 'error');
                }
            } catch (e) {
                terminalLog(appendErrorDetail(messages.requestFailed, e.message), 'error');
            }
            
            this.disabled = false;
        });
        
        // 环境修复（SSE）
        btnFixEnv.addEventListener('click', function() {
            this.disabled = true;
            terminalLog(messages.startEnvFix);
            
            const evtSource = new EventSource(baseUrl + '/envInstallStream');
            
            evtSource.onmessage = function(event) {
                const data = JSON.parse(event.data);
                const type = data.type;
                const msg = data.msg || '';
                
                switch (type) {
                    case 'start':
                    case 'step':
                        terminalLog(msg, 'info');
                        break;
                    case 'success':
                        terminalLog(msg, 'success');
                        break;
                    case 'warning':
                        terminalLog(msg, 'warning');
                        if (data.guide) {
                            terminalLog('  ' + messages.guideLocation + ': ' + (data.guide.location || ''), 'warning');
                            terminalLog('  ' + messages.guideAction + ': ' + (data.guide.action || ''), 'warning');
                        }
                        break;
                    case 'error':
                        terminalLog(msg, 'error');
                        break;
                    case 'complete':
                        evtSource.close();
                        btnFixEnv.disabled = false;
                        if (data.success) {
                            terminalLog(messages.fixCompleted, 'success');
                            setEnvStatus(messages.passed, 'success', '✓');
                            envPassed = true;
                            btnNextDb.style.display = 'inline-flex';
                            btnFixEnv.style.display = 'none';
                        } else {
                            terminalLog(messages.manualFixNeeded, 'warning');
                        }
                        break;
                }
            };
            
            evtSource.onerror = function() {
                evtSource.close();
                terminalLog(messages.streamInterrupted, 'error');
                btnFixEnv.disabled = false;
            };
        });
        
        // 下一步 -> 数据库
        btnNextDb.addEventListener('click', () => goToStep('db'));
        
        // 数据库类型切换
        dbType.addEventListener('change', function() {
            const isSqlite = this.value === 'sqlite';
            document.getElementById('db-connection-fields').style.display = isSqlite ? 'none' : 'block';
            document.getElementById('db-sqlite-fields').style.display = isSqlite ? 'block' : 'none';
        });
        
        // 测试数据库连接
        btnTestDb.addEventListener('click', async function() {
            this.disabled = true;
            this.textContent = messages.testing;
            setInlineMessage(dbMessage, '');
            
            const formData = new FormData(document.getElementById('form-db'));
            
            try {
                const res = await fetch(baseUrl + '/dbConfig', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                
                if (data.code === 200) {
                    setInlineMessage(dbMessage, messages.connectionSuccess, 'success');
                    btnNextAdmin.disabled = false;
                } else {
                    setInlineMessage(dbMessage, data.msg || messages.connectionFailed, 'error');
                    btnNextAdmin.disabled = true;
                }
            } catch (e) {
                setInlineMessage(dbMessage, appendErrorDetail(messages.requestFailed, e.message), 'error');
                btnNextAdmin.disabled = true;
            }
            
            this.disabled = false;
            this.textContent = messages.testConnection;
        });
        
        // 下一步 -> 管理员
        btnNextAdmin.addEventListener('click', () => goToStep('admin'));
        
        // 完成安装
        btnComplete.addEventListener('click', async function() {
            this.disabled = true;
            this.textContent = messages.installing;
            setInlineMessage(installMessage, '');
            
            const formData = new FormData(document.getElementById('form-admin'));
            
            try {
                const res = await fetch(baseUrl + '/complete', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                
                if (data.code === 200) {
                    // 显示完成信息
                    const info = data.data;
                    renderCompleteInfo(info);
                    document.getElementById('btn-goto-admin').href = info.admin_url;
                    goToStep('complete');
                } else {
                    setInlineMessage(installMessage, data.msg || messages.installFailed, 'error');
                    this.disabled = false;
                    this.textContent = messages.completeInstall;
                }
            } catch (e) {
                setInlineMessage(installMessage, appendErrorDetail(messages.requestFailed, e.message), 'error');
                this.disabled = false;
                this.textContent = messages.completeInstall;
            }
        });
    })();
    </script>
</body>
</html>
