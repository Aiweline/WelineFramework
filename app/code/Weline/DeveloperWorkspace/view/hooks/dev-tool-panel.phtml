        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 8px 0;
        border-bottom: 1px solid #e8e8e8;
        gap: 8px;
    }

    .performance-item:last-child {
        border-bottom: none;
    }

    .performance-label {
        font-size: 13px;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        flex: 1;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .performance-value {
        font-size: 13px;
        font-weight: 600;
        color: #5c574f;
        font-family: 'Courier New', monospace;
        flex-shrink: 0;
    }

    .trace-toggle, .trace-toggle-placeholder {
        display: inline-flex;
        width: 18px;
        flex-shrink: 0;
        margin-right: 2px;
    }
    .trace-toggle {
        cursor: pointer;
        color: #64748b;
        align-items: center;
        justify-content: center;
    }
    .trace-toggle:hover {
        color: #5c574f;
    }
    .trace-children {
        border-left: 1px solid #e8e8e8;
        margin-left: 9px;
    }

    .performance-value.fast {
        color: #5a6b5a;
    }

    .performance-value.medium {
        color: #b8956e;
    }

    .performance-value.slow {
        color: #a67c6b;
    }

    .performance-badge {
        display: inline-block;
        padding: 2px 6px;
        font-size: 10px;
        border-radius: 3px;
        margin-left: 6px;
    }

    .performance-badge.fast {
        background: #dce4dc;
        color: #5a6b5a !important;
    }

    .performance-badge.medium {
        background: #ebe4d8;
        color: #b8956e !important;
    }

    .performance-badge.slow {
        background: #e8ddd8;
        color: #a67c6b !important;
    }

    /* DB 链路表格：列宽固定、表头不截断、对齐统一 */
    #dev-tool-panel .dev-tool-trace-db-wrap {
        max-height: 320px;
        overflow: auto;
        font-size: 12px;
        border: 1px solid #e8e6e3;
        border-radius: 6px;
        background: #fafaf9;
    }
    #dev-tool-panel .dev-tool-trace-db-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }
    #dev-tool-panel .dev-tool-trace-db-table thead {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f0eeeb;
        box-shadow: 0 1px 0 #e8e6e3;
    }
    #dev-tool-panel .dev-tool-trace-db-table th {
        padding: 8px 10px;
        text-align: left;
        font-weight: 600;
        color: #5c574f;
        white-space: nowrap;
        border-bottom: 1px solid #e8e6e3;
    }
    #dev-tool-panel .dev-tool-trace-db-table th.col-op { width: 40px; min-width: 40px; text-align: center; }
    #dev-tool-panel .dev-tool-trace-db-table th.col-table { width: 90px; min-width: 90px; }
    #dev-tool-panel .dev-tool-trace-db-table th.col-parent { width: 110px; min-width: 110px; }
    #dev-tool-panel .dev-tool-trace-db-table th.col-duration { width: 70px; min-width: 70px; text-align: right; }
    #dev-tool-panel .dev-tool-trace-db-table td {
        padding: 6px 10px;
        border-top: 1px solid #eeece9;
        vertical-align: top;
        color: #5c574f;
    }
    #dev-tool-panel .dev-tool-trace-db-table td.col-op { word-break: keep-all; text-align: center; font-weight: 600; color: #5c574f; }
    #dev-tool-panel .dev-tool-trace-db-table td.col-table {
        word-break: break-word;
        overflow-wrap: break-word;
        white-space: normal;
        line-height: 1.35;
    }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-expand-btn {
        cursor: pointer;
        margin-left: 2px;
        color: #667eea;
        font-size: 10px;
        user-select: none;
    }
    /* 编码阶段内嵌的 DB 行（融合显示） */
    #dev-tool-panel .dev-tool-trace-db-inline {
        margin: 2px 0;
    }
    #dev-tool-panel .dev-tool-trace-db-inline .dev-tool-db-inline-row {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 0;
        border-bottom: 1px solid #eeece9;
        min-height: 24px;
    }
    #dev-tool-panel .dev-tool-trace-db-inline .dev-tool-db-expand-row .dev-tool-db-sql-block {
        margin-top: 4px;
    }
    /* 展开行占满整行：全宽显示，不挤在格子里 */
    #dev-tool-panel .dev-tool-trace-db-table tr.dev-tool-db-expand-row td {
        padding: 10px 0;
        background: #f8fafc;
        border-top: none;
        border-bottom: 1px solid #e8e6e3;
        vertical-align: top;
    }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-sql-block {
        display: block;
        width: 100%;
        box-sizing: border-box;
        margin: 0 0 8px 0;
        padding: 10px 12px;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 11px;
        background: #fff;
        border: none;
        border-top: 1px solid #e8e6e3;
        border-bottom: 1px solid #e8e6e3;
        border-radius: 0;
        max-height: 160px;
        overflow: auto;
        font-family: 'Courier New', monospace;
    }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-sql-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        padding: 0 2px;
    }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-btn {
        padding: 4px 10px;
        font-size: 11px;
        border: 1px solid #ccc;
        border-radius: 4px;
        background: #fff;
        color: #5c574f;
        cursor: pointer;
    }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-btn:hover { background: #f0eeeb; }
    #dev-tool-panel .dev-tool-trace-db-table .dev-tool-db-explain-result {
        display: block;
        width: 100%;
        box-sizing: border-box;
        margin-top: 8px;
        padding: 10px 12px;
        font-size: 11px;
        background: #fff;
        border: none;
        border-top: 1px solid #e8e6e3;
        border-bottom: 1px solid #e8e6e3;
        border-radius: 0;
        max-height: 180px;
        overflow: auto;
    }
    #dev-tool-panel .dev-tool-trace-db-table td.col-parent {
        color: #64748b;
        font-size: 11px;
        word-break: break-word;
        overflow-wrap: break-word;
        white-space: normal;
        line-height: 1.35;
    }
    #dev-tool-panel .dev-tool-trace-db-table td.col-duration {
        text-align: right;
        white-space: nowrap;
        font-family: 'Courier New', monospace;
        font-size: 11px;
    }

    .api-request-item {
        padding: 8px;
        margin-bottom: 6px;
        background: #ffffff;
        border-radius: 4px;
        border-left: 2px solid #2563eb;
        font-size: 12px;
    }

    .api-request-url {
        color: #667eea;
        word-break: break-all;
        margin-bottom: 4px;
    }

    .api-request-time {
        color: #999;
        font-size: 11px;
    }

    /* Weline Panel 工作台视觉刷新 */
    #dev-tool-panel,
    #dev-tool-panel * {
        box-sizing: border-box;
        letter-spacing: 0;
    }

    #dev-tool-panel button,
    #dev-tool-panel a,
    #dev-tool-panel [data-dev-tool-action],
    #dev-tool-panel [data-wls-action] {
        cursor: pointer;
    }

    #dev-tool-panel button:focus-visible,
    #dev-tool-panel a:focus-visible,
    #dev-tool-panel input:focus-visible,
    #dev-tool-panel select:focus-visible {
        outline: 2px solid rgba(37, 99, 235, 0.55);
        outline-offset: 2px;
    }

    .dev-tool-trigger {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.22);
    }

    .dev-tool-trigger.pressing,
    #dev-tool-panel.expand-right .dev-tool-trigger:hover,
    #dev-tool-panel:not(.expand-left) .dev-tool-trigger:hover,
    #dev-tool-panel.expand-left .dev-tool-trigger:hover {
        background: #1f2937;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.28);
        transform: none;
    }

    .dev-tool-trigger.drag-ready {
        background: #12805c;
        box-shadow: 0 0 0 4px rgba(18, 128, 92, 0.16), 0 14px 34px rgba(15, 23, 42, 0.26);
        transform: none;
    }

    .dev-tool-container {
        background: var(--dev-panel-shell);
        border: 1px solid var(--dev-panel-line);
        border-radius: 8px;
        box-shadow: 0 24px 90px rgba(15, 23, 42, 0.24);
    }

    .dev-tool-header {
        background: linear-gradient(90deg, #111827 0%, #1f2937 58%, #0f766e 100%);
        padding: 12px 16px;
        box-shadow: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .dev-tool-header h3 {
        color: #f8fafc;
        font-size: 15px;
        font-weight: 700;
    }

    .dev-tool-header h3 i {
        color: #67e8f9;
    }

    .dev-tool-page-context {
        min-width: 0;
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: #dbeafe;
    }

    .dev-tool-page-kicker {
        flex: 0 0 auto;
        padding: 2px 7px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.22);
        color: rgba(226, 232, 240, 0.88);
        font-size: 10px;
        font-weight: 750;
        line-height: 1.4;
    }

    .dev-tool-page-link {
        min-width: 0;
        max-width: min(700px, 48vw);
        display: grid;
        grid-template-columns: minmax(0, auto) minmax(0, 1fr);
        align-items: baseline;
        gap: 8px;
        padding: 5px 10px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 7px;
        background: rgba(15, 23, 42, 0.18);
        color: #f8fafc;
        text-decoration: none;
        cursor: pointer;
    }

    .dev-tool-page-link:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.28);
        color: #ffffff;
        text-decoration: none;
    }

    .dev-tool-page-title,
    .dev-tool-page-url {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dev-tool-page-title {
        color: #ffffff;
        font-size: 12px;
        font-weight: 800;
    }

    .dev-tool-page-url {
        color: #b9d9ff;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 10px;
        font-weight: 650;
    }

    .dev-tool-header-hint {
        display: none;
        min-width: 0;
        max-width: min(52vw, 720px);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #dbeafe;
        background: rgba(15, 23, 42, 0.34);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }

    .dev-tool-header-hint.is-visible {
        display: inline-flex !important;
        align-items: center;
    }

    .dev-tool-window-actions {
        gap: 6px;
    }

    .dev-tool-layout-btn,
    .dev-tool-close-btn,
    .dev-tool-quick-btn {
        border-radius: 6px;
        transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .dev-tool-layout-btn,
    .dev-tool-close-btn {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.2);
        color: #f8fafc;
    }

    .dev-tool-layout-btn:hover,
    .dev-tool-close-btn:hover {
        background: rgba(255, 255, 255, 0.16);
        border-color: rgba(255, 255, 255, 0.34);
        transform: none;
    }

    .dev-tool-layout-btn:active,
    .dev-tool-close-btn:active {
        transform: none;
    }

    .dev-tool-close-mark {
        display: block;
        font-size: 20px;
        line-height: 1;
        font-weight: 500;
        transform: translateY(-1px);
    }

    .dev-tool-quick-actions {
        margin-top: 8px;
    }

    .dev-tool-quick-btn {
        min-height: 30px;
        padding: 5px 10px;
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.18);
        color: #e5edf7;
    }

    .dev-tool-quick-btn:hover {
        background: rgba(255, 255, 255, 0.16);
        border-color: rgba(255, 255, 255, 0.34);
        color: #ffffff;
        transform: none;
    }

    .dev-tool-tabs {
        flex: 0 0 auto;
        gap: 6px;
        padding: 8px 10px 0;
        overflow-x: auto;
        background: #e9eff6;
        border-bottom: 1px solid var(--dev-panel-line);
        scrollbar-width: thin;
    }

    .dev-tool-tab {
        flex: 0 0 auto;
        min-width: 112px;
        min-height: 38px;
        padding: 9px 14px;
        border: 1px solid transparent;
        border-bottom: none;
        border-radius: 7px 7px 0 0;
        background: transparent;
        color: #475569;
        font-size: 13px;
        font-weight: 650;
        white-space: nowrap;
    }

    .dev-tool-tab:hover {
        background: rgba(255, 255, 255, 0.58);
        color: var(--dev-panel-ink);
    }

    .dev-tool-tab.active {
        background: var(--dev-panel-surface);
        border-color: var(--dev-panel-line);
        color: var(--dev-panel-accent);
        box-shadow: 0 -1px 0 #ffffff inset;
    }

    .dev-tool-tab.active::after {
        left: 12px;
        right: 12px;
        bottom: 0;
        height: 2px;
        background: var(--dev-panel-accent);
        border-radius: 999px 999px 0 0;
    }

    .dev-tool-search-area {
        flex: 0 0 auto;
        padding: 10px 14px;
        border-bottom: 1px solid var(--dev-panel-line);
        background: var(--dev-panel-surface);
    }

    .dev-tool-search-mode {
        display: inline-flex;
        gap: 3px;
        padding: 3px;
        margin-bottom: 10px;
        border: 1px solid var(--dev-panel-line);
        border-radius: 7px;
        background: #f8fafc;
    }

    .dev-tool-framework-tabs {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px;
        margin-bottom: 10px;
        border: 1px solid var(--dev-panel-line);
        border-radius: 8px;
        background: #eef3f8;
    }

    .dev-tool-framework-tab {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 30px;
        padding: 5px 12px;
        border: 1px solid transparent;
        border-radius: 6px;
        background: transparent;
        color: #475569;
        cursor: pointer;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .dev-tool-framework-tab:hover {
        background: #f8fbff;
        color: var(--dev-panel-ink);
    }

    .dev-tool-framework-tab.active {
        background: #ffffff;
        color: var(--dev-panel-accent);
        border-color: #cddbf0;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
    }

    .dev-tool-framework-pane {
        display: none;
    }

    .dev-tool-framework-pane.active {
        display: block;
    }

    .dev-tool-framework-hint {
        padding: 8px 2px;
        font-size: 12px;
        color: #64748b;
    }

    .search-mode-btn {
        flex: 0 0 auto;
        min-height: 30px;
        padding: 5px 11px;
        border: 1px solid transparent;
        border-radius: 5px;
        background: transparent;
        color: #475569;
        font-weight: 650;
    }

    .search-mode-btn:hover {
        background: #eef4fb;
        color: var(--dev-panel-ink);
    }

    .search-mode-btn.active {
        background: #ffffff;
        color: var(--dev-panel-accent);
        border-color: #dbe6f5;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
    }

    .dev-tool-module-select,
    .dev-tool-search-area input[type="text"] {
        min-height: 36px;
        border-color: #cbd5e1;
        border-radius: 6px;
        color: var(--dev-panel-ink);
        background: #ffffff;
    }

    .dev-tool-search-area input[type="text"]:focus,
    .dev-tool-module-select:focus {
        border-color: var(--dev-panel-accent);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        outline: none;
    }

    .dev-tool-content {
        background: var(--dev-panel-surface);
        color: var(--dev-panel-ink);
        scrollbar-color: #b6c3d3 #eef3f8;
    }

    .dev-tool-content::-webkit-scrollbar-track {
