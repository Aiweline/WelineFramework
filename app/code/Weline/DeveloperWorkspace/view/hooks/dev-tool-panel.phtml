<!-- 开发工具面板脚本 -->
<script>
const DevToolPanel = (function() {
    // ========== 状态管理 ==========
    const state = {
        // 面板状态
        collapsed: true,
        activeMainTab: 'docs', // 'routes' or 'docs' or 'performance'
        
        // 路由相关
        currentRouteType: '<?php echo $panelType; ?>',
        routeSearchKeyword: '',
        allRouteModules: [],
        
        // 文档相关
        docSearchMode: 'all', // 'all' or 'module'
        docSearchKeyword: '',
        selectedModule: '',
        allModules: [],
        docList: [],
        currentDocId: null,
        currentDocScrollPos: 0,
        
        // 拖拽相关
        panelX: 0,
        panelY: 0,
        isDragging: false,
        dragStartX: 0,
        dragStartY: 0,
        panelStartX: 0,
        panelStartY: 0,
        
        // 性能统计相关
        pageLoadStartTime: performance.timing ? performance.timing.navigationStart : Date.now(),
        apiRequests: [], // 存储API请求记录
    };

    // ========== LocalStorage 管理 ==========
    function saveState() {
        const dataToSave = {
            collapsed: state.collapsed,
            activeMainTab: state.activeMainTab,
            currentRouteType: state.currentRouteType,
            routeSearchKeyword: state.routeSearchKeyword,
            docSearchMode: state.docSearchMode,
            docSearchKeyword: state.docSearchKeyword,
            selectedModule: state.selectedModule,
            currentDocId: state.currentDocId,
            currentDocScrollPos: state.currentDocScrollPos,
            panelX: state.panelX,
            panelY: state.panelY,
        };
        localStorage.setItem('dev-panel-state', JSON.stringify(dataToSave));
    }

    function loadState() {
        const saved = localStorage.getItem('dev-panel-state');
        if (saved) {
            try {
                const data = JSON.parse(saved);
                Object.assign(state, data);
            } catch (e) {
                console.error('[DevToolPanel] Failed to load state:', e);
            }
        }
    }

    // ========== 初始化 ==========
    function init() {
        loadState();
        
        // 恢复面板状态
        const panel = document.getElementById('dev-tool-panel');
        if (!state.collapsed) {
            panel.classList.remove('collapsed');
        }
        
        // 恢复主标签
        switchMainTab(
            document.querySelector('.dev-tool-tab[data-tab="' + state.activeMainTab + '"]'),
            state.activeMainTab,
            false
        );
        
        // 加载模块列表
        const modulePromise = loadModules() || Promise.resolve();
        modulePromise.then(() => {
            // 恢复文档搜索状态
            if (state.activeMainTab === 'docs') {
                restoreDocSearchState();
            }
        }).catch(error => {
            console.warn('[DevToolPanel] Module loading error:', error);
            // 即使加载失败也要恢复搜索状态
            if (state.activeMainTab === 'docs') {
                restoreDocSearchState();
            }
        });
        
        // 如果是路由标签，加载路由
        if (state.activeMainTab === 'routes') {
            loadRoutes(state.currentRouteType);
        }
        
        // 如果是性能标签，渲染性能统计
        if (state.activeMainTab === 'performance') {
            renderPerformanceStats();
        }
        
        // 如果是请求链路标签，渲染请求链路
        if (state.activeMainTab === 'trace') {
            renderRequestTrace();
        }
        
        // 扩展标签：仅当当前为某扩展标签时才加载（由扩展通过 registerExtensionTab 注册，可能稍晚注册）
        var extTab = state.activeMainTab && state.activeMainTab !== 'routes' && state.activeMainTab !== 'docs' && state.activeMainTab !== 'performance' && state.activeMainTab !== 'trace';
        if (extTab) {
            (function tryLoadExtension() {
                if (window.DevToolPanelExtensionLoaders && window.DevToolPanelExtensionLoaders[state.activeMainTab]) {
                    window.DevToolPanelExtensionLoaders[state.activeMainTab]();
                } else {
                    setTimeout(tryLoadExtension, 80);
                }
            })();
        }
        
        // 恢复面板位置（包括第一次加载，默认位置0,0也要设置）
        panel.style.left = (state.panelX || 0) + 'px';
        panel.style.top = (state.panelY || 0) + 'px';
        
        // 同步container位置
        updateContainerPosition();
        
        // 检查并纠正超出屏幕的位置
        // 需要在下一帧执行，确保面板已经渲染完成
        requestAnimationFrame(() => {
            correctPanelPosition(panel);
            // 纠正位置后更新展开方向和container位置
            updateExpandDirection();
            updateContainerPosition();
        });
        
        // 初始化拖拽
        initDrag();
        
        // 初始化性能监控
        initPerformanceMonitoring();
        
        // 页面加载完成后更新性能统计
        if (document.readyState === 'complete') {
            // 如果页面已经加载完成，延迟一下再更新性能数据（确保performance API数据完整）
            setTimeout(() => {
                if (state.activeMainTab === 'performance') {
                    renderPerformanceStats();
                }
            }, 500);
        } else {
            window.addEventListener('load', () => {
                setTimeout(() => {
                    if (state.activeMainTab === 'performance') {
                        renderPerformanceStats();
                    }
                }, 500);
            });
        }
        
        // 监听窗口大小变化，自动调整位置
        window.addEventListener('resize', function() {
            const panel = document.getElementById('dev-tool-panel');
            if (panel) {
                correctPanelPosition(panel);
                updateExpandDirection();
                updateContainerPosition();
            }
        });
    }
    
    // ========== 更新container位置（container是fixed定位，需要手动同步panel位置） ==========
    function updateContainerPosition() {
        const panel = document.getElementById('dev-tool-panel');
        const container = document.querySelector('.dev-tool-container');
        if (!panel || !container) return;
        
        const panelX = parseInt(panel.style.left) || 0;
        const panelY = parseInt(panel.style.top) || 0;
        
        // container直接使用panel的位置
        container.style.left = panelX + 'px';
        container.style.top = panelY + 'px';
    }
    
    // ========== 纠正面板位置（防止超出屏幕） ==========
    function correctPanelPosition(panelEl) {
        // 临时移除collapsed类以获取正确的尺寸
        const wasCollapsed = panelEl.classList.contains('collapsed');
        if (wasCollapsed) {
            panelEl.classList.remove('collapsed');
        }
        
        // 获取container的实际尺寸（不是panel的尺寸，因为panel尺寸为0）
        const container = panelEl.querySelector('.dev-tool-container');
        const trigger = panelEl.querySelector('.dev-tool-trigger');
        const containerRect = container.getBoundingClientRect();
        const triggerRect = trigger.getBoundingClientRect();
        
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;
        
        let currentX = parseInt(panelEl.style.left) || 0;
        let currentY = parseInt(panelEl.style.top) || 0;
        
        // 使用container的实际尺寸
        const width = containerRect.width || 420;
        const height = containerRect.height || 600;
        
        // 计算触发器超出container的宽度
        const triggerExtraWidth = Math.max(0, triggerRect.right - containerRect.right);
        
        // 计算实际占用的总宽度（container + 触发器超出部分）
        const totalWidth = width + triggerExtraWidth;
        
        // 计算可见区域
        const visibleLeft = Math.max(0, currentX);
        const visibleRight = Math.min(windowWidth, currentX + totalWidth);
        const visibleWidth = visibleRight - visibleLeft;
        
        // 如果面板大部分隐藏（可见宽度小于100px），需要贴边
        const needSnap = visibleWidth < 100;
        
        // 恢复collapsed状态
        if (wasCollapsed) {
            panelEl.classList.add('collapsed');
        }
        
        if (needSnap) {
            // 调用贴边函数自动贴到最近的边
            snapToNearestEdge(panelEl);
        } else {
            // 边界约束：根据收起/展开状态使用不同的尺寸
            let minX, minY, maxX, maxY;
            
            if (wasCollapsed) {
                // 收起状态：使用触发器的实际屏幕位置计算边界
                // 确保触发器的bounding box完全在屏幕内
                const triggerOffsetLeft = currentX - triggerRect.left;   // panel到trigger左边的距离
                const triggerOffsetTop = currentY - triggerRect.top;      // panel到trigger顶部的距离
                const triggerOffsetRight = triggerRect.right - currentX;  // trigger右边到panel的距离
                const triggerOffsetBottom = triggerRect.bottom - currentY; // trigger底部到panel的距离
                
                // minX: 确保trigger.left >= 0 => panel.left >= triggerOffsetLeft
                minX = triggerOffsetLeft;
                // minY: 确保trigger.top >= 0 => panel.top >= triggerOffsetTop
                minY = triggerOffsetTop;
                // maxX: 确保trigger.right <= windowWidth => panel.left <= windowWidth - triggerOffsetRight
                maxX = windowWidth - triggerOffsetRight;
                // maxY: 确保trigger.bottom <= windowHeight => panel.top <= windowHeight - triggerOffsetBottom
                maxY = windowHeight - triggerOffsetBottom;
            } else {
                // 展开状态：使用container + 触发器的总尺寸
                minX = 0;
                minY = 0;
                maxX = windowWidth - totalWidth;
                maxY = windowHeight - height;
            }
            
            let correctedX = currentX;
            let correctedY = currentY;
            let needCorrection = false;
            
            // 检查并纠正X坐标
            if (currentX < minX) {
                correctedX = minX;
                needCorrection = true;
            } else if (currentX > maxX) {
                correctedX = maxX;
                needCorrection = true;
            }
            
            // 检查并纠正Y坐标
            if (currentY < minY) {
                correctedY = minY;
                needCorrection = true;
            } else if (currentY > maxY) {
                correctedY = maxY;
                needCorrection = true;
            }
            
            // 如果需要纠正，应用新位置并保存
            if (needCorrection) {
                panelEl.style.left = correctedX + 'px';
                panelEl.style.top = correctedY + 'px';
                state.panelX = correctedX;
                state.panelY = correctedY;
                saveState();
                
                // 同步container位置
                updateContainerPosition();
            }
        }
    }
    
    // ========== 拖拽功能 ==========
    function initDrag() {
        const header = document.querySelector('.dev-tool-header');
        const trigger = document.querySelector('.dev-tool-trigger');
        const panelEl = document.getElementById('dev-tool-panel');
        if (!panelEl) return;
        
        // Trigger拖动状态（外层定义，方便全局访问）
        let triggerMouseDownX = 0;
        let triggerMouseDownY = 0;
        let hasMoved = false;
        let isMouseDown = false;
        const moveThreshold = 5; // 移动5px以上才算拖动
        
        // Header拖拽处理（展开状态下拖动整个面板）
        if (header) {
            let headerClickCount = 0;
            let headerClickTimer = null;
            
            // 检测是否为移动设备
            const isMobileDevice = window.innerWidth <= 480 || ('ontouchstart' in window);
            
            header.addEventListener('mousedown', function(e) {
                // 排除关闭按钮的点击
                if (e.target.closest('.dev-tool-close-btn')) {
                    return;
                }
                
                // 移动设备禁用header拖动（移动端全屏无需拖动）
                if (isMobileDevice) return;
                
                // 只在展开状态下允许拖动Header
                if (!state.collapsed) {
                    startHeaderDrag(e);
                }
            });
            
            // Header双击收起
            header.addEventListener('click', function(e) {
                // 排除关闭按钮和快捷操作区域的点击
                if (e.target.closest('.dev-tool-close-btn') || e.target.closest('.dev-tool-quick-actions')) {
                    return;
                }
                
                headerClickCount++;
                
                if (headerClickCount === 1) {
                    // 第一次点击，等待第二次点击
                    headerClickTimer = setTimeout(() => {
                        headerClickCount = 0;
                    }, 300); // 300ms内的第二次点击才算双击
                } else if (headerClickCount === 2) {
                    // 双击
                    clearTimeout(headerClickTimer);
                    headerClickCount = 0;
                    
                    // 只在展开状态下才收起
                    if (!state.collapsed) {
                        DevToolPanel.toggle();
                    }
                }
            });
            
            // 触摸事件支持（仅用于双击收起，不支持拖动）
            if (!isMobileDevice) {
                header.addEventListener('touchstart', function(e) {
                    if (!state.collapsed) {
                        const touch = e.touches[0];
                        const mouseEvent = new MouseEvent('mousedown', {
                            clientX: touch.clientX,
                            clientY: touch.clientY
                        });
                        header.dispatchEvent(mouseEvent);
                    }
                });
                
                header.addEventListener('touchend', function(e) {
                    const mouseEvent = new MouseEvent('mouseup');
                    header.dispatchEvent(mouseEvent);
                });
            }
        }
        
        // Trigger拖拽处理（简化版：有位移=拖动，无位移=点击）
        if (trigger) {
            trigger.addEventListener('mousedown', function(e) {
                e.preventDefault();
                
                // 记录按下位置
                triggerMouseDownX = e.clientX;
                triggerMouseDownY = e.clientY;
                hasMoved = false;
                isMouseDown = true;
                
                // 添加按住状态的视觉反馈
                trigger.classList.add('pressing');
                trigger.style.cursor = 'grab';
            });
            
            // 监听全局鼠标移动，检测是否开始拖动
            document.addEventListener('mousemove', function(e) {
                if (!isMouseDown) return;
                
                // 计算位移
                const deltaX = Math.abs(e.clientX - triggerMouseDownX);
                const deltaY = Math.abs(e.clientY - triggerMouseDownY);
                
                // 如果位移超过阈值，开始拖动
                if (!hasMoved && (deltaX > moveThreshold || deltaY > moveThreshold)) {
                    hasMoved = true;
                    trigger.classList.remove('pressing');
                    trigger.classList.add('drag-ready');
                    trigger.style.cursor = 'grabbing';
                    
                    // 启动触发器拖动
                    startTriggerDrag({
                        clientX: triggerMouseDownX,
                        clientY: triggerMouseDownY
                    });
                }
            });
            
            trigger.addEventListener('mouseup', function(e) {
                // 移除视觉反馈
                trigger.classList.remove('pressing', 'drag-ready');
                trigger.style.cursor = '';
                
                // 如果没有移动过且没有正在拖动，认为是点击
                if (!hasMoved && !state.isDragging && state.collapsed) {
                    e.stopPropagation();
                    DevToolPanel.toggle();
                }
                
                // 重置状态
                isMouseDown = false;
                hasMoved = false;
            });
            
            trigger.addEventListener('mouseleave', function(e) {
                // 如果鼠标离开但还在按下状态，保持拖动
                if (!isMouseDown) {
                    trigger.classList.remove('pressing', 'drag-ready');
                    trigger.style.cursor = '';
                }
            });
            
            // 添加触摸事件支持
            trigger.addEventListener('touchstart', function(e) {
                e.preventDefault();
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousedown', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                trigger.dispatchEvent(mouseEvent);
            });
            
            // 同步触摸移动为鼠标移动，保证拖拽连续性
            document.addEventListener('touchmove', function(e) {
                if (!state.isDragging) return;
                const touch = e.touches[0];
                const moveEvent = new MouseEvent('mousemove', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                document.dispatchEvent(moveEvent);
            }, { passive: false });

            // 触摸取消/结束映射为鼠标抬起
            trigger.addEventListener('touchend', function(e) {
                e.preventDefault();
                const mouseEvent = new MouseEvent('mouseup');
                trigger.dispatchEvent(mouseEvent);
            });
            trigger.addEventListener('touchcancel', function(e) {
                e.preventDefault();
                const mouseEvent = new MouseEvent('mouseup');
                trigger.dispatchEvent(mouseEvent);
            });
        }
        
        // 启动触发器拖动（拖动触发器小块，面板位置跟随）
        function startTriggerDrag(e) {
            state.isDragging = true;
            state.dragStartX = e.clientX;
            state.dragStartY = e.clientY;
            state.panelStartX = parseInt(panelEl.style.left) || 0;
            state.panelStartY = parseInt(panelEl.style.top) || 0;
            
            panelEl.classList.add('dragging');
        }
        
        // 启动Header拖动（展开状态下拖动整个面板）
        function startHeaderDrag(e) {
            state.isDragging = true;
            state.dragStartX = e.clientX;
            state.dragStartY = e.clientY;
            state.panelStartX = parseInt(panelEl.style.left) || 0;
            state.panelStartY = parseInt(panelEl.style.top) || 0;
            
            panelEl.classList.add('dragging');
        }
        
        document.addEventListener('mousemove', function(e) {
            if (!state.isDragging) return;
            e.preventDefault();
            
            const deltaX = e.clientX - state.dragStartX;
            const deltaY = e.clientY - state.dragStartY;
            
            let newX = state.panelStartX + deltaX;
            let newY = state.panelStartY + deltaY;
            
            // 边界约束和贴边检测
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;
            const snapThreshold = 30; // 靠近边缘30px自动吸附
            
            // 自动贴边检测
            const isCollapsed = panelEl.classList.contains('collapsed');
            
            let panelWidth, panelHeight, triggerWidth;
            
            if (isCollapsed) {
                // 收起状态：只考虑触发器小块的尺寸
                const tRect = trigger.getBoundingClientRect();
                triggerWidth = tRect.width || 12; // 触发器宽度
                panelWidth = 0; // container不显示，宽度为0
                panelHeight = tRect.height || 80; // 触发器高度
            } else {
                // 展开状态：使用container的实际尺寸（不是panel，panel尺寸为0）
                const container = panelEl.querySelector('.dev-tool-container');
                const containerRect = container.getBoundingClientRect();
                const tRect = trigger.getBoundingClientRect();
                panelWidth = containerRect.width || 420;
                panelHeight = containerRect.height || 600;
                triggerWidth = Math.max(0, tRect.right - containerRect.right); // 触发器超出container的部分
            }
            
            // 计算实际占用的总宽度（container + 触发器）
            const totalWidth = panelWidth + triggerWidth;
            
            // 贴边检测 - 靠近边缘自动吸附
            if (newX < snapThreshold) {
                newX = 0; // 贴左边
            } else if (newX + totalWidth > windowWidth - snapThreshold) {
                newX = windowWidth - totalWidth; // 贴右边，确保触发器在屏幕内
            }
            
            if (newY < snapThreshold) {
                newY = 0; // 贴顶部
            } else if (newY + panelHeight > windowHeight - snapThreshold) {
                newY = windowHeight - panelHeight; // 贴底部
            }
            
            // 确保不超出边界（留出触发器空间）
            const maxX = windowWidth - totalWidth;
            const maxY = windowHeight - panelHeight;
            newX = Math.max(0, Math.min(maxX, newX));
            newY = Math.max(0, Math.min(maxY, newY));
            
            panelEl.style.left = newX + 'px';
            panelEl.style.top = newY + 'px';
            
            // 同步container位置
            updateContainerPosition();
        });
        
        document.addEventListener('mouseup', function(e) {
            // 重置触发器状态（无论是否在拖动）
            if (isMouseDown) {
                isMouseDown = false;
                if (trigger) {
                    trigger.classList.remove('pressing', 'drag-ready');
                    trigger.style.cursor = '';
                }
            }
            
            if (!state.isDragging) return;
            
            panelEl.classList.remove('dragging');
            state.isDragging = false;
            
            // 立即保存最终位置
            const finalX = parseInt(panelEl.style.left) || 0;
            const finalY = parseInt(panelEl.style.top) || 0;
            
            state.panelX = finalX;
            state.panelY = finalY;
            saveState();
            
            // 如果是展开状态，更新展开方向
            if (!state.collapsed) {
                updateExpandDirection();
            }
        });
    }
    
    // ========== 吸附到最近的边 ==========
    function snapToNearestEdge(panelEl) {
        // 若为收起状态，临时展开以便获取正确尺寸
        const wasCollapsed = panelEl.classList.contains('collapsed');
        if (wasCollapsed) {
            panelEl.classList.remove('collapsed');
        }

        // 获取container和trigger的实际尺寸
        const container = panelEl.querySelector('.dev-tool-container');
        const trigger = panelEl.querySelector('.dev-tool-trigger');
        const containerRect = container.getBoundingClientRect();
        const triggerRect = trigger.getBoundingClientRect();
        
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;

        // 使用container的实际尺寸
        const width = containerRect.width || 420;
        const height = containerRect.height || Math.min(600, windowHeight * 0.8);
        
        // 获取panel当前位置
        const currentX = parseInt(panelEl.style.left) || 0;
        const currentY = parseInt(panelEl.style.top) || 0;

        const centerX = currentX + width / 2;
        const centerY = currentY + height / 2;

        // 计算到各个边的距离
        const distToLeft = centerX;
        const distToRight = windowWidth - centerX;
        const distToTop = centerY;
        const distToBottom = windowHeight - centerY;

        // 找出最小距离
        const minDist = Math.min(distToLeft, distToRight, distToTop, distToBottom);

        // 触发器超出container的宽度
        const triggerExtraWidth = Math.max(0, triggerRect.right - containerRect.right);
        const totalWidth = width + triggerExtraWidth;

        let newX, newY;

        if (minDist === distToLeft) {
            // 吸附到左边：panel左边缘=0（container也在左边）
            newX = 0;
            newY = Math.max(0, Math.min(windowHeight - height, currentY));
        } else if (minDist === distToRight) {
            // 吸附到右边：确保触发器在屏幕内
            newX = windowWidth - totalWidth;
            newY = Math.max(0, Math.min(windowHeight - height, currentY));
        } else if (minDist === distToTop) {
            // 吸附到顶部：panel top=0（container top也=0）
            newY = 0;
            newX = Math.max(0, Math.min(windowWidth - totalWidth, currentX));
        } else {
            // 吸附到底部：panel top = windowHeight - container高度
            newY = windowHeight - height;
            newX = Math.max(0, Math.min(windowWidth - totalWidth, currentX));
        }

        // 还原收起状态（如果之前是收起）
        if (wasCollapsed) {
            panelEl.classList.add('collapsed');
        }

        // 应用吸附位置（带动画效果）
        panelEl.style.transition = 'left 0.3s ease, top 0.3s ease';
        container.style.transition = 'left 0.3s ease, top 0.3s ease';
        
        panelEl.style.left = newX + 'px';
        panelEl.style.top = newY + 'px';
        
        // 同步container位置
        container.style.left = newX + 'px';
        container.style.top = newY + 'px';

        // 动画结束后移除transition
        setTimeout(() => {
            panelEl.style.transition = '';
            container.style.transition = '';
            state.panelX = newX;
            state.panelY = newY;
            saveState();
        }, 300);
    }

    // ========== 检测并设置展开方向 ==========
    function updateExpandDirection() {
        const panel = document.getElementById('dev-tool-panel');
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;
        
        const x = parseInt(panel.style.left) || 0;
        const y = parseInt(panel.style.top) || 0;
        
        // 计算到各边的距离
        const distToLeft = x;
        const distToRight = windowWidth - x - 420; // 面板宽度420
        const distToTop = y;
        const distToBottom = windowHeight - y - 600; // 面板高度600
        
        // 移除所有方向class
        panel.classList.remove('expand-left', 'expand-right', 'expand-up', 'expand-down');
        
        // 根据最近的边设置展开方向
        const minDist = Math.min(distToLeft, distToRight, distToTop, distToBottom);
        
        if (minDist === distToLeft) {
            panel.classList.add('expand-right'); // 靠左边，向右展开
        } else if (minDist === distToRight) {
            panel.classList.add('expand-left'); // 靠右边，向左展开
        } else if (minDist === distToTop) {
            panel.classList.add('expand-down'); // 靠顶部，向下展开
        } else {
            panel.classList.add('expand-up'); // 靠底部，向上展开
        }
        
    }
    
    // ========== 面板控制 ==========
    function toggle() {
        state.collapsed = !state.collapsed;
        const panel = document.getElementById('dev-tool-panel');
        panel.classList.toggle('collapsed');
        
        // 展开时更新展开方向
        if (!state.collapsed) {
            updateExpandDirection();
        }
        
        // 保存状态（触发器位置保持不变）
        saveState();
    }
    
    // ========== 关闭面板（删除Cookie） ==========
    function closePanel() {
        // 获取Cookie名称（从PHP传递）
        const cookieName = '<?php echo isset($devToolCookieNameJs) ? $devToolCookieNameJs : "w_dev_tool"; ?>';
        
        // 删除Cookie（多种路径尝试，确保删除成功）
        // 1. 删除根路径Cookie
        document.cookie = cookieName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
        
        // 2. 删除当前路径Cookie
        document.cookie = cookieName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=' + window.location.pathname + ';';
        
        // 3. 删除可能的域名Cookie
        const domain = window.location.hostname;
        document.cookie = cookieName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=' + domain + ';';
        document.cookie = cookieName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=.' + domain + ';';
        
        // 4. 隐藏面板（立即生效，不等刷新）
        const panel = document.getElementById('dev-tool-panel');
        if (panel) {
            panel.style.display = 'none';
        }
        
        // 延迟刷新页面，给用户反馈时间
        setTimeout(() => {
            window.location.reload();
        }, 300);
    }

    function switchMainTab(button, tab, shouldSave = true) {
        // 更新标签状态
        document.querySelectorAll('.dev-tool-tab').forEach(t => t.classList.remove('active'));
        if (button) button.classList.add('active');
        
        state.activeMainTab = tab;
        if (shouldSave) saveState();
        
        // 显示/隐藏搜索区域
        const routeSearchArea = document.getElementById('route-search-area');
        const docSearchArea = document.getElementById('doc-search-area');
        const performanceSearchArea = document.getElementById('performance-search-area');
        const traceSearchArea = document.getElementById('trace-search-area');
        
        // 隐藏所有内置搜索区域
        routeSearchArea.style.display = 'none';
        docSearchArea.style.display = 'none';
        performanceSearchArea.style.display = 'none';
        if (traceSearchArea) traceSearchArea.style.display = 'none';
        // 隐藏所有扩展搜索区（约定 id 为 dev-tool-search-area-{tabId}）
        document.querySelectorAll('[id^="dev-tool-search-area-"]').forEach(el => { el.style.display = 'none'; });
        
        // 扩展标签：若加载器尚未注册则短时重试，最多重试几次；重试前检查用户是否已切换标签，避免覆盖
        const isExtensionTab = tab !== 'routes' && tab !== 'docs' && tab !== 'performance' && tab !== 'trace';
        const extSearchArea = document.getElementById('dev-tool-search-area-' + tab);
        const extLoader = window.DevToolPanelExtensionLoaders && window.DevToolPanelExtensionLoaders[tab];
        if (isExtensionTab && extSearchArea && !extLoader) {
            window._devToolExtensionRetryCount = window._devToolExtensionRetryCount || {};
            window._devToolExtensionRetryCount[tab] = (window._devToolExtensionRetryCount[tab] || 0) + 1;
            const maxRetries = 5;
            if (window._devToolExtensionRetryCount[tab] > maxRetries) {
                extSearchArea.style.display = 'block';
                const content = document.getElementById('dev-tool-content');
                if (content) content.innerHTML = '<div class="dev-tool-empty">扩展未就绪，请切换其他标签或刷新页面</div>';
                return;
            }
            extSearchArea.style.display = 'block';
            const content = document.getElementById('dev-tool-content');
            if (content) content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载中...</div></div>';
            setTimeout(function() {
                if (state.activeMainTab !== tab) return;
                switchMainTab(button, tab, false);
            }, 100);
            return;
        }
        
        if (tab === 'routes') {
            window._devToolExtensionRetryCount = {};
            routeSearchArea.style.display = 'block';
            loadRoutes(state.currentRouteType);
        } else if (tab === 'performance') {
            window._devToolExtensionRetryCount = {};
            performanceSearchArea.style.display = 'block';
            renderPerformanceStats();
        } else if (tab === 'trace') {
            window._devToolExtensionRetryCount = {};
            if (traceSearchArea) traceSearchArea.style.display = 'block';
            renderRequestTrace();
        } else if (extLoader) {
            if (window._devToolExtensionRetryCount) window._devToolExtensionRetryCount[tab] = 0;
            if (extSearchArea) extSearchArea.style.display = 'block';
            extLoader();
        } else {
            window._devToolExtensionRetryCount = {};
            docSearchArea.style.display = 'block';
            if (state.currentDocId) {
                loadDocDetail(state.currentDocId);
            } else {
                searchDocsAPI();
            }
        }
    }
    
    /** 供扩展模块注册：注册扩展标签的内容加载函数（仅切换到此标签时调用） */
    function registerExtensionTab(tabId, loadContentFn) {
        if (typeof tabId !== 'string' || typeof loadContentFn !== 'function') return;
        window.DevToolPanelExtensionLoaders = window.DevToolPanelExtensionLoaders || {};
        window.DevToolPanelExtensionLoaders[tabId] = loadContentFn;
    }

    // ========== 路由功能 ==========
    function switchRouteTab(button, type) {
        document.querySelectorAll('#route-search-area .search-mode-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        button.classList.add('active');
        
        state.currentRouteType = type;
        saveState();
        loadRoutes(type);
    }

    function loadRoutes(type) {
        const content = document.getElementById('dev-tool-content');
        if (!content) return Promise.resolve();
        
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载路由...</div></div>';
        
        const url = getDevToolApiUrl('routes', { type });
        if (!url) {
            content.innerHTML = '<div class="dev-tool-empty">⚠️ 无法构建 API 地址（请从后台打开本页）</div>';
            return Promise.resolve();
        }
        return fetch(url)
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.allRouteModules = data.data || [];
                    renderRouteModules(state.allRouteModules);
                } else {
                    content.innerHTML = '<div class="dev-tool-empty">⚠️ ' + (data?.msg || '加载失败') + '</div>';
                }
            })
            .catch(error => {
                console.warn('[DevToolPanel] Failed to load routes:', error);
                content.innerHTML = '<div class="dev-tool-empty">⚠️ 路由接口暂时不可用</div>';
                return Promise.resolve();
            });
    }

    function renderRouteModules(modules) {
        const content = document.getElementById('dev-tool-content');
        
        if (!modules || modules.length === 0) {
            content.innerHTML = '<div class="dev-tool-empty">📦 暂无模块</div>';
            return;
        }
        
        let html = '';
        modules.forEach(module => {
            if (!module.routes || module.routes.length === 0) return;
            
            html += '<div class="module-group">';
            html += '<div class="module-header" onclick="DevToolPanel.toggleModule(this)">';
            html += '<div class="module-name">';
            html += '<i class="fa fa-cube"></i>';
            html += module.name;
            html += '<span class="badge badge-primary">' + module.routes.length + '</span>';
            html += '</div>';
            html += '<i class="fa fa-chevron-down module-toggle"></i>';
            html += '</div>';
            html += '<div class="module-routes">';
            
            module.routes.forEach(route => {
                html += '<div class="route-item" onclick="DevToolPanel.openRoute(\'' + route.url + '\')">';
                html += '<a href="' + route.url + '" class="route-path" onclick="event.stopPropagation()">' + (route.path || route.url) + '</a>';
                html += '<div class="route-info">' + route.method + ' · ' + route.controller.split('\\').pop() + '</div>';
                html += '</div>';
            });
            
            html += '</div>';
            html += '</div>';
        });
        
        content.innerHTML = html;
        
        // 恢复搜索
        const searchInput = document.getElementById('route-search-input');
        if (state.routeSearchKeyword) {
            searchInput.value = state.routeSearchKeyword;
            searchRoutes({ target: searchInput });
        }
    }

    function toggleModule(header) {
        header.classList.toggle('collapsed');
        const routes = header.nextElementSibling;
        routes.classList.toggle('collapsed');
    }

    function openRoute(url) {
        window.open(url, '_blank');
    }

    function searchRoutes(event) {
        const keyword = event.target.value.trim().toLowerCase();
        state.routeSearchKeyword = keyword;
        saveState();
        
        if (!keyword) {
            renderRouteModules(state.allRouteModules);
            return;
        }
        
        const filtered = state.allRouteModules.map(module => {
            const matchingRoutes = module.routes.filter(route => {
                return route.path.toLowerCase().includes(keyword) ||
                       route.url.toLowerCase().includes(keyword) ||
                       module.name.toLowerCase().includes(keyword);
            });
            
            if (matchingRoutes.length > 0) {
                return { ...module, routes: matchingRoutes };
            }
            return null;
        }).filter(m => m !== null);
        
        renderRouteModules(filtered);
    }

    // ========== 文档功能 ==========
    /**
     * 构建开发工具后端 API URL（使用 rest_backend 前缀，避免 /api/rest/ 错误导致 404）
     * 优先 window.api，其次 window.site.api_host；无可用 base 时返回空字符串。
     */
    function getDevToolApiUrl(path, params) {
        const basePath = 'dev/tool/rest/v1/' + (path || '').replace(/^\//, '');
        if (typeof window.api === 'function') {
            return window.api(basePath, params || {});
        }
        if (window.site && window.site.api_host) {
            const base = (window.site.api_host || '').replace(/\/$/, '');
            const url = base ? (base + '/' + basePath) : '';
            if (!url) return '';
            if (params && typeof params === 'object' && Object.keys(params).length > 0) {
                const q = new URLSearchParams(params).toString();
                return q ? (url + (url.indexOf('?') >= 0 ? '&' : '?') + q) : url;
            }
            return url;
        }
        return '';
    }

    function loadModules() {
        const url = getDevToolApiUrl('document/modules');
        if (!url) {
            console.warn('[DevToolPanel] Cannot build document API URL (missing window.api / window.site.api_host)');
            return Promise.resolve();
        }
        return fetch(url)
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.allModules = data.data || [];
                    updateModuleSelect();
                } else {
                    console.warn('[DevToolPanel] Failed to load modules:', data?.msg || 'Unknown error');
                    state.allModules = [];
                    updateModuleSelect();
                }
            })
            .catch(error => {
                console.warn('[DevToolPanel] Failed to load modules:', error);
                state.allModules = [];
                updateModuleSelect();
                // 不要阻塞初始化
                return Promise.resolve();
            });
    }

    function updateModuleSelect() {
        const select = document.getElementById('doc-module-select');
        select.innerHTML = '<option value="">选择模块...</option>';
        
        state.allModules.forEach(module => {
            const option = document.createElement('option');
            option.value = module.name;
            option.textContent = module.display_name + ' (' + module.doc_count + ')';
            if (module.name === state.selectedModule) {
                option.selected = true;
            }
            select.appendChild(option);
        });
    }

    function switchDocSearchMode(button, mode) {
        document.querySelectorAll('#doc-search-area .search-mode-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        button.classList.add('active');
        
        state.docSearchMode = mode;
        saveState();
        
        const moduleSelect = document.getElementById('doc-module-select');
        if (mode === 'module') {
            moduleSelect.classList.add('show');
        } else {
            moduleSelect.classList.remove('show');
            state.selectedModule = '';
        }
        
        searchDocsAPI();
    }

    function onModuleChange() {
        const select = document.getElementById('doc-module-select');
        state.selectedModule = select.value;
        saveState();
        searchDocsAPI();
    }

    function searchDocs(event) {
        const keyword = event.target.value.trim();
        state.docSearchKeyword = keyword;
        saveState();
        searchDocsAPI();
    }

    function searchDocsAPI() {
        const content = document.getElementById('dev-tool-content');
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>搜索文档...</div></div>';
        
        const query = {};
        if (state.docSearchKeyword) query.keyword = state.docSearchKeyword;
        if (state.docSearchMode === 'module' && state.selectedModule) query.module = state.selectedModule;
        if (state.docSearchPage) query.page = state.docSearchPage;
        if (state.docSearchSize) query.size = state.docSearchSize;
        const url = getDevToolApiUrl('document/search', query);
        if (!url) {
            content.innerHTML = '<div class="dev-tool-empty">⚠️ 无法构建 API 地址（请从后台打开本页）</div>';
            return;
        }
        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.docList = data.data.items || [];
                    renderDocList(state.docList);
                } else {
                    content.innerHTML = '<div class="dev-tool-empty">⚠️ ' + (data.msg || '搜索失败') + '</div>';
                }
            })
            .catch(error => {
                content.innerHTML = '<div class="dev-tool-empty">❌ 搜索失败: ' + error.message + '</div>';
            });
    }

    function renderDocList(docs) {
        const content = document.getElementById('dev-tool-content');
        
        if (!docs || docs.length === 0) {
            content.innerHTML = '<div class="dev-tool-empty">📄 暂无文档</div>';
            return;
        }
        
        let html = '';
        docs.forEach(doc => {
            const isActive = doc.id === state.currentDocId ? ' active' : '';
            html += '<div class="doc-list-item' + isActive + '" onclick="DevToolPanel.openDoc(' + doc.id + ')">';
            html += '<div class="doc-title">' + (doc.title || '无标题') + '</div>';
            html += '<div class="doc-meta">';
            html += '<span class="doc-module-tag">' + (doc.module_display || doc.module_name) + '</span>';
            if (doc.summary) {
                const summary = doc.summary.length > 60 ? doc.summary.substring(0, 60) + '...' : doc.summary;
                html += '<span>' + summary + '</span>';
            }
            html += '</div>';
            html += '</div>';
        });
        
        content.innerHTML = html;
    }

    function openDoc(docId) {
        state.currentDocId = docId;
        state.currentDocScrollPos = 0;
        saveState();
        loadDocDetail(docId);
    }

    function loadDocDetail(docId) {
        const content = document.getElementById('dev-tool-content');
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载文档...</div></div>';
        
        const url = getDevToolApiUrl('document/detail', { id: docId });
        if (!url) {
            content.innerHTML = '<div class="dev-tool-empty">⚠️ 无法构建 API 地址（请从后台打开本页）</div>';
            return;
        }
        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data && Number(data.code) === 200) {
                    renderDocContent(data.data);
                } else {
                    content.innerHTML = '<div class="dev-tool-empty">⚠️ ' + (data.msg || '加载失败') + '</div>';
                }
            })
            .catch(error => {
                content.innerHTML = '<div class="dev-tool-empty">❌ 加载失败: ' + error.message + '</div>';
            });
    }

    function renderDocContent(doc) {
        const content = document.getElementById('dev-tool-content');
        
        // 简单 Markdown 转换为 HTML
        let html = doc.content || '';
        html = html
            .replace(/^### (.+)$/gm, '<h3>$1</h3>')
            .replace(/^## (.+)$/gm, '<h2>$1</h2>')
            .replace(/^# (.+)$/gm, '<h1>$1</h1>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/`([^`]+)`/g, '<code>$1</code>')
            .replace(/```([\s\S]+?)```/g, '<pre><code>$1</code></pre>')
            .replace(/\[([^\]]+)\]\(([^\)]+)\)/g, '<a href="$2" target="_blank">$1</a>')
            .replace(/\n\n/g, '</p><p>')
            .replace(/\n/g, '<br>');
        
        html = '<p>' + html + '</p>';
        
        content.innerHTML = '<div class="doc-content-view show">' +
            '<div class="doc-content-header">' +
                '<button class="doc-back-btn" onclick="DevToolPanel.backToDocList()">' +
                    '<i class="fa fa-arrow-left"></i> 返回列表' +
                '</button>' +
            '</div>' +
            '<div class="doc-content-title">' + (doc.title || '无标题') + '</div>' +
            '<div class="doc-meta" style="margin-bottom: 12px;">' +
                '<span class="doc-module-tag">' + (doc.module_display || doc.module_name) + '</span>' +
            '</div>' +
            '<div class="doc-content-body">' + html + '</div>' +
        '</div>';
        
        // 恢复滚动位置
        setTimeout(() => {
            content.scrollTop = state.currentDocScrollPos;
        }, 50);
        
        // 监听滚动事件保存位置
        content.onscroll = () => {
            state.currentDocScrollPos = content.scrollTop;
            saveState();
        };
    }

    function backToDocList() {
        state.currentDocId = null;
        state.currentDocScrollPos = 0;
        saveState();
        searchDocsAPI();
    }

    function restoreDocSearchState() {
        // 恢复搜索模式
        const modeButtons = document.querySelectorAll('#doc-search-area .search-mode-btn');
        modeButtons.forEach(btn => {
            if (btn.dataset.mode === state.docSearchMode) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
        
        // 恢复模块选择
        const moduleSelect = document.getElementById('doc-module-select');
        if (state.docSearchMode === 'module') {
            moduleSelect.classList.add('show');
            moduleSelect.value = state.selectedModule;
        }
        
        // 恢复搜索关键词
        const searchInput = document.getElementById('doc-search-input');
        searchInput.value = state.docSearchKeyword;
        
        // 如果有打开的文档，直接加载
        if (state.currentDocId) {
            loadDocDetail(state.currentDocId);
        } else {
            // 否则执行搜索
            searchDocsAPI();
        }
    }

    // ========== 性能统计功能 ==========
    function initPerformanceMonitoring() {
        // 拦截fetch请求，记录API耗时
        const originalFetch = window.fetch;
        window.fetch = function(...args) {
            const startTime = performance.now();
            const url = args[0] || '';
            
            return originalFetch.apply(this, args)
                .then(response => {
                    const endTime = performance.now();
                    const duration = endTime - startTime;
                    
                    // 记录API请求（只记录开发工具面板的API请求）
                    if (typeof url === 'string' && url.includes('/dev/tool/')) {
                        state.apiRequests.push({
                            url: url,
                            method: 'GET',
                            duration: duration,
                            timestamp: Date.now(),
                            status: response.status
                        });
                        
                        // 只保留最近50条记录
                        if (state.apiRequests.length > 50) {
                            state.apiRequests.shift();
                        }
                        
                        // 如果当前在性能标签页，更新显示
                        if (state.activeMainTab === 'performance') {
                            renderPerformanceStats();
                        }
                    }
                    
                    return response;
                })
                .catch(error => {
                    const endTime = performance.now();
                    const duration = endTime - startTime;
                    
                    if (typeof url === 'string' && url.includes('/dev/tool/')) {
                        state.apiRequests.push({
                            url: url,
                            method: 'GET',
                            duration: duration,
                            timestamp: Date.now(),
                            status: 'error',
                            error: error.message
                        });
                        
                        if (state.apiRequests.length > 50) {
                            state.apiRequests.shift();
                        }
                        
                        if (state.activeMainTab === 'performance') {
                            renderPerformanceStats();
                        }
                    }
                    
                    throw error;
                });
        };
    }

    function getPerformanceTiming() {
        const timing = performance.timing;
        if (!timing) {
            return null;
        }
        
        return {
            // DNS查询耗时
            dns: timing.domainLookupEnd - timing.domainLookupStart,
            // TCP连接耗时
            tcp: timing.connectEnd - timing.connectStart,
            // 请求耗时
            request: timing.responseStart - timing.requestStart,
            // 响应耗时
            response: timing.responseEnd - timing.responseStart,
            // DOM解析耗时
            domParsing: timing.domInteractive - timing.responseEnd,
            // DOMContentLoaded耗时
            domContentLoaded: timing.domContentLoadedEventEnd - timing.navigationStart,
            // 页面完全加载耗时
            loadComplete: timing.loadEventEnd - timing.navigationStart,
            // 首次渲染时间
            firstPaint: performance.getEntriesByType('paint').find(entry => entry.name === 'first-paint')?.startTime || 0,
            // 首次内容绘制时间
            firstContentfulPaint: performance.getEntriesByType('paint').find(entry => entry.name === 'first-contentful-paint')?.startTime || 0
        };
    }

    function formatTime(ms) {
        if (ms < 1) {
            return (ms * 1000).toFixed(2) + ' μs';
        } else if (ms < 1000) {
            return ms.toFixed(2) + ' ms';
        } else {
            return (ms / 1000).toFixed(2) + ' s';
        }
    }

    function formatSqlPreview(sql, maxLen) {
        var normalized = String(sql || '').replace(/\s+/g, ' ').trim();
        if (!normalized) {
            return '';
        }
        if (normalized.length <= maxLen) {
            return normalized;
        }
        return normalized.substring(0, maxLen) + ' ...';
    }

    /** 从 db span 的 name（如 db::find::m_acl）解析出 operation 和 table，兼容无 meta 的旧数据 */
    function parseDbSpanName(name) {
        var n = String(name || '');
        if (n.indexOf('db::') !== 0) {
            return { operation: n || '—', table: '—' };
        }
        var parts = n.split('::');
        if (parts.length >= 3) {
            return { operation: parts[1] || '—', table: parts[2] || '—' };
        }
        if (parts.length === 2) {
            return { operation: parts[1] || '—', table: '—' };
        }
        return { operation: '—', table: '—' };
    }

    function getTimeClass(ms, fast = 100, slow = 500) {
        if (ms < fast) return 'fast';
        if (ms < slow) return 'medium';
        return 'slow';
    }

    function buildTraceTree(spans) {
        var nodes = spans.map(function(s) {
            return {
                name: s.name || '',
                duration_ms: Number(s.duration_ms) || 0,
                category: s.category || '',
                parent: s.parent || null,
                db_duration_ms: Number(s.db_duration_ms || 0),
                children: []
            };
        });
        var byName = {};
        nodes.forEach(function(n) { byName[n.name] = n; });
        nodes.forEach(function(n) {
            if (n.parent && byName[n.parent]) byName[n.parent].children.push(n);
        });
        return nodes.filter(function(n) { return !n.parent; });
    }

    function renderTraceNode(node, depth, totalMsRef) {
        if (!node.parent) totalMsRef.value += node.duration_ms;
        var timeClass = getTimeClass(node.duration_ms);
        var category = node.category ? ' <span style="opacity:0.7;font-size:11px">[' + escapeHtml(node.category) + ']</span>' : '';
        var hasChildren = node.children && node.children.length > 0;
        var indent = depth > 0 ? ' style="padding-left:' + (depth * 14) + 'px"' : '';
        var html = '<div class="performance-item trace-node" data-depth="' + depth + '"' + indent + '>';
        if (hasChildren) {
            html += '<span class="trace-toggle" data-expanded="0" role="button" tabindex="0" title="展开/折叠">';
            html += '<i class="fa fa-caret-right"></i></span>';
        } else {
            html += '<span class="trace-toggle-placeholder"></span>';
        }
        html += '<span class="performance-label">' + escapeHtml(String(node.name)) + category + '</span>';
        html += '<span class="performance-value ' + timeClass + '">';
        html += formatTime(node.duration_ms);
        if (node.db_duration_ms && node.db_duration_ms > 0) {
            html += ' <span style="margin-left:6px;font-size:11px;color:#555;">DB ' + formatTime(node.db_duration_ms) + '</span>';
        }
        html += ' <span class="performance-badge ' + timeClass + '">' + (timeClass === 'fast' ? '快' : timeClass === 'medium' ? '中' : '慢') + '</span>';
        html += '</span>';
        html += '</div>';
        if (hasChildren) {
            html += '<div class="trace-children" style="display:none">';
            node.children.forEach(function(ch) { html += renderTraceNode(ch, depth + 1, totalMsRef); });
            html += '</div>';
        }
        return html;
    }

    function renderRequestTrace() {
        const content = document.getElementById('dev-tool-content');
        if (!content) return;
        const spans = (typeof window.__WELINE_REQUEST_TRACE__ !== 'undefined' && Array.isArray(window.__WELINE_REQUEST_TRACE__))
            ? window.__WELINE_REQUEST_TRACE__
            : [];
        const codeSpans = spans.filter(function(s) { return (s.category || '') !== 'db'; });
        const dbSpans = spans.filter(function(s) { return (s.category || '') === 'db'; });

        let html = '<div class="performance-stats">';

        // 子 Tab：编码 / DB
        html += '<div style="display:flex;border-bottom:1px solid #eee;margin-bottom:6px;">';
        html += '<button type="button" id="trace-subtab-code" class="dev-tool-tab dev-tool-subtab active" style="flex:1;font-size:12px;padding:4px 8px;border:none;border-bottom:2px solid #667eea;background:#f7f7ff;color:#333;cursor:pointer;">编码</button>';
        html += '<button type="button" id="trace-subtab-db" class="dev-tool-tab dev-tool-subtab" style="flex:1;font-size:12px;padding:4px 8px;border:none;border-bottom:2px solid transparent;background:#fafafa;color:#666;cursor:pointer;">DB</button>';
        html += '</div>';

        // 编码视图
        html += '<div id="trace-code-view" class="performance-section">';
        html += '<div class="performance-section-title">';
        html += '<i class="fa fa-list-alt"></i> 请求生命周期链路（编码阶段）';
        html += '</div>';
        if (codeSpans.length === 0) {
            html += '<div class="dev-tool-empty">当前页面无请求链路数据。</div>';
            html += '<div style="margin-top:8px;padding:8px;font-size:11px;color:#888;background:#f5f5f5;border-radius:4px;">';
            html += '请确认：<br>1) 已开启开发模式（env.php 中 system.deploy 为 dev）或开启 DEBUG；<br>';
            html += '2) 本页为 HTML 响应（WLS/CLI/FPM 均支持）。<br>刷新页面后再试。';
            html += '</div>';
        } else {
            var roots = buildTraceTree(codeSpans);
            var totalMsRef = { value: 0 };
            roots.forEach(function(node) { html += renderTraceNode(node, 0, totalMsRef); });
            html += '<div class="performance-item" style="border-top:1px solid #eee;margin-top:6px;padding-top:6px;">';
            html += '<span class="performance-label">合计</span>';
            html += '<span class="performance-value">' + formatTime(totalMsRef.value) + '</span>';
            html += '</div>';
        }
        html += '</div>';

        // DB 视图
        html += '<div id="trace-db-view" class="performance-section" style="display:none;">';
        html += '<div class="performance-section-title">';
        html += '<i class="fa fa-database"></i> 数据库链路';
        html += '</div>';
        if (dbSpans.length === 0) {
            html += '<div class="dev-tool-empty">当前请求未记录数据库访问。</div>';
        } else {
            let totalDb = 0;
            dbSpans.forEach(function(s) { totalDb += Number(s.duration_ms || 0); });
            html += '<div style="max-height:320px;overflow:auto;font-size:11px;border:1px solid #eee;border-radius:4px;">';
            html += '<table style="width:100%;border-collapse:collapse;table-layout:fixed;">';
            html += '<thead><tr style="background:#fafafa;">';
            html += '<th style="padding:4px 6px;text-align:left;width:70px;">操作</th>';
            html += '<th style="padding:4px 6px;text-align:left;width:100px;">表</th>';
            html += '<th style="padding:4px 6px;text-align:left;">SQL</th>';
            html += '<th style="padding:4px 6px;text-align:left;width:90px;">父阶段</th>';
            html += '<th style="padding:4px 6px;text-align:right;width:80px;white-space:nowrap;">耗时</th></tr></thead>';
            html += '<tbody>';
            dbSpans.forEach(function(s) {
                const meta = (s && typeof s.meta === 'object' && s.meta !== null) ? s.meta : {};
                const parsed = parseDbSpanName(s.name);
                const operation = String(meta.operation || parsed.operation || '');
                const table = String(meta.table || parsed.table || '');
                const sql = String(meta.sql || '');
                const parent = String(s.parent || '');
                const durationNum = Number(s.duration_ms);
                const dur = (durationNum >= 0 && durationNum < 1e9) ? formatTime(durationNum) : '—';
                const sqlPreview = formatSqlPreview(sql, 140);
                html += '<tr>';
                html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;">' + escapeHtml(operation || '—') + '</td>';
                html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;">' + escapeHtml(table || '—') + '</td>';
                if (sql) {
                    html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;word-break:break-word;overflow:hidden;">';
                    html += '<details><summary style="cursor:pointer;">' + escapeHtml(sqlPreview) + '</summary><pre style="margin:4px 0 0;white-space:pre-wrap;word-break:break-word;font-size:11px;">' + escapeHtml(sql) + '</pre></details>';
                    html += '</td>';
                } else {
                    html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;color:#999;">(无 SQL 文本)</td>';
                }
                html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;color:#777;">' + escapeHtml(parent) + '</td>';
                html += '<td style="padding:3px 6px;border-top:1px solid #f0f0f0;text-align:right;white-space:nowrap;">' + dur + '</td>';
                html += '</tr>';
            });
            html += '</tbody></table></div>';
            html += '<div class="performance-item" style="border-top:1px solid #eee;margin-top:6px;padding-top:6px;">';
            html += '<span class="performance-label">DB 合计</span>';
            html += '<span class="performance-value">' + formatTime(totalDb) + '</span>';
            html += '</div>';
        }
        html += '</div>'; // end db view

        html += '</div>'; // end performance-stats
        content.innerHTML = html;
        var container = content.closest('.dev-tool-container');
        if (container) {
            container.querySelectorAll('.trace-toggle').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var expanded = btn.getAttribute('data-expanded') === '1';
                    var children = btn.closest('.performance-item').nextElementSibling;
                    if (children && children.classList.contains('trace-children')) {
                        children.style.display = expanded ? 'none' : 'block';
                        btn.setAttribute('data-expanded', expanded ? '0' : '1');
                        btn.querySelector('i').className = expanded ? 'fa fa-caret-right' : 'fa fa-caret-down';
                    }
                });
            });

            // 绑定子 Tab 切换：编码 / DB
            var codeBtn = document.getElementById('trace-subtab-code');
            var dbBtn = document.getElementById('trace-subtab-db');
            var codeView = document.getElementById('trace-code-view');
            var dbView = document.getElementById('trace-db-view');
            if (codeBtn && dbBtn && codeView && dbView) {
                codeBtn.addEventListener('click', function () {
                    codeBtn.classList.add('active');
                    codeBtn.style.borderBottomColor = '#667eea';
                    codeBtn.style.background = '#f7f7ff';
                    dbBtn.classList.remove('active');
                    dbBtn.style.borderBottomColor = 'transparent';
                    dbBtn.style.background = '#fafafa';
                    codeView.style.display = 'block';
                    dbView.style.display = 'none';
                });
                dbBtn.addEventListener('click', function () {
                    dbBtn.classList.add('active');
                    dbBtn.style.borderBottomColor = '#667eea';
                    dbBtn.style.background = '#f7f7ff';
                    codeBtn.classList.remove('active');
                    codeBtn.style.borderBottomColor = 'transparent';
                    codeBtn.style.background = '#fafafa';
                    codeView.style.display = 'none';
                    dbView.style.display = 'block';
                });
            }
        }
    }

    function escapeHtml(s) {
        const div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
    }

    function renderPerformanceStats() {
        const content = document.getElementById('dev-tool-content');
        if (!content) return;
        
        let html = '<div class="performance-stats">';
        
        // 页面加载性能
        html += '<div class="performance-section">';
        html += '<div class="performance-section-title">';
        html += '<i class="fa fa-globe"></i> 页面加载性能';
        html += '</div>';
        
        const timing = getPerformanceTiming();
        if (timing) {
            const items = [
                { label: 'WLS处理耗时', value: (function() { try { var nav = performance.getEntriesByType('navigation')[0]; var st = nav && nav.serverTiming; if (st) { var wls = st.find(function(t) { return t.name === 'wls'; }); if (wls) return wls.duration; } } catch(e) {} return null; })(), unit: 'ms', optional: true },
                { label: 'DNS查询', value: timing.dns, unit: 'ms' },
                { label: 'TCP连接', value: timing.tcp, unit: 'ms' },
                { label: '请求发送', value: timing.request, unit: 'ms' },
                { label: '响应接收', value: timing.response, unit: 'ms' },
                { label: 'DOM解析', value: timing.domParsing, unit: 'ms' },
                { label: 'DOMContentLoaded', value: timing.domContentLoaded, unit: 'ms' },
                { label: '页面完全加载', value: timing.loadComplete, unit: 'ms' }
            ];
            
            if (timing.firstPaint > 0) {
                items.push({ label: '首次渲染 (FCP)', value: timing.firstPaint, unit: 'ms' });
            }
            if (timing.firstContentfulPaint > 0) {
                items.push({ label: '首次内容绘制 (FCP)', value: timing.firstContentfulPaint, unit: 'ms' });
            }
            
            items.forEach(item => {
                if (item.optional && (item.value == null || item.value === undefined)) return;
                const timeClass = getTimeClass(item.value);
                html += '<div class="performance-item">';
                html += '<span class="performance-label">' + item.label + '</span>';
                html += '<span class="performance-value ' + timeClass + '">';
                html += formatTime(item.value);
                html += ' <span class="performance-badge ' + timeClass + '">' + 
                    (timeClass === 'fast' ? '快' : timeClass === 'medium' ? '中' : '慢') + 
                    '</span>';
                html += '</span>';
                html += '</div>';
            });
        } else {
            html += '<div class="performance-item">';
            html += '<span class="performance-label">性能API不可用</span>';
            html += '</div>';
        }
        
        html += '</div>';
        
        // 资源加载统计
        html += '<div class="performance-section">';
        html += '<div class="performance-section-title">';
        html += '<i class="fa fa-cubes"></i> 资源加载统计';
        html += '</div>';
        
        const resources = performance.getEntriesByType('resource');
        const resourceStats = {
            total: resources.length,
            js: 0,
            css: 0,
            img: 0,
            font: 0,
            other: 0,
            totalSize: 0,
            totalTime: 0
        };
        
        resources.forEach(resource => {
            const name = resource.name.toLowerCase();
            if (name.endsWith('.js')) resourceStats.js++;
            else if (name.endsWith('.css')) resourceStats.css++;
            else if (name.match(/\.(jpg|jpeg|png|gif|svg|webp)$/)) resourceStats.img++;
            else if (name.match(/\.(woff|woff2|ttf|eot)$/)) resourceStats.font++;
            else resourceStats.other++;
            
            if (resource.transferSize) {
                resourceStats.totalSize += resource.transferSize;
            }
            resourceStats.totalTime += resource.duration || 0;
        });
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">总资源数</span>';
        html += '<span class="performance-value">' + resourceStats.total + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">JS文件</span>';
        html += '<span class="performance-value">' + resourceStats.js + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">CSS文件</span>';
        html += '<span class="performance-value">' + resourceStats.css + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">图片文件</span>';
        html += '<span class="performance-value">' + resourceStats.img + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">字体文件</span>';
        html += '<span class="performance-value">' + resourceStats.font + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">其他资源</span>';
        html += '<span class="performance-value">' + resourceStats.other + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">总传输大小</span>';
        html += '<span class="performance-value">' + formatBytes(resourceStats.totalSize) + '</span>';
        html += '</div>';
        
        html += '<div class="performance-item">';
        html += '<span class="performance-label">总加载时间</span>';
        html += '<span class="performance-value ' + getTimeClass(resourceStats.totalTime) + '">' + 
            formatTime(resourceStats.totalTime) + '</span>';
        html += '</div>';
        
        html += '</div>';
        
        // API请求统计
        html += '<div class="performance-section">';
        html += '<div class="performance-section-title">';
        html += '<i class="fa fa-exchange"></i> API请求统计 (最近' + state.apiRequests.length + '条)';
        html += '</div>';
        
        if (state.apiRequests.length === 0) {
            html += '<div class="performance-item">';
            html += '<span class="performance-label">暂无API请求记录</span>';
            html += '</div>';
        } else {
            // 显示最近10条
            const recentRequests = state.apiRequests.slice(-10).reverse();
            recentRequests.forEach(req => {
                const timeClass = getTimeClass(req.duration, 50, 200);
                html += '<div class="api-request-item">';
                html += '<div class="api-request-url">' + req.url + '</div>';
                html += '<div class="api-request-time">';
                html += '<span class="performance-value ' + timeClass + '">' + formatTime(req.duration) + '</span>';
                html += ' · 状态: ' + (req.status || req.error || 'unknown');
                html += ' · ' + new Date(req.timestamp).toLocaleTimeString();
                html += '</div>';
                html += '</div>';
            });
            
            // 统计信息
            const avgDuration = state.apiRequests.reduce((sum, req) => sum + req.duration, 0) / state.apiRequests.length;
            const maxDuration = Math.max(...state.apiRequests.map(req => req.duration));
            const minDuration = Math.min(...state.apiRequests.map(req => req.duration));
            
            html += '<div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e8e8e8;">';
            html += '<div class="performance-item">';
            html += '<span class="performance-label">平均耗时</span>';
            html += '<span class="performance-value ' + getTimeClass(avgDuration) + '">' + formatTime(avgDuration) + '</span>';
            html += '</div>';
            html += '<div class="performance-item">';
            html += '<span class="performance-label">最大耗时</span>';
            html += '<span class="performance-value ' + getTimeClass(maxDuration) + '">' + formatTime(maxDuration) + '</span>';
            html += '</div>';
            html += '<div class="performance-item">';
            html += '<span class="performance-label">最小耗时</span>';
            html += '<span class="performance-value ' + getTimeClass(minDuration) + '">' + formatTime(minDuration) + '</span>';
            html += '</div>';
            html += '</div>';
        }
        
        html += '</div>';
        
        html += '</div>';
        content.innerHTML = html;
    }

    function formatBytes(bytes) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return (bytes / Math.pow(k, i)).toFixed(2) + ' ' + sizes[i];
    }

    // ========== 导出公共API ==========
    return {
        init,
        toggle,
        closePanel,
        updateExpandDirection,
        switchMainTab,
        switchRouteTab,
        searchRoutes,
        toggleModule,
        openRoute,
        switchDocSearchMode,
        onModuleChange,
        searchDocs,
        openDoc,
        backToDocList,
        registerExtensionTab,
    };
})();

// 页面加载完成后初始化
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', DevToolPanel.init);
} else {
    DevToolPanel.init();
}
</script>