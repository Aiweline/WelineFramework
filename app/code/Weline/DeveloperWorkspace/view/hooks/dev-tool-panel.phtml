                        btn.querySelector('i').className = expanded ? 'fa fa-caret-right' : 'fa fa-caret-down';
                    }
                });
            });

            var lifecycleDetail = document.getElementById('trace-lifecycle-detail');
            if (lifecycleDetail && typeof allSpans !== 'undefined' && Array.isArray(allSpans)) {
                var lifecycleSpans = allSpans.slice().sort(function(a, b) {
                    return (Number(a.seq || 0) - Number(b.seq || 0));
