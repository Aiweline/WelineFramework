    }
    
    /* 向左展开时的拖动状态 */
    #dev-tool-panel.expand-left .dev-tool-trigger.drag-ready {
        left: -16px;
        right: auto;
    }
    
    .dev-tool-trigger.drag-ready::after {
        content: '⋮⋮';
        position: absolute;
        top: 50%;
