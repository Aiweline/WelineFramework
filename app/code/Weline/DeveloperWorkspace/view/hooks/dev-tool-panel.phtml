        align-items: center;
        gap: 6px;
        color: var(--dev-panel-accent);
        font-size: 12px;
        font-weight: 750;
    }

    #dev-tool-panel .dev-tool-performance-title {
        margin-top: 6px;
        color: var(--dev-panel-ink);
        font-size: 20px;
        font-weight: 800;
        line-height: 1.2;
