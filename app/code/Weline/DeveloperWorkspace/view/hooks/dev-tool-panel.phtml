<script>
const DevToolPanel = (function() {
    const PANEL_UI_VERSION = '20260701-workspace-ui-v9-performance-render';

    // ========== 状态管理 ==========
    const state = {
        // 面板状态
        collapsed: true,
        activeMainTab: 'performance',
        frameworkTab: 'routes',
        layoutMode: 'workspace', // workspace or compact
        
        // 路由相关
        currentRouteType: '<?php echo $panelType; ?>',
        routeSearchKeyword: '',
        allRouteModules: [],
        loadedRouteTypes: {},
        
        // 文档相关
        docSearchMode: 'all', // 'all' or 'module'
        docSearchKeyword: '',
        selectedModule: '',
        allModules: [],
        docList: [],
        currentDocId: null,
        currentDocScrollPos: 0,
        modulesLoaded: false,
        docsInitialized: false,
        docSearchTimer: null,
        
        // 拖拽相关
        panelX: 0,
        panelY: 0,
        isDragging: false,
        dragStartX: 0,
        dragStartY: 0,
        panelStartX: 0,
        panelStartY: 0,
        
        // 性能统计相关
        pageLoadStartTime: performance.timing ? performance.timing.navigationStart : Date.now(),
        apiRequests: [], // 存储API请求记录

        // 请求链路「编码」视图：graph=生命周期图，tree=常规树形，duration=按耗时倒序平铺
        traceCodeLayout: 'graph',
        // 请求链路「DB」视图：normal=常规顺序，duration=按耗时倒序
        traceDbLayout: 'normal',
        traceLoaded: false,
        traceSpans: null,
        traceSummary: null,
    };

    let pageContextBound = false;
    let pageTitleObserver = null;

    // ========== LocalStorage 管理 ==========
    function saveState() {
        const dataToSave = {
            collapsed: state.collapsed,
            activeMainTab: state.activeMainTab,
            frameworkTab: state.frameworkTab,
            currentRouteType: state.currentRouteType,
            routeSearchKeyword: state.routeSearchKeyword,
            docSearchMode: state.docSearchMode,
            docSearchKeyword: state.docSearchKeyword,
            selectedModule: state.selectedModule,
            currentDocId: state.currentDocId,
            currentDocScrollPos: state.currentDocScrollPos,
            layoutMode: state.layoutMode,
            panelX: state.panelX,
            panelY: state.panelY,
            traceCodeLayout: state.traceCodeLayout,
            traceDbLayout: state.traceDbLayout,
            panelUiVersion: PANEL_UI_VERSION,
        };
        localStorage.setItem('dev-panel-state', JSON.stringify(dataToSave));
    }

    function isBuiltInMainTab(tab) {
        return ['framework', 'docs', 'performance'].indexOf(tab) !== -1;
    }

    function loadState() {
        const saved = localStorage.getItem('dev-panel-state');
        if (saved) {
            try {
                const data = JSON.parse(saved);
                if (data.activeMainTab === 'routes' || data.activeMainTab === 'trace') {
                    data.frameworkTab = data.activeMainTab === 'trace' ? 'trace' : 'routes';
                    data.activeMainTab = 'framework';
                }
                Object.assign(state, data);
                state.layoutMode = state.layoutMode === 'compact' ? 'compact' : 'workspace';
                state.activeMainTab = typeof state.activeMainTab === 'string' && state.activeMainTab
                    ? state.activeMainTab
                    : 'performance';
                state.frameworkTab = state.frameworkTab === 'trace' ? 'trace' : 'routes';
                if (data.panelUiVersion !== PANEL_UI_VERSION) {
                    state.layoutMode = 'workspace';
                    if (state.activeMainTab === 'framework') {
                        state.frameworkTab = 'trace';
                    }
                    state.traceCodeLayout = 'graph';
                }
                state.traceCodeLayout = ['graph', 'tree', 'duration'].indexOf(state.traceCodeLayout) !== -1
                    ? state.traceCodeLayout
                    : 'graph';
                state.traceDbLayout = state.traceDbLayout === 'duration' ? 'duration' : 'normal';
            } catch (e) {
                console.error('[DevToolPanel] Failed to load state:', e);
            }
        }
    }

    function getPanelFallbackSize() {
        const isCompact = state.layoutMode === 'compact';
        const horizontalGutter = window.innerWidth <= 480 ? 0 : (isCompact ? 24 : 48);
        const verticalGutter = window.innerWidth <= 480 ? 0 : (isCompact ? 24 : 48);
        const availableWidth = Math.max(320, window.innerWidth - horizontalGutter);
        const availableHeight = Math.max(320, window.innerHeight - verticalGutter);

        return {
            width: isCompact ? Math.min(520, availableWidth) : Math.min(1440, availableWidth),
            height: isCompact ? Math.min(680, availableHeight) : Math.min(930, availableHeight),
        };
    }

    function getPanelSize(panelEl) {
        const fallback = getPanelFallbackSize();
        const container = panelEl ? panelEl.querySelector('.dev-tool-container') : null;
        const rect = container ? container.getBoundingClientRect() : null;

        return {
            width: rect && rect.width ? rect.width : fallback.width,
            height: rect && rect.height ? rect.height : fallback.height,
        };
    }

    function applyLayoutMode() {
        const panel = document.getElementById('dev-tool-panel');
        if (!panel) return;

        state.layoutMode = state.layoutMode === 'compact' ? 'compact' : 'workspace';
        const isCompact = state.layoutMode === 'compact';
        panel.classList.toggle('dev-panel-compact', isCompact);

        const button = panel.querySelector('[data-dev-tool-action="toggle-layout"]');
        if (!button) return;

        const icon = button.querySelector('i');
        const label = button.querySelector('.dev-tool-layout-label');
        const title = isCompact ? '切换到宽屏工作区' : '缩小为紧凑面板';
        button.title = title;
        button.setAttribute('aria-label', title);

        if (icon) {
            icon.className = isCompact ? 'fa fa-expand' : 'fa fa-compress';
        }
        if (label) {
            label.textContent = isCompact ? '宽屏' : '紧凑';
        }
    }

    function toggleLayoutMode() {
        state.layoutMode = state.layoutMode === 'compact' ? 'workspace' : 'compact';
        applyLayoutMode();

        const panel = document.getElementById('dev-tool-panel');
        if (!panel) {
            saveState();
            return;
        }

        requestAnimationFrame(function() {
            correctPanelPosition(panel);
            updateExpandDirection();
            updateContainerPosition();
            saveState();
        });
    }

    function currentPageTitle() {
        const title = String(document.title || '').trim();
        if (title) {
            return title;
        }

        const path = String(window.location.pathname || '').trim();
        if (path && path !== '/') {
            return path;
        }

        return window.location.host || '当前页面';
    }

    function updatePageContext() {
        const panel = document.getElementById('dev-tool-panel');
        if (!panel) {
            return;
        }

        const link = panel.querySelector('[data-dev-tool-page-link]');
        const titleNode = panel.querySelector('[data-dev-tool-page-title]');
        const urlNode = panel.querySelector('[data-dev-tool-page-url]');
        const href = window.location.href;
        const title = currentPageTitle();

        if (link) {
            link.href = href;
            link.title = title + '\n' + href;
            link.setAttribute('aria-label', '打开当前页面：' + title);
        }
        if (titleNode) {
            titleNode.textContent = title;
        }
        if (urlNode) {
            urlNode.textContent = href;
        }
    }

    function bindPageContext() {
        updatePageContext();
        if (pageContextBound) {
            return;
        }

        pageContextBound = true;
        window.addEventListener('hashchange', updatePageContext);
        window.addEventListener('popstate', updatePageContext);
        window.addEventListener('pageshow', updatePageContext);

        const titleNode = document.querySelector('head > title');
        if (titleNode && window.MutationObserver) {
            pageTitleObserver = new MutationObserver(updatePageContext);
            pageTitleObserver.observe(titleNode, { childList: true, characterData: true, subtree: true });
        }
    }

    function bindPanelActions(panel) {
        if (!panel || panel.dataset.devToolActionsBound === '1') {
            return;
        }

        panel.dataset.devToolActionsBound = '1';
        panel.addEventListener('click', handlePanelActionClick);
        panel.addEventListener('change', handlePanelActionChange);
        panel.addEventListener('keyup', handlePanelActionKeyup);
        panel.addEventListener('keydown', handlePanelActionKeydown);
    }

    function handlePanelActionClick(event) {
        if (event.target.closest('.route-path')) {
            event.stopPropagation();
            return;
        }

        const actionEl = event.target.closest('[data-dev-tool-action]');
        if (!actionEl) {
            return;
        }

        event.preventDefault();
        event.stopPropagation();

        switch (actionEl.dataset.devToolAction) {
            case 'close-panel':
                closePanel();
                break;
            case 'toggle-layout':
                toggleLayoutMode();
                break;
            case 'switch-main-tab':
                switchMainTab(actionEl, actionEl.dataset.tab || 'docs');
                break;
            case 'switch-framework-tab':
                switchFrameworkTab(actionEl, actionEl.dataset.frameworkTab || 'routes');
                break;
            case 'switch-route-tab':
                switchRouteTab(actionEl, actionEl.dataset.type || state.currentRouteType || 'frontend');
                break;
            case 'switch-doc-search-mode':
                switchDocSearchMode(actionEl, actionEl.dataset.mode || 'all');
                break;
            case 'toggle-module':
                toggleModule(actionEl);
                break;
            case 'open-route':
                openRoute(actionEl.dataset.routeUrl || '');
                break;
            case 'open-doc':
                {
                    const docId = Number.parseInt(actionEl.dataset.docId || '', 10);
                    if (Number.isFinite(docId)) {
                        openDoc(docId);
                    }
                }
                break;
            case 'back-to-doc-list':
                backToDocList();
                break;
            case 'retry-doc-api':
                retryDocApi();
                break;
        }
    }

    function handlePanelActionChange(event) {
        const actionEl = event.target.closest('[data-dev-tool-change-action]');
        if (!actionEl) {
            return;
        }

        if (actionEl.dataset.devToolChangeAction === 'doc-module-change') {
            onModuleChange();
        }
    }

    function handlePanelActionKeyup(event) {
        const actionEl = event.target.closest('[data-dev-tool-keyup-action]');
        if (!actionEl) {
            return;
        }

        if (actionEl.dataset.devToolKeyupAction === 'search-routes') {
            searchRoutes(event);
        } else if (actionEl.dataset.devToolKeyupAction === 'search-docs') {
            searchDocs(event);
        }
    }

    function handlePanelActionKeydown(event) {
        if (event.key !== 'Enter' && event.key !== ' ') {
            return;
        }

        const actionEl = event.target.closest('[data-dev-tool-action]');
        if (!actionEl) {
            return;
        }

        event.preventDefault();
        actionEl.click();
    }

    // ========== 初始化 ==========
    function init() {
        loadState();
        
        // 恢复面板状态
        const panel = document.getElementById('dev-tool-panel');
        bindPanelActions(panel);
        bindPageContext();
        applyLayoutMode();
        if (!state.collapsed) {
            panel.classList.remove('collapsed');
        }
        
        // 恢复主标签
        switchMainTab(
            document.querySelector('.dev-tool-tab[data-tab="' + state.activeMainTab + '"]'),
            state.activeMainTab,
            false
        );
        
        // 加载模块列表
        const modulePromise = state.collapsed ? Promise.resolve() : (loadModules() || Promise.resolve());
        modulePromise.then(() => {
            // 恢复文档搜索状态
            if (!state.collapsed && state.activeMainTab === 'docs') {
                restoreDocSearchState();
            }
        }).catch(error => {
            console.warn('[DevToolPanel] Module loading error:', error);
            // 即使加载失败也要恢复搜索状态
            if (!state.collapsed && state.activeMainTab === 'docs') {
                restoreDocSearchState();
            }
        });
        
        // 如果是性能标签，渲染性能统计
        if (!state.collapsed && state.activeMainTab === 'performance') {
            renderPerformanceStats();
        }
        
        // 扩展标签：仅当当前为某扩展标签时才加载（由扩展通过 registerExtensionTab 注册，可能稍晚注册）
        var extTab = state.activeMainTab && state.activeMainTab !== 'framework' && state.activeMainTab !== 'docs' && state.activeMainTab !== 'performance';
        if (extTab) {
            (function tryLoadExtension() {
                if (window.DevToolPanelExtensionLoaders && window.DevToolPanelExtensionLoaders[state.activeMainTab]) {
                    window.DevToolPanelExtensionLoaders[state.activeMainTab]();
                } else {
                    setTimeout(tryLoadExtension, 80);
                }
            })();
        }
        
        // 恢复面板位置（包括第一次加载，默认位置0,0也要设置）
        panel.style.left = (state.panelX || 0) + 'px';
        panel.style.top = (state.panelY || 0) + 'px';
        
        // 同步container位置
        updateContainerPosition();
        
        // 检查并纠正超出屏幕的位置
        // 需要在下一帧执行，确保面板已经渲染完成
        requestAnimationFrame(() => {
            correctPanelPosition(panel);
            // 纠正位置后更新展开方向和container位置
            updateExpandDirection();
            updateContainerPosition();
        });
        
        // 初始化拖拽
        initDrag();
        
        // 初始化性能监控
        initPerformanceMonitoring();
        
        // 页面加载完成后更新性能统计
        if (document.readyState === 'complete') {
            // 如果页面已经加载完成，延迟一下再更新性能数据（确保performance API数据完整）
            setTimeout(() => {
                if (state.activeMainTab === 'performance') {
                    renderPerformanceStats();
                }
            }, 500);
        } else {
            window.addEventListener('load', () => {
                setTimeout(() => {
                    if (state.activeMainTab === 'performance') {
                        renderPerformanceStats();
                    }
                }, 500);
            });
        }
        
        // 监听窗口大小变化，自动调整位置
        window.addEventListener('resize', function() {
            const panel = document.getElementById('dev-tool-panel');
            if (panel) {
                correctPanelPosition(panel);
                updateExpandDirection();
                updateContainerPosition();
            }
        });
    }
    
    // ========== 更新container位置（container是fixed定位，需要手动同步panel位置） ==========
    function updateContainerPosition() {
        const panel = document.getElementById('dev-tool-panel');
        const container = document.querySelector('.dev-tool-container');
        if (!panel || !container) return;
        
        const panelX = parseInt(panel.style.left) || 0;
        const panelY = parseInt(panel.style.top) || 0;
        
        // container直接使用panel的位置
        container.style.left = panelX + 'px';
        container.style.top = panelY + 'px';
    }
    
    // ========== 纠正面板位置（防止超出屏幕） ==========
    function correctPanelPosition(panelEl) {
        // 临时移除collapsed类以获取正确的尺寸
        const wasCollapsed = panelEl.classList.contains('collapsed');
        if (wasCollapsed) {
            panelEl.classList.remove('collapsed');
        }
        
        // 获取container的实际尺寸（不是panel的尺寸，因为panel尺寸为0）
        const container = panelEl.querySelector('.dev-tool-container');
        const trigger = panelEl.querySelector('.dev-tool-trigger');
        const containerRect = container.getBoundingClientRect();
        const triggerRect = trigger.getBoundingClientRect();
        
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;
        
        let currentX = parseInt(panelEl.style.left) || 0;
        let currentY = parseInt(panelEl.style.top) || 0;
        
        // 使用container的实际尺寸
        const panelSize = getPanelSize(panelEl);
        const width = panelSize.width;
        const height = panelSize.height;
        
        // 计算触发器超出container的宽度
        const triggerExtraWidth = Math.max(0, triggerRect.right - containerRect.right);
        
        // 计算实际占用的总宽度（container + 触发器超出部分）
        const totalWidth = width + triggerExtraWidth;
        
        // 计算可见区域
        const visibleLeft = Math.max(0, currentX);
        const visibleRight = Math.min(windowWidth, currentX + totalWidth);
        const visibleWidth = visibleRight - visibleLeft;
        
        // 如果面板大部分隐藏（可见宽度小于100px），需要贴边
        const needSnap = visibleWidth < 100;
        
        // 恢复collapsed状态
        if (wasCollapsed) {
            panelEl.classList.add('collapsed');
        }
        
        if (needSnap) {
            // 调用贴边函数自动贴到最近的边
            snapToNearestEdge(panelEl);
        } else {
            // 边界约束：根据收起/展开状态使用不同的尺寸
            let minX, minY, maxX, maxY;
            
            if (wasCollapsed) {
                // 收起状态：使用触发器的实际屏幕位置计算边界
                // 确保触发器的bounding box完全在屏幕内
                const triggerOffsetLeft = currentX - triggerRect.left;   // panel到trigger左边的距离
                const triggerOffsetTop = currentY - triggerRect.top;      // panel到trigger顶部的距离
                const triggerOffsetRight = triggerRect.right - currentX;  // trigger右边到panel的距离
                const triggerOffsetBottom = triggerRect.bottom - currentY; // trigger底部到panel的距离
                
                // minX: 确保trigger.left >= 0 => panel.left >= triggerOffsetLeft
                minX = triggerOffsetLeft;
                // minY: 确保trigger.top >= 0 => panel.top >= triggerOffsetTop
                minY = triggerOffsetTop;
                // maxX: 确保trigger.right <= windowWidth => panel.left <= windowWidth - triggerOffsetRight
                maxX = windowWidth - triggerOffsetRight;
                // maxY: 确保trigger.bottom <= windowHeight => panel.top <= windowHeight - triggerOffsetBottom
                maxY = windowHeight - triggerOffsetBottom;
            } else {
                // 展开状态：使用container + 触发器的总尺寸
                minX = 0;
                minY = 0;
                maxX = windowWidth - totalWidth;
                maxY = windowHeight - height;
            }
            
            let correctedX = currentX;
            let correctedY = currentY;
            let needCorrection = false;
            
            // 检查并纠正X坐标
            if (currentX < minX) {
                correctedX = minX;
                needCorrection = true;
            } else if (currentX > maxX) {
                correctedX = maxX;
                needCorrection = true;
            }
            
            // 检查并纠正Y坐标
            if (currentY < minY) {
                correctedY = minY;
                needCorrection = true;
            } else if (currentY > maxY) {
                correctedY = maxY;
                needCorrection = true;
            }
            
            // 如果需要纠正，应用新位置并保存
            if (needCorrection) {
                panelEl.style.left = correctedX + 'px';
                panelEl.style.top = correctedY + 'px';
                state.panelX = correctedX;
                state.panelY = correctedY;
                saveState();
                
                // 同步container位置
                updateContainerPosition();
            }
        }
    }
    
    // ========== 拖拽功能 ==========
    function initDrag() {
        const header = document.querySelector('.dev-tool-header');
        const trigger = document.querySelector('.dev-tool-trigger');
        const panelEl = document.getElementById('dev-tool-panel');
        if (!panelEl) return;
        
        // Trigger拖动状态（外层定义，方便全局访问）
        let triggerMouseDownX = 0;
        let triggerMouseDownY = 0;
        let hasMoved = false;
        let isMouseDown = false;
        const moveThreshold = 5; // 移动5px以上才算拖动
        
        // Header拖拽处理（展开状态下拖动整个面板）
        if (header) {
            let headerClickCount = 0;
            let headerClickTimer = null;
            
            // 检测是否为移动设备
            const isMobileDevice = window.innerWidth <= 480 || ('ontouchstart' in window);
            
            header.addEventListener('mousedown', function(e) {
                // 排除窗口控制按钮的点击
                if (e.target.closest('.dev-tool-window-actions') || e.target.closest('.dev-tool-page-context')) {
                    return;
                }
                
                // 移动设备禁用header拖动（移动端全屏无需拖动）
                if (isMobileDevice) return;
                
                // 只在展开状态下允许拖动Header
                if (!state.collapsed) {
                    startHeaderDrag(e);
                }
            });
            
            // Header双击收起
            header.addEventListener('click', function(e) {
                // 排除关闭按钮和快捷操作区域的点击
                if (e.target.closest('.dev-tool-window-actions') || e.target.closest('.dev-tool-quick-actions') || e.target.closest('.dev-tool-page-context')) {
                    return;
                }
                
                headerClickCount++;
                
                if (headerClickCount === 1) {
                    // 第一次点击，等待第二次点击
                    headerClickTimer = setTimeout(() => {
                        headerClickCount = 0;
                    }, 300); // 300ms内的第二次点击才算双击
                } else if (headerClickCount === 2) {
                    // 双击
                    clearTimeout(headerClickTimer);
                    headerClickCount = 0;
                    
                    // 只在展开状态下才收起
                    if (!state.collapsed) {
                        DevToolPanel.toggle();
                    }
                }
            });
            
            // 触摸事件支持（仅用于双击收起，不支持拖动）
            if (!isMobileDevice) {
                header.addEventListener('touchstart', function(e) {
                    if (!state.collapsed) {
                        const touch = e.touches[0];
                        const mouseEvent = new MouseEvent('mousedown', {
                            clientX: touch.clientX,
                            clientY: touch.clientY
                        });
                        header.dispatchEvent(mouseEvent);
                    }
                });
                
                header.addEventListener('touchend', function(e) {
                    const mouseEvent = new MouseEvent('mouseup');
                    header.dispatchEvent(mouseEvent);
                });
            }
        }
        
        // Trigger拖拽处理（简化版：有位移=拖动，无位移=点击）
        if (trigger) {
            trigger.addEventListener('mousedown', function(e) {
                e.preventDefault();
                
                // 记录按下位置
                triggerMouseDownX = e.clientX;
                triggerMouseDownY = e.clientY;
                hasMoved = false;
                isMouseDown = true;
                
                // 添加按住状态的视觉反馈
                trigger.classList.add('pressing');
                trigger.style.cursor = 'grab';
            });
            
            // 监听全局鼠标移动，检测是否开始拖动
            document.addEventListener('mousemove', function(e) {
                if (!isMouseDown) return;
                
                // 计算位移
                const deltaX = Math.abs(e.clientX - triggerMouseDownX);
                const deltaY = Math.abs(e.clientY - triggerMouseDownY);
                
                // 如果位移超过阈值，开始拖动
                if (!hasMoved && (deltaX > moveThreshold || deltaY > moveThreshold)) {
                    hasMoved = true;
                    trigger.classList.remove('pressing');
                    trigger.classList.add('drag-ready');
                    trigger.style.cursor = 'grabbing';
                    
                    // 启动触发器拖动
                    startTriggerDrag({
                        clientX: triggerMouseDownX,
                        clientY: triggerMouseDownY
                    });
                }
            });
            
            trigger.addEventListener('mouseup', function(e) {
                // 移除视觉反馈
                trigger.classList.remove('pressing', 'drag-ready');
                trigger.style.cursor = '';
                
                // 如果没有移动过且没有正在拖动，认为是点击
                if (!hasMoved && !state.isDragging && state.collapsed) {
                    e.stopPropagation();
                    DevToolPanel.toggle();
                }
                
                // 重置状态
                isMouseDown = false;
                hasMoved = false;
            });
            
            trigger.addEventListener('mouseleave', function(e) {
                // 如果鼠标离开但还在按下状态，保持拖动
                if (!isMouseDown) {
                    trigger.classList.remove('pressing', 'drag-ready');
                    trigger.style.cursor = '';
                }
            });
            
            // 添加触摸事件支持
            trigger.addEventListener('touchstart', function(e) {
                e.preventDefault();
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousedown', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                trigger.dispatchEvent(mouseEvent);
            });
            
            // 同步触摸移动为鼠标移动，保证拖拽连续性
            document.addEventListener('touchmove', function(e) {
                if (!state.isDragging) return;
                const touch = e.touches[0];
                const moveEvent = new MouseEvent('mousemove', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                document.dispatchEvent(moveEvent);
            }, { passive: false });

            // 触摸取消/结束映射为鼠标抬起
            trigger.addEventListener('touchend', function(e) {
                e.preventDefault();
                const mouseEvent = new MouseEvent('mouseup');
                trigger.dispatchEvent(mouseEvent);
            });
            trigger.addEventListener('touchcancel', function(e) {
                e.preventDefault();
                const mouseEvent = new MouseEvent('mouseup');
                trigger.dispatchEvent(mouseEvent);
            });
        }
        
        // 启动触发器拖动（拖动触发器小块，面板位置跟随）
        function startTriggerDrag(e) {
            state.isDragging = true;
            state.dragStartX = e.clientX;
            state.dragStartY = e.clientY;
            state.panelStartX = parseInt(panelEl.style.left) || 0;
            state.panelStartY = parseInt(panelEl.style.top) || 0;
            
            panelEl.classList.add('dragging');
        }
        
        // 启动Header拖动（展开状态下拖动整个面板）
        function startHeaderDrag(e) {
            state.isDragging = true;
            state.dragStartX = e.clientX;
            state.dragStartY = e.clientY;
            state.panelStartX = parseInt(panelEl.style.left) || 0;
            state.panelStartY = parseInt(panelEl.style.top) || 0;
            
            panelEl.classList.add('dragging');
        }
        
        document.addEventListener('mousemove', function(e) {
            if (!state.isDragging) return;
            e.preventDefault();
            
            const deltaX = e.clientX - state.dragStartX;
            const deltaY = e.clientY - state.dragStartY;
            
            let newX = state.panelStartX + deltaX;
            let newY = state.panelStartY + deltaY;
            
            // 边界约束和贴边检测
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;
            const snapThreshold = 30; // 靠近边缘30px自动吸附
            
            // 自动贴边检测
            const isCollapsed = panelEl.classList.contains('collapsed');
            
            let panelWidth, panelHeight, triggerWidth;
            
            if (isCollapsed) {
                // 收起状态：只考虑触发器小块的尺寸
                const tRect = trigger.getBoundingClientRect();
                triggerWidth = tRect.width || 12; // 触发器宽度
                panelWidth = 0; // container不显示，宽度为0
                panelHeight = tRect.height || 80; // 触发器高度
            } else {
                // 展开状态：使用container的实际尺寸（不是panel，panel尺寸为0）
                const container = panelEl.querySelector('.dev-tool-container');
                const containerRect = container.getBoundingClientRect();
                const tRect = trigger.getBoundingClientRect();
                const panelSize = getPanelSize(panelEl);
                panelWidth = panelSize.width;
                panelHeight = panelSize.height;
                triggerWidth = Math.max(0, tRect.right - containerRect.right); // 触发器超出container的部分
            }
            
            // 计算实际占用的总宽度（container + 触发器）
            const totalWidth = panelWidth + triggerWidth;
            
            // 贴边检测 - 靠近边缘自动吸附
            if (newX < snapThreshold) {
                newX = 0; // 贴左边
            } else if (newX + totalWidth > windowWidth - snapThreshold) {
                newX = windowWidth - totalWidth; // 贴右边，确保触发器在屏幕内
            }
            
            if (newY < snapThreshold) {
                newY = 0; // 贴顶部
            } else if (newY + panelHeight > windowHeight - snapThreshold) {
                newY = windowHeight - panelHeight; // 贴底部
            }
            
            // 确保不超出边界（留出触发器空间）
            const maxX = windowWidth - totalWidth;
            const maxY = windowHeight - panelHeight;
            newX = Math.max(0, Math.min(maxX, newX));
            newY = Math.max(0, Math.min(maxY, newY));
            
            panelEl.style.left = newX + 'px';
            panelEl.style.top = newY + 'px';
            
            // 同步container位置
            updateContainerPosition();
        });
        
        document.addEventListener('mouseup', function(e) {
            // 重置触发器状态（无论是否在拖动）
            if (isMouseDown) {
                isMouseDown = false;
                if (trigger) {
                    trigger.classList.remove('pressing', 'drag-ready');
                    trigger.style.cursor = '';
                }
            }
            
            if (!state.isDragging) return;
            
            panelEl.classList.remove('dragging');
            state.isDragging = false;
            
            // 立即保存最终位置
            const finalX = parseInt(panelEl.style.left) || 0;
            const finalY = parseInt(panelEl.style.top) || 0;
            
            state.panelX = finalX;
            state.panelY = finalY;
            saveState();
            
            // 如果是展开状态，更新展开方向
            if (!state.collapsed) {
                updateExpandDirection();
            }
        });
    }
    
    // ========== 吸附到最近的边 ==========
    function snapToNearestEdge(panelEl) {
        // 若为收起状态，临时展开以便获取正确尺寸
        const wasCollapsed = panelEl.classList.contains('collapsed');
        if (wasCollapsed) {
            panelEl.classList.remove('collapsed');
        }

        // 获取container和trigger的实际尺寸
        const container = panelEl.querySelector('.dev-tool-container');
        const trigger = panelEl.querySelector('.dev-tool-trigger');
        const containerRect = container.getBoundingClientRect();
        const triggerRect = trigger.getBoundingClientRect();
        
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;

        // 使用container的实际尺寸
        const panelSize = getPanelSize(panelEl);
        const width = panelSize.width;
        const height = panelSize.height;
        
        // 获取panel当前位置
        const currentX = parseInt(panelEl.style.left) || 0;
        const currentY = parseInt(panelEl.style.top) || 0;

        const centerX = currentX + width / 2;
        const centerY = currentY + height / 2;

        // 计算到各个边的距离
        const distToLeft = centerX;
        const distToRight = windowWidth - centerX;
        const distToTop = centerY;
        const distToBottom = windowHeight - centerY;

        // 找出最小距离
        const minDist = Math.min(distToLeft, distToRight, distToTop, distToBottom);

        // 触发器超出container的宽度
        const triggerExtraWidth = Math.max(0, triggerRect.right - containerRect.right);
        const totalWidth = width + triggerExtraWidth;

        let newX, newY;

        if (minDist === distToLeft) {
            // 吸附到左边：panel左边缘=0（container也在左边）
            newX = 0;
            newY = Math.max(0, Math.min(windowHeight - height, currentY));
        } else if (minDist === distToRight) {
            // 吸附到右边：确保触发器在屏幕内
            newX = windowWidth - totalWidth;
            newY = Math.max(0, Math.min(windowHeight - height, currentY));
        } else if (minDist === distToTop) {
            // 吸附到顶部：panel top=0（container top也=0）
            newY = 0;
            newX = Math.max(0, Math.min(windowWidth - totalWidth, currentX));
        } else {
            // 吸附到底部：panel top = windowHeight - container高度
            newY = windowHeight - height;
            newX = Math.max(0, Math.min(windowWidth - totalWidth, currentX));
        }

        // 还原收起状态（如果之前是收起）
        if (wasCollapsed) {
            panelEl.classList.add('collapsed');
        }

        // 应用吸附位置（带动画效果）
        panelEl.style.transition = 'left 0.3s ease, top 0.3s ease';
        container.style.transition = 'left 0.3s ease, top 0.3s ease';
        
        panelEl.style.left = newX + 'px';
        panelEl.style.top = newY + 'px';
        
        // 同步container位置
        container.style.left = newX + 'px';
        container.style.top = newY + 'px';

        // 动画结束后移除transition
        setTimeout(() => {
            panelEl.style.transition = '';
            container.style.transition = '';
            state.panelX = newX;
            state.panelY = newY;
            saveState();
        }, 300);
    }

    // ========== 检测并设置展开方向 ==========
    function updateExpandDirection() {
        const panel = document.getElementById('dev-tool-panel');
        if (!panel) return;
        const windowWidth = window.innerWidth;
        const windowHeight = window.innerHeight;
        
        const x = parseInt(panel.style.left) || 0;
        const y = parseInt(panel.style.top) || 0;
        const panelSize = getPanelSize(panel);
        
        // 计算到各边的距离
        const distToLeft = x;
        const distToRight = windowWidth - x - panelSize.width;
        const distToTop = y;
        const distToBottom = windowHeight - y - panelSize.height;
        
        // 移除所有方向class
        panel.classList.remove('expand-left', 'expand-right', 'expand-up', 'expand-down');
        
        // 根据最近的边设置展开方向
        const minDist = Math.min(distToLeft, distToRight, distToTop, distToBottom);
        
        if (minDist === distToLeft) {
            panel.classList.add('expand-right'); // 靠左边，向右展开
        } else if (minDist === distToRight) {
            panel.classList.add('expand-left'); // 靠右边，向左展开
        } else if (minDist === distToTop) {
            panel.classList.add('expand-down'); // 靠顶部，向下展开
        } else {
            panel.classList.add('expand-up'); // 靠底部，向上展开
        }
        
    }
    
    // ========== 面板控制 ==========
    function toggle() {
        state.collapsed = !state.collapsed;
        const panel = document.getElementById('dev-tool-panel');
        if (!panel) return;
        panel.classList.toggle('collapsed', state.collapsed);
        
        // 展开时更新展开方向
        if (!state.collapsed) {
            applyLayoutMode();
            requestAnimationFrame(function() {
                correctPanelPosition(panel);
                updateExpandDirection();
                updateContainerPosition();
            });
            switchMainTab(
                document.querySelector('.dev-tool-tab[data-tab="' + state.activeMainTab + '"]'),
                state.activeMainTab,
                false
            );
        }
        
        // 保存状态（触发器位置保持不变）
        saveState();
    }
    
    // ========== 关闭面板 ==========
    function closePanel() {
        const panel = document.getElementById('dev-tool-panel');
        if (panel) {
            state.collapsed = true;
            panel.classList.add('collapsed');
            saveState();
        }
    }

    function switchFrameworkTab(button, tab, shouldSave = true) {
        state.frameworkTab = tab === 'trace' ? 'trace' : 'routes';
        if (shouldSave) saveState();

        document.querySelectorAll('.dev-tool-framework-tab').forEach(function(tabButton) {
            const isActive = tabButton.dataset.frameworkTab === state.frameworkTab;
            tabButton.classList.toggle('active', isActive);
            tabButton.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        if (button) {
            button.classList.add('active');
            button.setAttribute('aria-selected', 'true');
        }

        const routeSearchArea = document.getElementById('route-search-area');
        const traceSearchArea = document.getElementById('trace-search-area');
        if (routeSearchArea) {
            routeSearchArea.classList.toggle('active', state.frameworkTab === 'routes');
        }
        if (traceSearchArea) {
            traceSearchArea.classList.toggle('active', state.frameworkTab === 'trace');
        }

        if (state.collapsed || state.activeMainTab !== 'framework') {
            return;
        }

        window._devToolExtensionRetryCount = {};
        if (state.frameworkTab === 'trace') {
            renderRequestTrace();
        } else {
            loadRoutes(state.currentRouteType);
        }
    }

    function switchMainTab(button, tab, shouldSave = true) {
        if (tab === 'routes' || tab === 'trace') {
            state.frameworkTab = tab === 'trace' ? 'trace' : 'routes';
            tab = 'framework';
            button = document.querySelector('.dev-tool-tabs > .dev-tool-tab[data-tab="framework"]');
        }
        if (!button && tab) {
            button = document.querySelector('.dev-tool-tabs > .dev-tool-tab[data-tab="' + String(tab).replace(/"/g, '\\"') + '"]');
        }
        // 更新标签状态
        document.querySelectorAll('.dev-tool-tabs > .dev-tool-tab').forEach(t => t.classList.remove('active'));
        if (button) button.classList.add('active');
        
        state.activeMainTab = tab;
        if (shouldSave) saveState();
        
        // 显示/隐藏搜索区域
        const frameworkSearchArea = document.getElementById('framework-search-area');
        const routeSearchArea = document.getElementById('route-search-area');
        const docSearchArea = document.getElementById('doc-search-area');
        const performanceSearchArea = document.getElementById('performance-search-area');
        const traceSearchArea = document.getElementById('trace-search-area');
        
        // 隐藏所有内置搜索区域
        if (frameworkSearchArea) frameworkSearchArea.style.display = 'none';
        if (routeSearchArea) routeSearchArea.classList.remove('active');
        docSearchArea.style.display = 'none';
        performanceSearchArea.style.display = 'none';
        if (traceSearchArea) traceSearchArea.classList.remove('active');
        // 隐藏所有扩展搜索区（约定 id 为 dev-tool-search-area-{tabId}）
        document.querySelectorAll('[id^="dev-tool-search-area-"]').forEach(el => { el.style.display = 'none'; });
        if (state.collapsed) {
            return;
        }
        
        // 扩展标签：若加载器尚未注册则短时重试，最多重试几次；重试前检查用户是否已切换标签，避免覆盖
        const isExtensionTab = !isBuiltInMainTab(tab);
        const extSearchArea = document.getElementById('dev-tool-search-area-' + tab);
        const extLoader = window.DevToolPanelExtensionLoaders && window.DevToolPanelExtensionLoaders[tab];
        if (isExtensionTab && !extLoader) {
            window._devToolExtensionRetryCount = window._devToolExtensionRetryCount || {};
            window._devToolExtensionRetryCount[tab] = (window._devToolExtensionRetryCount[tab] || 0) + 1;
            const maxRetries = 20;
            if (window._devToolExtensionRetryCount[tab] > maxRetries) {
                if (extSearchArea) extSearchArea.style.display = 'block';
                const content = document.getElementById('dev-tool-content');
                if (content) content.innerHTML = '<div class="dev-tool-empty">扩展未就绪，请切换其他标签或刷新页面</div>';
                return;
            }
            if (extSearchArea) extSearchArea.style.display = 'block';
            const content = document.getElementById('dev-tool-content');
            if (content) content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载中...</div></div>';
            setTimeout(function() {
                if (state.activeMainTab !== tab) return;
                switchMainTab(
                    document.querySelector('.dev-tool-tabs > .dev-tool-tab[data-tab="' + String(tab).replace(/"/g, '\\"') + '"]'),
                    tab,
                    false
                );
            }, 100);
            return;
        }
        
        if (tab === 'framework') {
            if (frameworkSearchArea) frameworkSearchArea.style.display = 'block';
            switchFrameworkTab(
                document.querySelector('.dev-tool-framework-tab[data-framework-tab="' + state.frameworkTab + '"]'),
                state.frameworkTab,
                false
            );
        } else if (tab === 'performance') {
            window._devToolExtensionRetryCount = {};
            performanceSearchArea.style.display = 'block';
            renderPerformanceStats();
        } else if (extLoader) {
            if (window._devToolExtensionRetryCount) window._devToolExtensionRetryCount[tab] = 0;
            if (extSearchArea) extSearchArea.style.display = 'block';
            extLoader();
        } else {
            window._devToolExtensionRetryCount = {};
            docSearchArea.style.display = 'block';
            ensureDocsLoaded();
        }
    }
    
    /** 供扩展模块注册：注册扩展标签的内容加载函数（仅切换到此标签时调用） */
    function registerExtensionTab(tabId, loadContentFn) {
        if (typeof tabId !== 'string' || typeof loadContentFn !== 'function') return;
        window.DevToolPanelExtensionLoaders = window.DevToolPanelExtensionLoaders || {};
        window.DevToolPanelExtensionLoaders[tabId] = loadContentFn;
        if (!state.collapsed && state.activeMainTab === tabId) {
            setTimeout(function() {
                switchMainTab(
                    document.querySelector('.dev-tool-tabs > .dev-tool-tab[data-tab="' + String(tabId).replace(/"/g, '\\"') + '"]'),
                    tabId,
                    false
                );
            }, 0);
        }
    }

    // ========== 路由功能 ==========
    function switchRouteTab(button, type) {
        document.querySelectorAll('#route-search-area .search-mode-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        button.classList.add('active');
        
        state.currentRouteType = type;
        saveState();
        loadRoutes(type);
    }

    function loadRoutes(type) {
        const content = document.getElementById('dev-tool-content');
        if (!content) return Promise.resolve();
        
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载路由...</div></div>';
        
        const url = getDevToolApiUrl('routes', { type });
        if (!url) {
            content.innerHTML = '<div class="dev-tool-empty">无法构建 API 地址（请从后台打开本页）</div>';
            return Promise.resolve();
        }
        return fetch(url)
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.allRouteModules = data.data || [];
                    renderRouteModules(state.allRouteModules);
                } else {
                    content.innerHTML = '<div class="dev-tool-empty">' + (data?.msg || '加载失败') + '</div>';
                }
            })
            .catch(error => {
                console.warn('[DevToolPanel] Failed to load routes:', error);
                content.innerHTML = '<div class="dev-tool-empty">路由接口暂时不可用</div>';
                return Promise.resolve();
            });
    }

    function renderRouteModules(modules) {
        const content = document.getElementById('dev-tool-content');
        
        if (!modules || modules.length === 0) {
            content.innerHTML = '<div class="dev-tool-empty">📦 暂无模块</div>';
            return;
        }
        
        let html = '';
        modules.forEach(module => {
            if (!module.routes || module.routes.length === 0) return;
            
            html += '<div class="module-group">';
            html += '<div class="module-header" data-dev-tool-action="toggle-module" role="button" tabindex="0">';
            html += '<div class="module-name">';
            html += '<i class="fa fa-cube"></i>';
            html += escapeHtml(module.name || '');
            html += '<span class="badge badge-primary">' + module.routes.length + '</span>';
            html += '</div>';
            html += '<i class="fa fa-chevron-down module-toggle"></i>';
            html += '</div>';
            html += '<div class="module-routes">';
            
            module.routes.forEach(route => {
                const routeUrl = String(route.url || '');
                const routePath = route.path || routeUrl;
                const controller = String(route.controller || '');
                const controllerName = controller ? controller.split('\\').pop() : '';
                html += '<div class="route-item" data-dev-tool-action="open-route" data-route-url="' + escapeAttr(routeUrl) + '">';
                html += '<a href="' + escapeAttr(routeUrl || '#') + '" class="route-path">' + escapeHtml(routePath) + '</a>';
                html += '<div class="route-info">' + escapeHtml(route.method || '') + ' · ' + escapeHtml(controllerName) + '</div>';
                html += '</div>';
            });
            
            html += '</div>';
            html += '</div>';
        });
        
        content.innerHTML = html;
        
        // 恢复搜索
        const searchInput = document.getElementById('route-search-input');
        if (state.routeSearchKeyword) {
            searchInput.value = state.routeSearchKeyword;
            searchRoutes({ target: searchInput });
        }
    }

    function toggleModule(header) {
        header.classList.toggle('collapsed');
        const routes = header.nextElementSibling;
        routes.classList.toggle('collapsed');
    }

    function openRoute(url) {
        window.open(url, '_blank');
    }

    function searchRoutes(event) {
        const keyword = event.target.value.trim().toLowerCase();
        state.routeSearchKeyword = keyword;
        saveState();
        
        if (!keyword) {
            renderRouteModules(state.allRouteModules);
            return;
        }
        
        const filtered = state.allRouteModules.map(module => {
            const matchingRoutes = module.routes.filter(route => {
                return route.path.toLowerCase().includes(keyword) ||
                       route.url.toLowerCase().includes(keyword) ||
                       module.name.toLowerCase().includes(keyword);
            });
            
            if (matchingRoutes.length > 0) {
                return { ...module, routes: matchingRoutes };
            }
            return null;
        }).filter(m => m !== null);
        
        renderRouteModules(filtered);
    }

    // ========== 文档功能 ==========
    function getDevToolRuntimeConfig() {
        const bootstrap = document.querySelector('[data-weline-panel-bootstrap]');
        const loaderScript = document.getElementById('weline-panel-loader-js');
        const attrSource = loaderScript || bootstrap;
        const attrConfig = {};

        if (attrSource) {
            const apiBase = attrSource.getAttribute('data-api-base') || '';
            const requestId = attrSource.getAttribute('data-request-id') || '';
            const sessionUrl = attrSource.getAttribute('data-session-url') || '';

            if (apiBase) {
                attrConfig.apiBase = apiBase;
            }
            if (requestId) {
                attrConfig.requestId = requestId;
            }
            if (sessionUrl) {
                attrConfig.sessionUrl = sessionUrl;
            }
            if (attrSource.hasAttribute('data-token-required')) {
                attrConfig.tokenRequired = attrSource.getAttribute('data-token-required') === '1';
            }
        }

        return Object.assign(
            {},
            attrConfig,
            window.__WELINE_DEV_TOOL__ || {},
            window.__WELINE_PANEL_CONFIG__ || {}
        );
    }

    /**
     * 构建开发工具后端 API URL（使用 rest_backend 前缀，避免 /api/rest/ 错误导致 404）
     * 优先 lazy bootstrap 注入的 apiBase，其次 window.api / window.site.api_host。
     */
    function getDevToolApiUrl(path, params) {
        const cleanPath = (path || '').replace(/^\//, '');
        const runtimeConfig = getDevToolRuntimeConfig();
        const configApiBase = runtimeConfig.apiBase
            ? String(runtimeConfig.apiBase).replace(/^\/+|\/+$/g, '')
            : '';
        if (configApiBase) {
            const url = window.location.origin.replace(/\/$/, '') + '/' + configApiBase + '/' + cleanPath;
            if (params && typeof params === 'object' && Object.keys(params).length > 0) {
                const q = new URLSearchParams(params).toString();
                return q ? (url + (url.indexOf('?') >= 0 ? '&' : '?') + q) : url;
            }
            return url;
        }
        const basePath = 'dev/tool/rest/v1/' + cleanPath;
        if (typeof window.api === 'function') {
            return window.api(basePath, params || {});
        }
        if (window.site && window.site.api_host) {
            const base = (window.site.api_host || '').replace(/\/$/, '');
            const url = base ? (base + '/' + basePath) : '';
            if (!url) return '';
            if (params && typeof params === 'object' && Object.keys(params).length > 0) {
                const q = new URLSearchParams(params).toString();
                return q ? (url + (url.indexOf('?') >= 0 ? '&' : '?') + q) : url;
            }
            return url;
        }
        return '';
    }

    function devToolFetchJson(url) {
        if (typeof window.fetch !== 'function') {
            return Promise.reject(new Error('当前浏览器不支持 fetch，无法请求开发面板 API。'));
        }

        return window.fetch(url, {
            method: 'GET',
            credentials: 'same-origin',
            cache: 'no-store',
            headers: {
                'Accept': 'application/json',
                'X-Weline-Dev-Tool': '1'
            }
        }).then(function(response) {
            return response.text().then(function(text) {
                let data = null;
                if (text) {
                    try {
                        data = JSON.parse(text);
                    } catch (error) {
                        throw new Error('API 返回了非 JSON 响应（HTTP ' + response.status + '）。');
                    }
                }
                if (!response.ok) {
                    const message = data && data.msg ? data.msg : ('HTTP ' + response.status);
                    throw new Error(message);
                }
                return data;
            });
        });
    }

    function docApiEndpointLabel(url) {
        try {
            const parsed = new URL(url, window.location.origin);
            const marker = '/dev/tool/rest/v1/';
            const markerIndex = parsed.pathname.indexOf(marker);
            const path = markerIndex >= 0 ? parsed.pathname.slice(markerIndex + marker.length) : parsed.pathname;
            return path + (parsed.search ? parsed.search : '');
        } catch (error) {
            return 'document API';
        }
    }

    function normalizeDocApiErrorMessage(error) {
        const raw = error && error.message ? String(error.message) : String(error || '');
        if (/failed to fetch/i.test(raw)) {
            return '文档 API 暂时不可用。通常是当前页面对应的本地服务已停止、页面来自旧服务实例，或浏览器拦截了这次同源请求。刷新页面或重启当前服务后可重试。';
        }
        if (/non json|非 JSON/i.test(raw)) {
            return '文档 API 返回内容不是 JSON，可能进入了错误页面或登录页。请确认当前页面仍在开发面板允许访问的环境。';
        }
        return raw || '文档 API 请求失败。';
    }

    function renderDocApiError(content, title, error, url) {
        if (!content) return;
        const message = normalizeDocApiErrorMessage(error);
        const endpoint = url ? docApiEndpointLabel(url) : 'document API';
        content.innerHTML =
            '<div class="dev-tool-api-error-card">' +
                '<div class="dev-tool-api-error-title"><i class="fa fa-exclamation-circle"></i>' + escapeHtml(title || '文档 API 不可用') + '</div>' +
                '<p class="dev-tool-api-error-desc">' + escapeHtml(message) + '</p>' +
                '<div class="dev-tool-api-error-meta">' + escapeHtml(endpoint) + '</div>' +
                '<div class="dev-tool-api-error-actions">' +
                    '<button type="button" class="dev-tool-api-error-btn" data-dev-tool-action="retry-doc-api">' +
                        '<i class="fa fa-refresh"></i> 重试' +
                    '</button>' +
                '</div>' +
            '</div>';
    }

    function retryDocApi() {
        state.modulesLoaded = false;
        if (state.currentDocId) {
            loadDocDetail(state.currentDocId);
            return;
        }
        loadModules().then(function() {
            searchDocsAPI();
        });
    }

    function loadModules() {
        if (state.modulesLoaded) {
            return Promise.resolve();
        }
        const url = getDevToolApiUrl('document/modules');
        if (!url) {
            console.warn('[DevToolPanel] Cannot build document API URL (missing panel apiBase / window.api / window.site.api_host)');
            return Promise.resolve();
        }
        return devToolFetchJson(url)
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.allModules = data.data || [];
                    state.modulesLoaded = true;
                    updateModuleSelect();
                } else {
                    console.warn('[DevToolPanel] Failed to load modules:', data?.msg || 'Unknown error');
                    state.allModules = [];
                    updateModuleSelect();
                }
            })
            .catch(error => {
                console.warn('[DevToolPanel] Failed to load modules:', error);
                state.allModules = [];
                updateModuleSelect();
                if (state.activeMainTab === 'docs') {
                    const content = document.getElementById('dev-tool-content');
                    renderDocApiError(content, '文档模块加载失败', error, url);
                }
                // 不要阻塞初始化
                return Promise.resolve();
            });
    }

    function ensureDocsLoaded() {
        const content = document.getElementById('dev-tool-content');
        if (!content) return Promise.resolve();
        if (state.docsInitialized) {
            if (state.currentDocId) {
                loadDocDetail(state.currentDocId);
            } else {
                searchDocsAPI();
            }
            return Promise.resolve();
        }
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载文档...</div></div>';
        return (loadModules() || Promise.resolve()).then(function() {
            state.docsInitialized = true;
            restoreDocSearchState();
        }).catch(function(error) {
            console.warn('[DevToolPanel] Module loading error:', error);
            state.docsInitialized = true;
            restoreDocSearchState();
        });
    }

    function updateModuleSelect() {
        const select = document.getElementById('doc-module-select');
        select.innerHTML = '<option value="">选择模块...</option>';
        
        state.allModules.forEach(module => {
            const option = document.createElement('option');
            option.value = module.name;
            option.textContent = module.display_name + ' (' + module.doc_count + ')';
            if (module.name === state.selectedModule) {
                option.selected = true;
            }
            select.appendChild(option);
        });
    }

    function switchDocSearchMode(button, mode) {
        document.querySelectorAll('#doc-search-area .search-mode-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        button.classList.add('active');
        
        state.docSearchMode = mode;
        saveState();
        
        const moduleSelect = document.getElementById('doc-module-select');
        if (mode === 'module') {
            moduleSelect.classList.add('show');
        } else {
            moduleSelect.classList.remove('show');
            state.selectedModule = '';
        }
        
        searchDocsAPI();
    }

    function onModuleChange() {
        const select = document.getElementById('doc-module-select');
        state.selectedModule = select.value;
        saveState();
        searchDocsAPI();
    }

    function searchDocs(event) {
        const keyword = event.target.value.trim();
        state.docSearchKeyword = keyword;
        saveState();
        if (state.docSearchTimer) {
            clearTimeout(state.docSearchTimer);
        }
        state.docSearchTimer = setTimeout(function() {
            state.currentDocId = null;
            searchDocsAPI();
        }, 250);
    }

    function searchDocsAPI() {
        const content = document.getElementById('dev-tool-content');
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>搜索文档...</div></div>';
        
        const query = {};
        if (state.docSearchKeyword) query.keyword = state.docSearchKeyword;
        if (state.docSearchMode === 'module' && state.selectedModule) query.module = state.selectedModule;
        if (state.docSearchPage) query.page = state.docSearchPage;
        if (state.docSearchSize) query.size = state.docSearchSize;
        const url = getDevToolApiUrl('document/search', query);
        if (!url) {
            renderDocApiError(content, '文档搜索失败', new Error('无法构建 API 地址（请从后台打开本页）。'), '');
            return;
        }
        devToolFetchJson(url)
            .then(data => {
                if (data && Number(data.code) === 200) {
                    state.docList = data.data.items || [];
                    renderDocList(state.docList);
                } else {
                    renderDocApiError(content, '文档搜索失败', new Error(data && data.msg ? data.msg : '搜索失败'), url);
                }
            })
            .catch(error => {
                renderDocApiError(content, '文档搜索失败', error, url);
            });
    }

    function renderDocList(docs) {
        const content = document.getElementById('dev-tool-content');
        
        if (!docs || docs.length === 0) {
            content.innerHTML = '<div class="dev-tool-empty">暂无文档</div>';
            return;
        }
        
        let html = '';
        docs.forEach(doc => {
            const docId = Number.parseInt(doc.id, 10);
            if (!Number.isFinite(docId)) return;
            const isActive = doc.id === state.currentDocId ? ' active' : '';
            html += '<div class="doc-list-item' + isActive + '" data-dev-tool-action="open-doc" data-doc-id="' + docId + '" role="button" tabindex="0">';
            html += '<div class="doc-title">' + escapeHtml(doc.title || '无标题') + '</div>';
            html += '<div class="doc-meta">';
            html += '<span class="doc-module-tag">' + escapeHtml(doc.module_display || doc.module_name) + '</span>';
            if (doc.summary) {
                const summary = doc.summary.length > 60 ? doc.summary.substring(0, 60) + '...' : doc.summary;
                html += '<span>' + escapeHtml(summary) + '</span>';
            }
            html += '</div>';
            html += '</div>';
        });
        
        content.innerHTML = html;
    }

    function openDoc(docId) {
        state.currentDocId = docId;
        state.currentDocScrollPos = 0;
        saveState();
        loadDocDetail(docId);
    }

    function loadDocDetail(docId) {
        const content = document.getElementById('dev-tool-content');
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载文档...</div></div>';
        
        const url = getDevToolApiUrl('document/detail', { id: docId });
        if (!url) {
            renderDocApiError(content, '文档加载失败', new Error('无法构建 API 地址（请从后台打开本页）。'), '');
            return;
        }
        devToolFetchJson(url)
            .then(data => {
                if (data && Number(data.code) === 200) {
                    renderDocContent(data.data);
                } else {
                    renderDocApiError(content, '文档加载失败', new Error(data && data.msg ? data.msg : '加载失败'), url);
                }
            })
            .catch(error => {
                renderDocApiError(content, '文档加载失败', error, url);
            });
    }

    function renderDocContent(doc) {
        const content = document.getElementById('dev-tool-content');
        
        // 简单 Markdown 转换为 HTML
        let html = escapeHtml(doc.content || '');
        html = html
            .replace(/^### (.+)$/gm, '<h3>$1</h3>')
            .replace(/^## (.+)$/gm, '<h2>$1</h2>')
            .replace(/^# (.+)$/gm, '<h1>$1</h1>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/`([^`]+)`/g, '<code>$1</code>')
            .replace(/```([\s\S]+?)```/g, '<pre><code>$1</code></pre>')
            .replace(/\[([^\]]+)\]\(([^\)]+)\)/g, function(match, label, href) {
                const safeHref = sanitizeDocHref(href);
                return safeHref ? '<a href="' + safeHref + '" target="_blank" rel="noopener noreferrer">' + label + '</a>' : label;
            })
            .replace(/\n\n/g, '</p><p>')
            .replace(/\n/g, '<br>');
        
        html = '<p>' + html + '</p>';
        
        content.innerHTML = '<div class="doc-content-view show">' +
            '<div class="doc-content-header">' +
                '<button class="doc-back-btn" data-dev-tool-action="back-to-doc-list">' +
                    '<i class="fa fa-arrow-left"></i> 返回列表' +
                '</button>' +
            '</div>' +
                '<div class="doc-content-title">' + escapeHtml(doc.title || '无标题') + '</div>' +
                '<div class="doc-meta" style="margin-bottom: 12px;">' +
                    '<span class="doc-module-tag">' + escapeHtml(doc.module_display || doc.module_name) + '</span>' +
            '</div>' +
            '<div class="doc-content-body">' + html + '</div>' +
        '</div>';
        
        // 恢复滚动位置
        setTimeout(() => {
            content.scrollTop = state.currentDocScrollPos;
        }, 50);
        
        // 监听滚动事件保存位置
        content.onscroll = () => {
            state.currentDocScrollPos = content.scrollTop;
            saveState();
        };
    }

    function backToDocList() {
        state.currentDocId = null;
        state.currentDocScrollPos = 0;
        saveState();
        searchDocsAPI();
    }

    function restoreDocSearchState() {
        // 恢复搜索模式
        const modeButtons = document.querySelectorAll('#doc-search-area .search-mode-btn');
        modeButtons.forEach(btn => {
            if (btn.dataset.mode === state.docSearchMode) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
        
        // 恢复模块选择
        const moduleSelect = document.getElementById('doc-module-select');
        if (state.docSearchMode === 'module') {
            moduleSelect.classList.add('show');
            moduleSelect.value = state.selectedModule;
        }
        
        // 恢复搜索关键词
        const searchInput = document.getElementById('doc-search-input');
        searchInput.value = state.docSearchKeyword;
        
        // 如果有打开的文档，直接加载
        if (state.currentDocId) {
            loadDocDetail(state.currentDocId);
        } else {
            // 否则执行搜索
            searchDocsAPI();
        }
    }

    // ========== 性能统计功能 ==========
    function initPerformanceMonitoring() {
        // 拦截fetch请求，记录API耗时
        const originalFetch = window.fetch;
        window.fetch = function(...args) {
            const startTime = performance.now();
            const url = args[0] || '';
            
            return originalFetch.apply(this, args)
                .then(response => {
                    const endTime = performance.now();
                    const duration = endTime - startTime;
                    
                    // 记录API请求（只记录开发工具面板的API请求）
                    if (typeof url === 'string' && url.includes('/dev/tool/')) {
                        state.apiRequests.push({
                            url: url,
                            method: 'GET',
                            duration: duration,
                            timestamp: Date.now(),
                            status: response.status
                        });
                        
                        // 只保留最近50条记录
                        if (state.apiRequests.length > 50) {
                            state.apiRequests.shift();
                        }
                        
                        // 如果当前在性能标签页，更新显示
                        if (state.activeMainTab === 'performance') {
                            renderPerformanceStats();
                        }
                    }
                    
                    return response;
                })
                .catch(error => {
                    const endTime = performance.now();
                    const duration = endTime - startTime;
                    
                    if (typeof url === 'string' && url.includes('/dev/tool/')) {
                        state.apiRequests.push({
                            url: url,
                            method: 'GET',
                            duration: duration,
                            timestamp: Date.now(),
                            status: 'error',
                            error: error.message
                        });
                        
                        if (state.apiRequests.length > 50) {
                            state.apiRequests.shift();
                        }
                        
                        if (state.activeMainTab === 'performance') {
                            renderPerformanceStats();
                        }
                    }
                    
                    throw error;
                });
        };
    }

    function getPerformanceTiming() {
        const timing = performance.timing;
        if (!timing) {
            return null;
        }
        
        return {
            // DNS查询耗时
            dns: timing.domainLookupEnd - timing.domainLookupStart,
            // TCP连接耗时
            tcp: timing.connectEnd - timing.connectStart,
            // 请求耗时
            request: timing.responseStart - timing.requestStart,
            // 响应耗时
            response: timing.responseEnd - timing.responseStart,
            // DOM解析耗时
            domParsing: timing.domInteractive - timing.responseEnd,
            // DOMContentLoaded耗时
            domContentLoaded: timing.domContentLoadedEventEnd - timing.navigationStart,
            // 页面完全加载耗时
            loadComplete: timing.loadEventEnd - timing.navigationStart,
            // 首次渲染时间
            firstPaint: performance.getEntriesByType('paint').find(entry => entry.name === 'first-paint')?.startTime || 0,
            // 首次内容绘制时间
            firstContentfulPaint: performance.getEntriesByType('paint').find(entry => entry.name === 'first-contentful-paint')?.startTime || 0
        };
    }

    function formatTime(ms) {
        ms = Number(ms);
        if (!Number.isFinite(ms) || ms < 0) {
            return '—';
        }
        if (ms === 0) {
            return '0 ms';
        }
        if (ms < 1) {
            return Math.max(1, Math.round(ms * 1000)) + ' μs';
        }
        if (ms < 100) {
            return ms.toFixed(2) + ' ms';
        }
        if (ms < 1000) {
            return ms.toFixed(0) + ' ms';
        }
        return (ms / 1000).toFixed(2) + ' s';
    }

    function formatSqlPreview(sql, maxLen) {
        var normalized = String(sql || '').replace(/\s+/g, ' ').trim();
        if (!normalized) {
            return '';
        }
        if (normalized.length <= maxLen) {
            return normalized;
        }
        return normalized.substring(0, maxLen) + ' ...';
    }

    /** 从 db span 的 name（如 db::find::m_acl）解析出 operation 和 table，兼容无 meta 的旧数据 */
    function parseDbSpanName(name) {
        var n = String(name || '');
        if (n.indexOf('db::') !== 0) {
            return { operation: n || '—', table: '—' };
        }
        var parts = n.split('::');
        if (parts.length >= 3) {
            return { operation: parts[1] || '—', table: parts[2] || '—' };
        }
        if (parts.length === 2) {
            return { operation: parts[1] || '—', table: '—' };
        }
        return { operation: '—', table: '—' };
    }

    /** 操作列缩写：单字母显示，hover 用 title 显示完整操作名 */
    function opToShort(op) {
        var s = String(op || '').toLowerCase().trim();
        if (!s) return '—';
        if (s === 'select' || s === 'find') return 'S';
        if (s === 'insert') return 'I';
        if (s === 'update') return 'U';
        if (s === 'delete') return 'D';
        if (s === 'fetch') return 'F';
        if (s === 'execute' || s === 'exec') return 'E';
        return s.charAt(0).toUpperCase();
    }

    function getTimeClass(ms, fast = 100, slow = 500) {
        if (ms < fast) return 'fast';
        if (ms < slow) return 'medium';
        return 'slow';
    }

    function buildTraceTree(spans) {
        var nodes = spans.map(function(s, index) {
            return {
                seq: Number(s.seq || (index + 1)),
                index: Number(typeof s.index === 'number' ? s.index : index),
                name: s.name || '',
                duration_ms: Number(s.duration_ms) || 0,
                category: s.category || '',
                parent: s.parent || null,
                db_duration_ms: Number(s.db_duration_ms || 0),
                meta: (s.meta && typeof s.meta === 'object') ? s.meta : {},
                children: []
            };
        });
        var byName = {};
        nodes.forEach(function(n) { byName[n.name] = n; });
        nodes.forEach(function(n) {
            if (n.parent && byName[n.parent]) byName[n.parent].children.push(n);
        });
        return nodes.filter(function(n) { return !n.parent; });
    }

    function renderTraceNode(node, depth, totalMsRef, inlineDb) {
        if (node.category === 'db' && inlineDb) {
            var meta = node.meta || {};
            var parsed = parseDbSpanName(node.name);
            var operation = String(meta.operation || parsed.operation || '');
            var table = String(meta.table || parsed.table || '');
            var sql = String(meta.sql || '');
            var dur = formatTime(Number(node.duration_ms) || 0);
            var hasSql = sql.length > 0;
            var indent = ' style="padding-left:' + (depth * 14) + 'px"';
            var html = '<div class="dev-tool-trace-db-inline" data-has-sql="' + (hasSql ? '1' : '0') + '"' + indent + '>';
            html += '<div class="performance-item dev-tool-db-inline-row">';
            html += '<span class="trace-toggle-placeholder"></span>';
            html += '<span class="performance-label" style="font-size:11px;color:#667eea;">DB</span>';
            html += '<span style="font-size:11px;color:#5c574f;margin-right:6px;">' + escapeHtml(opToShort(operation)) + '</span>';
            html += '<span style="font-size:11px;color:#64748b;">' + escapeHtml(table || '—') + '</span>';
            html += '<span class="performance-value" style="margin-left:auto;font-size:11px;">' + dur + '</span>';
            if (hasSql) html += ' <span class="dev-tool-db-expand-btn" role="button" tabindex="0" title="' + escapeAttr(operation || '') + '">▶</span>';
            html += '</div>';
            if (hasSql) {
                html += '<div class="dev-tool-db-expand-row" style="display:none;padding-left:' + (depth * 14 + 18) + 'px;">';
                html += '<pre class="dev-tool-db-sql-block" data-sql="' + escapeAttr(sql) + '">' + escapeHtml(sql) + '</pre>';
                html += '<div class="dev-tool-db-sql-actions"><button type="button" class="dev-tool-db-btn dev-tool-db-copy">复制 SQL</button>';
                html += '<button type="button" class="dev-tool-db-btn dev-tool-db-explain">EXPLAIN</button></div>';
                html += '<div class="dev-tool-db-explain-result" style="display:none;"></div></div>';
            }
            html += '</div>';
            return html;
        }
        if (!node.parent) totalMsRef.value += node.duration_ms;
        var timeClass = getTimeClass(node.duration_ms);
        var category = node.category ? ' <span style="opacity:0.7;font-size:11px">[' + escapeHtml(node.category) + ']</span>' : '';
        var hasChildren = node.children && node.children.length > 0;
        var indent = depth > 0 ? ' style="padding-left:' + (depth * 14) + 'px"' : '';
        var html = '<div class="performance-item trace-node" data-depth="' + depth + '"' + indent + '>';
        if (hasChildren) {
            html += '<span class="trace-toggle" data-expanded="0" role="button" tabindex="0" title="展开/折叠">';
            html += '<i class="fa fa-caret-right"></i></span>';
        } else {
            html += '<span class="trace-toggle-placeholder"></span>';
        }
        html += '<span class="performance-label">' + escapeHtml(String(node.name)) + category + '</span>';
        html += '<span class="performance-value ' + timeClass + '">';
        html += formatTime(node.duration_ms);
        if (node.db_duration_ms && node.db_duration_ms > 0) {
            html += ' <span style="margin-left:6px;font-size:11px;color:#555;">DB ' + formatTime(node.db_duration_ms) + '</span>';
        }
        html += ' <span class="performance-badge ' + timeClass + '">' + (timeClass === 'fast' ? '快' : timeClass === 'medium' ? '中' : '慢') + '</span>';
        html += '</span>';
        html += '</div>';
        if (hasChildren) {
            html += '<div class="trace-children" style="display:none">';
            node.children.forEach(function(ch) { html += renderTraceNode(ch, depth + 1, totalMsRef, inlineDb); });
            html += '</div>';
        }
        return html;
    }

    /** 请求链路「编码」视图：常规树 / 耗时倒序 子 Tab 的 UI 同步 */
    function syncTraceCodeLayoutUI(mode) {
        mode = traceLayoutMode(mode);
        var graphBtn = document.getElementById('trace-layout-graph');
        var treeBtn = document.getElementById('trace-layout-tree');
        var durBtn = document.getElementById('trace-layout-duration');
        var graphPanel = document.getElementById('trace-code-graph-panel');
        var treePanel = document.getElementById('trace-code-tree-panel');
        var durPanel = document.getElementById('trace-code-duration-panel');
        if (!graphBtn || !treeBtn || !durBtn || !graphPanel || !treePanel || !durPanel) {
            return;
        }
        var isGraph = mode === 'graph';
        var isTree = mode === 'tree';
        graphBtn.classList.toggle('active', isGraph);
        treeBtn.classList.toggle('active', isTree);
        durBtn.classList.toggle('active', mode === 'duration');
        graphBtn.setAttribute('aria-selected', isGraph ? 'true' : 'false');
        treeBtn.setAttribute('aria-selected', isTree ? 'true' : 'false');
        durBtn.setAttribute('aria-selected', mode === 'duration' ? 'true' : 'false');
        graphPanel.style.display = isGraph ? 'block' : 'none';
        treePanel.style.display = isTree ? 'block' : 'none';
        durPanel.style.display = mode === 'duration' ? 'block' : 'none';
    }

    function traceLayoutMode(mode) {
        return ['graph', 'tree', 'duration'].indexOf(mode) !== -1 ? mode : 'graph';
    }

    function traceCategoryLabel(category) {
        return {
            framework: '框架',
            controller: '控制器',
            event: '事件',
            observer: '观察者',
            view: '视图',
            db: 'DB'
        }[category || ''] || (category || '阶段');
    }

    function splitTraceName(name) {
        return String(name || '').split('::').filter(function(part) { return part !== ''; });
    }

    function parseTraceLifecycleInfo(span) {
        var meta = (span && span.meta && typeof span.meta === 'object') ? span.meta : {};
        var name = String(span && span.name || '');
        var category = String(span && span.category || '');
        var parts = splitTraceName(name);
        var parsedDb = category === 'db' ? parseDbSpanName(name) : null;
        var info = {
            title: name || '未命名阶段',
            phase: parts.length > 1 ? parts.slice(1).join(' / ') : name,
            className: String(meta.class || ''),
            method: String(meta.method || ''),
            file: String(meta.file || ''),
            hook: String(meta.hook || ''),
            eventName: '',
            sql: String(meta.sql || ''),
            operation: parsedDb ? String(meta.operation || parsedDb.operation || '') : '',
            table: parsedDb ? String(meta.table || parsedDb.table || '') : '',
            meta: meta
        };

        if (category === 'observer' && name.indexOf('observer::') === 0) {
            info.className = info.className || parts.slice(1).join('\\');
            info.method = info.method || 'execute';
            info.title = parts.length > 1 ? parts[parts.length - 1] : name;
            info.phase = 'Observer execute';
        } else if (category === 'event' && name.indexOf('event::') === 0) {
            info.eventName = parts.slice(1).join('::');
            info.title = info.eventName || name;
            info.phase = 'Event dispatch';
        } else if (category === 'view' && name.indexOf('view::block::') === 0) {
            info.className = info.className || parts.slice(2).join('\\');
            info.method = info.method || 'render/fetch';
            info.title = parts.length > 2 ? parts[parts.length - 1] : name;
            info.phase = 'Block render';
        } else if (category === 'view' && name.indexOf('view::hook_file::') === 0) {
            info.title = info.hook || parts.slice(2).join('::') || name;
            info.phase = 'Hook file render';
        } else if (category === 'view' && name.indexOf('view::hook::') === 0) {
            info.title = info.hook || parts.slice(2).join('::') || name;
            info.phase = 'Hook render';
        } else if (category === 'db') {
            info.title = (info.operation ? info.operation.toUpperCase() : 'DB') + (info.table ? ' ' + info.table : '');
            info.phase = 'Database query';
        } else if (name.indexOf('controller_chain::') === 0) {
            info.title = parts.slice(1).join(' / ') || name;
            info.phase = 'Controller chain';
        } else if (name.indexOf('router_start::') === 0 || name.indexOf('url_parser::') === 0) {
            info.title = parts.join(' / ');
            info.phase = 'Runtime sub phase';
        }

        return info;
    }

    function traceLifecycleDepths(spans) {
        var byName = {};
        spans.forEach(function(span) {
            if (span && span.name) byName[String(span.name)] = span;
        });
        var memo = {};
        function depthOf(span) {
            var name = String(span && span.name || '');
            if (!name) return 0;
            if (typeof memo[name] === 'number') return memo[name];
            var parent = String(span && span.parent || '');
            if (!parent || !byName[parent] || parent === name) {
                memo[name] = 0;
                return 0;
            }
            memo[name] = Math.min(7, depthOf(byName[parent]) + 1);
            return memo[name];
        }
        spans.forEach(depthOf);
        return memo;
    }

    function renderTraceLifecycleChips(span, info) {
        var chips = [];
        if (span.parent) chips.push('父：' + String(span.parent));
        if (info.className) chips.push(info.className);
        if (info.method) chips.push(info.method + '()');
        if (info.hook) chips.push('hook ' + info.hook);
        if (info.file) chips.push(info.file);
        if (info.table) chips.push('table ' + info.table);
        return chips.slice(0, 3).map(function(chip) {
            return '<span class="dev-tool-lifecycle-chip">' + escapeHtml(chip) + '</span>';
        }).join('');
    }

    function renderTraceLifecycleDetail(span) {
        var info = parseTraceLifecycleInfo(span || {});
        var seq = Number(span && span.seq || 0);
        var duration = Number(span && span.duration_ms || 0);
        var dbDuration = Number(span && span.db_duration_ms || 0);
        var rows = [
            ['阶段', info.phase || '—'],
            ['类', info.className || '—'],
            ['方法', info.method ? info.method + '()' : '—'],
            ['父阶段', span && span.parent ? String(span.parent) : '根阶段'],
            ['原始名称', span && span.name ? String(span.name) : '—']
        ];
        if (info.eventName) rows.push(['事件名', info.eventName]);
        if (info.hook) rows.push(['Hook', info.hook]);
        if (info.file) rows.push(['文件', info.file]);
        if (info.operation) rows.push(['DB 操作', info.operation]);
        if (info.table) rows.push(['DB 表', info.table]);
        if (dbDuration > 0) rows.push(['子 DB 合计', formatTime(dbDuration)]);

        var meta = info.meta || {};
        var metaKeys = Object.keys(meta).filter(function(key) {
            return ['class', 'method', 'file', 'hook', 'sql', 'operation', 'table'].indexOf(key) === -1;
        });
        metaKeys.slice(0, 12).forEach(function(key) {
            rows.push(['meta.' + key, typeof meta[key] === 'object' ? JSON.stringify(meta[key]) : String(meta[key])]);
        });

        var html = '<h4>' + escapeHtml(info.title || '请求阶段详情') + '</h4>';
        html += '<div class="dev-tool-lifecycle-detail-summary">';
        html += '<span>#' + escapeHtml(String(seq)) + '</span>';
        html += '<span>' + escapeHtml(traceCategoryLabel(span && span.category || '')) + '</span>';
        html += '<span>' + escapeHtml(formatTime(duration)) + '</span>';
        html += '</div>';
        html += '<dl>';
        rows.forEach(function(row) {
            html += '<div class="dev-tool-lifecycle-detail-row">';
            html += '<dt>' + escapeHtml(row[0]) + '</dt>';
            html += '<dd>' + escapeHtml(row[1]) + '</dd>';
            html += '</div>';
        });
        html += '</dl>';
        if (info.sql) {
            html += '<pre class="dev-tool-lifecycle-sql">' + escapeHtml(info.sql) + '</pre>';
        }
        return html;
    }

    function renderTraceLifecycleGraph(spans) {
        var ordered = spans.slice().sort(function(a, b) {
            var seqA = Number(a.seq || 0);
            var seqB = Number(b.seq || 0);
            return seqA === seqB ? 0 : seqA - seqB;
        });
        var depths = traceLifecycleDepths(ordered);
        var firstDetail = ordered.length ? renderTraceLifecycleDetail(ordered[0]) : '<h4>暂无阶段</h4>';
        var html = '<div class="dev-tool-lifecycle">';
        html += '<div class="dev-tool-lifecycle-map">';
        html += '<div class="dev-tool-lifecycle-track">';
        ordered.forEach(function(span, index) {
            var info = parseTraceLifecycleInfo(span);
            var depth = depths[String(span.name || '')] || 0;
            var duration = Number(span.duration_ms || 0);
            var timeClass = getTimeClass(duration);
            var category = String(span.category || '');
            html += '<button type="button" class="dev-tool-lifecycle-node' + (index === 0 ? ' is-active' : '') + '" data-trace-index="' + escapeAttr(String(index)) + '" data-category="' + escapeAttr(category) + '" style="padding-left:' + (depth * 28) + 'px">';
            html += '<span class="dev-tool-lifecycle-marker">';
            html += '<span class="dev-tool-lifecycle-seq">' + escapeHtml(String(span.seq || index + 1)) + '</span>';
            html += '<span class="dev-tool-lifecycle-time ' + escapeAttr(timeClass) + '">' + escapeHtml(formatTime(duration)) + '</span>';
            html += '</span>';
            html += '<span class="dev-tool-lifecycle-card">';
            html += '<span class="dev-tool-lifecycle-head">';
            html += '<span class="dev-tool-lifecycle-title" title="' + escapeAttr(span.name || '') + '">' + escapeHtml(info.title || span.name || '未命名阶段') + '</span>';
            html += '<span class="dev-tool-lifecycle-badge">' + escapeHtml(traceCategoryLabel(category)) + '</span>';
            html += '</span>';
            html += '<span class="dev-tool-lifecycle-meta">' + renderTraceLifecycleChips(span, info) + '</span>';
            html += '</span>';
            html += '</button>';
        });
        html += '</div>';
        html += '</div>';
        html += '<aside id="trace-lifecycle-detail" class="dev-tool-lifecycle-detail" aria-live="polite">' + firstDetail + '</aside>';
        html += '</div>';
        return html;
    }

    /** 请求链路「DB」视图：常规 / 耗时倒序 子 Tab 的 UI 同步 */
    function syncTraceDbLayoutUI(mode) {
        var normalBtn = document.getElementById('trace-db-layout-normal');
        var durBtn = document.getElementById('trace-db-layout-duration');
        var normalPanel = document.getElementById('trace-db-normal-panel');
        var durPanel = document.getElementById('trace-db-duration-panel');
        if (!normalBtn || !durBtn || !normalPanel || !durPanel) {
            return;
        }
        var isNormal = mode !== 'duration';
        normalBtn.classList.toggle('active', isNormal);
        durBtn.classList.toggle('active', !isNormal);
        normalBtn.setAttribute('aria-selected', isNormal ? 'true' : 'false');
        durBtn.setAttribute('aria-selected', isNormal ? 'false' : 'true');
        normalPanel.style.display = isNormal ? 'block' : 'none';
        durPanel.style.display = isNormal ? 'none' : 'block';
    }

    function currentPageUrlForFpcProbe() {
        try {
            var url = new URL(window.location.href);
            url.hash = '';
            return url;
        } catch (error) {
            return null;
        }
    }

    function probeCurrentPageFpcStatus() {
        var url = currentPageUrlForFpcProbe();
        if (!url || url.origin !== window.location.origin || !/^https?:$/.test(url.protocol)) {
            return Promise.resolve({
                checked: false,
                hit: false,
                error: '当前页面 URL 不支持 FPC 探测。'
            });
        }

        return fetch(url.href, {
            method: 'HEAD',
            credentials: 'same-origin'
        }).then(function(response) {
            var fpc = (response.headers.get('X-Weline-FPC') || '').trim();
            var hitHeader = (response.headers.get('X-Wls-Performance-Fpc-Hit') || '').trim();
            var source = (response.headers.get('X-Wls-Performance-Fpc-Source') || '').trim();
            var stale = (response.headers.get('X-Wls-Performance-Fpc-Stale') || '').trim();
            var hit = hitHeader === '1' || /^(HIT|STALE)$/i.test(fpc);
            return {
                checked: true,
                hit: hit,
                status: response.status,
                fpc: fpc,
                source: source,
                stale: stale === '1',
                hitHeader: hitHeader
            };
        }).catch(function(error) {
            return {
                checked: false,
                hit: false,
                error: error && error.message ? error.message : 'FPC 探测失败。'
            };
        });
    }

    function traceEmptyChip(label, value) {
        if (value === null || typeof value === 'undefined' || String(value) === '') {
            return '';
        }
        return '<span class="dev-tool-trace-empty-chip">' +
            escapeHtml(label) + ': ' + escapeHtml(String(value)) +
            '</span>';
    }

    function normalizeTraceUnavailableMessage(message) {
        var clean = String(message || '').trim();
        if (!clean) {
            return '当前页面没有可展示的请求链路数据。';
        }
        if (/^failed to fetch$/i.test(clean)) {
            return '请求链路接口暂时不可用：Failed to fetch。';
        }
        return clean;
    }

    function buildTraceUnavailableHtml(message, requestId, fpcStatus) {
        var isFpcHit = Boolean(fpcStatus && fpcStatus.hit);
        var title = isFpcHit ? '命中 FPC，请求链路未重新执行' : '请求链路暂无数据';
        var icon = isFpcHit ? 'fa-bolt' : 'fa-info-circle';
        var desc = isFpcHit
            ? '当前 HTML 由 Full Page Cache 直接返回，控制器、模板、Hook、DB 等后端阶段被缓存短路，所以本次请求不会产生新的请求链路数据。'
            : normalizeTraceUnavailableMessage(message);
        var html = '<div class="dev-tool-trace-empty-card' + (isFpcHit ? ' is-fpc-hit' : '') + '">';
        html += '<h3 class="dev-tool-trace-empty-title"><i class="fa ' + icon + '"></i>' + escapeHtml(title) + '</h3>';
        html += '<p class="dev-tool-trace-empty-desc">' + escapeHtml(desc) + '</p>';
        html += '<div class="dev-tool-trace-empty-meta">';
        html += traceEmptyChip('request_id', requestId || '');
        if (fpcStatus && fpcStatus.checked) {
            html += traceEmptyChip('FPC', fpcStatus.fpc || (isFpcHit ? 'HIT' : 'MISS/未命中'));
            html += traceEmptyChip('source', fpcStatus.source || '');
            html += traceEmptyChip('HTTP', fpcStatus.status || '');
            if (fpcStatus.stale) {
                html += traceEmptyChip('stale', '1');
            }
        }
        html += '</div>';
        html += '<ul class="dev-tool-trace-empty-actions">';
        if (isFpcHit) {
            html += '<li>这是预期行为：FPC 命中时后端链路没有重新跑，面板只能看到缓存结果。</li>';
            html += '<li>要看真实链路，请追加 <code>?nocache=1</code> 或清理/关闭 frontend/router cache 后刷新。</li>';
            html += '<li>如果想分析 FPC 构建耗时，请在缓存 miss 或缓存重建那一次请求打开面板。</li>';
        } else {
            html += '<li>确认当前是 DEV/DEBUG 且页面是 HTML 响应。</li>';
            html += '<li>刷新页面后再打开请求链路；trace 默认只保留短时间窗口。</li>';
            if (fpcStatus && fpcStatus.checked) {
                html += '<li>已探测当前页面 FPC 响应头，未发现 FPC HIT/STALE。</li>';
            } else if (fpcStatus && fpcStatus.error) {
                html += '<li>FPC 探测未完成：' + escapeHtml(fpcStatus.error) + '</li>';
            }
        }
        html += '</ul>';
        html += '</div>';
        return html;
    }

    function renderTraceUnavailable(content, message, requestId) {
        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>分析请求链路状态...</div></div>';
        probeCurrentPageFpcStatus().then(function(fpcStatus) {
            content.innerHTML = buildTraceUnavailableHtml(message, requestId, fpcStatus);
        });
    }

    function renderRequestTrace() {
        const content = document.getElementById('dev-tool-content');
        if (!content) return;

        if (Array.isArray(state.traceSpans)) {
            if (state.traceSpans.length === 0) {
                const config = getDevToolRuntimeConfig();
                renderTraceUnavailable(content, '当前页面无请求链路数据。', config.requestId || window.__WELINE_REQUEST_ID__ || '');
                return;
            }
            renderRequestTraceFromSpans(state.traceSpans, state.traceSummary);
            return;
        }

        if (typeof window.__WELINE_REQUEST_TRACE__ !== 'undefined' && Array.isArray(window.__WELINE_REQUEST_TRACE__)) {
            state.traceSpans = window.__WELINE_REQUEST_TRACE__;
            state.traceSummary = null;
            if (state.traceSpans.length === 0) {
                const config = getDevToolRuntimeConfig();
                renderTraceUnavailable(content, '当前页面无请求链路数据。', config.requestId || window.__WELINE_REQUEST_ID__ || '');
                return;
            }
            renderRequestTraceFromSpans(state.traceSpans, state.traceSummary);
            return;
        }

        const config = getDevToolRuntimeConfig();
        const requestId = config.requestId || window.__WELINE_REQUEST_ID__ || '';
        if (!requestId) {
            renderTraceUnavailable(content, '当前页面没有 request_id，请刷新页面。', '');
            return;
        }

        content.innerHTML = '<div class="dev-tool-loading"><i class="fa fa-spinner spinning"></i><div>加载请求链路...</div></div>';
        const url = getDevToolApiUrl('trace', { id: requestId });
        if (!url) {
            content.innerHTML = '<div class="dev-tool-empty">无法构建 trace API 地址。</div>';
            return;
        }

        fetch(url)
            .then(function(response) {
                if (!response.ok) {
                    throw new Error(response.status === 404 ? '请求链路不存在或已过期，请刷新页面重试' : ('HTTP ' + response.status));
                }
                return response.json();
            })
            .then(function(data) {
                if (!data || Number(data.code) !== 200) {
                    throw new Error((data && (data.msg || data.message)) || 'trace load failed');
                }
                const payload = data.data || {};
                state.traceSummary = payload.summary || null;
                state.traceSpans = decodeCompactTracePayload(payload);
                if (!state.traceSpans.length) {
                    renderTraceUnavailable(content, '当前页面无请求链路数据。', requestId);
                    return;
                }
                renderRequestTraceFromSpans(state.traceSpans, state.traceSummary);
            })
            .catch(function(error) {
                renderTraceUnavailable(content, error.message || '请求链路不存在或已过期，请刷新页面重试', requestId);
            });
    }

    function decodeCompactTracePayload(payload) {
        if (!payload || payload.format !== 'compact-v1') {
            return [];
        }
        const dict = payload.dict || {};
        const names = dict.names || {};
        const categories = dict.categories || {};
        const metas = dict.metas || {};
        const rows = String(payload.trace || '').split('\n').filter(Boolean);
        const spans = rows.map(function(row) {
            const parts = row.split('|');
            const parentId = Number(parts[1] || 0);
            const categoryId = Number(parts[2] || 0);
            const nameId = Number(parts[3] || 0);
            const durationUs = Number(parts[4] || 0);
            const metaId = Number(parts[5] || 0);
            const seq = Number(parts[0] || 0);
            const span = {
                seq: seq,
                index: seq > 0 ? seq - 1 : 0,
                name: names[nameId] || '',
                duration_ms: Math.round((durationUs / 1000) * 100) / 100,
                category: categories[categoryId] || 'framework'
            };
            if (parentId > 0 && names[parentId]) span.parent = names[parentId];
            if (metaId > 0 && metas[metaId]) span.meta = metas[metaId];
            return span;
        }).filter(function(span) {
            return span.name;
        });

        const dbByParent = {};
        spans.forEach(function(span) {
            if ((span.category || '') === 'db' && span.parent) {
                dbByParent[span.parent] = (dbByParent[span.parent] || 0) + (Number(span.duration_ms) || 0);
            }
        });
        spans.forEach(function(span) {
            if ((span.category || '') !== 'db' && dbByParent[span.name]) {
                span.db_duration_ms = Math.round(dbByParent[span.name] * 100) / 100;
            }
        });

        return spans;
    }

    function traceGetPath(source, path) {
        if (!source || typeof source !== 'object') {
            return undefined;
        }
        var current = source;
        String(path || '').split('.').forEach(function(part) {
            if (current === undefined || current === null || typeof current !== 'object') {
                current = undefined;
                return;
            }
            current = current[part];
        });
        return current;
    }

    function traceFiniteNumber(value, fallback) {
        var number = Number(value);
        return Number.isFinite(number) ? number : (fallback || 0);
    }

    function traceFirstNumber(summary, paths) {
        if (!summary || typeof summary !== 'object') {
            return null;
        }
        for (var i = 0; i < paths.length; i++) {
            var value = traceGetPath(summary, paths[i]);
            if (value === null || typeof value === 'undefined' || value === '') {
                continue;
            }
            var number = Number(value);
            if (Number.isFinite(number)) {
                return number;
            }
        }
        return null;
    }

    function traceSumDuration(spans) {
        return spans.reduce(function(total, span) {
            return total + Math.max(0, traceFiniteNumber(span && span.duration_ms, 0));
        }, 0);
    }

    function traceRootTotal(spans) {
        var roots = spans.filter(function(span) {
            return !span || !span.parent;
        });
        var source = roots.length ? roots : spans;
        return traceSumDuration(source);
    }

    function traceCategoryTotals(spans, summary) {
        var totals = {};
        var source = traceGetPath(summary || {}, 'category_totals')
            || traceGetPath(summary || {}, 'trace_category_totals')
            || traceGetPath(summary || {}, 'timing.trace_category_totals');
        if (source && typeof source === 'object') {
            Object.keys(source).forEach(function(key) {
                var number = Number(source[key]);
                if (Number.isFinite(number)) {
                    totals[key] = number;
                }
            });
        }
        if (Object.keys(totals).length > 0) {
            return totals;
        }
        spans.forEach(function(span) {
            var category = String(span && span.category || 'framework');
            totals[category] = (totals[category] || 0) + Math.max(0, traceFiniteNumber(span && span.duration_ms, 0));
        });
        return totals;
    }

    function traceSlowestSpan(spans) {
        var nonRoot = spans.filter(function(span) {
            return span && span.parent;
        });
        var source = nonRoot.length ? nonRoot : spans;
        return source.reduce(function(slowest, span) {
            if (!slowest) {
                return span;
            }
            return traceFiniteNumber(span && span.duration_ms, 0) > traceFiniteNumber(slowest.duration_ms, 0) ? span : slowest;
        }, null);
    }

    function traceStatusClass(status) {
        var code = Number(status || 0);
        if (code >= 500) return 'slow';
        if (code >= 400) return 'medium';
        if (code >= 200 && code < 400) return 'fast';
        return '';
    }

    function traceRequestSummary(summary) {
        var request = traceGetPath(summary || {}, 'request') || {};
        var method = String(request.method || traceGetPath(summary || {}, 'method') || '');
        var status = String(request.status || traceGetPath(summary || {}, 'status') || '');
        var uri = String(request.uri || traceGetPath(summary || {}, 'uri') || window.location.pathname || '');
        var host = String(request.host || traceGetPath(summary || {}, 'host') || window.location.host || '');
        return {
            method: method,
            status: status,
            uri: uri,
            host: host
        };
    }

    function traceRuntimeSummary(summary) {
        var runtime = traceGetPath(summary || {}, 'runtime') || {};
        var fpc = traceGetPath(summary || {}, 'fpc') || {};
        var fpcHit = Boolean(fpc.hit || traceGetPath(summary || {}, 'fpc_hit'));
        return {
            mode: String(runtime.mode || traceGetPath(summary || {}, 'mode') || ''),
            instance: String(runtime.instance || traceGetPath(summary || {}, 'instance') || ''),
            workerId: String(runtime.worker_id || traceGetPath(summary || {}, 'worker_id') || ''),
            workerPort: String(runtime.worker_port || traceGetPath(summary || {}, 'worker_port') || ''),
            pid: String(runtime.pid || traceGetPath(summary || {}, 'pid') || ''),
            requestCount: String(runtime.request_count || traceGetPath(summary || {}, 'request_count') || ''),
            fpcHit: fpcHit,
            fpcSource: String(fpc.source || traceGetPath(summary || {}, 'fpc_source') || '')
        };
    }

    function traceOverviewCard(label, value, note, tone) {
        var klass = tone ? ' ' + tone : '';
        var html = '<div class="dev-tool-trace-overview-card' + klass + '">';
        html += '<div class="dev-tool-trace-overview-label">' + escapeHtml(label) + '</div>';
        html += '<div class="dev-tool-trace-overview-value" title="' + escapeAttr(value) + '">' + escapeHtml(value) + '</div>';
        html += '<div class="dev-tool-trace-overview-note" title="' + escapeAttr(note) + '">' + escapeHtml(note || '') + '</div>';
        html += '</div>';
        return html;
    }

    function renderTraceOverview(spans, summary, codeSpans, dbSpans) {
        var totalFromSummary = traceFirstNumber(summary, ['total_ms', 'total_duration_ms', 'timing.total_ms']);
        var totalMs = totalFromSummary !== null && totalFromSummary > 0 ? totalFromSummary : traceRootTotal(spans);
        var categoryTotals = traceCategoryTotals(spans, summary);
        var dbFromSummary = traceFirstNumber(summary, ['db_duration_ms', 'db_ms', 'timing.db_ms', 'category_totals.db']);
        var dbMs = dbFromSummary !== null ? dbFromSummary : (categoryTotals.db || traceSumDuration(dbSpans));
        var codeMs = totalMs > 0 ? Math.max(0, totalMs - dbMs) : traceSumDuration(codeSpans);
        var dbRatio = totalMs > 0 ? Math.round((dbMs / totalMs) * 100) : 0;
        var slowest = traceSlowestSpan(spans);
        var slowestMs = traceFiniteNumber(slowest && slowest.duration_ms, 0);
        var slowInfo = slowest ? parseTraceLifecycleInfo(slowest) : null;
        var slowCount = spans.filter(function(span) {
            return traceFiniteNumber(span && span.duration_ms, 0) >= 200;
        }).length;
        var request = traceRequestSummary(summary || {});
        var runtime = traceRuntimeSummary(summary || {});
        var requestValue = (request.method ? request.method + ' ' : '') + (request.status ? request.status : '当前页');
        var requestNote = (request.host ? request.host : '') + (request.uri ? request.uri : '');
        var runtimeValue = runtime.fpcHit ? 'FPC HIT' : (runtime.instance || runtime.mode || '当前进程');
        var runtimeNote = [];
        if (runtime.workerId) runtimeNote.push('worker ' + runtime.workerId);
        if (runtime.workerPort) runtimeNote.push('port ' + runtime.workerPort);
        if (runtime.pid) runtimeNote.push('pid ' + runtime.pid);
        if (runtime.requestCount) runtimeNote.push('#' + runtime.requestCount);
        if (runtime.fpcSource) runtimeNote.push(runtime.fpcSource);

        var totalClass = getTimeClass(totalMs, 100, 500);
        var codeClass = getTimeClass(codeMs, 80, 400);
        var dbClass = dbRatio >= 40 || dbMs >= 200 ? 'medium' : getTimeClass(dbMs, 40, 200);
        var slowestClass = getTimeClass(slowestMs, 100, 500);
        var statusClass = traceStatusClass(request.status);
        var runtimeClass = runtime.fpcHit ? 'fast' : '';
        var requestId = traceGetPath(summary || {}, 'request_id') || window.__WELINE_REQUEST_ID__ || '';

        var html = '<div class="dev-tool-trace-overview">';
        html += traceOverviewCard('总耗时', formatTime(totalMs), 'span ' + spans.length + (requestId ? ' · request_id ' + requestId : ''), totalClass);
        html += traceOverviewCard('编码阶段', formatTime(codeMs), codeSpans.length + ' 段 · 已扣除 DB 估算', codeClass);
        html += traceOverviewCard('DB 耗时', formatTime(dbMs), dbSpans.length + ' 次 · ' + dbRatio + '%', dbClass);
        html += traceOverviewCard('最慢阶段', formatTime(slowestMs), slowInfo ? (traceCategoryLabel(slowest.category) + ' · ' + slowInfo.title) : '暂无', slowestClass);
        html += traceOverviewCard('请求状态', requestValue, requestNote || '当前页面', statusClass);
        html += traceOverviewCard('运行时', runtimeValue, runtimeNote.join(' · ') || '无运行时摘要', runtimeClass);
        html += '</div>';

        var attention = [];
        if (summary && summary.truncated) attention.push('链路已截断');
        if (totalClass === 'slow') attention.push('总耗时偏高');
        if (dbRatio >= 40 && dbSpans.length > 0) attention.push('DB 占比 ' + dbRatio + '%');
        if (slowCount > 0) attention.push('慢阶段 ' + slowCount + ' 个');
        if (Number(request.status || 0) >= 400) attention.push('HTTP ' + request.status);
        if (runtime.fpcHit) attention.push('FPC 命中');
        if (spans.length >= 300) attention.push('阶段数量偏多');
        if (attention.length > 0) {
            html += '<div class="dev-tool-trace-attention"><i class="fa fa-exclamation-circle"></i>';
            attention.forEach(function(item) {
                html += '<span>' + escapeHtml(item) + '</span>';
            });
            html += '</div>';
        }

        return html;
    }

    function renderRequestTraceFromSpans(spans, summary) {
        const content = document.getElementById('dev-tool-content');
        if (!content) return;
        const codeSpans = spans.filter(function(s) { return (s.category || '') !== 'db'; });
        const dbSpans = spans.filter(function(s) { return (s.category || '') === 'db'; });

        let html = '<div class="performance-stats dev-tool-trace-shell">';
