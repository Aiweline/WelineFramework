    /* ==================== 移动端响应式设计 ==================== */
    
    /* 平板设备 (768px 及以下) */
    @media screen and (max-width: 768px) {
        .dev-tool-container {
            width: 90vw;
            max-width: 380px;
            height: 70vh;
            max-height: 500px;
        }
        
        .dev-tool-header h3 {
            font-size: 14px;
        }
        
        .dev-tool-close-btn {
            width: 34px;
            height: 34px;
            font-size: 18px;
        }
        
        .dev-tool-quick-btn {
            padding: 3px 8px;
            font-size: 11px;
        }
        
        .dev-tool-tab {
            padding: 10px 12px;
            font-size: 12px;
        }
        
        .dev-tool-search input {
            font-size: 13px;
            padding: 8px 12px;
        }
        
        .route-item,
        .doc-item {
            padding: 10px 12px;
        }
        
        .route-item h4,
        .doc-item h4 {
            font-size: 13px;
        }
        
        .route-item small,
        .doc-item .doc-meta {
            font-size: 11px;
        }
    }
    
    /* 手机设备 (480px 及以下) */
    @media screen and (max-width: 480px) {
        .dev-tool-container {
            width: 100vw !important;
            height: 100vh !important;
            max-height: 100vh !important;
            border-radius: 0 !important;
            border: none !important;
            box-shadow: none !important;
        }
        
