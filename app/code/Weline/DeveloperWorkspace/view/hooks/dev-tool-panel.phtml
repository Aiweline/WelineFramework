            // DB 表 + 编码内嵌 DB：行展开（手风琴）、复制 SQL、EXPLAIN（统一委托到 content）
            content.addEventListener('click', function(ev) {
                var target = ev.target;
                var inTable = target.closest('.dev-tool-trace-db-wrap');
                var inInline = target.closest('.dev-tool-trace-db-inline');
                if (!inTable && !inInline) return;

                // 获取当前可见的 DB 面板（常规或倒序）
                var activeDbPanel = state.traceDbLayout === 'duration'
                    ? document.getElementById('trace-db-duration-panel')
                    : document.getElementById('trace-db-normal-panel');

                if (target.classList.contains('dev-tool-db-expand-btn') || (target.closest('.dev-tool-db-data-row') && !target.closest('.dev-tool-db-sql-actions')) || (inInline && target.closest('.dev-tool-db-inline-row') && !target.closest('.dev-tool-db-sql-actions'))) {
                    var dataRow, next, isExpand, btn;
                    if (inTable) {
                        dataRow = target.classList.contains('dev-tool-db-expand-btn') ? target.closest('tr') : target.closest('.dev-tool-db-data-row');
                        if (!dataRow || dataRow.getAttribute('data-has-sql') !== '1') return;
                        // 只在当前活动面板中操作
                        if (activeDbPanel && !activeDbPanel.contains(dataRow)) return;
                        next = dataRow.nextElementSibling;
                        isExpand = next && next.classList.contains('dev-tool-db-expand-row') && next.style.display !== 'none';
                        // 只关闭当前活动面板的所有展开行
                        activeDbPanel.querySelectorAll('.dev-tool-db-expand-row').forEach(function(r) { r.style.display = 'none'; });
                        activeDbPanel.querySelectorAll('.dev-tool-db-expand-btn').forEach(function(b) { b.textContent = '▶'; });
                        if (!isExpand && next) { next.style.display = 'table-row'; btn = dataRow.querySelector('.dev-tool-db-expand-btn'); if (btn) btn.textContent = '▼'; }
                    } else {
                        var inline = target.closest('.dev-tool-trace-db-inline');
                        if (!inline || inline.getAttribute('data-has-sql') !== '1') return;
                        next = inline.querySelector('.dev-tool-db-expand-row');
                        if (!next) return;
                        isExpand = next.style.display !== 'none';
                        if (activeDbPanel) {
                            activeDbPanel.querySelectorAll('.dev-tool-db-expand-row').forEach(function(r) { r.style.display = 'none'; });
                            activeDbPanel.querySelectorAll('.dev-tool-db-expand-btn').forEach(function(b) { b.textContent = '▶'; });
                        }
                        if (!isExpand) { next.style.display = 'block'; btn = inline.querySelector('.dev-tool-db-expand-btn'); if (btn) btn.textContent = '▼'; }
                    }
                    ev.preventDefault();
                } else if (target.classList.contains('dev-tool-db-copy')) {
                    var container = target.closest('td') || target.closest('.dev-tool-trace-db-inline');
                    var pre = container ? container.querySelector('.dev-tool-db-sql-block') : null;
                    if (pre && pre.getAttribute('data-sql')) {
                        var sql = pre.getAttribute('data-sql');
                        if (navigator.clipboard && navigator.clipboard.writeText) {
                            navigator.clipboard.writeText(sql).then(function() { target.textContent = '已复制'; setTimeout(function() { target.textContent = '复制 SQL'; }, 1200); });
                        } else { target.textContent = '已复制'; setTimeout(function() { target.textContent = '复制 SQL'; }, 1200); }
                    }
                } else if (target.classList.contains('dev-tool-db-explain')) {
                    var container = target.closest('td') || target.closest('.dev-tool-trace-db-inline');
                    var pre = container ? container.querySelector('.dev-tool-db-sql-block') : null;
                    var resultEl = container ? container.querySelector('.dev-tool-db-explain-result') : null;
                    var sql = pre ? pre.getAttribute('data-sql') : '';
                    if (!sql || !resultEl) return;
                    var url = getDevToolApiUrl('db/explain');
                    if (!url) { resultEl.style.display = 'block'; resultEl.innerHTML = '<span style="color:#999;">无法获取 API 地址</span>'; return; }
                    resultEl.style.display = 'block';
                    resultEl.innerHTML = '<span style="color:#888;">执行中…</span>';
                    target.disabled = true;
                    fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sql: sql }) })
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            target.disabled = false;
                            if (data && data.code === 200 && data.data && Array.isArray(data.data.rows)) {
                                var rows = data.data.rows;
                                if (rows.length === 0) { resultEl.innerHTML = '<span style="color:#888;">无结果</span>'; return; }
                                var table = '<table style="width:100%;border-collapse:collapse;font-size:11px;"><thead><tr>';
                                var keys = Object.keys(rows[0]);
                                keys.forEach(function(k) { table += '<th style="padding:4px 6px;text-align:left;border:1px solid #e0e0e0;">' + escapeHtml(k) + '</th>'; });
                                table += '</tr></thead><tbody>';
                                rows.forEach(function(row) {
                                    table += '<tr>';
                                    keys.forEach(function(k) { table += '<td style="padding:4px 6px;border:1px solid #eee;">' + escapeHtml(String(row[k] != null ? row[k] : '')) + '</td>'; });
                                    table += '</tr>';
                                });
                                table += '</tbody></table>';
                                resultEl.innerHTML = table;
                            } else {
                                resultEl.innerHTML = '<span style="color:#a67c6b;">' + escapeHtml((data && data.msg) ? data.msg : '请求失败') + '</span>';
                            }
                        })
                        .catch(function(e) {
                            target.disabled = false;
                            resultEl.innerHTML = '<span style="color:#a67c6b;">' + escapeHtml(e.message || '请求失败') + '</span>';
                        });
                }
            });
        }
    }

    function escapeHtml(s) {
        const div = document.createElement('div');
        div.textContent = s == null ? '' : String(s);
        return div.innerHTML;
    }

    function escapeAttr(value) {
        return escapeHtml(value).replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    function sanitizeDocHref(value) {
        const textarea = document.createElement('textarea');
        textarea.innerHTML = value == null ? '' : String(value);
        const href = textarea.value.trim();

        if (!/^(https?:|mailto:|\/|#)/i.test(href)) {
            return '';
        }

        return escapeAttr(href);
    }

    function renderPerformanceStats() {
        const content = document.getElementById('dev-tool-content');
        if (!content) return;

        const statusText = function(timeClass) {
            return timeClass === 'fast' ? '快' : (timeClass === 'medium' ? '中' : '慢');
        };
        const safeMs = function(value) {
            value = Number(value);
            return Number.isFinite(value) && value >= 0 ? value : 0;
        };
        const valueOrEmpty = function(value) {
            return value == null || value === undefined ? '未记录' : formatTime(value);
        };
        const metricCard = function(label, value, timeClass) {
            var klass = timeClass ? ' ' + timeClass : '';
            var html = '<div class="dev-tool-performance-card' + klass + '">';
            html += '<div class="dev-tool-performance-card-label">' + escapeHtml(label) + '</div>';
            html += '<div class="dev-tool-performance-card-value">' + escapeHtml(String(value)) + '</div>';
            html += '</div>';
            return html;
        };
        const metricTile = function(label, value) {
            var html = '<div class="dev-tool-performance-metric">';
            html += '<div class="dev-tool-performance-metric-label">' + escapeHtml(label) + '</div>';
            html += '<div class="dev-tool-performance-metric-value">' + escapeHtml(String(value)) + '</div>';
            html += '</div>';
            return html;
        };
        const resourceLabel = function(resource) {
            try {
                var url = new URL(resource.name, location.href);
                var name = url.pathname.split('/').filter(Boolean).pop();
                return name || url.hostname || resource.name;
            } catch (e) {
                var parts = String(resource.name || '').split('/');
                return parts.pop() || resource.name || 'resource';
            }
        };
        const resourceKind = function(resource) {
            var type = String(resource.initiatorType || '').toUpperCase();
            if (type) {
                return type;
            }
            var name = String(resource.name || '').toLowerCase();
            if (name.endsWith('.js')) return 'SCRIPT';
            if (name.endsWith('.css')) return 'CSS';
            if (name.match(/\.(jpg|jpeg|png|gif|svg|webp)$/)) return 'IMAGE';
            if (name.match(/\.(woff|woff2|ttf|eot)$/)) return 'FONT';
            return 'RESOURCE';
        };

        let html = '<div class="performance-stats dev-tool-performance-shell">';

        const timing = getPerformanceTiming();
        if (timing) {
            const wlsDuration = (function() {
                try {
                    var nav = performance.getEntriesByType('navigation')[0];
                    var st = nav && nav.serverTiming;
                    if (st) {
                        var wls = st.find(function(t) { return t.name === 'wls'; });
                        if (wls) return safeMs(wls.duration);
                    }
                } catch (e) {}
                return null;
            })();

            const stageItems = [
                { label: 'DNS 查询', value: safeMs(timing.dns), desc: '域名解析', fast: 40, slow: 120 },
                { label: 'TCP 连接', value: safeMs(timing.tcp), desc: '连接建立', fast: 80, slow: 250 },
                { label: '请求发送', value: safeMs(timing.request), desc: '请求到首包', fast: 120, slow: 500 },
                { label: '响应接收', value: safeMs(timing.response), desc: '首包到响应结束', fast: 80, slow: 250 },
                { label: 'DOM 解析', value: safeMs(timing.domParsing), desc: '响应结束到可交互', fast: 80, slow: 300 },
                { label: 'DOMContentLoaded', value: safeMs(timing.domContentLoaded), desc: 'DOM Ready', fast: 1000, slow: 2500 },
                { label: '页面完全加载', value: safeMs(timing.loadComplete), desc: 'Load Event', fast: 1500, slow: 3000 }
            ];

            if (timing.firstPaint > 0) {
                stageItems.push({ label: '首次渲染', value: safeMs(timing.firstPaint), desc: 'First Paint', fast: 1000, slow: 2500 });
            }
            if (timing.firstContentfulPaint > 0) {
                stageItems.push({ label: '首次内容绘制', value: safeMs(timing.firstContentfulPaint), desc: 'FCP', fast: 1000, slow: 2500 });
            }

            const pageTotal = Math.max(safeMs(timing.loadComplete), safeMs(timing.domContentLoaded), safeMs(timing.firstContentfulPaint), safeMs(timing.firstPaint));
            const networkTotal = safeMs(timing.dns) + safeMs(timing.tcp) + safeMs(timing.request) + safeMs(timing.response);
            const fcpValue = timing.firstContentfulPaint > 0 ? safeMs(timing.firstContentfulPaint) : (timing.firstPaint > 0 ? safeMs(timing.firstPaint) : null);
            const pageClass = getTimeClass(pageTotal, 1500, 3000);
            const maxStage = Math.max.apply(null, stageItems.map(function(item) { return item.value; }).concat([1]));

            html += '<div class="dev-tool-performance-hero">';
            html += '<div>';
            html += '<div class="dev-tool-performance-kicker"><i class="fa fa-tachometer"></i> 实时性能</div>';
            html += '<div class="dev-tool-performance-title">页面加载性能</div>';
            html += '<div class="dev-tool-performance-subtitle">按浏览器 Performance Timing 拆分网络、DOM 和渲染阶段，阶段条越长越值得优先查看。</div>';
            html += '</div>';
            html += '<div class="dev-tool-performance-total">';
            html += '<div class="dev-tool-performance-total-value">' + escapeHtml(formatTime(pageTotal)) + '</div>';
            html += '<span class="dev-tool-performance-status ' + pageClass + '">' + statusText(pageClass) + '</span>';
            html += '</div>';
            html += '</div>';

            html += '<div class="dev-tool-performance-summary">';
            html += metricCard('页面完全加载', formatTime(pageTotal), pageClass);
            html += metricCard('网络链路', formatTime(networkTotal), getTimeClass(networkTotal, 200, 700));
            html += metricCard('DOM Ready', formatTime(safeMs(timing.domContentLoaded)), getTimeClass(safeMs(timing.domContentLoaded), 1000, 2500));
            html += metricCard('首屏内容', valueOrEmpty(fcpValue), fcpValue == null ? '' : getTimeClass(fcpValue, 1000, 2500));
            html += '</div>';

            html += '<div class="dev-tool-performance-panel">';
            html += '<div class="dev-tool-performance-panel-head">';
            html += '<div class="dev-tool-performance-panel-title"><i class="fa fa-area-chart"></i> 加载阶段</div>';
            html += '<div class="dev-tool-performance-panel-note">按阶段耗时排序观察瓶颈</div>';
            html += '</div>';
            html += '<div class="dev-tool-performance-panel-body">';
            html += '<div class="dev-tool-performance-timeline">';
            stageItems.forEach(function(item) {
                var timeClass = getTimeClass(item.value, item.fast, item.slow);
                var width = maxStage > 0 ? Math.max(item.value === 0 ? 0 : 3, Math.min(100, (item.value / maxStage) * 100)) : 0;
                html += '<div class="dev-tool-performance-stage-row ' + timeClass + '">';
                html += '<div>';
                html += '<div class="dev-tool-performance-stage-name">' + escapeHtml(item.label) + '</div>';
                html += '<div class="dev-tool-performance-stage-desc">' + escapeHtml(item.desc) + '</div>';
                html += '</div>';
                html += '<div class="dev-tool-performance-stage-bar" aria-hidden="true"><span style="width:' + width.toFixed(2) + '%"></span></div>';
                html += '<div class="dev-tool-performance-stage-value">' + escapeHtml(formatTime(item.value)) + '</div>';
                html += '<span class="dev-tool-performance-status ' + timeClass + '">' + statusText(timeClass) + '</span>';
                html += '</div>';
            });
            html += '</div>';
            html += '</div>';
            html += '</div>';

            if (wlsDuration != null) {
                html += '<div class="dev-tool-performance-panel">';
                html += '<div class="dev-tool-performance-panel-head">';
                html += '<div class="dev-tool-performance-panel-title"><i class="fa fa-server"></i> 服务端</div>';
                html += '<div class="dev-tool-performance-panel-note">Server-Timing</div>';
                html += '</div>';
                html += '<div class="dev-tool-performance-panel-body">';
                html += '<div class="dev-tool-performance-metrics">';
                html += metricTile('WLS 处理耗时', formatTime(wlsDuration));
                html += metricTile('浏览器等待首包', formatTime(safeMs(timing.request)));
                html += metricTile('响应接收', formatTime(safeMs(timing.response)));
                html += metricTile('页面总耗时', formatTime(pageTotal));
                html += '</div>';
                html += '</div>';
                html += '</div>';
            }
        } else {
            html += '<div class="dev-tool-performance-panel">';
            html += '<div class="dev-tool-performance-panel-body">';
            html += '<div class="dev-tool-performance-empty">性能 API 不可用，无法读取页面加载阶段。</div>';
            html += '</div>';
            html += '</div>';
        }

        // 资源加载统计
        html += '<div class="dev-tool-performance-panel">';
        html += '<div class="dev-tool-performance-panel-head">';
        html += '<div class="dev-tool-performance-panel-title"><i class="fa fa-cubes"></i> 资源加载统计</div>';
        html += '<div class="dev-tool-performance-panel-note">当前页面资源</div>';
        html += '</div>';

        const resources = performance.getEntriesByType('resource');
        const resourceStats = {
            total: resources.length,
            js: 0,
            css: 0,
            img: 0,
            font: 0,
            other: 0,
            totalSize: 0,
            totalTime: 0
        };
        
        resources.forEach(resource => {
            const name = resource.name.toLowerCase();
            if (name.endsWith('.js')) resourceStats.js++;
            else if (name.endsWith('.css')) resourceStats.css++;
            else if (name.match(/\.(jpg|jpeg|png|gif|svg|webp)$/)) resourceStats.img++;
            else if (name.match(/\.(woff|woff2|ttf|eot)$/)) resourceStats.font++;
            else resourceStats.other++;
            
            if (resource.transferSize) {
                resourceStats.totalSize += resource.transferSize;
            }
            resourceStats.totalTime += resource.duration || 0;
        });

        html += '<div class="dev-tool-performance-panel-body">';
        html += '<div class="dev-tool-performance-metrics">';
        html += metricTile('总资源数', resourceStats.total);
        html += metricTile('JS / CSS', resourceStats.js + ' / ' + resourceStats.css);
        html += metricTile('图片 / 字体', resourceStats.img + ' / ' + resourceStats.font);
        html += metricTile('传输大小', formatBytes(resourceStats.totalSize));
        html += metricTile('其他资源', resourceStats.other);
        html += metricTile('总加载时间', formatTime(resourceStats.totalTime));
        html += '</div>';

        const slowResources = resources.slice().sort(function(a, b) {
            return safeMs(b.duration) - safeMs(a.duration);
        }).slice(0, 6);

        if (slowResources.length > 0) {
            html += '<div class="dev-tool-performance-resource-list dev-tool-performance-list-offset">';
            slowResources.forEach(function(resource) {
                var duration = safeMs(resource.duration);
                var timeClass = getTimeClass(duration, 100, 500);
                html += '<div class="dev-tool-performance-resource-row">';
                html += '<div class="dev-tool-performance-row-main">';
                html += '<div class="dev-tool-performance-row-title" title="' + escapeAttr(resource.name || '') + '">' + escapeHtml(resourceLabel(resource)) + '</div>';
                html += '<div class="dev-tool-performance-row-meta">' + escapeHtml(resourceKind(resource)) + ' · ' + escapeHtml(formatBytes(resource.transferSize || 0)) + '</div>';
                html += '</div>';
                html += '<div class="dev-tool-performance-row-side">';
                html += '<span class="dev-tool-performance-stage-value">' + escapeHtml(formatTime(duration)) + '</span>';
                html += '<span class="dev-tool-performance-status ' + timeClass + '">' + statusText(timeClass) + '</span>';
                html += '</div>';
                html += '</div>';
            });
            html += '</div>';
        } else {
            html += '<div class="dev-tool-performance-empty dev-tool-performance-list-offset">暂无资源加载明细。</div>';
        }

        html += '</div>';
        html += '</div>';

        // API请求统计
        html += '<div class="dev-tool-performance-panel">';
        html += '<div class="dev-tool-performance-panel-head">';
        html += '<div class="dev-tool-performance-panel-title"><i class="fa fa-exchange"></i> API 请求统计</div>';
        html += '<div class="dev-tool-performance-panel-note">最近 ' + state.apiRequests.length + ' 条</div>';
        html += '</div>';
        html += '<div class="dev-tool-performance-panel-body">';

        if (state.apiRequests.length === 0) {
            html += '<div class="dev-tool-performance-empty">暂无 API 请求记录。</div>';
        } else {
            const durations = state.apiRequests.map(function(req) { return safeMs(req.duration); });
            const avgDuration = durations.reduce(function(sum, duration) { return sum + duration; }, 0) / durations.length;
            const maxDuration = Math.max.apply(null, durations);
            const minDuration = Math.min.apply(null, durations);

            html += '<div class="dev-tool-performance-metrics">';
            html += metricTile('平均耗时', formatTime(avgDuration));
            html += metricTile('最大耗时', formatTime(maxDuration));
            html += metricTile('最小耗时', formatTime(minDuration));
            html += metricTile('请求数量', state.apiRequests.length);
            html += '</div>';

            // 显示最近10条
            const recentRequests = state.apiRequests.slice(-10).reverse();
            html += '<div class="dev-tool-performance-api-list dev-tool-performance-list-offset">';
            recentRequests.forEach(req => {
                const timeClass = getTimeClass(safeMs(req.duration), 50, 200);
                html += '<div class="dev-tool-performance-api-row">';
                html += '<div class="dev-tool-performance-row-main">';
                html += '<div class="dev-tool-performance-row-title" title="' + escapeAttr(req.url || '') + '">' + escapeHtml(req.url || '') + '</div>';
                html += '<div class="dev-tool-performance-row-meta">状态: ' + escapeHtml(String(req.status || req.error || 'unknown')) + ' · ' + escapeHtml(new Date(req.timestamp).toLocaleTimeString()) + '</div>';
                html += '</div>';
                html += '<div class="dev-tool-performance-row-side">';
                html += '<span class="dev-tool-performance-stage-value">' + escapeHtml(formatTime(req.duration)) + '</span>';
                html += '<span class="dev-tool-performance-status ' + timeClass + '">' + statusText(timeClass) + '</span>';
                html += '</div>';
                html += '</div>';
            });
            html += '</div>';
        }

        html += '</div>';
        html += '</div>';

        html += '</div>';
        content.innerHTML = html;
    }

    function formatBytes(bytes) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return (bytes / Math.pow(k, i)).toFixed(2) + ' ' + sizes[i];
    }

    // ========== 导出公共API ==========
    return {
        init,
        toggle,
        closePanel,
        toggleLayoutMode,
        updateExpandDirection,
        switchMainTab,
        switchFrameworkTab,
        switchRouteTab,
        searchRoutes,
        toggleModule,
        openRoute,
        switchDocSearchMode,
        onModuleChange,
        searchDocs,
        openDoc,
        backToDocList,
        registerExtensionTab,
    };
})();

window.DevToolPanel = DevToolPanel;

// 页面加载完成后初始化
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', DevToolPanel.init);
} else {
    DevToolPanel.init();
}
</script>
