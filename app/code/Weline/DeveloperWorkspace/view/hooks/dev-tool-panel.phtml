<?php
/**
 * 开发工具面板
 * 
 * Hook名称：dev-tool-panel
 * 
 * @hook-priority 200      Hook优先级：200（app模块默认优先级）
 * @hook-sort-order 0       Hook排序顺序：0（默认值）
 * @hook-solo false        Hook独享：false（不独占）
 * 
 * 变量说明：
 * $isBackend - 是否后端页面
 * $panelType - 面板类型 (frontend/backend)
 * 
 * 移动端适配说明：
 * - 本组件已支持响应式设计，可在手机、平板等设备上正常使用
 * - 请确保页面包含viewport meta标签：
 *   <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
 * - 手机端（≤480px）：面板全屏显示，触发器居中，优化触摸交互
 * - 平板端（≤768px）：面板占屏幕90%宽度，高度70vh
 * - 支持触摸拖动、横竖屏切换
 */
// 这些变量在Observer 中已经设置好了
// 但为了防止报错，提供默认值
$isBackend = $isBackend ?? false;
$panelType = $panelType ?? 'frontend';
?>

<!-- 开发工具面板样式 -->
<style>
    #dev-tool-panel {
