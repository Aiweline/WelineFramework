                        </div>
                    </div>

                    <div id="documentTranslationConfigNotice" class="alert d-none mt-3 mb-0" role="alert" aria-live="polite"></div>

                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <button type="submit" id="documentTranslationConfigSaveBtn" class="btn btn-primary">
                            <i class="mdi mdi-content-save me-1"></i>
                            <span class="doc-save-label"><?=htmlspecialchars($tr('保存配置'))?></span>
                            <span class="doc-save-loading d-none"><?=htmlspecialchars($tr('正在保存...'))?></span>
                        </button>
                        <button type="button" class="btn btn-outline-secondary doc-translation-action" data-action="translation-scan"><?=htmlspecialchars($tr('扫描适配器'))?></button>
                        <button type="button" class="btn btn-outline-info doc-translation-action" data-action="translation-test"><?=htmlspecialchars($tr('测试适配器'))?></button>
                        <button type="button" class="btn btn-outline-success doc-translation-action" data-action="translation-run"><?=htmlspecialchars($tr('立即入队并执行'))?></button>
                        <button type="button" class="btn btn-outline-warning doc-translation-action" data-action="translation-retry"><?=htmlspecialchars($tr('重试失败'))?></button>
                    </div>
                </form>

                <div class="row g-3 mt-4">
                    <div class="col-lg-5">
                        <div class="card border h-100">
                            <div class="card-header bg-light"><strong><?=htmlspecialchars($tr('任务状态'))?></strong></div>
                            <div class="card-body">
                                <?php if (empty($counts)): ?>
                                    <div class="text-muted"><?=htmlspecialchars($tr('暂无任务'))?></div>
                                <?php else: ?>
                                    <?php foreach ($counts as $status => $count): ?>
                                        <span class="badge bg-secondary me-2 mb-2"><?=htmlspecialchars((string)$status)?>: <?=number_format((int)$count)?></span>
                                    <?php endforeach; ?>
                                <?php endif; ?>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <div class="card border h-100">
                            <div class="card-header bg-light"><strong><?=htmlspecialchars($tr('操作结果 / 最近错误'))?></strong></div>
                            <div class="card-body">
                                <pre id="documentTranslationActionResult" class="bg-light border rounded p-3 mb-0" style="min-height: 120px; white-space: pre-wrap;"><?=htmlspecialchars(json_encode($overview['recent_failures'] ?? [], JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT))?></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var pageIsEnglish = <?= $isEnglishPage ? 'true' : 'false' ?>;
    var pageTextReplacements = {
        '文档管理配置': 'Document Management Config',
        '开发文档': 'Developer Docs',
        '开发工作台': 'Developer Workspace',
        '开发者': 'Developer'
    };

    function replacePageTextForEnglish() {
        if (!pageIsEnglish || !document.body || !document.createTreeWalker) {
            return;
        }
        var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        var node;
        while ((node = walker.nextNode())) {
            var value = node.nodeValue;
            var trimmed = value.trim();
            if (trimmed && pageTextReplacements[trimmed]) {
                node.nodeValue = value.replace(trimmed, pageTextReplacements[trimmed]);
            }
        }
        document.title = document.title.replace('文档管理配置', 'Document Management Config');
    }

    replacePageTextForEnglish();

    function getDocumentAdminBasePath() {
        var path = window.location.pathname.replace(/\/+$/, '');
        var marker = '/dev/tool/admin/document';
        var markerIndex = path.indexOf(marker);
        if (markerIndex >= 0) {
            return path.slice(0, markerIndex + marker.length);
        }
        return path.replace(/\/config$/, '');
    }

    function buildActionUrl(action) {
        return getDocumentAdminBasePath() + '/' + action;
    }

    var saveUrl = buildActionUrl('post-config');
    var csrfToken = '<?=htmlspecialchars($this->getFormKeyValue())?>';
    var resultBox = document.getElementById('documentTranslationActionResult');
    var noticeBox = document.getElementById('documentTranslationConfigNotice');
    var saveButton = document.getElementById('documentTranslationConfigSaveBtn');
    var form = document.getElementById('documentTranslationConfigForm');

    function writeResult(payload) {
        if (!resultBox) {
            return;
        }
        resultBox.textContent = typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);
    }

    function showNotice(type, message) {
        if (!noticeBox) {
            return;
        }
        noticeBox.className = 'alert alert-' + type + ' mt-3 mb-0';
        noticeBox.textContent = message;
        if (typeof noticeBox.scrollIntoView === 'function') {
            noticeBox.scrollIntoView({block: 'nearest', behavior: 'smooth'});
        }
    }

    function extractMessage(payload, fallback) {
        if (!payload || typeof payload !== 'object') {
            return fallback;
        }
        return payload.msg || payload.message || (payload.data && payload.data.message) || fallback;
    }

    function isSuccess(payload) {
        return !!payload && (payload.code === 200 || payload.success === true || payload.status === 'success');
    }

    function serializeForm(formElement) {
        var payload = {};
        new FormData(formElement).forEach(function(value, key) {
            var arrayMatch = key.match(/^(.+)\[\]$/);
            var objectMatch = key.match(/^([^\[]+)\[([^\]]+)\]$/);
            if (arrayMatch) {
                payload[arrayMatch[1]] = payload[arrayMatch[1]] || [];
                payload[arrayMatch[1]].push(value);
                return;
            }
            if (objectMatch) {
                payload[objectMatch[1]] = payload[objectMatch[1]] || {};
                payload[objectMatch[1]][objectMatch[2]] = value;
                return;
            }
            payload[key] = value;
        });
        return payload;
    }

    function attachRequestMeta(error, response, fallbackUrl) {
        error.status = response ? response.status : null;
        error.requestUrl = response && response.url ? response.url : fallbackUrl;
        return error;
    }

    function fetchJson(url, options) {
        options = options || {};
        options.headers = Object.assign({
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }, options.headers || {});
        options.credentials = 'same-origin';

        return fetch(url, options).then(function(response) {
            return response.text().then(function(text) {
                var payload = null;
                try {
                    payload = text ? JSON.parse(text) : {};
                } catch (error) {
                    throw new Error('服务端没有返回 JSON，HTTP ' + response.status + '：' + text.slice(0, 200));
                }
                if (!response.ok) {
                    throw new Error(extractMessage(payload, '请求失败，HTTP ' + response.status));
                }
                return payload;
            });
        }).catch(function(error) {
            if (!error.requestUrl) {
                error.requestUrl = url;
            }
            throw error;
        });
    }

    function setSaveLoading(loading) {
        if (!saveButton) {
            return;
        }
        saveButton.disabled = loading;
        saveButton.querySelector('.doc-save-label').classList.toggle('d-none', loading);
        saveButton.querySelector('.doc-save-loading').classList.toggle('d-none', !loading);
    }

    function finishSave(type, message, payload) {
        try {
            writeResult(payload);
            showNotice(type, message);
        } finally {
            setSaveLoading(false);
        }
    }

    function finishAction(button, type, message, payload) {
        try {
            writeResult(payload);
            showNotice(type, message);
        } finally {
            button.disabled = false;
        }
    }

    function refreshConfigPageSoon() {
        window.setTimeout(function() {
            window.location.reload();
        }, 900);
    }

    form.addEventListener('submit', function(event) {
        event.preventDefault();
        setSaveLoading(true);
        showNotice('info', '正在保存配置...');
        fetchJson(saveUrl, {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken},
            body: JSON.stringify(serializeForm(event.target))
        }).then(function(payload) {
            if (isSuccess(payload)) {
                finishSave('success', extractMessage(payload, '配置已保存'), payload);
                refreshConfigPageSoon();
            } else {
                finishSave('danger', extractMessage(payload, '配置保存失败'), payload);
            }
        }).catch(function(error) {
            var message = error.message || String(error);
            if (error.requestUrl) {
                message += ': ' + error.requestUrl;
            }
            finishSave('danger', message, {error: message, url: error.requestUrl || null});
        });
    });

    document.querySelectorAll('.doc-translation-action').forEach(function(button) {
        button.addEventListener('click', function() {
            var action = button.getAttribute('data-action');
            button.disabled = true;
            showNotice('info', '正在执行操作...');
            fetchJson(buildActionUrl(action), {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken},
                body: JSON.stringify({form_key: csrfToken})
            })
                .then(function(payload) {
                    var success = isSuccess(payload);
                    finishAction(
                        button,
                        success ? 'success' : 'danger',
                        extractMessage(payload, '操作已完成'),
                        payload
                    );
                    if (success && action !== 'translation-test') {
                        refreshConfigPageSoon();
                    }
                })
                .catch(function(error) {
                    var message = error.message || String(error);
                    if (error.requestUrl) {
                        message += ': ' + error.requestUrl;
                    }
                    finishAction(button, 'danger', message, {error: message, url: error.requestUrl || null});
                });
        });
    });
})();
</script>
