    // 保存分类
    function saveCatalog() {
        const catalogId = $('#catalog_id').val();
        const formData = {
            pid: $('#catalog_pid').val() || '0',
            name: $('#catalog_name').val().trim(),
            description: $('#catalog_description').val().trim(),
            is_active: $('#catalog_is_active').is(':checked') ? 1 : 0
        };
        
        // 如果有id（不为空字符串、null或undefined），添加到formData中
        if (catalogId && catalogId !== '' && catalogId !== '0') {
            formData.id = String(catalogId);
        }
        
        // 验证分类名称
        if (!formData.name) {
            showNotification(i18n.categoryNameRequired, 'error');
            return;
        }
        
        // 调试信息
        console.log('保存分类数据:', formData);
        console.log('catalogId原始值:', catalogId, '类型:', typeof catalogId);
        
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/post")',
            method: 'POST',
            data: formData,
            dataType: 'json',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                if (response && response.success) {
                    // 重新加载树
                    loadCatalogTree();
                    
                    // 如果是编辑，重新加载编辑表单
                    if (formData.id) {
                        setTimeout(function() {
                            loadCatalogForEdit(formData.id);
                            // 选中该节点
                            if (catalogTree) {
                                catalogTree.jstree('select_node', formData.id.toString());
                            }
                        }, 500);
                    } else {
                        // 如果是新增，清空表单
                        clearCatalogEditForm();
                    }
                    
                    // 显示成功消息（使用页面消息组件，不弹窗）
                    showPageMessage(response.msg || i18n.saveSuccess, 'success');
                } else {
                    showPageMessage(response.msg || response.message || i18n.saveFailed, 'error');
                }
            },
            error: function(xhr) {
                let errorMsg = i18n.saveFailed;
                try {
                    const response = JSON.parse(xhr.responseText);
                    errorMsg = response.msg || response.message || errorMsg;
                } catch(e) {
                    // 如果不是JSON，可能是HTML错误页面
                    if (xhr.responseText && xhr.responseText.length < 200) {
                        errorMsg = xhr.responseText;
                    }
                }
                showPageMessage(errorMsg, 'error');
            }
        });
    }
    
