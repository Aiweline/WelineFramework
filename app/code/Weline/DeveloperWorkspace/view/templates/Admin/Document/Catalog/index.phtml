    function handleDeleteNode(nodeId) {
        try {
            // 调试信息
            console.log('handleDeleteNode被调用，nodeId:', nodeId);
            console.log('catalogTree存在:', typeof catalogTree !== 'undefined' && catalogTree !== null);
            
            // 检查catalogTree是否存在
            if (typeof catalogTree === 'undefined' || !catalogTree) {
                showNotification(i18n.catalogTreeNotInitialized, 'error');
                return;
            }
            
            // 确保jstree实例可用
            if (!catalogTree.jstree) {
                showNotification(i18n.jstreeNotAvailable, 'error');
                return;
            }
            
            // 获取节点
            const node = catalogTree.jstree('get_node', nodeId);
            console.log('获取到的节点:', node);
            
            if (!node) {
                showNotification(i18n.nodeNotExists + ' ' + nodeId, 'error');
                return;
            }
            
            // 检查节点数据结构 - 优先从original顶层读取is_system
            let nodeData = null;
            let isSystem = false;
            
            // 方法1：优先从node.original顶层读取
            if (node.original) {
                if (node.original.is_system !== undefined) {
                    isSystem = node.original.is_system == 1;
                }
                if (node.original.data) {
                    nodeData = node.original.data;
                    // 如果顶层没有is_system，从data中读取
                    if (node.original.is_system === undefined && nodeData.is_system !== undefined) {
                        isSystem = nodeData.is_system == 1;
                    }
                }
            }
            
            // 方法2：从node.data读取（备用）
            if (!nodeData && node.data) {
                nodeData = node.data;
                if (isSystem === false && nodeData.is_system !== undefined) {
                    isSystem = nodeData.is_system == 1;
                }
            }
            
            if (!nodeData) {
                console.error('节点数据结构异常:', node);
                showNotification(i18n.nodeDataFormatErrorShort, 'error');
                return;
            }
            
            console.log('节点数据:', nodeData);
            console.log('是否是系统分类:', isSystem);
            
            // 检查是否是系统分类
            if (isSystem) {
                showNotification(i18n.systemCategoryNotDeletable, 'warning');
                return;
            }
            
            // 检查是否有系统子分类
            if (hasSystemChild(nodeData.id)) {
                showNotification(i18n.hasSystemChildNotDeletable, 'warning');
                return;
            }
            
            // 确认删除提示
            const confirmMsg = i18n.confirmDeleteCategory + '"' + (nodeData.name || i18n.unnamedCategory) + '"吗？\n\n' +
                              i18n.deleteWarning + '\n' +
                              i18n.deleteWarning2;
            
            if (!confirm(confirmMsg)) {
                return;
            }
            
            // 执行删除
            performDelete(nodeData.id);
        } catch(e) {
            console.error('删除节点失败:', e);
            showNotification(i18n.deleteNodeFailed + ' ' + e.message, 'error');
        }
    }
    
