    // 保存树形结构顺序
    function saveTreeOrder(data) {
        // 防止重复保存
        if (isSavingOrder) {
            console.log('[CatalogTree] 正在保存中，跳过重复请求');
            return;
        }
        
        // 检查data是否有效
        if (!data || !data.node) {
            console.error('[CatalogTree] saveTreeOrder 失败：data或node无效', data);
            return;
        }
        
        // 设置保存标志
        isSavingOrder = true;
        
        const node = data.node;
        const newParent = data.parent;
        // data.position 是节点在新父节点children数组中的索引位置（从0开始）
        // 保存时需要转换为从1开始的排序值
        const newPosition = typeof data.position === 'number' ? data.position + 1 : 1;
        const oldParent = data.old_parent;
        const oldPosition = data.old_position;
        
        console.log('[CatalogTree] saveTreeOrder 开始', {
            nodeId: node.id,
            newParent: newParent,
            newPosition: newPosition,
            oldParent: oldParent,
            oldPosition: oldPosition,
            rawPosition: data.position
        });
        
        // 获取节点数据 - 尝试多种路径
        let nodeData = {};
        
        // 方法1：从 node.original.data 获取（标准路径）
        if (node.original && node.original.data) {
            nodeData = node.original.data;
        } 
        // 方法2：从 node.original 直接获取
        else if (node.original) {
            nodeData = node.original;
        } 
        // 方法3：从 node.data 获取
        else if (node.data) {
            nodeData = node.data;
        }
        
        // 如果还是没有ID，尝试从node.id重新获取完整节点数据
        if (!nodeData.id && node.id) {
            // 重新从jstree获取完整节点
            const fullNode = catalogTree.jstree('get_node', node.id);
            if (fullNode) {
                if (fullNode.original && fullNode.original.data) {
                    nodeData = fullNode.original.data;
                } else if (fullNode.original) {
                    nodeData = fullNode.original;
                } else if (fullNode.data) {
                    nodeData = fullNode.data;
                } else {
                    // 使用顶层字段作为备用
                    nodeData = {
                        id: fullNode.node_id || fullNode.id || node.id,
                        name: fullNode.node_name || fullNode.text || '',
                        is_system: fullNode.is_system || 0,
                        is_active: fullNode.is_active || 0
                    };
                }
            } else {
                // 如果无法获取完整节点，使用顶层字段或node.id
                nodeData = {
                    id: node.node_id || node.id,
                    name: node.node_name || node.text || '',
                    is_system: node.is_system || 0,
                    is_active: node.is_active || 0
                };
            }
        }
        
        // 最终检查 - 确保至少有ID
        if (!nodeData.id) {
            // 最后尝试：直接使用 node.id
            if (node.id) {
                nodeData.id = node.id;
            } else {
                console.warn('[CatalogTree] saveTreeOrder 失败：无法获取节点ID', {
                    node: node,
                    nodeData: nodeData,
                    nodeOriginal: node.original
                });
                return;
            }
        }
        
        // 确保必要字段存在（使用备用值）
        if (!nodeData.name && node.text) {
            // 从text中提取名称（去除HTML标签）
            nodeData.name = node.text.replace(/<[^>]*>/g, '').trim();
        }
        if (nodeData.is_system === undefined) {
            nodeData.is_system = node.is_system || 0;
        }
        
        // 获取新父节点的ID
        let newParentId = 0;
        let newLevel = 1;
        if (newParent !== '#') {
            const parentNode = catalogTree.jstree('get_node', newParent);
            if (parentNode) {
                // 尝试多种路径获取父节点数据
                let parentData = null;
                if (parentNode.original && parentNode.original.data) {
                    parentData = parentNode.original.data;
                } else if (parentNode.original) {
                    parentData = parentNode.original;
                } else if (parentNode.data) {
                    parentData = parentNode.data;
                }
                
                if (parentData && parentData.id) {
                    newParentId = parseInt(parentData.id, 10) || 0;
                    newLevel = (parseInt(parentData.level, 10) || 0) + 1;
                }
            }
        }
        
        // 确保 nodeData.id 是数字类型用于比较
        const currentNodeId = parseInt(nodeData.id, 10);
        
        // 检查不能将自己作为自己的父分类
        if (newParentId > 0 && newParentId == currentNodeId) {
            // 恢复原位置
            catalogTree.jstree('move_node', node, oldParent, oldPosition);
            showNotification(i18n.cannotSetSelfAsParent, 'error');
            isSavingOrder = false; // 重置保存标志
            return;
        }
        
        // 检查系统分类不允许拖拽（理论上不会执行到这里，因为check_callback已经阻止了）
        const isSystem = nodeData.is_system == 1;
        if (isSystem) {
            // 恢复原位置
            catalogTree.jstree('move_node', node, oldParent, oldPosition);
            isSavingOrder = false; // 重置保存标志
            return;
        }
        
        // 检查目标位置是否已有同名分类
        const currentNodeName = nodeData.name || node.text.replace(/<[^>]*>/g, '').trim();
        let siblings = [];
        
        if (newParent !== '#') {
            // 获取目标父节点的所有子节点
            const parentNode = catalogTree.jstree('get_node', newParent);
            if (parentNode && parentNode.children) {
                siblings = parentNode.children;
            }
        } else {
            // 获取所有顶级节点
            siblings = catalogTree.jstree('get_children_dom', '#');
            // 转换为节点ID数组
            siblings = siblings.map(function(elem) {
                return $(elem).attr('id');
            }).filter(function(id) {
                return id && id !== '';
            });
        }
        
        // 检查同级节点是否有同名
        for (let i = 0; i < siblings.length; i++) {
            const siblingId = siblings[i];
            // 跳过当前节点本身
            if (siblingId === node.id) {
                continue;
            }
            const siblingNode = catalogTree.jstree('get_node', siblingId);
            if (siblingNode && siblingNode.original) {
                const siblingData = siblingNode.original.data || {};
                const siblingName = siblingData.name || siblingNode.text.replace(/<[^>]*>/g, '').trim();
                // 检查是否同名
                if (siblingName === currentNodeName) {
                    // 恢复原位置
                    catalogTree.jstree('move_node', node, oldParent, oldPosition);
                    showNotification(i18n.duplicateCategoryName + ': ' + currentNodeName, 'error');
                    isSavingOrder = false; // 重置保存标志
                    return;
                }
            }
        }
        
        // 更新分类的pid和level
        // 使用已解析的 currentNodeId
        if (isNaN(currentNodeId)) {
            console.error('[CatalogTree] saveTreeOrder 失败：节点ID不是有效数字', nodeData.id);
            isSavingOrder = false; // 重置保存标志
            return;
        }
        
        const saveData = {
            id: currentNodeId,
            pid: newParentId,
            level: newLevel,
            position: newPosition
        };
        
        console.log('[CatalogTree] 发送保存排序请求', saveData);
        
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/update-order")',
            method: 'POST',
            data: saveData,
            dataType: 'json',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                console.log('[CatalogTree] 保存排序响应', response);
                // 重置保存标志
                isSavingOrder = false;
                
                if (response && response.success) {
                    // 确认返回的位置信息
                    if (response.data) {
                        console.log('[CatalogTree] 位置信息已保存:', {
                            id: response.data.id,
                            pid: response.data.pid,
                            level: response.data.level,
                            position: response.data.position
                        });
                    }
                    
                    // 保存当前选中的节点ID
                    const selectedNodeId = currentCatalogId;
                    
                    // 重新加载树
                    loadCatalogTree();
                    
                    // 如果之前有选中的节点，重新选中并加载编辑表单
                    if (selectedNodeId) {
                        setTimeout(function() {
                            if (catalogTree) {
                                catalogTree.jstree('select_node', selectedNodeId.toString());
                                loadCatalogForEdit(selectedNodeId);
                            }
                        }, 500);
                    }
                    
                    // 使用轻量级提示（页面消息，不弹窗）
                    showPageMessage(response.msg || i18n.sortSaved, 'success');
                } else {
                    // 恢复原位置
                    catalogTree.jstree('move_node', node, oldParent, oldPosition);
                    // 使用轻量级提示（页面消息，不弹窗）
                    showPageMessage(response.msg || i18n.saveSortFailed, 'error');
                }
            },
            error: function(xhr, status, error) {
                console.error('[CatalogTree] 保存排序失败', {
                    status: status,
                    error: error,
                    responseText: xhr.responseText
                });
                // 重置保存标志
                isSavingOrder = false;
                
                // 恢复原位置
                catalogTree.jstree('move_node', node, oldParent, oldPosition);
                let errorMsg = i18n.saveSortFailed;
                try {
                    const response = JSON.parse(xhr.responseText);
                    errorMsg = response.msg || response.message || errorMsg;
                } catch(e) {
                    if (xhr.status === 404) {
                        errorMsg = i18n.saveSortFailed + ' (接口不存在)';
                    } else {
                        errorMsg = xhr.responseText || errorMsg;
                    }
                }
                // 使用轻量级提示（页面消息，不弹窗）
                showPageMessage(errorMsg, 'error');
            }
        });
    }
    
    // 显示消息 - 使用主题的消息提示，禁止使用 alert 弹窗
    function showNotification(message, type) {
        // 优先使用框架的消息提示
        if (typeof window.showMessage === 'function') {
            window.showMessage(message, type);
        } else {
            // 如果没有框架消息提示，使用页面消息（不弹窗）
            showPageMessage(message, type);
        }
    }
    
    // 显示页面消息（使用Bootstrap alert组件，不弹窗）
    function showPageMessage(message, type = 'success') {
        const container = $('#ajax-message-container .col-12');
        const alertClass = type === 'success' ? 'success' : type === 'error' ? 'danger' : type === 'warning' ? 'warning' : 'info';
        const iconClass = type === 'success' ? 'mdi-check-circle' : type === 'error' ? 'mdi-alert-circle' : type === 'warning' ? 'mdi-alert' : 'mdi-information';
        
        // 清除之前的消息
        container.empty();
        
        // 创建消息元素
        const messageHtml = `
            <div class="alert alert-${alertClass} alert-dismissible fade show" role="alert">
                <i class="mdi ${iconClass} me-2"></i> ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
        
        container.html(messageHtml);
        $('#ajax-message-container').slideDown(300);
        
        // 3秒后自动隐藏
        setTimeout(function() {
            $('#ajax-message-container').slideUp(300, function() {
                container.empty();
            });
        }, 3000);
    }
    
    // 添加拖拽滚动功能
    function initDragScroll() {
        const catalogTreeContainer = document.getElementById('catalog-tree-container');
        if (!catalogTreeContainer) return;
        
        let isMouseDown = false;
        let isDragging = false;
        let startX = 0;
        let startY = 0;
        let scrollLeft = 0;
        let scrollTop = 0;
        let dragThreshold = 5; // 拖拽阈值，超过这个距离才认为是拖拽
        
        catalogTreeContainer.addEventListener('mousedown', function(e) {
            // 只响应鼠标左键
            if (e.button !== 0) return;
            
            // 如果点击的是可交互元素（如链接、按钮、jstree节点），不启用拖拽
            if (e.target.tagName === 'A' || e.target.closest('a') || 
                e.target.closest('.jstree-anchor') ||
                e.target.closest('.jstree-node')) {
                // 检查是否点击的是jstree的展开/收起按钮
                if (e.target.classList.contains('jstree-ocl') || 
                    e.target.closest('.jstree-ocl')) {
                    return;
                }
            }
            
            isMouseDown = true;
            isDragging = false;
            startX = e.pageX;
            startY = e.pageY;
            scrollLeft = catalogTreeContainer.scrollLeft;
            scrollTop = catalogTreeContainer.scrollTop;
            e.preventDefault(); // 防止文本选择
        });
        
        document.addEventListener('mousemove', function(e) {
            if (!isMouseDown || !catalogTreeContainer) return;
            
            // 如果还没有开始拖拽，检查是否超过阈值
            if (!isDragging) {
                const deltaX = Math.abs(e.pageX - startX);
                const deltaY = Math.abs(e.pageY - startY);
                
                // 如果移动距离超过阈值，开始拖拽
                if (deltaX > dragThreshold || deltaY > dragThreshold) {
                    isDragging = true;
                    catalogTreeContainer.classList.add('dragging');
                    // 重新计算起始位置（相对于容器）
                    const rect = catalogTreeContainer.getBoundingClientRect();
                    startX = e.pageX - rect.left;
                    startY = e.pageY - rect.top;
                    scrollLeft = catalogTreeContainer.scrollLeft;
                    scrollTop = catalogTreeContainer.scrollTop;
                } else {
                    return; // 还没超过阈值，不处理
                }
            }
            
            // 执行拖拽滚动
            e.preventDefault();
            const rect = catalogTreeContainer.getBoundingClientRect();
            const x = e.pageX - rect.left;
            const y = e.pageY - rect.top;
            const walkX = (x - startX) * 2; // 滚动速度倍数
            const walkY = (y - startY) * 2;
            catalogTreeContainer.scrollLeft = scrollLeft - walkX;
            catalogTreeContainer.scrollTop = scrollTop - walkY;
        });
        
        document.addEventListener('mouseup', function(e) {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
        
        // 鼠标离开容器时也停止拖拽
        catalogTreeContainer.addEventListener('mouseleave', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
    }
    
    // 等待DOM加载完成后初始化拖拽滚动
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(initDragScroll, 500);
        });
    } else {
        setTimeout(initDragScroll, 500);
    }
})();
</script>

