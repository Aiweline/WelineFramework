<script>
(function() {
    let catalogTree = null;
    let currentCatalogId = null;
    let isSavingOrder = false; // 防止重复保存的标志
    let saveOrderTimer = null; // 防抖定时器
    
    // 初始化
    $(document).ready(function() {
        // 加载分类树
        loadCatalogTree();
        
        // 绑定添加顶级分类按钮事件
        $('#btn-add-top-level').on('click', function() {
            showAddCatalogForm(0);
        });
        
        // 表单提交（使用事件委托，因为表单是动态生成的）
        $(document).on('submit', '#catalog-edit-form', function(e) {
            e.preventDefault();
            saveCatalog();
        });
    });
    
    // 检查分类及其子分类中是否有系统分类
    function hasSystemChild(catalogId) {
        if (!catalogTree || !catalogTree.jstree) {
            return false;
        }
        try {
            const node = catalogTree.jstree('get_node', catalogId.toString());
            if (!node) {
                return false;
            }
            
            // 检查当前节点是否是系统分类 - 优先从original顶层读取
            let isSystem = false;
            if (node.original) {
                if (node.original.is_system !== undefined) {
                    isSystem = node.original.is_system == 1;
                } else if (node.original.data && node.original.data.is_system !== undefined) {
                    isSystem = node.original.data.is_system == 1;
                }
            } else if (node.data && node.data.is_system !== undefined) {
                isSystem = node.data.is_system == 1;
            }
            
            if (isSystem) {
                return true;
            }
            
            // 递归检查所有子节点
            if (node.children && node.children.length > 0) {
                for (let i = 0; i < node.children.length; i++) {
                    const childId = node.children[i];
                    if (hasSystemChild(childId)) {
                        return true;
                    }
                }
            }
            
            return false;
        } catch(e) {
            console.warn('检查系统子分类时出错:', e);
            return false;
        }
    }
    
    // 加载分类树
    function loadCatalogTree() {
        $.get({
            url: '@admin-url("dev/tool/admin/document/catalog/tree")',
            dataType: 'json'
        }).done(function(data) {
            if (!data || data.length === 0) {
                $('#catalog-tree-container').html('<div class="text-center py-5"><p class="text-muted">' + i18n.noCategories + '</p></div>');
                return;
            }
            
            // 转换为jstree格式
            const treeData = convertToJSTreeFormat(data);
            
            // 如果已存在 jstree 实例，先销毁它（防止事件重复绑定）
            if (catalogTree && catalogTree.jstree) {
                try {
                    // 清除防抖定时器
                    if (saveOrderTimer) {
                        clearTimeout(saveOrderTimer);
                        saveOrderTimer = null;
                    }
                    // 重置保存标志
                    isSavingOrder = false;
                    // 销毁 jstree 实例
                    catalogTree.jstree('destroy');
                } catch(e) {
                    console.warn('[CatalogTree] 销毁旧实例时出错:', e);
                }
            }
            
            // 初始化jstree
            $('#catalog-tree-container').html('<div id="catalog-tree"></div>');
            const $catalogTree = $('#catalog-tree');
            catalogTree = $catalogTree.jstree({
                'core': {
                    'data': treeData,
                    'check_callback': function(operation, node, node_parent, node_position, more) {
                        // 检查拖拽操作
                        if (operation === 'move_node') {
                            // 获取节点数据
                            const nodeData = node.original && node.original.data ? node.original.data : {};
                            const isSystem = nodeData.is_system == 1 || node.original.is_system == 1;
                            
                            // 系统分类不允许拖拽，直接禁止，不显示提示
                            if (isSystem) {
                                return false;
                            }
                            
                            return true;
                        }
                        return true;
                    },
                    'themes': {
                        'responsive': true,
                        'variant': 'large',
                        'stripes': false
                    }
                },
                'plugins': ['dnd', 'contextmenu'],
                'dnd': {
                    'copy': false,
                    'inside_pos': 'last'
                },
                'contextmenu': {
                    'items': function(node) {
                        console.log('node', node);
                        // 读取is_system属性 - 多种方式确保能读取到
                        let isSystem = false;
                        let nodeData = null;
                        
                        // 方法1：优先从node.original顶层读取（最直接）
                        if (node.original) {
                            if (node.original.is_system !== undefined) {
                                isSystem = node.original.is_system == 1;
                            }
                            // 从node.original.data读取完整数据
                            if (node.original.data) {
                                nodeData = node.original.data;
                                // 如果顶层没有is_system，从data中读取
                                if (node.original.is_system === undefined && nodeData.is_system !== undefined) {
                                    isSystem = nodeData.is_system == 1;
                                }
                            }
                        }
                        
                        // 方法2：从node.data读取（备用）
                        if (!nodeData && node.data) {
                            nodeData = node.data;
                            if (isSystem === false && nodeData.is_system !== undefined) {
                                isSystem = nodeData.is_system == 1;
                            }
                        }
                        
                        const items = {};
                        
                        // 删除选项 - 所有节点都显示，但系统分类或有系统子分类的禁用
                        const hasSystemChildren = nodeData && nodeData.id ? hasSystemChild(nodeData.id) : false;
                        items['delete'] = {
                            'label': '<i class="mdi mdi-delete"></i> ' + i18n.delete,
                            'action': function(data) {
                                // 如果禁用，直接返回false，不执行任何操作
                                if (isSystem || hasSystemChildren) {
                                    return false;
                                }
                                // jstree原生方式：直接处理删除逻辑
                                handleDeleteNode(data.reference);
                                return true;
                            },
                            '_disabled': isSystem || hasSystemChildren,
                            'title': isSystem ? i18n.systemCategoryNotDeletable : (hasSystemChildren ? i18n.hasSystemChildNotDeletable : i18n.deleteCategoryMenu),
                            'separator_after': true
                        };
                        
                        // 所有节点都可以添加子分类
                        items['add_child'] = {
                            'label': '<i class="mdi mdi-plus"></i> ' + i18n.addSubCategoryMenu,
                            'action': function(data) {
                                // jstree原生方式：直接处理添加子分类逻辑
                                handleAddChildNode(data.reference);
                            },
                            'title': i18n.addSubCategoryMenu
                        };
                        
                        return items;
                    }
                }
            }).on('ready.jstree', function() {
                // 为系统分类节点添加特殊标识和样式
                markSystemNodes();
            }).on('select_node.jstree', function(e, data) {
                // 点击分类节点时，在右侧显示编辑表单
                const nodeId = data.node.id;
                loadCatalogForEdit(nodeId);
            }).on('show_contextmenu.jstree', function(e, reference, element, position) {
                // 右键菜单显示后，为禁用项设置title属性并阻止点击事件
                setTimeout(function() {
                    const $menu = $('.jstree-contextmenu');
                    $menu.find('.jstree-contextmenu-item.jstree-contextmenu-disabled').each(function() {
                        const $item = $(this);
                        
                        // 从节点数据读取is_system属性
                        let isSystem = false;
                        let nodeData = null;
                        
                        try {
                            const node = catalogTree.jstree('get_node', reference);
                            if (node) {
                                // 方法1：优先从node.original顶层读取
                                if (node.original) {
                                    if (node.original.is_system !== undefined) {
                                        isSystem = node.original.is_system == 1;
                                    }
                                    if (node.original.data) {
                                        nodeData = node.original.data;
                                        // 如果顶层没有is_system，从data中读取
                                        if (node.original.is_system === undefined && nodeData.is_system !== undefined) {
                                            isSystem = nodeData.is_system == 1;
                                        }
                                    }
                                }
                                
                                // 方法2：从node.data读取（备用）
                                if (!nodeData && node.data) {
                                    nodeData = node.data;
                                    if (isSystem === false && nodeData.is_system !== undefined) {
                                        isSystem = nodeData.is_system == 1;
                                    }
                                }
                            }
                        } catch(err) {
                            console.warn('读取节点数据失败:', err);
                        }
                        
                        const hasSystemChildren = nodeData && nodeData.id ? hasSystemChild(nodeData.id) : false;
                        
                        // 根据菜单项文本设置title
                        const itemText = $item.text().trim();
                        if (itemText.includes(i18n.delete)) {
                            if (isSystem) {
                                $item.attr('title', i18n.systemCategoryNotDeletable);
                            } else if (hasSystemChildren) {
                                $item.attr('title', i18n.hasSystemChildNotDeletable);
                            }
                        }
                        
                        // 阻止禁用项的点击事件
                        $item.off('click').on('click', function(e) {
                            e.preventDefault();
                            e.stopPropagation();
                            e.stopImmediatePropagation();
                            return false;
                        });
                        
                        // 阻止禁用项内链接的点击事件
                        $item.find('a').off('click').on('click', function(e) {
                            e.preventDefault();
                            e.stopPropagation();
                            e.stopImmediatePropagation();
                            return false;
                        });
                    });
                }, 10);
            }).on('model.jstree', function() {
                // 树结构更新后重新标记系统节点
                setTimeout(markSystemNodes, 100);
            }).on('move_node.jstree', function(e, data) {
                // 拖拽完成后保存新位置 - 使用jstree原生事件
                // 注意：data.position 是节点在新父节点中的索引位置（从0开始）
                console.log('[CatalogTree] ========== move_node.jstree事件触发 ==========');
                console.log('[CatalogTree] 事件数据:', {
                    node: data.node,
                    parent: data.parent,
                    position: data.position,
                    old_parent: data.old_parent,
                    old_position: data.old_position,
                    instance: data.instance
                });
                
                // 立即检查是否正在保存中，如果是则直接返回
                if (isSavingOrder) {
                    console.log('[CatalogTree] 正在保存中，忽略本次 move_node 事件');
                    return;
                }
                
                // 清除之前的防抖定时器（如果存在）
                if (saveOrderTimer) {
                    clearTimeout(saveOrderTimer);
                    saveOrderTimer = null;
                }
                
                // 使用防抖机制，延迟500ms执行保存（避免快速连续触发）
                saveOrderTimer = setTimeout(function() {
                    saveOrderTimer = null;
                    // 再次检查，防止在延迟期间已经有其他保存操作开始
                    if (isSavingOrder) {
                        console.log('[CatalogTree] 防抖延迟期间已有保存操作，跳过本次');
                        return;
                    }
                    try {
                        // saveTreeOrder 函数内部会设置 isSavingOrder 标志
                        saveTreeOrder(data);
                    } catch(error) {
                        console.error('[CatalogTree] 保存排序时出错:', error);
                        isSavingOrder = false; // 确保出错时重置标志
                    }
                }, 500);
            });
        }).fail(function(xhr, status, error) {
            $('#catalog-tree-container').html('<div class="alert alert-danger">' + i18n.loadCatalogTreeFailed + error + '</div>');
        });
    }
    
    // 标记系统分类节点 - 将is_system属性添加到DOM元素上
    function markSystemNodes() {
        if (!catalogTree || !catalogTree.jstree) {
            return;
        }
        try {
            const allNodes = catalogTree.jstree('get_json', null, {flat: true});
            allNodes.forEach(function(node) {
                const nodeElement = catalogTree.jstree('get_node', node.id, true);
                if (nodeElement && nodeElement.length) {
                    // 获取节点数据
                    let nodeData = null;
                    if (node.original && node.original.data) {
                        nodeData = node.original.data;
                    } else if (node.data) {
                        nodeData = node.data;
                    }
                    
                    if (nodeData) {
                        const isSystem = nodeData.is_system == 1;
                        const nodeId = nodeData.id;
                        
                        // 将is_system属性添加到jstree-anchor元素上
                        const anchor = nodeElement.find('.jstree-anchor');
                        if (anchor.length) {
                            anchor.attr('data-is-system', isSystem ? '1' : '0');
                            anchor.attr('data-node-id', nodeId || '');
                        }
                        
                        // 同时标记jstree-node元素
                        const jstreeNode = nodeElement.closest('.jstree-node');
                        if (jstreeNode.length) {
                            jstreeNode.attr('data-is-system', isSystem ? '1' : '0');
                            jstreeNode.attr('data-node-id', nodeId || '');
                            if (isSystem) {
                                jstreeNode.attr('data-system', 'true');
                            } else {
                                jstreeNode.removeAttr('data-system');
                            }
                        }
                    }
                }
            });
        } catch(e) {
            console.warn('标记系统节点时出错:', e);
        }
    }
    
    // 转换为jstree格式
    function convertToJSTreeFormat(data, level = 1) {
        const result = [];
        if (!data || !Array.isArray(data)) {
            return result;
        }
        
        data.forEach(function(item) {
            if (!item || !item.id) {
                return;
            }
            
            const itemLevel = item.level || level;
            const isSystem = item.is_system == 1;
            const isActive = item.is_active == 1;
            
            // 根据节点类型设置图标
            let iconHtml = '';
            if (!isActive) {
                // 未激活的节点
                iconHtml = '<i class="mdi mdi-folder-off text-muted me-2"></i>';
            } else if (isSystem) {
                // 系统导入的激活节点
                iconHtml = '<i class="mdi mdi-folder-cog text-primary me-2"></i>';
            } else {
                // 用户创建的激活节点
                iconHtml = '<i class="mdi mdi-folder text-success me-2"></i>';
            }
            
            const node = {
                id: item.id.toString(),
                text: iconHtml + item.name + (item.description ? ' <small class="text-muted ms-2">(' + (item.description.length > 30 ? item.description.substring(0, 30) + '...' : item.description) + ')</small>' : '') + 
                      (isSystem ? ' <span class="badge bg-primary system-badge ms-2"><i class="mdi mdi-shield-check me-1"></i>' + i18n.systemCategory + '</span>' : ''),
                // 将数据直接放在data字段中，jstree会将其复制到original.data
                data: {
                    id: item.id,
                    name: item.name || '',
                    description: item.description || '',
                    pid: item.pid || 0,
                    level: itemLevel,
                    is_active: item.is_active || 0,
                    is_system: item.is_system || 0
                },
                // 同时将关键字段放在顶层，确保可以访问
                is_system: item.is_system || 0,
                is_active: item.is_active || 0,
                node_id: item.id,
                node_name: item.name || '',
                state: {
                    // 只展开一二级（level <= 2）
                    opened: itemLevel <= 2,
                    disabled: !isActive
                },
                icon: false
            };
            
            if (item.nodes && Array.isArray(item.nodes) && item.nodes.length > 0) {
                node.children = convertToJSTreeFormat(item.nodes, itemLevel + 1);
            }
            
            result.push(node);
        });
        return result;
    }
    
