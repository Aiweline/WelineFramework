<script>
(function() {
    'use strict';
    
    var catalogTree = null;
    var currentCatalogId = null;
    var isSavingOrder = false;
    var saveOrderTimer = null;
    
    $(document).ready(function() {
        loadCatalogTree();
        
        $('#btn-add-top-level').on('click', function() {
            showAddCatalogForm(0);
        });
        
        $(document).on('submit', '#catalog-edit-form', function(e) {
            e.preventDefault();
            saveCatalog();
        });
    });
    
    function hasSystemChild(catalogId) {
        if (!catalogTree || !catalogTree.jstree) {
            return false;
        }
        try {
            var node = catalogTree.jstree('get_node', catalogId.toString());
            if (!node) {
                return false;
            }
            
            var isSystem = false;
            if (node.original) {
                if (node.original.is_system !== undefined) {
                    isSystem = node.original.is_system == 1;
                } else if (node.original.data && node.original.data.is_system !== undefined) {
                    isSystem = node.original.data.is_system == 1;
                }
            } else if (node.data && node.data.is_system !== undefined) {
                isSystem = node.data.is_system == 1;
            }
            
            if (isSystem) {
                return true;
            }
            
            if (node.children && node.children.length > 0) {
                for (var i = 0; i < node.children.length; i++) {
                    var childId = node.children[i];
                    if (hasSystemChild(childId)) {
                        return true;
                    }
                }
            }
            
            return false;
        } catch(e) {
            console.warn('检查系统子分类时出错:', e);
            return false;
        }
    }
    
    function loadCatalogTree() {
        $.get({
            url: '@admin-url("dev/tool/admin/document/catalog/tree")',
            dataType: 'json'
        }).done(function(data) {
            if (!data || data.length === 0) {
                $('#catalog-tree-container').html('<div class="text-center py-5"><p class="text-muted">' + i18n.noCategories + '</p></div>');
                return;
            }
            
            var treeData = convertToJSTreeFormat(data);
            
            if (catalogTree && catalogTree.jstree) {
                try {
                    if (saveOrderTimer) {
                        clearTimeout(saveOrderTimer);
                        saveOrderTimer = null;
                    }
                    isSavingOrder = false;
                    catalogTree.jstree('destroy');
                } catch(e) {
                    console.warn('[CatalogTree] 销毁旧实例时出错:', e);
                }
            }
            
            $('#catalog-tree-container').html('<div id="catalog-tree"></div>');
            var $catalogTree = $('#catalog-tree');
            catalogTree = $catalogTree.jstree({
                'core': {
                    'data': treeData,
                    'check_callback': function(operation, node, node_parent, node_position, more) {
                        if (operation === 'move_node') {
                            var nodeData = node.original && node.original.data ? node.original.data : {};
                            var isSystem = nodeData.is_system == 1 || node.original.is_system == 1;
                            if (isSystem) {
                                return false;
                            }
                            return true;
                        }
                        return true;
                    },
                    'themes': {
                        'responsive': true,
                        'variant': 'large',
                        'stripes': false
                    }
                },
                'plugins': ['dnd', 'contextmenu'],
                'dnd': {
                    'copy': false,
                    'inside_pos': 'last'
                },
                'contextmenu': {
                    'items': function(node) {
                        var isSystem = false;
                        var nodeData = null;
                        
                        if (node.original) {
                            if (node.original.is_system !== undefined) {
                                isSystem = node.original.is_system == 1;
                            }
                            if (node.original.data) {
                                nodeData = node.original.data;
                                if (node.original.is_system === undefined && nodeData.is_system !== undefined) {
                                    isSystem = nodeData.is_system == 1;
                                }
                            }
                        }
                        
                        if (!nodeData && node.data) {
                            nodeData = node.data;
                            if (isSystem === false && nodeData.is_system !== undefined) {
                                isSystem = nodeData.is_system == 1;
                            }
                        }
                        
                        var items = {};
                        
                        var hasSystemChildren = nodeData && nodeData.id ? hasSystemChild(nodeData.id) : false;
                        items['delete'] = {
                            'label': '<i class="mdi mdi-delete"></i> ' + i18n.delete,
                            'action': function(data) {
                                if (isSystem || hasSystemChildren) {
                                    return false;
                                }
                                handleDeleteNode(data.reference);
                                return true;
                            },
                            '_disabled': isSystem || hasSystemChildren,
                            'title': isSystem ? i18n.systemCategoryNotDeletable : (hasSystemChildren ? i18n.hasSystemChildNotDeletable : i18n.deleteCategoryMenu),
                            'separator_after': true
                        };
                        
                        items['add_child'] = {
                            'label': '<i class="mdi mdi-plus"></i> ' + i18n.addSubCategoryMenu,
                            'action': function(data) {
                                handleAddChildNode(data.reference);
                            },
                            'title': i18n.addSubCategoryMenu
                        };
                        
                        return items;
                    }
                }
            }).on('ready.jstree', function() {
                markSystemNodes();
            }).on('select_node.jstree', function(e, data) {
                var nodeId = data.node.id;
                loadCatalogForEdit(nodeId);
            }).on('model.jstree', function() {
                setTimeout(markSystemNodes, 100);
            }).on('move_node.jstree', function(e, data) {
                if (isSavingOrder) {
                    return;
                }
                
                if (saveOrderTimer) {
                    clearTimeout(saveOrderTimer);
                    saveOrderTimer = null;
                }
                
                saveOrderTimer = setTimeout(function() {
                    saveOrderTimer = null;
                    if (isSavingOrder) {
                        return;
                    }
                    try {
                        saveTreeOrder(data);
                    } catch(error) {
                        console.error('[CatalogTree] 保存排序时出错:', error);
                        isSavingOrder = false;
                    }
                }, 500);
            });
        }).fail(function(xhr, status, error) {
            $('#catalog-tree-container').html('<div class="alert alert-danger">' + i18n.loadCatalogTreeFailed + error + '</div>');
        });
    }
    
    function markSystemNodes() {
        if (!catalogTree || !catalogTree.jstree) {
            return;
        }
        try {
            var allNodes = catalogTree.jstree('get_json', null, {flat: true});
            allNodes.forEach(function(node) {
                var nodeElement = catalogTree.jstree('get_node', node.id, true);
                if (nodeElement && nodeElement.length) {
                    var nodeData = null;
                    if (node.original && node.original.data) {
                        nodeData = node.original.data;
                    } else if (node.data) {
                        nodeData = node.data;
                    }
                    
                    if (nodeData) {
                        var isSystem = nodeData.is_system == 1;
                        var nodeId = nodeData.id;
                        
                        var anchor = nodeElement.find('.jstree-anchor');
                        if (anchor.length) {
                            anchor.attr('data-is-system', isSystem ? '1' : '0');
                            anchor.attr('data-node-id', nodeId || '');
                        }
                        
                        var jstreeNode = nodeElement.closest('.jstree-node');
                        if (jstreeNode.length) {
                            jstreeNode.attr('data-is-system', isSystem ? '1' : '0');
                            jstreeNode.attr('data-node-id', nodeId || '');
                            if (isSystem) {
                                jstreeNode.attr('data-system', 'true');
                            } else {
                                jstreeNode.removeAttr('data-system');
                            }
                        }
                    }
                }
            });
        } catch(e) {
            console.warn('标记系统节点时出错:', e);
        }
    }
    
    function convertToJSTreeFormat(data, level) {
        level = level || 1;
        var result = [];
        if (!data || !Array.isArray(data)) {
            return result;
        }
        
        data.forEach(function(item) {
            if (!item || !item.id) {
                return;
            }
            
            var itemLevel = item.level || level;
            var isSystem = item.is_system == 1;
            var isActive = item.is_active == 1;
            
            var iconHtml = '';
            if (!isActive) {
                iconHtml = '<i class="mdi mdi-folder-off text-muted me-2"></i>';
            } else if (isSystem) {
                iconHtml = '<i class="mdi mdi-folder-cog text-primary me-2"></i>';
            } else {
                iconHtml = '<i class="mdi mdi-folder text-success me-2"></i>';
            }
            
            var node = {
                id: item.id.toString(),
                text: iconHtml + item.name + (item.description ? ' <small class="text-muted ms-2">(' + (item.description.length > 30 ? item.description.substring(0, 30) + '...' : item.description) + ')</small>' : '') + 
                      (isSystem ? ' <span class="badge bg-primary system-badge ms-2"><i class="mdi mdi-shield-check me-1"></i>' + i18n.systemCategory + '</span>' : ''),
                data: {
                    id: item.id,
                    name: item.name || '',
                    description: item.description || '',
                    pid: item.pid || 0,
                    level: itemLevel,
                    is_active: item.is_active || 0,
                    is_system: item.is_system || 0
                },
                is_system: item.is_system || 0,
                is_active: item.is_active || 0,
                node_id: item.id,
                node_name: item.name || '',
                state: {
                    opened: itemLevel <= 2,
                    disabled: !isActive
                },
                icon: false
            };
            
            if (item.nodes && Array.isArray(item.nodes) && item.nodes.length > 0) {
                node.children = convertToJSTreeFormat(item.nodes, itemLevel + 1);
            }
            
            result.push(node);
        });
        return result;
    }
    
    function loadCatalogForEdit(catalogId) {
        currentCatalogId = catalogId;
        
        $('#catalog-edit-container').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">' + i18n.loading + '</span></div></div>');
        
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/view")',
            method: 'GET',
            data: { id: catalogId },
            dataType: 'json',
            success: function(response) {
                if (response.code === 200 && response.data) {
                    renderCatalogEditForm(response.data);
                } else {
                    $('#catalog-edit-container').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + (response.msg || i18n.loadDocumentFailed) + '</div>');
                }
            },
            error: function() {
                $('#catalog-edit-container').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + i18n.loadDocumentFailedRefresh + '</div>');
            }
        });
    }
    
    function renderCatalogEditForm(catalog) {
        var isSystem = catalog.is_system == 1;
        var isReadonly = isSystem;
        
        var html = '<form id="catalog-edit-form">' +
            '<input type="hidden" name="id" id="catalog_id" value="' + (catalog.id ? String(catalog.id) : '') + '">' +
            '<input type="hidden" name="pid" id="catalog_pid" value="' + (catalog.pid ? String(catalog.pid) : '0') + '">' +
            '<div class="mb-3"><label for="catalog_name" class="form-label">' + i18n.categoryName + ' <span class="text-danger">*</span></label>' +
            '<input type="text" class="form-control" id="catalog_name" name="name" value="' + (catalog.name || '').replace(/"/g, '&quot;') + '" required placeholder="' + i18n.pleaseEnterCategoryName + '"' + (isReadonly ? ' readonly' : '') + '>' +
            (isReadonly ? '<small class="text-muted"><i class="mdi mdi-information-outline me-1"></i>' + i18n.systemCategoryCannotEditName + '</small>' : '') + '</div>' +
            '<div class="mb-3"><label for="catalog_description" class="form-label">' + i18n.categoryDescription + '</label>' +
            '<textarea class="form-control" id="catalog_description" name="description" rows="3" placeholder="' + i18n.pleaseEnterCategoryDescription + '"' + (isReadonly ? ' readonly' : '') + '>' + (catalog.description || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;') + '</textarea></div>' +
            '<div class="mb-3"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="catalog_is_active" name="is_active" value="1"' + (catalog.is_active == 1 ? ' checked' : '') + (isReadonly ? ' disabled' : '') + '><label class="form-check-label" for="catalog_is_active">' + i18n.enableCategory + '</label></div></div>' +
            '<div class="mb-3"><label class="form-label">' + i18n.category + '</label><div class="form-control-plaintext"><span class="badge bg-info">' + (catalog.parent_name || i18n.topLevelCategory) + '</span></div></div>' +
            '<div class="mb-3"><label class="form-label">' + i18n.level + '</label><div class="form-control-plaintext"><span class="badge bg-secondary">' + (catalog.level || 1) + '</span></div></div>' +
            (isSystem ? '<div class="alert alert-info"><i class="mdi mdi-information-outline me-2"></i>' + i18n.systemCategoryCannotEdit + '</div>' : '') +
            '<div class="d-flex justify-content-between align-items-center"><div>' +
            (!isSystem && catalog.id ? '<button type="button" class="btn btn-danger btn-delete-catalog" onclick="handleDeleteCatalog(' + catalog.id + ', \'' + (catalog.name || '').replace(/'/g, "\\'") + '\')" data-catalog-id="' + catalog.id + '" data-catalog-name="' + (catalog.name || '').replace(/"/g, '&quot;') + '"><i class="mdi mdi-delete"></i> ' + i18n.delete + '</button>' : '') +
            '</div><div class="d-flex gap-2"><button type="button" class="btn btn-secondary" onclick="clearCatalogEditForm()">' + i18n.cancel + '</button><button type="submit" class="btn btn-primary"' + (isReadonly ? ' disabled' : '') + '>' + i18n.save + '</button></div></div></form>';
        
        $('#catalog-edit-title').html('<i class="mdi mdi-folder-edit me-2"></i>' + i18n.editCategory + ': ' + (catalog.name || ''));
        $('#catalog-edit-container').html(html);
    }
    
    function showAddCatalogForm(parentId) {
        currentCatalogId = null;
        
        var parentName = i18n.topLevelCategory;
        if (parentId) {
            var parentNode = catalogTree.jstree('get_node', parentId.toString());
            if (parentNode) {
                parentName = parentNode.text.replace(/<[^>]*>/g, '').trim();
            }
        }
        
        var html = '<form id="catalog-edit-form">' +
            '<input type="hidden" name="id" id="catalog_id" value="">' +
            '<input type="hidden" name="pid" id="catalog_pid" value="' + (parentId || '0') + '">' +
            '<div class="mb-3"><label for="catalog_name" class="form-label">' + i18n.categoryName + ' <span class="text-danger">*</span></label>' +
            '<input type="text" class="form-control" id="catalog_name" name="name" required placeholder="' + i18n.pleaseEnterCategoryName + '"></div>' +
            '<div class="mb-3"><label for="catalog_description" class="form-label">' + i18n.categoryDescription + '</label>' +
            '<textarea class="form-control" id="catalog_description" name="description" rows="3" placeholder="' + i18n.pleaseEnterCategoryDescription + '"></textarea></div>' +
            '<div class="mb-3"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="catalog_is_active" name="is_active" value="1" checked><label class="form-check-label" for="catalog_is_active">' + i18n.enableCategory + '</label></div></div>' +
            '<div class="mb-3"><label class="form-label">' + i18n.category + '</label><div class="form-control-plaintext"><span class="badge bg-info">' + parentName + '</span></div></div>' +
            '<div class="d-flex justify-content-end gap-2"><button type="button" class="btn btn-secondary" onclick="clearCatalogEditForm()">' + i18n.cancel + '</button><button type="submit" class="btn btn-primary">' + i18n.save + '</button></div></form>';
        
        $('#catalog-edit-title').html('<i class="mdi mdi-folder-plus me-2"></i>' + (parentId ? i18n.addSubCategory : i18n.addTopLevelCategory));
        $('#catalog-edit-container').html(html);
    }
    
    function clearCatalogEditForm() {
        $('#catalog-edit-container').html('<div class="text-center py-5"><i class="mdi mdi-folder-outline" style="font-size: 4rem; color: var(--backend-color-text-secondary, #6c757d); opacity: 0.5;"></i><p class="mt-3 text-muted">' + i18n.pleaseSelectCategory + '</p></div>');
        $('#catalog-edit-title').html('<i class="mdi mdi-folder-edit me-2"></i>' + i18n.categoryInfo);
        currentCatalogId = null;
        if (catalogTree) {
            catalogTree.jstree('deselect_all');
        }
    }
    
    window.clearCatalogEditForm = clearCatalogEditForm;
    
    function saveCatalog() {
        var catalogId = $('#catalog_id').val();
        var formData = {
            pid: $('#catalog_pid').val() || '0',
            name: $('#catalog_name').val().trim(),
            description: $('#catalog_description').val().trim(),
            is_active: $('#catalog_is_active').is(':checked') ? 1 : 0
        };
        
        if (catalogId && catalogId !== '' && catalogId !== '0') {
            formData.id = String(catalogId);
        }
        
        if (!formData.name) {
            showNotification(i18n.categoryNameRequired, 'error');
            return;
        }
        
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/post")',
            method: 'POST',
            data: formData,
            dataType: 'json',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                if (response && response.success) {
                    loadCatalogTree();
                    
                    if (formData.id) {
                        setTimeout(function() {
                            loadCatalogForEdit(formData.id);
                            if (catalogTree) {
                                catalogTree.jstree('select_node', formData.id.toString());
                            }
                        }, 500);
                    } else {
                        clearCatalogEditForm();
                    }
                    
                    showPageMessage(response.msg || i18n.saveSuccess, 'success');
                } else {
                    showPageMessage(response.msg || response.message || i18n.saveFailed, 'error');
                }
            },
            error: function(xhr) {
                var errorMsg = i18n.saveFailed;
                try {
                    var response = JSON.parse(xhr.responseText);
                    errorMsg = response.msg || response.message || errorMsg;
                } catch(e) {
                    if (xhr.responseText && xhr.responseText.length < 200) {
                        errorMsg = xhr.responseText;
                    }
                }
                showPageMessage(errorMsg, 'error');
            }
        });
    }
    
    function handleDeleteNode(nodeId) {
        try {
            if (typeof catalogTree === 'undefined' || !catalogTree) {
                showNotification(i18n.catalogTreeNotInitialized, 'error');
                return;
            }
            
            if (!catalogTree.jstree) {
                showNotification(i18n.jstreeNotAvailable, 'error');
                return;
            }
            
            var node = catalogTree.jstree('get_node', nodeId);
            
            if (!node) {
                showNotification(i18n.nodeNotExists + ' ' + nodeId, 'error');
                return;
            }
            
            var nodeData = null;
            var isSystem = false;
            
            if (node.original) {
                if (node.original.is_system !== undefined) {
                    isSystem = node.original.is_system == 1;
                }
                if (node.original.data) {
                    nodeData = node.original.data;
                    if (node.original.is_system === undefined && nodeData.is_system !== undefined) {
                        isSystem = nodeData.is_system == 1;
                    }
                }
            }
            
            if (!nodeData && node.data) {
                nodeData = node.data;
                if (isSystem === false && nodeData.is_system !== undefined) {
                    isSystem = nodeData.is_system == 1;
                }
            }
            
            if (!nodeData) {
                console.error('节点数据结构异常:', node);
                showNotification(i18n.nodeDataFormatErrorShort, 'error');
                return;
            }
            
            if (isSystem) {
                showNotification(i18n.systemCategoryNotDeletable, 'warning');
                return;
            }
            
            if (hasSystemChild(nodeData.id)) {
                showNotification(i18n.hasSystemChildNotDeletable, 'warning');
                return;
            }
            
            if (typeof AdminConfirm !== 'undefined') {
                AdminConfirm.show(i18n.confirmDeleteCategory + '"' + (nodeData.name || i18n.unnamedCategory) + '"吗？\n\n' + i18n.deleteWarning + '\n' + i18n.deleteWarning2).then(function(confirmed) {
                    if (confirmed) {
                        performDelete(nodeData.id);
                    }
                });
            } else {
                if (confirm(i18n.confirmDeleteCategory + '"' + (nodeData.name || i18n.unnamedCategory) + '"吗？\n\n' + i18n.deleteWarning + '\n' + i18n.deleteWarning2)) {
                    performDelete(nodeData.id);
                }
            }
        } catch(e) {
            console.error('删除节点失败:', e);
            showNotification(i18n.deleteNodeFailed + ' ' + e.message, 'error');
        }
    }
    
    function handleAddChildNode(nodeId) {
        showAddCatalogForm(nodeId);
    }
    
    function handleDeleteCatalog(catalogId, catalogName) {
        if (catalogTree && catalogTree.jstree) {
            var node = catalogTree.jstree('get_node', catalogId.toString());
            if (node) {
                var isSystem = false;
                if (node.original) {
                    if (node.original.is_system !== undefined) {
                        isSystem = node.original.is_system == 1;
                    } else if (node.original.data && node.original.data.is_system !== undefined) {
                        isSystem = node.original.data.is_system == 1;
                    }
                }
                
                if (isSystem) {
                    showNotification(i18n.systemCategoryNotDeletable, 'warning');
                    return;
                }
                
                if (hasSystemChild(catalogId)) {
                    showNotification(i18n.hasSystemChildNotDeletable, 'warning');
                    return;
                }
            }
        }
        
        if (typeof AdminConfirm !== 'undefined') {
            AdminConfirm.show(i18n.confirmDeleteCategory + ' "' + (catalogName || i18n.unnamedCategory) + '"吗？\n\n' + i18n.deleteWarning + '\n' + i18n.deleteWarning2).then(function(confirmed) {
                if (confirmed) {
                    performDelete(catalogId);
                }
            });
        } else {
            if (confirm(i18n.confirmDeleteCategory + ' "' + (catalogName || i18n.unnamedCategory) + '"吗？\n\n' + i18n.deleteWarning + '\n' + i18n.deleteWarning2)) {
                performDelete(catalogId);
            }
        }
    }
    
    window.handleDeleteCatalog = handleDeleteCatalog;
    
    function performDelete(id) {
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/delete")',
            method: 'POST',
            data: { id: id },
            dataType: 'json',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                if (response && response.success) {
                    loadCatalogTree();
                    clearCatalogEditForm();
                    showNotification(response.msg || i18n.deleteSuccess, 'success');
                } else {
                    showNotification(response.msg || response.message || i18n.deleteFailed, 'error');
                }
            },
            error: function(xhr) {
                var errorMsg = i18n.deleteFailed;
                try {
                    var response = JSON.parse(xhr.responseText);
                    errorMsg = response.msg || response.message || errorMsg;
                } catch(e) {
                    errorMsg = xhr.responseText || errorMsg;
                }
                showNotification(errorMsg, 'error');
            }
        });
    }
    
    function saveTreeOrder(data) {
        if (isSavingOrder) {
            return;
        }
        
        if (!data || !data.node) {
            console.error('[CatalogTree] saveTreeOrder 失败：data或node无效', data);
            return;
        }
        
        isSavingOrder = true;
        
        var node = data.node;
        var newParent = data.parent;
        var newPosition = typeof data.position === 'number' ? data.position + 1 : 1;
        var oldParent = data.old_parent;
        var oldPosition = data.old_position;
        
        var nodeData = {};
        
        if (node.original && node.original.data) {
            nodeData = node.original.data;
        } else if (node.original) {
            nodeData = node.original;
        } else if (node.data) {
            nodeData = node.data;
        }
        
        if (!nodeData.id && node.id) {
            var fullNode = catalogTree.jstree('get_node', node.id);
            if (fullNode) {
                if (fullNode.original && fullNode.original.data) {
                    nodeData = fullNode.original.data;
                } else if (fullNode.original) {
                    nodeData = fullNode.original;
                } else if (fullNode.data) {
                    nodeData = fullNode.data;
                } else {
                    nodeData = {
                        id: fullNode.node_id || fullNode.id || node.id,
                        name: fullNode.node_name || fullNode.text || '',
                        is_system: fullNode.is_system || 0,
                        is_active: fullNode.is_active || 0
                    };
                }
            } else {
                nodeData = {
                    id: node.node_id || node.id,
                    name: node.node_name || node.text || '',
                    is_system: node.is_system || 0,
                    is_active: node.is_active || 0
                };
            }
        }
        
        if (!nodeData.id) {
            if (node.id) {
                nodeData.id = node.id;
            } else {
                console.warn('[CatalogTree] saveTreeOrder 失败：无法获取节点ID');
                isSavingOrder = false;
                return;
            }
        }
        
        if (!nodeData.name && node.text) {
            nodeData.name = node.text.replace(/<[^>]*>/g, '').trim();
        }
        if (nodeData.is_system === undefined) {
            nodeData.is_system = node.is_system || 0;
        }
        
        var newParentId = 0;
        var newLevel = 1;
        if (newParent !== '#') {
            var parentNode = catalogTree.jstree('get_node', newParent);
            if (parentNode) {
                var parentData = null;
                if (parentNode.original && parentNode.original.data) {
                    parentData = parentNode.original.data;
                } else if (parentNode.original) {
                    parentData = parentNode.original;
                } else if (parentNode.data) {
                    parentData = parentNode.data;
                }
                
                if (parentData && parentData.id) {
                    newParentId = parseInt(parentData.id, 10) || 0;
                    newLevel = (parseInt(parentData.level, 10) || 0) + 1;
                }
            }
        }
        
        var currentNodeId = parseInt(nodeData.id, 10);
        
        if (newParentId > 0 && newParentId == currentNodeId) {
            catalogTree.jstree('move_node', node, oldParent, oldPosition);
            showNotification(i18n.cannotSetSelfAsParent, 'error');
            isSavingOrder = false;
            return;
        }
        
        var isSystem = nodeData.is_system == 1;
        if (isSystem) {
            catalogTree.jstree('move_node', node, oldParent, oldPosition);
            isSavingOrder = false;
            return;
        }
        
        if (isNaN(currentNodeId)) {
            console.error('[CatalogTree] saveTreeOrder 失败：节点ID不是有效数字', nodeData.id);
            isSavingOrder = false;
            return;
        }
        
        var saveData = {
            id: currentNodeId,
            pid: newParentId,
            level: newLevel,
            position: newPosition
        };
        
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/catalog/update-order")',
            method: 'POST',
            data: saveData,
            dataType: 'json',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function(response) {
                isSavingOrder = false;
                
                if (response && response.success) {
                    var selectedNodeId = currentCatalogId;
                    loadCatalogTree();
                    
                    if (selectedNodeId) {
                        setTimeout(function() {
                            if (catalogTree) {
                                catalogTree.jstree('select_node', selectedNodeId.toString());
                                loadCatalogForEdit(selectedNodeId);
                            }
                        }, 500);
                    }
                    
                    showPageMessage(response.msg || i18n.sortSaved, 'success');
                } else {
                    catalogTree.jstree('move_node', node, oldParent, oldPosition);
                    showPageMessage(response.msg || i18n.saveSortFailed, 'error');
                }
            },
            error: function(xhr, status, error) {
                isSavingOrder = false;
                catalogTree.jstree('move_node', node, oldParent, oldPosition);
                var errorMsg = i18n.saveSortFailed;
                try {
                    var response = JSON.parse(xhr.responseText);
                    errorMsg = response.msg || response.message || errorMsg;
                } catch(e) {
                    if (xhr.status === 404) {
                        errorMsg = i18n.saveSortFailed + ' (接口不存在)';
                    } else {
                        errorMsg = xhr.responseText || errorMsg;
                    }
                }
                showPageMessage(errorMsg, 'error');
            }
        });
    }
    
    function showNotification(message, type) {
        if (typeof BackendToast !== 'undefined') {
            BackendToast[type] ? BackendToast[type](message) : BackendToast.info(message);
        } else {
            showPageMessage(message, type);
        }
    }
    
    function showPageMessage(message, type) {
        type = type || 'success';
        var container = $('#ajax-message-container .col-12');
        var alertClass = type === 'success' ? 'success' : type === 'error' ? 'danger' : type === 'warning' ? 'warning' : 'info';
        var iconClass = type === 'success' ? 'mdi-check-circle' : type === 'error' ? 'mdi-alert-circle' : type === 'warning' ? 'mdi-alert' : 'mdi-information';
        
        container.empty();
        
        var messageHtml = '<div class="alert alert-' + alertClass + ' alert-dismissible fade show" role="alert"><i class="mdi ' + iconClass + ' me-2"></i> ' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>';
        
        container.html(messageHtml);
        $('#ajax-message-container').slideDown(300);
        
        setTimeout(function() {
            $('#ajax-message-container').slideUp(300, function() {
                container.empty();
            });
        }, 3000);
    }
    
    function initDragScroll() {
        var catalogTreeContainer = document.getElementById('catalog-tree-container');
        if (!catalogTreeContainer) return;
        
        var isMouseDown = false;
        var isDragging = false;
        var startX = 0;
        var startY = 0;
        var scrollLeft = 0;
        var scrollTop = 0;
        var dragThreshold = 5;
        
        catalogTreeContainer.addEventListener('mousedown', function(e) {
            if (e.button !== 0) return;
            
            if (e.target.tagName === 'A' || e.target.closest('a') || 
                e.target.closest('.jstree-anchor') ||
                e.target.closest('.jstree-node')) {
                if (e.target.classList.contains('jstree-ocl') || 
                    e.target.closest('.jstree-ocl')) {
                    return;
                }
            }
            
            isMouseDown = true;
            isDragging = false;
            startX = e.pageX;
            startY = e.pageY;
            scrollLeft = catalogTreeContainer.scrollLeft;
            scrollTop = catalogTreeContainer.scrollTop;
            e.preventDefault();
        });
        
        document.addEventListener('mousemove', function(e) {
            if (!isMouseDown || !catalogTreeContainer) return;
            
            if (!isDragging) {
                var deltaX = Math.abs(e.pageX - startX);
                var deltaY = Math.abs(e.pageY - startY);
                
                if (deltaX > dragThreshold || deltaY > dragThreshold) {
                    isDragging = true;
                    catalogTreeContainer.classList.add('dragging');
                    var rect = catalogTreeContainer.getBoundingClientRect();
                    startX = e.pageX - rect.left;
                    startY = e.pageY - rect.top;
                    scrollLeft = catalogTreeContainer.scrollLeft;
                    scrollTop = catalogTreeContainer.scrollTop;
                } else {
                    return;
                }
            }
            
            e.preventDefault();
            var rect = catalogTreeContainer.getBoundingClientRect();
            var x = e.pageX - rect.left;
            var y = e.pageY - rect.top;
            var walkX = (x - startX) * 2;
            var walkY = (y - startY) * 2;
            catalogTreeContainer.scrollLeft = scrollLeft - walkX;
            catalogTreeContainer.scrollTop = scrollTop - walkY;
        });
        
        document.addEventListener('mouseup', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
        
        catalogTreeContainer.addEventListener('mouseleave', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(initDragScroll, 500);
        });
    } else {
        setTimeout(initDragScroll, 500);
    }
})();
</script>
