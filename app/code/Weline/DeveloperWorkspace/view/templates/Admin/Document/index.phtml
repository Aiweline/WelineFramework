        'unknown': '<?=__('未知')?>',
        'createTime': '<?=__('创建时间:')?>',
        'updateTime': '<?=__('更新时间:')?>',
        'module': '<?=__('模块:')?>',
        'autoImported': '<?=__('自动导入')?>',
        'noTitle': '<?=__('无标题')?>',
        'noContent': '<?=__('暂无内容')?>'
    };

    var catalogTree = null;
    var currentCategoryId = <?= json_encode($this->getData('selectedCategoryId') ?? '', $jsonForScriptFlags) ?>;
    var documentAdminUrls = {
        list: '<?= $this->getBackendUrl('dev/tool/admin/document/list') ?>',
        view: '<?= $this->getBackendUrl('dev/tool/admin/document/view') ?>',
        edit: '<?= $this->getBackendUrl('dev/tool/admin/document/edit') ?>',
        delete: '<?= $this->getBackendUrl('dev/tool/admin/document/delete') ?>'
    };

    function centerElementInScrollContainer(container, element, behavior) {
        if (!container || !element) {
            return;
        }

        var target = element.querySelector('.jstree-anchor') || element;
        var containerRect = container.getBoundingClientRect();
        var targetRect = target.getBoundingClientRect();
        if (!containerRect.height || !targetRect.height) {
            return;
        }

        var offsetToCenter = (targetRect.top - containerRect.top)
            - (containerRect.height / 2)
            + (targetRect.height / 2);
        var maxScrollTop = Math.max(0, container.scrollHeight - container.clientHeight);
        var nextScrollTop = Math.max(0, Math.min(maxScrollTop, container.scrollTop + offsetToCenter));

        container.scrollTo({
            top: nextScrollTop,
            behavior: behavior || 'smooth'
        });
    }

    function openCatalogAncestors(categoryId) {
        if (!categoryId || !catalogTree || !catalogTree.jstree) {
            return;
        }

        var treeInstance = catalogTree.jstree(true);
        var node = treeInstance.get_node(categoryId.toString());
        if (!node) {
            return;
        }

        (node.parents || [])
            .filter(function(parentId) { return parentId && parentId !== '#'; })
            .reverse()
            .forEach(function(parentId) {
                treeInstance.open_node(parentId);
            });
    }

    function centerCatalogTreeNode(categoryId, behavior) {
        if (!categoryId || !catalogTree || !catalogTree.jstree) {
            return;
        }

        var run = function() {
            var container = document.getElementById('catalog-tree-container');
            var treeInstance = catalogTree.jstree(true);
            var nodeElement = treeInstance.get_node(categoryId.toString(), true);
            centerElementInScrollContainer(
                container,
                nodeElement && nodeElement.length ? nodeElement[0] : null,
                behavior || 'smooth'
            );
        };

        window.requestAnimationFrame(run);
        window.setTimeout(run, 220);
    }
    
    function initCatalogTree() {
        try {
            if (typeof $.fn.jstree === 'undefined') {
                $('#catalog-tree-container').html('<div class="alert alert-danger m-3"><i class="mdi mdi-alert-circle me-2"></i><strong><?=__('错误')?>:</strong> <?=__('jstree库未加载，请刷新页面重试')?></div>');
                return;
            }
            
            var catalogs = <?= json_encode($this->getData('catalogs') ?? [], $jsonForScriptFlags) ?>;
            var treeData = [];
            
            treeData.push({
                id: '',
                text: '<i class="mdi mdi-view-list me-2"></i><?=__('全部文档')?>',
                state: {
                    selected: !currentCategoryId
                },
                icon: false
            });
            
            if (catalogs && Array.isArray(catalogs) && catalogs.length > 0) {
                var catalogTreeData = convertToJSTreeFormat(catalogs);
                treeData = treeData.concat(catalogTreeData);
            }
            
            $('#catalog-tree-container').html('<div id="catalog-tree"></div>');
            
            catalogTree = $('#catalog-tree').jstree({
                'core': {
                    'data': treeData,
                    'themes': {
                        'responsive': true,
                        'variant': 'large',
                        'stripes': false
                    }
                },
                'plugins': []
            }).on('ready.jstree', function() {
                if (currentCategoryId) {
                    openCatalogAncestors(currentCategoryId);
                    catalogTree.jstree('select_node', currentCategoryId.toString());
                    centerCatalogTreeNode(currentCategoryId, 'auto');
                } else {
                    catalogTree.jstree('select_node', '');
                }
            }).on('select_node.jstree', function(e, data) {
                var categoryId = data.node.id;
                centerCatalogTreeNode(categoryId);
                loadDocumentsByCategory(categoryId);
            });
        } catch (error) {
            console.error('[CatalogTree] 初始化分类树时发生错误:', error);
        }
    }
    
    function convertToJSTreeFormat(data, level) {
        level = level || 1;
        var result = [];
        if (!data || !Array.isArray(data)) {
            return result;
        }
        
        data.forEach(function(item) {
            if (!item || !item.id) return;
            var itemLevel = (item.level !== null && item.level !== undefined) ? parseInt(item.level) : level;
            var itemName = (item.name !== null && item.name !== undefined) ? String(item.name) : '<?=__('未命名分类')?>';
            
            var node = {
                id: String(item.id),
                text: '<i class="mdi mdi-folder me-2"></i>' + escapeHtml(itemName),
                state: {
                    opened: itemLevel <= 2
                },
                icon: false
            };
            
            if (item.nodes && Array.isArray(item.nodes) && item.nodes.length > 0) {
                var children = convertToJSTreeFormat(item.nodes, itemLevel + 1);
                if (children && children.length > 0) {
                    node.children = children;
                }
            }
            
            result.push(node);
        });
        
        return result;
    }
    
    function escapeHtml(text) {
        if (text === null || text === undefined) {
            return '';
        }
        var div = document.createElement('div');
        div.textContent = String(text);
        return div.innerHTML;
    }
    
    function loadDocumentsByCategory(categoryId) {
        currentCategoryId = categoryId;
        
        $('#document-list-container').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">' + i18n.loading + '</span></div><p class="mt-2 text-muted">' + i18n.loadingDocument + '</p></div>');
        
        $.ajax({
            url: documentAdminUrls.list,
            method: 'GET',
            data: { category_id: categoryId },
            dataType: 'json',
            success: function(response) {
                if (response.code === 200 && response.data) {
                    renderDocumentList(response.data.items, response.data.pagination);
                } else {
                    $('#document-list-container').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + (response.msg || i18n.loadDocumentFailed) + '</div>');
                }
            },
            error: function() {
                $('#document-list-container').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + i18n.loadDocumentFailedRefresh + '</div>');
            }
        });
    }
    
    function renderDocumentList(items, pagination) {
        if (!items || items.length === 0) {
            $('#document-list-container').html('<div class="empty-state"><i class="mdi mdi-file-document-outline"></i><h5><?=__('暂无文章')?></h5><p class="text-muted"><?=__('该分类下暂无文档')?></p></div>');
            return;
        }
        
        var html = '<div class="row">';
        items.forEach(function(doc) {
            html += '<div class="col-md-4 col-lg-3 mb-3"><div class="document-card h-100"><div class="document-header"><div class="d-flex justify-content-between align-items-start"><div class="flex-grow-1"><h5 class="mb-1" style="font-size: 0.95rem; font-weight: 500; line-height: 1.4;">' + (doc.title || '') + '</h5><div class="d-flex align-items-center gap-1 mt-1 flex-wrap"><span class="badge bg-light text-dark" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;"><i class="mdi mdi-folder-outline me-1" style="font-size: 0.7rem;"></i>' + (doc.c_name || '') + '</span>' + (doc.module_name ? '<span class="badge-module" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;"><i class="mdi mdi-package-variant me-1" style="font-size: 0.7rem;"></i>' + doc.module_name + '</span>' : '') + (doc.is_auto_imported ? '<span class="badge-auto" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;"><i class="mdi mdi-auto-fix me-1" style="font-size: 0.7rem;"></i>' + i18n.autoImported + '</span>' : '') + '</div></div></div></div><div class="document-body"><p class="summary-text mb-2" style="font-size: 0.8rem; line-height: 1.5;">' + (doc.summary || '') + '</p><div class="d-flex justify-content-between align-items-center text-muted" style="font-size: 0.75rem;"><span><i class="mdi mdi-account-outline me-1"></i>' + i18n.author + ' ' + (doc.author || doc.author_id || i18n.unknown) + '</span><span><i class="mdi mdi-clock-outline me-1"></i>' + (doc.update_time || '') + '</span></div></div><div class="document-footer"><div class="action-buttons d-flex justify-content-end"><button type="button" class="btn btn-sm btn-primary view-document-btn" data-id="' + doc.doc_id + '"><i class="mdi mdi-eye me-1"></i><?=__('查看')?></button><a href="' + documentAdminUrls.edit + '?id=' + doc.doc_id + '"><button type="button" class="btn btn-sm btn-info"><i class="mdi mdi-pencil me-1"></i><?=__('编辑')?></button></a>' + (!doc.is_auto_imported ? '<button type="button" class="btn btn-sm btn-danger document-delete-btn" data-url="' + documentAdminUrls.delete + '?id=' + doc.doc_id + '"><i class="mdi mdi-delete me-1"></i><?=__('删除')?></button>' : '') + '</div></div></div></div>';
        });
        html += '</div>';
        
        if (pagination && pagination.html) {
            html += '<div class="mt-4" id="pagination-container">' + pagination.html + '</div>';
        }
        
        $('#document-list-container').html(html);
        bindDeleteButtons();
    }
    
    function bindDeleteButtons() {
        $('.document-delete-btn').off('click').on('click', function(e) {
            var target = $(e.target).closest('.document-delete-btn');
            var isDark = document.body.getAttribute('data-topbar') === 'dark';
            var swalConfig = {
                title: '<?=__('你确定要操作么？')?>',
                text: '<?=__('操作后你将无法恢复！')?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?=__('是的，我确定要删除！')?>',
                cancelButtonText: '<?=__('不要，取消吧！')?>',
                confirmButtonClass: 'btn btn-success mt-2',
                cancelButtonClass: 'btn btn-danger ms-2 mt-2',
                buttonsStyling: false,
                customClass: {
                    popup: isDark ? 'swal2-dark' : '',
                    title: isDark ? 'swal2-title-dark' : '',
                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                    confirmButton: isDark ? 'swal2-confirm-dark' : '',
                    cancelButton: isDark ? 'swal2-cancel-dark' : ''
                }
            };
            Swal.fire(swalConfig).then(function (result) {
                if (result.value) {
                    showLoading();
                    $.post({
                        url: target.attr('data-url')
                    }).done(function(res) {
                        hideLoading();
                        if (200 === res.code) {
                            Swal.fire({
                                title: '<?=__('已删除！')?>',
                                text: '<?=__('文章已经被删除了！')?>',
                                confirmButtonText: '<?=__('好的')?>',
                                icon: 'success',
                                customClass: {
                                    popup: isDark ? 'swal2-dark' : '',
                                    title: isDark ? 'swal2-title-dark' : '',
                                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                                    confirmButton: isDark ? 'swal2-confirm-dark' : ''
                                }
                            }).then(function() {
                                if (currentCategoryId) {
                                    loadDocumentsByCategory(currentCategoryId);
                                } else {
                                    window.location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                title: '<?=__('删除提示！')?>',
                                text: '<?=__('文章删除失败，请重试！')?>',
                                confirmButtonText: '<?=__('好的')?>',
                                icon: 'error',
                                customClass: {
                                    popup: isDark ? 'swal2-dark' : '',
                                    title: isDark ? 'swal2-title-dark' : '',
                                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                                    confirmButton: isDark ? 'swal2-confirm-dark' : ''
                                }
                            });
                        }
                    });
                }
            });
        });
    }
    
    window.initCatalogTree = initCatalogTree;
    
    $(document).ready(function() {
        initCatalogTree();
        bindDeleteButtons();
    });
    
    $(document).on('click', '.view-document-btn', function() {
        var docId = $(this).data('id');
        var offcanvasElement = document.getElementById('documentViewOffcanvas');
        var offcanvas = new bootstrap.Offcanvas(offcanvasElement);
        
        $('#documentViewContent').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">' + i18n.loading + '</span></div><p class="mt-2 text-muted">' + i18n.loadingDocument + '</p></div>');
        
        offcanvas.show();
        
        $.ajax({
            url: documentAdminUrls.view,
            method: 'GET',
            data: { id: docId },
            dataType: 'json',
            success: function(response) {
                if (response.code === 200 && response.data) {
                    var doc = response.data;
                    var html = '<div class="document-meta"><div class="meta-item"><i class="mdi mdi-folder-outline"></i><span><strong>' + i18n.category + '</strong> ' + (doc.category || i18n.uncategorized) + '</span></div><div class="meta-item"><i class="mdi mdi-account-outline"></i><span><strong>' + i18n.author + '</strong> ' + (doc.author || i18n.unknown) + '</span></div><div class="meta-item"><i class="mdi mdi-clock-outline"></i><span><strong>' + i18n.createTime + '</strong> ' + (doc.create_time || '-') + '</span></div><div class="meta-item"><i class="mdi mdi-update"></i><span><strong>' + i18n.updateTime + '</strong> ' + (doc.update_time || '-') + '</span></div>' + (doc.module_name ? '<div class="meta-item"><i class="mdi mdi-package-variant"></i><span><strong>' + i18n.module + '</strong> ' + doc.module_name + '</span></div>' : '') + (doc.is_auto_imported ? '<div class="meta-item"><i class="mdi mdi-auto-fix"></i><span class="badge-auto">' + i18n.autoImported + '</span></div>' : '') + '</div><div class="mb-3"><h4 class="mb-2">' + (doc.title || i18n.noTitle) + '</h4>' + (doc.summary ? '<p class="text-muted">' + doc.summary + '</p>' : '') + '</div><pre class="document-content">' + (doc.content ? escapeHtml(doc.content) : '<span class="text-muted">' + i18n.noContent + '</span>') + '</pre>';
                    $('#documentViewContent').html(html);
                } else {
                    $('#documentViewContent').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + (response.msg || i18n.loadDocumentFailed) + '</div>');
                }
            },
            error: function() {
                $('#documentViewContent').html('<div class="alert alert-danger"><i class="mdi mdi-alert-circle me-2"></i>' + i18n.loadDocumentFailedRefresh + '</div>');
            }
        });
    });
    
    function initDragScroll() {
        var catalogTreeContainer = document.getElementById('catalog-tree-container');
        if (!catalogTreeContainer) return;
        
        var isMouseDown = false;
        var isDragging = false;
        var startX = 0;
        var startY = 0;
        var scrollLeft = 0;
        var scrollTop = 0;
        var dragThreshold = 5;
        
        catalogTreeContainer.addEventListener('mousedown', function(e) {
            if (e.button !== 0) return;
            if (e.target.tagName === 'A' || e.target.closest('a') || e.target.closest('.jstree-anchor') || e.target.closest('.jstree-node')) {
                if (e.target.classList.contains('jstree-ocl') || e.target.closest('.jstree-ocl')) {
                    return;
                }
            }
            isMouseDown = true;
            isDragging = false;
            startX = e.pageX;
            startY = e.pageY;
            scrollLeft = catalogTreeContainer.scrollLeft;
            scrollTop = catalogTreeContainer.scrollTop;
            e.preventDefault();
        });
        
        document.addEventListener('mousemove', function(e) {
            if (!isMouseDown || !catalogTreeContainer) return;
            if (!isDragging) {
                var deltaX = Math.abs(e.pageX - startX);
                var deltaY = Math.abs(e.pageY - startY);
                if (deltaX > dragThreshold || deltaY > dragThreshold) {
                    isDragging = true;
                    catalogTreeContainer.classList.add('dragging');
                    var rect = catalogTreeContainer.getBoundingClientRect();
                    startX = e.pageX - rect.left;
                    startY = e.pageY - rect.top;
                    scrollLeft = catalogTreeContainer.scrollLeft;
                    scrollTop = catalogTreeContainer.scrollTop;
                } else {
                    return;
                }
            }
            e.preventDefault();
            var rect = catalogTreeContainer.getBoundingClientRect();
            var x = e.pageX - rect.left;
            var y = e.pageY - rect.top;
            var walkX = (x - startX) * 2;
            var walkY = (y - startY) * 2;
            catalogTreeContainer.scrollLeft = scrollLeft - walkX;
            catalogTreeContainer.scrollTop = scrollTop - walkY;
        });
        
        document.addEventListener('mouseup', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
        
        catalogTreeContainer.addEventListener('mouseleave', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(initDragScroll, 500);
        });
    } else {
        setTimeout(initDragScroll, 500);
    }
})();
</script>
<script>
(function () {
    if (!/\/en_US(?:\/|$)/.test(window.location.pathname)) {
        return;
    }
    const dict = {
        '开发文档': 'Developer Docs',
        '编写和管理开发文档': 'Write and manage developer documents',
        '视图切换': 'View Switcher',
        '卡片视图': 'Card View',
        '卡片': 'Cards',
        '列表视图': 'List View',
        '列表': 'List',
        '翻译配置': 'Translation Config',
        'API文档': 'API Docs',
        '目录管理': 'Catalog Management',
        '新增文章': 'New Article',
        '文档分类': 'Document Categories',
        '加载中...': 'Loading...',
        '暂无文章': 'No articles',
        '点击"新增文章"按钮开始创建您的第一篇文档': 'Click "New Article" to create your first document',
        '自动导入': 'Auto Imported',
        '作者:': 'Author:',
        '查看': 'View',
        '编辑': 'Edit',
        '删除': 'Delete',
        '文档详情': 'Document Details',
        '全部文档': 'All Documents',
        '该分类下暂无文档': 'No documents in this category'
    };
    function replaceNodeText(node) {
        const text = node.nodeValue;
        const trimmed = text.trim();
        if (!trimmed || !dict[trimmed]) {
            return;
        }
        node.nodeValue = text.replace(trimmed, dict[trimmed]);
    }
    function translate(root) {
        const walker = document.createTreeWalker(root || document.body, NodeFilter.SHOW_TEXT);
        const nodes = [];
        while (walker.nextNode()) {
            nodes.push(walker.currentNode);
        }
        nodes.forEach(replaceNodeText);
        document.querySelectorAll('[title],[aria-label],[placeholder]').forEach(function (el) {
            ['title', 'aria-label', 'placeholder'].forEach(function (attr) {
                const value = el.getAttribute(attr);
                if (value && dict[value.trim()]) {
                    el.setAttribute(attr, dict[value.trim()]);
                }
            });
        });
    }
    translate(document.body);
    new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
            mutation.addedNodes.forEach(function (node) {
                if (node.nodeType === Node.TEXT_NODE) {
                    replaceNodeText(node);
                } else if (node.nodeType === Node.ELEMENT_NODE) {
                    translate(node);
                }
            });
        });
    }).observe(document.body, {childList: true, subtree: true});
})();
</script>
