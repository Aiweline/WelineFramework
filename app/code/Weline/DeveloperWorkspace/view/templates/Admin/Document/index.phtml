<!--按钮-->
<script>
(function() {
    let catalogTree = null;
    let currentCategoryId = <?=json_encode($this->getData('selectedCategoryId') ?? '')?>;
    
    // 初始化分类树
    function initCatalogTree() {
        try {
            console.log('[CatalogTree] 开始初始化分类树...');
            
            // 检查jstree库是否加载
            if (typeof $.fn.jstree === 'undefined') {
                console.error('[CatalogTree] jstree库未加载！');
                $('#catalog-tree-container').html(`
                    <div class="alert alert-danger m-3">
                        <i class="mdi mdi-alert-circle me-2"></i>
                        <strong><?=__('错误')?>:</strong> <?=__('jstree库未加载，请刷新页面重试')?>
                    </div>
                `);
                return;
            }
            
            // 获取分类数据
            const catalogs = <?=json_encode($this->getData('catalogs') ?? [])?>;
            console.log('[CatalogTree] 获取到的分类数据:', catalogs);
            
            // 转换为jstree格式
            let treeData = [];
            
            // 添加"全部"选项
            treeData.push({
                id: '',
                text: '<i class="mdi mdi-view-list me-2"></i><?=__('全部文档')?>',
                state: {
                    selected: !currentCategoryId
                },
                icon: false
            });
            
            // 添加分类树
            if (catalogs && Array.isArray(catalogs) && catalogs.length > 0) {
                console.log('[CatalogTree] 开始转换分类数据格式，共', catalogs.length, '个分类');
                const catalogTreeData = convertToJSTreeFormat(catalogs);
                console.log('[CatalogTree] 转换后的树形数据:', catalogTreeData);
                treeData = treeData.concat(catalogTreeData);
            } else {
                console.warn('[CatalogTree] 没有分类数据或数据为空');
                // 即使没有分类，也显示"全部"选项
            }
            
            // 清空容器并创建jstree容器
            $('#catalog-tree-container').html('<div id="catalog-tree"></div>');
            
            // 如果没有分类数据（只有"全部"选项），显示提示
            if (treeData.length === 1) {
                console.log('[CatalogTree] 只有"全部"选项，没有分类数据');
                // 在树下方显示提示信息
                setTimeout(function() {
                    $('#catalog-tree-container').append(`
                        <div class="alert alert-info m-3 mt-2">
                            <i class="mdi mdi-information me-2"></i>
                            <small><?=__('暂无分类，请先')?> <a href="@admin-url('dev/tool/admin/document/catalog')" class="alert-link"><?=__('创建分类')?></a></small>
                        </div>
                    `);
                }, 500);
            }
            
            // 初始化jstree
            console.log('[CatalogTree] 开始初始化jstree，数据项数:', treeData.length);
            catalogTree = $('#catalog-tree').jstree({
                'core': {
                    'data': treeData,
                    'themes': {
                        'responsive': true,
                        'variant': 'large',
                        'stripes': false
                    }
                },
                'plugins': []
            }).on('ready.jstree', function() {
                console.log('[CatalogTree] jstree初始化完成');
                // 如果有选中的分类，选中它（文档已经在服务器端加载）
                if (currentCategoryId) {
                    try {
                        catalogTree.jstree('select_node', currentCategoryId.toString());
                        console.log('[CatalogTree] 已选中分类:', currentCategoryId);
                    } catch (e) {
                        console.warn('[CatalogTree] 选中分类失败:', e);
                    }
                } else {
                    // 如果没有选中分类，选中"全部"选项（文档已经在服务器端加载）
                    try {
                        catalogTree.jstree('select_node', '');
                        console.log('[CatalogTree] 已选中"全部"选项');
                    } catch (e) {
                        console.warn('[CatalogTree] 选中"全部"选项失败:', e);
                    }
                }
            }).on('select_node.jstree', function(e, data) {
                // 点击分类节点时加载该分类下的文档
                const categoryId = data.node.id;
                console.log('[CatalogTree] 分类节点被选中:', categoryId);
                loadDocumentsByCategory(categoryId);
            }).on('error.jstree', function(e, data) {
                console.error('[CatalogTree] jstree错误事件:', data);
                // 安全地提取错误信息，避免循环引用
                let errorMsg = '';
                try {
                    if (data && typeof data === 'object') {
                        if (data.error) {
                            errorMsg = String(data.error);
                        } else if (data.message) {
                            errorMsg = String(data.message);
                        } else if (data.type) {
                            errorMsg = '错误类型: ' + String(data.type);
                        }
                    } else if (data) {
                        errorMsg = String(data);
                    }
                } catch (err) {
                    errorMsg = '无法解析错误信息';
                }
                $('#catalog-tree-container').html(`
                    <div class="alert alert-danger m-3">
                        <i class="mdi mdi-alert-circle me-2"></i>
                        <strong><?=__('错误')?>:</strong> <?=__('分类树加载失败')?>
                        ${errorMsg ? '<br><small class="text-muted">' + escapeHtml(errorMsg) + '</small>' : ''}
                        <br><button class="btn btn-sm btn-primary mt-2" onclick="initCatalogTree()">
                            <i class="mdi mdi-refresh me-1"></i><?=__('重试')?>
                        </button>
                    </div>
                `);
            });
            
            console.log('[CatalogTree] 分类树初始化完成');
        } catch (error) {
            console.error('[CatalogTree] 初始化分类树时发生错误:', error);
            // 安全地提取错误信息
            let errorMsg = '';
            try {
                if (error && typeof error === 'object') {
                    errorMsg = error.message || error.toString();
                } else if (error) {
                    errorMsg = String(error);
                }
            } catch (err) {
                errorMsg = '未知错误';
            }
            $('#catalog-tree-container').html(`
                <div class="alert alert-danger m-3">
                    <i class="mdi mdi-alert-circle me-2"></i>
                    <strong><?=__('错误')?>:</strong> <?=__('初始化分类树失败')?>
                    ${errorMsg ? '<br><small class="text-muted">' + escapeHtml(errorMsg) + '</small>' : ''}
                    <br><button class="btn btn-sm btn-primary mt-2" onclick="initCatalogTree()">
                        <i class="mdi mdi-refresh me-1"></i><?=__('重试')?>
                    </button>
                    <button class="btn btn-sm btn-secondary mt-2 ms-2" onclick="location.reload()">
                        <i class="mdi mdi-reload me-1"></i><?=__('刷新页面')?>
                    </button>
                </div>
            `);
        }
    }
    
    // 转换为jstree格式
    function convertToJSTreeFormat(data, level = 1) {
        const result = [];
        
        // 数据验证
        if (!data) {
            console.warn('[CatalogTree] convertToJSTreeFormat: 数据为空');
            return result;
        }
        
        if (!Array.isArray(data)) {
            console.warn('[CatalogTree] convertToJSTreeFormat: 数据不是数组类型', typeof data);
            return result;
        }
        
        if (data.length === 0) {
            console.log('[CatalogTree] convertToJSTreeFormat: 数据数组为空');
            return result;
        }
        
        console.log('[CatalogTree] convertToJSTreeFormat: 开始转换，数据项数:', data.length, '层级:', level);
        
        data.forEach(function(item, index) {
            try {
                // 验证item是否为有效对象
                if (!item) {
                    console.warn('[CatalogTree] convertToJSTreeFormat: 第', index, '项数据为空，跳过');
                    return;
                }
                
                // 验证id字段
                if (item.id === null || item.id === undefined || item.id === '') {
                    console.warn('[CatalogTree] convertToJSTreeFormat: 第', index, '项数据缺少id字段，跳过', item);
                    return;
                }
                
                // 获取层级
                const itemLevel = (item.level !== null && item.level !== undefined) ? parseInt(item.level) : level;
                
                // 获取名称，处理null/undefined
                const itemName = (item.name !== null && item.name !== undefined) ? String(item.name) : '<?=__('未命名分类')?>';
                
                // 构建节点
                const node = {
                    id: String(item.id),
                    text: '<i class="mdi mdi-folder me-2"></i>' + escapeHtml(itemName),
                    state: {
                        opened: itemLevel <= 2
                    },
                    icon: false
                };
                
                // 处理子节点
                if (item.nodes && Array.isArray(item.nodes) && item.nodes.length > 0) {
                    console.log('[CatalogTree] convertToJSTreeFormat: 分类', itemName, '有', item.nodes.length, '个子分类');
                    const children = convertToJSTreeFormat(item.nodes, itemLevel + 1);
                    if (children && children.length > 0) {
                        node.children = children;
                    }
                }
                
                result.push(node);
                console.log('[CatalogTree] convertToJSTreeFormat: 成功转换分类', itemName, '(ID:', item.id, ')');
            } catch (error) {
                console.error('[CatalogTree] convertToJSTreeFormat: 转换第', index, '项数据时出错:', error, item);
                // 继续处理下一项，不中断整个转换过程
            }
        });
        
        console.log('[CatalogTree] convertToJSTreeFormat: 转换完成，返回', result.length, '个节点');
        return result;
    }
    
    // HTML转义函数（防止XSS）
    function escapeHtml(text) {
        if (text === null || text === undefined) {
            return '';
        }
        const div = document.createElement('div');
        div.textContent = String(text);
        return div.innerHTML;
    }
    
    // 根据分类加载文档
    function loadDocumentsByCategory(categoryId) {
        currentCategoryId = categoryId;
        
        // 显示加载状态
        $('#document-list-container').html(`
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">${i18n.loading}</span>
                </div>
                <p class="mt-2 text-muted">${i18n.loadingDocument}</p>
            </div>
        `);
        
        // 加载文档列表
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/list")',
            method: 'GET',
            data: { category_id: categoryId },
            dataType: 'json',
            success: function(response) {
                if (response.code === 200 && response.data) {
                    renderDocumentList(response.data.items, response.data.pagination);
                } else {
                    $('#document-list-container').html(`
                        <div class="alert alert-danger">
                            <i class="mdi mdi-alert-circle me-2"></i>
                            ${response.msg || i18n.loadDocumentFailed}
                        </div>
                    `);
                }
            },
            error: function(xhr) {
                $('#document-list-container').html(`
                    <div class="alert alert-danger">
                        <i class="mdi mdi-alert-circle me-2"></i>
                        ${i18n.loadDocumentFailedRefresh}
                    </div>
                `);
            }
        });
    }
    
    // 渲染文档列表
    function renderDocumentList(items, pagination) {
        if (!items || items.length === 0) {
            $('#document-list-container').html(`
                <div class="empty-state">
                    <i class="mdi mdi-file-document-outline"></i>
                    <h5><?=__('暂无文章')?></h5>
                    <p class="text-muted"><?=__('该分类下暂无文档')?></p>
                </div>
            `);
            return;
        }
        
        let html = '<div class="row">';
        items.forEach(function(doc) {
            html += `
                <div class="col-md-4 col-lg-3 mb-3">
                    <div class="document-card h-100">
                        <div class="document-header">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="mb-1" style="font-size: 0.95rem; font-weight: 500; line-height: 1.4;">
                                        ${doc.title || ''}
                                    </h5>
                                    <div class="d-flex align-items-center gap-1 mt-1 flex-wrap">
                                        <span class="badge bg-light text-dark" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;">
                                            <i class="mdi mdi-folder-outline me-1" style="font-size: 0.7rem;"></i>
                                            ${doc.c_name || ''}
                                        </span>
                                        ${doc.module_name ? `
                                        <span class="badge-module" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;">
                                            <i class="mdi mdi-package-variant me-1" style="font-size: 0.7rem;"></i>
                                            ${doc.module_name}
                                        </span>
                                        ` : ''}
                                        ${doc.is_auto_imported ? `
                                        <span class="badge-auto" style="font-size: 0.7rem; padding: 0.2rem 0.4rem;">
                                            <i class="mdi mdi-auto-fix me-1" style="font-size: 0.7rem;"></i>
                                            ${i18n.autoImported}
                                        </span>
                                        ` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="document-body">
                            <p class="summary-text mb-2" style="font-size: 0.8rem; line-height: 1.5;">
                                ${doc.summary || ''}
                            </p>
                            <div class="d-flex justify-content-between align-items-center text-muted" style="font-size: 0.75rem;">
                                <span>
                                    <i class="mdi mdi-account-outline me-1"></i>
                                    ${i18n.author} ${doc.author || doc.author_id || i18n.unknown}
                                </span>
                                <span>
                                    <i class="mdi mdi-clock-outline me-1"></i>
                                    ${doc.update_time || ''}
                                </span>
                            </div>
                        </div>
                        <div class="document-footer">
                            <div class="action-buttons d-flex justify-content-end">
                                <button type="button" 
                                        class="btn btn-sm btn-primary view-document-btn" 
                                        data-id="${doc.doc_id}">
                                    <i class="mdi mdi-eye me-1"></i>
                                    <?=__('查看')?>
                                </button>
                                <a href="@admin-url('dev/tool/admin/document/edit')?id=${doc.doc_id}">
                                    <button type="button" class="btn btn-sm btn-info">
                                        <i class="mdi mdi-pencil me-1"></i>
                                        <?=__('编辑')?>
                                    </button>
                                </a>
                                ${!doc.is_auto_imported ? `
                                <button type="button" 
                                        class="btn btn-sm btn-danger document-delete-btn" 
                                        data-url="@admin-url('dev/tool/admin/document/delete')?id=${doc.doc_id}">
                                    <i class="mdi mdi-delete me-1"></i>
                                    <?=__('删除')?>
                                </button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                </div>
            `;
        });
        html += '</div>';
        
        // 添加分页
        if (pagination && pagination.html) {
            html += `<div class="mt-4" id="pagination-container">${pagination.html}</div>`;
        }
        
        $('#document-list-container').html(html);
        
        // 重新绑定删除按钮事件
        bindDeleteButtons();
    }
    
    // 绑定删除按钮事件
    function bindDeleteButtons() {
        $('.document-delete-btn').off('click').on('click', function(e) {
            let target = $(e.target).closest('.document-delete-btn');
            // 检测当前主题
            const isDark = document.body.getAttribute('data-topbar') === 'dark';
            const swalConfig = {
                title: '@lang("你确定要操作么？")',
                text: '@lang("操作后你将无法恢复！")',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '@lang("是的，我确定要删除！")',
                cancelButtonText: '@lang("不要，取消吧！")',
                confirmButtonClass: 'btn btn-success mt-2',
                cancelButtonClass: 'btn btn-danger ms-2 mt-2',
                buttonsStyling: false,
                customClass: {
                    popup: isDark ? 'swal2-dark' : '',
                    title: isDark ? 'swal2-title-dark' : '',
                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                    confirmButton: isDark ? 'swal2-confirm-dark' : '',
                    cancelButton: isDark ? 'swal2-cancel-dark' : ''
                }
            };
            Swal.fire(swalConfig).then(function (result) {
                if (result.value) {
                    showLoading();
                    $.post({
                        url: target.attr('data-url')
                    }).done(res => {
                        hideLoading();
                        if (200 === res.code) {
                            Swal.fire({
                                title: '@lang("已删除！")',
                                text: '@lang("文章已经被删除了！")',
                                confirmButtonText: '@lang("好的")',
                                icon: 'success',
                                customClass: {
                                    popup: isDark ? 'swal2-dark' : '',
                                    title: isDark ? 'swal2-title-dark' : '',
                                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                                    confirmButton: isDark ? 'swal2-confirm-dark' : ''
                                }
                            }).then(res => {
                                if (res.value) {
                                    // 重新加载当前分类的文档
                                    if (currentCategoryId) {
                                        loadDocumentsByCategory(currentCategoryId);
                                    } else {
                                        window.location.reload();
                                    }
                                }
                            })
                        } else {
                            Swal.fire({
                                title: '@lang("删除提示！")',
                                text: '@lang("文章删除失败，请重试！")',
                                confirmButtonText: '@lang("好的")',
                                icon: 'error',
                                customClass: {
                                    popup: isDark ? 'swal2-dark' : '',
                                    title: isDark ? 'swal2-title-dark' : '',
                                    htmlContainer: isDark ? 'swal2-html-dark' : '',
                                    confirmButton: isDark ? 'swal2-confirm-dark' : ''
                                }
                            })
                        }
                    })
                }
            });
        });
    }
    
    // 将initCatalogTree暴露到全局作用域，以便重试按钮可以调用
    window.initCatalogTree = initCatalogTree;
    
    // 页面加载完成后初始化
    $(document).ready(function() {
        initCatalogTree();
        bindDeleteButtons();
    });
    
    // 查看文档
    $(document).on('click', '.view-document-btn', function() {
        const docId = $(this).data('id');
        const offcanvasElement = document.getElementById('documentViewOffcanvas');
        const offcanvas = new bootstrap.Offcanvas(offcanvasElement);
        
        // 显示加载状态
        $('#documentViewContent').html(`
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">${i18n.loading}</span>
                </div>
                <p class="mt-2 text-muted">${i18n.loadingDocument}</p>
            </div>
        `);
        
        // 打开offcanvas
        offcanvas.show();
        
        // 加载文档数据
        $.ajax({
            url: '@admin-url("dev/tool/admin/document/view")',
            method: 'GET',
            data: { id: docId },
            dataType: 'json',
            success: function(response) {
                if (response.code === 200 && response.data) {
                    const doc = response.data;
                    let html = `
                        <div class="document-meta">
                            <div class="meta-item">
                                <i class="mdi mdi-folder-outline"></i>
                                <span><strong>${i18n.category}</strong> ${doc.category || i18n.uncategorized}</span>
                            </div>
                            <div class="meta-item">
                                <i class="mdi mdi-account-outline"></i>
                                <span><strong>${i18n.author}</strong> ${doc.author || i18n.unknown}</span>
                            </div>
                            <div class="meta-item">
                                <i class="mdi mdi-clock-outline"></i>
                                <span><strong>${i18n.createTime}</strong> ${doc.create_time || '-'}</span>
                            </div>
                            <div class="meta-item">
                                <i class="mdi mdi-update"></i>
                                <span><strong>${i18n.updateTime}</strong> ${doc.update_time || '-'}</span>
                            </div>
                            ${doc.module_name ? `
                            <div class="meta-item">
                                <i class="mdi mdi-package-variant"></i>
                                <span><strong>${i18n.module}</strong> ${doc.module_name}</span>
                            </div>
                            ` : ''}
                            ${doc.is_auto_imported ? `
                            <div class="meta-item">
                                <i class="mdi mdi-auto-fix"></i>
                                <span class="badge-auto">${i18n.autoImported}</span>
                            </div>
                            ` : ''}
                        </div>
                        <div class="mb-3">
                            <h4 class="mb-2">${doc.title || i18n.noTitle}</h4>
                            ${doc.summary ? `<p class="text-muted">${doc.summary}</p>` : ''}
                        </div>
                        <pre class="document-content">${doc.content ? escapeHtml(doc.content) : '<span class="text-muted">' + i18n.noContent + '</span>'}</pre>
                    `;
                    $('#documentViewContent').html(html);
                } else {
                    $('#documentViewContent').html(`
                        <div class="alert alert-danger">
                            <i class="mdi mdi-alert-circle me-2"></i>
                            ${response.msg || i18n.loadDocumentFailed}
                        </div>
                    `);
                }
            },
            error: function(xhr) {
                $('#documentViewContent').html(`
                    <div class="alert alert-danger">
                        <i class="mdi mdi-alert-circle me-2"></i>
                        ${i18n.loadDocumentFailedRefresh}
                    </div>
                `);
            }
        });
    });
    
    // 添加拖拽滚动功能
    function initDragScroll() {
        const catalogTreeContainer = document.getElementById('catalog-tree-container');
        if (!catalogTreeContainer) return;
        
        let isMouseDown = false;
        let isDragging = false;
        let startX = 0;
        let startY = 0;
        let scrollLeft = 0;
        let scrollTop = 0;
        let dragThreshold = 5; // 拖拽阈值，超过这个距离才认为是拖拽
        
        catalogTreeContainer.addEventListener('mousedown', function(e) {
            // 只响应鼠标左键
            if (e.button !== 0) return;
            
            // 如果点击的是可交互元素（如链接、按钮、jstree节点），不启用拖拽
            if (e.target.tagName === 'A' || e.target.closest('a') || 
                e.target.closest('.jstree-anchor') ||
                e.target.closest('.jstree-node')) {
                // 检查是否点击的是jstree的展开/收起按钮
                if (e.target.classList.contains('jstree-ocl') || 
                    e.target.closest('.jstree-ocl')) {
                    return;
                }
            }
            
            isMouseDown = true;
            isDragging = false;
            startX = e.pageX;
            startY = e.pageY;
            scrollLeft = catalogTreeContainer.scrollLeft;
            scrollTop = catalogTreeContainer.scrollTop;
            e.preventDefault(); // 防止文本选择
        });
        
        document.addEventListener('mousemove', function(e) {
            if (!isMouseDown || !catalogTreeContainer) return;
            
            // 如果还没有开始拖拽，检查是否超过阈值
            if (!isDragging) {
                const deltaX = Math.abs(e.pageX - startX);
                const deltaY = Math.abs(e.pageY - startY);
                
                // 如果移动距离超过阈值，开始拖拽
                if (deltaX > dragThreshold || deltaY > dragThreshold) {
                    isDragging = true;
                    catalogTreeContainer.classList.add('dragging');
                    // 重新计算起始位置（相对于容器）
                    const rect = catalogTreeContainer.getBoundingClientRect();
                    startX = e.pageX - rect.left;
                    startY = e.pageY - rect.top;
                    scrollLeft = catalogTreeContainer.scrollLeft;
                    scrollTop = catalogTreeContainer.scrollTop;
                } else {
                    return; // 还没超过阈值，不处理
                }
            }
            
            // 执行拖拽滚动
            e.preventDefault();
            const rect = catalogTreeContainer.getBoundingClientRect();
            const x = e.pageX - rect.left;
            const y = e.pageY - rect.top;
            const walkX = (x - startX) * 2; // 滚动速度倍数
            const walkY = (y - startY) * 2;
            catalogTreeContainer.scrollLeft = scrollLeft - walkX;
            catalogTreeContainer.scrollTop = scrollTop - walkY;
        });
        
        document.addEventListener('mouseup', function(e) {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
        
        // 鼠标离开容器时也停止拖拽
        catalogTreeContainer.addEventListener('mouseleave', function() {
            if (isMouseDown) {
                isMouseDown = false;
                if (isDragging) {
                    isDragging = false;
                    catalogTreeContainer.classList.remove('dragging');
                }
            }
        });
    }
    
    // 等待DOM加载完成后初始化拖拽滚动
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(initDragScroll, 500);
        });
    } else {
        setTimeout(initDragScroll, 500);
    }
})();
</script>
