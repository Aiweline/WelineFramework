<div class='col-12'>
    <div class='card'>
        <div class='card-body'>
            <a href="@url('/dev/tool/')" class='btn btn-dark'>
                <lang>返回欢迎页</lang>
            </a>
            <button type='button' class='btn btn-info' data-dev-workspace-action='history-back'
                    data-dev-workspace-fallback="@url('/dev/tool/')">
                <lang>返回上一页</lang>
            </button>
        </div>
    </div>
</div>
<script>
(function() {
    'use strict';

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-dev-workspace-action="history-back"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();

        if (window.history.length > 1) {
            window.history.back();
            return;
        }

        var fallbackUrl = trigger.getAttribute('data-dev-workspace-fallback');
        if (fallbackUrl) {
            window.location.href = fallbackUrl;
        }
    });
})();
</script>
