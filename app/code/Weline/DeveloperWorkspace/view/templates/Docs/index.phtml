    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        // 应用状态
        const app = {
            modules: [],
            documents: [],
            currentModule: 'all',
            searchKeyword: '',
            theme: localStorage.getItem('theme') || 'light'
        };
        
        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            initTheme();
            loadModules();
            <?php if (!$document): ?>
            loadDocuments();
            <?php else: ?>
            renderMarkdown();
            <?php endif; ?>
            bindEvents();
        });
        
        // 初始化主题
        function initTheme() {
            document.body.setAttribute('data-theme', app.theme);
            updateThemeIcon();
        }
        
        // 更新主题图标
        function updateThemeIcon() {
            const icon = document.querySelector('#themeToggle i');
            icon.className = app.theme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
        }
        
        // 切换主题
        function toggleTheme() {
            app.theme = app.theme === 'light' ? 'dark' : 'light';
            document.body.setAttribute('data-theme', app.theme);
            localStorage.setItem('theme', app.theme);
            updateThemeIcon();
        }
        
        // 加载模块列表
        async function loadModules() {
            try {
                const response = await fetch('/api/dev/document/modules');
                const result = await response.json();
                
                if (result.code === 0) {
                    app.modules = result.data;
                    renderModuleSelect();
                }
            } catch (error) {
                console.error('加载模块列表失败:', error);
            }
        }
        
        // 渲染模块选择器
        function renderModuleSelect() {
            const select = document.getElementById('moduleFilter');
            select.innerHTML = '<option value="all">所有模块</option>';
            
            app.modules.forEach(module => {
                const option = document.createElement('option');
                option.value = module.name;
                option.textContent = `${module.display_name} (${module.doc_count})`;
                select.appendChild(option);
            });
        }
        
        // 加载文档列表
        async function loadDocuments() {
            const container = document.getElementById('searchResults');
            container.innerHTML = '<div class="loading"><div class="loading-spinner"></div></div>';
            
            try {
                const params = new URLSearchParams({
                    keyword: app.searchKeyword,
                    module: app.currentModule,
                    page: 1,
                    size: 50
                });
                
                const response = await fetch(`/api/dev/document/search?${params}`);
                const result = await response.json();
                
                if (result.code === 0) {
                    app.documents = result.data.items;
                    renderDocuments();
                } else {
                    container.innerHTML = `<div class="empty-state">
                        <div class="empty-state-icon"><i class="fas fa-exclamation-circle"></i></div>
                        <h3 class="empty-state-title">加载失败</h3>
                        <p class="empty-state-text">${result.msg}</p>
                    </div>`;
                }
            } catch (error) {
                console.error('加载文档失败:', error);
                container.innerHTML = `<div class="empty-state">
                    <div class="empty-state-icon"><i class="fas fa-exclamation-circle"></i></div>
                    <h3 class="empty-state-title">加载失败</h3>
                    <p class="empty-state-text">请检查网络连接后重试</p>
                </div>`;
            }
        }
        
        // 渲染文档列表
        function renderDocuments() {
            const container = document.getElementById('searchResults');
            
            if (app.documents.length === 0) {
                container.innerHTML = `<div class="empty-state">
                    <div class="empty-state-icon"><i class="fas fa-search"></i></div>
                    <h3 class="empty-state-title">未找到文档</h3>
                    <p class="empty-state-text">尝试使用其他关键词或选择不同的模块</p>
                </div>`;
                return;
            }
            
            const html = '<div class="search-results">' + app.documents.map(doc => `
                <div class="doc-card" onclick="openDocument(${doc.id})">
                    <div class="doc-card-header">
                        <div>
                            <h3 class="doc-card-title">${escapeHtml(doc.title)}</h3>
                            <span class="doc-card-module">${escapeHtml(doc.module_display)}</span>
                        </div>
                    </div>
                    <p class="doc-card-summary">${escapeHtml(doc.summary)}</p>
                    <div class="doc-card-footer">
                        ${doc.file_name ? `<span><i class="fas fa-file"></i> ${escapeHtml(doc.file_name)}</span>` : ''}
                        ${doc.is_auto_imported ? '<span><i class="fas fa-robot"></i> 自动导入</span>' : ''}
                    </div>
                </div>
            `).join('') + '</div>';
            
            container.innerHTML = html;
        }
        
        // 打开文档
        function openDocument(id) {
            window.location.href = '/dev/docs?id=' + id;
        }
        
        // 渲染Markdown
        function renderMarkdown() {
            const content = document.getElementById('documentContent');
            if (content && typeof marked !== 'undefined') {
                const rawContent = content.textContent;
                content.innerHTML = marked.parse(rawContent);
            }
        }
        
        // 绑定事件
        function bindEvents() {
            // 搜索输入
            let searchTimeout;
            document.getElementById('searchInput')?.addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    app.searchKeyword = e.target.value;
                    <?php if (!$document): ?>
                    loadDocuments();
                    <?php endif; ?>
                }, 300);
            });
            
            // 模块过滤
            document.getElementById('moduleFilter')?.addEventListener('change', function(e) {
                app.currentModule = e.target.value;
                <?php if (!$document): ?>
                loadDocuments();
                <?php endif; ?>
            });
            
            // 主题切换
            document.getElementById('themeToggle')?.addEventListener('click', toggleTheme);
        }
        
        // HTML转义
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
