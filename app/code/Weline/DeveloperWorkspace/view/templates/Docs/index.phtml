
<?php
/**@var \Weline\Framework\View\Template $this */
$document = $this->getData('document');
$documents = $this->getData('documents') ?? [];
$documentId = $this->request->getParam('id');
$catalogId = $this->request->getParam('catalog_id');
if ($document && $document->getId()) {
    $catalogId = $document->getCategoryId();
}

$documentThemeAttributes = '';
$documentHtmlDirection = '';
$documentThemeCssUrl = '';
try {
    /** @var \Weline\Backend\Block\ThemeConfig $documentThemeConfig */
    $documentThemeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);
    $documentThemeAttributes = trim((string)($documentThemeConfig->getLayouts() ?? ''));
    $documentHtmlDirection = ('rtl' === $documentThemeConfig->getThemeModel()) ? ' dir="rtl"' : '';

    $documentThemeData = $this->getData('theme') ?? [];
    $documentTheme = $documentThemeData['theme'] ?? null;
    $documentThemeArea = (string)($documentThemeData['area'] ?? 'backend');
    $documentThemeLayoutType = (string)($documentThemeData['layoutType'] ?? 'blank');
    $documentThemeLayoutOption = (string)($documentThemeData['layoutOption'] ?? 'full');
    if ($documentTheme && method_exists($documentTheme, 'getId') && $documentTheme->getId()) {
        /** @var \Weline\Theme\Helper\LayoutAssetsManager $documentThemeAssetsManager */
        $documentThemeAssetsManager = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Helper\LayoutAssetsManager::class);
        $documentThemeAssetsManager->ensureLayoutCssGenerated($documentThemeArea, $documentThemeLayoutType, $documentThemeLayoutOption, $documentTheme);
        $documentThemeCssUrl = (string)$documentThemeAssetsManager->getCssUrl($documentThemeArea, $documentThemeLayoutType, $documentThemeLayoutOption, $documentTheme, $this);
    }
} catch (\Throwable) {
    $documentThemeAttributes = '';
    $documentHtmlDirection = '';
    $documentThemeCssUrl = '';
}
