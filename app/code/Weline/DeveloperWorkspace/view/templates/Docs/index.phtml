                                if (typeof marked !== 'undefined') {
                                    try {
                                        marked.setOptions({
                                            breaks: true,
                                            gfm: true,
                                            headerIds: true,
                                            mangle: false
                                        });
                                        const rawContent = docBody.textContent || docBody.innerText || '';
                                        if (rawContent.trim()) {
                                            docBody.innerHTML = marked.parse(rawContent);
                                            // Markdown 渲染完成后，生成目录并定位锚点
                                            setTimeout(() => {
                                                if (typeof generateDocumentToc === 'function') {
                                                    generateDocumentToc();
                                                }
                                                if (typeof scrollToAnchor === 'function') {
                                                    scrollToAnchor();
                                                }
                                            }, 100);
