    <script>
        (function() {
            // 语言和货币切换相关常量
            const DOC_LOCALE_KEY = 'doc_locale';
            const DOC_CURRENCY_KEY = 'doc_currency';
            const DOC_SUPPORTED_LOCALES = <?= json_encode($documentLocaleCodes ?? [], JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
            const DOC_DEFAULT_LOCALE = <?= json_encode((string)($currentLanguage ?? 'zh_Hans_CN'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
            const DOC_SELECTOR_DEFAULT_LOCALE = <?= json_encode((string)($documentSelectorLocale ?? 'zh_Hans_CN'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

            function normalizeDocLocale(locale) {
                locale = String(locale || '').trim();
                return locale || DOC_DEFAULT_LOCALE;
            }

            function normalizeSelectableDocLocale(locale) {
                locale = normalizeDocLocale(locale);
                if (!DOC_SUPPORTED_LOCALES.length || DOC_SUPPORTED_LOCALES.indexOf(locale) !== -1) {
                    return locale;
                }
                return DOC_SELECTOR_DEFAULT_LOCALE;
            }
            
            // 获取当前语言和货币（从URL、localStorage或默认值）
            function getDocCurrentLocale() {
                const urlParams = new URLSearchParams(window.location.search);
                const pathParts = window.location.pathname.split('/').filter(p => p);
                // 尝试从路径中提取locale（格式：zh_Hans_CN）
                for (let i = 0; i < pathParts.length; i++) {
                    if (pathParts[i].match(/^[a-z]{2}_[A-Z]{2}$/) || pathParts[i].match(/^[a-z]{2}_[A-Z][a-z]+_[A-Z]{2}$/)) {
                        return normalizeDocLocale(pathParts[i]);
                    }
                }
                // 尝试从URL参数获取
                if (urlParams.has('locale')) {
                    return normalizeDocLocale(urlParams.get('locale'));
                }
                // 从localStorage获取
                return normalizeDocLocale(localStorage.getItem(DOC_LOCALE_KEY) || DOC_DEFAULT_LOCALE);
            }
            
            function getDocCurrentCurrency() {
                const urlParams = new URLSearchParams(window.location.search);
                const pathParts = window.location.pathname.split('/').filter(p => p);
                // 尝试从路径中提取currency（格式：CNY，3位大写字母）
                for (let i = 0; i < pathParts.length; i++) {
                    if (pathParts[i].match(/^[A-Z]{3}$/)) {
                        return pathParts[i];
                    }
                }
                // 尝试从URL参数获取
                if (urlParams.has('currency')) {
                    return urlParams.get('currency');
                }
                // 从localStorage获取
                return localStorage.getItem(DOC_CURRENCY_KEY) || '<?= htmlspecialchars($currentCurrency ?? 'CNY') ?>';
            }
            
            // 初始化语言和货币
            let docCurrentLocale = getDocCurrentLocale();
            let docCurrentCurrency = getDocCurrentCurrency();

            function appendDocLocale(url) {
                const separator = url.indexOf('?') === -1 ? '?' : '&';
                return url + separator + 'locale=' + encodeURIComponent(docCurrentLocale);
            }
            
            // 设置语言和货币选择器的值
            document.addEventListener('DOMContentLoaded', function() {
                const localeSelect = document.getElementById('doc-locale-select');
                const currencySelect = document.getElementById('doc-currency-select');
                if (localeSelect && localeSelect.tagName === 'SELECT') {
                    localeSelect.value = docCurrentLocale;
                }
                if (currencySelect) {
                    currencySelect.value = docCurrentCurrency;
                }
            });
            
            // 切换语言
            window.switchDocLocale = function(locale) {
                locale = normalizeSelectableDocLocale(locale);
                docCurrentLocale = locale;
                localStorage.setItem(DOC_LOCALE_KEY, locale);
                
                // 更新页面URL（路径切换模式）
                updateDocPageUrl();
            };

            window.switchDocLocaleFromSelect = function(detail) {
                const locale = detail && (detail.value || (detail.values && detail.values[0]));
                if (locale) {
                    window.switchDocLocale(locale);
                }
            };
            
            // 切换货币
            window.switchDocCurrency = function(currency) {
                docCurrentCurrency = currency;
                localStorage.setItem(DOC_CURRENCY_KEY, currency);
                
                // 更新页面URL（路径切换模式）
                updateDocPageUrl();
            };
            
            // 更新页面URL（路径切换模式，不刷新页面）
            function updateDocPageUrl() {
                const currentPath = window.location.pathname;
                const pathParts = currentPath.split('/').filter(p => p);
                
                // 移除旧的locale和currency（支持多种格式）
                // 使用与 API 文档相同的清理逻辑，确保一致性
                const cleanedParts = pathParts.filter(p => {
                    // 匹配currency格式：3位大写字母（如 USD, CNY, EUR）
                    if (p.match(/^[A-Z]{3}$/)) {
                        return false;
                    }
                    // 匹配locale格式：
                    // - zh_Hans_CN (三部分：语言_脚本_国家)
                    // - en_US (两部分：语言_国家)
                    // - en_US_XX (三部分，但第三部分可能是其他格式)
                    // 修复：支持 en_US 格式（两个大写字母）
                    if (p.match(/^[a-z]{2}_[A-Z]{2}$/) || // en_US 格式
                        p.match(/^[a-z]{2}_[A-Z][a-z]+(_[A-Z]{2})?$/)) { // zh_Hans_CN 格式
                        return false;
                    }
                    return true;
                });
                
                // 添加新的currency和locale
                const newPath = '/' + docCurrentCurrency + '/' + docCurrentLocale + '/' + cleanedParts.join('/');
                const newUrl = window.location.origin + newPath + window.location.search;
                
                // 更新URL并刷新页面
                window.location.href = newUrl;
            }
            
            // 更新开发文档的i18n信息提示条
            function updateDocI18nInfoBar() {
                const infoBar = document.querySelector('.i18n-info-bar');
                if (!infoBar) return;
                
                // 更新当前货币显示
                const currencyValue = infoBar.querySelector('.i18n-info-item:nth-child(1) .i18n-info-value');
                if (currencyValue) {
                    currencyValue.textContent = docCurrentCurrency;
                }
                
                // 更新当前语言显示
                const languageValue = infoBar.querySelector('.i18n-info-item:nth-child(2) .i18n-info-value');
                if (languageValue) {
                    languageValue.textContent = docCurrentLocale;
                }
            }
            
            let currentCatalogId = <?= $catalogId ? (int)$catalogId : 'null' ?>;
            let currentDocumentId = <?= $documentId ? (int)$documentId : 'null' ?>;
            const hasInitialDocument = <?= ($document && $document->getId()) ? 'true' : 'false' ?>;
            let catalogTree = null;
            
            // 获取基础URL
            function getBaseUrl() {
                const path = window.location.pathname;
                const parts = path.split('/').filter(p => p);
                // 找到 dev/tool 的位置
                const devToolIndex = parts.findIndex(p => p === 'dev');
                if (devToolIndex >= 0 && parts[devToolIndex + 1] === 'tool') {
                    return '/' + parts.slice(0, devToolIndex + 2).join('/');
                }
                return '/dev/tool';
            }
            
            const baseUrl = getBaseUrl();
            
            // 检查jQuery和jstree是否加载
            function checkDependencies() {
                if (typeof jQuery === 'undefined' || typeof jQuery.fn.jstree === 'undefined') {
                    console.error('jQuery 或 jstree 未加载');
                    document.getElementById('catalog-tree').innerHTML = 
                        '<div class="empty-state"><div class="empty-state-text">加载失败：缺少必要的库文件，请刷新重试</div></div>';
                    return false;
                }
                return true;
            }
            
            // 转换为jstree格式（直接使用数据中的level字段，不进行递增计算）
            function convertToJSTreeFormat(data) {
                const result = [];
                if (!data || !Array.isArray(data)) {
                    return result;
                }
                
                data.forEach(function(item) {
                    if (!item || !item.id) {
                        return;
                    }
                    
                    // 跳过未激活的分类
                    if (item.is_active != 1) {
                        return;
                    }
                    
                    // 直接使用数据中的level字段（数据已经是正确的层级值）
                    const itemLevel = (item.level !== null && item.level !== undefined) ? parseInt(item.level) || 1 : 1;
                    
                    const node = {
                        id: item.id.toString(),
                        text: escapeHtml(item.name || ''),
                        data: {
                            id: item.id,
                            name: item.name || '',
                            level: itemLevel
                        },
                        state: {
                            // 只展开一二级（level <= 2）
                            opened: itemLevel <= 2
                        },
                        icon: false
                    };
                    
                    // 递归处理子节点，子节点的level值已经在数据中了，不需要传递level参数
                    if (item.nodes && Array.isArray(item.nodes) && item.nodes.length > 0) {
                        node.children = convertToJSTreeFormat(item.nodes);
                    }
                    
                    result.push(node);
                });
                return result;
            }
            
            // 加载分类树
            function loadCatalogTree() {
                if (!checkDependencies()) {
                    return;
                }
                
                fetch(appendDocLocale(baseUrl + '/docs/tree'))
                    .then(response => response.json())
                    .then(data => {
                        if (data.error) {
                            $('#catalog-tree').html('<div class="empty-state"><div class="empty-state-text">' + escapeHtml(data.error) + '</div></div>');
                            return;
                        }
                        
                        // 转换为jstree格式
                        const treeData = convertToJSTreeFormat(data);
                        
                        // 初始化jstree
                        catalogTree = $('#catalog-tree').jstree({
                            'core': {
                                'data': treeData,
                                'themes': {
                                    'responsive': true,
                                    'variant': 'large',
                                    'stripes': false,
                                    'dots': false
                                },
                                'animation': 200
                            },
                            'plugins': []
                        }).on('ready.jstree', function() {
                            // jstree初始化完成
                            // 检查 URL 是否有 search 参数
                            const urlParams = new URLSearchParams(window.location.search);
                            const searchKeyword = urlParams.get('search');
                            if (searchKeyword) {
                                // 设置搜索框的值
                                const searchInput = document.getElementById('search-input');
                                if (searchInput) {
                                    searchInput.value = searchKeyword;
                                }
                                // 执行搜索
                                searchDocuments(searchKeyword);
                            } else if (currentDocumentId) {
                                if (hasInitialDocument && currentCatalogId) {
                                    selectCatalog(currentCatalogId, true, false);
                                    setTimeout(() => {
                                        scrollToAnchor();
                                    }, 200);
                                } else {
                                    loadDocument(currentDocumentId);
                                }
                            } else if (currentCatalogId) {
                                // 如果有当前分类ID，自动选中
                                selectCatalog(currentCatalogId);
                            }
                        }).on('select_node.jstree', function(e, data) {
                            // 节点被选中（用户点击或程序化选中）
                            // 如果是程序化选中且不需要加载文档，跳过
                            if (isProgrammaticSelect) {
                                return;
                            }
                            const nodeId = parseInt(data.node.id);
                            
                            // 如果点击的是当前已选中的分类
                            if (currentCatalogId === nodeId) {
                                // 如果当前正在查看文档详情，返回文档列表页
                                if (currentDocumentId) {
                                    backToDocumentList();
                                    return;
                                }
                                // 如果已经在列表页，刷新列表（重新加载文档列表）
                                loadDocuments(nodeId);
                                return;
                            }
                            
                            selectCatalog(nodeId);
                        }).on('open_node.jstree', function(e, data) {
                            // 节点展开 - jstree原生事件
                            // 这里可以添加展开后的逻辑
                        }).on('close_node.jstree', function(e, data) {
                            // 节点收起 - jstree原生事件
                            // 这里可以添加收起后的逻辑
                        });
                    })
                    .catch(error => {
                        console.error('加载分类树失败:', error);
                        $('#catalog-tree').html('<div class="empty-state"><div class="empty-state-text">加载失败，请刷新重试</div></div>');
                    });
            }
            
            // 标记是否正在程序化选中节点（避免触发事件处理中的加载）
            let isProgrammaticSelect = false;

            function openCatalogAncestors(catalogId) {
                if (!catalogTree || !catalogTree.jstree) {
                    return null;
                }

                const treeInstance = catalogTree.jstree(true);
                const node = treeInstance.get_node(catalogId.toString());
                if (!node) {
                    return null;
                }

                const parents = (node.parents || []).filter(parentId => parentId !== '#').reverse();
                parents.forEach(parentId => treeInstance.open_node(parentId));

                return node;
            }

            function centerElementInScrollContainer(container, element, behavior = 'smooth') {
                if (!container || !element) {
                    return;
                }

                const target = element.querySelector('.jstree-anchor') || element;
                const containerRect = container.getBoundingClientRect();
                const targetRect = target.getBoundingClientRect();
                if (!containerRect.height || !targetRect.height) {
                    return;
                }

                const offsetToCenter = (targetRect.top - containerRect.top)
                    - (containerRect.height / 2)
                    + (targetRect.height / 2);
                const maxScrollTop = Math.max(0, container.scrollHeight - container.clientHeight);
                const nextScrollTop = Math.max(0, Math.min(maxScrollTop, container.scrollTop + offsetToCenter));

                container.scrollTo({
                    top: nextScrollTop,
                    behavior: behavior
                });
            }

            function centerCatalogTreeNode(catalogId, behavior = 'smooth') {
                if (!catalogId || !catalogTree || !catalogTree.jstree) {
                    return;
                }

                const run = function() {
                    const container = document.getElementById('catalog-tree');
                    const treeInstance = catalogTree.jstree(true);
                    const nodeElement = treeInstance.get_node(catalogId.toString(), true);
                    centerElementInScrollContainer(
                        container,
                        nodeElement && nodeElement.length ? nodeElement[0] : null,
                        behavior
                    );
                };

                window.requestAnimationFrame(run);
                window.setTimeout(run, 220);
            }
            
            // 选中分类
            // @param catalogId 分类ID
            // @param scrollToView 是否滚动到可见区域，默认true
            // @param loadDocs 是否加载文档列表，默认true
            function selectCatalog(catalogId, scrollToView = true, loadDocs = true) {
                if (!catalogTree || !catalogTree.jstree) {
                    return;
                }
                
                try {
                    isProgrammaticSelect = true;
                    
                    // 使用jstree的API选中节点（这会触发 select_node.jstree 事件）
                    const treeInstance = catalogTree.jstree(true);
                    openCatalogAncestors(catalogId);
                    treeInstance.deselect_all(true);
                    treeInstance.select_node(catalogId.toString());
                    
                    // 展开父节点
                    const node = treeInstance.get_node(catalogId.toString());
                    if (node && node.parent && node.parent !== '#') {
                        treeInstance.open_node(node.parent);
                    }
                    
                    // 滚动到可见区域（可选）
                    if (scrollToView) {
                        centerCatalogTreeNode(catalogId);
                    }
                    
                    currentCatalogId = catalogId;
                    
                    // 加载文档列表（可选）
                    if (loadDocs) {
                        loadDocuments(catalogId);
                    }
                    
                    // 延迟重置，确保 jstree select_node 事件已被当前调用吞掉。
                    setTimeout(() => {
                        isProgrammaticSelect = false;
                    }, 100);
                } catch (error) {
                    console.error('选中分类失败:', error);
                    // 如果jstree API失败，直接加载文档
                    currentCatalogId = catalogId;
                    if (loadDocs) {
                        loadDocuments(catalogId);
                    }
                    isProgrammaticSelect = false;
                }
            }
            
            // 加载文档列表
            // @param catalogId 分类ID
            // @param highlightDocId 需要高亮显示的文档ID（可选）
            function loadDocuments(catalogId, highlightDocId = null) {
                const safeCatalogId = normalizeNumericId(catalogId);
                const safeHighlightDocId = normalizeNumericId(highlightDocId);
                if (!safeCatalogId) {
                    return;
                }

                // 隐藏返回文档列表按钮
                const backButton = document.getElementById('document-back-button');
                if (backButton) {
                    backButton.classList.add('hidden');
                }
                
                const contentBody = document.getElementById('content-body');
                contentBody.innerHTML = '<div class="loading"><div class="spinner"></div><p style="margin-top: 10px;">加载中...</p></div>';
                
                fetch(appendDocLocale(`${baseUrl}/docs/documents?catalog_id=${safeCatalogId}`))
                    .then(response => response.json())
                    .then(data => {
                        if (data.error) {
                            contentBody.innerHTML = 
                                '<div class="empty-state"><div class="empty-state-text">' + escapeHtml(data.error) + '</div></div>';
                            return;
                        }
                        
                        if (data.length === 0) {
                            contentBody.innerHTML = 
                                '<div class="empty-state"><div class="empty-state-icon">📄</div><div class="empty-state-text">该分类下暂无文档</div></div>';
                            return;
                        }
                        
                        let html = '<div class="document-list">';
                        data.forEach(doc => {
                            const docId = normalizeNumericId(doc.id);
                            if (!docId) {
                                return;
                            }

                            const isHighlight = safeHighlightDocId && docId === safeHighlightDocId;
                            const highlightClass = isHighlight ? ' highlight' : '';
                            html += `
                                <div class="document-item${highlightClass}" data-doc-id="${docId}">
                                    <h3>${escapeHtml(doc.title)}</h3>
                                    ${doc.summary ? '<p>' + escapeHtml(doc.summary) + '</p>' : ''}
                                    <div class="document-meta">
                                        ${doc.module_name ? '<span>📦 ' + escapeHtml(doc.module_name) + '</span>' : ''}
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div>';
                        contentBody.innerHTML = html;
                        
                        // 如果需要高亮显示某个文档，滚动到该位置
                        if (safeHighlightDocId) {
                            setTimeout(() => {
                                const targetItem = contentBody.querySelector(`[data-doc-id="${safeHighlightDocId}"]`);
                                if (targetItem) {
                                    targetItem.scrollIntoView({ 
                                        behavior: 'smooth', 
                                        block: 'center' 
                                    });
                                    
                                    // 3秒后移除高亮效果
                                    setTimeout(() => {
                                        targetItem.classList.remove('highlight');
                                    }, 3000);
                                }
                            }, 100);
                        }
                    })
                    .catch(error => {
                        console.error('加载文档列表失败:', error);
                        contentBody.innerHTML = 
                            '<div class="empty-state"><div class="empty-state-text">加载失败，请刷新重试</div></div>';
                    });
            }
            
            // 返回文档列表
            window.backToDocumentList = function() {
                // 隐藏返回文档列表按钮
                const backButton = document.getElementById('document-back-button');
                if (backButton) {
                    backButton.classList.add('hidden');
                }
                
                // 隐藏目录
                const toc = document.getElementById('document-toc');
                const toggle = document.querySelector('.document-toc-toggle');
                if (toc) {
                    toc.classList.add('hidden');
                }
                if (toggle) {
                    toggle.classList.remove('visible');
                }
                
                // 保存当前文档ID，用于定位
                const docIdToHighlight = currentDocumentId;
                
                // 如果有当前分类ID，加载该分类的文档列表
                if (currentCatalogId) {
                    // 传递文档ID用于高亮显示和定位
                    loadDocuments(currentCatalogId, docIdToHighlight);
                    // 更新URL（移除文档ID参数）
                    const url = new URL(window.location);
                    url.searchParams.delete('id');
                    url.hash = ''; // 清除 hash
                    window.history.pushState({}, '', url);
                    currentDocumentId = null;
                } else {
                    // 如果没有分类ID，清空内容显示空状态
                    const contentBody = document.getElementById('content-body');
                    contentBody.innerHTML = 
                        '<div class="empty-state"><div class="empty-state-icon">📄</div><div class="empty-state-text">请选择分类查看文档</div></div>';
                    // 更新URL
                    const url = new URL(window.location);
                    url.searchParams.delete('id');
                    url.hash = ''; // 清除 hash
                    window.history.pushState({}, '', url);
                    currentDocumentId = null;
                }
            };
            
            // 加载文档详情
            window.loadDocument = function(documentId) {
                const safeDocumentId = normalizeNumericId(documentId);
                if (!safeDocumentId) {
                    return;
                }

                const contentBody = document.getElementById('content-body');
                contentBody.innerHTML = '<div class="loading"><div class="spinner"></div><p style="margin-top: 10px;">加载中...</p></div>';
                
                fetch(appendDocLocale(`${baseUrl}/docs/document?id=${safeDocumentId}`))
                    .then(response => response.json())
                    .then(data => {
                        if (data.error) {
                            contentBody.innerHTML = 
                                '<div class="empty-state"><div class="empty-state-text">' + escapeHtml(data.error) + '</div></div>';
                            return;
                        }
                        
                        // 处理文档内容，统一换行符
                        const processedContent = processDocumentContent(data.content || '');
                        
                        // 显示返回文档列表按钮
                        const backButton = document.getElementById('document-back-button');
                        if (backButton) {
                            backButton.classList.remove('hidden');
                        }
                        
                        let html = `
                            <div class="document-detail">
                                <h1 class="document-title">${escapeHtml(data.title)}</h1>
                                ${data.translation_status ? '<div class="document-meta-detail"><span>' + escapeHtml(data.translation_status) + '</span></div>' : ''}
                                <div class="document-meta-detail">
                                    ${data.module_name ? '<span>📦 ' + escapeHtml(data.module_name) + '</span>' : ''}
                                    ${data.file_name ? '<span>📄 ' + escapeHtml(data.file_name) + '</span>' : ''}
                                </div>
                                <div class="document-body">${processedContent}</div>
                            </div>
                            <button class="document-toc-toggle" data-doc-toggle-toc title="显示/隐藏目录">📑</button>
                            <div class="document-toc" id="document-toc">
                                <div class="document-toc-header">
                                    <span>目录</span>
                                    <span class="document-toc-close" data-doc-toggle-toc>×</span>
                                </div>
                                <ul class="document-toc-list" id="document-toc-list"></ul>
                            </div>
                        `;
                        contentBody.innerHTML = html;
                        
                        // 生成目录导航
                        generateDocumentToc();
                        
                        // 更新URL（不刷新页面）
                        const url = new URL(window.location);
                        url.searchParams.set('id', safeDocumentId);
                        // 保留 hash（锚点）
                        if (window.location.hash) {
                            url.hash = window.location.hash;
                        }
                        window.history.pushState({}, '', url);
                        currentDocumentId = safeDocumentId;
                        
                        // 文档加载完成后，选中对应的分类（不刷新右边界面的内容）
                        if (data.category_id && data.category_id != currentCatalogId) {
                            // 延迟定位，确保文档内容先显示
                            setTimeout(() => {
                                selectCatalog(data.category_id, true, false); // 只定位选中，不加载文档列表
                                // 分类定位后，再定位锚点
                                setTimeout(() => {
                                    scrollToAnchor();
                                }, 200);
                            }, 100);
                        } else if (data.category_id) {
                            // 如果分类ID相同，只更新变量
                            currentCatalogId = data.category_id;
                            centerCatalogTreeNode(data.category_id, 'auto');
                            // 延迟定位锚点，确保文档内容已渲染
                            setTimeout(() => {
                                scrollToAnchor();
                            }, 200);
                        } else {
                            // 没有分类ID，直接定位锚点
                            setTimeout(() => {
                                scrollToAnchor();
                            }, 200);
                        }
                    })
                    .catch(error => {
                        console.error('加载文档详情失败:', error);
                        contentBody.innerHTML = 
                            '<div class="empty-state"><div class="empty-state-text">加载失败，请刷新重试</div></div>';
                    });
            };
            
            // 搜索功能
            let searchTimer = null;
            document.getElementById('search-input').addEventListener('input', function(e) {
                const keyword = e.target.value.trim();
                
                clearTimeout(searchTimer);
                
                if (keyword.length < 2) {
                    // 如果关键词太短，恢复显示当前分类的文档
                    if (currentCatalogId) {
                        loadDocuments(currentCatalogId);
                    }
                    return;
                }
                
                searchTimer = setTimeout(() => {
                    searchDocuments(keyword);
                }, 300);
            });

            window.locateCatalog = function(catalogId) {
                const targetCatalogId = parseInt(catalogId, 10);
                if (!targetCatalogId) {
                    return;
                }

                const url = new URL(window.location);
                url.searchParams.set('catalog_id', targetCatalogId.toString());
                url.searchParams.delete('id');
                url.hash = '';
                window.history.pushState({}, '', url);
                currentDocumentId = null;

                selectCatalog(targetCatalogId, true, true);
            };
            
            function searchDocuments(keyword) {
                const contentBody = document.getElementById('content-body');
                contentBody.innerHTML = '<div class="loading"><div class="spinner"></div><p style="margin-top: 10px;">搜索中...</p></div>';
                
                fetch(appendDocLocale(`${baseUrl}/docs/search?keyword=${encodeURIComponent(keyword)}&include_catalogs=1`))
                    .then(response => response.json())
                    .then(data => {
                        if (data.error) {
                            contentBody.innerHTML = 
                                '<div class="empty-state"><div class="empty-state-text">' + escapeHtml(data.error) + '</div></div>';
                            return;
                        }

                        const catalogs = Array.isArray(data.catalogs) ? data.catalogs : [];
                        const documents = Array.isArray(data) ? data : (Array.isArray(data.documents) ? data.documents : []);
                        
                        if (catalogs.length === 0 && documents.length === 0) {
                            contentBody.innerHTML = 
                                '<div class="empty-state"><div class="empty-state-icon">🔍</div><div class="empty-state-text">未找到相关目录或文档</div></div>';
                            return;
                        }
                        
                        let html = '<div class="document-list">';
                        if (catalogs.length > 0) {
                            html += '<div class="search-section-title">目录匹配</div>';
                            catalogs.forEach(catalog => {
                                const catalogId = normalizeNumericId(catalog.id);
                                if (!catalogId) {
                                    return;
                                }

                                html += `
                                <div class="document-item catalog-result" data-catalog-id="${catalogId}">
                                    <h3>${escapeHtml(catalog.name)}</h3>
                                    ${catalog.path ? '<div class="catalog-result-path">' + escapeHtml(catalog.path) + '</div>' : ''}
                                    ${catalog.description ? '<p>' + escapeHtml(catalog.description) + '</p>' : ''}
                                    <div class="document-meta">
                                        <span class="catalog-result-badge">📁 定位目录</span>
                                    </div>
                                </div>
                            `;
                            });
                        }

                        if (documents.length > 0) {
                            html += '<div class="search-section-title">文档匹配</div>';
                        }

                        documents.forEach(doc => {
                            const docId = normalizeNumericId(doc.id);
                            if (!docId) {
                                return;
                            }

                            html += `
                                <div class="document-item" data-doc-id="${docId}">
                                    <h3>${escapeHtml(doc.title)}</h3>
                                    ${doc.summary ? '<p>' + escapeHtml(doc.summary) + '</p>' : ''}
                                    <div class="document-meta">
                                        ${doc.module_name ? '<span>📦 ' + escapeHtml(doc.module_name) + '</span>' : ''}
                                    </div>
</div>
                            `;
                        });
                        html += '</div>';
                        contentBody.innerHTML = html;
                    })
                    .catch(error => {
                        console.error('搜索失败:', error);
                        contentBody.innerHTML = 
                            '<div class="empty-state"><div class="empty-state-text">搜索失败，请刷新重试</div></div>';
                    });
            }
            
            // HTML转义
            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            function normalizeNumericId(value) {
                const id = Number.parseInt(value, 10);
                return Number.isSafeInteger(id) && id > 0 ? id : 0;
            }

            const docCurrencySelect = document.getElementById('doc-currency-select');
            if (docCurrencySelect) {
                docCurrencySelect.addEventListener('change', function(event) {
                    switchDocCurrency(event.target.value);
                });
            }

            document.addEventListener('click', function(event) {
                if (event.target.closest('[data-doc-toggle-sidebar]')) {
                    event.preventDefault();
                    toggleSidebar();
                    return;
                }

                if (event.target.closest('[data-doc-back-list]')) {
                    event.preventDefault();
                    backToDocumentList();
                    return;
                }

                if (event.target.closest('[data-doc-toggle-theme]')) {
                    event.preventDefault();
                    toggleTheme();
                    return;
                }

                if (event.target.closest('[data-doc-toggle-toc]')) {
                    event.preventDefault();
                    toggleDocumentToc();
                    return;
                }

                const catalogItem = event.target.closest('[data-catalog-id]');
                if (catalogItem) {
                    event.preventDefault();
                    locateCatalog(catalogItem.getAttribute('data-catalog-id'));
                    return;
                }

                const documentItem = event.target.closest('[data-doc-id]');
                if (documentItem) {
                    const documentId = normalizeNumericId(documentItem.getAttribute('data-doc-id'));
                    if (documentId) {
                        event.preventDefault();
                        loadDocument(documentId);
                    }
                }
            });

            function sanitizeRenderedHtml(html) {
                if (!html) {
                    return '';
                }

                const template = document.createElement('template');
                template.innerHTML = String(html);
                const blockedTags = 'script,style,link,meta,iframe,frame,frameset,object,embed,base,form,input,button,textarea,select,option';
                template.content.querySelectorAll(blockedTags).forEach(node => node.remove());
                const uriAttributes = new Set(['href', 'src', 'xlink:href', 'action', 'formaction', 'poster']);
                const allowedDataImage = /^data:image\/(?:png|gif|jpe?g|webp|bmp);base64,/i;

                template.content.querySelectorAll('*').forEach(element => {
                    Array.from(element.attributes).forEach(attribute => {
                        const name = attribute.name.toLowerCase();
                        const value = String(attribute.value || '').trim();
                        const compactValue = value.replace(/[\u0000-\u001F\u007F\s]+/g, '').toLowerCase();

                        if (name.startsWith('on') || name === 'srcdoc' || name === 'style') {
                            element.removeAttribute(attribute.name);
                            return;
                        }

                        if (uriAttributes.has(name)) {
                            const hasScheme = /^[a-z][a-z0-9+.-]*:/i.test(value);
                            const allowedScheme = /^(https?:|mailto:|tel:|ftp:)/i.test(value);
                            const allowedData = allowedDataImage.test(value);
                            const blockedScheme = compactValue.startsWith('javascript:')
                                || compactValue.startsWith('vbscript:')
                                || (compactValue.startsWith('data:') && !allowedData);

                            if (blockedScheme || (hasScheme && !allowedScheme && !allowedData)) {
                                element.removeAttribute(attribute.name);
                            }
                        }
                    });
                });

                return template.innerHTML;
            }
            
            // 生成文档目录导航（暴露到全局作用域）
            window.generateDocumentToc = function() {
                const tocList = document.getElementById('document-toc-list');
                const tocContainer = document.getElementById('document-toc');
                const tocToggle = document.querySelector('.document-toc-toggle');
                
                if (!tocList) return;
                
                // 获取所有标题
                const headings = document.querySelectorAll('.document-body h1, .document-body h2, .document-body h3, .document-body h4, .document-body h5, .document-body h6');
                
                if (headings.length === 0) {
                    // 没有标题，隐藏目录
                    if (tocContainer) tocContainer.classList.add('hidden');
                    if (tocToggle) tocToggle.classList.remove('visible');
                    return;
                }
                
                // 有标题，显示目录，隐藏按钮
                if (tocContainer) tocContainer.classList.remove('hidden');
                if (tocToggle) tocToggle.classList.remove('visible');
                
                // 清空目录列表
                tocList.innerHTML = '';
                
                // 生成目录项
                headings.forEach((heading, index) => {
                    const level = parseInt(heading.tagName.substring(1));
                    const text = heading.textContent.trim();
                    
                    // 生成或获取标题 ID
                    let id = heading.id;
                    
                    // 如果没有 ID，尝试从文本生成一个（与 marked.js 的 ID 生成规则一致）
                    if (!id || id === '') {
                        // 使用文本生成 ID：转小写、替换空格为连字符、移除特殊字符
                        id = text.toLowerCase()
                            .replace(/\s+/g, '-')
                            .replace(/[^\w\u4e00-\u9fa5-]/g, '')
                            .replace(/-+/g, '-')
                            .replace(/^-|-$/g, '');
                        
                        // 如果生成的 ID 为空或已存在，使用索引
                        if (!id || document.getElementById(id)) {
                            id = `heading-${index}`;
                        }
                        
                        // 设置标题 ID
                        heading.id = id;
                    }
                    
                    const li = document.createElement('li');
                    li.className = 'document-toc-item';
                    li.setAttribute('data-level', level);
                    li.setAttribute('data-id', id);
                    
                    const a = document.createElement('a');
                    a.href = '#' + encodeURIComponent(id);
                    a.textContent = text;
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        scrollToHeading(id);
                    });
                    
                    li.appendChild(a);
                    tocList.appendChild(li);
                });
                
                // 监听滚动，高亮当前章节
                let ticking = false;
                window.addEventListener('scroll', function() {
                    if (!ticking) {
                        window.requestAnimationFrame(function() {
                            updateActiveTocItem();
                            ticking = false;
                        });
                        ticking = true;
                    }
                }, { passive: true });
                
                // 初始更新一次
                updateActiveTocItem();
            };
            
            // 更新当前激活的目录项
            function updateActiveTocItem() {
                const headings = document.querySelectorAll('.document-body h1, .document-body h2, .document-body h3, .document-body h4, .document-body h5, .document-body h6');
                const tocItems = document.querySelectorAll('.document-toc-item');
                
                if (headings.length === 0 || tocItems.length === 0) return;
                
                // 找到当前视口中最上方的标题
                let currentHeading = null;
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                const offset = 100; // 偏移量
                
                for (let i = headings.length - 1; i >= 0; i--) {
                    const heading = headings[i];
                    const rect = heading.getBoundingClientRect();
                    if (rect.top <= offset + 100) {
                        currentHeading = heading;
                        break;
                    }
                }
                
                // 如果没有找到，使用第一个标题
                if (!currentHeading && headings.length > 0) {
                    currentHeading = headings[0];
                }
                
                // 更新目录项状态
                tocItems.forEach(item => {
                    item.classList.remove('active');
                    const itemId = item.getAttribute('data-id');
                    if (currentHeading && currentHeading.id === itemId) {
                        item.classList.add('active');
                        // 滚动目录，使当前项可见
                        const tocContainer = document.getElementById('document-toc');
                        if (tocContainer && item.offsetTop < tocContainer.scrollTop) {
                            tocContainer.scrollTop = item.offsetTop - 20;
                        } else if (tocContainer && item.offsetTop + item.offsetHeight > tocContainer.scrollTop + tocContainer.clientHeight) {
                            tocContainer.scrollTop = item.offsetTop - tocContainer.clientHeight + item.offsetHeight + 20;
                        }
                    }
                });
            }
            
            // 滚动到指定标题
            function scrollToHeading(headingId) {
                const heading = document.getElementById(headingId);
                if (heading) {
                    heading.style.scrollMarginTop = '80px';
                    heading.scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'start' 
                    });
                    
                    // 更新 URL hash
                    const url = new URL(window.location);
                    url.hash = '#' + encodeURIComponent(headingId);
                    window.history.pushState({}, '', url);
                    
                    // 高亮显示（使用 class）
                    heading.classList.add('heading-highlight');
                    
                    setTimeout(() => {
                        heading.classList.remove('heading-highlight');
                    }, 2000);
                }
            }
            
            // 切换目录显示/隐藏
            window.toggleDocumentToc = function() {
                const toc = document.getElementById('document-toc');
                const toggle = document.querySelector('.document-toc-toggle');
                if (toc) {
                    const isHidden = toc.classList.contains('hidden');
                    if (isHidden) {
                        // 显示目录，隐藏按钮
                        toc.classList.remove('hidden');
                        if (toggle) toggle.classList.remove('visible');
                    } else {
                        // 隐藏目录，显示按钮
                        toc.classList.add('hidden');
                        if (toggle) toggle.classList.add('visible');
                    }
                }
            };
            
            // 定位到锚点（URL hash）（暴露到全局作用域）
            window.scrollToAnchor = function() {
                const hash = window.location.hash;
                if (!hash) {
                    return;
                }
                
                // 移除 # 号
                const anchorId = decodeURIComponent(hash.substring(1));
                if (!anchorId) {
                    return;
                }
                
                // 查找对应的标题元素
                // Markdown 渲染后的标题 ID 格式可能是：原始文本、URL编码后的文本、或者 marked 生成的 ID
                let targetElement = null;
                
                // 方法1：直接使用 hash 查找（marked 会自动生成 ID）
                targetElement = document.getElementById(anchorId);
                
                // 方法2：如果找不到，尝试 URL 解码后的 ID
                if (!targetElement) {
                    const decodedId = decodeURIComponent(anchorId);
                    if (decodedId !== anchorId) {
                        targetElement = document.getElementById(decodedId);
                    }
                }
                
                // 方法3：如果还是找不到，尝试查找所有标题，匹配文本内容或 ID
                if (!targetElement) {
                    const headings = document.querySelectorAll('.document-body h1, .document-body h2, .document-body h3, .document-body h4, .document-body h5, .document-body h6');
                    for (let heading of headings) {
                        // 获取标题文本和 ID
                        const headingText = heading.textContent.trim();
                        const headingId = heading.id || '';
                        
                        // 尝试多种匹配方式
                        if (headingId === anchorId || 
                            headingId === decodeURIComponent(anchorId) ||
                            headingText === anchorId ||
                            headingText === decodeURIComponent(anchorId)) {
                            targetElement = heading;
                            break;
                        }
                        
                        // 模糊匹配：忽略大小写、空格、特殊字符
                        const normalizedAnchor = anchorId.toLowerCase().replace(/[^\w\u4e00-\u9fa5]/g, '');
                        const normalizedHeadingText = headingText.toLowerCase().replace(/[^\w\u4e00-\u9fa5]/g, '');
                        const normalizedHeadingId = headingId.toLowerCase().replace(/[^\w\u4e00-\u9fa5]/g, '');
                        
                        if (normalizedHeadingText === normalizedAnchor || 
                            normalizedHeadingId === normalizedAnchor) {
                            targetElement = heading;
                            break;
                        }
                    }
                }
                
                // 方法4：如果还是找不到，尝试查找包含该文本的元素
                if (!targetElement) {
                    const allElements = document.querySelectorAll('.document-body *');
                    for (let el of allElements) {
                        const elText = el.textContent ? el.textContent.trim() : '';
                        if (elText === anchorId || elText === decodeURIComponent(anchorId)) {
                            targetElement = el;
                            break;
                        }
                    }
                }
                
                if (targetElement) {
                    // 高亮显示目标元素
                    targetElement.style.scrollMarginTop = '80px'; // 为固定头部留出空间
                    targetElement.scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'start' 
                    });
                    
                    // 添加高亮效果（使用 class）
                    targetElement.classList.add('heading-highlight');
                    
                    // 3秒后移除高亮
                    setTimeout(() => {
                        targetElement.classList.remove('heading-highlight');
                    }, 3000);
                } else {
                    console.warn('未找到锚点目标:', anchorId);
                }
            };
            
            // 处理文档内容，渲染 Markdown 格式
            function processDocumentContent(content) {
                if (!content) return '';
                
                // 统一换行符格式
                content = content.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
                
                // 如果 marked.js 已加载，使用它渲染 Markdown
                if (typeof marked !== 'undefined') {
                    try {
                        // 配置 marked 选项
                        marked.setOptions({
                            breaks: true,  // 支持 GitHub 风格的换行
                            gfm: true,     // 启用 GitHub Flavored Markdown
                            headerIds: true, // 为标题添加 ID
                            mangle: false   // 不混淆邮箱地址
                        });
                        
                        // 渲染 Markdown 为 HTML
                        return sanitizeRenderedHtml(marked.parse(content));
                    } catch (e) {
                        console.error('Markdown 渲染失败:', e);
                        // 如果渲染失败，返回原始内容（HTML 转义）
                        return escapeHtml(content);
                    }
                } else {
                    // 如果 marked.js 未加载，返回 HTML 转义的原始内容
                    console.warn('marked.js 未加载，使用纯文本显示');
                    return escapeHtml(content);
                }
            }
            
            // 添加拖拽滚动功能
            function initDragScroll() {
                const catalogTreeEl = document.getElementById('catalog-tree');
                if (!catalogTreeEl) return;
                
                let isMouseDown = false;
                let isDragging = false;
                let startX = 0;
                let startY = 0;
                let scrollLeft = 0;
                let scrollTop = 0;
                let dragThreshold = 5; // 拖拽阈值，超过这个距离才认为是拖拽
                
                catalogTreeEl.addEventListener('mousedown', function(e) {
                    // 只响应鼠标左键
                    if (e.button !== 0) return;
                    
                    // 如果点击的是可交互元素（如链接、按钮、jstree节点），不启用拖拽
                    if (e.target.tagName === 'A' || e.target.closest('a') || 
                        e.target.closest('.jstree-anchor') ||
                        e.target.closest('.jstree-node')) {
                        return;
                    }
                    
                    isMouseDown = true;
                    isDragging = false;
                    startX = e.pageX;
                    startY = e.pageY;
                    scrollLeft = catalogTreeEl.scrollLeft;
                    scrollTop = catalogTreeEl.scrollTop;
                    e.preventDefault(); // 防止文本选择
                });
                
                document.addEventListener('mousemove', function(e) {
                    if (!isMouseDown || !catalogTreeEl) return;
                    
                    // 如果还没有开始拖拽，检查是否超过阈值
                    if (!isDragging) {
                        const deltaX = Math.abs(e.pageX - startX);
                        const deltaY = Math.abs(e.pageY - startY);
                        
                        // 如果移动距离超过阈值，开始拖拽
                        if (deltaX > dragThreshold || deltaY > dragThreshold) {
                            isDragging = true;
                            catalogTreeEl.classList.add('dragging');
                            // 重新计算起始位置（相对于容器）
                            const rect = catalogTreeEl.getBoundingClientRect();
                            startX = e.pageX - rect.left;
                            startY = e.pageY - rect.top;
                            scrollLeft = catalogTreeEl.scrollLeft;
                            scrollTop = catalogTreeEl.scrollTop;
                        } else {
                            return; // 还没超过阈值，不处理
                        }
                    }
                    
                    // 执行拖拽滚动
                    e.preventDefault();
                    const rect = catalogTreeEl.getBoundingClientRect();
                    const x = e.pageX - rect.left;
                    const y = e.pageY - rect.top;
                    const walkX = (x - startX) * 2; // 滚动速度倍数
                    const walkY = (y - startY) * 2;
                    catalogTreeEl.scrollLeft = scrollLeft - walkX;
                    catalogTreeEl.scrollTop = scrollTop - walkY;
                });
                
                document.addEventListener('mouseup', function(e) {
                    if (isMouseDown) {
                        isMouseDown = false;
                        if (isDragging) {
                            isDragging = false;
                            catalogTreeEl.classList.remove('dragging');
                        }
                    }
                });
                
                // 鼠标离开容器时也停止拖拽
                catalogTreeEl.addEventListener('mouseleave', function() {
                    if (isMouseDown) {
                        isMouseDown = false;
                        if (isDragging) {
                            isDragging = false;
                            catalogTreeEl.classList.remove('dragging');
                        }
                    }
                });
            }
            
            // 切换侧边栏展开/收起（暴露到全局作用域）
            window.toggleSidebar = function() {
                const sidebar = document.querySelector('.doc-sidebar');
                if (!sidebar) return;
                
                sidebar.classList.toggle('collapsed');
                const toggleButton = document.querySelector('.sidebar-toggle');
                if (toggleButton) {
                    toggleButton.classList.toggle('collapsed');
                    
                    // 更新图标：展开时显示左箭头，收起时显示右箭头
                    const iconSpan = toggleButton.querySelector('span');
                    if (iconSpan) {
                        if (sidebar.classList.contains('collapsed')) {
                            iconSpan.textContent = '▶';
                        } else {
                            iconSpan.textContent = '◀';
                        }
                    }
                }
            };
            
            // 等待jQuery和jstree加载完成后再初始化
            if (typeof jQuery !== 'undefined' && typeof jQuery.fn.jstree !== 'undefined') {
                // 已经加载，直接初始化
                loadCatalogTree();
                // 等待DOM加载完成后初始化拖拽滚动
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', function() {
                        setTimeout(initDragScroll, 500);
                        // 页面加载完成后，如果有 hash，定位锚点
                        setTimeout(function() {
                            if (window.location.hash && typeof window.scrollToAnchor === 'function') {
                                window.scrollToAnchor();
                            }
                        }, 600);
                    });
                } else {
                    setTimeout(initDragScroll, 500);
                    // 页面加载完成后，如果有 hash，定位锚点
                    setTimeout(function() {
                        if (window.location.hash && typeof window.scrollToAnchor === 'function') {
                            window.scrollToAnchor();
                        }
                    }, 600);
                }
            } else {
                // 等待加载
                window.addEventListener('load', function() {
                    setTimeout(function() {
                        loadCatalogTree();
                        setTimeout(initDragScroll, 500);
                        // 页面加载完成后，如果有 hash，定位锚点
                        setTimeout(function() {
                            if (window.location.hash && typeof window.scrollToAnchor === 'function') {
                                window.scrollToAnchor();
                            }
                        }, 600);
                    }, 100);
                });
            }
            
            // 监听 hash 变化事件（当用户点击页面内的锚点链接时）
            window.addEventListener('hashchange', function() {
                if (typeof window.scrollToAnchor === 'function') {
                    setTimeout(function() {
                        window.scrollToAnchor();
                    }, 100);
                }
            });
            
            // 主题切换功能
            function getCurrentThemeMode() {
                return document.body.getAttribute('data-theme-mode')
                    || document.body.getAttribute('data-layout-mode')
                    || document.body.getAttribute('data-theme')
                    || 'light';
            }

            function initTheme() {
                updateThemeIcon(getCurrentThemeMode());
            }
            
            function updateThemeIcon(theme) {
                const icon = document.getElementById('theme-icon');
                if (icon) {
                    icon.textContent = theme === 'dark' ? '☀️' : '🌙';
                }
            }
            
            window.toggleTheme = function() {
                const currentTheme = getCurrentThemeMode();
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.body.setAttribute('data-theme-mode', newTheme);
                document.body.setAttribute('data-layout-mode', newTheme);
                updateThemeIcon(newTheme);
            };
            
            // 初始化主题
            initTheme();
        })();
    </script>
    <w:seo slot="inspector"/>
</body>
</html>
