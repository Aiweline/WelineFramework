        // 切换正式环境模式
        function toggleProductionMode() {
            const switchEl = document.getElementById('production-mode-switch');
            const toggleEl = document.getElementById('production-mode-toggle');
            
            if (!switchEl || !toggleEl) {
                return;
            }
            
            if (switchEl.checked && !productionMode) {
                // 开启正式环境模式 - 显示警告
                if (confirm('⚠️ 警告：您即将开启正式环境调试模式！\n\n' +
                    '开启后，所有API请求将直接发送到正式环境，可能会：\n' +
                    '• 修改正式环境的数据\n' +
                    '• 影响正式环境的业务\n' +
                    '• 造成不可逆的数据损失\n\n' +
                    '请确认您已充分了解风险，并谨慎操作！\n\n' +
                    '是否继续开启？')) {
                    productionMode = true;
                    localStorage.setItem(PRODUCTION_MODE_KEY, 'true');
                    toggleEl.classList.add('active');
                    // 如果当前有选中的API，重新加载详情以显示警告
                    if (window.selectedApi) {
                        loadApiDetail(window.selectedApi);
                    }
                } else {
                    // 用户取消，恢复开关状态
                    switchEl.checked = false;
                }
            } else if (!switchEl.checked && productionMode) {
                // 关闭正式环境模式
                productionMode = false;
                localStorage.setItem(PRODUCTION_MODE_KEY, 'false');
                toggleEl.classList.remove('active');
                // 如果当前有选中的API，重新加载详情以移除警告
                if (window.selectedApi) {
                    loadApiDetail(window.selectedApi);
                }
            }
        }
        
