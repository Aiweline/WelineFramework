    <script>
        // API数据
        const apiData = <?= json_encode($apis ?? [], JSON_UNESCAPED_UNICODE) ?>;
        const moduleDisplayNames = <?= json_encode($this->getData('moduleDisplayNames') ?? [], JSON_UNESCAPED_UNICODE) ?>;
        const selectedApiId = '<?= htmlspecialchars($apiId ?? '') ?>';
        const selectedApi = <?= json_encode($selectedApi ?? null, JSON_UNESCAPED_UNICODE) ?>;
        
        // 获取可用的货币和语言列表（从后端传递）
        const availableCurrencies = <?= json_encode($this->getData('availableCurrencies') ?? [], JSON_UNESCAPED_UNICODE) ?>;
        const availableLocales = <?= json_encode($this->getData('availableLocales') ?? [], JSON_UNESCAPED_UNICODE) ?>;
        
        // 将selectedApi存储到全局变量
        window.selectedApi = selectedApi;
        
        // 存储token到localStorage
        const TOKEN_KEY = 'api_doc_access_token'; // 前端API token
        const REFRESH_TOKEN_KEY = 'api_doc_refresh_token'; // 前端API refresh token
        const USER_KEY = 'api_doc_user'; // 前端API用户
        const BACKEND_TOKEN_KEY = 'api_doc_backend_access_token'; // 后端API token
        const BACKEND_REFRESH_TOKEN_KEY = 'api_doc_backend_refresh_token'; // 后端API refresh token
        const BACKEND_USER_KEY = 'api_doc_backend_user'; // 后端API用户
        const SANDBOX_KEY = 'api_doc_sandbox_key';
        const PRODUCTION_MODE_KEY = 'api_doc_production_mode';
        const LOCALE_KEY = 'api_doc_locale';
        const CURRENCY_KEY = 'api_doc_currency';
        const I18N_MODE_KEY = 'api_doc_i18n_mode';
        const API_TYPE_KEY = 'api_doc_api_type';
        
        // 获取沙盒密钥（从后端获取或使用默认值）
        const sandboxKey = '<?= \Weline\Framework\App\Env::getInstance()->getConfig('sandbox_key') ?? 'dev_sandbox_2024' ?>';
        
        // 获取API area配置（从后端传递，使用Env::get('api')）
        const API_AREA = '<?= htmlspecialchars(\Weline\Framework\App\Env::get('api') ?: 'api', ENT_QUOTES, 'UTF-8') ?>';
        const API_ADMIN_AREA = '<?= htmlspecialchars(\Weline\Framework\App\Env::get('api_admin') ?: 'api_admin', ENT_QUOTES, 'UTF-8') ?>';
        
        // 定义 window.api 函数，统一使用它生成 API URL
        // 获取当前货币和语言
        function getCurrentCurrency() {
            const urlParams = new URLSearchParams(window.location.search);
            const pathParts = window.location.pathname.split('/').filter(p => p);
            for (let i = 0; i < pathParts.length; i++) {
                if (pathParts[i].match(/^[A-Z]{3}$/)) {
                    return pathParts[i];
                }
            }
            if (urlParams.has('currency')) {
                return urlParams.get('currency');
            }
            return localStorage.getItem('api_doc_currency') || 'CNY';
        }
        
        function getCurrentLocale() {
            const urlParams = new URLSearchParams(window.location.search);
            const pathParts = window.location.pathname.split('/').filter(p => p);
            for (let i = 0; i < pathParts.length; i++) {
                if (pathParts[i].match(/^[a-z]{2}_[A-Z][a-z]+_[A-Z]{2}$/)) {
                    return pathParts[i];
                }
            }
            if (urlParams.has('locale')) {
                return urlParams.get('locale');
            }
            return localStorage.getItem('api_doc_locale') || 'zh_Hans_CN';
        }
        
        // 保存 getCurrentCurrency 和 getCurrentLocale 到 window 对象，以便临时替换
        window.getCurrentCurrency = getCurrentCurrency;
        window.getCurrentLocale = getCurrentLocale;
        
        // 重写 window.api 函数，支持 i18n
        if (typeof window.api === 'undefined' || !window.api.__custom) {
            const originalApi = window.api;
            window.api = function(path, isBackend = false) {
                if (!path) {
                    return '';
                }
                // 移除开头的斜杠
                path = path.replace(/^\//, '');
                const baseUrl = window.location.origin;
                // 使用 window 上的函数，这样可以被临时替换
                const currency = (window.getCurrentCurrency || getCurrentCurrency)();
                const locale = (window.getCurrentLocale || getCurrentLocale)();
                
                if (isBackend) {
                    // 后端API: /{api_admin_area}/{path}
                    return baseUrl + '/' + API_ADMIN_AREA + '/' + path;
                } else {
                    // 前端API: /{api_area}/{currency}/{locale}/{path}
                    return baseUrl + '/' + API_AREA + '/' + currency + '/' + locale + '/' + path;
                }
            };
            window.api.__custom = true;
        }
        
        // 定义 window.backend_api 函数
        window.backend_api = function(path) {
            return window.api(path, true);
        };
        
        // 正式环境调试模式
        let productionMode = localStorage.getItem(PRODUCTION_MODE_KEY) === 'true';
        
        // 初始化语言和货币
        let currentLocale = getCurrentLocale();
        let currentCurrency = getCurrentCurrency();
        let currentApiType = localStorage.getItem(API_TYPE_KEY) || 'frontend';
        let currentI18nMode = localStorage.getItem(I18N_MODE_KEY) || 'path';
        
        // 设置语言和货币选择器的值
        document.addEventListener('DOMContentLoaded', function() {
            const localeSelect = document.getElementById('locale-select');
            const currencySelect = document.getElementById('currency-select');
            if (localeSelect) {
                localeSelect.value = currentLocale;
            }
            if (currencySelect) {
                currencySelect.value = currentCurrency;
            }
            
            // 设置API类型Tab
            switchApiType(currentApiType);
        });
        
        // 初始化正式环境模式开关
        function initProductionMode() {
            const switchEl = document.getElementById('production-mode-switch');
            const toggleEl = document.getElementById('production-mode-toggle');
            if (switchEl && toggleEl) {
                switchEl.checked = productionMode;
                if (productionMode) {
                    toggleEl.classList.add('active');
