                        'dots': true,  // 显示连接点
                        'stripes': false,  // 不显示条纹
                        'variant': 'large'  // 使用大尺寸变体
                    },
                    'animation': 200  // 展开/收起动画
                },
                'plugins': ['search'],  // 添加搜索插件
                'search': {
                    'case_insensitive': true,
                    'show_only_matches': true,
                    'show_only_matches_children': true
                }
            });
            
            // 绑定事件（在jstree初始化后）
            $('#api-tree').on('select_node.jstree', function(e, data) {
