        // 添加请求头
        function addHeader() {
            const editor = document.getElementById('headers-editor');
            if (!editor) return;
            
            const row = document.createElement('div');
            row.className = 'header-row';
            row.innerHTML = `
                <input type="text" class="header-key" placeholder="<?=__('Header名称')?>">
                <input type="text" class="header-value" placeholder="<?=__('Header值')?>">
                <button type="button" class="btn-remove" onclick="removeHeader(this)">×</button>
            `;
            editor.appendChild(row);
        }
        
        // 删除请求头
        function removeHeader(btn) {
            btn.closest('.header-row').remove();
        }
        
        // 发送测试请求
        async function sendTestRequest() {
            const api = window.selectedApi;
            if (!api) {
                alert('<?=__('请先选择一个API接口')?>');
                return;
            }
            
            // 获取请求配置
            const method = document.getElementById('test-method').value;
            const url = document.getElementById('test-url').value;
            
            // 获取请求头
            const headers = {};
            document.querySelectorAll('.header-row').forEach(row => {
                const key = row.querySelector('.header-key').value.trim();
                const value = row.querySelector('.header-value').value.trim();
                if (key && value) {
                    headers[key] = value;
                }
            });
            
            // 获取请求体
            let body = null;
            const bodyEl = document.getElementById('test-body');
            if (bodyEl && ['POST', 'PUT', 'PATCH'].includes(method)) {
                const bodyText = bodyEl.value.trim();
                if (bodyText) {
                    try {
                        // 验证JSON格式
                        JSON.parse(bodyText);
                        body = bodyText;
                    } catch (e) {
                        alert('<?=__('请求体格式错误，请输入有效的JSON')?>');
                        return;
                    }
                }
            }
            
            // 添加沙盒参数（仅在非正式环境模式下）
            const requestUrl = new URL(url);
            if (!productionMode && sandboxKey) {
                requestUrl.searchParams.set('sandbox', sandboxKey);
            }
            
            // 显示响应区域
            const responseSection = document.getElementById('test-response-section');
            if (responseSection) {
                responseSection.style.display = 'block';
            }
            
            // 显示加载状态
            const responseInfo = document.getElementById('response-info');
            const responseHeadersBody = document.getElementById('response-headers-body');
            const responseBodyContent = document.getElementById('response-body-content');
            
            if (responseInfo) {
                responseInfo.innerHTML = '<div class="response-info-item"><label><?=__('状态')?>:</label><span>请求中...</span></div>';
            }
            if (responseHeadersBody) {
                responseHeadersBody.innerHTML = '';
            }
            if (responseBodyContent) {
                responseBodyContent.textContent = '';
            }
            
            // 禁用发送按钮
            const sendBtn = document.querySelector('.test-send-btn');
            if (sendBtn) {
                sendBtn.disabled = true;
            }
            
            const startTime = Date.now();
            
            try {
                const response = await fetch(requestUrl.toString(), {
                    method: method,
                    headers: headers,
                    body: body
                });
                
                const endTime = Date.now();
                const duration = endTime - startTime;
                
                // 获取响应头
                const responseHeaders = {};
                response.headers.forEach((value, key) => {
                    responseHeaders[key] = value;
                });
                
                // 获取响应体
                const responseText = await response.text();
                
                // 更新响应信息
                if (responseInfo) {
                    const statusClass = response.ok ? 'success' : 'error';
                    responseInfo.innerHTML = `
                        <div class="response-info-item">
                            <label><?=__('状态码')?>:</label>
                            <span class="response-status-badge ${statusClass}">${response.status} ${response.statusText}</span>
                        </div>
                        <div class="response-info-item">
                            <label><?=__('请求时间')?>:</label>
                            <span>${duration}ms</span>
                        </div>
                        <div class="response-info-item">
                            <label><?=__('响应大小')?>:</label>
                            <span>${formatBytes(responseText.length)}</span>
                        </div>
                    `;
                }
                
                // 更新响应头
                if (responseHeadersBody) {
                    responseHeadersBody.innerHTML = '';
                    Object.entries(responseHeaders).forEach(([key, value]) => {
                        const row = document.createElement('tr');
                        row.innerHTML = `<td>${escapeHtml(key)}</td><td>${escapeHtml(value)}</td>`;
                        responseHeadersBody.appendChild(row);
                    });
                }
                
                // 更新响应体（美化处理）
                if (responseBodyContent) {
                    let formattedResponse = responseText;
                    try {
                        const jsonData = JSON.parse(responseText);
                        formattedResponse = JSON.stringify(jsonData, null, 2)
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t')
                            .replace(/\\"/g, '"');
                    } catch (e) {
                        // 不是JSON，直接显示，但处理转义字符
                        formattedResponse = responseText
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t');
                    }
                    responseBodyContent.textContent = formattedResponse;
                    
                    // 高亮代码
                    if (typeof Prism !== 'undefined') {
                        Prism.highlightElement(responseBodyContent);
                    }
                }
                
            } catch (error) {
                if (responseInfo) {
                    responseInfo.innerHTML = `
                        <div class="response-info-item">
                            <label><?=__('状态')?>:</label>
                            <span class="response-status-badge error"><?=__('请求失败')?></span>
                        </div>
                        <div class="response-info-item">
                            <label><?=__('错误')?>:</label>
                            <span>${escapeHtml(error.message)}</span>
                        </div>
                    `;
                }
                if (responseBodyContent) {
                    responseBodyContent.textContent = '错误：' + error.message;
                }
            } finally {
                // 恢复发送按钮
                if (sendBtn) {
                    sendBtn.disabled = false;
                }
            }
        }
        
        // 格式化字节大小
        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }
        
        // 复制响应体
        function copyResponseBody() {
            const content = document.getElementById('response-body-content');
            if (content) {
                navigator.clipboard.writeText(content.textContent).then(() => {
                    alert('<?=__('已复制到剪贴板')?>');
                });
            }
        }
        
        // 复制示例路径
        function copyExamplePath(path) {
            if (path) {
                navigator.clipboard.writeText(path).then(() => {
                    alert('<?=__('路径已复制到剪贴板')?>');
                }).catch(() => {
                    // 降级方案
                    const textarea = document.createElement('textarea');
                    textarea.value = path;
                    textarea.style.position = 'fixed';
                    textarea.style.opacity = '0';
                    document.body.appendChild(textarea);
                    textarea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textarea);
                    alert('<?=__('路径已复制到剪贴板')?>');
                });
            }
        }
        
        // 复制示例请求体
        function copyExampleBody() {
            const content = document.getElementById('example-body-content');
            if (content) {
                const text = content.textContent || content.innerText;
                navigator.clipboard.writeText(text).then(() => {
                    alert('<?=__('请求体已复制到剪贴板')?>');
                }).catch(() => {
                    // 降级方案
                    const textarea = document.createElement('textarea');
                    textarea.value = text;
                    textarea.style.position = 'fixed';
                    textarea.style.opacity = '0';
                    document.body.appendChild(textarea);
                    textarea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textarea);
                    alert('<?=__('请求体已复制到剪贴板')?>');
                });
            }
        }
        
        // 复制示例响应体
        function copyExampleResponse() {
            const content = document.getElementById('example-response-content');
            if (content) {
                const text = content.textContent || content.innerText;
                navigator.clipboard.writeText(text).then(() => {
                    alert('<?=__('响应体已复制到剪贴板')?>');
                }).catch(() => {
                    // 降级方案
                    const textarea = document.createElement('textarea');
                    textarea.value = text;
                    textarea.style.position = 'fixed';
                    textarea.style.opacity = '0';
                    document.body.appendChild(textarea);
                    textarea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textarea);
                    alert('<?=__('响应体已复制到剪贴板')?>');
                });
            }
        }
        
        // 格式化响应体
        function formatResponseBody() {
            const content = document.getElementById('response-body-content');
            if (!content) return;
            
            try {
                const jsonData = JSON.parse(content.textContent);
                const formatted = JSON.stringify(jsonData, null, 2)
                    .replace(/\\r\\n/g, '\n')
                    .replace(/\\n/g, '\n')
                    .replace(/\\t/g, '\t')
                    .replace(/\\"/g, '"');
                content.textContent = formatted;
                if (typeof Prism !== 'undefined') {
                    Prism.highlightElement(content);
                }
            } catch (e) {
                alert('<?=__('无法格式化，内容不是有效的JSON')?>');
            }
        }
        
        // 导入示例请求头
        function importExampleHeaders() {
            const example = window.currentApiExample;
            if (!example || !example.Headers) {
                return;
            }
            
            const headers = example.Headers;
            const headersEditor = document.getElementById('headers-editor');
            if (!headersEditor) return;
            
            // 清空现有请求头
            headersEditor.innerHTML = '';
            
            // 添加示例请求头
            if (typeof headers === 'object') {
                Object.entries(headers).forEach(([key, value]) => {
                    const row = document.createElement('div');
                    row.className = 'header-row';
                    row.innerHTML = `
                        <input type="text" class="header-key" placeholder="<?=__('Header名称')?>" value="${escapeHtml(key)}">
                        <input type="text" class="header-value" placeholder="<?=__('Header值')?>" value="${escapeHtml(String(value))}">
                        <button type="button" class="btn-remove" onclick="removeHeader(this)">×</button>
                    `;
                    headersEditor.appendChild(row);
                });
            }
        }
        
        // 导入示例请求体
        function importExampleBody() {
            const example = window.currentApiExample;
            if (!example || !example.Body) {
                return;
            }
            
            const bodyEl = document.getElementById('test-body');
            if (!bodyEl) return;
            
            let bodyText = '';
            try {
                if (typeof example.Body === 'string') {
                    try {
                        const parsed = JSON.parse(example.Body);
                        bodyText = JSON.stringify(parsed, null, 2)
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t')
                            .replace(/\\"/g, '"');
                    } catch (e) {
                        bodyText = example.Body
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t');
                    }
                } else {
                    bodyText = JSON.stringify(example.Body, null, 2)
                        .replace(/\\r\\n/g, '\n')
                        .replace(/\\n/g, '\n')
                        .replace(/\\t/g, '\t')
                        .replace(/\\"/g, '"');
                }
            } catch (e) {
                bodyText = JSON.stringify(example.Body, null, 2);
            }
            
            bodyEl.value = bodyText;
        }
        
        // 让在线测试面板在滚动时悬浮
        function initStickyTestPanel() {
            const testPanel = document.getElementById('api-test-panel');
            if (!testPanel) return;
            
            // 添加悬浮类
            testPanel.classList.add('sticky');
        }
        
        // HTML转义函数
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // 切换侧边栏
        function toggleSidebar() {
            const sidebar = document.getElementById('api-sidebar');
            sidebar.classList.toggle('collapsed');
        }
        
        // 初始化侧边栏拖拽调整宽度功能
        function initSidebarResize() {
            const sidebar = document.getElementById('api-sidebar');
            const apiTree = document.querySelector('.api-tree');
            if (!sidebar || !apiTree) return;
            
            let isResizing = false;
            let startX = 0;
            let startWidth = 0;
            
            // 鼠标按下事件
            const handleMouseDown = (e) => {
                // 检查是否点击在空白区域（不是节点）
                const target = e.target;
                
                // 如果点击的是jstree节点、链接或其他交互元素，不触发拖拽
                if (target.closest('.jstree-node') || 
                    target.closest('.jstree-anchor') ||
                    target.closest('a') ||
                    target.closest('button') ||
                    target.closest('.jstree-icon')) {
                    return;
                }
                
                // 检查是否在右侧边缘8px范围内
                const rect = apiTree.getBoundingClientRect();
                const isNearRightEdge = e.clientX >= rect.right - 8;
                
                // 检查是否点击在空白区域（树容器本身或空白处）
                const isBlankArea = target === apiTree || 
                                   target.closest('.api-tree') === apiTree ||
                                   (!target.closest('.jstree-node') && 
                                    !target.closest('.jstree-anchor') &&
                                    !target.closest('a') &&
                                    !target.closest('button') &&
                                    !target.closest('.jstree-icon'));
                
                // 在右侧边缘或空白区域都可以拖拽
                if (isNearRightEdge || isBlankArea) {
                    isResizing = true;
                    startX = e.clientX;
                    startWidth = sidebar.offsetWidth;
                    apiTree.classList.add('dragging');
                    document.body.style.cursor = 'col-resize';
                    document.body.style.userSelect = 'none';
                    e.preventDefault();
                    e.stopPropagation();
                }
            };
            
            // 鼠标移动事件
            const handleMouseMove = (e) => {
                if (!isResizing) return;
                
                const diff = e.clientX - startX;
                let newWidth = startWidth + diff;
                
                // 限制最小和最大宽度
                const minWidth = 300;
                const maxWidth = 800;
                newWidth = Math.max(minWidth, Math.min(maxWidth, newWidth));
                
                sidebar.style.width = newWidth + 'px';
                sidebar.style.transition = 'none'; // 拖拽时禁用过渡动画
                e.preventDefault();
            };
            
            // 鼠标释放事件
            const handleMouseUp = () => {
                if (isResizing) {
                    isResizing = false;
                    apiTree.classList.remove('dragging');
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                    sidebar.style.transition = 'width 0.3s ease'; // 恢复过渡动画
                    
                    // 保存宽度到localStorage
                    localStorage.setItem('api-sidebar-width', sidebar.offsetWidth + 'px');
                }
            };
            
            // 绑定事件
            apiTree.addEventListener('mousedown', handleMouseDown);
            document.addEventListener('mousemove', handleMouseMove);
            document.addEventListener('mouseup', handleMouseUp);
            
            // 恢复保存的宽度
            const savedWidth = localStorage.getItem('api-sidebar-width');
            if (savedWidth && !sidebar.classList.contains('collapsed')) {
                sidebar.style.width = savedWidth;
            }
        }
        
        // 切换主题
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('api-doc-theme', newTheme);
            
            const icon = document.getElementById('theme-icon');
            icon.textContent = newTheme === 'dark' ? '☀️' : '🌙';
        }
        
        // 初始化主题
        (function() {
            const savedTheme = localStorage.getItem('api-doc-theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            const icon = document.getElementById('theme-icon');
            icon.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
        })();
        
        // 显示登录模态框
        function showLoginModal() {
            document.getElementById('login-modal').classList.add('active');
        }
        
        // 处理登录
        async function handleLogin(event) {
            event.preventDefault();
            const formData = new FormData(event.target);
            const data = {
                username: formData.get('username'),
                password: formData.get('password')
            };
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.code === 200 && result.data) {
                    // 保存token和用户信息
                    localStorage.setItem(TOKEN_KEY, result.data.access_token || '');
                    localStorage.setItem(REFRESH_TOKEN_KEY, result.data.refresh_token || '');
                    localStorage.setItem(USER_KEY, JSON.stringify(result.data.user || {}));
                    
                    // 关闭登录模态框
                    document.getElementById('login-modal').classList.remove('active');
                    
                    // 更新登录状态显示
                    updateLoginStatus();
                    
                    alert('登录成功！');
                } else {
                    alert('登录失败：' + (result.msg || '未知错误'));
                }
            } catch (error) {
                console.error('Login error:', error);
                alert('登录失败：' + error.message);
            }
        }
        
        // 更新登录状态显示
        function updateLoginStatus() {
            const user = JSON.parse(localStorage.getItem(USER_KEY) || '{}');
            const token = localStorage.getItem(TOKEN_KEY);
            const loginBtn = document.querySelector('.btn-primary');
            
            if (token && user.username) {
                if (loginBtn) {
                    loginBtn.innerHTML = `<span>👤</span><span>${user.username}</span>`;
                    loginBtn.onclick = handleLogout;
                    loginBtn.title = '点击退出登录';
                }
            } else {
                if (loginBtn) {
                    loginBtn.innerHTML = `<span>🔐</span><span><?=__('登录')?></span>`;
                    loginBtn.onclick = showLoginModal;
                    loginBtn.title = '点击登录';
                }
            }
        }
        
        // 退出登录
        function handleLogout() {
            if (confirm('确定要退出登录吗？')) {
                localStorage.removeItem(TOKEN_KEY);
                localStorage.removeItem(REFRESH_TOKEN_KEY);
                localStorage.removeItem(USER_KEY);
                updateLoginStatus();
                alert('已退出登录');
            }
        }
        
        
        // 页面加载时更新登录状态和正式环境模式
        $(function() {
            updateLoginStatus();
            initProductionMode();
            initSidebarResize(); // 初始化侧边栏拖拽调整宽度功能
        });
    </script>
</body>
