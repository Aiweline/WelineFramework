    <script>
        // API数据
        const apiData = <?= json_encode($apis ?? [], JSON_UNESCAPED_UNICODE) ?>;
        const moduleDisplayNames = <?= json_encode($this->getData('moduleDisplayNames') ?? [], JSON_UNESCAPED_UNICODE) ?>;
        const selectedApiId = '<?= htmlspecialchars($apiId ?? '') ?>';
        const selectedApi = <?= json_encode($selectedApi ?? null, JSON_UNESCAPED_UNICODE) ?>;
        
        // 将selectedApi存储到全局变量
        window.selectedApi = selectedApi;
        
        // 存储token到localStorage
        const TOKEN_KEY = 'api_doc_access_token';
        const REFRESH_TOKEN_KEY = 'api_doc_refresh_token';
        const USER_KEY = 'api_doc_user';
        const SANDBOX_KEY = 'api_doc_sandbox_key';
        const PRODUCTION_MODE_KEY = 'api_doc_production_mode';
        
        // 获取沙盒密钥（从后端获取或使用默认值）
        const sandboxKey = '<?= \Weline\Framework\App\Env::getInstance()->getConfig('sandbox_key') ?? 'dev_sandbox_2024' ?>';
        
        // 正式环境调试模式
        let productionMode = localStorage.getItem(PRODUCTION_MODE_KEY) === 'true';
        
        // 初始化正式环境模式开关
        function initProductionMode() {
            const switchEl = document.getElementById('production-mode-switch');
            const toggleEl = document.getElementById('production-mode-toggle');
            if (switchEl && toggleEl) {
                switchEl.checked = productionMode;
                if (productionMode) {
                    toggleEl.classList.add('active');
                }
            }
        }
        
        // 切换正式环境模式
        function toggleProductionMode() {
            const switchEl = document.getElementById('production-mode-switch');
            const toggleEl = document.getElementById('production-mode-toggle');
            
            if (!switchEl || !toggleEl) {
                return;
            }
            
            if (switchEl.checked && !productionMode) {
                // 开启正式环境模式 - 显示警告
                if (confirm('⚠️ 警告：您即将开启正式环境调试模式！\n\n' +
                    '开启后，所有API请求将直接发送到正式环境，可能会：\n' +
                    '• 修改正式环境的数据\n' +
                    '• 影响正式环境的业务\n' +
                    '• 造成不可逆的数据损失\n\n' +
                    '请确认您已充分了解风险，并谨慎操作！\n\n' +
                    '是否继续开启？')) {
                    productionMode = true;
                    localStorage.setItem(PRODUCTION_MODE_KEY, 'true');
                    toggleEl.classList.add('active');
                    // 如果当前有选中的API，重新加载详情以显示警告
                    if (window.selectedApi) {
                        loadApiDetail(window.selectedApi);
                    }
                } else {
                    // 用户取消，恢复开关状态
                    switchEl.checked = false;
                }
            } else if (!switchEl.checked && productionMode) {
                // 关闭正式环境模式
                productionMode = false;
                localStorage.setItem(PRODUCTION_MODE_KEY, 'false');
                toggleEl.classList.remove('active');
                // 如果当前有选中的API，重新加载详情以移除警告
                if (window.selectedApi) {
                    loadApiDetail(window.selectedApi);
                }
            }
        }
        
        // 初始化jstree
        $(function() {
            if (Object.keys(apiData).length === 0) {
                $('#api-tree').html('<div class="empty-state"><p><?=__('暂无API文档')?></p></div>');
                return;
            }
            
            const treeData = buildTreeData(apiData);
            $('#api-tree').jstree({
                'core': {
                    'data': treeData,
                    'themes': {
                        'name': 'default',
                        'responsive': true,
                        'dots': true,  // 显示连接点
                        'stripes': false,  // 不显示条纹
                        'variant': 'large'  // 使用大尺寸变体
                    },
                    'animation': 200  // 展开/收起动画
                },
                'plugins': []  // 可以添加其他插件
            }).on('select_node.jstree', function(e, data) {
                const node = data.node;
                // 检查是否是API节点（有api属性）
                // jstree会将数据存储在node.original中，但我们的api是直接存储的
                const api = node.api || (node.original && (node.original.api || (node.original.original && node.original.original.api)));
                if (api) {
                    // 直接更新右侧内容，不跳转页面
                    console.log('Loading API detail:', api);
                    loadApiDetail(api);
                    
                    // 更新URL（不刷新页面）
                    const apiId = api.id || node.id || (node.a_attr && node.a_attr['data-api-id']);
                    if (apiId) {
                        const url = new URL(window.location);
                        url.searchParams.set('api_id', apiId);
                        window.history.pushState({}, '', url);
                    }
                } else {
                    console.log('Node does not have API data:', node, 'original:', node.original);
                }
            }).on('ready.jstree', function() {
                // 渲染HTML内容到jstree节点
                $('#api-tree').find('.jstree-anchor').each(function() {
                    const $anchor = $(this);
                    const $node = $anchor.closest('.jstree-node');
                    const nodeId = $node.attr('id');
                    if (nodeId) {
                        const node = $('#api-tree').jstree('get_node', nodeId);
                        if (node && node.text) {
                            // 如果text包含HTML，直接设置HTML
                            if (node.text.indexOf('<') !== -1) {
                                $anchor.html(node.text);
                            }
                        }
                    }
                });
                
                // 如果有选中的API，展开并选中，并加载详情
                if (selectedApiId) {
                    const node = $('#api-tree').jstree('get_node', selectedApiId);
                    const api = node ? (node.api || (node.original && (node.original.api || (node.original.original && node.original.original.api)))) : null;
                    if (api) {
                        // 加载API详情
                        loadApiDetail(api);
                        // 选中节点
                        $('#api-tree').jstree('select_node', selectedApiId);
                        // 展开所有父节点
                        const parents = $('#api-tree').jstree('get_path', selectedApiId, true);
                        parents.forEach(function(parentId) {
                            $('#api-tree').jstree('open_node', parentId);
                        });
                    }
                }
            });
            
        });
        
        // 构建树形数据
        function buildTreeData(apis) {
            const tree = [];
            for (const [moduleName, versions] of Object.entries(apis)) {
                // 使用display_name显示模块名称（去掉排序号）
                const displayName = moduleDisplayNames[moduleName] || moduleName;
                const moduleNode = {
                    id: 'module_' + moduleName,
                    text: displayName, // 使用display_name显示
                    icon: 'jstree-folder', // 模块使用文件夹图标
                    children: [],
                    state: { opened: true }
                };
                
                for (const [version, classes] of Object.entries(versions)) {
                    const versionNode = {
                        id: 'version_' + moduleName + '_' + version,
                        text: version,
                        icon: 'jstree-folder', // 版本使用文件夹图标
                        children: [],
                        state: { opened: true }
                    };
                    
                    for (const [className, methods] of Object.entries(classes)) {
                        // 提取类名（只显示最后一部分，去掉命名空间）
                        const classDisplayName = className.split('\\').pop() || className;
                        const classNode = {
                            id: 'class_' + moduleName + '_' + version + '_' + className,
                            text: classDisplayName,
                            icon: 'jstree-folder', // 类使用文件夹图标
                            children: [],
                            state: { opened: true }
                        };
                        
                        for (const api of methods) {
                            const apiId = 'api_' + moduleName + '_' + version + '_' + className + '_' + (api.method || '');
                            // 构建显示文本：请求方法（重点标记）+ 接口名称 + 地址（code样式）
                            const method = (api.route?.method || 'GET').toUpperCase();
                            const path = api.route?.path || '';
                            const summary = api.document?.summary || api.method || '';
                            // 使用HTML格式显示
                            const displayText = `<strong class="api-method-${method.toLowerCase()}">${method}</strong> ${summary} <code class="api-path-code">${path}</code>`;
                            classNode.children.push({
                                id: apiId,
                                text: displayText,
                                icon: 'jstree-route-icon', // 接口使用路由图标（十字路口图标）
                                api: api, // 直接存储api数据
                                a_attr: { 'data-api-id': apiId }
                            });
                        }
                        
                        versionNode.children.push(classNode);
                    }
                    
                    moduleNode.children.push(versionNode);
                }
                
                tree.push(moduleNode);
            }
            
            return tree;
        }
        
