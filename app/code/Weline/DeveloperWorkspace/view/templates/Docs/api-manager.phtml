        // 添加请求头
        function addHeader() {
            const editor = document.getElementById('headers-editor');
            if (!editor) return;
            
            const row = document.createElement('div');
            row.className = 'header-row';
            row.innerHTML = `
                <input type="text" class="header-key" placeholder="<?=__('Header名称')?>">
                <input type="text" class="header-value" placeholder="<?=__('Header值')?>">
                <button type="button" class="btn-remove" onclick="removeHeader(this)">×</button>
            `;
            editor.appendChild(row);
        }
        
        // 删除请求头
        function removeHeader(btn) {
            btn.closest('.header-row').remove();
        }
        
        // 发送测试请求
        async function sendTestRequest() {
            const api = window.selectedApi;
            if (!api) {
                showToast('<?=__('请先选择一个API接口')?>', 'error');
                return;
            }
            
            // 获取请求配置
            const method = document.getElementById('test-method').value;
            let url = document.getElementById('test-url').value;
            
            // 检查是否需要登录
            // 公开接口白名单（认证相关接口不需要登录）
            const publicApiPaths = [
                '/auth/login',
                '/auth/exchange',
                '/weline-api/auth/login',
                '/weline-api/auth/exchange',
                '/api/rest/v1/weline_api/auth/login',
                '/api/rest/v1/weline_api/auth/exchange'
            ];
            
            // 检查是否为公开接口
            const apiPath = api.route?.path || '';
            const isPublicApi = publicApiPaths.some(path => {
                return apiPath.includes(path) || url.includes(path);
            });
            
            // 如果有ACL注解且不是公开接口，则需要登录
            const requiresLogin = !isPublicApi && api.acl && (api.acl.class || api.acl.method);
            
            // 根据API类型获取对应的token
            const isBackendApi = api.route?.is_backend || false;
            let token = null;
            if (isBackendApi) {
                token = localStorage.getItem(BACKEND_TOKEN_KEY);
            } else {
                token = localStorage.getItem(TOKEN_KEY);
            }
            
            const isLoggedIn = !!token;
            
            if (requiresLogin && !isLoggedIn) {
                // 需要登录但未登录，显示提示并打开登录模态框
                const apiTypeText = isBackendApi ? '<?=__('后端')?>' : '<?=__('前端')?>';
                showToast('<?=__('此接口需要登录，请先登录%{1}API账户后再发起请求')?>'.replace('%{1}', apiTypeText), 'error');
                showLoginModal();
                return;
            }
            
            // 如果是GET请求，从请求参数编辑器获取参数并更新URL
            if (method === 'GET') {
                const paramsEditor = document.getElementById('request-params-editor');
                if (paramsEditor) {
                    const urlObj = new URL(url.split('?')[0]); // 获取基础URL
                    paramsEditor.querySelectorAll('.header-row').forEach(row => {
                        const key = row.querySelector('.header-key').value.trim();
                        const value = row.querySelector('.header-value').value.trim();
                        if (key && value) {
                            urlObj.searchParams.set(key, value);
                        }
                    });
                    url = urlObj.toString();
                }
            }
            
            // 获取请求头
            const headers = {};
            // 只从headers-editor获取请求头，不包括request-params-editor
            const headersEditor = document.getElementById('headers-editor');
            if (headersEditor) {
                headersEditor.querySelectorAll('.header-row').forEach(row => {
                    const key = row.querySelector('.header-key').value.trim();
                    const value = row.querySelector('.header-value').value.trim();
                    if (key && value) {
                        headers[key] = value;
                    }
                });
            }
            
            // 如果请求头中没有Authorization，且需要登录，则自动添加token
            if (!headers['Authorization'] && !headers['authorization']) {
                const isBackendApi = api.route?.is_backend || false;
                let token = null;
                if (isBackendApi) {
                    token = localStorage.getItem(BACKEND_TOKEN_KEY);
                } else {
                    token = localStorage.getItem(TOKEN_KEY);
                }
                
                if (token) {
                    headers['Authorization'] = 'Bearer ' + token;
                }
            }
            
            // 获取请求体
            let body = null;
            const bodyEl = document.getElementById('test-body');
            if (bodyEl && ['POST', 'PUT', 'PATCH'].includes(method)) {
                const bodyText = bodyEl.value.trim();
                if (bodyText) {
                    try {
                        // 验证JSON格式
                        JSON.parse(bodyText);
                        body = bodyText;
                    } catch (e) {
                        showToast('<?=__('请求体格式错误，请输入有效的JSON')?>', 'error');
                        return;
                    }
                }
            }
            
            // 添加沙盒参数（仅在非正式环境模式下）
            const requestUrl = new URL(url);
            if (!productionMode && sandboxKey) {
                requestUrl.searchParams.set('sandbox', sandboxKey);
            }
            
            // 显示响应区域
            const responseSection = document.getElementById('test-response-section');
            if (responseSection) {
                responseSection.style.display = 'block';
            }
            
            // 显示加载状态
            const responseInfo = document.getElementById('response-info');
            const responseHeadersBody = document.getElementById('response-headers-body');
            const responseBodyContent = document.getElementById('response-body-content');
            
            if (responseInfo) {
                responseInfo.innerHTML = '<div class="response-info-item"><label><?=__('状态')?>:</label><span>请求中...</span></div>';
            }
            if (responseHeadersBody) {
                responseHeadersBody.innerHTML = '';
            }
            if (responseBodyContent) {
                responseBodyContent.textContent = '';
            }
            
            // 禁用发送按钮
            const sendBtn = document.querySelector('.test-send-btn');
            if (sendBtn) {
                sendBtn.disabled = true;
            }
            
            // 显示"请求中"状态码
            const statusCodeEl = document.getElementById('request-status-code');
            if (statusCodeEl) {
                statusCodeEl.textContent = '请求中...';
                statusCodeEl.className = 'request-status-code loading';
                statusCodeEl.style.display = 'inline-block';
            }
            
            const startTime = Date.now();
            
            try {
                const response = await fetch(requestUrl.toString(), {
                    method: method,
                    headers: headers,
                    body: body
                });
                
                const endTime = Date.now();
                const duration = endTime - startTime;
                
                // 获取响应头
                const responseHeaders = {};
                response.headers.forEach((value, key) => {
                    responseHeaders[key] = value;
                });
                
                // 获取响应体
                const responseText = await response.text();
                
                // 解析响应JSON，提取code和msg
                let responseCode = '';
                let responseMsg = '';
                try {
                    const jsonData = JSON.parse(responseText);
                    if (jsonData.code !== undefined) {
                        responseCode = jsonData.code;
                    }
                    if (jsonData.msg !== undefined) {
                        responseMsg = jsonData.msg;
                    }
                } catch (e) {
                    // 不是JSON格式，忽略
                }
                
                // 更新请求状态码显示（在发送按钮左边）
                const statusCodeEl = document.getElementById('request-status-code');
                if (statusCodeEl) {
                    // 根据HTTP状态码设置颜色类
                    let statusClass = 'status-' + response.status;
                    
                    // 显示HTTP状态码
                    let statusText = response.status + ' ' + response.statusText;
                    statusCodeEl.textContent = statusText;
                    statusCodeEl.className = 'request-status-code ' + statusClass;
                    statusCodeEl.style.display = 'inline-block';
                    statusCodeEl.title = response.status + ' ' + response.statusText;
                }
                
                // 更新响应信息
                if (responseInfo) {
                    const statusClass = response.ok ? 'success' : 'error';
                    let infoHtml = `
                        <div class="response-info-item">
                            <label><?=__('状态码')?>:</label>
                            <span class="response-status-badge ${statusClass}">${response.status} ${response.statusText}</span>
                        </div>
                    `;
                    if (responseCode !== '') {
                        infoHtml += `
                        <div class="response-info-item">
                            <label><?=__('响应Code')?>:</label>
                            <span>${escapeHtml(responseCode)}</span>
                        </div>
                        `;
                    }
                    if (responseMsg !== '') {
                        infoHtml += `
                        <div class="response-info-item">
                            <label><?=__('响应消息')?>:</label>
                            <span>${escapeHtml(responseMsg)}</span>
                        </div>
                        `;
                    }
                    infoHtml += `
                        <div class="response-info-item">
                            <label><?=__('请求时间')?>:</label>
                            <span>${duration}ms</span>
                        </div>
                        <div class="response-info-item">
                            <label><?=__('响应大小')?>:</label>
                            <span>${formatBytes(responseText.length)}</span>
                        </div>
                    `;
                    responseInfo.innerHTML = infoHtml;
                }
                
                // 更新响应头
                if (responseHeadersBody) {
                    responseHeadersBody.innerHTML = '';
                    Object.entries(responseHeaders).forEach(([key, value]) => {
                        const row = document.createElement('tr');
                        row.innerHTML = `<td>${escapeHtml(key)}</td><td>${escapeHtml(value)}</td>`;
                        responseHeadersBody.appendChild(row);
                    });
                }
                
                // 更新响应体（美化处理）
                if (responseBodyContent) {
                    let formattedResponse = responseText;
                    try {
                        const jsonData = JSON.parse(responseText);
                        formattedResponse = JSON.stringify(jsonData, null, 2)
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t')
                            .replace(/\\"/g, '"');
                    } catch (e) {
                        // 不是JSON，直接显示，但处理转义字符
                        formattedResponse = responseText
                            .replace(/\\r\\n/g, '\n')
                            .replace(/\\n/g, '\n')
                            .replace(/\\t/g, '\t');
                    }
                    responseBodyContent.textContent = formattedResponse;
                    
                    // 高亮代码
                    if (typeof Prism !== 'undefined') {
                        Prism.highlightElement(responseBodyContent);
                    }
                }
                
            } catch (error) {
                // 显示错误状态码
                const statusCodeEl = document.getElementById('request-status-code');
                if (statusCodeEl) {
                    statusCodeEl.textContent = '错误: ' + error.message;
                    statusCodeEl.className = 'request-status-code error';
                    statusCodeEl.style.display = 'inline-block';
                    statusCodeEl.title = error.message;
                }
                
                if (responseInfo) {
                    responseInfo.innerHTML = `
                        <div class="response-info-item">
                            <label><?=__('状态')?>:</label>
                            <span class="response-status-badge error"><?=__('请求失败')?></span>
                        </div>
                        <div class="response-info-item">
                            <label><?=__('错误')?>:</label>
                            <span>${escapeHtml(error.message)}</span>
                        </div>
                    `;
                }
                if (responseBodyContent) {
                    responseBodyContent.textContent = '错误：' + error.message;
                }
            } finally {
                // 恢复发送按钮
                if (sendBtn) {
                    sendBtn.disabled = false;
                }
            }
        }
        
        // 格式化字节大小
        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }
        
