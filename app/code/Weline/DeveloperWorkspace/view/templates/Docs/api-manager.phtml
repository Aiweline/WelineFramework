        });
        
        // 构建树形数据（根据API类型过滤）
        function buildTreeData(apis, apiType = 'frontend') {
            const tree = [];
            for (const [moduleName, versions] of Object.entries(apis)) {
                // 使用display_name显示模块名称（去掉排序号）
                const displayName = moduleDisplayNames[moduleName] || moduleName;
                const moduleNode = {
                    id: 'module_' + moduleName,
                    text: displayName, // 使用display_name显示
                    icon: 'jstree-folder', // 模块使用文件夹图标
                    children: [],
                    state: { opened: true },
                    search: [displayName, moduleName].filter(k => k).join(' ').toLowerCase()
                };
                
                for (const [version, classes] of Object.entries(versions)) {
                    const versionNode = {
                        id: 'version_' + moduleName + '_' + version,
                        text: version,
                        icon: 'jstree-folder', // 版本使用文件夹图标
                        children: [],
                        state: { opened: true },
                        search: version.toLowerCase()
                    };
                    
                    for (const [className, methods] of Object.entries(classes)) {
                        // 提取类名（只显示最后一部分，去掉命名空间）
                        const classDisplayName = className.split('\\').pop() || className;
                        const classNode = {
                            id: 'class_' + moduleName + '_' + version + '_' + className,
                            text: classDisplayName,
                            icon: 'jstree-folder', // 类使用文件夹图标
                            children: [],
                            state: { opened: true },
                            search: [classDisplayName, className].filter(k => k).join(' ').toLowerCase()
                        };
                        
                        for (const api of methods) {
                            // 根据API类型过滤
                            const isBackendApi = api.route?.is_backend || false;
                            if (apiType === 'frontend' && isBackendApi) {
                                continue; // 前端API模式，跳过后端API
                            }
                            if (apiType === 'backend' && !isBackendApi) {
                                continue; // 后端API模式，跳过前端API
                            }
                            
                            const apiId = 'api_' + moduleName + '_' + version + '_' + className + '_' + (api.method || '');
                            // 构建显示文本：请求方法（重点标记）+ 接口名称 + 地址（code样式）
                            const method = (api.route?.method || 'GET').toUpperCase();
                            const path = api.route?.path || '';
                            const summary = api.document?.summary || api.method || '';
                            // 使用HTML格式显示
                            const displayText = `<strong class="api-method-${method.toLowerCase()}">${method}</strong> ${summary} <code class="api-path-code">${path}</code>`;
                            // 构建搜索关键词（用于jstree搜索，包含方法、摘要、路径、类名等）
                            const searchKeywords = [
                                method,
                                summary,
                                path,
                                classDisplayName,
                                className,
                                api.document?.description || '',
                                (api.parameters || []).map(p => p.name || '').join(' ')
                            ].filter(k => k).join(' ').toLowerCase();
                            classNode.children.push({
                                id: apiId,
                                text: displayText,
                                icon: 'jstree-route-icon', // 接口使用路由图标（十字路口图标）
                                api: api, // 直接存储api数据
                                a_attr: { 'data-api-id': apiId },
                                // 添加搜索关键词，jstree search插件会搜索这个字段
                                search: searchKeywords
                            });
                        }
                        
                        // 如果类下没有API（被过滤掉了），跳过这个类
                        if (classNode.children.length === 0) {
                            continue;
                        }
                        
                        versionNode.children.push(classNode);
                    }
                    
                    moduleNode.children.push(versionNode);
                }
                
                tree.push(moduleNode);
            }
            
            return tree;
        }
        
