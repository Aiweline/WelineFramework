        // 根据请求参数更新URL
        function updateUrlFromParams() {
            const urlEl = document.getElementById('test-url');
            if (!urlEl) return;
            
            const baseUrl = urlEl.value.split('?')[0]; // 获取基础URL（去掉参数部分）
            const paramsEditor = document.getElementById('request-params-editor');
            if (!paramsEditor) return;
            
            const url = new URL(baseUrl);
            paramsEditor.querySelectorAll('.header-row').forEach(row => {
                const key = row.querySelector('.header-key').value.trim();
                const value = row.querySelector('.header-value').value.trim();
                if (key) {
                    if (value) {
                        url.searchParams.set(key, value);
                    } else {
                        url.searchParams.delete(key);
                    }
                }
            });
            
            urlEl.value = url.toString();
        }
        
