        // 加载测试面板
        function loadTestPanel(api) {
            const testPanel = document.getElementById('api-test-panel') || document.querySelector('.api-test-panel');
            if (!testPanel) return;
            
            // 隐藏状态码显示（加载新API时重置）
            const statusCodeEl = document.getElementById('request-status-code');
            if (statusCodeEl) {
                statusCodeEl.style.display = 'none';
            }
            
            const method = (api.route?.method || 'GET').toUpperCase();
            let path = api.route?.path || '';
            
            // 构建完整URL - 使用 window.api 函数
            let fullUrl = '';
            if (path.startsWith('http')) {
                // 已经是完整URL，直接使用
                fullUrl = path;
            } else {
                // 判断是前端API还是后端API
                const isBackendApi = api.route?.is_backend || false;
                
                // 处理路径：移除开头的斜杠
                let cleanPath = path.replace(/^\//, '');
                
                // 移除路径中可能包含的 area 前缀、货币和语言（因为 window.api 会自动添加）
                const pathSegments = cleanPath.split('/');
                const filteredSegments = [];
                for (let i = 0; i < pathSegments.length; i++) {
                    const segment = pathSegments[i];
                    // 跳过 area 前缀
                    if (segment === API_AREA || segment === API_ADMIN_AREA) {
                        continue;
                    }
                    // 跳过货币（3位大写字母）
                    if (segment.match(/^[A-Z]{3}$/)) {
                        continue;
                    }
                    // 跳过语言（格式：zh_Hans_CN）
                    if (segment.match(/^[a-z]{2}_[A-Z][a-z]+(_[A-Z]{2})?$/)) {
                        continue;
                    }
                    filteredSegments.push(segment);
                }
                cleanPath = filteredSegments.join('/');
                
                if (isBackendApi) {
                    fullUrl = window.backend_api(cleanPath);
                } else {
                    fullUrl = window.api(cleanPath);
                }
            }
            
            // 默认请求头
            const defaultHeaders = [
                { key: 'Content-Type', value: 'application/json' }
            ];
            
            // 根据API类型获取对应的token并添加Authorization头
            const isBackendApi = api.route?.is_backend || false;
            let token = null;
            if (isBackendApi) {
                token = localStorage.getItem(BACKEND_TOKEN_KEY);
            } else {
                token = localStorage.getItem(TOKEN_KEY);
            }
            
            if (token) {
                defaultHeaders.push({ key: 'Authorization', value: 'Bearer ' + token });
            }
            
            // 默认请求体（美化处理）
            let defaultBody = '{}';
            let exampleBody = null;
            // 存储示例数据到全局，供导入函数使用
            window.currentApiExample = api.example || null;
            // 优先使用body，兼容Body
            if (api.example) {
                exampleBody = api.example.body || api.example.Body;
                if (exampleBody) {
                    try {
                        if (typeof exampleBody === 'string') {
                            // 尝试解析JSON字符串
                            try {
                                const parsed = JSON.parse(exampleBody);
                                defaultBody = JSON.stringify(parsed, null, 2);
                            } catch (e) {
                                // 不是JSON，直接使用字符串
                                defaultBody = exampleBody;
