        // 初始化侧边栏拖拽调整宽度功能
        function initSidebarResize() {
            const sidebar = document.getElementById('api-sidebar');
            const apiTree = document.querySelector('.api-tree');
            if (!sidebar || !apiTree) return;
            
            let isResizing = false;
            let startX = 0;
            let startWidth = 0;
            
            // 鼠标按下事件
            const handleMouseDown = (e) => {
                // 检查是否点击在空白区域（不是节点）
                const target = e.target;
                
                // 如果点击的是jstree节点、链接或其他交互元素，不触发拖拽
                if (target.closest('.jstree-node') || 
                    target.closest('.jstree-anchor') ||
                    target.closest('a') ||
                    target.closest('button') ||
                    target.closest('.jstree-icon')) {
                    return;
                }
                
                // 检查是否在右侧边缘8px范围内
                const rect = apiTree.getBoundingClientRect();
                const isNearRightEdge = e.clientX >= rect.right - 8;
                
                // 检查是否点击在空白区域（树容器本身或空白处）
                const isBlankArea = target === apiTree || 
                                   target.closest('.api-tree') === apiTree ||
                                   (!target.closest('.jstree-node') && 
                                    !target.closest('.jstree-anchor') &&
                                    !target.closest('a') &&
                                    !target.closest('button') &&
                                    !target.closest('.jstree-icon'));
                
                // 在右侧边缘或空白区域都可以拖拽
                if (isNearRightEdge || isBlankArea) {
                    isResizing = true;
                    startX = e.clientX;
                    startWidth = sidebar.offsetWidth;
                    apiTree.classList.add('dragging');
                    document.body.style.cursor = 'col-resize';
                    document.body.style.userSelect = 'none';
                    e.preventDefault();
                    e.stopPropagation();
                }
            };
            
            // 鼠标移动事件
            const handleMouseMove = (e) => {
                if (!isResizing) return;
                
                const diff = e.clientX - startX;
                let newWidth = startWidth + diff;
                
                // 限制最小和最大宽度
                const minWidth = 300;
                const maxWidth = 800;
                newWidth = Math.max(minWidth, Math.min(maxWidth, newWidth));
                
                sidebar.style.width = newWidth + 'px';
                sidebar.style.transition = 'none'; // 拖拽时禁用过渡动画
                e.preventDefault();
            };
            
            // 鼠标释放事件
            const handleMouseUp = () => {
                if (isResizing) {
                    isResizing = false;
                    apiTree.classList.remove('dragging');
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                    sidebar.style.transition = 'width 0.3s ease'; // 恢复过渡动画
                    
                    // 保存宽度到localStorage
                    localStorage.setItem('api-sidebar-width', sidebar.offsetWidth + 'px');
                }
            };
            
            // 绑定事件
            apiTree.addEventListener('mousedown', handleMouseDown);
            document.addEventListener('mousemove', handleMouseMove);
            document.addEventListener('mouseup', handleMouseUp);
            
            // 恢复保存的宽度
            const savedWidth = localStorage.getItem('api-sidebar-width');
            if (savedWidth && !sidebar.classList.contains('collapsed')) {
                sidebar.style.width = savedWidth;
            }
        }
        
