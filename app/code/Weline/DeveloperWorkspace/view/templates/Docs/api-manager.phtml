        // 处理登录
        async function handleLogin(event) {
            event.preventDefault();
            const formData = new FormData(event.target);
            const data = {
                username: formData.get('username'),
                password: formData.get('password')
            };
            
            // 根据当前选中的API类型确定登录接口
            const isBackendApi = window.selectedApi?.route?.is_backend || currentApiType === 'backend';
            // 使用 window.api 函数生成登录URL
            let loginUrl = window.api('rest/v1/weline_api/auth/login', isBackendApi);
            if (isBackendApi) {
                // 后端API登录接口
                loginUrl = window.backend_api('rest/v1/weline_api/backend/auth/login');
            }
            
            try {
                const response = await fetch(loginUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.code === 200 && result.data) {
                    if (isBackendApi) {
                        // 后端API：保存后端token和用户信息
                        localStorage.setItem(BACKEND_TOKEN_KEY, result.data.token || result.data.access_token || '');
                        if (result.data.refresh_token) {
                            localStorage.setItem(BACKEND_REFRESH_TOKEN_KEY, result.data.refresh_token);
                        }
                        localStorage.setItem(BACKEND_USER_KEY, JSON.stringify(result.data.user || {}));
                    } else {
                        // 前端API：保存前端token和用户信息
                        localStorage.setItem(TOKEN_KEY, result.data.access_token || '');
                        localStorage.setItem(REFRESH_TOKEN_KEY, result.data.refresh_token || '');
                        localStorage.setItem(USER_KEY, JSON.stringify(result.data.user || {}));
                    }
                    
                    // 关闭登录模态框
                    closeLoginModal();
                    
                    // 更新登录状态显示
                    updateLoginStatus();
                    
                    // 更新测试面板按钮状态（如果当前有选中的API）
                    if (window.selectedApi) {
                        loadTestPanel(window.selectedApi);
                    }
                    
                    showToast('登录成功！');
                } else {
                    showToast('登录失败：' + (result.msg || '未知错误'), 'error');
                }
            } catch (error) {
                console.error('Login error:', error);
                showToast('登录失败：' + error.message, 'error');
            }
        }
        
        // 更新登录状态显示
        function updateLoginStatus() {
            // 根据当前选中的API类型获取对应的用户和token
            const isBackendApi = window.selectedApi?.route?.is_backend || currentApiType === 'backend';
            let user, token;
            
            if (isBackendApi) {
                user = JSON.parse(localStorage.getItem(BACKEND_USER_KEY) || '{}');
                token = localStorage.getItem(BACKEND_TOKEN_KEY);
            } else {
                user = JSON.parse(localStorage.getItem(USER_KEY) || '{}');
                token = localStorage.getItem(TOKEN_KEY);
            }
            
            const loginBtn = document.querySelector('.btn-primary');
            
            if (token && user.username) {
                if (loginBtn) {
                    loginBtn.innerHTML = `<span>👤</span><span>${user.username}</span>`;
                    loginBtn.onclick = handleLogout;
                    loginBtn.title = '点击退出登录';
                }
            } else {
                if (loginBtn) {
                    loginBtn.innerHTML = `<span>🔐</span><span><?=__('登录')?></span>`;
                    loginBtn.onclick = showLoginModal;
                    loginBtn.title = '点击登录';
                }
            }
        }
        
        // 退出登录
        function handleLogout() {
            if (confirm('确定要退出登录吗？')) {
                // 根据当前选中的API类型清除对应的token
                const isBackendApi = window.selectedApi?.route?.is_backend || currentApiType === 'backend';
                
                if (isBackendApi) {
                    localStorage.removeItem(BACKEND_TOKEN_KEY);
                    localStorage.removeItem(BACKEND_REFRESH_TOKEN_KEY);
                    localStorage.removeItem(BACKEND_USER_KEY);
                } else {
                    localStorage.removeItem(TOKEN_KEY);
                    localStorage.removeItem(REFRESH_TOKEN_KEY);
                    localStorage.removeItem(USER_KEY);
                }
                
                updateLoginStatus();
                showToast('已退出登录');
                
                // 如果当前有选中的API，重新加载测试面板
                if (window.selectedApi) {
                    loadTestPanel(window.selectedApi);
                }
            }
        }
        
        
