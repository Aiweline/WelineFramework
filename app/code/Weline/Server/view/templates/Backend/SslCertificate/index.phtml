<script>
(function() {
    'use strict';

    var baseUrl = '<?= $this->getBackendUrl('*/backend/ssl-certificate/') ?>';

    function getSelectedProvider() {
        var select = document.querySelector('#requestForm select[name="provider"]');
        return select ? select.value : 'letsencrypt';
    }

    function hideRequestModal() {
        var modalEl = document.getElementById('requestModal');
        if (!modalEl) return;
        var bsModal = (typeof bootstrap !== 'undefined' && bootstrap.Modal)
            ? bootstrap.Modal.getInstance(modalEl)
            : null;
        if (bsModal) {
            bsModal.hide();
        } else {
            modalEl.classList.remove('show');
            modalEl.style.display = 'none';
            document.body.classList.remove('modal-open');
            var backdrop = document.querySelector('.modal-backdrop');
            if (backdrop) backdrop.remove();
        }
    }

    window.toggleHttps = async function(domain, enabled) {
        try {
            var response = await fetch(baseUrl + 'toggle-https', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'domain=' + encodeURIComponent(domain) + '&enabled=' + (enabled ? 1 : 0)
            });
            var result = await response.json();
            if (result.success) {
                BackendToast.success(result.message);
                if (enabled) {
                    BackendToast.warning('<?= __('请重启服务器使配置生效') ?>');
                }
            } else {
                BackendToast.error(result.message);
                var el = document.getElementById('https_' + btoa(domain).replace(/[^a-zA-Z0-9]/g, ''));
                if (el) el.checked = !enabled;
            }
        } catch (e) {
            BackendToast.error(e.message);
        }
    };

    window.requestCertificate = async function(domain) {
        BackendConfirm.show('<?= __('确定要为此域名申请证书吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            BackendConfirm.showInput('<?= __('请输入联系邮箱') ?>', {defaultValue: 'admin@' + domain}).then(async function(email) {
                if (!email) return;
                var provider = getSelectedProvider();
                BackendToast.info('<?= __('正在申请证书，请稍候...') ?>');
                try {
                    var response = await fetch(baseUrl + 'request', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                        body: 'domain=' + encodeURIComponent(domain) + '&email=' + encodeURIComponent(email) + '&provider=' + encodeURIComponent(provider)
                    });
                    var result = await response.json();
                    if (result.success) {
                        BackendToast.success(result.message);
                        setTimeout(function() { location.reload(); }, 1500);
                    } else {
                        BackendToast.error(result.message);
                    }
                } catch (e) {
                    BackendToast.error(e.message);
                }
            });
        });
    };

    window.renewCertificate = async function(domain) {
        BackendConfirm.show('<?= __('确定要续签此证书吗？') ?>').then(async function(confirmed) {
            if (!confirmed) return;
            BackendToast.info('<?= __('正在续签证书，请稍候...') ?>');
            try {
                var response = await fetch(baseUrl + 'renew', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: 'domain=' + encodeURIComponent(domain)
                });
                var result = await response.json();
                if (result.success) {
                    BackendToast.success(result.message);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(result.message);
                }
            } catch (e) {
                BackendToast.error(e.message);
            }
        });
    };

    window.deleteCertificate = async function(domain) {
        BackendConfirm.show('<?= __('确定要删除此证书吗？此操作不可恢复！') ?>').then(async function(confirmed) {
            if (!confirmed) return;
            try {
                var response = await fetch(baseUrl + 'delete', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: 'domain=' + encodeURIComponent(domain)
                });
                var result = await response.json();
                if (result.success) {
                    BackendToast.success(result.message);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(result.message);
                }
            } catch (e) {
                BackendToast.error(e.message);
            }
        });
    };

    window.syncDomains = function() {
        BackendConfirm.showInput('<?= __('请输入联系邮箱（用于申请证书）') ?>', {defaultValue: 'admin@localhost'}).then(async function(email) {
            if (!email) return;
            try {
                var response = await fetch(baseUrl + 'sync', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: 'email=' + encodeURIComponent(email)
                });
                var result = await response.json();
                if (result.success) {
                    BackendToast.success(result.message);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(result.message);
                }
            } catch (e) {
                BackendToast.error(e.message);
            }
        });
    };

    window.submitRequest = async function() {
        var form = document.getElementById('requestForm');
        var formData = new FormData(form);
        BackendToast.info('<?= __('正在申请证书，请稍候...') ?>');
        try {
            var response = await fetch(baseUrl + 'request', {
                method: 'POST',
                body: new URLSearchParams(formData)
            });
            var result = await response.json();
            if (result.success) {
                BackendToast.success(result.message);
                hideRequestModal();
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                BackendToast.error(result.message);
            }
        } catch (e) {
            BackendToast.error(e.message);
        }
    };

    // --- 批量操作 ---
    var batchBar = document.getElementById('sslCertBatchBar');
    var countEl = document.getElementById('sslCertSelectedCount');
    var selectAllEl = document.getElementById('sslCertSelectAll');

    function getCheckedDomains(opts) {
        var checkboxes = document.querySelectorAll('.ssl-cert-row-check:checked');
        var domains = [];
        checkboxes.forEach(function(cb) {
            if (opts && opts.skipProtected && cb.getAttribute('data-protected') === '1') {
                return;
            }
            domains.push(cb.getAttribute('data-domain'));
        });
        return domains;
    }

    function getAllCheckedDomains() {
        var checkboxes = document.querySelectorAll('.ssl-cert-row-check:checked');
        var domains = [];
        checkboxes.forEach(function(cb) { domains.push(cb.getAttribute('data-domain')); });
        return domains;
    }

    function updateBatchBar() {
        var all = getAllCheckedDomains();
        var count = all.length;
        if (countEl) { countEl.textContent = count; }
        if (batchBar) { batchBar.style.display = count > 0 ? '' : 'none'; }
        var allBoxes = document.querySelectorAll('.ssl-cert-row-check');
        if (selectAllEl) {
            selectAllEl.checked = allBoxes.length > 0 && count === allBoxes.length;
            selectAllEl.indeterminate = count > 0 && count < allBoxes.length;
        }
    }

    var SslCertBatch = {};

    SslCertBatch.toggleAll = function(checked) {
        document.querySelectorAll('.ssl-cert-row-check').forEach(function(cb) { cb.checked = checked; });
        updateBatchBar();
    };

    SslCertBatch.updateSelection = function() {
        updateBatchBar();
    };

    SslCertBatch.clearSelection = function() {
        document.querySelectorAll('.ssl-cert-row-check').forEach(function(cb) { cb.checked = false; });
        if (selectAllEl) { selectAllEl.checked = false; selectAllEl.indeterminate = false; }
        updateBatchBar();
    };

    SslCertBatch.batchDelete = function() {
        var domains = getCheckedDomains({skipProtected: true});
        var allSelected = getAllCheckedDomains();
        var protectedCount = allSelected.length - domains.length;

        if (domains.length === 0) {
            if (protectedCount > 0) {
                BackendToast.warning('<?= __('所选证书均为本地域名证书，不允许删除') ?>');
            } else {
                BackendToast.warning('<?= __('请先选择要删除的证书') ?>');
            }
            return;
        }

        var msg = '<?= __('确定要删除选中的 ') ?>' + domains.length + ' <?= __(' 个证书吗？此操作不可恢复！') ?>';
        if (protectedCount > 0) {
            msg += '\n<?= __('（本地域名证书将被自动跳过）') ?>';
        }

        BackendConfirm.show(msg).then(async function(confirmed) {
            if (!confirmed) return;
            BackendToast.info('<?= __('正在批量删除，请稍候...') ?>');
            try {
                var body = new URLSearchParams();
                domains.forEach(function(d) { body.append('domains[]', d); });
                var response = await fetch(baseUrl + 'batch-delete', {
                    method: 'POST',
                    body: body
                });
                var result = await response.json();
                if (result.success) {
                    BackendToast.success(result.message);
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    BackendToast.error(result.message);
                }
            } catch (e) {
                BackendToast.error(e.message);
            }
        });
    };

    SslCertBatch.batchRenew = function() {
        var domains = getAllCheckedDomains();
        if (domains.length === 0) {
            BackendToast.warning('<?= __('请先选择要续签的证书') ?>');
            return;
        }

        BackendConfirm.show('<?= __('确定要批量续签选中的 ') ?>' + domains.length + ' <?= __(' 个证书吗？') ?>').then(async function(confirmed) {
            if (!confirmed) return;
            BackendToast.info('<?= __('正在批量续签，请稍候...') ?>');
            try {
                var body = new URLSearchParams();
                domains.forEach(function(d) { body.append('domains[]', d); });
                var response = await fetch(baseUrl + 'batch-renew', {
                    method: 'POST',
                    body: body
                });
                var result = await response.json();
                if (result.success) {
                    BackendToast.success(result.message);
                } else {
                    BackendToast.warning(result.message);
                }
                if (result.errors && result.errors.length > 0) {
                    result.errors.forEach(function(err) { BackendToast.error(err); });
                }
                setTimeout(function() { location.reload(); }, 2000);
            } catch (e) {
                BackendToast.error(e.message);
            }
        });
    };

    window.SslCertBatch = SslCertBatch;
})();
</script>
