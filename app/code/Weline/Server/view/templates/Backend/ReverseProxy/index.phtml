<script>
const reverseProxyUrls = <?= json_encode([
    'apply' => $this->getUrl('*/backend/reverse-proxy/apply'),
    'toggleStatus' => $this->getUrl('*/backend/reverse-proxy/toggle-status'),
    'delete' => $this->getUrl('*/backend/reverse-proxy/delete'),
    'testConnection' => $this->getUrl('*/backend/reverse-proxy/test-connection'),
], $jsonForScriptFlags) ?>;
const reverseProxyMessages = <?= json_encode([
    'applyConfirm' => (string)__('确定要应用配置到 Gateway 吗？'),
    'deleteConfirm' => (string)__('确定要删除此规则吗？'),
    'applyFailed' => (string)__('应用失败'),
    'requestFailed' => (string)__('请求失败'),
    'operationFailed' => (string)__('操作失败'),
    'deleteFailed' => (string)__('删除失败'),
    'connectionSuccess' => (string)__('连接成功'),
    'connectionFailed' => (string)__('连接失败'),
    'confirmUnavailable' => (string)__('确认组件不可用，请刷新页面后重试'),
], $jsonForScriptFlags) ?>;

document.addEventListener('click', function(event) {
    const trigger = event.target.closest('[data-reverse-proxy-action]');
    if (!trigger) {
        return;
    }

    const action = trigger.dataset.reverseProxyAction;
    if (action === 'apply') {
        applyConfig();
        return;
    }
    if (action === 'reload-page') {
        location.reload();
        return;
    }
    if (action === 'test-connection') {
        testConnection(
            Number(trigger.dataset.proxyId || 0),
            trigger.dataset.backendHost || '',
            Number(trigger.dataset.backendPort || 0),
            trigger.dataset.backendSsl === '1'
        );
        return;
    }
    if (action === 'toggle-status') {
        toggleStatus(Number(trigger.dataset.proxyId || 0), trigger.dataset.status || '');
        return;
    }
    if (action === 'delete') {
        deleteProxy(Number(trigger.dataset.proxyId || 0));
    }
});

function showReverseProxyToast(type, message) {
    const text = String(message || reverseProxyMessages.operationFailed);
    if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
        window.BackendToast[type](text);
        return;
    }

    const logger = type === 'error' ? 'error' : 'log';
    if (window.console && typeof window.console[logger] === 'function') {
        window.console[logger](text);
    }
}

function confirmReverseProxyAction(message) {
    if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
        return window.BackendConfirm.show(message);
    }

    showReverseProxyToast('error', reverseProxyMessages.confirmUnavailable);
    return Promise.resolve(false);
}

function requestReverseProxy(url, body) {
    return fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(body || {})
    }).then(res => res.json());
}

function applyConfig() {
    confirmReverseProxyAction(reverseProxyMessages.applyConfirm).then(confirmed => {
        if (!confirmed) {
            return;
        }

        requestReverseProxy(reverseProxyUrls.apply, {})
            .then(data => {
                if (data.success) {
                    showReverseProxyToast('success', data.message);
                    location.reload();
                } else {
                    showReverseProxyToast('error', reverseProxyMessages.applyFailed + ': ' + (data.message || reverseProxyMessages.operationFailed));
                }
            })
            .catch(err => showReverseProxyToast('error', reverseProxyMessages.requestFailed + ': ' + err));
    })
}

function toggleStatus(proxyId, status) {
    requestReverseProxy(reverseProxyUrls.toggleStatus, {proxy_id: proxyId, status: status})
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            showReverseProxyToast('error', reverseProxyMessages.operationFailed + ': ' + (data.message || reverseProxyMessages.operationFailed));
        }
    })
    .catch(err => showReverseProxyToast('error', reverseProxyMessages.requestFailed + ': ' + err));
}

function deleteProxy(proxyId) {
    confirmReverseProxyAction(reverseProxyMessages.deleteConfirm).then(confirmed => {
        if (!confirmed) {
            return;
        }

        requestReverseProxy(reverseProxyUrls.delete, {proxy_id: proxyId})
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    showReverseProxyToast('error', reverseProxyMessages.deleteFailed + ': ' + (data.message || reverseProxyMessages.operationFailed));
                }
            })
            .catch(err => showReverseProxyToast('error', reverseProxyMessages.requestFailed + ': ' + err));
    })
}

function testConnection(proxyId, host, port, ssl) {
    requestReverseProxy(reverseProxyUrls.testConnection, {backend_host: host, backend_port: port, backend_ssl: ssl})
    .then(data => {
        if (data.success) {
            showReverseProxyToast('success', reverseProxyMessages.connectionSuccess + ' (' + data.latency_ms + 'ms)');
        } else {
            showReverseProxyToast('error', reverseProxyMessages.connectionFailed + ': ' + (data.message || reverseProxyMessages.operationFailed));
        }
    })
    .catch(err => showReverseProxyToast('error', reverseProxyMessages.requestFailed + ': ' + err));
}
</script>
