<script>
function applyConfig() {
    if (!confirm('<?php echo __('确定要应用配置到 Gateway 吗？'); ?>')) {
        return;
    }

    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/apply'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({})
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?php echo __('应用失败'); ?>: ' + data.message);
        }
    })
    .catch(err => alert('<?php echo __('请求失败'); ?>: ' + err));
}

function toggleStatus(proxyId, status) {
    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/toggle-status'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({proxy_id: proxyId, status: status})
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('<?php echo __('操作失败'); ?>: ' + data.message);
        }
    });
}

function deleteProxy(proxyId) {
    if (!confirm('<?php echo __('确定要删除此规则吗？'); ?>')) {
        return;
    }

    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/delete'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({proxy_id: proxyId})
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('<?php echo __('删除失败'); ?>: ' + data.message);
        }
    });
}

function testConnection(proxyId, host, port, ssl) {
    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/test-connection'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({backend_host: host, backend_port: port, backend_ssl: ssl})
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert('<?php echo __('连接成功'); ?> (' + data.latency_ms + 'ms)');
        } else {
            alert('<?php echo __('连接失败'); ?>: ' + data.message);
        }
    });
}
</script>
