        <div class="col-12">
            <h2>
                <i class="bi bi-arrow-left-right"></i>
                <?php echo $isEdit ? '<lang>编辑代理规则</lang>' : '<lang>新建代理规则</lang>'; ?>
            </h2>
            <a href="<?php echo $this->getUrl('*/backend/reverse-proxy'); ?>" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> <lang>返回列表</lang>
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form id="proxyForm">
                        <input type="hidden" name="proxy_id" value="<?php echo $proxyId; ?>">

                        <!-- 域名 -->
                        <div class="mb-3">
