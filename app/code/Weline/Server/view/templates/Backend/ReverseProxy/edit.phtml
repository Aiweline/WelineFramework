                </div>
            </div>
        </div>
    </div>
</div>

<script>
function saveProxy() {
    const form = document.getElementById('proxyForm');
    const formData = new FormData(form);
    const data = {};

    formData.forEach((value, key) => {
        if (key === 'backend_ssl') {
            data[key] = document.getElementById('backend_ssl').checked ? 1 : 0;
        } else {
            data[key] = value;
        }
    });

    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/save'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            window.location.href = '<?php echo $this->getUrl('*/backend/reverse-proxy'); ?>';
        } else {
            alert('<?php echo __('保存失败'); ?>: ' + data.message);
        }
    })
    .catch(err => alert('<?php echo __('请求失败'); ?>: ' + err));
}

function testConnection() {
    const host = document.getElementById('backend_host').value;
    const port = document.getElementById('backend_port').value;
    const ssl = document.getElementById('backend_ssl').checked;

    if (!host || !port) {
        alert('<?php echo __('请先填写后端主机和端口'); ?>');
        return;
    }

    fetch('<?php echo $this->getUrl('*/backend/reverse-proxy/test-connection'); ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({backend_host: host, backend_port: port, backend_ssl: ssl})
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert('<?php echo __('连接成功'); ?> (' + data.latency_ms + 'ms)');
        } else {
            alert('<?php echo __('连接失败'); ?>: ' + data.message);
        }
    });
}
</script>
