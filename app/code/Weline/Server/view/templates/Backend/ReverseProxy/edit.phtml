                                   placeholder="127.0.0.1" required>
                        </div>

                        <!-- 后端端口 -->
                        <div class="mb-3">
                            <label for="backend_port" class="form-label"><lang>后端端口</lang> <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="backend_port" name="backend_port"
                                   value="<?php echo $isEdit ? $proxy->getData(ReverseProxy::schema_fields_BACKEND_PORT) : '10443'; ?>"
                                   min="1" max="65535" required>
                        </div>

                        <!-- 后端SSL -->
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="backend_ssl" name="backend_ssl" value="1"
                                   <?php echo (!$isEdit || $proxy->getData(ReverseProxy::schema_fields_BACKEND_SSL)) ? 'checked' : ''; ?>>
                            <label class="form-check-label" for="backend_ssl">
                                <lang>后端使用 SSL</lang>
                            </label>
                        </div>

                        <!-- 优先级 -->
                        <div class="mb-3">
                            <label for="priority" class="form-label"><lang>优先级</lang></label>
                            <input type="number" class="form-control" id="priority" name="priority"
                                   value="<?php echo $isEdit ? $proxy->getData(ReverseProxy::schema_fields_PRIORITY) : '0'; ?>">
                            <small class="form-text text-muted"><lang>数字越大优先级越高</lang></small>
                        </div>

                        <!-- 状态 -->
                        <div class="mb-3">
                            <label for="status" class="form-label"><lang>状态</lang></label>
                            <select class="form-select" id="status" name="status">
                                <option value="<?php echo ReverseProxy::STATUS_ACTIVE; ?>"
                                        <?php echo (!$isEdit || $proxy->getData(ReverseProxy::schema_fields_STATUS) === ReverseProxy::STATUS_ACTIVE) ? 'selected' : ''; ?>>
                                    <lang>启用</lang>
                                </option>
                                <option value="<?php echo ReverseProxy::STATUS_INACTIVE; ?>"
                                        <?php echo ($isEdit && $proxy->getData(ReverseProxy::schema_fields_STATUS) === ReverseProxy::STATUS_INACTIVE) ? 'selected' : ''; ?>>
                                    <lang>禁用</lang>
                                </option>
