                        <div class="mb-3">
                            <label for="description" class="form-label"><lang>描述</lang></label>
                            <textarea class="form-control" id="description" name="description" rows="3"><?php echo $isEdit ? htmlspecialchars($proxy->getData(ReverseProxy::schema_fields_DESCRIPTION)) : ''; ?></textarea>
