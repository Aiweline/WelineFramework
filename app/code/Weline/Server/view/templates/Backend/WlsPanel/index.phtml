(function () {
    const form = document.querySelector('[data-wls-security-rules-form]');
    if (!form) {
        return;
    }

    const preview = form.querySelector('[data-wls-rule-diff-preview]');
    const badge = form.querySelector('[data-wls-rule-diff-badge]');
    const list = form.querySelector('[data-wls-rule-diff-list]');
    const rulesTextarea = form.querySelector('textarea[name="rules_json"]');
    if (!preview || !badge || !list || !rulesTextarea) {
        return;
    }

    const labels = {
        empty: preview.getAttribute('data-label-empty') || 'No rule changes pending.',
        invalid: preview.getAttribute('data-label-invalid') || 'Rules JSON is invalid; preview is unavailable.',
        count: preview.getAttribute('data-label-count') || '%{1} pending changes',
        before: preview.getAttribute('data-label-before') || 'Before',
        after: preview.getAttribute('data-label-after') || 'After',
    };

    const fields = function () {
        return Array.from(form.elements).filter(function (element) {
            return element && element.name;
        });
    };
    const fieldByName = function (name, type) {
        return fields().find(function (element) {
            return element.name === name && (!type || element.type === type);
        }) || null;
    };
    const checkboxValue = function (name) {
        const checkbox = fieldByName(name, 'checkbox');
        return checkbox ? checkbox.checked : false;
    };
    const fieldValue = function (name, fallback) {
        const field = fieldByName(name);
        return field ? field.value : fallback;
    };
    const numberValue = function (name, min, max, fallback) {
        const value = Number(fieldValue(name, fallback));
        const normalized = Number.isFinite(value) ? Math.trunc(value) : fallback;
        return Math.max(min, Math.min(max, normalized));
    };
    const floatValue = function (name, min, max, fallback) {
        const value = Number(fieldValue(name, fallback));
        const normalized = Number.isFinite(value) ? value : fallback;
        return Math.max(min, Math.min(max, normalized));
    };
    const listValue = function (name) {
        const seen = new Set();
        const value = String(fieldValue(name, '') || '');
        return value.split(/\r?\n+/).map(function (line) {
            return line.trim();
        }).filter(function (line) {
            if (!line || seen.has(line)) {
                return false;
            }
            seen.add(line);
            return true;
        });
    };
    const isPlainObject = function (value) {
        return value && typeof value === 'object' && !Array.isArray(value);
    };
    const cloneObject = function (value) {
        return isPlainObject(value) ? Object.assign({}, value) : {};
    };
    const sanitizePath = function (value) {
        let path = String(value || '').trim();
        if (!path) {
            return '';
        }
        if (/^[a-z][a-z\d+.-]*:\/\//i.test(path)) {
            try {
                path = new URL(path).pathname || '';
            } catch (error) {
                path = path.split('?', 1)[0] || path;
            }
        }
        path = path.split('?', 1)[0].trim();
        if (!path) {
            return '';
        }
        return path.charAt(0) === '/' ? path : '/' + path;
    };
    const collectPathRateRows = function () {
        const rows = new Map();
        fields().forEach(function (element) {
            const match = element.name.match(/^visual_rules\[path_rate_limits\]\[rules\]\[(\d+)\]\[(enabled|path|window|max_requests|block_duration)\]$/);
            if (!match) {
                return;
            }
            const index = match[1];
            const key = match[2];
            const row = rows.get(index) || {};
            if (key === 'enabled') {
                if (element.type === 'checkbox') {
                    row.enabled = element.checked;
                } else if (row.enabled === undefined) {
                    row.enabled = false;
                }
            } else {
                row[key] = element.value;
            }
            rows.set(index, row);
        });

        const normalized = [];
        Array.from(rows.keys()).sort(function (a, b) {
            return Number(a) - Number(b);
        }).forEach(function (index) {
            const row = rows.get(index) || {};
            const path = sanitizePath(row.path);
            if (!path) {
                return;
            }
            normalized.push({
                path: path,
                window: Math.max(1, Math.min(86400, Number.parseInt(row.window || '60', 10) || 60)),
                max_requests: Math.max(1, Math.min(1000000, Number.parseInt(row.max_requests || '60', 10) || 60)),
                block_duration: Math.max(0, Math.min(86400, Number.parseInt(row.block_duration || '120', 10) || 120)),
                enabled: row.enabled === true,
            });
        });

        return normalized.slice(0, 50);
    };
    const mergeVisualRules = function (base) {
        const merged = JSON.parse(JSON.stringify(base || {}));
        merged.rate_limit = Object.assign(cloneObject(merged.rate_limit), {
            enabled: checkboxValue('visual_rules[rate_limit][enabled]'),
            window: numberValue('visual_rules[rate_limit][window]', 1, 86400, 60),
            max_requests: numberValue('visual_rules[rate_limit][max_requests]', 1, 1000000, 200),
            block_duration: numberValue('visual_rules[rate_limit][block_duration]', 0, 86400, 300),
        });
        merged.path_rate_limits = Object.assign(cloneObject(merged.path_rate_limits), {
            enabled: checkboxValue('visual_rules[path_rate_limits][enabled]'),
            rules: collectPathRateRows(),
        });
        merged.path_scan = Object.assign(cloneObject(merged.path_scan), {
            enabled: checkboxValue('visual_rules[path_scan][enabled]'),
            window: numberValue('visual_rules[path_scan][window]', 1, 86400, 60),
            max_unique_paths: numberValue('visual_rules[path_scan][max_unique_paths]', 1, 100000, 50),
            block_duration: numberValue('visual_rules[path_scan][block_duration]', 0, 86400, 600),
        });
        merged.ssl_handshake_failure = Object.assign(cloneObject(merged.ssl_handshake_failure), {
            enabled: checkboxValue('visual_rules[ssl_handshake_failure][enabled]'),
            window: numberValue('visual_rules[ssl_handshake_failure][window]', 1, 86400, 60),
            max_failures: numberValue('visual_rules[ssl_handshake_failure][max_failures]', 1, 100000, 30),
            block_duration: numberValue('visual_rules[ssl_handshake_failure][block_duration]', 0, 86400, 60),
            fast_close_threshold: floatValue('visual_rules[ssl_handshake_failure][fast_close_threshold]', 0.01, 10, 0.2),
        });
        merged.unknown_route_ban = Object.assign(cloneObject(merged.unknown_route_ban), {
            enabled: checkboxValue('visual_rules[unknown_route_ban][enabled]'),
            only_in_spike_mode: checkboxValue('visual_rules[unknown_route_ban][only_in_spike_mode]'),
            consecutive_count: numberValue('visual_rules[unknown_route_ban][consecutive_count]', 1, 100000, 5),
            block_duration: numberValue('visual_rules[unknown_route_ban][block_duration]', 0, 86400, 300),
        });
        merged.ip_whitelist = Object.assign(cloneObject(merged.ip_whitelist), {
            enabled: checkboxValue('visual_rules[ip_whitelist][enabled]'),
            ips: listValue('visual_rules[ip_whitelist][ips]'),
        });
        merged.protected_paths = Object.assign(cloneObject(merged.protected_paths), {
            enabled: checkboxValue('visual_rules[protected_paths][enabled]'),
            paths: listValue('visual_rules[protected_paths][paths]'),
            block_duration: numberValue('visual_rules[protected_paths][block_duration]', 0, 86400, 1800),
        });
        return merged;
    };
    const comparable = function (value) {
        return JSON.stringify(value);
    };
    const formatValue = function (value) {
        if (value === undefined) {
            return 'undefined';
        }
        if (value === null) {
            return 'null';
        }
        if (typeof value === 'boolean') {
            return value ? 'true' : 'false';
        }
        if (typeof value === 'string' || typeof value === 'number') {
            return String(value);
        }
        return JSON.stringify(value, null, 2);
    };
    const flattenValues = function (value, prefix, output) {
        if (isPlainObject(value)) {
            Object.keys(value).sort().forEach(function (key) {
                flattenValues(value[key], prefix ? prefix + '.' + key : key, output);
            });
            return output;
        }
        output[prefix || 'rules'] = value;
        return output;
    };
    const diffRules = function (before, after) {
        const beforeFlat = flattenValues(before, '', {});
        const afterFlat = flattenValues(after, '', {});
        const paths = Array.from(new Set(Object.keys(beforeFlat).concat(Object.keys(afterFlat)))).sort();
        return paths.filter(function (path) {
            return comparable(beforeFlat[path]) !== comparable(afterFlat[path]);
        }).slice(0, 120).map(function (path) {
            return {
                path: path,
                before: formatValue(beforeFlat[path]),
                after: formatValue(afterFlat[path]),
            };
        });
    };
    const renderEmpty = function (message) {
        const empty = document.createElement('div');
        empty.className = 'wls-empty-state wls-rule-diff-empty';
        const title = document.createElement('strong');
        title.textContent = message;
        empty.appendChild(title);
        list.appendChild(empty);
    };
    const renderPreview = function () {
        let baseRules;
        try {
            baseRules = JSON.parse(rulesTextarea.value || '{}');
        } catch (error) {
            preview.setAttribute('data-wls-rule-diff-state', 'invalid');
            preview.setAttribute('data-wls-rule-diff-count-value', '0');
            badge.className = 'wls-status-pill is-off';
            badge.textContent = labels.invalid;
            list.textContent = '';
            renderEmpty(labels.invalid);
            return;
        }

        const mergedRules = mergeVisualRules(baseRules);
        const changes = diffRules(baseRules, mergedRules);
        preview.setAttribute('data-wls-rule-diff-state', changes.length > 0 ? 'changed' : 'empty');
        preview.setAttribute('data-wls-rule-diff-count-value', String(changes.length));
        badge.className = changes.length > 0 ? 'wls-status-pill is-on' : 'wls-status-pill is-off';
        badge.textContent = changes.length > 0
            ? labels.count.replace('%{1}', String(changes.length))
            : labels.empty;
        list.textContent = '';

        if (changes.length === 0) {
            renderEmpty(labels.empty);
            return;
        }

        changes.forEach(function (change) {
            const item = document.createElement('article');
            item.className = 'wls-rule-diff-item';
            const path = document.createElement('code');
            path.textContent = change.path;
            const values = document.createElement('div');
            values.className = 'wls-rule-diff-values';
            [
                [labels.before, change.before],
                [labels.after, change.after],
            ].forEach(function (pair) {
                const column = document.createElement('div');
                const label = document.createElement('span');
                const pre = document.createElement('pre');
                label.textContent = pair[0];
                pre.textContent = pair[1];
                column.appendChild(label);
                column.appendChild(pre);
                values.appendChild(column);
            });
            item.appendChild(path);
            item.appendChild(values);
            list.appendChild(item);
        });
    };

    form.addEventListener('input', renderPreview);
    form.addEventListener('change', renderPreview);
    renderPreview();
})();
</script>
