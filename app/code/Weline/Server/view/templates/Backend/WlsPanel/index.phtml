    $resolveProjectSecurityScope
): array {
    $projectType = (string)($project['type'] ?? '');
    $projectAdminLink = (string)($project['admin'] ?? '');
    $projectPanelLink = (string)($project['panel'] ?? '');
    $projectPhpLink = (string)($project['php'] ?? '');
    $projectDbLink = (string)($project['db'] ?? '');
    $projectBackendLink = (string)($project['backend'] ?? '');

    $phpOperationUrl = $buildOperationCapabilityUrl('php-profile', 'WLS PHP Manager', $buildProjectOperationContext($project, 'php-profile'));
    $dbOperationUrl = $buildOperationCapabilityUrl('database-profile', 'WLS Database Manager', $buildProjectOperationContext($project, 'database-profile'));
    $fileManagerUrl = $buildOperationCapabilityUrl('file-manager', 'WLS File Manager', $buildProjectOperationContext($project, 'file-manager'));
    $deployUrl = $buildOperationCapabilityUrl('deploy', 'WLS Deploy', $buildProjectOperationContext($project, 'deploy'));

    if ($projectAdminLink === '') {
        $projectAdminLink = $projectType === 'current' ? $projectAdminUrl : $projectBackendLink;
    }
    if ($projectPanelLink === '') {
        $projectPanelLink = $projectType === 'current' ? $dashboardUrl : $projectBackendLink;
    }
    if ($projectPhpLink === '') {
        $projectPhpLink = $phpOperationUrl;
    }
    if ($projectDbLink === '' || $projectDbLink === '#database-profile') {
        $projectDbLink = $dbOperationUrl;
    }

    return [
        'admin' => $projectAdminLink,
        'panel' => $projectPanelLink,
        'php-profile' => $projectPhpLink,
        'database-profile' => $projectDbLink,
        'file-manager' => $fileManagerUrl,
        'deploy' => $deployUrl,
        'security' => $buildSecurityLogUrl(['security_scope' => $resolveProjectSecurityScope($project), 'security_page' => 1]),
        'security-logs' => $buildSecurityLogUrl(['security_scope' => $resolveProjectSecurityScope($project), 'security_page' => 1]),
        'security-policy' => $buildSecurityPolicyUrl(['security_scope' => $resolveProjectSecurityScope($project), 'security_page' => 1]),
        'gateway' => $gatewayUrl,
    ];
};
