<script>
(function () {
    const shell = document.querySelector('[data-wls-shell="standalone"]');
    const button = document.querySelector('[data-wls-theme-toggle]');
    const label = document.querySelector('[data-wls-theme-icon]');
    if (!shell || !button || !label) {
        return;
    }
    const storageKey = 'wls_panel_theme';
    const syncHostThemeAttributes = function (theme) {
        document.documentElement.setAttribute('data-wls-panel-theme', theme);
        document.documentElement.setAttribute('data-theme-mode', theme);
        document.documentElement.setAttribute('data-bs-theme', theme);
        document.documentElement.style.colorScheme = theme;
        if (document.body) {
            document.body.setAttribute('data-wls-panel-theme', theme);
            document.body.setAttribute('data-bs-theme', theme);
            document.body.setAttribute('data-sidebar', theme);
            document.body.setAttribute('data-topbar', theme);
        }
    };
    const applyTheme = function (theme) {
        const normalized = theme === 'dark' ? 'dark' : 'light';
        const darkLabel = button.getAttribute('data-wls-theme-dark-label') || label.textContent || '';
        const lightLabel = button.getAttribute('data-wls-theme-light-label') || label.textContent || '';
        const nextLabel = normalized === 'dark' ? lightLabel : darkLabel;
        shell.setAttribute('data-wls-theme', normalized);
        shell.setAttribute('data-wls-theme-ready', '1');
        syncHostThemeAttributes(normalized);
        button.setAttribute('aria-pressed', normalized === 'dark' ? 'true' : 'false');
        label.textContent = nextLabel;
        try {
            window.localStorage.setItem(storageKey, normalized);
        } catch (error) {
            // Local storage can be unavailable in hardened browser contexts.
        }
        document.dispatchEvent(new CustomEvent('wls-panel-theme-change', {
            detail: {
                theme: normalized
            }
        }));
    };
    let initialTheme = 'light';
    try {
        const storedTheme = window.localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia
            && window.matchMedia('(prefers-color-scheme: dark)').matches;
        initialTheme = storedTheme || (prefersDark ? 'dark' : 'light');
    } catch (error) {
        initialTheme = 'light';
    }
    applyTheme(initialTheme);
    button.addEventListener('click', function () {
        applyTheme(shell.getAttribute('data-wls-theme') === 'dark' ? 'light' : 'dark');
    });
})();

(function () {
    const shell = document.querySelector('[data-wls-shell="standalone"]');
    if (!shell) {
        return;
    }

    const groups = Array.from(shell.querySelectorAll('[data-wls-plugin-nav-group]'));
    if (groups.length === 0) {
        return;
    }

    const setOpen = function (group, open) {
        const subnav = group.querySelector('[data-wls-plugin-subnav]');
        const toggle = group.querySelector('[data-wls-plugin-nav-toggle]');
        group.classList.toggle('is-open', open);
        if (subnav) {
            subnav.hidden = !open;
        }
        if (toggle) {
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
    };

    groups.forEach(function (group) {
        setOpen(group, group.getAttribute('data-plugin-active') === '1');
        const toggle = group.querySelector('[data-wls-plugin-nav-toggle]');
        if (!toggle) {
            return;
        }
        toggle.addEventListener('click', function () {
            const willOpen = !group.classList.contains('is-open');
            groups.forEach(function (otherGroup) {
                setOpen(otherGroup, false);
            });
            if (willOpen) {
                setOpen(group, true);
            }
        });
    });

    const activeItem = shell.querySelector('.wls-plugin-subnav-item.is-active, .wls-plugin-nav-trigger.is-active');
    if (activeItem && typeof activeItem.scrollIntoView === 'function') {
        window.requestAnimationFrame(function () {
            activeItem.scrollIntoView({
                block: 'nearest',
                inline: 'nearest'
            });
        });
    }
})();

(function () {
    const shell = document.querySelector('[data-wls-shell="standalone"]');
    if (!shell || shell.getAttribute('data-wls-auto-refresh') !== 'plugins') {
        return;
    }

    const form = document.querySelector('[data-wls-plugin-refresh-form]');
    if (!form || form.getAttribute('data-wls-auto-refresh-submitted') === '1') {
        return;
    }

    form.setAttribute('data-wls-auto-refresh-submitted', '1');
    if (typeof form.requestSubmit === 'function') {
        form.requestSubmit();
        return;
    }
    form.submit();
})();

(function () {
