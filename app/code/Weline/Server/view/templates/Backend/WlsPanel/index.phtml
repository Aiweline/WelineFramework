};
$buildOperationCapabilityUrl = static function (string $key, string $installQuery, array $context = []) use ($operationCapabilityByKey, $buildWlsMarketplaceUrl, $buildPanelEntryUrl, $buildPluginShellUrlForModule): string {
    $capability = is_array($operationCapabilityByKey[$key] ?? null) ? $operationCapabilityByKey[$key] : [];
    $installed = !empty($capability['installed']);
    $actionUrl = trim((string)($capability['action_url'] ?? ''));
    if ($installed && $actionUrl !== '') {
        $pluginShellUrl = $buildPluginShellUrlForModule((string)($capability['plugin_module'] ?? ''), $key, $context);
        if ($pluginShellUrl !== '') {
            return $pluginShellUrl;
        }
        $actionUrl = $buildPanelEntryUrl($actionUrl);
        $params = [];
        foreach ($context as $contextKey => $contextValue) {
            $contextValue = is_scalar($contextValue) ? trim((string)$contextValue) : '';
            if ($contextValue !== '') {
                $params[(string)$contextKey] = $contextValue;
            }
        }
        if ($params === []) {
            return $actionUrl;
        }
        return $actionUrl . (str_contains($actionUrl, '?') ? '&' : '?') . http_build_query($params);
    }

    $query = trim((string)($capability['install_query'] ?? $installQuery));
    return $buildWlsMarketplaceUrl($query !== '' ? $query : $installQuery);
};
