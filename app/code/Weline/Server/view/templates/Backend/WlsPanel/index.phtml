$template = $this;
$buildPanelEntryUrl = static function (string $url) use ($template): string {
    $url = trim($url);
    if ($url === '' || str_starts_with($url, '#')) {
        return '';
    }
    if (preg_match('/^(javascript|data|vbscript):/i', ltrim($url)) === 1) {
        return '';
    }
    $isAbsoluteUrl = preg_match('/^[a-z][a-z0-9+.-]*:/i', $url) === 1;
    $entryUrl = $isAbsoluteUrl || str_starts_with($url, '/') ? $url : $template->getBackendUrl($url);
    $fragmentPosition = strpos($entryUrl, '#');
    if ($fragmentPosition !== false) {
        $entryUrl = substr($entryUrl, 0, $fragmentPosition);
    }
    if ($isAbsoluteUrl) {
        return $entryUrl;
    }
    if (!str_contains($entryUrl, 'embedded=') && !str_contains($entryUrl, 'wls_panel=')) {
        $entryUrl .= (str_contains($entryUrl, '?') ? '&' : '?') . http_build_query(['embedded' => 1]);
    }

    return $entryUrl;
};
$buildPanelEntryUrlWithParams = static function (string $url, array $params = []) use ($buildPanelEntryUrl): string {
    $entryUrl = $buildPanelEntryUrl($url);
    if ($entryUrl === '') {
        return '';
    }
    $safeParams = [];
    foreach ($params as $key => $value) {
        $key = trim((string)$key);
        if ($key === '' || !is_scalar($value)) {
            continue;
        }
        $value = trim((string)$value);
        if ($value !== '' && !str_contains($entryUrl, rawurlencode($key) . '=')) {
            $safeParams[$key] = $value;
        }
    }
    if ($safeParams === []) {
        return $entryUrl;
    }

    return $entryUrl . (str_contains($entryUrl, '?') ? '&' : '?') . http_build_query($safeParams);
};
$normalizePanelPluginKey = static function (string $key): string {
    $key = trim(strtolower($key));
    if ($key === '') {
        return '';
    }
    $key = (string)preg_replace('/[^a-z0-9:_-]+/', '-', $key);
    return trim($key, '-_');
};
$buildPluginShellUrl = static function (array $parent, ?array $child = null, array $params = []) use ($pluginViewerUrl, $normalizePanelPluginKey): string {
    $parentKey = $normalizePanelPluginKey((string)($parent['key'] ?? ''));
    $childKey = $child !== null ? $normalizePanelPluginKey((string)($child['key'] ?? '')) : '';
    $moduleName = trim((string)($parent['module_name'] ?? $child['module_name'] ?? ''));
    if ($parentKey === '' && $moduleName === '') {
        return '';
    }
    $query = [
        'plugin_key' => $parentKey,
    ];
    if ($childKey !== '') {
        $query['child_key'] = $childKey;
    }
    if ($moduleName !== '') {
        $query['plugin_module'] = $moduleName;
    }
    foreach ($params as $key => $value) {
        $key = trim((string)$key);
        if ($key === '' || array_key_exists($key, $query) || !is_scalar($value)) {
            continue;
        }
        $value = trim((string)$value);
        if ($value !== '') {
            $query[$key] = $value;
        }
    }

    return $pluginViewerUrl . (str_contains($pluginViewerUrl, '?') ? '&' : '?') . http_build_query($query);
};
