$buildPluginShellUrlForModule = static function (string $moduleName, string $childKey = '', array $params = []) use (
    $panelPluginMenuByModule,
    $normalizePanelPluginKey,
    $buildPluginShellUrl
): string {
    $moduleKey = strtolower(trim($moduleName));
    if ($moduleKey === '' || !is_array($panelPluginMenuByModule[$moduleKey] ?? null)) {
        return '';
    }
    $parent = $panelPluginMenuByModule[$moduleKey];
    $normalizedChildKey = $normalizePanelPluginKey($childKey);
    $children = is_array($parent['children'] ?? null) ? array_values($parent['children']) : [];
    $selectedChild = null;
    foreach ($children as $child) {
        if (!is_array($child)) {
            continue;
        }
        if ($normalizedChildKey !== '' && $normalizePanelPluginKey((string)($child['key'] ?? '')) === $normalizedChildKey) {
            $selectedChild = $child;
            break;
        }
    }
    if ($selectedChild === null && $children !== []) {
        foreach ($children as $child) {
            if (is_array($child) && trim((string)($child['url'] ?? '')) !== '') {
                $selectedChild = $child;
                break;
            }
        }
    }

    return $buildPluginShellUrl($parent, $selectedChild, $params);
};
