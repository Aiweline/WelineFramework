    const prevButton = list.querySelector('[data-wls-project-page-prev]');
    const nextButton = list.querySelector('[data-wls-project-page-next]');
    const rows = Array.from(list.querySelectorAll('[data-wls-project-row]'));
    const detailRows = new Map();

    list.querySelectorAll('[data-wls-project-detail-row]').forEach(function (row) {
        if (row.id) {
            detailRows.set(row.id, row);
        }
    });

    let state = {
        page: 1,
        pageSize: Number.parseInt(list.getAttribute('data-wls-project-page-size') || '10', 10) || 10,
        query: '',
    };

    const collapseAll = function () {
        rows.forEach(function (row) {
            row.classList.remove('is-expanded');
            const toggle = row.querySelector('[data-wls-project-detail-toggle]');
            if (toggle) {
                toggle.setAttribute('aria-expanded', 'false');
            }
        });
        detailRows.forEach(function (row) {
            row.hidden = true;
        });
    };

    const matchingRows = function () {
        const query = state.query.trim().toLowerCase();
        if (!query) {
            return rows;
        }
        return rows.filter(function (row) {
            return String(row.getAttribute('data-wls-project-search') || '').includes(query);
        });
    };

    const render = function () {
        const matches = matchingRows();
        const total = matches.length;
        const totalPages = Math.max(1, Math.ceil(total / state.pageSize));
        state.page = Math.max(1, Math.min(state.page, totalPages));
        const start = (state.page - 1) * state.pageSize;
        const end = start + state.pageSize;
        const visible = new Set(matches.slice(start, end));

        rows.forEach(function (row) {
            const detailId = row.getAttribute('data-wls-project-detail') || '';
            const detailRow = detailRows.get(detailId);
            const isVisible = visible.has(row);
            row.hidden = !isVisible;
            if (!isVisible && detailRow) {
                detailRow.hidden = true;
                row.classList.remove('is-expanded');
                const toggle = row.querySelector('[data-wls-project-detail-toggle]');
                if (toggle) {
                    toggle.setAttribute('aria-expanded', 'false');
                }
            }
        });

        const from = total === 0 ? 0 : start + 1;
        const to = Math.min(end, total);
        const summaryLabel = list.getAttribute('data-summary-label') || 'Showing %{1}-%{2} of %{3} instances';
        if (summary) {
            summary.textContent = summaryLabel
                .replace('%{1}', String(from))
                .replace('%{2}', String(to))
                .replace('%{3}', String(total));
        }
        if (empty) {
            empty.hidden = total !== 0;
        }
        if (pageLabel) {
            pageLabel.textContent = String(state.page) + ' / ' + String(totalPages);
        }
        if (prevButton) {
            prevButton.disabled = state.page <= 1;
        }
        if (nextButton) {
            nextButton.disabled = state.page >= totalPages;
        }
    };

    if (searchInput) {
        searchInput.addEventListener('input', function () {
            state.query = searchInput.value || '';
            state.page = 1;
            collapseAll();
            render();
        });
    }
    if (pageSizeSelect) {
        pageSizeSelect.addEventListener('change', function () {
            state.pageSize = Number.parseInt(pageSizeSelect.value || '10', 10) || 10;
            state.page = 1;
            collapseAll();
            render();
        });
    }
    if (prevButton) {
        prevButton.addEventListener('click', function () {
            state.page -= 1;
            collapseAll();
            render();
        });
    }
    if (nextButton) {
        nextButton.addEventListener('click', function () {
            state.page += 1;
            collapseAll();
            render();
        });
    }

    list.addEventListener('click', function (event) {
        const toggle = event.target.closest('[data-wls-project-detail-toggle]');
        if (!toggle) {
            return;
        }
        const row = toggle.closest('[data-wls-project-row]');
        if (!row) {
            return;
        }
        const detailId = row.getAttribute('data-wls-project-detail') || '';
        const detailRow = detailRows.get(detailId);
        if (!detailRow) {
            return;
        }
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        collapseAll();
        if (!expanded) {
            row.classList.add('is-expanded');
            detailRow.hidden = false;
            toggle.setAttribute('aria-expanded', 'true');
        }
    });

    render();
})();

