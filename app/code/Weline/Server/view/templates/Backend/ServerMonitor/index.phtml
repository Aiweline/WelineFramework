<script>
const STATUS_API_URL = '<?= $statusApiUrl ?>';
const CLEANUP_API_URL = '<?= $block->getUrl('backend/server/server-monitor/cleanup-logs') ?>';

let refreshTimer = null;

document.addEventListener('DOMContentLoaded', () => {
    // 每 30 秒自动刷新
    refreshTimer = setInterval(refreshStatus, 30000);
});

async function refreshStatus() {
    try {
        const response = await fetch(STATUS_API_URL + '?instance=<?= $instance ?>', {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (data.success) {
            updateStats(data.data);
        }
    } catch (error) {
        console.error('Failed to refresh status:', error);
    }
}

function updateStats(data) {
    const stats = data.server_stats || {};
    
    document.getElementById('running-workers').textContent = stats.running_workers || 0;
    document.getElementById('total-connections').textContent = stats.total_connections || 0;
    document.getElementById('total-requests').textContent = formatNumber(stats.total_requests || 0);
}

function formatNumber(num) {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

async function cleanupLogs() {
    if (!confirm('<?= __('确定要清理过期日志吗？\n- 状态日志：保留7天\n- 攻击日志：保留30天') ?>')) {
        return;
    }
    
    AdminToast.info('<?= __('正在清理...') ?>');
    
    try {
        const response = await fetch(CLEANUP_API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'status_days=7&attack_days=30',
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (data.success) {
            AdminToast.success(data.message + ' (状态日志: ' + data.data.status_logs_cleaned + ', 攻击日志: ' + data.data.attack_logs_cleaned + ')');
        } else {
            AdminToast.error(data.message || '<?= __('清理失败') ?>');
        }
    } catch (error) {
        AdminToast.error('<?= __('清理失败') ?>: ' + error.message);
    }
}
</script>
