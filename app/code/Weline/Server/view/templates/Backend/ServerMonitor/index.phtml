const CLEANUP_API_URL = '<?= $this->getBackendUrl('*/backend/server-monitor/cleanup-logs') ?>';
const TRAFFIC_API_URL = '<?= $trafficApiUrl ?>';
const TRAFFIC_HISTORY_API_URL = '<?= $trafficHistoryApiUrl ?>';
const BENCHMARK_API_URL = '<?= $benchmarkApiUrl ?>';
const BENCHMARKS_API_URL = '<?= $benchmarksApiUrl ?>';
const BENCHMARK_DETAIL_API_URL = '<?= $benchmarkDetailApiUrl ?>';

let refreshTimer = null;

document.addEventListener('DOMContentLoaded', () => {
    // 每 30 秒自动刷新
    refreshTimer = setInterval(refreshStatus, 30000);
    refreshStatus();
    refreshTraffic();
});

async function refreshStatus() {
    try {
        const response = await fetch(STATUS_API_URL + '?instance=<?= $instance ?>', {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (data.success) {
            updateStats(data.data);
            renderTrafficHosts((data.data.traffic || {}).hosts || []);
            renderProcessDetails((data.data.status_dto || {}).services || []);
            renderProcessHistory(data.data.status_logs || []);
        }
    } catch (error) {
        console.error('Failed to refresh status:', error);
    }
}

function updateStats(data) {
    const stats = data.server_stats || {};
    
    document.getElementById('running-workers').textContent = stats.running_workers || 0;
    document.getElementById('total-connections').textContent = stats.total_connections || 0;
    document.getElementById('total-requests').textContent = formatNumber(stats.total_requests || 0);
}

function renderProcessDetails(services) {
    const tbody = document.getElementById('process-detail-body');
    if (!tbody) {
        return;
    }
    if (!Array.isArray(services) || services.length === 0) {
        tbody.innerHTML = `<tr><td colspan="13" class="text-center text-muted py-3"><?= __('暂无进程明细数据') ?></td></tr>`;
        return;
    }
    const rows = [];
    let rowIndex = 0;
    services.forEach((serviceGroup) => {
        const role = String(serviceGroup.role || '').toLowerCase();
        const instances = Array.isArray(serviceGroup.instances) ? serviceGroup.instances : [];
        instances.forEach((item) => {
            const roleBadge = getRoleBadge(serviceGroup.role || '');
            const stateBadge = getStateBadge(item.state || '');
            const uptime = formatSeconds(item.uptime || 0);
            const heartbeat = formatHeartbeat(item.heartbeat || 0);
            const memory = formatBytes(item.memory_usage || 0);
            const connections = Number(item.connections || 0);
            const activeRequests = Number(item.active_requests || 0);
            const totalRequests = formatNumber(Number(item.total_requests || 0));
            const healthDetail = item.health_detail || {};
            const fiberCount = Number(healthDetail.fiber_count ?? 0);
            const fibers = Array.isArray(healthDetail.fibers) ? healthDetail.fibers : [];
            const isWorker = role === 'worker';
            const canExpand = isWorker && fiberCount > 0;
            const fibersJson = escapeHtml(JSON.stringify(fibers));
            const expandCell = canExpand
                ? `<td class="text-center align-middle"><button type="button" class="btn btn-sm btn-outline-secondary border-0 p-1 server-monitor-fiber-toggle" data-fibers-json="${fibersJson}" data-row-idx="${rowIndex}" aria-label="<?= __('展开 Fiber 列表') ?>"><i class="bi bi-chevron-down"></i></button></td>`
                : `<td class="text-center"></td>`;
            const fiberCell = isWorker
                ? `<td class="process-detail-table-memory">${fiberCount}</td>`
                : `<td class="text-muted">-</td>`;
            rows.push(`
                <tr class="server-monitor-process-row" data-row-idx="${rowIndex}">
                    ${expandCell}
                    <td><span class="badge process-role-badge ${roleBadge.cls}">${escapeHtml(roleBadge.label)}</span></td>
                    <td>#${escapeHtml(String(item.instance_id ?? '-'))}</td>
                    <td>${escapeHtml(String(item.pid || '-'))}</td>
                    <td>${escapeHtml(String(item.port || '-'))}</td>
                    <td><span class="badge ${stateBadge.cls}">${escapeHtml(stateBadge.label)}</span></td>
                    <td>${escapeHtml(uptime)}</td>
                    <td>${escapeHtml(String(item.restarts || 0))}</td>
                    <td>${formatNumber(connections)} / ${formatNumber(activeRequests)}</td>
                    ${fiberCell}
                    <td>${totalRequests}</td>
                    <td class="process-detail-table-memory">${escapeHtml(memory)}</td>
                    <td>${escapeHtml(heartbeat)}</td>
                </tr>
            `);
            rowIndex++;
        });
    });
    tbody.innerHTML = rows.join('');
    tbody.querySelectorAll('.server-monitor-fiber-toggle').forEach((btn) => {
        btn.addEventListener('click', function () {
            const row = this.closest('tr');
            const fibersJson = this.getAttribute('data-fibers-json');
            let fibers = [];
            try {
                fibers = fibersJson ? JSON.parse(fibersJson) : [];
            } catch (e) {
                fibers = [];
            }
            const next = row.nextElementSibling;
            if (next && next.classList.contains('server-monitor-fiber-detail-row')) {
                next.remove();
                this.querySelector('i').classList.remove('bi-chevron-up');
                this.querySelector('i').classList.add('bi-chevron-down');
                return;
            }
            const detailRow = document.createElement('tr');
            detailRow.className = 'server-monitor-fiber-detail-row bg-light';
            const statusLabel = function (s) {
                return s === 'idle' ? '<?= __("闲") ?>' : '<?= __("忙") ?>';
            };
            const protocolLabel = function (p) {
                return (p === 'sse' ? 'SSE' : 'HTTP');
            };
            const fiberRows = fibers.length === 0
                ? `<tr><td colspan="4" class="text-muted"><?= __('无 Fiber') ?></td></tr>`
                : fibers.map((f) => `
                    <tr>
                        <td>${escapeHtml(String(f.conn_id ?? ''))}</td>
                        <td><span class="badge ${(f.status === 'idle' ? 'bg-secondary' : 'bg-primary')}">${escapeHtml(statusLabel(f.status))}</span></td>
                        <td>${escapeHtml(protocolLabel(f.protocol))}</td>
                    </tr>
                `).join('');
            detailRow.innerHTML = `
                <td colspan="13" class="p-0">
                    <div class="p-2 border-start border-3 border-info">
                        <table class="table table-sm table-borderless mb-0 small">
                            <thead><tr><th><?= __('连接 ID') ?></th><th><?= __('状态') ?></th><th><?= __('协议') ?></th></tr></thead>
                            <tbody>${fiberRows}</tbody>
                        </table>
                    </div>
                </td>
            `;
            row.after(detailRow);
            this.querySelector('i').classList.remove('bi-chevron-down');
            this.querySelector('i').classList.add('bi-chevron-up');
        });
    });
}

function renderProcessHistory(logs) {
    const tbody = document.getElementById('process-history-body');
    if (!tbody) {
        return;
    }
    if (!Array.isArray(logs) || logs.length === 0) {
        tbody.innerHTML = `<tr><td colspan="10" class="text-center text-muted py-3"><?= __('暂无状态日志') ?></td></tr>`;
        return;
    }
    const rows = logs.slice(0, 30).map((log) => {
        const type = String(log.process_type || '-');
        const statusBadge = getStateBadge(log.status || '');
        const memory = formatBytes(Number(log.memory_usage || 0));
        const lastError = String(log.last_error || '');
        return `
            <tr>
                <td>${escapeHtml(String(log.created_at || '-'))}</td>
                <td>${escapeHtml(type)}</td>
                <td>${escapeHtml(String(log.process_id || '-'))}</td>
                <td>${escapeHtml(String(log.pid || '-'))}</td>
                <td><span class="badge ${statusBadge.cls}">${escapeHtml(statusBadge.label)}</span></td>
                <td>${formatNumber(Number(log.connections || 0))}</td>
                <td>${formatNumber(Number(log.active_requests || 0))}</td>
                <td>${formatNumber(Number(log.total_requests || 0))}</td>
                <td>${escapeHtml(memory)}</td>
                <td title="${escapeHtml(lastError)}">${escapeHtml(lastError || '-')}</td>
            </tr>
        `;
    });
    tbody.innerHTML = rows.join('');
}

function getRoleBadge(role) {
    const lower = String(role || '').toLowerCase();
    if (lower === 'master') {
        return {cls: 'bg-primary', label: 'MASTER'};
    }
    if (lower === 'dispatcher') {
        return {cls: 'bg-info', label: 'DISPATCHER'};
    }
    if (lower === 'worker') {
        return {cls: 'bg-success', label: 'WORKER'};
    }
    return {cls: 'bg-secondary', label: role || 'UNKNOWN'};
}

function getStateBadge(state) {
    const lower = String(state || '').toLowerCase();
    if (lower === 'running') {
        return {cls: 'bg-success', label: 'running'};
    }
    if (lower === 'starting') {
        return {cls: 'bg-warning', label: 'starting'};
    }
    if (lower === 'error') {
        return {cls: 'bg-danger', label: 'error'};
    }
    if (lower === 'stopped' || lower === 'down') {
        return {cls: 'bg-secondary', label: state || 'stopped'};
    }
    return {cls: 'bg-dark', label: state || 'unknown'};
}

function formatSeconds(seconds) {
    const total = Math.max(0, Math.floor(Number(seconds || 0)));
    const h = Math.floor(total / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = total % 60;
    if (h > 0) {
        return `${h}h ${m}m ${s}s`;
    }
    if (m > 0) {
        return `${m}m ${s}s`;
    }
    return `${s}s`;
}

function formatHeartbeat(ts) {
    const value = Number(ts || 0);
    if (!value) {
        return '-';
    }
    const now = Math.floor(Date.now() / 1000);
    const delta = now - value;
    return delta <= 0 ? 'now' : `${delta}s ago`;
}

function formatBytes(bytes) {
    const value = Number(bytes || 0);
    if (!value) {
        return '0 B';
    }
    if (value < 1024) {
        return `${value} B`;
    }
    if (value < 1024 * 1024) {
        return `${(value / 1024).toFixed(1)} KB`;
    }
    if (value < 1024 * 1024 * 1024) {
        return `${(value / (1024 * 1024)).toFixed(1)} MB`;
    }
    return `${(value / (1024 * 1024 * 1024)).toFixed(2)} GB`;
}

async function refreshTraffic() {
    try {
        const response = await fetch(TRAFFIC_API_URL + '?instance=<?= $instance ?>&window_sec=300', {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        const data = await response.json();
        if (data.success) {
            renderTrafficHosts((data.data || {}).hosts || []);
        }
    } catch (error) {
        console.error('Failed to refresh traffic:', error);
    }
}

function renderTrafficHosts(hosts) {
    const tbody = document.getElementById('traffic-host-table');
    if (!tbody) {
        return;
    }
    if (!hosts || hosts.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted"><?= __('暂无流量数据') ?></td></tr>`;
        return;
    }
    tbody.innerHTML = hosts.map(item => {
        const avg = item.request_count > 0 ? (item.latency_total_ms / item.request_count).toFixed(2) : '0.00';
        return `
            <tr>
                <td>${escapeHtml(item.host || '*')}</td>
                <td class="text-end">${formatNumber(item.request_count || 0)}</td>
                <td class="text-end">${formatNumber(item.error_count || 0)}</td>
                <td class="text-end">${avg}</td>
            </tr>
        `;
    }).join('');
}

async function runBenchmark() {
    const target = (document.getElementById('benchmark-target')?.value || '').trim();
    const concurrency = parseInt(document.getElementById('benchmark-concurrency')?.value || '50', 10);
    const requests = parseInt(document.getElementById('benchmark-requests')?.value || '1000', 10);
    if (!target) {
        BackendToast.warning('<?= __('请先输入压测目标 URL。') ?>');
        return;
    }
    BackendToast.info('<?= __('压测执行中，请稍候...') ?>');
    try {
        const response = await fetch(BENCHMARK_API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: `instance=<?= $instance ?>&target=${encodeURIComponent(target)}&concurrency=${encodeURIComponent(concurrency)}&requests=${encodeURIComponent(requests)}`,
            credentials: 'same-origin'
        });
        const data = await response.json();
        if (!data.success) {
            BackendToast.error(data.message || '<?= __('压测失败') ?>');
            return;
        }
        const result = data.data || {};
        const text = `QPS: ${result.qps || 0}, p95: ${result.latency_p95 || 0}ms, error_rate: ${result.error_rate || 0}%`;
        document.getElementById('benchmark-last-result').textContent = text;
        BackendToast.success('<?= __('压测完成') ?>');
    } catch (error) {
        BackendToast.error('<?= __('压测失败：请检查网络连接后重试。') ?> ' + error.message);
    }
}

function escapeHtml(value) {
    const div = document.createElement('div');
    div.textContent = value ?? '';
    return div.innerHTML;
}

function formatNumber(num) {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

async function cleanupLogs() {
    const confirmed = await BackendConfirm.show('<?= __('确定要清理过期日志吗？状态日志保留 7 天，攻击日志保留 30 天。') ?>', {
        title: '<?= __('清理过期日志') ?>',
        type: 'warning',
        confirmText: '<?= __('确认清理') ?>',
        cancelText: '<?= __('取消') ?>'
    });
    if (!confirmed) {
        return;
    }
    
    BackendToast.info('<?= __('正在清理...') ?>');
    
    try {
        const response = await fetch(CLEANUP_API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'status_days=7&attack_days=30',
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (data.success) {
            BackendToast.success(data.message + ' (状态日志: ' + data.data.status_logs_cleaned + ', 攻击日志: ' + data.data.attack_logs_cleaned + ')');
        } else {
            BackendToast.error(data.message || '<?= __('清理失败') ?>');
        }
    } catch (error) {
        BackendToast.error('<?= __('清理失败') ?>: ' + error.message);
    }
}
</script>
