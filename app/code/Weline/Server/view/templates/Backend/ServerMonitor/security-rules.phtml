<script>
(function () {
    'use strict';

    function toastSuccess(message) {
        if (window.BackendToast && window.BackendToast.success) {
            window.BackendToast.success(message);
            return;
        }
        if (window.BackendToast && window.BackendToast.success) {
            window.BackendToast.success(message);
        }
    }

    function toastError(message) {
        if (window.BackendToast && window.BackendToast.error) {
            window.BackendToast.error(message);
            return;
        }
        if (window.BackendToast && window.BackendToast.error) {
            window.BackendToast.error(message);
        }
    }

    function getDefaultRules() {
        return {
            rate_limit: { enabled: true, window: 60, max_requests: 200, block_duration: 300 },
            path_rate_limits: {
                enabled: true,
                rules: [
                    { path: '/api/framework/query', window: 60, max_requests: 120, block_duration: 120, enabled: true },
                    { path: '/api_admin/framework/query', window: 60, max_requests: 300, block_duration: 120, enabled: true }
                ]
            },
            cdn_trusted_ips: { enabled: true, ips: [] },
            ip_whitelist: { enabled: true, ips: [] },
            path_scan: { enabled: true, window: 60, max_unique_paths: 50, block_duration: 600 },
            malicious_patterns: {
                enabled: true,
                patterns: [
                    '/(\\bunion\\b.*\\bselect\\b|\\bor\\b\\s+\\d+=\\d+|\\band\\b\\s+\\d+=\\d+|\\\'.*--)/i',
                    '/<script[^>]*>|javascript:|on\\w+\\s*=/i'
                ],
                block_duration: 3600
            },
            bad_user_agents: { enabled: true, patterns: ['/^$/i', '/sqlmap/i'], block_duration: 300 },
            protected_paths: { enabled: true, paths: ['/.git/', '/.env'], block_duration: 1800 },
            ssl_handshake_failure: { enabled: true, window: 60, max_failures: 30, block_duration: 60, fast_close_threshold: 0.2 }
        };
    }

    function deepMerge(base, incoming) {
        var result = Array.isArray(base) ? base.slice() : Object.assign({}, base);
        if (!incoming || typeof incoming !== 'object') {
            return result;
        }
        Object.keys(incoming).forEach(function (key) {
            var value = incoming[key];
            if (Array.isArray(value)) {
                result[key] = value.slice();
                return;
            }
            if (value && typeof value === 'object') {
                var current = result[key] && typeof result[key] === 'object' ? result[key] : {};
                result[key] = deepMerge(current, value);
                return;
            }
            result[key] = value;
        });
        return result;
    }

    function parseRulesJson() {
        var node = document.getElementById('wls-security-rules-json');
        if (!node) {
            return getDefaultRules();
        }
        try {
            var parsed = JSON.parse(node.textContent || '{}');
            if (!parsed || typeof parsed !== 'object') {
                return getDefaultRules();
            }
            return deepMerge(getDefaultRules(), parsed);
        } catch (error) {
            toastError(__('规则数据解析失败，已回退默认值：%{1}', {1: (error && error.message) || ''}));
            return getDefaultRules();
        }
    }

    function asBool(value) {
        return value === true || value === 1 || value === '1';
    }

    function asInt(value, fallback) {
        var n = Number.parseInt(String(value), 10);
        return Number.isFinite(n) ? n : fallback;
    }

    function asFloat(value, fallback) {
        var n = Number.parseFloat(String(value));
        return Number.isFinite(n) ? n : fallback;
    }

    function bindSimpleRules(rules) {
        document.getElementById('sr-rate-enabled').checked = asBool(rules.rate_limit.enabled);
        document.getElementById('sr-rate-window').value = asInt(rules.rate_limit.window, 60);
        document.getElementById('sr-rate-max').value = asInt(rules.rate_limit.max_requests, 200);
        document.getElementById('sr-rate-block').value = asInt(rules.rate_limit.block_duration, 300);

        document.getElementById('sr-path-scan-enabled').checked = asBool(rules.path_scan.enabled);
        document.getElementById('sr-path-scan-window').value = asInt(rules.path_scan.window, 60);
        document.getElementById('sr-path-scan-max').value = asInt(rules.path_scan.max_unique_paths, 50);
        document.getElementById('sr-path-scan-block').value = asInt(rules.path_scan.block_duration, 600);

        document.getElementById('sr-ssl-enabled').checked = asBool(rules.ssl_handshake_failure.enabled);
        document.getElementById('sr-ssl-window').value = asInt(rules.ssl_handshake_failure.window, 60);
        document.getElementById('sr-ssl-max').value = asInt(rules.ssl_handshake_failure.max_failures, 30);
        document.getElementById('sr-ssl-block').value = asInt(rules.ssl_handshake_failure.block_duration, 60);
        document.getElementById('sr-ssl-fast-close').value = asFloat(rules.ssl_handshake_failure.fast_close_threshold, 0.2);

        document.getElementById('sr-path-rate-enabled').checked = asBool(rules.path_rate_limits.enabled);

        document.getElementById('sr-ip-whitelist-enabled').checked = asBool(rules.ip_whitelist.enabled);
        document.getElementById('sr-cdn-enabled').checked = asBool(rules.cdn_trusted_ips.enabled);

        document.getElementById('sr-malicious-enabled').checked = asBool(rules.malicious_patterns.enabled);
        document.getElementById('sr-malicious-block').value = asInt(rules.malicious_patterns.block_duration, 3600);

        document.getElementById('sr-ua-enabled').checked = asBool(rules.bad_user_agents.enabled);
        document.getElementById('sr-ua-block').value = asInt(rules.bad_user_agents.block_duration, 300);

        document.getElementById('sr-protected-enabled').checked = asBool(rules.protected_paths.enabled);
        document.getElementById('sr-protected-block').value = asInt(rules.protected_paths.block_duration, 1800);
    }

    function createListItem(value) {
        var row = document.createElement('div');
        row.className = 'wls-security-rules-list-item';
        row.innerHTML = ''
            + '<input type="text" class="form-control form-control-sm" value="' + String(value || '').replace(/"/g, '&quot;') + '">'
            + '<button type="button" class="btn btn-sm btn-outline-danger"><?= __('删除') ?></button>';
        row.querySelector('button').addEventListener('click', function () {
            row.remove();
            updateJsonPreview();
        });
        row.querySelector('input').addEventListener('input', updateJsonPreview);
        return row;
    }

    function renderList(containerId, items) {
        var container = document.getElementById(containerId);
        if (!container) {
            return;
        }
        container.innerHTML = '';
        (Array.isArray(items) ? items : []).forEach(function (item) {
            container.appendChild(createListItem(item));
        });
        if (!container.children.length) {
            container.appendChild(createListItem(''));
        }
    }

    function collectList(containerId) {
        var container = document.getElementById(containerId);
        if (!container) {
            return [];
        }
        return Array.from(container.querySelectorAll('input'))
            .map(function (input) { return (input.value || '').trim(); })
            .filter(function (value) { return value.length > 0; });
    }

    function createPathRateRow(rule) {
        var tr = document.createElement('tr');
        tr.innerHTML = ''
            + '<td><input type="checkbox" class="form-check-input sr-path-enabled"></td>'
            + '<td><input type="text" class="form-control form-control-sm sr-path-path" placeholder="/api/framework/query"></td>'
            + '<td><input type="number" min="1" class="form-control form-control-sm sr-path-window"></td>'
            + '<td><input type="number" min="1" class="form-control form-control-sm sr-path-max"></td>'
            + '<td><input type="number" min="1" class="form-control form-control-sm sr-path-block"></td>'
            + '<td><button type="button" class="btn btn-sm btn-outline-danger"><?= __('删除') ?></button></td>';
        tr.querySelector('.sr-path-enabled').checked = asBool(rule.enabled);
        tr.querySelector('.sr-path-path').value = rule.path || '';
        tr.querySelector('.sr-path-window').value = asInt(rule.window, 60);
        tr.querySelector('.sr-path-max').value = asInt(rule.max_requests, 120);
        tr.querySelector('.sr-path-block').value = asInt(rule.block_duration, 120);
        tr.querySelector('button').addEventListener('click', function () {
            tr.remove();
            updateJsonPreview();
        });
        tr.querySelectorAll('input').forEach(function (input) {
            input.addEventListener('input', updateJsonPreview);
            input.addEventListener('change', updateJsonPreview);
        });
        return tr;
    }

    function renderPathRateRows(rules) {
        var body = document.getElementById('sr-path-rate-body');
        if (!body) {
            return;
        }
        body.innerHTML = '';
        (Array.isArray(rules) ? rules : []).forEach(function (item) {
            body.appendChild(createPathRateRow(item || {}));
        });
        if (!body.children.length) {
            body.appendChild(createPathRateRow({ path: '', window: 60, max_requests: 120, block_duration: 120, enabled: true }));
        }
    }

    function collectPathRateRows() {
        var body = document.getElementById('sr-path-rate-body');
        if (!body) {
            return [];
        }
        return Array.from(body.querySelectorAll('tr')).map(function (tr) {
            return {
                enabled: tr.querySelector('.sr-path-enabled').checked,
                path: (tr.querySelector('.sr-path-path').value || '').trim(),
                window: asInt(tr.querySelector('.sr-path-window').value, 60),
                max_requests: asInt(tr.querySelector('.sr-path-max').value, 120),
                block_duration: asInt(tr.querySelector('.sr-path-block').value, 120)
            };
        }).filter(function (item) {
            return item.path.length > 0;
        });
    }

    function collectRules() {
        return {
            rate_limit: {
                enabled: document.getElementById('sr-rate-enabled').checked,
                window: asInt(document.getElementById('sr-rate-window').value, 60),
                max_requests: asInt(document.getElementById('sr-rate-max').value, 200),
                block_duration: asInt(document.getElementById('sr-rate-block').value, 300)
            },
            path_rate_limits: {
                enabled: document.getElementById('sr-path-rate-enabled').checked,
                rules: collectPathRateRows()
            },
            cdn_trusted_ips: {
                enabled: document.getElementById('sr-cdn-enabled').checked,
                ips: collectList('sr-cdn-list')
            },
            ip_whitelist: {
                enabled: document.getElementById('sr-ip-whitelist-enabled').checked,
                ips: collectList('sr-ip-whitelist-list')
            },
            path_scan: {
                enabled: document.getElementById('sr-path-scan-enabled').checked,
                window: asInt(document.getElementById('sr-path-scan-window').value, 60),
                max_unique_paths: asInt(document.getElementById('sr-path-scan-max').value, 50),
                block_duration: asInt(document.getElementById('sr-path-scan-block').value, 600)
            },
            malicious_patterns: {
                enabled: document.getElementById('sr-malicious-enabled').checked,
                patterns: collectList('sr-malicious-list'),
                block_duration: asInt(document.getElementById('sr-malicious-block').value, 3600)
            },
            bad_user_agents: {
                enabled: document.getElementById('sr-ua-enabled').checked,
                patterns: collectList('sr-ua-list'),
                block_duration: asInt(document.getElementById('sr-ua-block').value, 300)
            },
            protected_paths: {
                enabled: document.getElementById('sr-protected-enabled').checked,
                paths: collectList('sr-protected-list'),
                block_duration: asInt(document.getElementById('sr-protected-block').value, 1800)
            },
            ssl_handshake_failure: {
                enabled: document.getElementById('sr-ssl-enabled').checked,
                window: asInt(document.getElementById('sr-ssl-window').value, 60),
                max_failures: asInt(document.getElementById('sr-ssl-max').value, 30),
                block_duration: asInt(document.getElementById('sr-ssl-block').value, 60),
                fast_close_threshold: asFloat(document.getElementById('sr-ssl-fast-close').value, 0.2)
            }
        };
    }

    function updateJsonPreview() {
        var preview = document.getElementById('sr-json-preview');
        if (!preview) {
            return;
        }
        preview.value = JSON.stringify(collectRules(), null, 2);
    }

    function bindListButtons() {
        var mappings = [
            ['sr-add-whitelist-ip', 'sr-ip-whitelist-list', '127.0.0.1'],
            ['sr-add-cdn-ip', 'sr-cdn-list', '10.0.0.0/8'],
            ['sr-add-malicious-pattern', 'sr-malicious-list', '/<script[^>]*>/i'],
            ['sr-add-ua-pattern', 'sr-ua-list', '/sqlmap/i'],
            ['sr-add-protected-path', 'sr-protected-list', '/.git/']
        ];
        mappings.forEach(function (item) {
            var btn = document.getElementById(item[0]);
            var container = document.getElementById(item[1]);
            if (!btn || !container) {
                return;
            }
            btn.addEventListener('click', function () {
                container.appendChild(createListItem(item[2]));
                updateJsonPreview();
            });
        });
    }

    function bindPathRateButton() {
        var btn = document.getElementById('sr-add-path-limit');
        var body = document.getElementById('sr-path-rate-body');
        if (!btn || !body) {
            return;
        }
        btn.addEventListener('click', function () {
            body.appendChild(createPathRateRow({
                path: '/api/',
                window: 60,
                max_requests: 120,
                block_duration: 120,
                enabled: true
            }));
            updateJsonPreview();
        });
    }

    function bindCommonInputEvents() {
        document.querySelectorAll('#save-wls-security-rules, #refresh-wls-security-rules').forEach(function () {});
        document.querySelectorAll('input').forEach(function (input) {
            input.addEventListener('input', updateJsonPreview);
            input.addEventListener('change', updateJsonPreview);
        });
    }

    async function saveRules() {
        var url = '<?= $this->getBackendUrl('*/backend/server-monitor/save-security-rules') ?>';
        var payload = collectRules();
        try {
            var response = await Weline.Api.request(url, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ rules: payload })
            });
            var result = (response && response.data !== undefined) ? response.data : response;
            if (result && result.success) {
                toastSuccess(result.message || __('安全规则已保存'));
                return;
            }
            toastError((result && result.message) || __('保存失败'));
        } catch (error) {
            toastError(__('请求失败：%{1}', {1: (error && error.message) || ''}));
        }
    }

    function renderAll(rules) {
        bindSimpleRules(rules);
        renderPathRateRows(rules.path_rate_limits.rules);
        renderList('sr-ip-whitelist-list', rules.ip_whitelist.ips);
        renderList('sr-cdn-list', rules.cdn_trusted_ips.ips);
        renderList('sr-malicious-list', rules.malicious_patterns.patterns);
        renderList('sr-ua-list', rules.bad_user_agents.patterns);
        renderList('sr-protected-list', rules.protected_paths.paths);
        bindCommonInputEvents();
        updateJsonPreview();
    }

    function init() {
        var rules = parseRulesJson();
        renderAll(rules);
        bindListButtons();
        bindPathRateButton();
        var saveButton = document.getElementById('save-wls-security-rules');
        if (saveButton) {
            saveButton.addEventListener('click', saveRules);
        }
        var refreshButton = document.getElementById('refresh-wls-security-rules');
        if (refreshButton) {
            refreshButton.addEventListener('click', function () {
                location.reload();
            });
        }
    }

    init();
})();
</script>

