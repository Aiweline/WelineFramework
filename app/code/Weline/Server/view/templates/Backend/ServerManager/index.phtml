<script>
const STATUS_API_URL = '<?= $statusApiUrl ?>';
const START_API_URL = '<?= $startApiUrl ?>';
const STOP_API_URL = '<?= $stopApiUrl ?>';
const RESTART_API_URL = '<?= $restartApiUrl ?>';
const RELOAD_API_URL = '<?= $reloadApiUrl ?>';
const MAINTENANCE_ENABLE_API_URL = '<?= $maintenanceEnableApiUrl ?>';
const MAINTENANCE_DISABLE_API_URL = '<?= $maintenanceDisableApiUrl ?>';
const SESSION_LIST_API_URL = '<?= $sessionListApiUrl ?>';
const SESSION_DETAIL_API_URL = '<?= $sessionDetailApiUrl ?>';
const SESSION_DESTROY_API_URL = '<?= $sessionDestroyApiUrl ?>';
const SESSION_PERSIST_API_URL = '<?= $sessionPersistApiUrl ?>';
const SESSION_GC_API_URL = '<?= $sessionGcApiUrl ?>';
const MEMORY_NAMESPACES_API_URL = '<?= $memoryNamespacesApiUrl ?>';
const MEMORY_NAMESPACE_DETAIL_API_URL = '<?= $memoryNamespaceDetailApiUrl ?>';
const MEMORY_NAMESPACE_CLEAR_API_URL = '<?= $memoryNamespaceClearApiUrl ?>';
const MEMORY_KEY_DELETE_API_URL = '<?= $memoryKeyDeleteApiUrl ?>';
const MEMORY_PERSIST_API_URL = '<?= $memoryPersistApiUrl ?>';
const MEMORY_GC_API_URL = '<?= $memoryGcApiUrl ?>';
const DEFAULT_TAB = '<?= $defaultTab ?>';
const GUIDE_URL = '<?= $guideUrl ?>';

let refreshInterval = null;

document.addEventListener('DOMContentLoaded', () => {
    loadServerData();
    // 每 30 秒自动刷新
    refreshInterval = setInterval(loadServerData, 30000);
});

async function loadServerData() {
    try {
        const response = await fetch(STATUS_API_URL, {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }
        
        const data = await response.json();
        
        if (!data.success) {
            throw new Error(data.error || '<?= __('未知错误') ?>');
        }
        
        renderContent(data);
        showContent();
        loadSessionList();
        loadMemoryNamespaces();
        if (DEFAULT_TAB === 'session') {
            scrollToSharedState();
        }
        if (DEFAULT_TAB === 'memory') {
            scrollToSharedState();
        }
        
    } catch (error) {
        console.error('Failed to load server data:', error);
        showError(error.message);
    }
}

function showLoading() {
    document.getElementById('loading-state').classList.remove('d-none');
    document.getElementById('error-state').classList.add('d-none');
    document.getElementById('content-container').classList.add('d-none');
}

function showError(message) {
    document.getElementById('loading-state').classList.add('d-none');
    document.getElementById('error-state').classList.remove('d-none');
    document.getElementById('content-container').classList.add('d-none');
    document.getElementById('error-message').textContent = message;
}

function showContent() {
    document.getElementById('loading-state').classList.add('d-none');
    document.getElementById('error-state').classList.add('d-none');
    document.getElementById('content-container').classList.remove('d-none');
}

function renderContent(data) {
    const container = document.getElementById('content-container');
    const { servers, summary, php_info } = data;
    
    if (DEFAULT_TAB === 'memory' || DEFAULT_TAB === 'session') {
        const title = DEFAULT_TAB === 'memory'
            ? '<?= __('内存服务管理') ?>'
            : '<?= __('Session 管理') ?>';
        const desc = DEFAULT_TAB === 'memory'
            ? '<?= __('当前页面已聚焦到内存服务管理，仅展示内存缓存相关管理能力。') ?>'
            : '<?= __('当前页面已聚焦到 Session 管理，仅展示会话相关管理能力。') ?>';
        container.innerHTML = `
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-database-gear me-2"></i>${title}</h5>
                    <a href="<?= $this->getBackendUrl('*/backend/server-manager') ?>" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> <?= __('返回实例管理') ?>
                    </a>
                </div>
                <div class="card-body text-muted">${desc}</div>
            </div>
        ` + renderSharedStateManagement(data, DEFAULT_TAB);
        return;
    }

    const runningCount = Object.values(servers).filter(s => s.running).length;
    const totalCount = Object.keys(servers).length;
    
    let html = `
        <!-- 状态概览 -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-speedometer2 me-2"></i>
                    <?= __('服务器状态') ?>
                </h5>
                <div>
                    <button class="btn btn-sm btn-outline-primary" onclick="loadServerData()">
                        <i class="bi bi-arrow-clockwise"></i> <?= __('刷新') ?>
                    </button>
                    <a href="${GUIDE_URL}" class="btn btn-sm btn-outline-info ms-2">
                        <i class="bi bi-book"></i> <?= __('优化指南') ?>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-value text-success">${runningCount}</div>
                            <div class="stat-label"><?= __('运行中') ?></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-value text-primary">${totalCount}</div>
                            <div class="stat-label"><?= __('实例总数') ?></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-value ${summary.missing > 0 ? 'text-warning' : 'text-success'}">
                                ${summary.installed}/${summary.total}
                            </div>
                            <div class="stat-label"><?= __('优化项') ?></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- PHP 环境信息 -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-info-circle me-2"></i>
                    <?= __('PHP 环境') ?>
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr>
                                <th width="40%"><?= __('PHP 版本') ?></th>
                                <td><code>${escapeHtml(php_info.version)}</code></td>
                            </tr>
                            <tr>
                                <th><?= __('PHP 路径') ?></th>
                                <td><code class="text-truncate d-inline-block" style="max-width: 300px;" title="${escapeHtml(php_info.binary)}">${escapeHtml(php_info.binary)}</code></td>
                            </tr>
                            <tr>
                                <th><?= __('配置文件') ?></th>
                                <td><code class="text-truncate d-inline-block" style="max-width: 300px;" title="${escapeHtml(php_info.ini_path)}">${escapeHtml(php_info.ini_path)}</code></td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr>
                                <th width="40%"><?= __('扩展目录') ?></th>
                                <td><code class="text-truncate d-inline-block" style="max-width: 300px;" title="${escapeHtml(php_info.ext_dir)}">${escapeHtml(php_info.ext_dir)}</code></td>
                            </tr>
                            <tr>
                                <th><?= __('操作系统') ?></th>
                                <td><code>${escapeHtml(php_info.os)} (${escapeHtml(php_info.arch)})</code></td>
                            </tr>
                            <tr>
                                <th><?= __('线程安全') ?></th>
                                <td>${php_info.thread_safe ? '<span class="badge bg-success">TS</span>' : '<span class="badge bg-info">NTS</span>'}</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 服务器实例列表 -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-hdd-rack me-2"></i>
                    <?= __('服务器实例') ?>
                </h5>
                <button class="btn btn-sm btn-success" onclick="startNewServer()">
                    <i class="bi bi-plus-lg"></i> <?= __('启动新实例') ?>
                </button>
            </div>
            <div class="card-body">
    `;
    
    if (totalCount === 0) {
        html += `
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-3"><?= __('暂无服务器实例') ?></p>
                <p class="small"><?= __('运行') ?> <code>php bin/w server:start</code> <?= __('启动服务器') ?></p>
            </div>
        `;
    } else {
        html += `
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th><?= __('实例名称') ?></th>
                            <th><?= __('监听地址') ?></th>
                            <th><?= __('端口范围') ?></th>
                            <th><?= __('Worker 数') ?></th>
                            <th><?= __('状态') ?></th>
                            <th><?= __('操作') ?></th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        for (const [name, server] of Object.entries(servers)) {
            const port = server.port || 9981;
            const count = server.count || 1;
            const endPort = port + count - 1;
            const isRunning = server.running || false;
            
            html += `
                <tr data-instance="${escapeHtml(name)}">
                    <td><strong>${escapeHtml(name)}</strong></td>
                    <td><code>${escapeHtml(server.host || '127.0.0.1')}</code></td>
                    <td><code>${port} - ${endPort}</code></td>
                    <td>${count}</td>
                    <td>
                        ${isRunning 
                            ? '<span class="badge bg-success"><i class="bi bi-circle-fill me-1"></i><?= __('运行中') ?></span>'
                            : '<span class="badge bg-secondary"><i class="bi bi-circle me-1"></i><?= __('已停止') ?></span>'
                        }
                    </td>
                    <td>
                        ${isRunning ? `
                            <button class="btn btn-sm btn-warning server-action-btn" onclick="restartServer('${escapeHtml(name)}')" title="<?= __('重启') ?>">
                                <i class="bi bi-arrow-repeat"></i>
                            </button>
                            <button class="btn btn-sm btn-info server-action-btn" onclick="reloadServer('${escapeHtml(name)}')" title="<?= __('热重载') ?>">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                            <button class="btn btn-sm btn-danger server-action-btn" onclick="stopServer('${escapeHtml(name)}')" title="<?= __('停止') ?>">
                                <i class="bi bi-stop-fill"></i>
                            </button>
                            <button class="btn btn-sm btn-secondary server-action-btn" onclick="toggleMaintenance('${escapeHtml(name)}', true)" title="<?= __('启用维护模式') ?>">
                                <i class="bi bi-shield-fill-check"></i>
                            </button>
                            <button class="btn btn-sm btn-secondary server-action-btn" onclick="toggleMaintenance('${escapeHtml(name)}', false)" title="<?= __('禁用维护模式') ?>">
                                <i class="bi bi-shield-x"></i>
                            </button>
                        ` : `
                            <button class="btn btn-sm btn-success server-action-btn" onclick="startServer('${escapeHtml(name)}')" title="<?= __('启动') ?>">
                                <i class="bi bi-play-fill"></i>
                            </button>
                        `}
                    </td>
                </tr>
            `;
        }
        
        html += `
                    </tbody>
                </table>
            </div>
        `;
    }
    
    html += `
            </div>
        </div>
        
        <!-- 性能优化项 -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-lightning-charge me-2"></i>
                    <?= __('性能优化') ?>
                    <span class="badge bg-${summary.missing > 0 ? 'warning' : 'success'} ms-2">
                        ${summary.missing > 0 ? '<?= __('可优化') ?> +' + summary.potential_boost : '<?= __('已最优') ?>'}
                    </span>
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
    `;
    
    for (const [key, opt] of Object.entries(summary.optimizations)) {
        if (opt.priority === 'skip') continue;
        
        const isInstalled = opt.installed || false;
        
        html += `
            <div class="col-md-4 mb-3">
                <div class="optimization-card ${isInstalled ? 'installed' : 'missing'}">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">${escapeHtml(opt.name)}</h6>
                            <p class="small text-muted mb-2">${escapeHtml(opt.description)}</p>
                        </div>
                        <span class="badge bg-${isInstalled ? 'success' : 'warning'}">
                            ${isInstalled ? '<?= __('已安装') ?>' : escapeHtml(opt.impact)}
                        </span>
                    </div>
                    ${!isInstalled ? `
                        <a href="${GUIDE_URL}#${key}" class="btn btn-sm btn-outline-primary w-100 mt-2">
                            <i class="bi bi-book"></i> <?= __('查看安装指南') ?>
                        </a>
                    ` : ''}
                </div>
            </div>
        `;
    }
    
    html += `
                </div>
            </div>
        </div>
    `;
    html += renderSharedStateManagement(data);
    
    container.innerHTML = html;
}

function renderSharedStateManagement(data, mode = 'all') {
    const session = data.session || {};
    const memory = data.memory || {};
    const sessionStats = session.stats || {};
    const memoryStats = memory.stats || {};
    const sessionConnectedClass = session.connected ? 'bg-success' : 'bg-danger';
    const sessionConnectedText = session.connected ? '<?= __('已连接') ?>' : '<?= __('不可用') ?>';
    const memoryConnectedClass = memory.connected ? 'bg-success' : 'bg-danger';
    const memoryConnectedText = memory.connected ? '<?= __('已连接') ?>' : '<?= __('不可用') ?>';

    const showSession = mode === 'all' || mode === 'session';
    const showMemory = mode === 'all' || mode === 'memory';
    return `
        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-database-gear me-2"></i><?= __('共享状态管理') ?></h5>
                <span class="text-muted small"><?= __('覆盖 Session 与 Memory Service 的状态、检索、清理能力') ?></span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    ${showSession ? `
                    <div class="${showMemory ? 'col-lg-6' : 'col-12'}">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0"><i class="bi bi-person-lines-fill me-1"></i><?= __('Session 管理') ?></h6>
                                <span class="badge ${sessionConnectedClass}">${sessionConnectedText}</span>
                            </div>
                            <div class="small text-muted mb-2">
                                ${escapeHtml(session.host || '127.0.0.1')}:${escapeHtml(session.port || 19970)} / ${escapeHtml(session.token_file_name || '')}
                            </div>
                            <div class="mb-2 small">
                                <?= __('Session 数') ?>: <strong>${sessionStats.session_count || 0}</strong>,
                                <?= __('客户端') ?>: <strong>${sessionStats.client_count || 0}</strong>,
                                <?= __('内存') ?>: <strong>${formatBytes(sessionStats.memory_usage || 0)}</strong>
                            </div>
                            <div class="d-flex gap-2 flex-wrap mb-3">
                                <button class="btn btn-sm btn-outline-primary" onclick="loadSessionList()"><i class="bi bi-arrow-clockwise"></i> <?= __('刷新列表') ?></button>
                                <button class="btn btn-sm btn-outline-info" onclick="persistSessionStore()"><i class="bi bi-save"></i> <?= __('立即持久化') ?></button>
                                <button class="btn btn-sm btn-outline-warning" onclick="gcSessionStore()"><i class="bi bi-recycle"></i> <?= __('GC 清理') ?></button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th><?= __('Session ID') ?></th>
                                            <th><?= __('字段数') ?></th>
                                            <th><?= __('预览') ?></th>
                                            <th><?= __('操作') ?></th>
                                        </tr>
                                    </thead>
                                    <caption class="text-start small text-muted"><?= __('点击「查看详情」可查看该 Session 的全部字段信息') ?></caption>
                                    <tbody id="session-list-body">
                                        <tr><td colspan="4" class="text-muted text-center"><?= __('点击“刷新列表”加载 Session 数据') ?></td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    ` : ''}
                    ${showMemory ? `
                    <div class="${showSession ? 'col-lg-6' : 'col-12'}">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0"><i class="bi bi-memory me-1"></i><?= __('内存缓存管理') ?></h6>
                                <span class="badge ${memoryConnectedClass}">${memoryConnectedText}</span>
                            </div>
                            <div class="small text-muted mb-2">
                                ${escapeHtml(memory.host || '127.0.0.1')}:${escapeHtml(memory.port || 19971)} / ${escapeHtml(memory.token_file_name || '')}
                            </div>
                            <div class="mb-2 small">
                                <?= __('命名空间') ?>: <strong>${memoryStats.session_count || 0}</strong>,
