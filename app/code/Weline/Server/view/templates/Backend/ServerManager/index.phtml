        });
        
        const data = await response.json();
        AdminToast.success(data.message || '<?= __('重启成功') ?>');
        setTimeout(loadServerData, 1500);
        
    } catch (error) {
        AdminToast.error('<?= __('重启失败') ?>: ' + error.message);
    }
}

async function reloadServer(instance) {
    AdminToast.info('<?= __('正在热重载...') ?>');

    try {
        const response = await fetch(RELOAD_API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'instance=' + encodeURIComponent(instance),
            credentials: 'same-origin'
        });

        const data = await response.json();
        if (data.success) {
            AdminToast.success(data.message || '<?= __('热重载命令已发送') ?>');
        } else {
            AdminToast.warning(data.message || '<?= __('热重载命令发送失败') ?>');
        }
        setTimeout(loadServerData, 1000);
    } catch (error) {
        AdminToast.error('<?= __('热重载失败：请检查网络连接后重试。') ?> ' + error.message);
    }
}

async function toggleMaintenance(instance, enabled) {
    const apiUrl = enabled ? MAINTENANCE_ENABLE_API_URL : MAINTENANCE_DISABLE_API_URL;
    const actionText = enabled ? '<?= __('启用维护模式') ?>' : '<?= __('禁用维护模式') ?>';
    const confirmed = await BackendConfirm.show('<?= __('确认执行该操作吗？此操作会影响流量接入状态。') ?>', {
        title: actionText,
        type: enabled ? 'warning' : 'info',
        confirmText: '<?= __('确认') ?>',
        cancelText: '<?= __('取消') ?>'
    });
    if (!confirmed) {
        return;
    }

    AdminToast.info(actionText + '...');
    try {
        const response = await fetch(apiUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'instance=' + encodeURIComponent(instance),
            credentials: 'same-origin'
        });
        const data = await response.json();
        if (data.success) {
            AdminToast.success(data.message || actionText + '<?= __('成功') ?>');
        } else {
            AdminToast.warning(data.message || actionText + '<?= __('失败') ?>');
        }
        setTimeout(loadServerData, 1000);
    } catch (error) {
        AdminToast.error(actionText + '<?= __('失败：请检查网络连接后重试。') ?> ' + error.message);
    }
}

function startNewServer() {
    BackendConfirm.showInput({
        title: '<?= __('启动新实例') ?>',
        message: '<?= __('请输入 Worker 数量（留空将使用默认值）') ?>',
        placeholder: '<?= __('例如：4') ?>',
        defaultValue: ''
    }).then(workers => {
        if (workers === null) {
            return;
        }
        AdminToast.info('<?= __('正在启动新实例...') ?>');

        const body = 'instance=default' + (workers ? '&workers=' + encodeURIComponent(workers) : '');

        fetch(START_API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: body,
            credentials: 'same-origin'
        })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    AdminToast.success(data.message || '<?= __('启动成功') ?>');
                } else {
                    AdminToast.warning(data.message || '<?= __('启动命令已发送，请稍后刷新状态。') ?>');
                }
                setTimeout(loadServerData, 1000);
            })
            .catch(error => {
                AdminToast.error('<?= __('启动失败：请检查网络连接后重试。') ?> ' + error.message);
            });
    });
}
</script>
