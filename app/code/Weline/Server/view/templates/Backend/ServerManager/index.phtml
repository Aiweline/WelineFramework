async function showSessionDetail(encodedSessionId) {
    const sessionId = decodeURIComponent(encodedSessionId);
    const offcanvasEl = document.getElementById('sessionDetailOffcanvas');
    const loadingEl = document.getElementById('session-detail-loading');
    const contentEl = document.getElementById('session-detail-content');
    const emptyEl = document.getElementById('session-detail-empty');
    const idEl = document.getElementById('session-detail-id');
    const bodyEl = document.getElementById('session-detail-body');
    if (!offcanvasEl || !bodyEl) return;

    const bsOffcanvas = bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl);
    bsOffcanvas.show();
    loadingEl.classList.remove('d-none');
    contentEl.classList.add('d-none');
    emptyEl.classList.add('d-none');
    idEl.textContent = sessionId;

    try {
        const response = await fetch(SESSION_DETAIL_API_URL + '?session_id=' + encodeURIComponent(sessionId), {
            method: 'GET',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        });
        const data = await response.json();
        loadingEl.classList.add('d-none');
        if (!data.success || !Array.isArray(data.data) || !data.data.length) {
            emptyEl.classList.remove('d-none');
            return;
        }
        bodyEl.innerHTML = data.data.map(row => {
            const key = escapeHtml(String(row.key || ''));
            const type = escapeHtml(String(row.type || ''));
            const valueHtml = renderSessionDetailValue(row);
            return `<tr><td><code class="small">${key}</code></td><td><span class="badge bg-secondary">${type}</span></td><td class="small">${valueHtml}</td></tr>`;
        }).join('');
        contentEl.classList.remove('d-none');
    } catch (error) {
        loadingEl.classList.add('d-none');
        emptyEl.textContent = '<?= __('加载失败：') ?>' + escapeHtml(error.message);
        emptyEl.classList.remove('d-none');
    }
}

function renderSessionDetailValue(row) {
    const detail = row && row.preview_detail && typeof row.preview_detail === 'object' ? row.preview_detail : null;
    const fallback = escapeHtml(row && row.preview ? String(row.preview) : '-');
    if (!detail) return `<span class="text-muted">${fallback}</span>`;
    const kind = String(detail.kind || '');
    const display = escapeHtml(detail.display || row.preview || '');
    const size = Number(detail.size || 0);
    const json = typeof detail.json === 'string' ? detail.json.trim() : '';
    if ((kind === 'array' || kind === 'object') && json) {
        return `<details class="mt-1"><summary><span class="badge bg-info">${display}</span><span class="text-muted ms-1">(${Number.isFinite(size) ? size : 0} <?= __('项') ?>)</span></summary><pre class="small mb-0 mt-2 p-2 border rounded bg-body-tertiary" style="white-space:pre-wrap; word-break:break-word;">${escapeHtml(json)}</pre></details>`;
    }
    if (kind === 'null') return '<span class="badge bg-secondary">null</span>';
    return `<span class="text-break">${display}</span>`;
}

