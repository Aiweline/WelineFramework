function renderSessionPreview(preview) {
    if (!preview || typeof preview !== 'object') {
        return '<span class="text-muted small">-</span>';
    }
    const entries = Object.entries(preview);
    if (!entries.length) {
        return '<span class="text-muted small">-</span>';
    }
    const authKeys = ['WF_BACKEND_USER', 'WF_FRONTEND_USER', 'WF_BACKEND_USER_ID', 'WF_FRONTEND_USER_ID'];
    const items = entries.map(([k, v]) => {
        const isSensitive = v === '***';
        const isAuth = authKeys.includes(k);
        const val = escapeHtml(String(v));
        const keyCls = isAuth ? 'bg-primary text-white' : 'bg-secondary';
        const valCls = isSensitive ? 'text-muted' : 'text-dark';
        const valIcon = isSensitive ? '<i class="bi bi-shield-lock-fill small me-1" title="<?= __('敏感') ?>"></i>' : '';
        return `<span class="d-inline-flex align-items-center gap-1 me-2 mb-1">
            <span class="badge ${keyCls}">${escapeHtml(k)}</span>
            <span class="small ${valCls}">${valIcon}${val.length > 40 ? val.substring(0, 40) + '…' : val}</span>
        </span>`;
    });
    const shortHtml = items.join('');
    const fullHtml = entries.map(([k, v]) => `<div class="mb-1"><span class="badge bg-body-secondary me-1">${escapeHtml(k)}</span><span class="small">${escapeHtml(String(v))}</span></div>`).join('');
    return `
        <details class="weline-session-preview">
            <summary class="small cursor-pointer list-unstyled mb-0">${shortHtml}</summary>
            <div class="mt-2 p-2 rounded border bg-body-tertiary small" style="max-width: 420px; max-height: 200px; overflow-y: auto;">${fullHtml}</div>
        </details>
    `;
}

function renderMemoryPreview(row) {
    const detail = row && row.preview_detail && typeof row.preview_detail === 'object' ? row.preview_detail : null;
    const fallback = escapeHtml(row && row.preview ? row.preview : '');
    if (!detail) {
        return `<span class="text-muted">${fallback}</span>`;
    }

    const kind = String(detail.kind || '');
    const display = escapeHtml(detail.display || row.preview || '');
    const size = Number(detail.size || 0);
    const json = typeof detail.json === 'string' ? detail.json.trim() : '';
    if ((kind === 'array' || kind === 'object') && json) {
        return `
            <details class="mt-1">
                <summary>
                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">${display}</span>
                    <span class="text-muted ms-1">(<?= __('元素') ?>: ${Number.isFinite(size) ? size : 0})</span>
                </summary>
                <pre class="small mb-0 mt-2 p-2 border rounded bg-body-tertiary" style="max-width:560px; white-space:pre-wrap; word-break:break-word;">${escapeHtml(json)}</pre>
            </details>
        `;
    }
    if (kind === 'null') {
        return `<span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">null</span>`;
    }
    return `<span class="text-muted">${display}</span>`;
}

