<?php
/**
 * Hook 名称：Weline_Websites::backend::partials::domain::tabs-content
 * 
 * 在域名管理页面注入"证书管理"Tab 内容面板。
 * 通过 AJAX 加载 Server 模块已有的 SSL 证书管理 UI，复用已有功能。
 *
 * @hook-priority 150
 * @hook-sort-order 100
 * @hook-solo false
 */
$this->request->addModule('Weline_Server');
\Weline\Framework\Phrase\Parser::$loaded = false;

$sslIndexUrl = $this->getBackendUrl('server/backend/ssl-certificate');
?>
<div class='tab-pane fade'
     id='domain-certificate'
     role='tabpanel'
     aria-labelledby='domain-certificate-tab'>
    <div id="ssl-cert-container" class="p-2">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted"><?= __('正在加载证书管理...') ?></p>
        </div>
    </div>
</div>

<script>
(function() {
    var sslUrl = '<?= $sslIndexUrl ?>';
    var container = document.getElementById('ssl-cert-container');
    var loaded = false;

    // 当 Tab 被激活时加载内容
    var tabEl = document.getElementById('domain-certificate-tab');
    if (tabEl) {
        tabEl.addEventListener('shown.bs.tab', function() {
            if (!loaded) {
                loadSslContent();
                loaded = true;
            }
        });
    }

    function loadSslContent() {
        fetch(sslUrl, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'text/html'
            }
        })
        .then(function(response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.text();
        })
        .then(function(html) {
            // 尝试解析为 JSON（如果是 JSON 格式则提取 HTML）
            try {
                var json = JSON.parse(html);
                if (json.html) {
                    html = json.html;
                }
            } catch(e) {
                // 不是 JSON，直接使用 HTML
            }
            
            container.innerHTML = html;

            // 执行嵌入的脚本
            var scripts = container.querySelectorAll('script');
            scripts.forEach(function(oldScript) {
                var newScript = document.createElement('script');
                Array.from(oldScript.attributes).forEach(function(attr) {
                    newScript.setAttribute(attr.name, attr.value);
                });
                if (oldScript.innerHTML) {
                    newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                }
                oldScript.parentNode.replaceChild(newScript, oldScript);
            });
        })
        .catch(function(err) {
            container.innerHTML = '<div class="alert alert-warning">' +
                '<i class="mdi mdi-alert me-1"></i>' +
                '<?= __('加载证书管理界面失败') ?>: ' + err.message +
                '<br><a href="' + sslUrl + '" target="_blank" class="btn btn-sm btn-outline-primary mt-2">' +
                '<i class="mdi mdi-open-in-new me-1"></i><?= __('在新窗口打开证书管理') ?></a></div>';
        });
    }
})();
</script>
