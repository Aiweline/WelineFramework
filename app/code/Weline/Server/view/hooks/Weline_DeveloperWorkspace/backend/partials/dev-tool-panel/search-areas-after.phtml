    function register() {
        var manifest = {
            id: 'wls',
            title: 'WLS 服务',
            order: 40,
            activate: function() {
                return loadWlsContent();
            },
            report: function(ctx, options) {
                return getWlsPanelReport(options || {});
            }
        };
        window.__WELINE_PANEL_REPORT_PROVIDERS__ = window.__WELINE_PANEL_REPORT_PROVIDERS__ || {};
        window.__WELINE_PANEL_REPORT_PROVIDERS__.wls = function(options) {
            return getWlsPanelReport(options || {});
        };
        window.__WELINE_PANEL_TABS__ = window.__WELINE_PANEL_TABS__ || {};
        window.__WELINE_PANEL_TABS__.wls = manifest;
        window.__WELINE_PANEL_TAB_QUEUE__ = window.__WELINE_PANEL_TAB_QUEUE__ || [];
        if (window.WelinePanel && typeof window.WelinePanel.registerTab === 'function') {
            window.WelinePanel.registerTab(manifest);
        } else {
            var queued = false;
            for (var i = 0; i < window.__WELINE_PANEL_TAB_QUEUE__.length; i++) {
                if (window.__WELINE_PANEL_TAB_QUEUE__[i] && window.__WELINE_PANEL_TAB_QUEUE__[i].id === 'wls') {
                    queued = true;
                    break;
                }
            }
            if (!queued) {
                window.__WELINE_PANEL_TAB_QUEUE__.push(manifest);
            }
        }
        if (window.WelinePanel && typeof window.WelinePanel.registerReportProvider === 'function') {
            window.WelinePanel.registerReportProvider('wls', function(options) {
                return getWlsPanelReport(options || {});
            });
        }
        if (typeof window.DevToolPanelRegisterExtensionTab === 'function') {
            window.DevToolPanelRegisterExtensionTab('wls', loadWlsContent);
            bindWlsRefreshButton();
        } else if (window.DevToolPanel && typeof window.DevToolPanel.registerExtensionTab === 'function') {
            window.DevToolPanel.registerExtensionTab('wls', loadWlsContent);
            bindWlsRefreshButton();
        } else {
            setTimeout(register, 50);
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', register);
    } else {
        register();
    }
    
    function escapeHtml(text) {
        return String(text || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function resolveApiMessage(result, fallback) {
        if (!result || typeof result !== 'object') {
            return fallback || '加载失败';
        }
        return String(result.message || result.msg || fallback || '加载失败').trim() || (fallback || '加载失败');
    }

    function buildWlsPanelEndpoint(path, params) {
        var base = String(wlsPerformanceEndpointUrl || '').replace(/\/+$/, '');
        var cleanPath = String(path || '').replace(/^\/+/, '');
        var url = base + (cleanPath ? '/' + cleanPath : '');
        var query = new URLSearchParams();
        params = params || {};
        Object.keys(params).forEach(function(key) {
            var value = params[key];
            if (value === undefined || value === null || value === '') {
                return;
            }
            query.set(key, String(value));
        });
        var queryString = query.toString();
        return queryString ? url + '?' + queryString : url;
    }

    function fetchWlsPanelJson(path, params, options) {
        options = options || {};
        var method = String(options.method || 'GET').toUpperCase();
        var request = {
            method: method,
            credentials: 'same-origin',
            cache: 'no-store',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'X-Weline-Panel': '1'
            }
        };
        var url = buildWlsPanelEndpoint(path, method === 'GET' ? params : {});
        if (method !== 'GET') {
            request.headers['Content-Type'] = 'application/json';
            request.body = JSON.stringify(params || {});
        }
        return fetch(url, request).then(function(response) {
            return response.text().then(function(text) {
                var payload = {};
                if (text) {
                    try {
                        payload = JSON.parse(text);
                    } catch (error) {
                        throw new Error('WLS 面板接口返回非 JSON 内容');
                    }
                }
                if (!response.ok || payload.success === false) {
                    throw new Error(resolveApiMessage(payload, 'WLS 面板接口请求失败'));
                }
                return payload;
            });
        });
    }

