    function loadWlsPerformanceSummary(content, force) {
        if (!content || !document.getElementById('wls-performance-summary')) {
            return Promise.resolve(null);
        }
        if (!force && document.getElementById('wls-performance-summary').getAttribute('data-loaded') === '1') {
            return Promise.resolve(null);
        }
        setWlsPerformanceStatus('正在加载 WLS 性能快照...');
        return getWlsPanelReport({ refresh: true, limit: 20 }).then(function(report) {
            var summary = report.summary || {};
            var requests = report.requests || {};
            var bottlenecks = report.bottlenecks || {};
            var slow = Array.isArray(bottlenecks.slowRequests) ? bottlenecks.slowRequests[0] : null;
            var text = '请求 ' + (summary.request_count || requests.total || 0)
                + '，平均 ' + Number(summary.avg_ms || 0).toFixed(2) + ' ms'
                + '，P95 ' + Number(summary.p95_ms || 0).toFixed(2) + ' ms';
            if (slow && slow.uri) {
                text += '，最慢 ' + slow.uri + ' ' + Number(slow.total_ms || 0).toFixed(2) + ' ms';
            }
            var node = document.getElementById('wls-performance-summary');
            if (node) {
                node.textContent = text;
                node.setAttribute('data-loaded', '1');
            }
            return report;
        }).catch(function(error) {
            setWlsPerformanceStatus((error && error.message) || 'WLS 性能快照加载失败');
            return null;
        });
    }

    function mountWlsPerformanceDiagnostics(content) {
        var target = document.getElementById('weline-panel-wls-diagnostics');
        if (!content || !target) {
            return Promise.resolve(null);
        }
        target.innerHTML = '<div class="wls-loading">正在加载 WLS 性能明细...</div>';
        return ensureWlsPerformanceAgent(true).then(function(agent) {
            if (!agent || typeof agent.mount !== 'function') {
                throw new Error('WLS 性能诊断内嵌接口不可用');
            }
            return agent.mount(target, { requestId: window.__WELINE_REQUEST_ID__ || '' });
        }).catch(function(error) {
            target.innerHTML = '<div class="wls-error">' + escapeHtml((error && error.message) || 'WLS 性能诊断加载失败') + '</div>';
            throw error;
        });
    }

    function publishWlsPanelReport(trigger) {
