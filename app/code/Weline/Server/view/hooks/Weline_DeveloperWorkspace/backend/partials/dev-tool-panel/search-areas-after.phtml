    function activateWlsSectionTab(tab) {
        var active = isValidWlsSectionTab(tab) ? tab : 'runtime';
        saveWlsSectionTab(active);
        document.querySelectorAll('[data-wls-section-tab]').forEach(function(button) {
            button.setAttribute('aria-selected', button.getAttribute('data-wls-section-tab') === active ? 'true' : 'false');
        });
        document.querySelectorAll('[data-wls-section-panel]').forEach(function(panel) {
            if (panel.getAttribute('data-wls-section-panel') === active) {
