<script>
(function() {
    var wlsRequestHistory = [];
    var wlsPerformanceAgentPromise = null;
    var wlsPerformanceCssPromise = null;
    var wlsSectionTabStateKey = 'weline-devtool-wls-section-tab-v1';
    var wlsPerformanceJsUrl = <?= json_encode($wlsPerformanceJsUrl, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
    var wlsPerformanceCssUrl = <?= json_encode($wlsPerformanceCssUrl, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
    var wlsPerformanceEndpointUrl = <?= json_encode($wlsPerformanceEndpointUrl, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
    var wlsPanelRuntimeConfig = <?= $wlsPanelRuntimeConfigJson ?>;
    window.__WELINE_PANEL_WLS_CONFIG__ = Object.assign(
        {},
        wlsPanelRuntimeConfig || {},
        window.__WELINE_PANEL_WLS_CONFIG__ || {}
    );
    function formatUptime(seconds) {
        if (seconds < 60) return seconds + ' 秒';
        if (seconds < 3600) { var m = Math.floor(seconds / 60), s = seconds % 60; return m + ' 分 ' + s + ' 秒'; }
        var h = Math.floor(seconds / 3600), m = Math.floor((seconds % 3600) / 60);
        return h + ' 小时 ' + m + ' 分';
    }
    function getWlsRuntimeConfig() {
        return Object.assign({}, wlsPanelRuntimeConfig || {}, window.__WELINE_PANEL_WLS_CONFIG__ || {});
    }
    function hasWlsRuntimeHint() {
        var cfg = getWlsRuntimeConfig();
        return cfg.isWls === true || String(cfg.runtimeMode || '').toLowerCase() === 'wls';
    }
    function normalizeWlsStatus(value) {
        return String(value || '').toLowerCase();
    }
    function isHealthyWlsStatus(value) {
        return ['healthy', 'ok', 'running', 'wls', 'ready'].indexOf(normalizeWlsStatus(value)) !== -1;
    }
    function requestWlsHealth() {
        var healthUrl = getWlsRuntimeConfig().healthUrl || '/_wls/health?detail=1';
        if (typeof fetch === 'function') {
            return fetch(healthUrl, {
                method: 'GET',
                cache: 'no-store',
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' }
            }).then(function(response) {
                if (!response.ok) {
                    return { ok: false, status: response.status, data: null };
                }
                return response.json().then(function(data) {
                    return { ok: true, status: response.status, data: data };
                });
            });
        }

        return Promise.resolve({ ok: false, status: 0, data: null });
    }
    function normalizeWlsHealthInfo(response) {
        if (!response || !response.ok) {
            if (response && response.status === 403) {
                return { isWls: 'restricted' };
            }
            return { isWls: false };
        }
        var data = response.data;
        if (!data || typeof data !== 'object') {
            return { isWls: false };
        }
        var memoryMb = data.memory_usage ? (data.memory_usage / 1024 / 1024).toFixed(2) : null;
        return {
            workerId: data.worker_id !== undefined ? String(data.worker_id) : null,
            workerPort: data.port ? String(data.port) : null,
            workerPid: data.pid ? String(data.pid) : '-',
            instance: data.instance || 'default',
            requestCount: data.total_requests !== undefined ? String(data.total_requests) : '0',
            memory: memoryMb,
            uptime: data.uptime !== undefined ? String(data.uptime) : '0',
            connections: data.connections || 0,
            activeRequests: data.active_requests || 0,
            detectionSource: 'health',
            isWls: isHealthyWlsStatus(data.status) || hasWlsRuntimeHint()
        };
    }
    function normalizeWlsRuntimeHintInfo() {
        if (!hasWlsRuntimeHint()) {
            return null;
        }
        var cfg = getWlsRuntimeConfig();
        var signals = cfg.signals && typeof cfg.signals === 'object' ? cfg.signals : {};
        return {
            workerId: signals.WLS_WORKER_ID ? String(signals.WLS_WORKER_ID) : null,
            workerPort: signals.WLS_WORKER_PORT ? String(signals.WLS_WORKER_PORT) : null,
            workerPid: signals.WLS_WORKER_PID ? String(signals.WLS_WORKER_PID) : '-',
            instance: signals.WLS_INSTANCE_NAME || signals.WLS_INSTANCE || 'default',
            requestCount: '0',
            memory: null,
            uptime: '0',
            connections: '-',
            activeRequests: '-',
            detectionSource: 'runtime',
            isWls: true
        };
    }
    function normalizeWlsSummaryInfo(summary) {
        if (!summary || typeof summary !== 'object' || summary.success === false) {
            return null;
        }
        var requestCount = Number(summary.request_count || 0);
        var slowest = summary.slowest && typeof summary.slowest === 'object' ? summary.slowest : {};
        var hasTraceData = requestCount > 0 || !!slowest.request_id;
        if (!hasTraceData && !hasWlsRuntimeHint()) {
            return null;
        }
        return {
            workerId: slowest.worker_id ? String(slowest.worker_id) : null,
            workerPort: slowest.worker_port ? String(slowest.worker_port) : null,
            workerPid: slowest.pid ? String(slowest.pid) : '-',
            instance: slowest.instance || 'default',
            requestCount: String(requestCount || 0),
            memory: null,
            uptime: '0',
            connections: '-',
            activeRequests: '-',
            detectionSource: hasTraceData ? 'performance-summary' : 'runtime',
            isWls: true
        };
    }
    function mergeWlsInfo() {
        var merged = {};
        Array.prototype.slice.call(arguments).forEach(function(info) {
            if (!info || typeof info !== 'object') {
                return;
            }
            Object.keys(info).forEach(function(key) {
                var value = info[key];
                if (value !== undefined && value !== null && value !== '') {
                    merged[key] = value;
                }
            });
        });
        return merged;
    }
    function detectWlsService() {
        return requestWlsHealth().then(function(response) {
            var healthInfo = normalizeWlsHealthInfo(response);
            if (healthInfo && healthInfo.isWls === true) {
                return healthInfo;
            }
            return fetchWlsPanelJson('summary', { window_sec: 300 }).then(function(summary) {
                var summaryInfo = normalizeWlsSummaryInfo(summary);
                var runtimeInfo = normalizeWlsRuntimeHintInfo();
                if (summaryInfo || runtimeInfo) {
                    return mergeWlsInfo(runtimeInfo, healthInfo, summaryInfo, { isWls: true });
                }
                return healthInfo || { isWls: false };
            }).catch(function() {
                var runtimeInfo = normalizeWlsRuntimeHintInfo();
                if (runtimeInfo) {
                    return mergeWlsInfo(runtimeInfo, healthInfo, { isWls: true });
                }
                return healthInfo || { isWls: false };
            });
        }).catch(function() {
            var runtimeInfo = normalizeWlsRuntimeHintInfo();
            if (runtimeInfo) {
                return runtimeInfo;
            }
            return fetchWlsPanelJson('summary', { window_sec: 300 }).then(function(summary) {
                return normalizeWlsSummaryInfo(summary) || { isWls: false };
            }).catch(function() {
                return { isWls: false };
            });
        });
    }

    function bindWlsRefreshButton() {
        var btn = document.getElementById('dev-tool-wls-refresh-btn');
        if (!btn || btn.getAttribute('data-wls-refresh-bound') === '1') {
            return;
        }
        btn.setAttribute('data-wls-refresh-bound', '1');
        btn.addEventListener('click', loadWlsContent);
    }

    function bindWlsContentActionContainer(content) {
        if (!content || content.getAttribute('data-wls-action-bound') === '1') {
            return;
        }
        content.setAttribute('data-wls-action-bound', '1');
        content.addEventListener('click', handleWlsContentAction);
    }

    function handleWlsContentAction(event) {
        var trigger = event.target.closest('[data-wls-action]');
        if (!trigger || !event.currentTarget.contains(trigger)) {
            return;
        }

        var action = trigger.getAttribute('data-wls-action');
        if (action === 'switch-wls-section-tab') {
            activateWlsSectionTab(trigger.getAttribute('data-wls-section-tab') || 'runtime');
            return;
        }
        if (action === 'load-attack-stats') {
            window.loadWlsAttackStats();
            return;
        }
        if (action === 'load-performance-summary') {
            loadWlsPerformanceSummary(document.getElementById('dev-tool-content'), true);
            return;
        }
        if (action === 'publish-performance-report') {
            publishWlsPanelReport(trigger);
            return;
        }
        if (action === 'mount-performance-diagnostics') {
            trigger.disabled = true;
            mountWlsPerformanceDiagnostics(document.getElementById('dev-tool-content')).catch(function(error) {
                setWlsPerformanceStatus((error && error.message) || 'WLS 性能诊断加载失败');
            }).finally(function() {
                trigger.disabled = false;
            });
            return;
        }
        if (action === 'set-health-allow-cookie') {
            trigger.disabled = true;
            fetchWlsPanelJson('', { operation: 'health-allow-cookie' }).then(function(res) {
                if (!res || res.success === false) {
                    throw new Error(resolveApiMessage(res, '健康检查放行失败'));
                }
                if (window.BackendToast && res.message) window.BackendToast[res.success ? 'success' : 'warning'](res.message);
                return res;
            }).then(function(res) {
                if (!window.BackendToast && res && res.message) {
                    setWlsPerformanceStatus(res.message);
                }
            }).catch(function(error) {
                if (window.BackendToast) {
                    window.BackendToast.error((error && error.message) || '健康检查放行失败');
                } else {
                    setWlsPerformanceStatus((error && error.message) || '健康检查放行失败');
                }
            }).finally(function() { trigger.disabled = false; });
        }
    }

    function getWlsSectionTabs() {
        return [
            { key: 'runtime', label: '请求处理', icon: 'fa-cog' },
            { key: 'workers', label: 'Worker 分配', icon: 'fa-balance-scale' },
            { key: 'security', label: '安全监控', icon: 'fa-shield' },
            { key: 'links', label: '快速链接', icon: 'fa-link' },
            { key: 'performance', label: '性能诊断', icon: 'fa-line-chart' }
        ];
    }

    function isValidWlsSectionTab(tab) {
        return getWlsSectionTabs().some(function(item) {
            return item.key === tab;
        });
    }

    function readWlsSectionTab() {
        try {
            var value = window.localStorage ? window.localStorage.getItem(wlsSectionTabStateKey) : '';
            return isValidWlsSectionTab(value) ? value : 'runtime';
        } catch (error) {
            return 'runtime';
        }
    }

