foreach (['WLS_MODE', 'WLS_PROCESS_ROLE', 'WLS_INSTANCE', 'WLS_INSTANCE_NAME', 'WLS_WORKER_ID', 'WLS_WORKER_PORT', 'WLS_WORKER_PID'] as $wlsSignalKey) {
