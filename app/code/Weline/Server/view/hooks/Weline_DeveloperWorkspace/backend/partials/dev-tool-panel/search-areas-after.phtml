    function ensureWlsPerformanceConfig() {
        window.__WELINE_PANEL_WLS_CONFIG__ = Object.assign({}, window.__WELINE_PANEL_WLS_CONFIG__ || {}, {
            requestId: window.__WELINE_REQUEST_ID__ || getWlsRuntimeConfig().requestId || '',
            mountSelector: '#weline-panel-wls-diagnostics',
            endpointUrl: wlsPerformanceEndpointUrl
        });
    }

    function loadWlsPerformanceCss() {
        if (document.querySelector('link[data-weline-panel-wls="css"]')) {
            return Promise.resolve();
        }
        if (wlsPerformanceCssPromise) {
            return wlsPerformanceCssPromise;
        }
        wlsPerformanceCssPromise = new Promise(function(resolve, reject) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = wlsPerformanceCssUrl;
            link.setAttribute('data-weline-panel-wls', 'css');
            link.onload = function() { resolve(); };
            link.onerror = function() { reject(new Error('WLS 性能面板样式加载失败')); };
            document.head.appendChild(link);
        });
        return wlsPerformanceCssPromise;
    }

    function ensureWlsPerformanceAgent(withCss) {
        ensureWlsPerformanceConfig();
        var cssPromise = withCss ? loadWlsPerformanceCss() : Promise.resolve();
        if (window.__WELINE_PANEL_WLS_AGENT__) {
            return cssPromise.then(function() { return window.__WELINE_PANEL_WLS_AGENT__; });
        }
        if (!wlsPerformanceAgentPromise) {
            wlsPerformanceAgentPromise = new Promise(function(resolve, reject) {
                var existing = document.querySelector('script[data-weline-panel-wls="js"]');
                var finish = function() {
                    if (window.__WELINE_PANEL_WLS_AGENT__) {
                        resolve(window.__WELINE_PANEL_WLS_AGENT__);
                    } else {
                        reject(new Error('WLS 性能面板 API 未注册'));
                    }
                };
                if (existing) {
                    if (window.__WELINE_PANEL_WLS_AGENT__) {
                        finish();
                    } else {
                        existing.addEventListener('load', finish, { once: true });
                        existing.addEventListener('error', function() { reject(new Error('WLS 性能面板脚本加载失败')); }, { once: true });
                    }
                    return;
                }
                var script = document.createElement('script');
                script.src = wlsPerformanceJsUrl;
                script.defer = true;
                script.setAttribute('data-weline-panel-wls', 'js');
                script.onload = finish;
                script.onerror = function() { reject(new Error('WLS 性能面板脚本加载失败')); };
                document.head.appendChild(script);
            });
        }
        return cssPromise.then(function() {
            return wlsPerformanceAgentPromise;
        });
    }

    function normalizeWlsPanelReport(report) {
        var output = Object.assign({}, report || {});
