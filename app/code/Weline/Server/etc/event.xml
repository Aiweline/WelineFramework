<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- CLI 命令执行完成后，通知 WLS Worker 重载 -->
    <event name="Weline_Framework::cli::command_executed">
        <observer name="Weline_Server::wls_worker_reload" 
                  instance="Weline\Server\Observer\CliCommandExecutedObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="100"/>
    </event>

    <!-- 系统配置变更后，通知 WLS Worker 重载（仅服务器相关模块） -->
    <event name="Weline_SystemConfig::domain::config_set_after">
        <observer name="Weline_Server::config_changed_reload"
                  instance="Weline\Server\Observer\ConfigChangedObserver"
                  disabled="false"
                  shared="true"
                  sort="10"/>
    </event>
    
    <!-- 缓存清理后通知 WLS 重载内存缓存（服务于 HTTP 请求中的 flush/clear 调用） -->
    <event name="Weline_Framework_Cache::integration::cache_flushed">
        <observer name="Weline_Server::cache_flushed_reload"
                  instance="Weline\Server\Observer\CacheFlushedObserver"
                  disabled="false"
                  shared="true"
                  sort="10"/>
    </event>

    <!-- 日志运行模式：WLS 进程内将 runtime 设为 wls，LoggerFactory 使用 WlsLoggerAdapter -->
    <event name="Weline_Framework_Log::resolve_runtime">
        <observer name="Weline_Server::logger_resolve_runtime"
                  instance="Weline\Server\Log\Observer\LoggerResolveRuntimeObserver"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <!-- WLS 模式下接管缓存驱动：File => WlsMemoryCache -->
    <event name="Weline_Framework_Cache::driver_create_before">
        <observer name="Weline_Server::cache_driver_interceptor"
                  instance="Weline\Server\Observer\CacheDriverInterceptor"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>
    
    <!-- WLS 模式下接管 Session 驱动（已废弃）：新架构使用 SessionFactory 自动选择策略 -->
    <!-- @deprecated 使用 Weline\Framework\Session\SessionFactory 替代 -->
    <event name="Weline_Framework_Session::driver_create_before">
        <observer name="Weline_Server::session_driver_interceptor"
                  instance="Weline\Server\Observer\SessionDriverInterceptor"
                  disabled="true"
                  shared="true"
                  sort="0"/>
    </event>
    
    <!-- Master 复活失败时向后台报错，由 Admin 消息中心展示 -->
    <event name="Weline_Server::service::master_resurrection_failed">
        <observer name="Weline_Server::master_resurrection_failed_notify"
                  instance="Weline\Server\Observer\MasterResurrectionFailedObserver"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <!-- 维护模式：WLS 下由 Env 通过事件请求状态/设置，本模块通过 IPC 与 Orchestrator 通信 -->
    <event name="Weline_Server::integration::maintenance_check">
        <observer name="Weline_Server::maintenance_check_ipc"
                  instance="Weline\Server\Observer\MaintenanceCheckObserver"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>
    <event name="Weline_Server::integration::maintenance_set">
        <observer name="Weline_Server::maintenance_set_ipc"
                  instance="Weline\Server\Observer\MaintenanceSetObserver"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <!-- 攻击信号处理已改为 Cron 定时任务方式（非阻塞） -->
    <!-- @see Weline\Server\Cron\AttackSignalMonitor -->
    <!-- @see Weline\Server\Service\AttackSignalFileService -->
    
    <!-- ========== Fiber 调度器事件 ========== -->
    
    <!-- SchedulerSystem::sleep/usleep 在 WLS 模式下 dispatch，由调度器注册定时器 -->
    <event name="Weline_Framework::scheduler::wait">
        <observer name="Weline_Server::scheduler_wait"
                  instance="Weline\Server\Observer\SchedulerWaitObserver"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>
</config>
