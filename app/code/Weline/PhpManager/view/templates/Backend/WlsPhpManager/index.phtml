<script>
    (() => {
        const shell = document.querySelector('[data-wls-php-manager-shell]');
        if (!shell) return;
        const button = shell.querySelector('[data-wpm-theme-toggle]');
        const label = shell.querySelector('[data-wpm-theme-label]');
        const icon = button ? button.querySelector('.mdi') : null;
        const labels = <?= $themeLabels ?: '{"dark":"Dark","light":"Light"}' ?>;
        const saved = window.localStorage.getItem('wls_panel_theme') || 'dark';
        const apply = (theme) => {
            const next = theme === 'light' ? 'light' : 'dark';
            shell.setAttribute('data-theme', next);
            document.documentElement.style.colorScheme = next;
            if (button) button.setAttribute('aria-pressed', next === 'dark' ? 'true' : 'false');
            if (label) label.textContent = labels[next];
            if (icon) {
                icon.classList.toggle('mdi-weather-night', next === 'dark');
                icon.classList.toggle('mdi-white-balance-sunny', next === 'light');
            }
            window.localStorage.setItem('wls_panel_theme', next);
        };
        apply(saved);
        if (button) {
            button.addEventListener('click', () => {
                apply(shell.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
            });
        }
    })();
</script>
