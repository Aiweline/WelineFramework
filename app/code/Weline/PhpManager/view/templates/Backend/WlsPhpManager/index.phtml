$extensionWarnings = is_array($extensionPlan['warnings'] ?? null) ? array_values($extensionPlan['warnings']) : [];
$auditRecords = $this->getData('wlsPhpManagerAuditRecords');
$auditRecords = is_array($auditRecords) ? array_values($auditRecords) : [];
$profileSaveUrl = (string)$this->getData('wlsPhpManagerProfileSaveUrl');
$iniApplyUrl = (string)$this->getData('wlsPhpManagerIniApplyUrl');
$iniRollbackUrl = (string)$this->getData('wlsPhpManagerIniRollbackUrl');
$notice = trim((string)$this->getData('wlsPhpManagerNotice'));
$error = trim((string)$this->getData('wlsPhpManagerError'));
$formKey = (string)$this->getFormKeyValue();
$operation = trim((string)($context['operation'] ?? 'php-profile'));
$projectId = trim((string)($context['project_id'] ?? ''));
$domain = trim((string)($context['domain'] ?? ''));
$projectType = trim((string)($context['project_type'] ?? ''));
$panelUrl = $this->getBackendUrl('server/backend/wls-panel');
$marketplaceUrl = $this->getBackendUrl('server/backend/wls-panel/marketplace');
$projectAdminUrl = $this->getBackendUrl('admin');
$extensionPlanUrl = $this->getBackendUrl('weline_phpmanager/backend/wls-php-manager');
$buildPhpManagerAnchorUrl = static function (string $anchor) use ($extensionPlanUrl, $operation, $projectId, $domain, $projectType): string {
    $query = array_filter([
        'operation' => $operation,
        'project_id' => $projectId,
        'domain' => $domain,
        'project_type' => $projectType,
    ], static fn (mixed $value): bool => $value !== null && $value !== '');

    return $extensionPlanUrl . ($query !== [] ? '?' . http_build_query($query) : '') . '#' . ltrim($anchor, '#');
};
$escapeHtml = static fn (mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
$profileValue = static fn (string $key, mixed $default = ''): string => htmlspecialchars((string)($projectProfile[$key] ?? $default), ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
$profileChecked = static fn (string $key): string => !empty($projectProfile[$key]) ? 'checked' : '';
$selected = static fn (string $value, mixed $current): string => $value === (string)$current ? 'selected' : '';
$extensionActionSelected = static fn (string $value, array $plan): string => $value === (string)($plan['action'] ?? '') ? 'selected' : '';
$extensions = is_array($runtime['extensions'] ?? null) ? array_values($runtime['extensions']) : [];
$scannedIniFiles = is_array($runtime['scanned_ini_files'] ?? null) ? array_values($runtime['scanned_ini_files']) : [];
$hasProjectProfile = !empty($projectProfile['has_profile']);
$themeLabels = json_encode(
    [
        'dark' => (string)__('Dark'),
        'light' => (string)__('Light'),
    ],
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
