{
  "host": {
    "host": "192.168.1.100",
    "port": 22,
    "user": "root",
    "password": "your_password",
    "key_path": "/path/to/id_rsa"
  },
  "mapping": {
    "local_path": "./",
    "remote_path": "/var/www/html/your_project",
    "include_paths": [
      "app/code/Weline/Async",
      "view/templates"
    ],
    "exclude_patterns": [
      "node_modules",
      ".git",
      "*.log",
      ".idea",
      "vendor",
      "var/cache",
      "var/log",
      "weline-async.json"
    ]
  }
}
