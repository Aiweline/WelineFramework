<script>
let currentHostId = <?= $host->getId() ?>;
let currentMappingId = null;

function loadMappingForm(hostId, mappingId) {
    currentHostId = hostId;
    currentMappingId = mappingId;
    
    const container = document.getElementById('mappingFormContainer');
    container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div></div>';
    
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/form') ?>' + 
                '?host_id=' + hostId + 
                (mappingId ? '&id=' + mappingId : '');
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 && data.data && data.data.html) {
            container.innerHTML = data.data.html;
            // 更新标题
            document.getElementById('mappingOffcanvasLabel').textContent = 
                mappingId ? '<?= __('编辑映射') ?>' : '<?= __('新增映射') ?>';
            
            // 初始化目录树
            setTimeout(() => {
                initializeDirectoryTrees();
                // 如果有已保存的配置，恢复选中的目录
                restoreSelectedDirectories();
            }, 100);
        } else {
            container.innerHTML = '<div class="alert alert-danger">' + (data.msg || '<?= __('加载失败') ?>') + '</div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = '<div class="alert alert-danger"><?= __('加载失败，请稍后重试') ?></div>';
    });
}

// 目录树相关变量
let localDirectoryTree = null;
let selectedIncludePaths = new Set();
let selectedExcludePaths = new Set();
let directoryBasePath = null; // 存储基础路径，用于懒加载

// 初始化目录树
function initializeDirectoryTrees() {
    const localPath = document.getElementById('local_path');
    if (localPath && localPath.value) {
        loadDirectoryTree('local', localPath.value);
    }
    
    // 监听本地路径变化
    if (localPath) {
        localPath.addEventListener('change', function() {
            if (this.value) {
                loadDirectoryTree('local', this.value);
            }
        });
    }
}

// 浏览本地目录
function browseLocalDirectory() {
    const currentPath = document.getElementById('local_path').value || '<?= htmlspecialchars(BP) ?>';
    const newPath = prompt('<?= __('请输入本地目录路径：') ?>', currentPath);
    if (newPath) {
        document.getElementById('local_path').value = newPath;
        loadDirectoryTree('local', newPath);
    }
}

// 浏览远程目录
function browseRemoteDirectory() {
    const currentPath = document.getElementById('remote_path').value || '';
    const newPath = prompt('<?= __('请输入远程目录路径：') ?>', currentPath);
    if (newPath) {
        document.getElementById('remote_path').value = newPath;
        // 远程目录树需要SSH连接，暂时只显示提示
        alert('<?= __('远程目录浏览功能需要SSH连接，请手动输入路径') ?>');
    }
}

// 加载目录树
function loadDirectoryTree(type, path) {
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/getDirectoryTree') ?>' + 
                '?path=' + encodeURIComponent(path) + '&type=' + type;
    
    const containerId = type === 'local' ? 'local_tree_content' : 'remote_tree_content';
    const container = document.getElementById(containerId);
    const treeContainer = document.getElementById(type + '_directory_tree');
    
    if (container) {
        container.innerHTML = '<div class="text-center py-2"><small class="text-muted"><?= __('加载中...') ?></small></div>';
    }
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 && data.data && data.data.tree) {
            if (type === 'local') {
                localDirectoryTree = data.data.tree;
                directoryBasePath = data.data.root; // 保存基础路径
                renderDirectoryTree(container, data.data.tree, type, 0, data.data.root);
                if (treeContainer) {
                    treeContainer.style.display = 'block';
                }
                // 更新包含和排除的目录树
                updateIncludeExcludeTrees();
            } else {
                directoryBasePath = data.data.root;
                renderDirectoryTree(container, data.data.tree, type, 0, data.data.root);
                if (treeContainer) {
                    treeContainer.style.display = 'block';
                }
            }
        } else {
            if (container) {
                container.innerHTML = '<div class="alert alert-warning"><small>' + (data.msg || '<?= __('加载失败') ?>') + '</small></div>';
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (container) {
            container.innerHTML = '<div class="alert alert-danger"><small><?= __('加载失败，请稍后重试') ?></small></div>';
        }
    });
}

// 渲染目录树
function renderDirectoryTree(container, tree, type, level = 0, basePath = null) {
    if (!tree || tree.length === 0) {
        if (container) {
            container.innerHTML = '<small class="text-muted"><?= __('暂无目录') ?></small>';
        }
        return '';
    }
    
    if (!basePath && directoryBasePath) {
        basePath = directoryBasePath;
    }
    
    let html = '<ul class="list-unstyled mb-0" style="padding-left: ' + (level * 20) + 'px;">';
    
    tree.forEach(node => {
        const relativePath = node.relative_path || node.name;
        const checkboxId = type + '_' + relativePath.replace(/[^a-zA-Z0-9]/g, '_');
        // 检查是否有子目录：优先使用 has_children 字段，如果没有则检查 children 数组
        const hasChildren = node.has_children === true || node.has_children === 1 || node.has_children === '1' || (node.children && Array.isArray(node.children) && node.children.length > 0);
        const childrenLoaded = node.children && Array.isArray(node.children) && node.children.length > 0;
        // 所有层如果有子目录但未加载，都需要懒加载
        const needsLazyLoad = hasChildren && !childrenLoaded;
        
        
        html += '<li class="mb-1">';
        html += '<div class="form-check d-flex align-items-center">';
        html += '<input class="form-check-input" type="checkbox" id="' + checkboxId + '" ';
        html += 'value="' + escapeHtml(relativePath) + '" ';
        html += 'onchange="handleDirectoryCheckbox(\'' + type + '\', \'' + escapeHtml(relativePath) + '\', this.checked)">';
        html += '<label class="form-check-label flex-grow-1" for="' + checkboxId + '">';
        html += '<i class="mdi mdi-folder"></i> ' + escapeHtml(node.name);
        html += '</label>';
        
        // 如果有子目录但未加载，显示展开按钮（所有层都支持）
        if (needsLazyLoad) {
            html += '<button type="button" class="btn btn-sm btn-link p-0 ms-2 expand-btn" ';
            html += 'onclick="loadDirectoryChildren(\'' + escapeHtml(node.path) + '\', \'' + checkboxId + '\', \'' + type + '\', ' + level + ', \'' + escapeHtml(basePath || '') + '\')" ';
            html += 'title="<?= __('展开') ?>" ';
            html += 'data-path="' + escapeHtml(node.path) + '" ';
            html += 'data-parent-id="' + checkboxId + '">';
            html += '<i class="mdi mdi-chevron-right"></i>';
            html += '</button>';
        } else if (hasChildren && childrenLoaded) {
            // 如果已加载子目录，显示折叠/展开按钮
            html += '<button type="button" class="btn btn-sm btn-link p-0 ms-2 toggle-btn" ';
            html += 'onclick="toggleDirectoryChildren(\'' + checkboxId + '\')" ';
            html += 'title="<?= __('折叠/展开') ?>" ';
            html += 'data-parent-id="' + checkboxId + '">';
            html += '<i class="mdi mdi-chevron-down"></i>';
            html += '</button>';
        }
        
        html += '</div>';
        
        // 如果已有子目录，渲染它们（默认不展开，需要点击展开按钮）
        if (childrenLoaded) {
            html += '<div id="children_' + checkboxId + '" class="directory-children" style="display: none;">';
            html += renderDirectoryTree(null, node.children, type, level + 1, basePath);
            html += '</div>';
        } else if (needsLazyLoad) {
            // 需要懒加载的占位符
            html += '<div id="children_' + checkboxId + '" class="directory-children" style="display: none;"></div>';
        }
        
        html += '</li>';
    });
    
    html += '</ul>';
    
    if (container && level === 0) {
        container.innerHTML = html;
    }
    
    return html;
}

// 转义 HTML
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// 加载目录子节点（懒加载）
function loadDirectoryChildren(path, parentId, type, level, basePath) {
    const childrenContainer = document.getElementById('children_' + parentId);
    if (!childrenContainer) return;
    
    // 显示加载状态
    childrenContainer.innerHTML = '<div class="text-center py-1"><small class="text-muted"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></small></div>';
    childrenContainer.style.display = 'block';
    
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/getDirectoryChildren') ?>' + 
                '?path=' + encodeURIComponent(path) + 
                '&base_path=' + encodeURIComponent(basePath || path);
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 && data.data && data.data.children) {
            // 渲染子目录（默认不展开）
            const html = renderDirectoryTree(null, data.data.children, type, level + 1, basePath);
            childrenContainer.innerHTML = html;
            childrenContainer.style.display = 'block'; // 显示加载的子目录
            
            // 更新按钮为折叠/展开按钮
            const parentLi = childrenContainer.closest('li');
            if (parentLi) {
                const button = parentLi.querySelector('.form-check button');
                if (button) {
                    button.onclick = function() { toggleDirectoryChildren(parentId); };
                    button.innerHTML = '<i class="mdi mdi-chevron-down"></i>';
                    button.title = '<?= __('折叠/展开') ?>';
                }
            }
        } else {
            childrenContainer.innerHTML = '<div class="alert alert-warning py-1"><small>' + (data.msg || '<?= __('加载失败') ?>') + '</small></div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        childrenContainer.innerHTML = '<div class="alert alert-danger py-1"><small><?= __('加载失败，请稍后重试') ?></small></div>';
    });
}

// 切换目录子节点的显示/隐藏
function toggleDirectoryChildren(parentId) {
    const childrenContainer = document.getElementById('children_' + parentId);
    if (!childrenContainer) return;
    
    const parentLi = childrenContainer.closest('li');
    if (!parentLi) return;
    
    const button = parentLi.querySelector('.form-check button');
    if (!button) return;
    
    if (childrenContainer.style.display === 'none') {
        childrenContainer.style.display = 'block';
        button.innerHTML = '<i class="mdi mdi-chevron-down"></i>';
    } else {
        childrenContainer.style.display = 'none';
        button.innerHTML = '<i class="mdi mdi-chevron-right"></i>';
    }
}

// 更新包含和排除的目录树
function updateIncludeExcludeTrees() {
    if (!localDirectoryTree) return;
    
    const includeContainer = document.getElementById('include_tree_content');
    const excludeContainer = document.getElementById('exclude_tree_content');
    
    if (includeContainer && directoryBasePath) {
        renderDirectoryTree(includeContainer, localDirectoryTree, 'include', 0, directoryBasePath);
    }
    
    if (excludeContainer && directoryBasePath) {
        renderDirectoryTree(excludeContainer, localDirectoryTree, 'exclude', 0, directoryBasePath);
    }
}

// 处理目录复选框
function handleDirectoryCheckbox(type, path, checked) {
    if (type === 'include') {
        if (checked) {
            selectedIncludePaths.add(path);
        } else {
            selectedIncludePaths.delete(path);
        }
        updateIncludePathsTextarea();
    } else if (type === 'exclude') {
        if (checked) {
            selectedExcludePaths.add(path);
        } else {
            selectedExcludePaths.delete(path);
        }
        updateExcludePatternsTextarea();
    }
}

// 更新包含路径文本域
function updateIncludePathsTextarea() {
    const textarea = document.getElementById('include_paths');
    if (textarea) {
        textarea.value = Array.from(selectedIncludePaths).join('\n');
    }
}

// 更新排除模式文本域
function updateExcludePatternsTextarea() {
    const textarea = document.getElementById('exclude_patterns');
    if (textarea) {
        const currentPatterns = textarea.value.split('\n').filter(p => p.trim());
        const excludePaths = Array.from(selectedExcludePaths);
        const allPatterns = [...new Set([...excludePaths, ...currentPatterns])].filter(p => p.trim());
        textarea.value = allPatterns.join('\n');
    }
}

// 全选/取消本地目录
function toggleAllLocalDirectories() {
    const checkboxes = document.querySelectorAll('#local_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        handleDirectoryCheckbox('local', path, !allChecked);
    });
}

// 全选/取消包含目录
function toggleAllIncludeDirectories() {
    const checkboxes = document.querySelectorAll('#include_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        handleDirectoryCheckbox('include', path, !allChecked);
    });
}

// 全选/取消排除目录
function toggleAllExcludeDirectories() {
    const checkboxes = document.querySelectorAll('#exclude_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        handleDirectoryCheckbox('exclude', path, !allChecked);
    });
}

// 恢复已选中的目录
function restoreSelectedDirectories() {
    // 恢复包含路径
    const includeTextarea = document.getElementById('include_paths');
    if (includeTextarea && includeTextarea.value) {
        const paths = includeTextarea.value.split('\n').filter(p => p.trim());
        paths.forEach(path => {
            selectedIncludePaths.add(path.trim());
            const checkbox = document.querySelector('#include_tree_content input[value="' + path.trim() + '"]');
            if (checkbox) {
                checkbox.checked = true;
            }
        });
    }
    
    // 恢复排除路径
    const excludeTextarea = document.getElementById('exclude_patterns');
    if (excludeTextarea && excludeTextarea.value) {
        const patterns = excludeTextarea.value.split('\n').filter(p => p.trim());
        patterns.forEach(pattern => {
            // 检查是否是目录路径（不包含通配符）
            if (!pattern.includes('*') && !pattern.includes('?')) {
                selectedExcludePaths.add(pattern.trim());
                const checkbox = document.querySelector('#exclude_tree_content input[value="' + pattern.trim() + '"]');
                if (checkbox) {
                    checkbox.checked = true;
                }
            }
        });
    }
}

function saveMappingForm(event) {
    event.preventDefault();
    
    const form = event.target;
    const formData = new FormData(form);
    
    // 收集选中的包含路径
    const includePaths = Array.from(selectedIncludePaths);
    if (includePaths.length > 0) {
        formData.set('include_paths', includePaths.join('\n'));
    }
    
    // 收集选中的排除路径并合并到排除模式
    const excludePaths = Array.from(selectedExcludePaths);
    const excludeTextarea = document.getElementById('exclude_patterns');
    if (excludeTextarea) {
        const textPatterns = excludeTextarea.value.split('\n').filter(p => p.trim());
        const allExcludes = [...new Set([...excludePaths, ...textPatterns])].filter(p => p.trim());
        formData.set('exclude_patterns', allExcludes.join('\n'));
    }
    
    // 添加 host_id 和 id（如果存在）
    formData.append('host_id', currentHostId);
    if (currentMappingId) {
        formData.append('id', currentMappingId);
    }
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> <?= __('保存中...') ?>';
    
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/save') ?>';
    
    fetch(url, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 || data.success) {
            // 显示成功消息
            alert(data.msg || '<?= __('保存成功') ?>');
            // 关闭 offcanvas
            const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('mappingOffcanvas'));
            if (offcanvas) {
                offcanvas.hide();
            }
            // 刷新页面
            location.reload();
        } else {
            alert(data.msg || '<?= __('保存失败') ?>');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败，请稍后重试') ?>');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    });
}

// 处理删除操作
function deleteMapping(mappingId, hostId) {
    if (!confirm('<?= __('确定要删除该映射吗？') ?>')) {
        return;
    }
    
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/delete') ?>' + 
                '?id=' + mappingId + '&host_id=' + hostId;
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 || data.success) {
            alert(data.msg || '<?= __('删除成功') ?>');
            location.reload();
        } else {
            alert(data.msg || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('删除失败，请稍后重试') ?>');
    });
}

// 处理切换状态
function toggleMapping(mappingId, hostId) {
    const url = '<?= $this->getBackendUrl('async/backend/api/mapping/toggle') ?>' + 
                '?id=' + mappingId + '&host_id=' + hostId;
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 || data.success) {
            location.reload();
        } else {
            alert(data.msg || '<?= __('操作失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('操作失败，请稍后重试') ?>');
    });
}
