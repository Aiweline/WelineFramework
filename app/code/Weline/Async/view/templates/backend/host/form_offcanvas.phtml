<?php
/** @var \Weline\Framework\View\Template $this */

use Weline\Async\Model\SyncHost;
use Weline\Framework\App\Env;

$host = $this->getData('host');
$isEdit = $host && $host->getId();
?>

<form method="post" onsubmit="saveHostForm(event)" id="hostForm">
    <?php if ($isEdit): ?>
        <input type="hidden" name="id" value="<?= $host->getId() ?>">
    <?php endif; ?>
    
    <div class="mb-3">
        <label class="form-label"><?= __('主机名称') ?> <span class="text-danger">*</span></label>
        <input type="text" name="name" class="form-control" 
               value="<?= htmlspecialchars($host && $host->getId() ? ($host->getData(SyncHost::fields_NAME) ?: '') : '') ?>" 
               required>
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('主机地址') ?> <span class="text-danger">*</span></label>
        <input type="text" name="host" class="form-control" 
               value="<?= htmlspecialchars($host && $host->getId() ? ($host->getData(SyncHost::fields_HOST) ?: '') : '') ?>" 
               placeholder="192.168.1.100 或 example.com" required>
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('SSH端口') ?></label>
        <input type="number" name="port" class="form-control" 
               value="<?= htmlspecialchars($host && $host->getId() ? ($host->getData(SyncHost::fields_PORT) ?: 22) : 22) ?>" 
               min="1" max="65535">
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('SSH用户名') ?> <span class="text-danger">*</span></label>
        <input type="text" name="user" class="form-control" 
               value="<?= htmlspecialchars($host && $host->getId() ? ($host->getData(SyncHost::fields_USER) ?: '') : '') ?>" 
               required>
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('SSH密码') ?></label>
        <input type="password" name="password" class="form-control" 
               placeholder="<?= $isEdit ? __('留空则不修改密码') : __('请输入SSH密码') ?>">
        <small class="form-text text-muted"><?= __('如果使用密钥认证，可留空') ?></small>
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('SSH密钥') ?></label>
        <ul class="nav nav-tabs mb-2" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" type="button" data-bs-toggle="tab" data-bs-target="#key_file_tab">
                    <i class="mdi mdi-file"></i> <?= __('选择文件') ?>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" type="button" data-bs-toggle="tab" data-bs-target="#key_text_tab">
                    <i class="mdi mdi-text"></i> <?= __('文本输入') ?>
                </button>
            </li>
        </ul>
        <div class="tab-content">
            <div class="tab-pane fade show active" id="key_file_tab">
                <div class="input-group">
                    <input type="text" name="key_path" id="host_key_path" class="form-control" 
                           placeholder="/path/to/id_rsa">
                    <button type="button" class="btn btn-outline-secondary" onclick="selectHostKeyFile()">
                        <i class="mdi mdi-folder-open"></i> <?= __('选择文件') ?>
                    </button>
                </div>
                <input type="file" id="host_key_file_input" style="display: none;" accept="*" onchange="handleHostKeyFileSelect(event)">
                <small class="form-text text-muted"><?= __('选择SSH私钥文件，系统将自动提取密钥内容保存') ?></small>
            </div>
            <div class="tab-pane fade" id="key_text_tab">
                <textarea name="key_content" id="host_key_content" class="form-control" rows="8" 
                          placeholder="-----BEGIN RSA PRIVATE KEY-----&#10;...&#10;-----END RSA PRIVATE KEY-----"><?php
                    if ($host && $host->getData(SyncHost::fields_KEY_CONTENT)) {
                        echo htmlspecialchars($host->getDecryptedKeyContent());
                    }
                ?></textarea>
                <small class="form-text text-muted"><?= __('直接粘贴SSH私钥内容（支持RSA、ED25519等格式）') ?></small>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label"><?= __('描述') ?></label>
        <textarea name="description" class="form-control" rows="3"><?= htmlspecialchars($host && $host->getId() ? ($host->getData(SyncHost::fields_DESCRIPTION) ?: '') : '') ?></textarea>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas"><?= __('取消') ?></button>
        <button type="submit" class="btn btn-primary"><?= __('保存') ?></button>
    </div>
</form>

<script>
// 函数已在主页面（index.phtml）中定义，这里不需要重复定义
// 如果函数未定义，说明主页面未加载，这里作为备用
if (typeof window.selectHostKeyFile === 'undefined') {
    window.selectHostKeyFile = function() {
        const fileInput = document.getElementById('host_key_file_input');
        if (fileInput) {
            fileInput.click();
        } else {
            console.error('host_key_file_input element not found');
        }
    };
}

if (typeof window.handleHostKeyFileSelect === 'undefined') {
    window.handleHostKeyFileSelect = function(event) {
        const fileInput = event.target;
        const keyContentTextarea = document.getElementById('host_key_content');
        
        if (fileInput.files && fileInput.files.length > 0) {
            const file = fileInput.files[0];
            
            // 读取文件内容
            const reader = new FileReader();
            reader.onload = function(e) {
                const content = e.target.result;
                // 将内容填充到文本输入区域
                if (keyContentTextarea) {
                    keyContentTextarea.value = content;
                    // 自动切换到文本输入标签页，让用户看到内容
                    const textTab = document.querySelector('[data-bs-target="#key_text_tab"]');
                    if (textTab) {
                        textTab.click();
                    }
                }
            };
            reader.onerror = function() {
                alert('<?= __('读取文件失败，请尝试直接粘贴密钥内容') ?>');
            };
            reader.readAsText(file);
        }
        
        // 清空文件选择，允许重复选择同一文件
        if (fileInput) {
            fileInput.value = '';
        }
    };
}
</script>
