<script>
function selectKeyFile() {
    // 触发文件选择对话框
    document.getElementById('key_file_input').click();
}

function handleKeyFileSelect(event) {
    const fileInput = event.target;
    const filePathInput = document.getElementById('key_path');
    
    if (fileInput.files && fileInput.files.length > 0) {
        const file = fileInput.files[0];
        const fileName = file.name;
        
        // 尝试获取完整路径
        let fullPath = '';
        
        // 方法1: 检查是否有 path 属性（某些环境支持）
        if (file.path) {
            fullPath = file.path;
        }
        // 方法2: 检查是否有 webkitRelativePath
        else if (file.webkitRelativePath) {
            fullPath = file.webkitRelativePath;
        }
        // 方法3: 尝试使用 FileReader（仅用于验证文件，无法获取路径）
        else {
            // 由于浏览器安全限制，无法直接获取完整路径
            // 显示提示对话框，帮助用户输入路径
            const currentValue = filePathInput.value || '';
            const defaultPath = getDefaultKeyPath(fileName);
            
            const message = '<?= __('由于浏览器安全限制，无法自动获取文件的完整路径。\n\n请手动输入SSH密钥的完整路径：\n\nWindows示例: C:\\Users\\YourName\\.ssh\\id_rsa\nLinux/Mac示例: /home/username/.ssh/id_rsa\n\n当前选择的文件名: ') ?>' + fileName;
            
            const userPath = prompt(message, defaultPath || currentValue);
            if (userPath !== null) {
                fullPath = userPath.trim();
            }
        }
        
        if (fullPath) {
            filePathInput.value = fullPath;
            // 显示成功提示
            showKeyPathHint('<?= __('路径已设置') ?>: ' + fullPath, 'success');
        }
    }
    
    // 清空文件输入，以便可以重复选择
    fileInput.value = '';
}

function getDefaultKeyPath(fileName) {
    // 根据操作系统和文件名提供默认路径建议
    const isWindows = navigator.platform.indexOf('Win') > -1;
    
    if (isWindows) {
        // Windows 默认路径
        return 'C:\\Users\\YourName\\.ssh\\' + fileName;
    } else {
        // Linux/Mac 默认路径
        return '/home/username/.ssh/' + fileName;
    }
}

function showKeyPathHint(message, type) {
    // 创建临时提示元素
    const hint = document.createElement('div');
    hint.className = 'alert alert-' + (type === 'success' ? 'success' : 'info') + ' alert-dismissible fade show';
    hint.style.position = 'fixed';
    hint.style.top = '20px';
    hint.style.right = '20px';
    hint.style.zIndex = '9999';
    hint.style.minWidth = '300px';
    hint.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    
    document.body.appendChild(hint);
    
    // 3秒后自动移除
    setTimeout(function() {
        if (hint.parentNode) {
            hint.parentNode.removeChild(hint);
        }
    }, 3000);
}
</script>
