<js:part>
<script>
(function() {
    'use strict';
    
    window.AsyncHostForm = {
        selectKeyFile: function() {
            document.getElementById('key_file_input').click();
        },
        
        handleKeyFileSelect: function(event) {
            var fileInput = event.target;
            var filePathInput = document.getElementById('key_path');
            
            if (fileInput.files && fileInput.files.length > 0) {
                var file = fileInput.files[0];
                var fileName = file.name;
                
                var fullPath = '';
                
                if (file.path) {
                    fullPath = file.path;
                } else if (file.webkitRelativePath) {
                    fullPath = file.webkitRelativePath;
                } else {
                    var currentValue = filePathInput.value || '';
                    var defaultPath = this.getDefaultKeyPath(fileName);
                    
                    var message = '<?= __('由于浏览器安全限制，无法自动获取文件的完整路径。请手动输入SSH密钥的完整路径：') ?>\n\n' +
                                  'Windows示例: C:\\Users\\YourName\\.ssh\\id_rsa\n' +
                                  'Linux/Mac示例: /home/username/.ssh/id_rsa\n\n' +
                                  '<?= __('当前选择的文件名') ?>: ' + fileName;
                    
                    var userPath = prompt(message, defaultPath || currentValue);
                    if (userPath !== null) {
                        fullPath = userPath.trim();
                    }
                }
                
                if (fullPath) {
                    filePathInput.value = fullPath;
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.success('<?= __('路径已设置') ?>: ' + fullPath);
                    }
                }
            }
            
            fileInput.value = '';
        },
        
        getDefaultKeyPath: function(fileName) {
            var isWindows = navigator.platform.indexOf('Win') > -1;
            
            if (isWindows) {
                return 'C:\\Users\\YourName\\.ssh\\' + fileName;
            } else {
                return '/home/username/.ssh/' + fileName;
            }
        }
    };
})();
</script>
</js:part>
