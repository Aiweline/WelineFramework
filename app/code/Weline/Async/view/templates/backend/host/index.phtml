// 加载浏览器目录树
window.loadBrowserDirectoryTree = function() {
    const pathInput = document.getElementById('browser_path_input');
    if (!pathInput) return;
    
    const path = pathInput.value.trim();
    if (!path) {
        alert('<?= __('请输入目录路径') ?>');
        return;
    }
    
    const container = document.getElementById('browser_tree_content');
    if (!container) return;
    
    container.innerHTML = '<div class="text-center py-2"><div class="spinner-border spinner-border-sm"></div> <small class="text-muted"><?= __('加载中...') ?></small></div>';
    
    // 使用现有的 getDirectoryTree API
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/getDirectoryTree') ?>';
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'path=' + encodeURIComponent(path) + '&type=local';
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 && data.data && data.data.tree) {
            // 创建可点击的目录树（点击目录名选择该目录）
            let html = '<ul class="list-unstyled mb-0">';
            const renderTree = (tree, level = 0) => {
                tree.forEach(node => {
                    const fullPath = node.full_path || (path + (path.endsWith('/') || path.endsWith('\\') ? '' : (path.includes('\\') ? '\\' : '/')) + node.relative_path);
                    html += '<li class="mb-1" style="padding-left: ' + (level * 20) + 'px;">';
                    html += '<div class="d-flex align-items-center">';
                    html += '<i class="mdi mdi-folder text-warning me-2"></i>';
                    html += '<a href="javascript:void(0)" class="text-decoration-none directory-link" ';
                    html += 'data-path="' + window.escapeHtml(fullPath) + '">';
                    html += window.escapeHtml(node.name);
                    html += '</a>';
                    html += '</div>';
                    if (node.children && node.children.length > 0) {
                        renderTree(node.children, level + 1);
                    }
                    html += '</li>';
                });
            };
            renderTree(data.data.tree);
            html += '</ul>';
            container.innerHTML = html;
            
            // 绑定点击事件
            container.querySelectorAll('.directory-link').forEach(link => {
                link.addEventListener('click', function() {
                    const selectedPath = this.getAttribute('data-path');
                    const pathInput = document.getElementById('browser_path_input');
                    if (pathInput) {
                        pathInput.value = selectedPath;
                        // 高亮选中的项
                        container.querySelectorAll('.directory-link').forEach(l => {
                            l.classList.remove('fw-bold', 'text-primary');
                        });
                        this.classList.add('fw-bold', 'text-primary');
                    }
                });
            });
        } else {
            container.innerHTML = '<div class="alert alert-warning"><small>' + (data.msg || '<?= __('加载失败') ?>') + '</small></div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = '<div class="alert alert-danger"><small><?= __('加载失败，请稍后重试') ?></small></div>';
    });
}

