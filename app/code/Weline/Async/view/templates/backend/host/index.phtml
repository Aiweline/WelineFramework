    container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div></div>';
    
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/form') ?>';
    // 添加 isAjax 参数确保后端识别为 AJAX 请求
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'host_id=' + hostId + 
                (mappingId ? '&id=' + mappingId : '') + '&isAjax=1';
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
    .then(response => {
        // 检查响应类型
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json();
        } else {
            // 如果不是 JSON，尝试解析为文本并显示错误
            return response.text().then(text => {
                console.error('Expected JSON but got:', text.substring(0, 200));
                throw new Error('服务器返回的不是 JSON 格式');
            });
        }
    })
    .then(data => {
        if (data.code === 200 && data.data && data.data.html) {
            container.innerHTML = data.data.html;
            document.getElementById('mappingOffcanvasLabel').textContent = 
                mappingId ? '<?= __('编辑映射') ?>' : '<?= __('新增映射') ?>';
            setTimeout(() => {
                window.initializeDirectoryTrees();
                window.restoreSelectedDirectories();
                window.restoreSelectedRemotePaths();
                
                // 先加载本地目录树（只加载第一级）
                const localPathInput = document.getElementById('local_path');
                if (localPathInput && localPathInput.value) {
                    window.loadDirectoryTree('local', localPathInput.value);
                }
                
                // 然后加载远程目录树（只加载第一级）
                setTimeout(() => {
                    const remoteBasePathInput = document.getElementById('remote_base_path');
                    const hostId = window.currentHostId || document.querySelector('input[name="host_id"]')?.value;
                    if (remoteBasePathInput && hostId) {
                        let remotePath = remoteBasePathInput.value.trim();
                        if (!remotePath) {
                            remotePath = '/www/wwwroot/';
                            remoteBasePathInput.value = remotePath;
                        }
                        // 确保路径以 / 结尾
                        if (!remotePath.endsWith('/')) {
                            remotePath += '/';
                        }
                        window.loadRemoteDirectoryTree(remotePath, hostId);
                    }
                }, 200); // 延迟200ms，确保本地目录先加载
            }, 100);
        } else {
            container.innerHTML = '<div class="alert alert-danger">' + (data.msg || '<?= __('加载失败') ?>') + '</div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = '<div class="alert alert-danger"><?= __('加载失败，请稍后重试') ?></div>';
    });
}

// 保存映射表单
window.saveMappingForm = function(event) {
    event.preventDefault();
    
    const form = event.target;
    const formData = new FormData(form);
    
    // 收集选中的包含路径
    const includePaths = Array.from(window.selectedIncludePaths);
    if (includePaths.length > 0) {
        formData.set('include_paths', includePaths.join('\n'));
    }
    
    // 收集选中的排除路径并合并到排除模式
    const excludePaths = Array.from(window.selectedExcludePaths);
    const excludeTextarea = document.getElementById('exclude_patterns');
    if (excludeTextarea) {
        const textPatterns = excludeTextarea.value.split('\n').filter(p => p.trim());
        const allExcludes = [...new Set([...excludePaths, ...textPatterns])].filter(p => p.trim());
        formData.set('exclude_patterns', allExcludes.join('\n'));
    }
    
    formData.append('host_id', window.currentHostId);
    if (window.currentMappingId) {
        formData.append('id', window.currentMappingId);
    }
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> <?= __('保存中...') ?>';
    
    const url = '<?= $this->getBackendUrl('async/backend/mapping/save') ?>';
    
    fetch(url, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 || data.success) {
            alert(data.msg || '<?= __('保存成功') ?>');
            const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('mappingOffcanvas'));
            if (offcanvas) {
                offcanvas.hide();
            }
            // 刷新映射列表
            if (window.currentHostId) {
                window.loadMappingList(window.currentHostId);
            }
        } else {
            alert(data.msg || '<?= __('保存失败') ?>');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败，请稍后重试') ?>');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    });
}

