<script>
// 确保在全局作用域中定义
window.currentHostId = null;
window.currentMappingId = null;

// SSH密钥文件选择函数（必须在全局作用域中，因为offcanvas是动态加载的）
window.selectHostKeyFile = function() {
    const fileInput = document.getElementById('host_key_file_input');
    if (fileInput) {
        fileInput.click();
    } else {
        console.error('host_key_file_input element not found');
    }
};

window.handleHostKeyFileSelect = function(event) {
    const fileInput = event.target;
    const keyContentTextarea = document.getElementById('host_key_content');
    
    if (fileInput.files && fileInput.files.length > 0) {
        const file = fileInput.files[0];
        
        // 读取文件内容
        const reader = new FileReader();
        reader.onload = function(e) {
            const content = e.target.result;
            // 将内容填充到文本输入区域
            if (keyContentTextarea) {
                keyContentTextarea.value = content;
                // 自动切换到文本输入标签页，让用户看到内容
                const textTab = document.querySelector('[data-bs-target="#key_text_tab"]');
                if (textTab) {
                    textTab.click();
                }
            }
        };
        reader.onerror = function() {
            alert('<?= __('读取文件失败，请尝试直接粘贴密钥内容') ?>');
        };
        reader.readAsText(file);
    }
    
    // 清空文件选择，允许重复选择同一文件
    if (fileInput) {
        fileInput.value = '';
    }
};

// 主机相关函数
// 加载主机表单
window.loadHostForm = function(hostId) {
    const container = document.getElementById('hostFormContainer');
    if (!container) {
        console.error('hostFormContainer not found');
        return;
    }
    
    container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div></div>';
    
    const baseUrl = '<?= $this->getBackendUrl('async/backend/host/form') ?>';
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'isAjax=1' + 
                (hostId ? '&id=' + hostId : '');
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
    .then(response => {
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json();
        } else {
            return response.text().then(text => {
                console.error('Expected JSON but got:', text.substring(0, 200));
                throw new Error('服务器返回的不是 JSON 格式');
            });
        }
    })
    .then(data => {
        if (data.code === 200 && data.data && data.data.html) {
            container.innerHTML = data.data.html;
            document.getElementById('hostOffcanvasLabel').textContent = 
                hostId ? '<?= __('编辑主机') ?>' : '<?= __('新增主机') ?>';
        } else {
            container.innerHTML = '<div class="alert alert-danger">' + (data.msg || '<?= __('加载失败') ?>') + '</div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = '<div class="alert alert-danger"><?= __('加载失败，请稍后重试') ?></div>';
    });
};

// 保存主机表单
window.saveHostForm = function(event) {
    event.preventDefault();
    
    const form = document.getElementById('hostForm');
    if (!form) {
        alert('<?= __('表单不存在') ?>');
        return;
    }
    
    const formData = new FormData(form);
    formData.append('isAjax', '1');
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __('保存中...') ?>';
    
    const baseUrl = '<?= $this->getBackendUrl('async/backend/host/save') ?>';
    
    fetch(baseUrl, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        },
        body: formData
    })
    .then(response => {
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json();
        } else {
            return response.text().then(text => {
                console.error('Expected JSON but got:', text.substring(0, 200));
                throw new Error('服务器返回的不是 JSON 格式');
            });
        }
    })
    .then(data => {
        if (data.code === 200 || data.success) {
            alert(data.msg || '<?= __('保存成功') ?>');
            // 关闭 offcanvas
            const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('hostOffcanvas'));
            if (offcanvas) {
                offcanvas.hide();
            }
            // 刷新页面
            location.reload();
        } else {
            alert(data.msg || '<?= __('保存失败') ?>');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败，请稍后重试') ?>');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    });
};

// 删除主机
window.deleteHost = function(hostId) {
    if (!confirm('<?= __('确定要删除该主机吗？') ?>')) {
        return;
    }
    
    const baseUrl = '<?= $this->getBackendUrl('async/backend/host/delete') ?>';
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'id=' + hostId + '&isAjax=1';
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
    .then(response => {
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json();
        } else {
            return response.text().then(text => {
                console.error('Expected JSON but got:', text.substring(0, 200));
                throw new Error('服务器返回的不是 JSON 格式');
            });
        }
    })
    .then(data => {
        if (data.code === 200 || data.success) {
            alert(data.msg || '<?= __('删除成功') ?>');
            location.reload();
        } else {
            alert(data.msg || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('删除失败，请稍后重试') ?>');
    });
};

// 加载映射列表
window.loadMappingList = function(hostId) {
    window.currentHostId = hostId;
    
    const container = document.getElementById('mappingListContainer');
    if (!container) {
        console.error('mappingListContainer not found');
        return;
    }
    
    container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div></div>';
    
    // 使用已注册的后端控制器路由
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/getList') ?>';
    
    // 使用 URL 对象或手动构建查询字符串，确保参数正确编码
    const separator = baseUrl.includes('?') ? '&' : '?';
    const url = baseUrl + separator + 'host_id=' + encodeURIComponent(hostId);
    
    console.log('Loading mapping list, hostId:', hostId);
    console.log('Base URL:', baseUrl);
    console.log('Full URL:', url);
    
    if (!baseUrl || baseUrl.trim() === '') {
        console.error('Base URL is empty!');
        container.innerHTML = '<div class="alert alert-danger"><?= __('URL生成失败，请检查路由配置') ?></div>';
        return;
    }
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        console.log('Response status:', response.status);
        if (!response.ok) {
            throw new Error('HTTP error! status: ' + response.status);
        }
        return response.json();
    })
    .then(data => {
        console.log('Response data:', data);
        if (data.code === 200 && data.data) {
            renderMappingList(container, data.data, hostId);
        } else {
            container.innerHTML = '<div class="alert alert-danger">' + (data.msg || '<?= __('加载失败') ?>') + '</div>';
        }
    })
    .catch(error => {
        console.error('Error loading mapping list:', error);
        container.innerHTML = '<div class="alert alert-danger"><?= __('加载失败，请稍后重试') ?><br><small>' + error.message + '</small></div>';
    });
}

// 渲染映射列表
window.renderMappingList = function(container, mappings, hostId) {
    let html = '<div class="d-flex justify-content-between align-items-center mb-3">';
    html += '<h6 class="mb-0"><?= __('映射列表') ?></h6>';
    html += '<button type="button" class="btn btn-primary btn-sm btn-load-mapping-form" ';
    html += 'data-bs-toggle="offcanvas" data-bs-target="#mappingOffcanvas" ';
    html += 'data-host-id="' + window.escapeHtml(String(hostId)) + '" ';
    html += 'data-mapping-id="">';
    html += '<i class="mdi mdi-plus"></i> <?= __('新增映射') ?>';
    html += '</button>';
    html += '</div>';
    
    if (!mappings || mappings.length === 0) {
        html += '<div class="alert alert-info"><?= __('当前暂无目录映射，请点击"新增映射"按钮添加。') ?></div>';
    } else {
        html += '<div class="table-responsive">';
        html += '<table class="table table-bordered table-hover align-middle">';
        html += '<thead><tr>';
        html += '<th><?= __('本地路径') ?></th>';
        html += '<th><?= __('远程路径') ?></th>';
        html += '<th><?= __('状态') ?></th>';
        html += '<th><?= __('运行状态') ?></th>';
        html += '<th><?= __('操作') ?></th>';
        html += '</tr></thead><tbody>';
        
        mappings.forEach(mapping => {
            const status = mapping.status || 0;
            const isRunning = mapping.is_running || false;
            const pid = mapping.pid;
            
            html += '<tr>';
            html += '<td>' + escapeHtml(mapping.local_path || '') + '</td>';
            html += '<td>' + escapeHtml(mapping.remote_path || '') + '</td>';
            html += '<td>';
            if (status === 1) {
                html += '<span class="badge bg-success"><?= __('开启') ?></span>';
            } else {
                html += '<span class="badge bg-secondary"><?= __('关闭') ?></span>';
            }
            html += '</td>';
            html += '<td>';
            if (isRunning) {
                html += '<span class="badge bg-success"><?= __('运行中') ?></span>';
                if (pid) {
                    html += ' <small class="text-muted">(PID: ' + pid + ')</small>';
                }
            } else {
                html += '<span class="badge bg-danger"><?= __('未运行') ?></span>';
            }
            html += '</td>';
            html += '<td>';
            html += '<button type="button" class="btn btn-sm btn-toggle-mapping ' + (status === 1 ? 'btn-warning' : 'btn-success') + '" ';
            html += 'data-mapping-id="' + window.escapeHtml(String(mapping.mapping_id)) + '" ';
            html += 'data-host-id="' + window.escapeHtml(String(hostId)) + '">';
            html += '<i class="mdi mdi-' + (status === 1 ? 'stop' : 'play') + '"></i> ';
            html += (status === 1 ? '<?= __('关闭') ?>' : '<?= __('开启') ?>');
            html += '</button> ';
            html += '<button type="button" class="btn btn-sm btn-primary btn-load-mapping-form" ';
            html += 'data-bs-toggle="offcanvas" data-bs-target="#mappingOffcanvas" ';
            html += 'data-host-id="' + window.escapeHtml(String(hostId)) + '" ';
            html += 'data-mapping-id="' + window.escapeHtml(String(mapping.mapping_id)) + '">';
            html += '<i class="mdi mdi-pencil"></i> <?= __('编辑') ?>';
            html += '</button> ';
            html += '<button type="button" class="btn btn-sm btn-danger btn-delete-mapping" ';
            html += 'data-mapping-id="' + window.escapeHtml(String(mapping.mapping_id)) + '" ';
            html += 'data-host-id="' + window.escapeHtml(String(hostId)) + '">';
            html += '<i class="mdi mdi-delete"></i> <?= __('删除') ?>';
            html += '</button>';
            html += '</td>';
            html += '</tr>';
        });
        
        html += '</tbody></table></div>';
    }
    
    container.innerHTML = html;
}

