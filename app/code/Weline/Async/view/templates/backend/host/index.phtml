// 加载远程目录树
window.loadRemoteDirectoryTree = function(remotePath, hostId) {
    const container = document.getElementById('remote_tree_content');
    const treeContainer = document.getElementById('remote_directory_tree');
    const currentPathSpan = document.getElementById('remote_current_path');
    const navUpBtn = document.getElementById('remote_nav_up_btn');
    const navDownBtn = document.getElementById('remote_nav_down_btn');
    
    if (!container) {
        console.error('找不到远程目录树容器');
        return;
    }
    
    // 保存当前路径和主机ID
    window.currentRemotePath = remotePath;
    window.currentRemoteHostId = hostId;
    
    container.innerHTML = '<div class="text-center py-2"><small class="text-muted"><?= __('加载中...') ?></small></div>';
    if (treeContainer) {
        treeContainer.style.display = 'block';
    }
    
    // 更新当前路径显示
    if (currentPathSpan) {
        currentPathSpan.textContent = remotePath;
    }
    
    // 显示向上级按钮（如果不是根目录）
    if (navUpBtn) {
        navUpBtn.style.display = remotePath !== '/' ? 'inline-block' : 'none';
    }
    
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/getDirectoryTree') ?>';
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 
                'path=' + encodeURIComponent(remotePath) + 
                '&type=remote' + 
                '&host_id=' + encodeURIComponent(hostId) +
                '&max_depth=1' + // 只加载第一级目录
                '&isAjax=1';
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
    .then(response => {
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json();
        } else {
            return response.text().then(text => {
                console.error('Expected JSON but got:', text.substring(0, 200));
                throw new Error('服务器返回的不是 JSON 格式');
            });
        }
    })
    .then(data => {
        if (data.code === 200 && data.data && data.data.tree) {
            window.remoteDirectoryTree = data.data.tree;
            window.renderDirectoryTree(container, data.data.tree, 'remote');
            if (treeContainer) {
                treeContainer.style.display = 'block';
            }
        } else {
            // 显示错误信息
            let errorMsg = data.msg || '<?= __('加载失败') ?>';
            if (data.data && data.data.error) {
                errorMsg += '<br><small style="color: #dc3545;">' + window.escapeHtml(data.data.error) + '</small>';
            }
            container.innerHTML = '<div class="alert alert-danger"><small>' + errorMsg + '</small></div>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = '<div class="alert alert-danger"><small><?= __('加载失败，请稍后重试') ?></small></div>';
    });
}

// 远程目录导航：向上级
window.navigateRemoteDirectory = function(direction) {
    if (direction === 'up') {
        const currentPath = window.currentRemotePath || '';
        if (!currentPath || currentPath === '/') {
            return;
        }
        // 获取父目录
        const parentPath = currentPath.split('/').slice(0, -1).join('/') || '/';
        window.loadRemoteDirectoryTree(parentPath, window.currentRemoteHostId);
    } else if (direction === 'down') {
        // 向下级：展开选中的目录
        const selectedPath = window.selectedRemotePathForNavigation;
        if (selectedPath) {
            window.loadRemoteDirectoryTree(selectedPath, window.currentRemoteHostId);
        }
    }
}

// 本地目录导航：向上级
window.navigateLocalDirectory = function(direction) {
    if (direction === 'up') {
        const localPathInput = document.getElementById('local_path');
        if (!localPathInput) return;
        
        const currentPath = localPathInput.value || '';
        if (!currentPath) return;
        
        // 获取父目录
        let parentPath;
        if (currentPath.includes('\\')) {
            // Windows路径
            const parts = currentPath.split('\\').filter(p => p);
            if (parts.length <= 1) {
                parentPath = parts[0] + '\\';
            } else {
                parentPath = parts.slice(0, -1).join('\\');
            }
        } else {
            // Unix路径
            const parts = currentPath.split('/').filter(p => p);
            if (parts.length === 0) {
                parentPath = '/';
            } else {
                parentPath = '/' + parts.slice(0, -1).join('/');
            }
        }
        
        localPathInput.value = parentPath;
        localPathInput.dispatchEvent(new Event('change'));
        
        // 更新当前路径显示
        const currentPathSpan = document.getElementById('local_current_path');
        if (currentPathSpan) {
            currentPathSpan.textContent = parentPath;
        }
        
        // 显示/隐藏向上级按钮
        const navUpBtn = document.getElementById('local_nav_up_btn');
        if (navUpBtn) {
            navUpBtn.style.display = (parentPath !== '/' && parentPath.length > 3) ? 'inline-block' : 'none';
        }
    }
}

window.loadDirectoryTree = function(type, path) {
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/getDirectoryTree') ?>';
    const url = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 
                'path=' + encodeURIComponent(path) + 
                '&type=' + type + 
                '&max_depth=1'; // 只加载第一级目录
    
    const containerId = type === 'local' ? 'local_tree_content' : 'remote_tree_content';
    const container = document.getElementById(containerId);
    const treeContainer = document.getElementById(type + '_directory_tree');
    
    if (container) {
        container.innerHTML = '<div class="text-center py-2"><small class="text-muted"><?= __('加载中...') ?></small></div>';
    }
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 && data.data && data.data.tree) {
            if (type === 'local') {
                window.localDirectoryTree = data.data.tree;
                window.renderDirectoryTree(container, data.data.tree, type);
                if (treeContainer) {
                    treeContainer.style.display = 'block';
                }
                window.updateIncludeExcludeTrees();
            } else {
                window.renderDirectoryTree(container, data.data.tree, type);
                if (treeContainer) {
                    treeContainer.style.display = 'block';
                }
            }
        } else {
            if (container) {
                container.innerHTML = '<div class="alert alert-warning"><small>' + (data.msg || '<?= __('加载失败') ?>') + '</small></div>';
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (container) {
            container.innerHTML = '<div class="alert alert-danger"><small><?= __('加载失败，请稍后重试') ?></small></div>';
        }
    });
}

window.renderDirectoryTree = function(container, tree, type, level = 0) {
    if (!tree || tree.length === 0) {
        if (container) {
            container.innerHTML = '<small class="text-muted"><?= __('暂无目录') ?></small>';
        }
        return '';
    }
    
    let html = '<ul class="list-unstyled mb-0" style="padding-left: ' + (level * 20) + 'px;">';
    
    tree.forEach(node => {
        const relativePath = node.relative_path || node.name;
        // 对于远程目录，使用完整路径；对于本地目录，使用相对路径
        const pathValue = type === 'remote' ? (node.path || relativePath) : relativePath;
        const checkboxId = type + '_' + pathValue.replace(/[^a-zA-Z0-9]/g, '_');
        
        html += '<li class="mb-1">';
        html += '<div class="form-check">';
        html += '<input class="form-check-input directory-checkbox" type="checkbox" id="' + checkboxId + '" ';
        html += 'value="' + window.escapeHtml(pathValue) + '" ';
        html += 'data-type="' + window.escapeHtml(type) + '" ';
        html += 'data-path="' + window.escapeHtml(pathValue) + '">';
        html += '<label class="form-check-label" for="' + checkboxId + '">';
        html += '<i class="mdi mdi-folder"></i> ' + window.escapeHtml(node.name);
        html += '</label>';
        html += '</div>';
        
        if (node.children && node.children.length > 0) {
            html += '<div id="children_' + checkboxId + '">';
            html += window.renderDirectoryTree(null, node.children, type, level + 1);
            html += '</div>';
        }
        
        html += '</li>';
    });
    
    html += '</ul>';
    
    if (container && level === 0) {
        container.innerHTML = html;
    }
    
    return html;
}

window.updateIncludeExcludeTrees = function() {
    if (!window.localDirectoryTree) return;
    
    const includeContainer = document.getElementById('include_tree_content');
    const excludeContainer = document.getElementById('exclude_tree_content');
    
    if (includeContainer) {
        window.renderDirectoryTree(includeContainer, window.localDirectoryTree, 'include');
    }
    
    if (excludeContainer) {
        window.renderDirectoryTree(excludeContainer, window.localDirectoryTree, 'exclude');
    }
};

window.handleDirectoryCheckbox = function(type, path, checked) {
    if (type === 'include') {
        if (checked) {
            window.selectedIncludePaths.add(path);
        } else {
            window.selectedIncludePaths.delete(path);
        }
        window.updateIncludePathsTextarea();
    } else if (type === 'exclude') {
        if (checked) {
            window.selectedExcludePaths.add(path);
        } else {
            window.selectedExcludePaths.delete(path);
        }
        window.updateExcludePatternsTextarea();
    }
};

window.updateIncludePathsTextarea = function() {
    const textarea = document.getElementById('include_paths');
    if (textarea) {
        textarea.value = Array.from(window.selectedIncludePaths).join('\n');
    }
};

window.updateExcludePatternsTextarea = function() {
    const textarea = document.getElementById('exclude_patterns');
    if (textarea) {
        const currentPatterns = textarea.value.split('\n').filter(p => p.trim());
        const excludePaths = Array.from(window.selectedExcludePaths);
        const allPatterns = [...new Set([...excludePaths, ...currentPatterns])].filter(p => p.trim());
        textarea.value = allPatterns.join('\n');
    }
}

window.toggleAllLocalDirectories = function() {
    const checkboxes = document.querySelectorAll('#local_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        window.handleDirectoryCheckbox('local', path, !allChecked);
    });
}

window.toggleAllIncludeDirectories = function() {
    const checkboxes = document.querySelectorAll('#include_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        window.handleDirectoryCheckbox('include', path, !allChecked);
    });
}

window.toggleAllExcludeDirectories = function() {
    const checkboxes = document.querySelectorAll('#exclude_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.value;
        window.handleDirectoryCheckbox('exclude', path, !allChecked);
    });
}

window.toggleAllRemoteDirectories = function() {
    const checkboxes = document.querySelectorAll('#remote_tree_content input[type="checkbox"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        const path = cb.getAttribute('data-path') || cb.value;
        if (cb.checked) {
            window.addRemotePath(path);
        } else {
            window.removeRemotePath(path);
        }
    });
    window.updateSelectedRemotePaths();
}

// 显示远程映射选项
window.showRemoteMappingOptions = function() {
    const remoteTreeContainer = document.getElementById('remote_directory_tree');
    const remoteBasePathInput = document.getElementById('remote_base_path');
    
    if (!remoteBasePathInput || !remoteBasePathInput.value) {
        alert('<?= __('请先输入远程基础路径') ?>');
        return;
    }
    
    const hostId = window.currentHostId || document.querySelector('input[name="host_id"]')?.value;
    if (!hostId) {
        alert('<?= __('请先选择主机') ?>');
        return;
    }
    
    // 显示远程目录树
    if (remoteTreeContainer) {
        remoteTreeContainer.style.display = 'block';
    }
    
    // 加载远程目录树
    window.loadRemoteDirectoryTree(remoteBasePathInput.value, hostId);
}

// 添加远程路径到选择列表
window.addRemotePath = function(path) {
    if (!window.selectedRemotePaths) {
        window.selectedRemotePaths = [];
    }
    if (!window.selectedRemotePaths.includes(path)) {
        window.selectedRemotePaths.push(path);
    }
}

// 从选择列表移除远程路径
window.removeRemotePath = function(path) {
    if (window.selectedRemotePaths) {
        window.selectedRemotePaths = window.selectedRemotePaths.filter(p => p !== path);
    }
}

// 更新已选择的远程路径显示
window.updateSelectedRemotePaths = function() {
    const container = document.getElementById('selected_remote_paths');
    if (!container) return;
    
    const paths = window.selectedRemotePaths || [];
    if (paths.length === 0) {
        container.innerHTML = '';
        return;
    }
    
    let html = '<div class="d-flex flex-wrap gap-1">';
    paths.forEach(path => {
        html += '<span class="badge bg-primary">' + window.escapeHtml(path) + 
                ' <button type="button" class="btn-close btn-close-white btn-sm" onclick="window.removeRemotePath(\'' + 
                window.escapeHtml(path) + '\'); window.updateSelectedRemotePaths();"></button></span>';
    });
    html += '</div>';
    
    container.innerHTML = html;
    
    // 更新隐藏字段
    const remotePathsInput = document.getElementById('remote_paths');
    if (remotePathsInput) {
        remotePathsInput.value = JSON.stringify(paths);
    }
}

// 初始化已选择的远程路径
window.selectedRemotePaths = [];

// 初始化时恢复已选择的远程路径（编辑模式）
window.restoreSelectedRemotePaths = function() {
    const remotePathsInput = document.getElementById('remote_paths');
    if (remotePathsInput && remotePathsInput.value) {
        try {
            const paths = JSON.parse(remotePathsInput.value);
            if (Array.isArray(paths)) {
                window.selectedRemotePaths = paths;
                window.updateSelectedRemotePaths();
                // 勾选对应的复选框
                paths.forEach(path => {
                    const checkbox = document.querySelector('#remote_tree_content input[data-path="' + window.escapeHtml(path) + '"]');
                    if (checkbox) {
                        checkbox.checked = true;
                    }
                });
            }
        } catch (e) {
            console.error('解析远程路径失败:', e);
        }
    }
};

window.restoreSelectedDirectories = function() {
    const includeTextarea = document.getElementById('include_paths');
    if (includeTextarea && includeTextarea.value) {
        const paths = includeTextarea.value.split('\n').filter(p => p.trim());
        paths.forEach(path => {
            window.selectedIncludePaths.add(path.trim());
            const checkbox = document.querySelector('#include_tree_content input[value="' + path.trim() + '"]');
            if (checkbox) {
                checkbox.checked = true;
            }
        });
    }
    
    const excludeTextarea = document.getElementById('exclude_patterns');
    if (excludeTextarea && excludeTextarea.value) {
        const patterns = excludeTextarea.value.split('\n').filter(p => p.trim());
        patterns.forEach(pattern => {
            if (!pattern.includes('*') && !pattern.includes('?')) {
                window.selectedExcludePaths.add(pattern.trim());
                const checkbox = document.querySelector('#exclude_tree_content input[value="' + pattern.trim() + '"]');
                if (checkbox) {
                    checkbox.checked = true;
                }
            }
        });
    }
};

window.escapeHtml = function(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

window.asyncControl = function(action, mappingId, confirmMsg) {
    if (confirmMsg && !confirm(confirmMsg)) {
        return;
    }
    
    // 使用 Mapping 控制器的路由，已添加 start/stop/restart 方法
    const baseUrl = '<?= $this->getBackendUrl('async/backend/mapping/') ?>';
    const url = baseUrl + action + (baseUrl.includes('?') ? '&' : '?') + 'mapping_id=' + mappingId;
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.code === 200 || data.success) {
            alert(data.msg || '操作成功');
            location.reload();
        } else {
            alert(data.msg || '操作失败');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('操作失败，请稍后重试');
    });
};

// 将函数也直接暴露到全局作用域（兼容性）
// 这样 onclick="loadMappingList(...)" 也能正常工作
loadMappingList = window.loadMappingList;

// 确保 DOM 加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded, loadMappingList function available:', typeof window.loadMappingList);
    console.log('Global loadMappingList function available:', typeof loadMappingList);
    
    // 为所有"新增/编辑主机"按钮绑定点击事件
    document.querySelectorAll('.btn-load-host-form').forEach(function(button) {
        button.addEventListener('click', function(e) {
            const hostId = this.getAttribute('data-host-id') || '';
            if (window.loadHostForm) {
                window.loadHostForm(hostId);
            } else {
                console.error('loadHostForm is not defined');
            }
        });
    });
    
    // 为所有"删除主机"按钮绑定点击事件
    document.querySelectorAll('.btn-delete-host').forEach(function(button) {
        button.addEventListener('click', function(e) {
            const hostId = this.getAttribute('data-host-id');
            if (hostId && window.deleteHost) {
                window.deleteHost(hostId);
            } else {
                console.error('deleteHost is not defined or hostId is missing');
            }
        });
    });
    
    // 为所有"同步映射"按钮绑定点击事件
    document.querySelectorAll('.btn-load-mapping').forEach(function(button) {
        button.addEventListener('click', function(e) {
            const hostId = this.getAttribute('data-host-id');
            if (hostId && window.loadMappingList) {
                window.loadMappingList(parseInt(hostId));
            } else {
                console.error('loadMappingList is not defined or hostId is missing');
            }
        });
    });
    
    // 为动态生成的按钮绑定事件（使用事件委托）
    document.addEventListener('click', function(e) {
        // 加载主机表单按钮（动态生成的）
        if (e.target.closest('.btn-load-host-form')) {
            const button = e.target.closest('.btn-load-host-form');
            const hostId = button.getAttribute('data-host-id') || '';
            if (window.loadHostForm) {
                window.loadHostForm(hostId);
            }
        }
        // 删除主机按钮（动态生成的）
        else if (e.target.closest('.btn-delete-host')) {
            const button = e.target.closest('.btn-delete-host');
            const hostId = button.getAttribute('data-host-id');
            if (hostId && window.deleteHost) {
                window.deleteHost(hostId);
            }
        }
        // 加载映射表单按钮
        else if (e.target.closest('.btn-load-mapping-form')) {
            const button = e.target.closest('.btn-load-mapping-form');
            const hostId = button.getAttribute('data-host-id');
            const mappingId = button.getAttribute('data-mapping-id');
            if (hostId && window.loadMappingForm) {
                window.loadMappingForm(parseInt(hostId), mappingId ? parseInt(mappingId) : null);
            }
        }
        // 切换映射状态按钮
        else if (e.target.closest('.btn-toggle-mapping')) {
            const button = e.target.closest('.btn-toggle-mapping');
            const mappingId = button.getAttribute('data-mapping-id');
            const hostId = button.getAttribute('data-host-id');
            if (mappingId && hostId && window.toggleMapping) {
                window.toggleMapping(parseInt(mappingId), parseInt(hostId));
            }
        }
        // 删除映射按钮
        else if (e.target.closest('.btn-delete-mapping')) {
            const button = e.target.closest('.btn-delete-mapping');
            const mappingId = button.getAttribute('data-mapping-id');
            const hostId = button.getAttribute('data-host-id');
            if (mappingId && hostId && window.deleteMapping) {
                window.deleteMapping(parseInt(mappingId), parseInt(hostId));
            }
        }
    });
    
    // 为目录复选框绑定事件（使用事件委托）
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('directory-checkbox')) {
            const type = e.target.getAttribute('data-type');
            const path = e.target.getAttribute('data-path') || e.target.value;
            const checked = e.target.checked;
            
            if (type === 'remote') {
                // 处理远程目录选择
                if (checked) {
                    window.addRemotePath(path);
                } else {
                    window.removeRemotePath(path);
                }
                window.updateSelectedRemotePaths();
            } else if (type && path && window.handleDirectoryCheckbox) {
                // 处理本地目录选择
                window.handleDirectoryCheckbox(type, path, checked);
            }
        }
    });
    
    // 监听 offcanvas 显示事件，自动加载映射列表
    const mappingListOffcanvas = document.getElementById('mappingListOffcanvas');
    if (mappingListOffcanvas) {
        mappingListOffcanvas.addEventListener('show.bs.offcanvas', function(event) {
            const button = event.relatedTarget;
            if (button && button.classList.contains('btn-load-mapping')) {
                const hostId = button.getAttribute('data-host-id');
                if (hostId && window.loadMappingList) {
                    window.loadMappingList(parseInt(hostId));
                }
            }
        });
    }
    
    // 监听映射表单 offcanvas 显示事件
    const mappingOffcanvas = document.getElementById('mappingOffcanvas');
    if (mappingOffcanvas) {
        mappingOffcanvas.addEventListener('show.bs.offcanvas', function(event) {
            const button = event.relatedTarget;
            if (button && button.classList.contains('btn-load-mapping-form')) {
                const hostId = button.getAttribute('data-host-id');
                const mappingId = button.getAttribute('data-mapping-id');
                if (hostId && window.loadMappingForm) {
                    window.loadMappingForm(parseInt(hostId), mappingId ? parseInt(mappingId) : null);
                }
            }
        });
        
        // 监听 offcanvas 完全显示后，自动加载本地和远程目录树
        mappingOffcanvas.addEventListener('shown.bs.offcanvas', function(event) {
            // offcanvas 完全显示后，尝试自动加载目录树
            setTimeout(() => {
                // 先加载本地目录树（只加载第一级）
                const localPathInput = document.getElementById('local_path');
                if (localPathInput && localPathInput.value) {
                    window.loadDirectoryTree('local', localPathInput.value);
                }
                
                // 然后加载远程目录树（只加载第一级）
                setTimeout(() => {
                    const remoteBasePathInput = document.getElementById('remote_base_path');
                    const hostId = window.currentHostId || document.querySelector('input[name="host_id"]')?.value;
                    if (remoteBasePathInput && hostId) {
                        let remotePath = remoteBasePathInput.value.trim();
                        if (!remotePath) {
                            remotePath = '/www/wwwroot/';
                            remoteBasePathInput.value = remotePath;
                        }
                        // 确保路径以 / 结尾
                        if (!remotePath.endsWith('/')) {
                            remotePath += '/';
                        }
                        window.loadRemoteDirectoryTree(remotePath, hostId);
                    }
                }, 200); // 延迟200ms，确保本地目录先加载
            }, 300);
        });
    }
    
    // 监听远程基础路径输入框变化，自动加载远程目录树
    document.addEventListener('change', function(e) {
        if (e.target.id === 'remote_base_path') {
            const remotePath = e.target.value.trim();
            const hostId = window.currentHostId || document.querySelector('input[name="host_id"]')?.value;
            if (remotePath && hostId) {
                // 确保路径以 / 结尾
                const pathToLoad = remotePath.endsWith('/') ? remotePath : remotePath + '/';
                window.loadRemoteDirectoryTree(pathToLoad, hostId);
            }
        }
    });
});
</script>

<style>
/* 目录树滚动条样式 - 兼容主题滚动条 */
.async-directory-tree {
    /* Firefox滚动条 */
    scrollbar-width: thin;
    scrollbar-color: var(--scrollbar-thumb, #a2adb7) var(--scrollbar-track, transparent);
}

/* Webkit浏览器滚动条 */
.async-directory-tree::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

.async-directory-tree::-webkit-scrollbar-track {
    background: var(--scrollbar-track, transparent);
    border-radius: 3px;
}

.async-directory-tree::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb, #a2adb7);
    border-radius: 3px;
    transition: background 0.2s ease;
}

.async-directory-tree::-webkit-scrollbar-thumb:hover {
    background: var(--scrollbar-thumb-hover, #8590a5);
}

/* 暗色主题支持 */
[data-theme="dark"] .async-directory-tree {
    scrollbar-color: var(--scrollbar-thumb, #8590a5) var(--scrollbar-track, transparent);
}

[data-theme="dark"] .async-directory-tree::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb, #8590a5);
}

[data-theme="dark"] .async-directory-tree::-webkit-scrollbar-thumb:hover {
    background: var(--scrollbar-thumb-hover, #a2adb7);
}
</style>

@template(Weline_Admin::common/footer.phtml)
