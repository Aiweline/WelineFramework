<script type="module">
import { BackendToast } from '<?= $this->getStaticUrl('Weline_Admin/js/admin-toast.js') ?>';

const driverSelect = document.getElementById('driver-select');
const driverConfigs = document.querySelectorAll('.driver-config');

driverSelect.addEventListener('change', function() {
    driverConfigs.forEach(el => el.style.display = 'none');
    const target = document.getElementById('config-' + this.value);
    if (target) target.style.display = '';
});

const form = document.getElementById('storage-config-form');

form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const formData = new FormData(form);
    const params = new URLSearchParams();
    for (const [key, value] of formData) {
        params.append(key, value);
    }
    
    try {
        var saveUrl = '<?= $this->getUrl('storage/backend/config/save') ?>';
        var saveOpts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString() };
        var res = await window.Weline.Api.request(saveUrl, saveOpts);
        var data = (res && res.data) !== undefined ? res.data : res;
        
        if (data.code === 200) {
            BackendToast.success(data.msg);
            setTimeout(() => {
                location.href = '<?= $this->getUrl('storage/backend/config') ?>';
            }, 1000);
        } else {
            BackendToast.error(data.msg);
        }
    } catch (e) {
        BackendToast.error('<?= __('保存失败') ?>');
    }
});

document.getElementById('btn-test').addEventListener('click', async function() {
    const formData = new FormData(form);
    const params = new URLSearchParams();
    for (const [key, value] of formData) {
        params.append(key, value);
    }
    
    this.disabled = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> <?= __('测试中...') ?>';
    
    try {
        var url = '<?= $this->getUrl('storage/backend/config/test') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString() };
        var res = await window.Weline.Api.request(url, opts);
        var data = (res && res.data) !== undefined ? res.data : res;
        
        if (data.code === 200) {
            BackendToast.success(data.msg);
        } else {
            BackendToast.error(data.msg);
        }
    } catch (e) {
        BackendToast.error('<?= __('测试失败') ?>');
    } finally {
        this.disabled = false;
        this.innerHTML = '<i class="bi bi-plug"></i> <?= __('测试连接') ?>';
    }
});
</script>
