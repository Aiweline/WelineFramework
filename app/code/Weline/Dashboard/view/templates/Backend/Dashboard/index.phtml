<script>
(function () {
    var state = <?= json_encode([
        'websiteId' => $websiteId,
        'viewId' => $activeViewId,
        'baseUrl' => $this->getBackendUrl('weline_dashboard/backend/dashboard/index'),
        'editorUrl' => $editorUrl,
    ], $jsonFlags) ?>;
    var messages = <?= $messagesJson ?>;
    var editorDirty = false;
    var editorSaving = false;

    function root() {
        return document.querySelector('[data-dashboard-root]');
    }

    function showStatus(message, isError) {
        var el = document.querySelector('[data-dashboard-status]');
        if (!el) {
            return;
        }
        el.textContent = message || '';
        el.hidden = !message;
        el.classList.toggle('error', !!isError);
    }

    function waitForQuery(resolve, reject, attempt) {
        if (typeof window.w_query === 'function') {
            resolve(window.w_query);
            return;
        }
        if (attempt > 50) {
            reject(new Error('w_query is not ready'));
            return;
        }
        window.setTimeout(function () {
            waitForQuery(resolve, reject, attempt + 1);
        }, 100);
    }

    function query(operation, params) {
        return new Promise(function (resolve, reject) {
            waitForQuery(resolve, reject, 0);
        }).then(function (wQuery) {
            return wQuery('dashboard', operation, params || {}, {area: 'backend'});
        });
    }

    function reload(nextViewId) {
        var url = new URL(state.baseUrl, window.location.origin);
        url.searchParams.set('website_id', String(state.websiteId || 0));
        if (nextViewId) {
            url.searchParams.set('view_id', String(nextViewId));
        }
        window.location.href = url.href;
    }

    function setPanel(name) {
        document.querySelectorAll('[data-dashboard-form]').forEach(function (el) {
            el.hidden = el.getAttribute('data-dashboard-form') !== name || !el.hidden;
        });
    }

    function buildEditorUrl() {
        var url = new URL(state.editorUrl || '#', window.location.origin);
        url.searchParams.set('dashboard_modal', '1');
        return url.href;
    }

    function openEditorModal() {
        var modal = document.querySelector('[data-dashboard-editor-modal]');
        var frame = document.querySelector('[data-dashboard-editor-frame]');
        if (!modal || !frame || !state.editorUrl || state.editorUrl === '#') {
            window.location.href = state.editorUrl || '#';
            return;
        }
        editorDirty = false;
        frame.src = buildEditorUrl();
        modal.hidden = false;
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('w-dashboard-editor-open');
    }

    function closeEditorModal(shouldRefresh) {
        var modal = document.querySelector('[data-dashboard-editor-modal]');
        var frame = document.querySelector('[data-dashboard-editor-frame]');
        if (modal) {
            modal.hidden = true;
            modal.setAttribute('aria-hidden', 'true');
        }
        document.body.classList.remove('w-dashboard-editor-open');
        if (frame) {
            frame.src = 'about:blank';
        }
        if (shouldRefresh) {
            reload(state.viewId);
        }
    }

    function setEditorSaving(isSaving) {
        editorSaving = isSaving;
        document.querySelectorAll('[data-dashboard-editor-save-close], [data-dashboard-editor-close]').forEach(function (button) {
            button.disabled = isSaving;
        });
    }

    function editorUnavailableError(message) {
        var error = new Error(message || 'ThemeEditor is not ready');
        error.editorUnavailable = true;
        return error;
    }

    function postEditorSaveRequest() {
        return new Promise(function (resolve, reject) {
            var frame = document.querySelector('[data-dashboard-editor-frame]');
            var frameWindow = frame && frame.contentWindow ? frame.contentWindow : null;
            if (!frameWindow) {
                reject(editorUnavailableError('ThemeEditor frame is not ready'));
                return;
            }

            var requestId = 'dashboard-save-close-' + Date.now() + '-' + Math.random().toString(36).slice(2);
            var timeout = null;
            var retryTimer = null;

            function cleanup() {
                window.removeEventListener('message', onMessage);
                if (timeout) {
                    window.clearTimeout(timeout);
                }
                if (retryTimer) {
                    window.clearInterval(retryTimer);
                }
            }

            function onMessage(event) {
                if (!event.data || typeof event.data !== 'object') {
                    return;
                }
                if (event.data.type !== 'weline-theme-editor:save-close-result' || event.data.requestId !== requestId) {
                    return;
                }

                cleanup();
                if (event.data.success === false) {
                    reject(new Error(event.data.message || messages.layoutSaveFailed));
                    return;
                }
                resolve({
                    success: true,
                    message: event.data.message || messages.layoutSaved,
                    data: event.data.data || null
                });
            }

            function sendRequest() {
                try {
                    frameWindow.postMessage({
                        type: 'weline-dashboard-editor:save-close',
                        requestId: requestId
                    }, '*');
                } catch (error) {
                    cleanup();
                    reject(error);
                }
            }

            window.addEventListener('message', onMessage);
            timeout = window.setTimeout(function () {
                cleanup();
                reject(editorUnavailableError('ThemeEditor save request timed out'));
            }, 90000);
            retryTimer = window.setInterval(sendRequest, 300);
            sendRequest();
        });
    }

    function saveEditorLayoutAndClose(forceSave) {
        if (editorSaving) {
            return;
        }
        if (!editorDirty && !forceSave) {
            closeEditorModal(false);
            return;
        }

        setEditorSaving(true);
        showStatus(messages.layoutSaving, false);
        postEditorSaveRequest()
            .catch(function (error) {
                if (error && error.editorUnavailable) {
                    return query('saveLayout', {view_id: state.viewId});
                }
                throw error;
            })
            .then(function (result) {
                if (!result || result.success === false) {
                    throw new Error((result && result.message) || messages.layoutSaveFailed);
                }
                editorDirty = false;
                showStatus(result.message || messages.layoutSaved, false);
                closeEditorModal(true);
            })
            .catch(function (error) {
                showStatus((error && error.message) || messages.layoutSaveFailed, true);
            })
            .finally(function () {
                setEditorSaving(false);
            });
    }

    document.addEventListener('DOMContentLoaded', function () {
        var app = root();
        if (!app) {
            return;
        }

        app.querySelectorAll('[data-dashboard-editor-open]').forEach(function (button) {
            button.addEventListener('click', function (event) {
                event.preventDefault();
                openEditorModal();
            });
        });

        app.querySelectorAll('[data-dashboard-editor-close]').forEach(function (button) {
            button.addEventListener('click', function () {
                saveEditorLayoutAndClose(false);
            });
        });

        app.querySelectorAll('[data-dashboard-editor-save-close]').forEach(function (button) {
            button.addEventListener('click', function () {
                saveEditorLayoutAndClose(true);
            });
        });

        window.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                var modal = document.querySelector('[data-dashboard-editor-modal]');
                if (modal && !modal.hidden) {
                    saveEditorLayoutAndClose(false);
                }
            }
        });

        window.addEventListener('message', function (event) {
            if (event.origin !== window.location.origin || !event.data || typeof event.data !== 'object') {
                return;
            }
            if (event.data.type === 'weline-theme-editor:layout-mutated') {
                editorDirty = true;
            }
            if (event.data.type === 'weline-theme-editor:saved') {
                editorDirty = true;
                saveEditorLayoutAndClose(true);
            }
        });

        var websiteSelect = app.querySelector('[data-dashboard-website]');
        if (websiteSelect) {
            websiteSelect.addEventListener('change', function () {
                state.websiteId = Number(websiteSelect.value || 0);
                reload(0);
            });
        }

        var sitePicker = app.querySelector('[data-dashboard-site-picker]');
        var siteTrigger = app.querySelector('[data-dashboard-site-trigger]');
        var siteMenu = app.querySelector('[data-dashboard-site-menu]');
        var siteSearch = app.querySelector('[data-dashboard-site-search]');
        var siteOptions = app.querySelectorAll('[data-dashboard-site-option]');
        if (sitePicker && siteTrigger && siteMenu) {
            siteTrigger.addEventListener('click', function () {
                siteMenu.hidden = !siteMenu.hidden;
                if (!siteMenu.hidden && siteSearch) {
                    siteSearch.focus();
                    siteSearch.select();
                }
            });

            if (siteSearch) {
                siteSearch.addEventListener('input', function () {
                    var keyword = String(siteSearch.value || '').trim().toLowerCase();
                    siteOptions.forEach(function (option) {
                        var name = String(option.getAttribute('data-site-name') || option.textContent || '').toLowerCase();
                        option.hidden = keyword !== '' && name.indexOf(keyword) === -1;
                    });
                });
            }

            siteOptions.forEach(function (option) {
                option.addEventListener('click', function () {
                    var nextWebsiteId = Number(option.getAttribute('data-site-id') || 0);
                    if (!nextWebsiteId || nextWebsiteId === state.websiteId) {
                        siteMenu.hidden = true;
                        return;
                    }
                    state.websiteId = nextWebsiteId;
                    if (websiteSelect) {
                        websiteSelect.value = String(nextWebsiteId);
                    }
                    reload(0);
                });
            });

            document.addEventListener('click', function (event) {
                if (!sitePicker.contains(event.target)) {
                    siteMenu.hidden = true;
                }
            });
        }

        app.querySelectorAll('[data-dashboard-panel]').forEach(function (button) {
            button.addEventListener('click', function () {
                setPanel(button.getAttribute('data-dashboard-panel') || '');
            });
        });

        var createForm = app.querySelector('[data-dashboard-create-form]');
        if (createForm) {
            createForm.addEventListener('submit', function (event) {
                event.preventDefault();
                var formData = new FormData(createForm);
                showStatus(messages.creating, false);
                query('createView', {
                    website_id: state.websiteId,
                    name: String(formData.get('name') || ''),
                    visibility: formData.get('public') ? 'public' : 'private'
                }).then(function (res) {
                    if (!res || res.success === false) {
                        throw new Error((res && res.message) || 'Create failed');
                    }
                    reload(res.item && res.item.view_id);
                }).catch(function (error) {
                    showStatus(error.message || 'Create failed', true);
                });
            });
        }

        var renameForm = app.querySelector('[data-dashboard-rename-form]');
        if (renameForm) {
            renameForm.addEventListener('submit', function (event) {
                event.preventDefault();
                var formData = new FormData(renameForm);
                showStatus(messages.savingName, false);
                query('renameView', {
                    view_id: state.viewId,
                    name: String(formData.get('name') || '')
                }).then(function (res) {
                    if (!res || res.success === false) {
                        throw new Error((res && res.message) || 'Rename failed');
                    }
                    reload(state.viewId);
                }).catch(function (error) {
                    showStatus(error.message || 'Rename failed', true);
                });
            });
        }

        var deleteForm = app.querySelector('[data-dashboard-delete-form]');
        if (deleteForm) {
            deleteForm.addEventListener('submit', function (event) {
                event.preventDefault();
                var formData = new FormData(deleteForm);
                if (!formData.get('ack')) {
                    showStatus(messages.deleteAckRequired, true);
                    return;
                }
                showStatus(messages.deleting, false);
                query('deleteView', {view_id: state.viewId}).then(function (res) {
                    if (!res || res.success === false) {
                        throw new Error((res && res.message) || 'Delete failed');
                    }
                    reload(0);
                }).catch(function (error) {
                    showStatus(error.message || 'Delete failed', true);
                });
            });
        }

        app.querySelectorAll('[data-dashboard-action]').forEach(function (button) {
            button.addEventListener('click', function () {
                var action = button.getAttribute('data-dashboard-action') || '';
                showStatus(messages.processing, false);
                query(action, {view_id: state.viewId}).then(function (res) {
                    if (!res || res.success === false) {
                        throw new Error((res && res.message) || 'Action failed');
                    }
                    reload((res.item && res.item.view_id) || state.viewId);
                }).catch(function (error) {
                    showStatus(error.message || 'Action failed', true);
                });
            });
        });
    });
})();
</script>
