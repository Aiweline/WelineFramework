<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!--控制器注解属性-->
    <event name="Weline_Framework_Url::detect_website">
        <observer name="Weline_Websites::detect_website" instance="Weline\Websites\Observer\DetectWebsite"
                  disabled="false"
                  shared="true" sort="0"/>
    </event>
    <!--货币验证观察者：在网站检测之后验证货币是否被允许-->
    <event name="Weline_Framework_Url::detect_currency">
        <observer name="Weline_Websites::validate_currency" instance="Weline\Websites\Observer\ValidateCurrency"
                  disabled="false"
                  shared="true" sort="100"/>
    </event>
    <!--语言验证观察者：在网站检测之后验证语言是否被允许-->
    <event name="Weline_Framework_Url::detect_language">
        <observer name="Weline_Websites::validate_language" instance="Weline\Websites\Observer\ValidateLanguage"
                  disabled="false"
                  shared="true" sort="100"/>
    </event>
    
    <!-- ========== Server 模块事件观察者 ========== -->
    
    <!--证书签发完成：同步域名 HTTPS 状态-->
    <event name="Weline_Server::domain::certificate_issued">
        <observer name="Weline_Websites::sync_https_status" 
                  instance="Weline\Websites\Observer\SyncHttpsStatus"
                  disabled="false"
                  shared="true" sort="10"/>
        <observer name="Weline_Websites::certificate_issued_lifecycle"
                  instance="Weline\Websites\Observer\CertificateIssuedLifecycle"
                  disabled="false"
                  shared="true" sort="20"/>
    </event>
    
    <!--证书禁用：回退 HTTPS 状态-->
    <event name="Weline_Server::domain::certificate_disabled">
        <observer name="Weline_Websites::rollback_https_status" 
                  instance="Weline\Websites\Observer\RollbackHttpsStatus"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>
    
    <!--证书删除：清除域名池 HTTPS 和可建站状态-->
    <event name="Weline_Server::domain::certificate_deleted">
        <observer name="Weline_Websites::clear_domain_pool_certificate" 
                  instance="Weline\Websites\Observer\ClearDomainPoolCertificate"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>
    
    <!--证书更新：同步更新状态-->
    <event name="Weline_Server::domain::certificate_renewed">
        <observer name="Weline_Websites::update_certificate_status" 
                  instance="Weline\Websites\Observer\UpdateCertificateStatus"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>
    
    <!--请求域名列表：提供域名数据-->
    <event name="Weline_Server::integration::domain_list_requested">
        <observer name="Weline_Websites::provide_domain_list" 
                  instance="Weline\Websites\Observer\ProvideDomainList"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>
    <!-- 域名池解析偏离本站：发送通知 -->
    <event name="Weline_Websites::domain_pool::resolve_off_local">
        <observer name="Weline_Websites::domain_pool_resolve_off_local_notify"
                  instance="Weline\Websites\Observer\DomainPoolResolveOffLocalObserver"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>

    <event name="Weline_Websites::domain::purchase_success">
        <observer name="Weline_Websites::domain_purchase_success_lifecycle"
                  instance="Weline\Websites\Observer\DomainPurchaseSuccess"
                  disabled="false"
                  shared="true" sort="20"/>
    </event>

    <event name="Weline_Seo::integration::head_context_resolve">
        <observer name="Weline_Websites::seo_head_context_resolve"
                  instance="Weline\Websites\Observer\SeoHeadContextResolve"
                  disabled="false"
                  shared="true" sort="10"/>
    </event>
</config>
