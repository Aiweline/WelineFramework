    function createWorkspaceAndGoToNextStep(donePayload) {
        var formState = readFormState();
        var payload = donePayload && typeof donePayload === 'object' ? donePayload : {};
        var domain = '';
        if (payload.domain && String(payload.domain).trim() !== '') {
            domain = String(payload.domain).trim();
        } else if (formState.domain) {
            domain = formState.domain;
        }
        var description = formState.description || domain;
        var scopePatch = {
            journey_intent: 'virtual_theme_edit',
            next_step: 'virtual_theme_edit'
        };
        if (payload.theme_id) {
            scopePatch.theme_id = payload.theme_id;
        }
        if (payload.website_id) {
            scopePatch.website_id = payload.website_id;
        }
        if (payload.preview_url) {
            scopePatch.preview_url = payload.preview_url;
        }

        function isLocalFlowDomain(domainName) {
            var normalized = String(domainName || '').trim().toLowerCase();
            if (!normalized) {
                return false;
            }
            return normalized === 'localhost'
                || normalized.endsWith('.local')
                || normalized.endsWith('.localhost');
        }

        var fd = new FormData();
        fd.append('provider_code', selectedProviderCode || 'websites_default');
        fd.append('description', description);
        fd.append('domain', domain);
        fd.append('account_id', formState.accountId > 0 ? String(formState.accountId) : '0');
        fd.append('use_ai', formState.useAi ? '1' : '0');
        fd.append('scope', JSON.stringify(scopePatch));
        fd.append('provider_state', JSON.stringify({
            entry: {
                source: 'site_builder_trigger_sse_done',
                next_step: 'virtual_theme_edit'
            }
        }));
        if (fakeMode) {
            fd.append('fake_mode', '1');
        }

        return fetch(createSessionUrl, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        }).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) ? data.message : messages.createWorkspaceFailed);
            }
            var nextUrl = '';
            if (data.workspace_url && String(data.workspace_url).trim() !== '') {
                nextUrl = String(data.workspace_url).trim();
            } else if (data.native_entry_url && String(data.native_entry_url).trim() !== '') {
                nextUrl = String(data.native_entry_url).trim();
            }
            if (!nextUrl) {
                throw new Error(messages.nextStepFailed);
            }
            if (nextUrl.indexOf('/site-builder-agent/workspace') > -1) {
                nextUrl += (nextUrl.indexOf('?') > -1 ? '&' : '?')
                    + 'next_step=virtual_theme_edit';
                if (!isLocalFlowDomain(domain)) {
                    nextUrl += '&auto_start_domain_purchase=1';
                }
            }
            toast('info', messages.workspaceFlowHint);
            window.location.href = nextUrl;
        });
    }

