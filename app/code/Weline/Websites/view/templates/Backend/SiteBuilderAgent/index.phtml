<script>
(function () {
    'use strict';

    var startBtn = document.getElementById('site-agent-start-btn');
    var createWorkspaceBtn = document.getElementById('site-agent-create-workspace');
    var descInput = document.getElementById('site-agent-description');
    var domainInput = document.getElementById('site-agent-domain');
    var accountSelect = document.getElementById('site-agent-account');
    var useAiToggle = document.getElementById('site-agent-use-ai');
    var domainHint = document.getElementById('site-agent-domain-hint');
    var accountHint = document.getElementById('site-agent-account-hint');
    var modeTip = document.getElementById('site-agent-mode-tip');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['site-builder-agent-terminal'] : null;
    var terminalUnlocked = true;
    var createSessionUrl = <?= json_encode($create_session_url, JSON_THROW_ON_ERROR) ?>;
    var fakeMode = <?= $fake_mode ? 'true' : 'false' ?>;

    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.warning === 'function') {
            window.BackendToast.warning(message);
        }
    }

    function syncModeUi() {
        if (!useAiToggle) {
            return;
        }
        var useAi = !!useAiToggle.checked;
        if (domainHint) {
            domainHint.textContent = useAi ? <?= json_encode((string)__('AI 模式下可选'), JSON_THROW_ON_ERROR) ?> : <?= json_encode((string)__('关闭 AI 后必填'), JSON_THROW_ON_ERROR) ?>;
        }
        if (accountHint) {
            accountHint.textContent = useAi ? <?= json_encode((string)__('AI 模式下可后补'), JSON_THROW_ON_ERROR) ?> : <?= json_encode((string)__('关闭 AI 后必填'), JSON_THROW_ON_ERROR) ?>;
        }
        if (modeTip) {
            modeTip.innerHTML = useAi
                ? '<i class="mdi mdi-information-outline me-1"></i><span>' + <?= json_encode((string)__('推荐先用 AI 模式跑出域名和站点方向，再到分阶段工作台做页面、主题和发布检查。'), JSON_THROW_ON_ERROR) ?> + '</span>'
                : '<i class="mdi mdi-shield-check-outline me-1"></i><span>' + <?= json_encode((string)__('你已经关闭 AI 模式，系统将按明确输入直接执行，所以域名和账户都需要现在就确认。'), JSON_THROW_ON_ERROR) ?> + '</span>';
        }
    }

    function readFormState() {
        return {
            description: descInput && descInput.value ? descInput.value.trim() : '',
            domain: domainInput && domainInput.value ? domainInput.value.trim() : '',
            accountId: accountSelect && accountSelect.value ? parseInt(accountSelect.value, 10) : 0,
            useAi: useAiToggle ? !!useAiToggle.checked : true
        };
    }

    function postCreateWorkspace(providerCode) {
        var formState = readFormState();
        var fd = new FormData();
        fd.append('provider_code', providerCode);
        fd.append('description', formState.description);
        fd.append('domain', formState.domain);
        fd.append('account_id', formState.accountId > 0 ? String(formState.accountId) : '0');
        fd.append('use_ai', formState.useAi ? '1' : '0');
        if (fakeMode) {
            fd.append('fake_mode', '1');
        }

        fetch(createSessionUrl, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (r) {
            return r.json();
        }).then(function (data) {
            if (data && data.success && data.workspace_url) {
                window.location.href = data.workspace_url;
                return;
            }
            toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('创建工作区失败'), JSON_THROW_ON_ERROR) ?>);
        }).catch(function () {
            toast('error', <?= json_encode((string)__('网络错误，请稍后重试'), JSON_THROW_ON_ERROR) ?>);
        });
    }

    if (useAiToggle) {
        useAiToggle.addEventListener('change', syncModeUi);
        syncModeUi();
    }

    if (createWorkspaceBtn) {
        createWorkspaceBtn.addEventListener('click', function () {
            postCreateWorkspace(createWorkspaceBtn.getAttribute('data-provider-code') || 'websites_default');
        });
    }

    document.querySelectorAll('.site-create-session-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            postCreateWorkspace(btn.getAttribute('data-provider-code') || 'websites_default');
        });
    });

    if (!startBtn || !terminal) {
        return;
    }

    function finalizeTerminalRun() {
        startBtn.disabled = false;
        terminalUnlocked = true;
    }

    function parseTerminalPayload(event) {
        if (!event || typeof event.data !== 'string' || event.data === '') {
            return null;
        }
        try {
            return JSON.parse(event.data);
        } catch (err) {
            return null;
        }
    }

    terminal.on('done', function (event) {
        var payload = parseTerminalPayload(event);
        finalizeTerminalRun();
        if (payload && payload.message) {
            terminal.log(payload.message, 'done');
        }
    });
    terminal.on('error', function (event) {
        var payload = parseTerminalPayload(event);
        finalizeTerminalRun();
        if (payload && payload.message) {
            terminal.log(payload.message, 'error');
        }
    });

    startBtn.addEventListener('click', function () {
        var useAi = useAiToggle ? !!useAiToggle.checked : true;
        var domain = domainInput && domainInput.value ? domainInput.value.trim() : '';
        var accountId = accountSelect && accountSelect.value ? parseInt(accountSelect.value, 10) : 0;
        var description = descInput && descInput.value ? descInput.value.trim() : '';

        if (!useAi && !fakeMode) {
            if (!domain) {
                toast('warning', <?= json_encode((string)__('关闭 AI 模式后，请先填写目标域名。'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            if (!accountId) {
                toast('warning', <?= json_encode((string)__('关闭 AI 模式后，请先选择域名商账户。'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
        } else if (!description && !domain) {
            toast('warning', <?= json_encode((string)__('请至少填写需求描述或预期域名，AI 才知道要帮你建什么。'), JSON_THROW_ON_ERROR) ?>);
            return;
        }

        var finalDescription = description || domain;
        var baseUrl = <?= json_encode((string)$this->getBackendUrl('websites/backend/site-builder-agent/trigger-sse'), JSON_THROW_ON_ERROR) ?>;
        var separator = baseUrl.indexOf('?') >= 0 ? '&' : '?';
        var url = baseUrl + separator + 'description=' + encodeURIComponent(finalDescription)
            + '&domain=' + encodeURIComponent(domain)
            + '&account_id=' + encodeURIComponent(accountId > 0 ? String(accountId) : '')
            + '&use_ai=' + (useAi ? '1' : '0');
        if (fakeMode) {
            url += '&fake_mode=1';
        }

        if (terminalUnlocked) {
            terminal.clear();
            terminalUnlocked = false;
        }
        terminal.setUrl(url);
        startBtn.disabled = true;
        terminal.start();

        var terminalWrap = document.getElementById('site-builder-agent-terminal');
        if (terminalWrap && typeof terminalWrap.scrollIntoView === 'function') {
            terminalWrap.scrollIntoView({behavior: 'smooth', block: 'center'});
        }
    });
})();
</script>
