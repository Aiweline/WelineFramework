    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.warning === 'function') {
            window.BackendToast.warning(message);
        }
    }

    function confirmAction(message, onConfirm) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(message).then(function (confirmed) {
                if (confirmed) {
                    onConfirm();
                }
            });
            return;
        }
        toast('error', messages.confirmUnavailable);
    }

    function escapeHtml(value) {
        var node = document.createElement('div');
        node.textContent = value === undefined || value === null ? '' : String(value);
        return node.innerHTML;
    }

    function ensureQuickBuildRegistrarInstance() {
        window.WelineRegistrarSelect = window.WelineRegistrarSelect || {};
        if (window.WelineRegistrarSelect['site-agent-account']) {
            return window.WelineRegistrarSelect['site-agent-account'];
        }

        var id = 'site-agent-account';
        var wrapper = document.getElementById(id + '_wrapper');
        var trigger = document.getElementById(id + '_trigger');
        var dropdown = document.getElementById(id + '_dropdown');
        var search = document.getElementById(id + '_search');
        var list = document.getElementById(id + '_list');
        var tags = document.getElementById(id + '_tags');
        var hidden = document.getElementById(id + '_value');
        var multiple = wrapper && String(wrapper.getAttribute('data-multiple') || '').toLowerCase() === 'true';
        var selected = [];
        var options = [];
        var emptyLabel = '';
        var closeOnOutsideClickBound = false;

        if (!wrapper || !trigger || !dropdown || !search || !list || !tags || !hidden) {
            return null;
        }

        emptyLabel = tags.textContent ? tags.textContent.trim() : '';

        function readInitialSelection() {
            var raw = String(hidden.value || '').trim();
            if (!raw) {
                return [];
            }

            return raw.split(',').map(function (value) {
                return value.trim();
            }).filter(Boolean);
        }

        function normalizeOptions(items) {
            return (Array.isArray(items) ? items : []).map(function (item) {
                return {
                    value: String(item && item.value ? item.value : ''),
                    label: String(item && item.label ? item.label : (item && item.value ? item.value : '')),
                    group: String(item && item.group ? item.group : ''),
                    meta: String(item && item.meta ? item.meta : ''),
                    raw: item || null
                };
            }).filter(function (item) {
                return item.value !== '';
            });
        }

        function isPicked(value) {
            return selected.indexOf(String(value)) > -1;
        }

        function syncHidden() {
            hidden.value = selected.join(',');
        }

        function getSelected() {
            return selected.map(function (value) {
                return options.find(function (option) {
                    return option.value === value;
                }) || {
                    value: value,
                    label: value,
                    group: '',
                    meta: '',
                    raw: null
                };
            });
        }

        function emitChange(item) {
            try {
                hidden.dispatchEvent(new Event('change', { bubbles: true }));
            } catch (error) {
            }

            if (typeof window.handleQuickBuildRegistrarSelect === 'function') {
                window.handleQuickBuildRegistrarSelect(item || null, { selected: selected.slice() });
            }
        }

        function renderTags() {
            tags.innerHTML = '';
            if (selected.length === 0) {
                var placeholder = document.createElement('span');
                placeholder.id = id + '_display';
                placeholder.textContent = emptyLabel;
                tags.appendChild(placeholder);
                return;
            }

            selected.forEach(function (value) {
                var item = options.find(function (option) {
                    return option.value === value;
                });
                if (!item) {
                    return;
                }

                if (!multiple) {
                    var display = document.createElement('span');
                    display.id = id + '_display';
                    display.textContent = item.label;
                    tags.appendChild(display);
                    return;
                }

                var tag = document.createElement('span');
                tag.className = 'weline-registrar-tag';
                tag.textContent = item.label;

                var remove = document.createElement('span');
                remove.className = 'weline-registrar-tag-remove';
                remove.innerHTML = '&times;';
                remove.addEventListener('click', function (event) {
                    event.stopPropagation();
                    selected = selected.filter(function (picked) {
                        return picked !== value;
                    });
                    syncHidden();
                    renderTags();
                    renderList(search.value || '');
                    emitChange(null);
                });

                tag.appendChild(remove);
                tags.appendChild(tag);
            });
        }

        function renderList(keyword) {
            var normalizedKeyword = String(keyword || '').trim().toLowerCase();
            var filtered = options.filter(function (item) {
                return !normalizedKeyword
                    || item.label.toLowerCase().indexOf(normalizedKeyword) > -1
                    || item.group.toLowerCase().indexOf(normalizedKeyword) > -1
                    || item.meta.toLowerCase().indexOf(normalizedKeyword) > -1;
            });

            if (filtered.length === 0) {
                list.innerHTML = '<div class="weline-registrar-empty">' + escapeHtml('No matching registrar account') + '</div>';
                return;
            }

            var grouped = {};
            filtered.forEach(function (item) {
                var groupKey = item.group || 'default';
                if (!grouped[groupKey]) {
                    grouped[groupKey] = [];
                }
                grouped[groupKey].push(item);
            });

            var html = '';
            Object.keys(grouped).forEach(function (groupKey) {
                if (groupKey !== 'default') {
                    html += '<div class="weline-registrar-group">' + escapeHtml(groupKey) + '</div>';
                }

                grouped[groupKey].forEach(function (item) {
                    var meta = item.meta ? '<div class="weline-registrar-item-meta">' + escapeHtml(item.meta) + '</div>' : '';
                    html += '<div class="weline-registrar-item' + (isPicked(item.value) ? ' active' : '') + '" data-value="' + escapeHtml(item.value) + '"><div>' + escapeHtml(item.label) + '</div>' + meta + '</div>';
                });
            });

            list.innerHTML = html;
            Array.prototype.slice.call(list.querySelectorAll('.weline-registrar-item')).forEach(function (element) {
                element.addEventListener('click', function () {
                    var value = this.getAttribute('data-value') || '';
                    var pickedItem = options.find(function (option) {
                        return option.value === value;
                    }) || null;
                    if (!value) {
                        return;
                    }

                    if (multiple) {
                        selected = isPicked(value)
                            ? selected.filter(function (picked) { return picked !== value; })
                            : selected.concat(value);
                    } else {
                        selected = [value];
                        dropdown.style.display = 'none';
                    }

                    syncHidden();
                    renderTags();
                    renderList(search.value || '');
                    emitChange(pickedItem);
                });
            });
        }

        function setOptions(nextOptions) {
            options = normalizeOptions(nextOptions);
            selected = selected.filter(function (value) {
                return options.some(function (option) {
                    return option.value === value;
                });
            });
            if (!multiple && selected.length > 1) {
                selected = selected.slice(0, 1);
            }
            syncHidden();
            renderTags();
            renderList(search.value || '');
        }

        function setValue(value, emitEvent) {
            var values = Array.isArray(value)
                ? value.map(String)
                : String(value || '').split(',').map(function (item) {
                    return item.trim();
                }).filter(Boolean);
            selected = multiple ? values : (values[0] ? [values[0]] : []);
            syncHidden();
            renderTags();
            renderList(search.value || '');
            if (emitEvent !== false) {
                emitChange(getSelected()[0] || null);
            }
        }

        trigger.addEventListener('click', function (event) {
            event.stopPropagation();
            dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
            if (dropdown.style.display === 'block') {
                renderList(search.value || '');
                search.focus();
            }
        });

        search.addEventListener('input', function () {
            renderList(search.value || '');
        });

        if (!closeOnOutsideClickBound) {
            document.addEventListener('click', function (event) {
                if (!wrapper.contains(event.target)) {
                    dropdown.style.display = 'none';
                }
            });
            closeOnOutsideClickBound = true;
        }

        selected = readInitialSelection();
        window.WelineRegistrarSelect[id] = {
            setOptions: setOptions,
            setValue: function (value) {
                setValue(value, true);
            },
            getValue: function () {
                return String(hidden.value || '');
            },
            getValues: function () {
                return selected.slice();
            },
            getSelected: getSelected
        };

        return window.WelineRegistrarSelect[id];
    }

    function getRegistrarInstance() {
        return ensureQuickBuildRegistrarInstance();
    }

    function hydrateQuickBuildRegistrarOptions() {
        var registrarInstance = getRegistrarInstance();
        if (registrarInstance && typeof registrarInstance.setOptions === 'function') {
            registrarInstance.setOptions(Array.isArray(quickBuildRegistrarOptions) ? quickBuildRegistrarOptions : []);
        }
    }

    function getRegistrarAccountId() {
        var registrarInstance = getRegistrarInstance();
        var rawValue = registrarInstance && typeof registrarInstance.getValue === 'function'
            ? registrarInstance.getValue()
            : (accountValueInput && accountValueInput.value ? accountValueInput.value : '');
        var parsed = rawValue ? parseInt(rawValue, 10) : 0;
        return Number.isFinite(parsed) ? parsed : 0;
    }

    function buildRecommendationDetails(payload) {
        var checkedResults = Array.isArray(payload && payload.checked_results) ? payload.checked_results : [];
        if (checkedResults.length === 0) {
            return '';
        }

        var details = checkedResults.slice(0, 4).map(function (item) {
            var domain = item && item.domain ? String(item.domain) : '';
            var status = item && item.available ? messages.recommendationAvailable : messages.recommendationUnavailable;
            return domain ? (domain + ' ' + status) : '';
        }).filter(Boolean);

        if (details.length === 0) {
            return '';
        }

        return '<span class="text-muted">' + escapeHtml(messages.checkedCandidatesLabel + ': ' + details.join(' | ')) + '</span>';
    }

    function setRecommendationState(type, message, detailHtml) {
        if (!recommendationBox) {
            return;
        }

        if (!message) {
            recommendationBox.className = 'alert alert-light border d-none mt-2 py-2 px-3 mb-0';
            recommendationBox.innerHTML = '';
            return;
        }

        var stateClass = 'alert-light';
        if (type === 'success') {
            stateClass = 'alert-success';
        } else if (type === 'warning') {
            stateClass = 'alert-warning';
        } else if (type === 'error') {
            stateClass = 'alert-danger';
        } else if (type === 'info') {
            stateClass = 'alert-info';
        }

        recommendationBox.className = 'alert border mt-2 py-2 px-3 mb-0 ' + stateClass;
        recommendationBox.innerHTML = '<div>' + escapeHtml(message) + '</div>' + (detailHtml ? '<div class="small mt-1">' + detailHtml + '</div>' : '');
    }

    function syncModeUi() {
