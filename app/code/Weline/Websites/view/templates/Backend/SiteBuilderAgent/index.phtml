/**
 * @var \Weline\Framework\View\Template $this
 * @var list<array{account_id:int,account_name:string,registrar_name:string,registrar_code:string}> $accounts
 * @var list<array{code:string,name:string,description:string,badge:string,target_url:string,target_label:string,workspace_label:string,selected:bool}> $provider_cards
 * @var list<array{public_id:string,provider_name:string,stage_label:string,summary:string,update_time:string,workspace_url:string,native_entry_url:string}> $recent_sessions
 * @var array{code:string,name:string,description:string,badge:string} $selected_provider_context
 * @var list<array{code:string,label:string,title:string,description:string,ai_recommendation_title:string,ai_recommendation:string,confirm_label:string,previous_label:string,next_stage:string,previous_stage:string,tool_codes:list<string>,scope_patch:array<string,mixed>,key_points:list<string>}> $selected_stage_guides
 * @var string $selected_provider
 * @var string $create_session_url
 * @var string $delete_session_url
 * @var string $recommend_domain_url
 * @var string $recommend_domain_sse_url
 * @var string $current_entry_url
 * @var string $check_domain_url
 * @var bool $fake_mode
 */

$accounts = $this->getData('accounts');
$accounts = \is_array($accounts) ? $accounts : [];
$provider_cards = $this->getData('provider_cards');
$provider_cards = \is_array($provider_cards) ? $provider_cards : [];
$recent_sessions = $this->getData('recent_sessions');
$recent_sessions = \is_array($recent_sessions) ? $recent_sessions : [];
$selected_provider_context = $this->getData('selected_provider_context');
$selected_provider_context = \is_array($selected_provider_context) ? $selected_provider_context : ['code' => 'websites_default', 'name' => 'AI 建站工作台', 'description' => '', 'badge' => ''];
$selected_stage_guides = $this->getData('selected_stage_guides');
$selected_stage_guides = \is_array($selected_stage_guides) ? $selected_stage_guides : [];
$selected_provider = (string)($this->getData('selected_provider') ?? 'websites_default');
$create_session_url = (string)($this->getData('create_session_url') ?? '');
$delete_session_url = (string)($this->getData('delete_session_url') ?? '');
$recommend_domain_url = (string)($this->getData('recommend_domain_url') ?? '');
$recommend_domain_sse_url = (string)($this->getData('recommend_domain_sse_url') ?? '');
$check_domain_url = (string)($this->getData('check_domain_url') ?? '');
$current_entry_url = (string)($this->getData('current_entry_url') ?? $this->getBackendUrl('websites/backend/site-builder-agent/index', ['provider' => $selected_provider]));
$fake_mode = (bool)($this->getData('fake_mode') ?? false);
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
$quick_build_url = $current_entry_url . '#quick-build';
$provider_lane_url = $current_entry_url . '#provider-lane';
$quickBuildRegistrarOptions = [];
foreach ($accounts as $account) {
    $accountId = (int)($account['account_id'] ?? 0);
    if ($accountId <= 0) {
        continue;
    }

    $registrarName = \trim((string)($account['registrar_name'] ?? $account['registrar_code'] ?? ''));
    $accountName = \trim((string)($account['account_name'] ?? ''));
    $quickBuildRegistrarOptions[] = [
        'value' => (string)$accountId,
        'label' => $registrarName . ($accountName !== '' ? (' - ' . $accountName) : ''),
        'group' => $registrarName !== '' ? $registrarName : (string)__('其他'),
        'meta' => (string)($account['registrar_code'] ?? ''),
    ];
}
$quickBuildRegistrarOptionsJson = \json_encode($quickBuildRegistrarOptions, $jsonForScriptFlags | JSON_THROW_ON_ERROR);
$quickBuildRegistrarAccountId = '';
$quickBuildRegistrarDisplay = '';
?>

