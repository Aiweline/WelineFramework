<script>
(function(){
    'use strict';
    var startBtn = document.getElementById('site-agent-start-btn');
    var descInput = document.getElementById('site-agent-description');
    var domainInput = document.getElementById('site-agent-domain');
    var accountSelect = document.getElementById('site-agent-account');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['site-builder-agent-terminal'] : null;

    if (!startBtn || !terminal) return;

    startBtn.addEventListener('click', function(){
        var domain = (domainInput && domainInput.value) ? domainInput.value.trim() : '';
        var accountId = (accountSelect && accountSelect.value) ? parseInt(accountSelect.value, 10) : 0;
        var description = (descInput && descInput.value) ? descInput.value.trim() : domain;

        if (!domain) {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.warning('<?= addslashes(__('请填写要购买的域名')) ?>');
            }
            return;
        }
        if (!accountId) {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.warning('<?= addslashes(__('请选择域名商账号')) ?>');
            }
            return;
        }

        var baseUrl = '<?= addslashes((string)$this->getBackendUrl($triggerPath)) ?>';
        var sep = baseUrl.indexOf('?') >= 0 ? '&' : '?';
        var url = baseUrl + sep + 'description=' + encodeURIComponent(description)
            + '&domain=' + encodeURIComponent(domain)
            + '&account_id=' + accountId;

        terminal.clear();
        terminal.setUrl(url);
        startBtn.disabled = true;
        terminal.start();

        terminal.on('done', function(){
            startBtn.disabled = false;
        });
        terminal.on('error', function(){
            startBtn.disabled = false;
        });
    });
})();
</script>
