    function createFallbackTerminal() {
        var terminalBody = document.getElementById('site-builder-agent-terminal_body');
        var terminalContent = document.getElementById('site-builder-agent-terminal_content');
        var terminalStatus = document.getElementById('site-builder-agent-terminal_status');
        var eventSource = null;
        var currentUrl = '';
        var running = false;
        var callbacks = {};
        var streamingLine = null;
        var chunkRafPending = '';
        var chunkRafScheduled = false;

        if (!terminalContent) {
            return null;
        }

        function formatTime() {
            return new Date().toLocaleTimeString('zh-CN', { hour12: false });
        }

        function setStatus(text) {
            if (terminalStatus) {
                terminalStatus.textContent = text;
            }
        }

        function appendLine(text, type) {
            streamingLine = null;
            var safeText = (text === undefined || text === null) ? '' : String(text);
            safeText.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').forEach(function (lineText) {
                var line = document.createElement('div');
                line.className = 'weline-sse-terminal-line ' + (type || 'info');

                var time = document.createElement('span');
                time.className = 'weline-sse-terminal-time';
                time.textContent = '[' + formatTime() + ']';
                line.appendChild(time);

                var textEl = document.createElement('span');
                textEl.className = 'weline-sse-terminal-text';
                textEl.textContent = lineText;
                line.appendChild(textEl);

                terminalContent.appendChild(line);
            });

            if (terminalBody) {
                terminalBody.scrollTop = terminalBody.scrollHeight;
            }
        }

        function appendChunkDom(text) {
            if (!text) {
                return;
            }

            if (!streamingLine) {
                streamingLine = document.createElement('div');
                streamingLine.className = 'weline-sse-terminal-line weline-sse-terminal-streaming chunk';

                var time = document.createElement('span');
                time.className = 'weline-sse-terminal-time';
                time.textContent = '[' + formatTime() + ']';
                streamingLine.appendChild(time);

                var textEl0 = document.createElement('span');
                textEl0.className = 'weline-sse-terminal-text';
                streamingLine.appendChild(textEl0);

                terminalContent.appendChild(streamingLine);
            }

            var textEl = streamingLine.querySelector('.weline-sse-terminal-text') || streamingLine.lastChild;
            if (textEl) {
                textEl.textContent += text;
            }

            if (terminalBody) {
                terminalBody.scrollTop = terminalBody.scrollHeight;
            }
        }

        function flushChunkRaf() {
            chunkRafScheduled = false;
            var batch = chunkRafPending;
            chunkRafPending = '';
            if (batch) {
                appendChunkDom(batch);
            }
        }

        function appendChunk(text) {
            var safeText = (text === undefined || text === null) ? '' : String(text);
            if (!safeText) {
                return;
            }

            chunkRafPending += safeText;
            if (!chunkRafScheduled) {
                chunkRafScheduled = true;
                requestAnimationFrame(flushChunkRaf);
            }
        }

        function parsePayload(event) {
            if (!event || typeof event.data !== 'string' || event.data === '') {
                return {};
            }

            try {
                return JSON.parse(event.data);
            } catch (err) {
                return { message: event.data };
            }
        }

        function payloadToMessage(payload, fallbackMessage) {
            if (payload && typeof payload.message === 'string' && payload.message !== '') {
                return payload.message;
            }
            if (payload && typeof payload.content === 'string' && payload.content !== '') {
                return payload.content;
            }
            return fallbackMessage || '';
        }

        function stop() {
            if (eventSource) {
                var currentEventSource = eventSource;
                eventSource = null;
                currentEventSource.close();
            }

            running = false;
            setStatus(messages.disconnected);
            if (typeof callbacks.stop === 'function') {
                callbacks.stop();
            }
        }

        function dispatch(eventName, payload) {
            if (eventName === 'chunk') {
                var chunkMessage = payloadToMessage(payload, '');
                if (chunkMessage) {
                    if (typeof callbacks.chunk === 'function') {
                        callbacks.chunk({ data: JSON.stringify(payload || {}) });
                    } else {
                        appendChunk(chunkMessage);
                    }
                }
                return;
            }

            if (typeof callbacks[eventName] === 'function') {
                callbacks[eventName]({ data: JSON.stringify(payload || {}) });
                return;
            }

            var fallbackMessage = eventName === 'error' ? messages.connectionFailed : eventName;
            var message = payloadToMessage(payload, fallbackMessage);
            if (message) {
                appendLine(message, eventName === 'error' ? 'error' : eventName);
            }
        }

        return {
            start: function (url) {
                if (url) {
                    currentUrl = url;
                }
                if (!currentUrl || running) {
                    return;
                }

                running = true;
                setStatus(messages.connecting);
                appendLine(messages.connecting, 'info');
                eventSource = new EventSource(currentUrl);

                eventSource.onopen = function () {
                    setStatus(messages.connected);
                    appendLine(messages.connected, 'success');
                    if (typeof callbacks.open === 'function') {
                        callbacks.open();
                    }
                };

                ['start', 'progress', 'chunk', 'warning', 'info', 'done', 'error'].forEach(function (eventName) {
                    eventSource.addEventListener(eventName, function (event) {
                        var payload = parsePayload(event);
                        dispatch(eventName, payload);
                        if (eventName === 'done' || eventName === 'error') {
                            stop();
                        }
                    });
                });

                eventSource.onerror = function () {
                    if (!running) {
                        return;
                    }

                    dispatch('error', { message: messages.connectionFailed });
                    stop();
                };
            },
            stop: stop,
            clear: function () {
                terminalContent.innerHTML = '';
                streamingLine = null;
                chunkRafPending = '';
                chunkRafScheduled = false;
            },
            log: function (text, type) {
                appendLine(text, type || 'info');
            },
            setUrl: function (url) {
                currentUrl = url;
            },
            getUrl: function () {
                return currentUrl;
            },
            isRunning: function () {
                return running;
            },
            on: function (eventName, callback) {
                callbacks[eventName] = callback;
            }
        };
    }

    function resolveTerminal() {
        if (window.WelineSseTerminal && window.WelineSseTerminal['site-builder-agent-terminal']) {
            return window.WelineSseTerminal['site-builder-agent-terminal'];
        }

        if (!fallbackTerminal) {
            fallbackTerminal = createFallbackTerminal();
        }

        return fallbackTerminal;
    }

    function finalizeTerminalRun() {
        if (startBtn) {
            startBtn.disabled = false;
        }
        terminalUnlocked = true;
    }

    function parseTerminalPayload(event) {
        if (!event || typeof event.data !== 'string' || event.data === '') {
            return null;
        }

        try {
            return JSON.parse(event.data);
        } catch (err) {
            return null;
        }
    }

    function ensureTerminal() {
        terminal = resolveTerminal();
        if (!terminal) {
            return null;
        }
        if (terminalEventsBound && terminalBoundTarget === terminal) {
            return terminal;
        }

        terminal.on('done', function (event) {
            var payload = parseTerminalPayload(event);
            finalizeTerminalRun();
            if (payload && payload.message) {
                terminal.log(payload.message, 'done');
            }
            if (payload && payload.success && !nextStepTriggered) {
                nextStepTriggered = true;
                toast('success', messages.nextStepPreparing);
                createWorkspaceAndGoToNextStep(payload).catch(function (error) {
                    nextStepTriggered = false;
                    toast('error', error && error.message ? error.message : messages.nextStepFailed);
                });
            }
        });

        terminal.on('error', function (event) {
            var payload = parseTerminalPayload(event);
            finalizeTerminalRun();
            if (payload && payload.message) {
                terminal.log(payload.message, 'error');
            }
        });

        terminalEventsBound = true;
        terminalBoundTarget = terminal;
        return terminal;
    }

    if (useAiToggle) {
        useAiToggle.addEventListener('change', syncModeUi);
        syncModeUi();
    }

    hydrateQuickBuildRegistrarOptions();

    window.handleQuickBuildRegistrarSelect = function () {
        resetRecommendationAfterRegistrarChange();
    };

    if (accountValueInput) {
        accountValueInput.addEventListener('change', resetRecommendationAfterRegistrarChange);
    }

    if (domainInput) {
        domainInput.addEventListener('input', resetRecommendationAfterManualDomainChange);
        domainInput.addEventListener('input', scheduleManualDomainCheck);
        domainInput.addEventListener('blur', function () {
            requestManualDomainAvailability({ showLoading: true, silent: true });
        });
    }

    if (recommendDomainBtn) {
        recommendDomainBtn.addEventListener('click', requestAiDomainRecommendation);
    }

    bindCreateButton(createWorkspaceBtn);
    bindCreateButton(inlineCreateWorkspaceBtn);
    document.querySelectorAll('.site-create-session-btn').forEach(bindCreateButton);
    document.querySelectorAll('[data-recent-session-delete="1"]').forEach(function (button) {
        button.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            deleteRecentSession(button.getAttribute('data-public-id') || '');
        });
    });

    if (!startBtn) {
        return;
    }

    startBtn.addEventListener('click', async function () {
        var formState = readFormState();
        nextStepTriggered = false;

        if (!formState.useAi) {
            if (!formState.domain) {
                toast('warning', messages.domainRequired);
                return;
            }
            if (!formState.accountId) {
                toast('warning', messages.registrarRequired);
                return;
            }
        } else if (!formState.description && !formState.domain) {
            toast('warning', messages.briefRequired);
            return;
        }

        if (formState.domain) {
            var preflightCheck = await requestManualDomainAvailability({
                showLoading: true,
                silent: false,
                force: true,
                enforceAccount: true
            });
            if (!preflightCheck.checked || !preflightCheck.available) {
                toast('warning', messages.startCheckFailed);
                return;
            }
        }

        var activeTerminal = ensureTerminal();
        if (!activeTerminal) {
            toast('warning', messages.terminalLoading);
            return;
        }

        var finalDescription = formState.description || formState.domain;
        var separator = startSseUrl.indexOf('?') >= 0 ? '&' : '?';
        var url = startSseUrl + separator + 'description=' + encodeURIComponent(finalDescription)
            + '&domain=' + encodeURIComponent(formState.domain)
            + '&account_id=' + encodeURIComponent(formState.accountId > 0 ? String(formState.accountId) : '')
            + '&use_ai=' + (formState.useAi ? '1' : '0');
        if (fakeMode) {
            url += '&fake_mode=1';
        }

        if (terminalUnlocked) {
            activeTerminal.clear();
            activeTerminal.log(messages.loadingLog, 'info');
            terminalUnlocked = false;
        }

        activeTerminal.setUrl(url);
        startBtn.disabled = true;
        activeTerminal.start(url);

        var terminalWrap = document.getElementById('site-builder-agent-terminal');
        if (terminalWrap && typeof terminalWrap.scrollIntoView === 'function') {
            terminalWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
})();
</script>
