    function normalizeDomain(value) {
        return String(value || '').trim().toLowerCase();
    }

    function clearManualCheckCache() {
        manualCheckCache = {
            domain: '',
            accountId: 0,
            available: null
        };
    }

    function resetRecommendationAfterRegistrarChange() {
        if (!lastRecommendedDomain) {
            clearManualCheckCache();
            return;
        }

        lastRecommendedDomain = '';
        setRecommendationState('info', messages.recommendRegistrarChanged);
        clearManualCheckCache();
    }

    function resetRecommendationAfterManualDomainChange() {
        if (!lastRecommendedDomain || !domainInput) {
            return;
        }

        var currentDomain = domainInput.value ? domainInput.value.trim().toLowerCase() : '';
        if (currentDomain === '' || currentDomain === lastRecommendedDomain) {
            return;
        }

        lastRecommendedDomain = '';
        setRecommendationState('info', messages.recommendDomainChanged);
        clearManualCheckCache();
    }

    function requestManualDomainAvailability(options) {
        var resolvedOptions = options || {};
        var showLoading = resolvedOptions.showLoading !== false;
        var silent = resolvedOptions.silent === true;
        var force = resolvedOptions.force === true;
        var enforceAccount = resolvedOptions.enforceAccount === true;
        var formState = readFormState();
        var normalizedDomain = normalizeDomain(formState.domain);

        if (!normalizedDomain) {
            clearManualCheckCache();
            return Promise.resolve({ checked: false, available: false, reason: 'empty-domain' });
        }
        if (!force && normalizedDomain === lastRecommendedDomain) {
            return Promise.resolve({ checked: false, available: true, reason: 'ai-recommended-domain' });
        }
        if (formState.accountId <= 0) {
            clearManualCheckCache();
            if (!silent || enforceAccount) {
                setRecommendationState('warning', messages.manualCheckNeedsRegistrar);
                toast('warning', enforceAccount ? messages.startCheckNeedsRegistrar : messages.manualCheckNeedsRegistrar);
            }
            return Promise.resolve({ checked: false, available: false, reason: 'missing-account' });
        }
        if (!checkDomainUrl) {
            if (!silent) {
                setRecommendationState('error', messages.networkError);
                toast('error', messages.networkError);
            }
            return Promise.resolve({ checked: false, available: false, reason: 'missing-endpoint' });
        }
        if (!force
            && manualCheckCache.domain === normalizedDomain
            && manualCheckCache.accountId === formState.accountId
            && typeof manualCheckCache.available === 'boolean') {
            return Promise.resolve({
                checked: true,
                available: manualCheckCache.available,
                reason: 'cache'
            });
        }

        if (showLoading) {
            setRecommendationState('info', messages.manualCheckLoading);
        }

        var fd = new FormData();
        fd.append('domain', normalizedDomain);
        fd.append('account_id', String(formState.accountId));
        if (fakeMode) {
            fd.append('fake_mode', '1');
        }

        return fetch(checkDomainUrl, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        }).then(function (data) {
            var available = !!(data && data.success && data.available);
            manualCheckCache = {
                domain: normalizedDomain,
                accountId: formState.accountId,
                available: available
            };

            if (available) {
                setRecommendationState('success', (data && data.message) ? data.message : messages.manualCheckAvailable.replace('%{1}', normalizedDomain));
                return { checked: true, available: true, data: data };
            }

            setRecommendationState('warning', (data && data.message) ? data.message : messages.manualCheckUnavailable.replace('%{1}', normalizedDomain));
            if (!silent) {
                toast('warning', (data && data.message) ? data.message : messages.manualCheckUnavailable.replace('%{1}', normalizedDomain));
            }
            return { checked: true, available: false, data: data };
        }).catch(function () {
            clearManualCheckCache();
            if (!silent) {
                setRecommendationState('error', messages.networkError);
                toast('error', messages.networkError);
            }
            return { checked: false, available: false, reason: 'network-error' };
        });
    }

    function scheduleManualDomainCheck() {
        if (manualDomainCheckTimer) {
            clearTimeout(manualDomainCheckTimer);
        }
        manualDomainCheckTimer = setTimeout(function () {
            requestManualDomainAvailability({ showLoading: false, silent: true });
        }, 450);
    }

    function requestAiDomainRecommendation() {
        var formState = readFormState();
        var useSimulatedDomain = !!(simulateDomainToggle && simulateDomainToggle.checked);

        if (useSimulatedDomain) {
            if (domainInput) {
                domainInput.value = 'weline-dev.local';
            }
            lastRecommendedDomain = 'weline-dev.local';
            setRecommendationState(
                'success',
                messages.simulatedDomainRecommended.replace('%{1}', 'weline-dev.local'),
                '<span class="text-muted">' + escapeHtml(messages.checkedCandidatesLabel + ': weline-dev.local ' + messages.recommendationAvailable) + '</span>'
            );
            clearManualCheckCache();
            return;
        }

        if (!formState.accountId) {
            setRecommendationState('warning', messages.recommendNeedsRegistrar);
            toast('warning', messages.recommendNeedsRegistrar);
            return;
        }

        if (!formState.description && !formState.domain) {
            setRecommendationState('warning', messages.briefRequired);
            toast('warning', messages.briefRequired);
            return;
        }

        if (!recommendDomainSseUrl && !recommendDomainUrl) {
            toast('error', messages.networkError);
            return;
        }

        if (recommendDomainEventSource) {
            recommendDomainEventSource.close();
            recommendDomainEventSource = null;
        }

        if (recommendDomainBtn) {
            recommendDomainBtn.disabled = true;
        }
        setRecommendationState('info', messages.recommendLoading);
        var checkedAggregate = [];
        var recommended = false;
        var sseUrl = new URL(recommendDomainSseUrl || recommendDomainUrl, window.location.origin);
        sseUrl.searchParams.set('description', formState.description);
        sseUrl.searchParams.set('domain', formState.domain);
        sseUrl.searchParams.set('account_id', formState.accountId > 0 ? String(formState.accountId) : '0');
        if (fakeMode) {
            sseUrl.searchParams.set('fake_mode', '1');
        }

        try {
            recommendDomainEventSource = new EventSource(sseUrl.toString(), { withCredentials: true });
        } catch (e) {
            lastRecommendedDomain = '';
            setRecommendationState('error', messages.networkError);
            toast('error', messages.networkError);
            if (recommendDomainBtn) {
                recommendDomainBtn.disabled = false;
            }
            return;
        }

        function finalizeStream() {
            if (recommendDomainEventSource) {
                recommendDomainEventSource.close();
                recommendDomainEventSource = null;
            }
            if (recommendDomainBtn) {
                recommendDomainBtn.disabled = false;
            }
        }

        recommendDomainEventSource.addEventListener('batch', function (event) {
            try {
                var data = event && event.data ? JSON.parse(event.data) : {};
                if (Array.isArray(data.checked_results)) {
                    checkedAggregate = data.checked_results;
                }
                setRecommendationState(
                    'info',
                    (data && data.message) ? data.message : messages.recommendLoading,
                    buildRecommendationDetails({
                        checked_results: checkedAggregate,
                        candidate_domains: data.candidate_domains || []
                    })
                );
            } catch (e) {
            }
        });

        recommendDomainEventSource.addEventListener('success', function (event) {
            try {
                var data = event && event.data ? JSON.parse(event.data) : {};
                recommended = true;
                if (data && data.domain && domainInput) {
                    domainInput.value = String(data.domain);
                    lastRecommendedDomain = String(data.domain).trim().toLowerCase();
                }
                setRecommendationState(
                    'success',
                    (data && data.message) ? data.message : (data.domain || ''),
                    buildRecommendationDetails(data)
                );
            } catch (e) {
            }
            finalizeStream();
        });

        recommendDomainEventSource.addEventListener('done', function (event) {
            if (recommended) {
                finalizeStream();
                return;
            }
            try {
                var data = event && event.data ? JSON.parse(event.data) : {};
                lastRecommendedDomain = '';
                setRecommendationState(
                    'warning',
                    (data && data.message) ? data.message : messages.recommendUnavailable,
                    buildRecommendationDetails(data)
                );
            } catch (e) {
                lastRecommendedDomain = '';
                setRecommendationState('warning', messages.recommendUnavailable);
            }
            finalizeStream();
        });

        recommendDomainEventSource.addEventListener('error', function () {
            if (recommended) {
                finalizeStream();
                return;
            }
            lastRecommendedDomain = '';
            setRecommendationState('error', messages.networkError);
            toast('error', messages.networkError);
            finalizeStream();
        });
    }

