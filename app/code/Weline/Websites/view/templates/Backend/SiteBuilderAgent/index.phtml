        return {
            description: descInput && descInput.value ? descInput.value.trim() : '',
            domain: domainInput && domainInput.value ? domainInput.value.trim() : '',
            accountId: getRegistrarAccountId(),
            useAi: useAiToggle ? !!useAiToggle.checked : true
        };
