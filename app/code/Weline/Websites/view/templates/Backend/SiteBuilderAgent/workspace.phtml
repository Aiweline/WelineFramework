    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(message);
        }
    }

    function confirmAction(message, onConfirm) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(message).then(function (confirmed) {
                if (confirmed) {
                    onConfirm();
                }
            });
            return;
        }
        toast('error', messages.confirmUnavailable);
    }

    function toSameOriginRequestPath(rawUrl) {
        if (!rawUrl) {
            return rawUrl;
        }
        try {
            if (String(rawUrl).indexOf('://') >= 0) {
                var pu = new URL(String(rawUrl), window.location.origin);
                return pu.pathname + (pu.search || '');
            }
        } catch (toOriginPathErr) {
            return rawUrl;
        }
        return rawUrl;
    }

    function postForm(url, fields) {
        var fd = new FormData();
        Object.keys(fields || {}).forEach(function (key) {
            fd.append(key, fields[key]);
        });

        return fetch(toSameOriginRequestPath(url), {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        });
    }

    function removeRecentSessionCard(publicId) {
        if (!publicId) {
            return;
        }
        document.querySelectorAll('[data-recent-session-item="1"]').forEach(function (node) {
            if ((node.getAttribute('data-public-id') || '') === publicId) {
                node.remove();
            }
        });
        var list = document.getElementById('site-builder-recent-session-list');
        if (list && list.children.length === 0) {
            var empty = document.createElement('div');
            empty.className = 'wb-empty';
            empty.textContent = '<?= addslashes((string)__('暂无其他最近会话。')) ?>';
            list.replaceWith(empty);
        }
    }

    function deleteRecentSession(publicId) {
        if (!deleteSessionUrl || !publicId) {
            toast('error', messages.deleteSessionFailed);
            return;
        }
        confirmAction(messages.deleteSessionConfirm, function () {
            postForm(deleteSessionUrl, { public_id: publicId }).then(function (data) {
                if (data && data.success) {
                    removeRecentSessionCard(publicId);
                    toast('success', data.message || messages.deleteSessionSuccess);
                    return;
                }
                toast('error', (data && data.message) ? data.message : messages.deleteSessionFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var workspaceBusy = false;
    function setWorkspaceBusy(flag) {
        workspaceBusy = !!flag;
        document.querySelectorAll('#site-builder-workspace-root button').forEach(function (button) {
            button.disabled = workspaceBusy;
