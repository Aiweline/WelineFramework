                    <?php if ($provider_tools === []) { ?><div class="wb-empty"><lang>当前 provider 还没有声明额外工具。</lang></div><?php } else { ?>
                        <div class="wb-list">
                            <?php foreach ($provider_tools as $tool) {
                                $toolType = (string)($tool['type'] ?? 'link');
                                $toolTarget = (string)($tool['target'] ?? '_self');
                                $toolPatchJson = '{}';
                                try { $toolPatchJson = (string)\json_encode($tool['scope_patch'] ?? [], JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR); } catch (\JsonException) {}
                                ?>
                                <div class="wb-tool">
                                    <div><strong><?= htmlspecialchars((string)($tool['label'] ?? ''), ENT_QUOTES, 'UTF-8') ?></strong><p class="mb-0 text-muted small"><?= htmlspecialchars((string)($tool['description'] ?? ''), ENT_QUOTES, 'UTF-8') ?></p></div>
                                    <?php if ($toolType === 'link') { ?><a class="btn btn-sm <?= htmlspecialchars((string)($tool['button_class'] ?? 'btn-outline-secondary'), ENT_QUOTES, 'UTF-8') ?>" href="<?= htmlspecialchars((string)($tool['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" target="<?= htmlspecialchars($toolTarget, ENT_QUOTES, 'UTF-8') ?>" <?= $toolTarget === '_blank' ? 'rel="noopener"' : '' ?>><lang>打开</lang></a><?php } else { ?><button type="button" class="btn btn-sm <?= htmlspecialchars((string)($tool['button_class'] ?? 'btn-outline-primary'), ENT_QUOTES, 'UTF-8') ?> site-builder-provider-tool" data-tool-code="<?= htmlspecialchars((string)($tool['code'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" data-tool-stage="<?= htmlspecialchars((string)($tool['stage'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" data-tool-patch="<?= htmlspecialchars($toolPatchJson, ENT_QUOTES, 'UTF-8') ?>"><lang>应用</lang></button><?php } ?>
                                </div>
                            <?php } ?>
                        </div>
                    <?php } ?>
                </div>
            </div>
        </details>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0"><h5 class="card-title mb-1"><lang>实时事件流</lang></h5></div>
            <div class="card-body p-0">
                <div class="px-4 pt-3"><button type="button" class="btn btn-primary btn-sm mb-3" id="site-builder-start-sse"><lang>连接事件流</lang></button></div>
                <w:theme:sse-terminal id="site-builder-workspace-terminal" path="site_builder_sse_path" title="site_builder_sse_title" height="260px" events="start,snapshot,log,done,error,warning,info" />
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0"><h5 class="card-title mb-1"><lang>最近工作区</lang></h5></div>
            <div class="card-body p-4">
                <?php if ($recent_sessions === []) { ?><div class="wb-empty"><lang>暂无其他最近会话。</lang></div><?php } else { ?><div class="wb-list"><?php foreach ($recent_sessions as $recent) { ?><a class="wb-link" href="<?= htmlspecialchars((string)($recent['workspace_url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"><strong><?= htmlspecialchars((string)($recent['provider_name'] ?? ''), ENT_QUOTES, 'UTF-8') ?></strong><span><?= htmlspecialchars((string)($recent['stage_label'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span><small><?= htmlspecialchars((string)($recent['summary'] ?? ''), ENT_QUOTES, 'UTF-8') ?></small></a><?php } ?></div><?php } ?>
            </div>
        </div>

        <details class="mt-3">
            <summary class="wb-summary-link"><lang>查看最近事件</lang></summary>
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-4">
                    <?php if ($events === []) { ?><div class="wb-empty"><lang>暂无事件。</lang></div><?php } else { ?><div class="wb-list"><?php foreach ($events as $event) { ?><div class="wb-event"><div class="wb-head"><strong><?= htmlspecialchars((string)($event['event_type'] ?? ''), ENT_QUOTES, 'UTF-8') ?></strong><span><?= htmlspecialchars((string)($event['create_time'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span></div><div class="wb-code"><?= htmlspecialchars((string)\json_encode($event['payload'] ?? [], JSON_UNESCAPED_UNICODE), ENT_QUOTES, 'UTF-8') ?></div></div><?php } ?></div><?php } ?>
                </div>
            </div>
        </details>
    </div>
</div>

<style>
