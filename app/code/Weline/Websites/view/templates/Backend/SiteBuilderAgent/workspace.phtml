                { redirectToProviderOnGenerate: true }
            ).catch(function (error) {
                toast('error', error && error.message ? error.message : messages.applyRecommendationFailed);
            }).finally(function () {
                applyStageBtn.disabled = false;
            });
        });
    }

    var goBackBtn = document.getElementById('site-builder-go-back-stage');
    if (goBackBtn) {
        goBackBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            var stage = (goBackBtn.getAttribute('data-stage') || '').trim();
            if (!stage) {
                return;
            }

            postForm(setStageUrl, {
                public_id: publicId,
                stage: stage
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.returnedToPreviousStage);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.stageUpdateFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var saveStageBtn = document.getElementById('site-builder-save-stage');
    var stageSelect = document.getElementById('site-builder-stage');
    if (saveStageBtn && stageSelect) {
        saveStageBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            postForm(setStageUrl, {
                public_id: publicId,
                stage: stageSelect.value
            }).then(function (data) {
                if (data && data.success) {
                    var stageLabel = document.getElementById('site-builder-current-stage');
                    if (stageLabel) {
                        stageLabel.textContent = data.stage_label || data.stage || stageSelect.value;
                    }
                    toast('success', messages.stageUpdated);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.stageUpdateFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var addMessageBtn = document.getElementById('site-builder-add-message');
    var messageInput = document.getElementById('site-builder-message');
    if (addMessageBtn && messageInput) {
        addMessageBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            var content = messageInput.value.trim();
            if (!content) {
                toast('warning', messages.messageRequired);
                return;
            }

            postForm(appendMessageUrl, {
                public_id: publicId,
                content: content,
                role: 'user',
                message_type: 'note'
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.noteSaved);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.noteSaveFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var replaceScopeBtn = document.getElementById('site-builder-replace-scope');
    var mergeScopeBtn = document.getElementById('site-builder-merge-scope');
    var fullScopeEl = document.getElementById('site-builder-scope-full');
    var patchScopeEl = document.getElementById('site-builder-scope-patch');

    if (replaceScopeBtn && fullScopeEl) {
        replaceScopeBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            postForm(replaceScopeUrl, {
                public_id: publicId,
                scope: fullScopeEl.value
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.scopeReplaced);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.scopeReplaceFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    if (mergeScopeBtn && patchScopeEl) {
        mergeScopeBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            postForm(mergeScopeUrl, {
                public_id: publicId,
                scope_patch: patchScopeEl.value
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.patchMerged);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.patchMergeFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    document.querySelectorAll('.site-builder-provider-tool').forEach(function (button) {
        button.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            var patch = {};

            try {
                patch = JSON.parse(button.getAttribute('data-tool-patch') || '{}');
            } catch (error) {
                toast('error', messages.toolPatchBroken);
                return;
            }

            button.disabled = true;
            applyScopeThenMaybeStage(
                patch,
                (button.getAttribute('data-tool-stage') || '').trim(),
                messages.toolApplied,
                { redirectToProviderOnGenerate: true }
            ).catch(function (error) {
                toast('error', error && error.message ? error.message : messages.toolApplyFailed);
            }).finally(function () {
                button.disabled = false;
            });
        });
    });

    var reloadBtn = document.getElementById('site-builder-reload-page');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            window.location.reload();
        });
    }

    var sseBtn = document.getElementById('site-builder-start-sse');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['site-builder-workspace-terminal'] : null;
    if (sseBtn && terminal) {
        var terminalTitleEl = document.querySelector('#site-builder-workspace-terminal .weline-sse-terminal-title-text');
        var terminalCardTitleEl = sseBtn.closest('.card') ? sseBtn.closest('.card').querySelector('.card-title') : null;
        if (terminalTitleEl && terminalCardTitleEl && terminalCardTitleEl.textContent) {
            terminalTitleEl.textContent = terminalCardTitleEl.textContent.trim();
        }
        sseBtn.textContent = messages.streamReconnect;

        function resolveWorkspacePublicId() {
            // 后台工作区 URL 以 query 参数携带 public_id，不能再从路径首段猜测。
            var searchParams = new URLSearchParams(window.location.search || '');
            var queryPublicId = (searchParams.get('public_id') || '').trim();
            if (queryPublicId) {
                return queryPublicId;
            }
            return typeof publicId === 'string' ? publicId.trim() : '';
        }

        function buildWorkspaceStreamUrl() {
            var resolvedPublicId = resolveWorkspacePublicId();
            if (!resolvedPublicId || !streamBaseUrl) {
                return '';
            }
            try {
                var requestUrl = new URL(streamBaseUrl, window.location.origin);
                requestUrl.searchParams.set('public_id', resolvedPublicId);
                requestUrl.searchParams.set('last_event_id', String(lastEventId));
                // 使用 path+query，与当前页同源，避免 E2E 代理下绝对 URL 偶发导致 EventSource 不带 Cookie（adminId=0）
                return requestUrl.pathname + (requestUrl.search || '');
            } catch (error) {
                var separator = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
                return streamBaseUrl + separator + 'public_id=' + encodeURIComponent(resolvedPublicId)
                    + '&last_event_id=' + encodeURIComponent(String(lastEventId));
            }
        }

        function formatWorkspaceTerminalLog(entry) {
            var payload = entry && entry.payload && typeof entry.payload === 'object' ? entry.payload : {};
            var stageLabel = payload.stage_label || payload.stage || entry.event_type || 'log';
            var message = payload.message || entry.event_type || '';
            return stageLabel ? (stageLabel + ': ' + message) : message;
        }

        function scheduleWorkspaceReconnect() {
            if (workspaceReconnectTimer) {
                return;
            }
            if (workspaceReconnectAttempts >= workspaceReconnectAttemptsMax) {
                terminal.log(messages.streamDisconnected || '<?= __('事件流已断开，请刷新页面重试。') ?>', 'error');
                return;
            }
            workspaceReconnectAttempts++;
            workspaceReconnectTimer = window.setTimeout(function () {
                workspaceReconnectTimer = null;
                if (!terminal.isRunning()) {
                    var reconnectUrl = buildWorkspaceStreamUrl();
                    if (!reconnectUrl) {
                        terminal.log(messages.streamSessionMissing || '<?= __('无法解析当前工作区会话，请刷新页面后重试。') ?>', 'error');
                        return;
                    }
                    terminal.setUrl(reconnectUrl);
                    terminal.start(reconnectUrl);
                }
            }, 1500);
        }

        terminal.on('snapshot', function (event) {
            var data = parseSsePayload(event);
            if (data && data.domain_purchase && typeof data.domain_purchase === 'object') {
                updateDomainPurchaseUi(data.domain_purchase);
            }
            if (Array.isArray(data.events)) {
                data.events.forEach(function (entry) {
                    if (isDomainPurchaseEventEntry(entry)) {
                        appendDomainLogEntry(entry);
                        syncDomainPurchaseStateFromPayload(entry.payload || {});
                    }
                });
            }
        });

        terminal.on('log', function (event) {
            var entry = parseSsePayload(event);
            if (!entry || typeof entry !== 'object') {
                return;
            }
            var eventId = parseInt(entry.event_id || 0, 10) || 0;
            if (eventId > 0 && workspaceLogIdMap[String(eventId)]) {
                return;
            }
            if (eventId > 0) {
                workspaceLogIdMap[String(eventId)] = true;
            }
            if (eventId > lastEventId) {
                lastEventId = eventId;
            }
            if (isDomainPurchaseEventEntry(entry)) {
                appendDomainLogEntry(entry);
                syncDomainPurchaseStateFromPayload(entry.payload || {});
            }
            terminal.log(formatWorkspaceTerminalLog(entry), entry.level || 'info');
        });

        terminal.on('start', function (event) {
            var data = parseSsePayload(event);
            terminal.log((data.message || messages.streamConnected), 'start');
            sseBtn.disabled = true;
            workspaceReconnectAttempts = 0;
        });

        terminal.on('done', function (event) {
            var data = parseSsePayload(event);
            if (data && data.last_event_id) {
                lastEventId = parseInt(data.last_event_id, 10) || lastEventId;
            }
            // done 表示流正常结束，重置重试计数即可，不应该触发重连
            workspaceReconnectAttempts = 0;
            terminal.log((data.message || messages.streamDisconnected), 'done');
            sseBtn.disabled = false;
            // 不调用 scheduleWorkspaceReconnect()，done 是正常结束
        });

        terminal.on('error', function (event) {
            var data = parseSsePayload(event);
            var hasPayload = !!(event && typeof event.data === 'string' && event.data !== '');
            if (hasPayload) {
                terminal.log((data.message || messages.streamDisconnected), 'error');
                sseBtn.disabled = false;
                // 会话不存在或参数无效属于业务错误，不应继续自动重连
                var errMsg = data && (data.message || '');
                if (typeof errMsg === 'string' && (errMsg.indexOf('会话不存在') >= 0 || errMsg.indexOf('session') >= 0 || errMsg.indexOf('无效') >= 0)) {
                    workspaceReconnectAttempts = 0;
                    return;
                }
            }
            sseBtn.disabled = false;
            scheduleWorkspaceReconnect();
        });

        sseBtn.addEventListener('click', function () {
            if (workspaceBusy) {
                toast('warning', messages.workspaceBusy);
                return;
            }
            var manualStreamUrl = buildWorkspaceStreamUrl();
            if (!manualStreamUrl) {
                terminal.log(messages.streamSessionMissing || '<?= __('无法解析当前工作区会话，请刷新页面后重试。') ?>', 'error');
                return;
            }
            terminal.setUrl(manualStreamUrl);
            terminal.start(manualStreamUrl);
            sseBtn.disabled = true;
        });

        var initialStreamUrl = buildWorkspaceStreamUrl();
        if (initialStreamUrl) {
            terminal.setUrl(initialStreamUrl);
            terminal.start(initialStreamUrl);
            sseBtn.disabled = true;
        } else {
            terminal.log(messages.streamSessionMissing || '<?= __('无法解析当前工作区会话，请刷新页面后重试。') ?>', 'error');
            sseBtn.disabled = false;
        }
    }

    if (currentStageCode === 'generate' && (!virtualThemeAutoGenerated || virtualThemeSeedEmpty)) {
        startVirtualThemeAiGeneration();
    }
})();
</script>
