<script>
(function () {
    'use strict';

    var publicId = <?= json_encode($publicId, JSON_THROW_ON_ERROR) ?>;
    var mergeScopeUrl = <?= json_encode($merge_scope_url, JSON_THROW_ON_ERROR) ?>;
    var replaceScopeUrl = <?= json_encode($replace_scope_url, JSON_THROW_ON_ERROR) ?>;
    var setStageUrl = <?= json_encode($set_stage_url, JSON_THROW_ON_ERROR) ?>;
    var appendMessageUrl = <?= json_encode($append_message_url, JSON_THROW_ON_ERROR) ?>;
    var streamBaseUrl = <?= json_encode((string)$this->getBackendUrl($site_builder_sse_path), JSON_THROW_ON_ERROR) ?>;
    var lastEventId = <?= (int)$last_event_id ?>;

    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(message);
        }
    }

    function postForm(url, fields) {
        var fd = new FormData();
        Object.keys(fields).forEach(function (key) { fd.append(key, fields[key]); });
        return fetch(url, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (r) { return r.json(); });
    }

    var saveStageBtn = document.getElementById('site-builder-save-stage');
    var stageSelect = document.getElementById('site-builder-stage');
    if (saveStageBtn && stageSelect) {
        saveStageBtn.addEventListener('click', function () {
            postForm(setStageUrl, { public_id: publicId, stage: stageSelect.value }).then(function (data) {
                if (data && data.success) {
                    var stageLabel = document.getElementById('site-builder-current-stage');
                    if (stageLabel) stageLabel.textContent = data.stage || stageSelect.value;
                    toast('success', <?= json_encode((string)__('阶段已更新'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('更新阶段失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                toast('error', <?= json_encode((string)__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var saveSummaryBtn = document.getElementById('site-builder-save-summary');
    if (saveSummaryBtn) {
        saveSummaryBtn.addEventListener('click', function () {
            var patch = {
                site_title: document.getElementById('site-builder-title') ? document.getElementById('site-builder-title').value.trim() : '',
                site_tagline: document.getElementById('site-builder-tagline') ? document.getElementById('site-builder-tagline').value.trim() : '',
                brief_description: document.getElementById('site-builder-brief') ? document.getElementById('site-builder-brief').value.trim() : '',
                target_domain: document.getElementById('site-builder-domain') ? document.getElementById('site-builder-domain').value.trim() : '',
                workbench_notes: document.getElementById('site-builder-notes') ? document.getElementById('site-builder-notes').value.trim() : ''
            };
            postForm(mergeScopeUrl, { public_id: publicId, scope_patch: JSON.stringify(patch) }).then(function (data) {
                if (data && data.success) {
                    toast('success', <?= json_encode((string)__('简报已保存'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('保存简报失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                toast('error', <?= json_encode((string)__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var addMessageBtn = document.getElementById('site-builder-add-message');
    var messageInput = document.getElementById('site-builder-message');
    if (addMessageBtn && messageInput) {
        addMessageBtn.addEventListener('click', function () {
            var content = messageInput.value.trim();
            if (!content) {
                toast('warning', <?= json_encode((string)__('请先写一点内容再保存'), JSON_THROW_ON_ERROR) ?>);
                return;
            }
            postForm(appendMessageUrl, {
                public_id: publicId,
                content: content,
                role: 'user',
                message_type: 'note'
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', <?= json_encode((string)__('说明已写入工作区'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('保存消息失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                toast('error', <?= json_encode((string)__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    var replaceScopeBtn = document.getElementById('site-builder-replace-scope');
    var mergeScopeBtn = document.getElementById('site-builder-merge-scope');
    var fullScopeEl = document.getElementById('site-builder-scope-full');
    var patchScopeEl = document.getElementById('site-builder-scope-patch');

    if (replaceScopeBtn && fullScopeEl) {
        replaceScopeBtn.addEventListener('click', function () {
            postForm(replaceScopeUrl, { public_id: publicId, scope: fullScopeEl.value }).then(function (data) {
                if (data && data.success) {
                    toast('success', <?= json_encode((string)__('Scope 已整体替换'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('替换 Scope 失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                toast('error', <?= json_encode((string)__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    if (mergeScopeBtn && patchScopeEl) {
        mergeScopeBtn.addEventListener('click', function () {
            postForm(mergeScopeUrl, { public_id: publicId, scope_patch: patchScopeEl.value }).then(function (data) {
                if (data && data.success) {
                    toast('success', <?= json_encode((string)__('Patch 已合并到 Scope'), JSON_THROW_ON_ERROR) ?>);
                    window.location.reload();
                    return;
                }
                toast('error', (data && data.message) ? data.message : <?= json_encode((string)__('合并 Scope 失败'), JSON_THROW_ON_ERROR) ?>);
            }).catch(function () {
                toast('error', <?= json_encode((string)__('网络错误'), JSON_THROW_ON_ERROR) ?>);
            });
        });
    }

    document.querySelectorAll('.site-builder-provider-tool').forEach(function (button) {
        button.addEventListener('click', function () {
            var patchRaw = button.getAttribute('data-tool-patch') || '{}';
            var stage = (button.getAttribute('data-tool-stage') || '').trim();
            var patch;

            try {
                patch = JSON.parse(patchRaw);
            } catch (error) {
                toast('error', <?= json_encode((string)__('工具配置损坏，无法解析 scope patch'), JSON_THROW_ON_ERROR) ?>);
                return;
            }

            button.disabled = true;
            postForm(mergeScopeUrl, { public_id: publicId, scope_patch: JSON.stringify(patch) }).then(function (data) {
                if (!data || !data.success) {
                    throw new Error((data && data.message) ? data.message : <?= json_encode((string)__('应用工具失败'), JSON_THROW_ON_ERROR) ?>);
                }
                if (!stage) {
                    return null;
                }
                return postForm(setStageUrl, { public_id: publicId, stage: stage }).then(function (stageData) {
                    if (!stageData || !stageData.success) {
                        throw new Error((stageData && stageData.message) ? stageData.message : <?= json_encode((string)__('更新阶段失败'), JSON_THROW_ON_ERROR) ?>);
                    }
                    return stageData;
                });
            }).then(function () {
                toast('success', <?= json_encode((string)__('Provider 工具已应用到工作区'), JSON_THROW_ON_ERROR) ?>);
                window.location.reload();
            }).catch(function (error) {
                toast('error', error && error.message ? error.message : <?= json_encode((string)__('应用工具失败'), JSON_THROW_ON_ERROR) ?>);
            }).finally(function () {
                button.disabled = false;
            });
        });
    });

    var reloadBtn = document.getElementById('site-builder-reload-page');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', function () {
            window.location.reload();
        });
    }

    var sseBtn = document.getElementById('site-builder-start-sse');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['site-builder-workspace-terminal'] : null;
    if (sseBtn && terminal) {
        sseBtn.addEventListener('click', function () {
            var sep = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + sep + 'public_id=' + encodeURIComponent(publicId) + '&last_event_id=' + encodeURIComponent(String(lastEventId));
            terminal.clear();
            terminal.setUrl(url);
            sseBtn.disabled = true;
            terminal.start();
            terminal.on('done', function () { sseBtn.disabled = false; });
            terminal.on('error', function () { sseBtn.disabled = false; });
        });
    }
})();
</script>
