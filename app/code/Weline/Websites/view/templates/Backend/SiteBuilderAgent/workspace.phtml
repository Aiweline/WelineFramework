            workspaceReconnectAttempts++;
            workspaceReconnectTimer = window.setTimeout(function () {
                workspaceReconnectTimer = null;
                if (!terminal.isRunning()) {
                    var reconnectUrl = buildWorkspaceStreamUrl();
                    if (!reconnectUrl) {
