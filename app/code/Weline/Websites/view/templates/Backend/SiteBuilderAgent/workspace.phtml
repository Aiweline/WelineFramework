    // 页面类型选择模态框
    var planCompleteModal = null;
    var planCompleteModalResolve = null;

    function showPageTypeSelectionModal() {
        // 同步页面类型选择器到模态框
        var sourceChecks = document.querySelectorAll('.site-builder-page-type-check');
        var modalChecks = document.querySelectorAll('.site-builder-modal-page-type-check');
        if (sourceChecks.length > 0 && modalChecks.length > 0) {
            // 将源选择器的选中状态同步到模态框
            var sourceChecked = {};
            sourceChecks.forEach(function (check) {
                if (check.checked) {
                    sourceChecked[check.value] = true;
                }
            });
            modalChecks.forEach(function (check) {
                check.checked = !!sourceChecked[check.value];
                // 更新 label 样式
                var label = check.closest('label');
                if (label) {
                    if (check.checked) {
                        label.classList.add('is-checked');
                    } else {
                        label.classList.remove('is-checked');
                    }
                }
            });
        }

        // 显示模态框
        planCompleteModal = new bootstrap.Modal(document.getElementById('site-builder-plan-complete-modal'));
        planCompleteModal.show();

        return new Promise(function (resolve) {
            planCompleteModalResolve = resolve;
        });
    }

    // 模态框确认按钮事件
    document.addEventListener('DOMContentLoaded', function () {
        var confirmBtn = document.getElementById('site-builder-confirm-page-types');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', function () {
                // 获取选中的页面类型并同步回源选择器
                var modalChecks = document.querySelectorAll('.site-builder-modal-page-type-check');
                var sourceChecks = document.querySelectorAll('.site-builder-page-type-check');
                var selectedTypes = [];
                modalChecks.forEach(function (check) {
                    if (check.checked) {
                        selectedTypes.push(check.value);
                        // 同步到源选择器
                        sourceChecks.forEach(function (source) {
                            if (source.value === check.value) {
                                source.checked = true;
                                var label = source.closest('label');
                                if (label) {
                                    label.classList.add('is-checked');
                                }
                            }
                        });
                    } else {
                        // 取消选中的也要同步
                        sourceChecks.forEach(function (source) {
                            if (source.value === check.value) {
                                source.checked = false;
                                var label = source.closest('label');
                                if (label) {
                                    label.classList.remove('is-checked');
                                }
                            }
                        });
                    }
                });

                // 关闭模态框
                if (planCompleteModal) {
                    planCompleteModal.hide();
                    planCompleteModal = null;
                }

                // 触发下一步：自动保存简报并进入 generate 阶段生成虚拟主题
                if (planCompleteModalResolve) {
                    planCompleteModalResolve(selectedTypes);
                    planCompleteModalResolve = null;
                }

                // 自动开始生成虚拟主题
                setTimeout(function () {
                    triggerAutoGenerateVirtualTheme();
                }, 300);
            });
        }

        // 模态框取消时的处理
        var modalEl = document.getElementById('site-builder-plan-complete-modal');
        if (modalEl) {
            modalEl.addEventListener('hidden.bs.modal', function () {
                if (planCompleteModalResolve) {
                    planCompleteModalResolve(null);
                    planCompleteModalResolve = null;
                }
                planCompleteModal = null;
            });
        }
    });

    // 自动触发生成虚拟主题（保存页面类型后）
    function triggerAutoGenerateVirtualTheme() {
        // 保存页面类型并切换到 generate 阶段
        var pageTypes = getSelectedPageTypes();
        var patch = { page_types: pageTypes };

        applyScopeThenMaybeStage(
            patch,
            'generate',
            messages.recommendationApplied,
            { redirectToProviderOnGenerate: true }
        ).catch(function (error) {
            toast('error', error && error.message ? error.message : messages.applyRecommendationFailed);
        });
    }

    function startVirtualThemeAiGeneration() {
        if (!generateVirtualThemeSseBaseUrl) {
            return Promise.resolve();
        }
        var vtBase = toSameOriginRequestPath(generateVirtualThemeSseBaseUrl);
        var requestUrl = vtBase
            + (vtBase.indexOf('?') >= 0 ? '&' : '?')
            + 'public_id=' + encodeURIComponent(publicId);
        setWorkspaceBusy(true);
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(messages.virtualThemeAiStart);
        }

        return fetch(requestUrl, {
            method: 'GET',
            headers: { 'Accept': 'text/event-stream' },
            credentials: 'same-origin'
        }).then(function (response) {
            if (!response.ok || !response.body) {
                throw new Error(messages.virtualThemeAiFailed);
            }
            var reader = response.body.getReader();
            var decoder = new TextDecoder('utf-8');
            var buffer = '';

            function consumeEvent(rawEvent) {
                if (!rawEvent) {
                    return;
                }
                var lines = rawEvent.split('\n');
                var eventName = 'message';
                var dataLines = [];
                lines.forEach(function (line) {
                    if (line.indexOf('event:') === 0) {
                        eventName = line.slice(6).trim();
                    } else if (line.indexOf('data:') === 0) {
                        dataLines.push(line.slice(5).trim());
                    }
                });
                var payloadText = dataLines.join('\n');
                var payload = {};
                if (payloadText) {
                    try {
                        payload = JSON.parse(payloadText);
                    } catch (error) {
                        payload = { message: payloadText };
                    }
                }

                if (eventName === 'progress' && payload.message && window.BackendToast && typeof window.BackendToast.info === 'function') {
                    window.BackendToast.info(payload.message);
                }
                if (eventName === 'error') {
                    throw new Error(payload.message || messages.virtualThemeAiFailed);
                }
                if (eventName === 'done') {
                    if (window.BackendToast && typeof window.BackendToast.success === 'function') {
                        window.BackendToast.success(payload.message || messages.virtualThemeAiDone);
                    }
                    window.location.reload();
                }
            }

            function pump() {
                return reader.read().then(function (result) {
                    if (!result || result.done) {
                        return;
                    }
                    buffer += decoder.decode(result.value, { stream: true });
                    var eventsRaw = buffer.split('\n\n');
                    buffer = eventsRaw.pop() || '';
                    eventsRaw.forEach(consumeEvent);
                    return pump();
                });
            }

            return pump();
        }).catch(function (error) {
            if (window.BackendToast && typeof window.BackendToast.error === 'function') {
                window.BackendToast.error(error && error.message ? error.message : messages.virtualThemeAiFailed);
            }
        }).finally(function () {
            setWorkspaceBusy(false);
        });
    }

    function getLanguageSelector(selectorId) {
        if (!languageUtils || typeof languageUtils.get !== 'function') {
            return null;
        }

        return languageUtils.get(selectorId);
    }

    function compactPatch(patch) {
        var compacted = {};

        Object.keys(patch || {}).forEach(function (key) {
            var value = patch[key];

            if (Array.isArray(value)) {
                if (value.length > 0) {
                    compacted[key] = value;
                }
                return;
            }

            if (typeof value === 'number') {
                if (value > 0) {
                    compacted[key] = value;
                }
                return;
            }

            if (value !== null && value !== undefined && value !== '') {
                compacted[key] = value;
            }
        });

        return compacted;
    }

    function readSelectedRegistrarLabel() {
        var registrarInstance = window.WelineRegistrarSelect && window.WelineRegistrarSelect['site-builder-registrar-account']
            ? window.WelineRegistrarSelect['site-builder-registrar-account']
            : null;
        var registrarLabel = document.getElementById('site-builder-registrar-label');
