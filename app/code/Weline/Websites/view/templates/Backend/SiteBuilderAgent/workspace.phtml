);box-shadow:0 10px 24px rgba(15,23,42,.06)}.wb-empty{padding:1rem 1.1rem;border-radius:16px;background:#f8fafc;border:1px dashed #cbd5e1;color:#64748b}.wb-tool{display:grid;gap:.9rem}.wb-code{font-family:Consolas,Monaco,monospace;font-size:.8rem}.wb-summary-link{cursor:pointer;color:#0f766e;font-weight:700}@media (min-width:576px){.wb-tool{grid-template-columns:minmax(0,1fr) auto;align-items:center}}
</style>

<script>
(function () {
    'use strict';

    var publicId = <?= json_encode($publicId, JSON_THROW_ON_ERROR) ?>;
    var mergeScopeUrl = <?= json_encode($merge_scope_url, JSON_THROW_ON_ERROR) ?>;
    var replaceScopeUrl = <?= json_encode($replace_scope_url, JSON_THROW_ON_ERROR) ?>;
    var setStageUrl = <?= json_encode($set_stage_url, JSON_THROW_ON_ERROR) ?>;
    var appendMessageUrl = <?= json_encode($append_message_url, JSON_THROW_ON_ERROR) ?>;
    var streamBaseUrl = <?= json_encode((string)$this->getBackendUrl($site_builder_sse_path), JSON_THROW_ON_ERROR) ?>;
    var lastEventId = <?= (int)$last_event_id ?>;
    var languageUtils = window.WelineLanguageSelectUtils || null;
    var messages = {
        applyRecommendationFailed: <?= json_encode((string)__('Failed to apply recommendation'), JSON_THROW_ON_ERROR) ?>,
        stageUpdateFailed: <?= json_encode((string)__('Failed to update stage'), JSON_THROW_ON_ERROR) ?>,
        summarySaved: <?= json_encode((string)__('Summary saved'), JSON_THROW_ON_ERROR) ?>,
        summarySaveFailed: <?= json_encode((string)__('Failed to save summary'), JSON_THROW_ON_ERROR) ?>,
        recommendationApplied: <?= json_encode((string)__('AI recommendation applied'), JSON_THROW_ON_ERROR) ?>,
        recommendationDataBroken: <?= json_encode((string)__('Recommendation data is invalid'), JSON_THROW_ON_ERROR) ?>,
        returnedToPreviousStage: <?= json_encode((string)__('Returned to previous stage'), JSON_THROW_ON_ERROR) ?>,
        stageUpdated: <?= json_encode((string)__('Stage updated'), JSON_THROW_ON_ERROR) ?>,
        networkError: <?= json_encode((string)__('Network error'), JSON_THROW_ON_ERROR) ?>,
        messageRequired: <?= json_encode((string)__('Please enter a note first'), JSON_THROW_ON_ERROR) ?>,
        noteSaved: <?= json_encode((string)__('Note saved to workspace'), JSON_THROW_ON_ERROR) ?>,
        noteSaveFailed: <?= json_encode((string)__('Failed to save note'), JSON_THROW_ON_ERROR) ?>,
        scopeReplaced: <?= json_encode((string)__('Scope replaced'), JSON_THROW_ON_ERROR) ?>,
        scopeReplaceFailed: <?= json_encode((string)__('Failed to replace scope'), JSON_THROW_ON_ERROR) ?>,
        patchMerged: <?= json_encode((string)__('Patch merged into scope'), JSON_THROW_ON_ERROR) ?>,
        patchMergeFailed: <?= json_encode((string)__('Failed to merge patch'), JSON_THROW_ON_ERROR) ?>,
        toolPatchBroken: <?= json_encode((string)__('Tool scope patch is invalid'), JSON_THROW_ON_ERROR) ?>,
        toolApplied: <?= json_encode((string)__('Provider tool applied'), JSON_THROW_ON_ERROR) ?>,
        toolApplyFailed: <?= json_encode((string)__('Failed to apply provider tool'), JSON_THROW_ON_ERROR) ?>
    };

    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(message);
        }
    }

    function postForm(url, fields) {
        var fd = new FormData();
        Object.keys(fields || {}).forEach(function (key) {
            fd.append(key, fields[key]);
        });

        return fetch(url, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd,
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        });
    }

    function getLanguageSelector(selectorId) {
        if (!languageUtils || typeof languageUtils.get !== 'function') {
            return null;
        }

        return languageUtils.get(selectorId);
    }

    function compactPatch(patch) {
        var compacted = {};

        Object.keys(patch || {}).forEach(function (key) {
            var value = patch[key];

            if (Array.isArray(value)) {
                if (value.length > 0) {
                    compacted[key] = value;
                }
                return;
            }

            if (typeof value === 'number') {
                if (value > 0) {
                    compacted[key] = value;
                }
                return;
            }

            if (value !== null && value !== undefined && value !== '') {
                compacted[key] = value;
            }
        });

        return compacted;
    }

    function readSelectedRegistrarLabel() {
        var registrarSelect = document.getElementById('site-builder-registrar-account');
        var registrarLabel = document.getElementById('site-builder-registrar-label');

        if (registrarSelect && registrarSelect.value) {
            var selectedOption = registrarSelect.options[registrarSelect.selectedIndex];
            return selectedOption ? selectedOption.text.trim() : '';
        }

        return registrarLabel ? registrarLabel.value.trim() : '';
    }

    function syncRegistrarUi() {
        var registrarSelect = document.getElementById('site-builder-registrar-account');
        var registrarLabel = document.getElementById('site-builder-registrar-label');
        var registrarHelp = document.getElementById('site-builder-registrar-help');
        var registrarSidebar = document.getElementById('site-builder-registrar-sidebar');
        var label = readSelectedRegistrarLabel();

        if (registrarLabel) {
            registrarLabel.value = label;
        }
        if (registrarHelp) {
            registrarHelp.textContent = label
                ? '当前将使用：' + label
                : '如果你不确定选谁，先让 AI 推荐，再点确认就行。';
        }
        if (registrarSidebar) {
            registrarSidebar.textContent = label || '还没有推荐，确认当前阶段建议后会自动补齐。';
        }
    }

    function readSummaryPatch() {
        var defaultLanguageSelector = getLanguageSelector('site_builder_default_language_selector');
        var relatedLanguagesSelector = getLanguageSelector('site_builder_related_languages_selector');
        var registrarSelect = document.getElementById('site-builder-registrar-account');
        var registrarAccountId = registrarSelect && registrarSelect.value ? parseInt(registrarSelect.value, 10) : 0;
        var registrarLabel = readSelectedRegistrarLabel();

        return {
            site_title: document.getElementById('site-builder-title') ? document.getElementById('site-builder-title').value.trim() : '',
            site_tagline: document.getElementById('site-builder-tagline') ? document.getElementById('site-builder-tagline').value.trim() : '',
            brief_description: document.getElementById('site-builder-brief') ? document.getElementById('site-builder-brief').value.trim() : '',
            target_domain: document.getElementById('site-builder-domain') ? document.getElementById('site-builder-domain').value.trim() : '',
            workbench_notes: document.getElementById('site-builder-notes') ? document.getElementById('site-builder-notes').value.trim() : '',
            preferred_registrar_account_id: registrarAccountId,
            registrar_account_id: registrarAccountId,
            recommended_registrar_label: registrarLabel,
            default_language: defaultLanguageSelector && typeof defaultLanguageSelector.getValue === 'function' ? defaultLanguageSelector.getValue() : '',
            language_codes: relatedLanguagesSelector && typeof relatedLanguagesSelector.getValues === 'function' ? relatedLanguagesSelector.getValues() : []
        };
    }

    function applyScopeThenMaybeStage(patch, nextStage, successMessage) {
        var mergedPatch = Object.assign({}, patch || {}, compactPatch(readSummaryPatch()));

        return postForm(mergeScopeUrl, {
            public_id: publicId,
            scope_patch: JSON.stringify(mergedPatch)
        }).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) ? data.message : messages.applyRecommendationFailed);
            }

            if (!nextStage) {
                return null;
            }

            return postForm(setStageUrl, {
                public_id: publicId,
                stage: nextStage
            }).then(function (stageData) {
                if (!stageData || !stageData.success) {
                    throw new Error((stageData && stageData.message) ? stageData.message : messages.stageUpdateFailed);
                }
            });
        }).then(function () {
            toast('success', successMessage);
            window.location.reload();
        });
    }

    if (languageUtils && typeof languageUtils.bindDefaultToMultiple === 'function') {
        languageUtils.bindDefaultToMultiple({
            singleId: 'site_builder_default_language_selector',
            multipleId: 'site_builder_related_languages_selector'
        });
    }

    var registrarSelect = document.getElementById('site-builder-registrar-account');
    if (registrarSelect) {
        registrarSelect.addEventListener('change', syncRegistrarUi);
    }
    syncRegistrarUi();

    var saveSummaryBtn = document.getElementById('site-builder-save-summary');
    if (saveSummaryBtn) {
        saveSummaryBtn.addEventListener('click', function () {
            applyScopeThenMaybeStage(compactPatch(readSummaryPatch()), '', messages.summarySaved).catch(function (error) {
                toast('error', error && error.message ? error.message : messages.summarySaveFailed);
            });
        });
    }

    var applyStageBtn = document.getElementById('site-builder-apply-stage-recommendation');
    if (applyStageBtn) {
        applyStageBtn.addEventListener('click', function () {
            var patch = {};

            try {
                patch = JSON.parse(applyStageBtn.getAttribute('data-patch') || '{}');
            } catch (error) {
                toast('error', messages.recommendationDataBroken);
                return;
            }

            applyStageBtn.disabled = true;
            applyScopeThenMaybeStage(
                patch,
                (applyStageBtn.getAttribute('data-next-stage') || '').trim(),
                messages.recommendationApplied
            ).catch(function (error) {
                toast('error', error && error.message ? error.message : messages.applyRecommendationFailed);
            }).finally(function () {
                applyStageBtn.disabled = false;
            });
        });
    }

    var goBackBtn = document.getElementById('site-builder-go-back-stage');
    if (goBackBtn) {
        goBackBtn.addEventListener('click', function () {
            var stage = (goBackBtn.getAttribute('data-stage') || '').trim();
            if (!stage) {
                return;
            }

            postForm(setStageUrl, {
                public_id: publicId,
                stage: stage
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.returnedToPreviousStage);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.stageUpdateFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var saveStageBtn = document.getElementById('site-builder-save-stage');
    var stageSelect = document.getElementById('site-builder-stage');
    if (saveStageBtn && stageSelect) {
        saveStageBtn.addEventListener('click', function () {
            postForm(setStageUrl, {
                public_id: publicId,
                stage: stageSelect.value
            }).then(function (data) {
                if (data && data.success) {
                    var stageLabel = document.getElementById('site-builder-current-stage');
                    if (stageLabel) {
                        stageLabel.textContent = data.stage_label || data.stage || stageSelect.value;
                    }
                    toast('success', messages.stageUpdated);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.stageUpdateFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var addMessageBtn = document.getElementById('site-builder-add-message');
    var messageInput = document.getElementById('site-builder-message');
    if (addMessageBtn && messageInput) {
        addMessageBtn.addEventListener('click', function () {
            var content = messageInput.value.trim();
            if (!content) {
                toast('warning', messages.messageRequired);
                return;
            }

            postForm(appendMessageUrl, {
                public_id: publicId,
                content: content,
                role: 'user',
                message_type: 'note'
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.noteSaved);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.noteSaveFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    var replaceScopeBtn = document.getElementById('site-builder-replace-scope');
    var mergeScopeBtn = document.getElementById('site-builder-merge-scope');
    var fullScopeEl = document.getElementById('site-builder-scope-full');
    var patchScopeEl = document.getElementById('site-builder-scope-patch');

    if (replaceScopeBtn && fullScopeEl) {
        replaceScopeBtn.addEventListener('click', function () {
            postForm(replaceScopeUrl, {
                public_id: publicId,
                scope: fullScopeEl.value
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.scopeReplaced);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.scopeReplaceFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    if (mergeScopeBtn && patchScopeEl) {
        mergeScopeBtn.addEventListener('click', function () {
            postForm(mergeScopeUrl, {
                public_id: publicId,
                scope_patch: patchScopeEl.value
            }).then(function (data) {
                if (data && data.success) {
                    toast('success', messages.patchMerged);
                    window.location.reload();
                    return;
                }

                toast('error', (data && data.message) ? data.message : messages.patchMergeFailed);
            }).catch(function () {
                toast('error', messages.networkError);
            });
        });
    }

    document.querySelectorAll('.site-builder-provider-tool').forEach(function (button) {
        button.addEventListener('click', function () {
            var patch = {};

            try {
                patch = JSON.parse(button.getAttribute('data-tool-patch') || '{}');
            } catch (error) {
                toast('error', messages.toolPatchBroken);
                return;
            }

            button.disabled = true;
            applyScopeThenMaybeStage(
                patch,
                (button.getAttribute('data-tool-stage') || '').trim(),
                messages.toolApplied
            ).catch(function (error) {
                toast('error', error && error.message ? error.message : messages.toolApplyFailed);
            }).finally(function () {
                button.disabled = false;
            });
        });
    });

    var reloadBtn = document.getElementById('site-builder-reload-page');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', function () {
            window.location.reload();
        });
    }

    var sseBtn = document.getElementById('site-builder-start-sse');
    var terminal = window.WelineSseTerminal ? window.WelineSseTerminal['site-builder-workspace-terminal'] : null;
    if (sseBtn && terminal) {
        terminal.on('done', function () {
            sseBtn.disabled = false;
        });
        terminal.on('error', function () {
            sseBtn.disabled = false;
        });

        sseBtn.addEventListener('click', function () {
            var separator = streamBaseUrl.indexOf('?') >= 0 ? '&' : '?';
            var url = streamBaseUrl + separator + 'public_id=' + encodeURIComponent(publicId)
                + '&last_event_id=' + encodeURIComponent(String(lastEventId));

            terminal.clear();
            terminal.setUrl(url);
            sseBtn.disabled = true;
            terminal.start();
        });
    }
})();
</script>
