    --wb-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    color: var(--wb-text);
}

[data-theme="dark"] .site-builder-workspace-page,
body[data-sidebar="dark"] .site-builder-workspace-page,
body[data-topbar="dark"] .site-builder-workspace-page {
    --wb-text: var(--backend-color-text-primary, #e2e8f0);
    --wb-text-muted: var(--backend-color-text-secondary, #94a3b8);
    --wb-border: var(--backend-color-card-border, rgba(148, 163, 184, 0.24));
    --wb-border-strong: var(--backend-color-input-focus-border, rgba(96, 165, 250, 0.48));
    --wb-surface: var(--backend-color-card-bg, rgba(15, 23, 42, 0.9));
    --wb-surface-soft: var(--backend-color-bg-secondary, rgba(30, 41, 59, 0.86));
    --wb-surface-strong: var(--backend-color-bg-primary, rgba(15, 23, 42, 0.96));
    --wb-accent-subtle: var(--backend-color-primary-bg-subtle, rgba(59, 130, 246, 0.18));
    --wb-warning-subtle: rgba(245, 158, 11, 0.2);
