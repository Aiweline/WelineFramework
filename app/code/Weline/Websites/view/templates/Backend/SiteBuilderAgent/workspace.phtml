                                <span><?= htmlspecialchars((string)($recent['stage_label'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span>
                                <small><?= htmlspecialchars((string)($recent['summary'] ?? ''), ENT_QUOTES, 'UTF-8') ?></small>
                            </a>
                        <?php } ?>
                    </div>
                <?php } ?>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0">
                <h5 class="card-title mb-1">
                    <i class="mdi mdi-format-list-bulleted me-1"></i>
                    <lang>最近事件</lang>
                </h5>
                <p class="text-muted mb-0"><lang>这里显示最近写入的工作区事件，便于快速回顾。</lang></p>
            </div>
            <div class="card-body p-4">
                <?php if ($events === []) { ?>
                    <div class="workspace-empty-inline"><lang>暂无事件。</lang></div>
                <?php } else { ?>
                    <div class="workspace-event-list">
                        <?php foreach ($events as $event) { ?>
                            <div class="workspace-event-item">
                                <div class="workspace-event-head">
                                    <strong><?= htmlspecialchars((string)($event['event_type'] ?? ''), ENT_QUOTES, 'UTF-8') ?></strong>
                                    <span><?= htmlspecialchars((string)($event['create_time'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span>
                                </div>
                                <div class="workspace-event-body"><?= htmlspecialchars((string)\json_encode($event['payload'] ?? [], JSON_UNESCAPED_UNICODE), ENT_QUOTES, 'UTF-8') ?></div>
                            </div>
                        <?php } ?>
                    </div>
                <?php } ?>
            </div>
        </div>
    </div>
</div>

