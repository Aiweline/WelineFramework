    updateDomainPurchaseUi(domainPurchaseState || {});
    updateDomainLogSummary();

    var startDomainPurchaseBtn = document.getElementById('site-builder-start-domain-purchase');
    function triggerDomainPurchaseQueue(silentMode) {
        if (!startDomainPurchaseUrl) {
            if (!silentMode) {
                toast('error', messages.domainPurchaseQueueFailed);
            }
            return;
        }
        if (startDomainPurchaseBtn) {
            startDomainPurchaseBtn.disabled = true;
        }
        postForm(startDomainPurchaseUrl, {
            public_id: publicId,
            scope_patch: JSON.stringify(compactPatch(readSummaryPatch()))
        }).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) ? data.message : messages.domainPurchaseQueueFailed);
            }

            if (data.state && typeof data.state === 'object') {
                updateDomainPurchaseUi(data.state);
            }
            toast('success', silentMode ? messages.domainPurchaseAutoQueued : (data.message || messages.domainPurchaseQueued));

            if (data.startable && data.stream_url) {
                startBackgroundDomainPurchase(data.stream_url);
            }
        }).catch(function (error) {
            toast('error', error && error.message ? error.message : messages.domainPurchaseQueueFailed);
            updateDomainPurchaseUi(domainPurchaseState || {});
        }).finally(function () {
            updateDomainPurchaseUi(domainPurchaseState || {});
        });
    }
    if (startDomainPurchaseBtn) {
        startDomainPurchaseBtn.addEventListener('click', function () {
            triggerDomainPurchaseQueue(false);
        });
    }

    if (domainPurchaseState && domainPurchaseState.needs_resume && domainPurchaseState.execution_token) {
        var separator = domainPurchaseSseBaseUrl.indexOf('?') >= 0 ? '&' : '?';
        startBackgroundDomainPurchase(
            domainPurchaseSseBaseUrl + separator + 'public_id=' + encodeURIComponent(publicId)
            + '&execution_token=' + encodeURIComponent(String(domainPurchaseState.execution_token || ''))
        );
    }

    if (autoStartDomainPurchase) {
        var currentDomainPurchaseStatus = String((domainPurchaseState && domainPurchaseState.status) || 'idle').trim() || 'idle';
        if (['queued', 'running', 'completed'].indexOf(currentDomainPurchaseStatus) === -1) {
            triggerDomainPurchaseQueue(true);
        }
    }

    var saveSummaryBtn = document.getElementById('site-builder-save-summary');
