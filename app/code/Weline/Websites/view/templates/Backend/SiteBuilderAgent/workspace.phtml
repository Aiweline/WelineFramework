    function startBackgroundDomainPurchase(streamUrl) {
        if (!streamUrl || domainPurchaseStreamController) {
            return;
        }

        domainPurchaseStreamController = new AbortController();
        fetch(toSameOriginRequestPath(streamUrl), {
            method: 'GET',
            headers: {
                'Accept': 'text/event-stream',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            signal: domainPurchaseStreamController.signal
        }).then(function (response) {
            if (!response.ok) {
                return response.text().then(function (text) {
                    throw new Error(text || messages.domainPurchaseQueueFailed);
                });
            }
            if (!response.body) {
                return null;
            }

            var reader = response.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';

            function consumeEvent(rawEvent) {
                var lines = rawEvent.split('\n');
                var eventName = 'message';
                var dataText = '';

                lines.forEach(function (line) {
                    if (line.indexOf('event:') === 0) {
                        eventName = line.replace(/^event:\s*/, '').trim() || 'message';
                    } else if (line.indexOf('data:') === 0) {
                        dataText += line.replace(/^data:\s*/, '');
                    }
                });

                if (!dataText) {
                    return;
                }

                var payload = {};
                try {
                    payload = JSON.parse(dataText);
                } catch (error) {
                    payload = { message: dataText };
                }

                if (payload && payload.state && typeof payload.state === 'object') {
                    updateDomainPurchaseUi(payload.state);
                } else {
                    syncDomainPurchaseStateFromPayload(payload);
                }

                if (eventName === 'done' || eventName === 'error') {
                    if (eventName === 'error' && payload.message) {
                        toast('error', payload.message);
                    }
                    domainPurchaseStreamController = null;
                }
            }

            function pump() {
                return reader.read().then(function (result) {
                    if (!result || result.done) {
                        domainPurchaseStreamController = null;
                        return;
                    }

                    buffer += decoder.decode(result.value, { stream: true });
                    var eventsRaw = buffer.split('\n\n');
                    buffer = eventsRaw.pop() || '';
                    eventsRaw.forEach(consumeEvent);
                    return pump();
                });
            }

            return pump();
        }).catch(function (error) {
            if (!error || error.name === 'AbortError') {
                return;
            }
            domainPurchaseStreamController = null;
            toast('error', error.message || messages.domainPurchaseQueueFailed);
        });
    }

