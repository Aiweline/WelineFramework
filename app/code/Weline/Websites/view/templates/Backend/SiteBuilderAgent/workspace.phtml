    function escapeHtml(value) {
        var node = document.createElement('div');
        node.textContent = value === undefined || value === null ? '' : String(value);
        return node.innerHTML;
    }

    function ensureWorkspaceRegistrarInstance() {
        window.WelineRegistrarSelect = window.WelineRegistrarSelect || {};
        if (window.WelineRegistrarSelect['site-builder-registrar-account']) {
            return window.WelineRegistrarSelect['site-builder-registrar-account'];
        }

        var id = 'site-builder-registrar-account';
        var wrapper = document.getElementById(id + '_wrapper');
        var trigger = document.getElementById(id + '_trigger');
        var dropdown = document.getElementById(id + '_dropdown');
        var search = document.getElementById(id + '_search');
        var list = document.getElementById(id + '_list');
        var tags = document.getElementById(id + '_tags');
        var hidden = document.getElementById(id + '_value');
        var multiple = wrapper && String(wrapper.getAttribute('data-multiple') || '').toLowerCase() === 'true';
        var emptyLabel = tags && tags.textContent ? tags.textContent.trim() : '';
        var selected = [];
        var options = [];

        if (!wrapper || !trigger || !dropdown || !search || !list || !tags || !hidden) {
            return null;
        }

        function readInitialSelection() {
            return String(hidden.value || '').split(',').map(function (value) {
                return value.trim();
            }).filter(Boolean);
        }

        function normalizeOptions(items) {
            return (Array.isArray(items) ? items : []).map(function (item) {
                return {
                    value: String(item && item.value ? item.value : ''),
                    label: String(item && item.label ? item.label : (item && item.value ? item.value : '')),
                    group: String(item && item.group ? item.group : ''),
                    meta: String(item && item.meta ? item.meta : ''),
                    raw: item || null
                };
            }).filter(function (item) {
                return item.value !== '';
            });
        }

        function isPicked(value) {
            return selected.indexOf(String(value)) > -1;
        }

        function syncHidden() {
            hidden.value = selected.join(',');
        }

        function getSelected() {
            return selected.map(function (value) {
                return options.find(function (item) {
                    return item.value === value;
                }) || { value: value, label: value, group: '', meta: '', raw: null };
            });
        }

        function emitChange(item) {
            try {
                hidden.dispatchEvent(new Event('change', { bubbles: true }));
            } catch (error) {
            }

            if (typeof window.handleSiteBuilderRegistrarSelect === 'function') {
                window.handleSiteBuilderRegistrarSelect(item || null, { selected: selected.slice() });
            }
        }

        function renderTags() {
            tags.innerHTML = '';
            if (selected.length === 0) {
                var placeholder = document.createElement('span');
                placeholder.id = id + '_display';
                placeholder.textContent = emptyLabel;
                tags.appendChild(placeholder);
                return;
            }

            selected.forEach(function (value) {
                var item = options.find(function (option) {
                    return option.value === value;
                });
