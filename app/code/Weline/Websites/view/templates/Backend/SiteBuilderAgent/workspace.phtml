            order_id: payload.order_id !== undefined ? payload.order_id : domainPurchaseState.order_id,
            purchase_order_id: payload.purchase_order_id !== undefined ? payload.purchase_order_id : domainPurchaseState.purchase_order_id,
            execution_token: payload.execution_token !== undefined ? payload.execution_token : domainPurchaseState.execution_token,
            updated_at: payload.updated_at !== undefined ? payload.updated_at : domainPurchaseState.updated_at,
            started_at: payload.started_at !== undefined ? payload.started_at : domainPurchaseState.started_at,
            finished_at: payload.finished_at !== undefined ? payload.finished_at : domainPurchaseState.finished_at
        });
    }

    function parseSsePayload(event) {
        if (!event || typeof event.data !== 'string') {
            return {};
        }
        try {
            return JSON.parse(event.data || '{}');
        } catch (error) {
            return {};
        }
    }

    function startBackgroundDomainPurchase(streamUrl) {
        if (!streamUrl || domainPurchaseStreamController) {
            return;
        }

        domainPurchaseStreamController = new AbortController();
        fetch(toSameOriginRequestPath(streamUrl), {
            method: 'GET',
            headers: {
                'Accept': 'text/event-stream',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            signal: domainPurchaseStreamController.signal
        }).then(function (response) {
            if (!response.ok) {
                return response.text().then(function (text) {
                    throw new Error(text || messages.domainPurchaseQueueFailed);
                });
            }
            if (!response.body) {
                return null;
            }

            var reader = response.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';

            function consumeEvent(rawEvent) {
                var lines = rawEvent.split('\n');
                var eventName = 'message';
                var dataText = '';

                lines.forEach(function (line) {
                    if (line.indexOf('event:') === 0) {
                        eventName = line.replace(/^event:\s*/, '').trim() || 'message';
                    } else if (line.indexOf('data:') === 0) {
                        dataText += line.replace(/^data:\s*/, '');
                    }
                });

                if (!dataText) {
                    return;
                }

                var payload = {};
                try {
                    payload = JSON.parse(dataText);
                } catch (error) {
                    payload = { message: dataText };
                }

                if (payload && payload.state && typeof payload.state === 'object') {
                    updateDomainPurchaseUi(payload.state);
                } else {
                    syncDomainPurchaseStateFromPayload(payload);
                }

                if (eventName === 'done' || eventName === 'error') {
                    if (eventName === 'error' && payload.message) {
                        toast('error', payload.message);
                    }
                    domainPurchaseStreamController = null;
                }
            }

            function pump() {
                return reader.read().then(function (result) {
                    if (!result || result.done) {
                        domainPurchaseStreamController = null;
                        return;
                    }

                    buffer += decoder.decode(result.value, { stream: true });
                    var eventsRaw = buffer.split('\n\n');
                    buffer = eventsRaw.pop() || '';
                    eventsRaw.forEach(consumeEvent);
                    return pump();
                });
            }

            return pump();
        }).catch(function (error) {
            if (!error || error.name === 'AbortError') {
                return;
            }
            domainPurchaseStreamController = null;
            toast('error', error.message || messages.domainPurchaseQueueFailed);
        });
    }

    function applyScopeThenMaybeStage(patch, nextStage, successMessage, options) {
        var settings = options || {};
        var mergedPatch = Object.assign({}, patch || {}, compactPatch(readSummaryPatch()));

        return postForm(mergeScopeUrl, {
            public_id: publicId,
            scope_patch: JSON.stringify(mergedPatch)
        }).then(function (data) {
            if (!data || !data.success) {
                throw new Error((data && data.message) ? data.message : messages.applyRecommendationFailed);
            }

            if (!nextStage) {
                return null;
            }

            return postForm(setStageUrl, {
                public_id: publicId,
                stage: nextStage
            }).then(function (stageData) {
                if (!stageData || !stageData.success) {
                    throw new Error((stageData && stageData.message) ? stageData.message : messages.stageUpdateFailed);
                }
            });
        }).then(function () {
            toast('success', successMessage);
            if (
                settings.redirectToProviderOnGenerate
                && providerCode === 'pagebuilder'
                && nextStage === 'generate'
                && providerNativeUrl
            ) {
                window.location.href = providerNativeUrl;
                return;
            }
            window.location.reload();
        });
    }

    function getSelectedPageTypes() {
        return Array.prototype.slice.call(document.querySelectorAll('.site-builder-page-type-check:checked')).map(function (node) {
