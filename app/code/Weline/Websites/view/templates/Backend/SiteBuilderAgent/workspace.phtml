    --wb-danger-subtle: rgba(239, 68, 68, 0.2);
    --wb-shadow: 0 14px 30px rgba(2, 6, 23, 0.32);
}

.site-builder-workspace-page .text-muted,
.site-builder-workspace-page .form-text {
