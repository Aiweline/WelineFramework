.site-builder-workspace-page .form-control,
.site-builder-workspace-page .form-select {
    color: var(--wb-text);
    background: var(--wb-surface-strong);
    border-color: var(--wb-border);
}

.site-builder-workspace-page .form-control::placeholder {
    color: var(--wb-text-muted);
