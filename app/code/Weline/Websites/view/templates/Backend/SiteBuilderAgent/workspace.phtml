$parseLanguageValues = static function ($raw): array {
    if (\is_array($raw)) {
        $values = $raw;
    } elseif (\is_string($raw) && $raw !== '') {
        $decoded = \json_decode($raw, true);
        $values = \is_array($decoded) ? $decoded : (\preg_split('/[\s,]+/', $raw, -1, PREG_SPLIT_NO_EMPTY) ?: []);
    } else {
        $values = [];
    }

    $result = [];
    foreach ($values as $value) {
        if (!\is_scalar($value)) {
            continue;
        }
        $value = \trim((string)$value);
        if ($value === '' || \in_array($value, $result, true)) {
            continue;
        }
        $result[] = $value;
    }

    return $result;
};
