                theme_style_direction: document.getElementById('site-builder-theme-style-direction') ? document.getElementById('site-builder-theme-style-direction').value : '',
                theme_color_scheme: document.getElementById('site-builder-theme-color-scheme') ? document.getElementById('site-builder-theme-color-scheme').value : '',
                page_types: JSON.stringify(getSelectedPageTypes()),
