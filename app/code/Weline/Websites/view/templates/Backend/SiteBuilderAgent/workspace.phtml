    function startProgressiveGeneration() {
        var selectedTypes = [];
        var checkboxes = document.querySelectorAll('#pageTypeSelectorModal input[type="checkbox"]:checked');
        checkboxes.forEach(function(cb) {
            selectedTypes.push(cb.value);
        });

        if (selectedTypes.length === 0) {
            toast('warning', '<?= __('请至少选择一个页面类型') ?>');
            return;
        }

        // 关闭弹窗
        var modal = bootstrap.Modal.getInstance(document.getElementById('pageTypeSelectorModal'));
        if (modal) {
            modal.hide();
        }

        // 初始化页面状态
        selectedTypes.forEach(function(pageType) {
            if (pageTypeStates[pageType]) {
                pageTypeStates[pageType].generating = true;
                pageTypeStates[pageType].generated = false;
            }
        });

        // 更新页面类型切换器
        updatePageTypeSwitcher();

        // 启动 SSE 流式生成
        // 添加时间戳参数避免缓存问题，并确保独立连接
        var sseBaseUrl = '<?= $generate_virtual_theme_sse_url ?>?public_id=<?= urlencode($publicId) ?>&stream_mode=progressive';
        var sseUrl = sseBaseUrl + '&_ts=' + Date.now();

        // SSE 连接管理
        var eventSource = null;
        var sseReconnectCount = 0;
        var maxReconnectAttempts = 3;
        var sseLastEventTime = Date.now();
        var sseHeartbeatInterval = null;
        var sseConnectionTimeout = 15000; // 15秒超时（缩短以更快释放连接槽）
        var sseFatalStop = false; // 命中不可恢复错误（如 402）后停止所有重连
        var generatedPages = {}; // 记录已生成的页面，避免重复处理
        var isGenerationComplete = false; // 标记生成是否完成

        function initEventSource() {
            if (eventSource) {
                try { eventSource.close(); } catch(e) {}
            }

            eventSource = new EventSource(sseUrl);
            sseLastEventTime = Date.now();

            eventSource.addEventListener('page_generated', function(e) {
                sseLastEventTime = Date.now();
                var data = JSON.parse(e.data);
                var pageType = data.page_type;

                // 避免重复处理同一页面
                if (generatedPages[pageType]) return;
                generatedPages[pageType] = true;

                if (pageTypeStates[pageType]) {
                    pageTypeStates[pageType].generated = true;
                    pageTypeStates[pageType].generating = false;
                    pageTypeStates[pageType].visualEditUrl = data.visual_edit_url;
                }

                // 首页生成完成后，立即显示编辑器
                if (pageType === 'home_page') {
                    currentEditingPageType = 'home_page';
                    showVisualEditor(data.visual_edit_url);
                }

                updatePageTypeSwitcher();
                terminal.log('<?= __('页面 %{page_type} 生成完成') ?>'.replace('%{page_type}', getPageTypeLabel(pageType)), 'success');
            });

            eventSource.addEventListener('progress', function(e) {
                sseLastEventTime = Date.now();
                var data = JSON.parse(e.data);
                terminal.log(data.message || '', 'info');
            });

            eventSource.addEventListener('error', function(e) {
                sseLastEventTime = Date.now();
                var data = e.data ? JSON.parse(e.data) : {};
                var message = data.message || '<?= __('生成过程中发生错误') ?>';
                terminal.log(message, 'error');
                var httpCode = parseInt(data.http_code || data.code || 0, 10) || 0;
                var lowerMessage = String(message).toLowerCase();
                var isFatal402 = httpCode === 402
                    || lowerMessage.indexOf('http 402') >= 0
                    || lowerMessage.indexOf('402') >= 0
                    || lowerMessage.indexOf('insufficient balance') >= 0
                    || lowerMessage.indexOf('余额不足') >= 0
                    || lowerMessage.indexOf('额度不足') >= 0;
                if (isFatal402) {
                    sseFatalStop = true;
                    if (eventSource) {
                        try { eventSource.close(); } catch (ignore) {}
                        eventSource = null;
                    }
                    if (sseHeartbeatInterval) {
                        clearInterval(sseHeartbeatInterval);
                        sseHeartbeatInterval = null;
                    }
                    terminal.log('<?= __('AI 链接失败（402），已停止重试，请检查账户余额或密钥配置。') ?>', 'error');
                }
            });

            eventSource.addEventListener('done', function(e) {
                sseLastEventTime = Date.now();
                isGenerationComplete = true;
                // 立即关闭 SSE 连接释放资源
                if (eventSource) {
                    eventSource.close();
                    eventSource = null;
                }
                clearInterval(sseHeartbeatInterval);
                sseHeartbeatInterval = null;
                terminal.log('<?= __('所有页面生成完成') ?>', 'success');
                // 延迟加载 iframe，确保 SSE 连接已释放
                setTimeout(function() {
                    if (currentEditingPageType && pageTypeStates[currentEditingPageType]) {
                        showVisualEditor(pageTypeStates[currentEditingPageType].visualEditUrl);
                    }
                }, 100);
            });

            // 连接打开事件
            eventSource.onopen = function() {
                sseLastEventTime = Date.now();
                sseReconnectCount = 0; // 重置重连计数
                terminal.log('<?= __('SSE连接已建立') ?>', 'info');
            };

            // 连接错误处理 - 自动重连
            eventSource.onerror = function(e) {
                if (sseFatalStop) {
                    return;
                }
                terminal.log('<?= __('SSE连接异常，准备重连...') ?>', 'warning');

                if (sseReconnectCount < maxReconnectAttempts) {
                    sseReconnectCount++;
                    var delay = Math.min(1000 * sseReconnectCount, 5000); // 递增延迟，最大5秒
                    terminal.log('<?= __('第%{count}次重连，等待%{delay}ms') ?>'.replace('%{count}', sseReconnectCount).replace('%{delay}', delay), 'info');

                    setTimeout(function() {
                        // 更新 URL 避免缓存
                        sseUrl = sseBaseUrl + '&_ts=' + Date.now() + '&_reconnect=' + sseReconnectCount;
                        initEventSource();
                    }, delay);
                } else {
                    terminal.log('<?= __('SSE重连次数超过限制，请刷新页面重试') ?>', 'error');
                    clearInterval(sseHeartbeatInterval);
                    // 标记所有正在生成的页面为失败
                    Object.keys(pageTypeStates).forEach(function(pt) {
                        if (pageTypeStates[pt].generating) {
                            pageTypeStates[pt].generating = false;
                        }
                    });
                    updatePageTypeSwitcher();
                }
            };

            // 心跳检测 - 防止连接僵死
            if (sseHeartbeatInterval) clearInterval(sseHeartbeatInterval);
            sseHeartbeatInterval = setInterval(function() {
                var now = Date.now();
                var elapsed = now - sseLastEventTime;
                if (sseFatalStop) {
                    return;
                }
                if (elapsed > sseConnectionTimeout) {
                    terminal.log('<?= __('SSE连接超时，正在重新连接...') ?>', 'warning');
                    if (eventSource) {
                        eventSource.close();
                    }
                    // 触发重连
                    if (sseReconnectCount < maxReconnectAttempts) {
                        sseReconnectCount++;
                        sseUrl = sseBaseUrl + '&_ts=' + Date.now() + '&_reconnect=' + sseReconnectCount;
                        initEventSource();
                    }
                }
            }, 10000); // 每10秒检查一次
        }

        // 初始化连接
        initEventSource();
    }

    // iframe 加载状态管理
    var iframeLoadRetries = 0;
    var maxIframeRetries = 3;
    var iframeLoadTimeout = null;

    // iframe 加载完成回调
    window.visualEditorFrameLoaded = function() {
        if (iframeLoadTimeout) {
            clearTimeout(iframeLoadTimeout);
            iframeLoadTimeout = null;
        }
        iframeLoadRetries = 0; // 重置重试计数
    };

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-site-builder-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();
        var action = trigger.getAttribute('data-site-builder-action');
        if (action === 'start-progressive-generation') {
            startProgressiveGeneration();
        } else if (action === 'show-page-type-selector') {
            showPageTypeSelectorModal();
        }
    });

    document.addEventListener('DOMContentLoaded', function() {
        var frame = document.getElementById('visualEditorFrame');
        if (!frame) {
            return;
        }
        frame.addEventListener('load', function() {
            if (window.visualEditorFrameLoaded) {
                window.visualEditorFrameLoaded();
            }
        });
    });

    function showVisualEditor(url) {
        if (!visualEditorFrame || !visualEditorContainer) return;

        // 清除之前的加载超时
        if (iframeLoadTimeout) {
            clearTimeout(iframeLoadTimeout);
            iframeLoadTimeout = null;
        }

        // 重置 iframe 加载重试计数
        if (url !== visualEditorFrame.getAttribute('data-current-url')) {
            iframeLoadRetries = 0;
            visualEditorFrame.setAttribute('data-current-url', url);
        }

        visualEditorContainer.style.display = 'block';

        // 延迟加载 iframe，确保其他资源已加载完成
        setTimeout(function() {
            visualEditorFrame.src = url;

            // 设置加载超时检测
            iframeLoadTimeout = setTimeout(function() {
                if (iframeLoadRetries < maxIframeRetries) {
                    iframeLoadRetries++;
                    terminal.log('<?= __('编辑器加载超时，正在重试%{count}/%{max}...') ?>'.replace('%{count}', iframeLoadRetries).replace('%{max}', maxIframeRetries), 'warning');
                    // 重新加载
                    visualEditorFrame.src = 'about:blank';
                    setTimeout(function() {
                        visualEditorFrame.src = url;
                    }, 500);
                } else {
                    terminal.log('<?= __('编辑器加载失败，请刷新页面重试') ?>', 'error');
                }
            }, 10000); // 10秒加载超时
        }, iframeLoadRetries * 500); // 递增延迟，避免并发冲击
    }

    function switchPageType(pageType) {
        var state = pageTypeStates[pageType];
        if (!state || !state.generated) {
            toast('warning', '<?= __('该页面尚未生成完成') ?>');
            return;
        }

        currentEditingPageType = pageType;
        showVisualEditor(state.visualEditUrl);
        updatePageTypeSwitcher();
    }

    function updatePageTypeSwitcher() {
        var container = document.getElementById('pageTypeSwitcher');
        if (!container) return;

        container.innerHTML = '';
        Object.keys(pageTypeStates).forEach(function(pageType) {
            var state = pageTypeStates[pageType];
            var btn = document.createElement('button');
            btn.className = 'btn btn-sm';
            btn.className += (pageType === currentEditingPageType) ? ' btn-primary' : ' btn-outline-primary';
            btn.disabled = !state.generated;
            btn.textContent = state.label;

            if (state.generating) {
                var spinner = document.createElement('span');
                spinner.className = 'spinner-border spinner-border-sm ms-1';
                btn.appendChild(spinner);
            }

            if (state.generated) {
                var badge = document.createElement('span');
                badge.className = 'badge bg-success ms-1';
                badge.textContent = '✓';
                btn.appendChild(badge);
            }

            btn.addEventListener('click', function() {
                switchPageType(pageType);
            });

            container.appendChild(btn);
        });
    }

    // 全局资源加载错误处理和重试机制
    (function setupResourceLoadRetry() {
        // 记录失败资源的重试次数
        var resourceRetryCount = {};
        var maxResourceRetries = 3;

        // 监听资源加载错误
        window.addEventListener('error', function(e) {
            var target = e.target;
            // 检查是否是资源加载错误（script, link, img, iframe）
            if (target && (target.tagName === 'SCRIPT' || target.tagName === 'LINK' || target.tagName === 'IMG' || target.tagName === 'IFRAME')) {
                var src = target.src || target.href;
                if (!src) return;

                var retryKey = target.tagName + ':' + src;
                var currentRetries = resourceRetryCount[retryKey] || 0;

                if (currentRetries < maxResourceRetries) {
                    resourceRetryCount[retryKey] = currentRetries + 1;
                    console.warn('[Resource Retry] ' + target.tagName + ' load failed, retrying ' + resourceRetryCount[retryKey] + '/' + maxResourceRetries + ': ' + src);

                    // 延迟重试
                    setTimeout(function() {
                        if (target.tagName === 'LINK') {
                            // 对于 CSS，创建新的 link 元素
                            var newLink = document.createElement('link');
                            newLink.rel = target.rel;
                            newLink.type = target.type;
                            newLink.href = src + (src.indexOf('?') >= 0 ? '&' : '?') + '_retry=' + resourceRetryCount[retryKey];
                            if (target.parentNode) {
                                target.parentNode.insertBefore(newLink, target.nextSibling);
                            }
                        } else if (target.tagName === 'SCRIPT') {
                            // 对于 JS，创建新的 script 元素
                            var newScript = document.createElement('script');
                            newScript.src = src + (src.indexOf('?') >= 0 ? '&' : '?') + '_retry=' + resourceRetryCount[retryKey];
                            newScript.async = target.async;
                            newScript.defer = target.defer;
                            if (target.parentNode) {
                                target.parentNode.insertBefore(newScript, target.nextSibling);
                            }
                        } else if (target.tagName === 'IMG') {
                            // 对于图片，直接修改 src
                            target.src = src + (src.indexOf('?') >= 0 ? '&' : '?') + '_retry=' + resourceRetryCount[retryKey];
                            return; // 不阻止默认行为，让浏览器重新加载
                        } else if (target.tagName === 'IFRAME') {
                            // 对于 iframe，直接修改 src
                            target.src = src + (src.indexOf('?') >= 0 ? '&' : '?') + '_retry=' + resourceRetryCount[retryKey];
                            return;
                        }
                    }, 1000 * resourceRetryCount[retryKey]); // 递增延迟

                    // 阻止默认错误处理
                    e.preventDefault();
                    e.stopPropagation();
                } else {
                    console.error('[Resource Failed] ' + target.tagName + ' failed after ' + maxResourceRetries + ' retries: ' + src);
                }
            }
        }, true); // 使用捕获阶段

        // 定期清理重试计数，避免内存泄漏
        setInterval(function() {
            resourceRetryCount = {};
        }, 300000); // 每5分钟清理一次
    })();
})();
</script>

