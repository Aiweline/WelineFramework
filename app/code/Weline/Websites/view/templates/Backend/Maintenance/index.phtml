<script>
function toggleMaintenance(websiteId, enabled) {
    const action = enabled ? '<?= __('开启') ?>' : '<?= __('关闭') ?>';
    if (!confirm('<?= __('确定要') ?>' + action + '<?= __('维护模式吗？') ?>')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('website_id', websiteId);
    formData.append('enabled', enabled ? '1' : '0');
    
    fetch('<?= $this->getBackendUrl('*/backend/maintenance/toggle') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('操作失败') ?>');
    });
}
</script>

