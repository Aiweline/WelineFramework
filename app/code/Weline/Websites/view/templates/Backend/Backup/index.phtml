<script>
(function() {
    'use strict';

    var config = {
        createUrl: <?= $jsonForScript($createUrl) ?>,
        deleteUrl: <?= $jsonForScript($deleteUrl) ?>,
        downloadUrl: <?= $jsonForScript($downloadUrl) ?>,
        text: {
            creating: <?= $jsonForScript((string)__('正在创建...')) ?>,
            createDefault: <?= $jsonForScript((string)__('创建备份')) ?>,
            createFail: <?= $jsonForScript((string)__('创建备份失败')) ?>,
            deleteConfirm: <?= $jsonForScript((string)__('确定要删除这个备份吗？删除后无法从列表恢复。')) ?>,
            deleteFail: <?= $jsonForScript((string)__('删除备份失败')) ?>,
            apiUnavailable: <?= $jsonForScript((string)__('后台请求组件不可用，请刷新页面后重试。')) ?>,
            confirmUnavailable: <?= $jsonForScript((string)__('确认组件不可用，请刷新页面后重试。')) ?>
        }
    };

    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.console && typeof window.console.log === 'function') {
            window.console.log(message);
        }
    }

    function unwrapResponse(response) {
        if (response && typeof response === 'object' && response.data && typeof response.data.success !== 'undefined') {
            return response.data;
        }
        return response || {};
    }

    function ensureApi() {
        return !!(window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function');
    }

    function appendQuery(url, key, value) {
        var separator = url.indexOf('?') === -1 ? '?' : '&';
        return url + separator + encodeURIComponent(key) + '=' + encodeURIComponent(value);
    }

    var form = document.getElementById('backupForm');
    if (form) {
        form.addEventListener('submit', function(event) {
            event.preventDefault();
            if (!ensureApi()) {
                toast('error', config.text.apiUnavailable);
                return;
            }

            var submit = form.querySelector('[data-backup-submit]');
            var submitLabel = submit ? submit.querySelector('span') : null;
            if (submit) {
                submit.disabled = true;
            }
            if (submitLabel) {
                submitLabel.textContent = config.text.creating;
            }

            window.Weline.Api.request(config.createUrl, {
                method: 'POST',
                body: new FormData(form)
            }).then(function(response) {
                var data = unwrapResponse(response);
                if (data.success) {
                    toast('success', data.message || config.text.createDefault);
                    window.setTimeout(function() {
                        window.location.reload();
                    }, 800);
                    return;
                }
                toast('error', data.message || config.text.createFail);
            }).catch(function(error) {
                toast('error', (error && error.message) || config.text.createFail);
            }).finally(function() {
                if (submit) {
                    submit.disabled = false;
                }
                if (submitLabel) {
                    submitLabel.textContent = config.text.createDefault;
                }
            });
        });
    }

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-backup-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();

        var filename = trigger.getAttribute('data-backup-filename') || '';
        var action = trigger.getAttribute('data-backup-action') || '';
        if (!filename) {
            return;
        }

        if (action === 'download') {
            var downloadUrl = appendQuery(config.downloadUrl, 'backup_action', 'download');
            window.location.href = appendQuery(downloadUrl, 'filename', filename);
            return;
        }

        if (action !== 'delete') {
            return;
        }

        if (!window.BackendConfirm || typeof window.BackendConfirm.show !== 'function') {
            toast('error', config.text.confirmUnavailable);
            return;
        }

        window.BackendConfirm.show(config.text.deleteConfirm).then(function(confirmed) {
            if (!confirmed) {
                return;
            }
            if (!ensureApi()) {
                toast('error', config.text.apiUnavailable);
                return;
            }

            var formData = new FormData();
            formData.append('backup_action', 'delete');
            formData.append('filename', filename);
            window.Weline.Api.request(config.deleteUrl, {
                method: 'POST',
                body: formData
            }).then(function(response) {
                var data = unwrapResponse(response);
                if (data.success) {
                    toast('success', data.message || '');
                    window.setTimeout(function() {
                        window.location.reload();
                    }, 500);
                    return;
                }
                toast('error', data.message || config.text.deleteFail);
            }).catch(function(error) {
                toast('error', (error && error.message) || config.text.deleteFail);
            });
        });
    });
})();
</script>
