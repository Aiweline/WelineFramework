<js:part name="w-delete"/>

<script>
(function() {
    'use strict';

    var guideToggle = document.getElementById('weline-websites-guide-toggle');
    if (guideToggle) {
        guideToggle.addEventListener('click', function() {
            var body = document.getElementById('weline-websites-guide-body');
            var icon = document.getElementById('weline-websites-guide-icon');
            if (body && icon) {
                body.classList.toggle('show');
                icon.style.transform = body.classList.contains('show') ? 'rotate(180deg)' : 'rotate(0deg)';
            }
        });
    }

    var searchTimeout = null;
    var searchForm = document.getElementById('search-form');
    var searchInput = document.getElementById('search-input');
    var tableContainer = document.getElementById('website-table-container');
    var clearSearchBtn = document.getElementById('clear-search');
    var searchUrl = '<?= $this->getUrl('*/admin/website') ?>';
    
    function performSearch() {
        if (!searchForm || !tableContainer) return;
        
        var searchValue = searchInput ? searchInput.value.trim() : '';
        
        tableContainer.innerHTML = '<div class="text-center p-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div><p class="mt-3"><?= __('正在搜索...') ?></p></div>';
        
        var params = new URLSearchParams();
        if (searchValue) {
            params.append('search', searchValue);
        }
        var ajaxUrl = searchUrl + (params.toString() ? '?' + params.toString() : '');
        
        fetch(ajaxUrl, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) {
            if (!response.ok) {
                throw new Error('HTTP error! status: ' + response.status);
            }
            return response.text();
        })
        .then(function(text) {
            try {
                return JSON.parse(text);
            } catch (e) {
                console.error('JSON parse error:', e, text);
                throw new Error('<?= __('服务器返回的不是有效的JSON数据') ?>');
            }
        })
        .then(function(data) {
            if (data.success) {
                tableContainer.innerHTML = data.html;
                
                var scripts = tableContainer.querySelectorAll('script');
                scripts.forEach(function(oldScript) {
                    var newScript = document.createElement('script');
                    Array.from(oldScript.attributes).forEach(function(attr) {
                        newScript.setAttribute(attr.name, attr.value);
                    });
                    newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                    oldScript.parentNode.replaceChild(newScript, oldScript);
                });
                
                var currentClearBtn = document.getElementById('clear-search');
                if (searchValue) {
                    if (!currentClearBtn) {
                        var btn = document.createElement('a');
                        btn.href = searchUrl;
                        btn.className = 'btn btn-outline-secondary';
                        btn.id = 'clear-search';
                        btn.innerHTML = '<i class="mdi mdi-close"></i> <?= __('清除') ?>';
                        searchForm.appendChild(btn);
                        btn.addEventListener('click', function(e) {
                            e.preventDefault();
                            searchInput.value = '';
                            performSearch();
                        });
                    }
                } else {
                    if (currentClearBtn && currentClearBtn.parentNode) {
                        currentClearBtn.parentNode.removeChild(currentClearBtn);
                    }
                }
                
                if (typeof window.initWDelete === 'function') {
                    window.initWDelete();
                } else {
                    var wDeleteScript = document.querySelector('script[src*="w-delete"]');
                    if (wDeleteScript) {
                        var newScript = document.createElement('script');
                        newScript.src = wDeleteScript.src;
                        document.body.appendChild(newScript);
                    }
                }
            } else {
                tableContainer.innerHTML = '<div class="alert alert-danger"><?= __('搜索失败') ?>: ' + (data.message || '<?= __('未知错误') ?>') + '</div>';
            }
        })
        .catch(function(error) {
            console.error('Search error:', error);
            tableContainer.innerHTML = '<div class="alert alert-danger"><?= __('搜索出错，请刷新页面重试') ?></div>';
        });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        if (!searchForm || !searchInput) return;
        
        searchForm.addEventListener('submit', function(e) {
            e.preventDefault();
            clearTimeout(searchTimeout);
            performSearch();
        });
        
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                performSearch();
            }, 500);
        });
        
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                clearTimeout(searchTimeout);
                performSearch();
            }
        });
        
        if (clearSearchBtn) {
            clearSearchBtn.addEventListener('click', function(e) {
                e.preventDefault();
                searchInput.value = '';
                performSearch();
            });
        }
    });
})();
</script>
