<script>
(function(){
'use strict';
var poolListUrl = <?= json_encode($poolListUrl) ?>;
var cleanInvalidUrl = <?= json_encode($cleanInvalidUrl) ?>;
var cleanMispointedUrl = <?= json_encode($cleanMispointedUrl) ?>;
var formKey = <?= json_encode($formKey) ?>;
var currentPage = <?= (int) $poolPage ?>;
var pageSize = <?= (int) $poolLimit ?>;
var totalRows = <?= (int) $poolTotal ?>;

function rowHtml(row) {
    var d = row.domain || '';
    var r = row.root_domain || '';
    var rs = row.resolve_status || 'pending';
    var il = parseInt(row.is_local_server, 10) === 1;
    var hs = row.https_status || 'none';
    var sr = parseInt(row.site_ready, 10) === 1;
    var sc = parseInt(row.site_created, 10) === 1;
    var pid = parseInt(row.pool_id, 10) || 0;
    var flowH = row._flow_html || '';
    var reg = row._registrar_name || '-';
    var dns = row._dns_provider_name || '-';
    var cdn = row._cdn_provider_name || '-';
    function rb(s, a, b, c, e) {
        if (s === 'resolved') return '<span class="badge bg-success-subtle text-success">' + a + '</span>';
        if (s === 'resolving') return '<span class="badge bg-info-subtle text-info">' + b + '</span>';
        if (s === 'error') return '<span class="badge bg-danger-subtle text-danger">' + c + '</span>';
        return '<span class="badge bg-warning-subtle text-warning">' + e + '</span>';
    }
    var resolveBadge = rb(rs, '<?= __('已解析') ?>', '<?= __('解析中') ?>', '<?= __('异常') ?>', '<?= __('待检测') ?>');
    var localBadge = il ? '<span class="badge bg-success-subtle text-success"><?= __('是') ?></span>' : '<span class="badge bg-secondary-subtle text-secondary"><?= __('否') ?></span>';
    var httpsBadge = hs === 'valid' ? '<span class="badge bg-success-subtle text-success"><?= __('有效') ?></span>' : (hs === 'pending' ? '<span class="badge bg-warning-subtle text-warning"><?= __('申请中') ?></span>' : '<span class="badge bg-secondary-subtle text-secondary"><?= __('无') ?></span>');
    var readyBadge = sr ? '<span class="badge bg-success"><?= __('可用') ?></span>' : '<span class="badge bg-secondary"><?= __('未就绪') ?></span>';
    var createdBadge = sc ? '<span class="badge bg-info"><?= __('是') ?></span>' : '<span class="badge bg-secondary"><?= __('否') ?></span>';
    return '<tr><td><strong>' + escapeHtml(d) + '</strong></td><td>' + escapeHtml(r) + '</td><td><div class="d-flex flex-column gap-1 small">' +
        '<div><span class="text-muted"><?= __('注册') ?>:</span> ' + escapeHtml(reg) + '</div>' +
        '<div><span class="text-muted">DNS:</span> ' + escapeHtml(dns) + '</div>' +
        '<div><span class="text-muted">CDN:</span> ' + escapeHtml(cdn) + '</div></div></td>' +
        '<td>' + resolveBadge + '</td><td>' + localBadge + '</td><td>' + httpsBadge + '</td><td>' + readyBadge + '</td><td>' + createdBadge + '</td></tr>';
}
function openWelinePoolFlowLogModal(title, htmlInner) {
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10002;display:flex;align-items:center;justify-content:center;padding:1rem;';
    var dlg = document.createElement('div');
    dlg.style.cssText = 'background:var(--backend-color-card-bg,#fff);border-radius:.75rem;padding:1.25rem;max-width:90vw;width:720px;max-height:85vh;overflow:auto;box-shadow:0 8px 32px rgba(0,0,0,.2);';
    dlg.innerHTML = '<h5 class="mb-3" style="margin:0 0 12px;font-size:1.1rem;">' + escapeHtml(title) + '</h5>' +
        '<div class="weline-pool-flow-body">' + htmlInner + '</div>' +
        '<button type="button" class="btn btn-primary mt-3 weline-pool-flow-close"><?= __('关闭') ?></button>';
    overlay.appendChild(dlg);
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';
    function close() {
        overlay.remove();
        document.body.style.overflow = '';
    }
    dlg.querySelector('.weline-pool-flow-close').addEventListener('click', close);
    overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
    document.addEventListener('keydown', function kw(e) {
        if (e.key === 'Escape') { document.removeEventListener('keydown', kw); close(); }
    });
}
function escapeHtml(s) {
    if (!s) return '';
    var el = document.createElement('div');
    el.textContent = s;
    return el.innerHTML;
}
function loadPage(page) {
    currentPage = page || 1;
    var tbody = document.getElementById('weline-pool-tbody');
    if (!tbody) return;
    tbody.innerHTML = '<tr><td colspan="9" class="text-center py-4"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></td></tr>';
    var u = poolListUrl + (poolListUrl.indexOf('?') >= 0 ? '&' : '?') + 'page=' + encodeURIComponent(currentPage) + '&page_size=' + encodeURIComponent(pageSize);
    fetch(u, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(function(r){ return r.json(); }).then(function(data){
        if (data.code !== 200 || !data.data) {
            tbody.innerHTML = '<tr><td colspan="9" class="text-center text-danger py-4">' + escapeHtml(data.msg || 'Error') + '</td></tr>';
            return;
        }
        var d = data.data;
        totalRows = d.total || 0;
        var pages = Math.max(1, d.pages || 1);
        document.getElementById('weline-pool-total-badge').textContent = '<?= __('共') ?> ' + totalRows + ' <?= __('条') ?>';
        var lim = d.limit || pageSize;
        document.getElementById('weline-pool-page-info').textContent = totalRows > 0
            ? '<?= __('第') ?> ' + d.page + ' / ' + pages + ' <?= __('页，每页') ?> ' + lim + ' <?= __('条，合计') ?> ' + totalRows + ' <?= __('条') ?>'
            : '<?= __('暂无数据') ?>';
        var items = d.items || [];
        if (items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="9" class="text-center py-5 text-muted"><i class="mdi mdi-database-remove" style="font-size:2rem;"></i><p class="mb-0 mt-2"><?= __('域名池暂无数据') ?></p></td></tr>';
        } else {
            tbody.innerHTML = items.map(rowHtml).join('');
        }
        renderPager(parseInt(d.page, 10) || 1, pages);
    }).catch(function(){
        tbody.innerHTML = '<tr><td colspan="9" class="text-center text-danger py-4"><?= __('请求失败') ?></td></tr>';
    });
}
function renderPager(page, lastPage) {
    var nav = document.getElementById('weline-pool-pagination');
    if (!nav) return;
    var h = '';
    if (lastPage > 1) {
        h += '<li class="page-item ' + (page <= 1 ? 'disabled' : '') + '"><a class="page-link" href="#" data-p="' + (page - 1) + '">&laquo;</a></li>';
        var s = Math.max(1, page - 2), e = Math.min(lastPage, page + 2);
        for (var i = s; i <= e; i++) {
            h += '<li class="page-item ' + (i === page ? 'active' : '') + '"><a class="page-link" href="#" data-p="' + i + '">' + i + '</a></li>';
        }
        h += '<li class="page-item ' + (page >= lastPage ? 'disabled' : '') + '"><a class="page-link" href="#" data-p="' + (page + 1) + '">&raquo;</a></li>';
    } else if (totalRows > 0) {
        h = '<li class="page-item disabled"><span class="page-link"><?= __('共 1 页') ?></span></li>';
    }
    nav.innerHTML = h;
    nav.querySelectorAll('a.page-link[data-p]').forEach(function(a){
        a.addEventListener('click', function(e){
            e.preventDefault();
            var p = parseInt(a.getAttribute('data-p'), 10);
            if (p >= 1 && p <= lastPage) loadPage(p);
        });
    });
}
renderPager(<?= (int) $poolPage ?>, <?= (int) max(1, $poolPages) ?>);

document.getElementById('weline-pool-page-size').addEventListener('change', function(){
    pageSize = parseInt(this.value, 10) || 20;
    loadPage(1);
});

function postJson(url, dry) {
    var fd = new FormData();
    fd.append('dry_run', dry ? '1' : '0');
    if (formKey) fd.append('form_key', formKey);
    return fetch(url, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(function(r){ return r.json(); });
}
function toastResult(data) {
    if (data.code !== 200) {
        if (typeof BackendToast !== 'undefined') BackendToast.error(data.msg || 'Error');
        else alert(data.msg);
        return;
    }
    var extra = '';
    if (data.data && data.data.domains && data.data.domains.length) {
        extra = ' ' + data.data.domains.slice(0, 12).join(', ');
    }
    if (data.data && data.data.dns_deleted && data.data.dns_deleted.length) {
        extra += ' | DNS: ' + data.data.dns_deleted.slice(0, 6).map(function(x){ return x.root + ' ' + x.type; }).join('; ');
    }
    if (data.data && data.data.errors && data.data.errors.length) {
        extra += ' | ' + data.data.errors.slice(0, 3).join('; ');
    }
    if (typeof BackendToast !== 'undefined') BackendToast.success((data.msg || '') + extra);
    else alert((data.msg || '') + extra);
}
function runDryThenCommit(url, titleDry) {
    var doCommit = function() {
        postJson(url, false).then(function(data){
            toastResult(data);
            if (data.code === 200) loadPage(1);
        }).catch(function(){
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __('请求失败') ?>');
        });
    };
    var p = typeof BackendConfirm !== 'undefined'
        ? BackendConfirm.show(titleDry, { title: '<?= __('试运行') ?>', type: 'info', confirmText: '<?= __('开始试运行') ?>' })
        : new Promise(function(res){ res(confirm(titleDry)); });
    p.then(function(ok){
        if (!ok) return;
        postJson(url, true).then(function(data){
            toastResult(data);
            if (data.code !== 200) return;
            var q = typeof BackendConfirm !== 'undefined'
                ? BackendConfirm.show('<?= __('试运行已完成。是否正式执行删除？此操作不可撤销。') ?>', { title: '<?= __('确认') ?>', type: 'danger' })
                : new Promise(function(res){ res(confirm('<?= __('正式执行？') ?>')); });
            q.then(function(ok2){ if (ok2) doCommit(); });
        }).catch(function(){
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __('请求失败') ?>');
        });
    });
}
document.getElementById('weline-pool-btn-clean-invalid').addEventListener('click', function(){
    runDryThenCommit(cleanInvalidUrl, '<?= __('将列出含 [] 的非法池记录（不删除）。继续？') ?>');
});
document.getElementById('weline-pool-btn-clean-dns').addEventListener('click', function(){
    runDryThenCommit(cleanMispointedUrl, '<?= __('将检查根域 @ 的 A/AAAA 是否指向本机公网（橙云代理不删）。继续试运行？') ?>');
});
document.getElementById('weline-pool-tbody').addEventListener('click', function(ev){
    var t = ev.target;
    if (!t || !t.classList || !t.classList.contains('weline-pool-flow-log-btn')) return;
    var id = t.getAttribute('data-pool-id');
    if (!id) return;
    var u = poolFlowLogUrl + (poolFlowLogUrl.indexOf('?') >= 0 ? '&' : '?') + 'pool_id=' + encodeURIComponent(id);
    fetch(u, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(function(r){ return r.json(); }).then(function(data){
        if (data.code !== 200 || !data.data || !data.data.items) {
            if (typeof BackendToast !== 'undefined') BackendToast.error(data.msg || 'Error');
            return;
        }
        var lines = data.data.items.map(function(x){ return (x.at || '') + ' [' + (x.kind || '') + '] ' + (x.message || ''); });
        var body = lines.length ? '<pre class="small mb-0 text-start" style="white-space:pre-wrap;max-height:70vh;overflow:auto;">' +
            lines.map(function(s){ return escapeHtml(s); }).join('\n') + '</pre>' : '<?= __('暂无记录') ?>';
        openWelinePoolFlowLogModal('<?= __('流转记录') ?> #' + id, body);
    }).catch(function(){ if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __('请求失败') ?>'); });
});
})();
</script>
