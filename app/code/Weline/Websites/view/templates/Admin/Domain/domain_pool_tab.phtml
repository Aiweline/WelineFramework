<?php
declare(strict_types=1);

use Weline\Framework\Manager\ObjectManager;
use Weline\Websites\Model\DomainPool;

/** @var \Weline\Framework\View\Template $this */
$cronInstalled = $this->getData('cronInstalled') ?? true;

/** @var DomainPool $poolModel */
$poolModel = ObjectManager::getInstance(DomainPool::class);
$poolRows = $poolModel->clearQuery()
    ->where(DomainPool::schema_fields_STATUS, DomainPool::STATUS_ACTIVE)
    ->order(DomainPool::schema_fields_ROOT_DOMAIN, 'ASC')
    ->order(DomainPool::schema_fields_DOMAIN, 'ASC')
    ->pagination(1, 300)
    ->select()
    ->fetchArray();

$total = \count($poolRows);
?>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
        <i class="mdi mdi-database me-1"></i><?= __('域名池') ?>
    </h5>
    <span class="badge bg-light text-dark">
        <?= __('共 %{1} 条', [$total]) ?>
    </span>
</div>

<?php if (!$cronInstalled): ?>
<div class="alert alert-warning mb-3" role="alert">
    <div class="d-flex align-items-start">
        <i class="mdi mdi-alert-circle-outline me-2 mt-1" style="font-size:1.25rem;"></i>
        <div class="flex-grow-1">
            <button type="button" class="btn btn-link p-0 text-start text-decoration-none fw-semibold" data-bs-toggle="collapse" data-bs-target="#weline-domain-pool-cron-collapse" aria-expanded="false" aria-controls="weline-domain-pool-cron-collapse">
                <?= __('cron未安装，无法自动检查域名状态，请点击查看安装指南') ?>
                <i class="mdi mdi-chevron-down ms-1"></i>
            </button>
            <div class="collapse mt-2" id="weline-domain-pool-cron-collapse">
                <p class="text-muted small mb-2"><?= __('域名池中的域名需通过定时任务定期检测解析状态、HTTPS 与建站就绪。请按以下步骤安装系统定时任务：') ?></p>
                <ol class="small mb-0 ps-3">
                    <li><?= __('在项目根目录执行命令：') ?><code class="bg-light px-1 rounded">php bin/w cron:install</code></li>
                    <li><strong><?= __('Linux / macOS') ?></strong>：<?= __('命令会在 crontab 中添加每分钟执行的任务，自动运行所有定时任务（含域名池解析检测）。') ?></li>
                    <li><strong><?= __('Windows') ?></strong>：<?= __('命令会创建系统计划任务。若遇到权限问题，请以管理员身份运行，或在本地安全策略中赋予当前用户「作为批处理作业登录」权限。') ?></li>
                </ol>
                <p class="small text-muted mt-2 mb-0"><?= __('安装完成后刷新本页面，将不再显示此提示。') ?></p>
            </div>
        </div>
    </div>
</div>
<?php endif; ?>

<?php if ($total === 0): ?>
    <div class="text-center py-5 text-muted">
        <i class="mdi mdi-database-remove" style="font-size:2rem;"></i>
        <p class="mb-0 mt-2"><?= __('域名池暂无数据') ?></p>
        <small><?= __('请先在「域名列表」中转存到域名池，或执行 DNS 查询/解析自动入池') ?></small>
    </div>
<?php else: ?>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th><?= __('域名') ?></th>
                <th><?= __('根域') ?></th>
                <th><?= __('解析') ?></th>
                <th><?= __('本机') ?></th>
                <th><?= __('HTTPS') ?></th>
                <th><?= __('可建站') ?></th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($poolRows as $row): ?>
                <?php
                $domain = (string)($row[DomainPool::schema_fields_DOMAIN] ?? '');
                $rootDomain = (string)($row[DomainPool::schema_fields_ROOT_DOMAIN] ?? '');
                $resolveStatus = (string)($row[DomainPool::schema_fields_RESOLVE_STATUS] ?? DomainPool::RESOLVE_STATUS_PENDING);
                $isLocal = (int)($row[DomainPool::schema_fields_IS_LOCAL_SERVER] ?? 0) === 1;
                $httpsStatus = (string)($row[DomainPool::schema_fields_HTTPS_STATUS] ?? DomainPool::HTTPS_STATUS_NONE);
                $siteReady = (int)($row[DomainPool::schema_fields_SITE_READY] ?? 0) === 1;
                ?>
                <tr>
                    <td><strong><?= \htmlspecialchars($domain, ENT_QUOTES, 'UTF-8') ?></strong></td>
                    <td><?= \htmlspecialchars($rootDomain, ENT_QUOTES, 'UTF-8') ?></td>
                    <td>
                        <?php if ($resolveStatus === DomainPool::RESOLVE_STATUS_RESOLVED): ?>
                            <span class="badge bg-success-subtle text-success"><?= __('已解析') ?></span>
                        <?php elseif ($resolveStatus === DomainPool::RESOLVE_STATUS_ERROR): ?>
                            <span class="badge bg-danger-subtle text-danger"><?= __('异常') ?></span>
                        <?php else: ?>
                            <span class="badge bg-warning-subtle text-warning"><?= __('待检测') ?></span>
                        <?php endif; ?>
                    </td>
                    <td>
                        <?php if ($isLocal): ?>
                            <span class="badge bg-success-subtle text-success"><?= __('是') ?></span>
                        <?php else: ?>
                            <span class="badge bg-secondary-subtle text-secondary"><?= __('否') ?></span>
                        <?php endif; ?>
                    </td>
                    <td>
                        <?php if ($httpsStatus === DomainPool::HTTPS_STATUS_VALID): ?>
                            <span class="badge bg-success-subtle text-success"><?= __('有效') ?></span>
                        <?php elseif ($httpsStatus === DomainPool::HTTPS_STATUS_PENDING): ?>
                            <span class="badge bg-warning-subtle text-warning"><?= __('申请中') ?></span>
                        <?php else: ?>
                            <span class="badge bg-secondary-subtle text-secondary"><?= __('无') ?></span>
                        <?php endif; ?>
                    </td>
                    <td>
                        <?php if ($siteReady): ?>
                            <span class="badge bg-success"><?= __('可用') ?></span>
                        <?php else: ?>
                            <span class="badge bg-secondary"><?= __('未就绪') ?></span>
                        <?php endif; ?>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>

    <?php if ($total >= 300): ?>
        <div class="mt-2 text-muted small">
            <?= __('当前仅展示前 300 条域名池记录。') ?>
        </div>
    <?php endif; ?>
<?php endif; ?>
