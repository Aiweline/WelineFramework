/**
 * 域名购买 Tab 内容
 *
 * 支持批量输入域名、检查可用性、选择绑定站点、批量购买。
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $accounts 域名商账号列表（含域名商信息）
 * @var array $websites 网站列表（供绑定选择）
 */
$accounts = $accounts ?? [];
$websites = $websites ?? [];
$purchaseDialogAssetVersion = (string) (@filemtime(\dirname(__DIR__, 3) . '/statics/backend/domain-purchase-dialog.js') ?: \time());
$purchaseDialogJsUrl = $this->getViewFileUrl('Weline_Websites::backend/domain-purchase-dialog.js') . '?v=' . $purchaseDialogAssetVersion;
$activeAccounts = [];
$activeAccountSelectOptions = [];
$providerSelectMap = [];
foreach ($accounts as $account) {
    if (($account['status'] ?? '') !== 'active') {
        continue;
    }
    $providerCode = (string)($account['registrar_code'] ?? '');
    $providerName = (string)($account['registrar_name'] ?? $providerCode);
    $activeAccounts[] = [
        'account_id' => (int)($account['account_id'] ?? 0),
        'account_name' => (string)($account['account_name'] ?? ''),
        'registrar_code' => $providerCode,
        'registrar_name' => $providerName,
    ];
    $activeAccountSelectOptions[] = [
        'value' => (string)((int)($account['account_id'] ?? 0)),
        'label' => $providerName . ' - ' . (string)($account['account_name'] ?? ''),
        'group' => $providerName !== '' ? $providerName : (string)__('其他'),
        'meta' => (string)($account['registrar_code'] ?? ''),
    ];
    if ($providerCode !== '' && !isset($providerSelectMap[$providerCode])) {
        $providerSelectMap[$providerCode] = [
            'value' => $providerCode,
            'label' => $providerName !== '' ? $providerName : $providerCode,
            'group' => (string)__('服务商'),
            'meta' => $providerCode,
        ];
    }
}
$activeAccountSelectOptionsJson = json_encode(array_values($activeAccountSelectOptions), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
$providerSelectOptionsJson = json_encode(array_values($providerSelectMap), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
