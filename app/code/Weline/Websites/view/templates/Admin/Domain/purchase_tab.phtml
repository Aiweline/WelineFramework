    <!-- 右侧：结果区 -->
    <div class="col-lg-7">
        <h5 class="mb-3"><?= __('检查结果') ?></h5>
        <div id="availability-results">
            <div class="text-center py-5 text-muted">
                <i class="mdi mdi-dns-outline" style="font-size:3rem;"></i>
                <p class="mt-2"><?= __('请在左侧输入域名并点击"检查可用性"。') ?></p>
            </div>
        </div>

        <!-- 购买确认区域（检查完成后显示） -->
        <div id="purchase-actions" style="display:none;" class="mt-3">
            <div class="card bg-light border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong id="purchase-count-text"><?= __('0 个可用域名') ?></strong>
                        </div>
                        <button type="button" class="btn btn-success" onclick="submitPurchase()">
                            <i class="mdi mdi-cart-check me-1"></i><?= __('批量购买') ?>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 购买记录 -->
        <div class="mt-4">
            <h6><?= __('购买记录') ?></h6>
            <div id="purchase-orders-container">
                <p class="text-muted small"><?= __('购买完成后会在此处显示记录。') ?></p>
            </div>
