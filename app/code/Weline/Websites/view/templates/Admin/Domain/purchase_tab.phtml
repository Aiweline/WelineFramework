<script>
var checkAvailabilityUrl = '<?= $this->getUrl('*/admin/domain/check-availability') ?>';
var purchaseUrl = '<?= $this->getUrl('*/admin/domain/purchase') ?>';
var ordersUrl = '<?= $this->getUrl('*/admin/domain/orders') ?>';
var getRegistrarAccountsUrl = '<?= $this->getUrl('*/admin/domain/get-registrar-accounts') ?>?active_only=1';
var purchaseDialogModal = null;
var pendingPurchasePayload = null;
var purchaseProviderAccounts = {};
var purchaseActiveAccounts = <?= json_encode($activeAccounts, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

var availabilityResults = [];

function getPurchaseDialogCurrentAccount() {
    var currentId = String(document.getElementById('purchase-account-id').value || '');
    return purchaseActiveAccounts.find(function(account) {
        return String(account.account_id || '') === currentId;
    }) || null;
}

function loadPurchaseDialogProviders(callback) {
    if (Object.keys(purchaseProviderAccounts).length > 0) {
        if (typeof callback === 'function') callback();
        return;
    }
    var dnsProvider = document.getElementById('purchase-dialog-dns-provider');
    var cdnProvider = document.getElementById('purchase-dialog-cdn-provider');
    if (dnsProvider) dnsProvider.innerHTML = '<option value=""><?= __('加载中...') ?></option>';
    if (cdnProvider) cdnProvider.innerHTML = '<option value=""><?= __('加载中...') ?></option>';
    fetch(getRegistrarAccountsUrl).then(function(r) { return r.json(); }).then(function(data) {
        purchaseProviderAccounts = {};
        var accounts = (data.data && data.data.accounts) ? data.data.accounts : [];
        accounts.forEach(function(acc) {
            var code = String(acc.registrar_code || '').trim();
            if (!code) return;
            if (!purchaseProviderAccounts[code]) {
                purchaseProviderAccounts[code] = { name: acc.registrar_name || code, accounts: [] };
            }
            purchaseProviderAccounts[code].accounts.push({
                id: acc.id,
                name: acc.name || '',
                registrar_name: acc.registrar_name || code
            });
        });
        var providerOpts = '<option value=""><?= __('请选择 DNS 服务商') ?></option>';
        Object.keys(purchaseProviderAccounts).forEach(function(code) {
            providerOpts += '<option value="' + escapeHtml(code) + '">' + escapeHtml(purchaseProviderAccounts[code].name) + '</option>';
        });
        if (dnsProvider) dnsProvider.innerHTML = providerOpts;
        if (cdnProvider) cdnProvider.innerHTML = providerOpts.replace('<?= __('请选择 DNS 服务商') ?>', '<?= __('请选择 CDN 服务商') ?>');
        if (typeof callback === 'function') callback();
    }).catch(function() {
        if (dnsProvider) dnsProvider.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
        if (cdnProvider) cdnProvider.innerHTML = '<option value=""><?= __('加载失败') ?></option>';
        if (typeof callback === 'function') callback();
    });
}

function populateAccountSelect(kind, providerCode) {
    var accountSelect = document.getElementById('purchase-dialog-' + kind + '-account');
    if (!accountSelect) return;
    accountSelect.innerHTML = '';
    if (!providerCode || !purchaseProviderAccounts[providerCode]) {
        accountSelect.innerHTML = '<option value=""><?= __('请先选择服务商') ?></option>';
        accountSelect.disabled = true;
        return;
    }
    accountSelect.disabled = false;
    accountSelect.innerHTML = '<option value=""><?= __('请选择子账户') ?></option>';
    var accounts = purchaseProviderAccounts[providerCode].accounts || [];
    accounts.forEach(function(acc) {
        var opt = document.createElement('option');
        opt.value = acc.id;
        opt.textContent = acc.name + '（' + acc.registrar_name + '）';
        accountSelect.appendChild(opt);
    });

    var currentAccount = getPurchaseDialogCurrentAccount();
    if (currentAccount && providerCode === String(currentAccount.registrar_code || '')) {
        accountSelect.value = String(currentAccount.account_id || '');
    }
}

function syncPurchaseDialogSections() {
    var dnsChoice = document.getElementById('purchase-dialog-dns-choice').value;
    var cdnChoice = document.getElementById('purchase-dialog-cdn-choice').value;
    document.getElementById('purchase-dialog-dns-provider-area').style.display = dnsChoice === 'provider_account' ? '' : 'none';
    document.getElementById('purchase-dialog-dns-ns-area').style.display = dnsChoice === 'custom_nameservers' ? '' : 'none';
    document.getElementById('purchase-dialog-cdn-provider-area').style.display = cdnChoice === 'provider_account' ? '' : 'none';
    if (dnsChoice === 'provider_account' || cdnChoice === 'provider_account') {
        loadPurchaseDialogProviders(function() {
            if (dnsChoice === 'provider_account') {
                populateAccountSelect('dns', document.getElementById('purchase-dialog-dns-provider').value);
            }
            if (cdnChoice === 'provider_account') {
                populateAccountSelect('cdn', document.getElementById('purchase-dialog-cdn-provider').value);
            }
        });
    }
}

function openPurchaseConfigModal(accountId, items) {
    pendingPurchasePayload = { accountId: accountId, items: items };
    if (!purchaseDialogModal) {
        purchaseDialogModal = new bootstrap.Modal(document.getElementById('welinePurchaseConfigModal'));
    }

    var currentAccount = getPurchaseDialogCurrentAccount();
    document.getElementById('purchase-dialog-dns-choice').value = 'follow_registrar';
    document.getElementById('purchase-dialog-cdn-choice').value = 'follow_registrar';
    document.getElementById('purchase-dialog-dns-nameservers').value = '';
    document.getElementById('purchase-dialog-resolve-to-local').checked = !!(document.getElementById('purchase-auto-resolve') && document.getElementById('purchase-auto-resolve').checked);
    document.getElementById('purchase-dialog-subdomains').value = (document.getElementById('purchase-subdomains') || {}).value || '@, www';
    document.getElementById('purchase-dialog-start-lifecycle').checked = true;

    var dnsProviderSelect = document.getElementById('purchase-dialog-dns-provider');
    var cdnProviderSelect = document.getElementById('purchase-dialog-cdn-provider');
    dnsProviderSelect.value = currentAccount ? String(currentAccount.registrar_code || '') : '';
    cdnProviderSelect.value = currentAccount ? String(currentAccount.registrar_code || '') : '';
    document.getElementById('purchase-dialog-dns-account').value = '';
    document.getElementById('purchase-dialog-cdn-account').value = '';

    syncPurchaseDialogSections();
    purchaseDialogModal.show();
}

function collectPurchaseDialogResult() {
    var dnsChoice = document.getElementById('purchase-dialog-dns-choice').value || 'follow_registrar';
    var cdnChoice = document.getElementById('purchase-dialog-cdn-choice').value || 'follow_registrar';
    var dnsProvider = document.getElementById('purchase-dialog-dns-provider').value || '';
    var cdnProvider = document.getElementById('purchase-dialog-cdn-provider').value || '';
    var dnsAccountId = document.getElementById('purchase-dialog-dns-account').value || '';
    var cdnAccountId = document.getElementById('purchase-dialog-cdn-account').value || '';

    if (dnsChoice === 'provider_account' && (!dnsProvider || !dnsAccountId)) {
        showToast('<?= __('请选择 DNS 服务商和对应子账户') ?>', 'warning');
        return null;
    }
    if (cdnChoice === 'provider_account' && (!cdnProvider || !cdnAccountId)) {
        showToast('<?= __('请选择 CDN 服务商和对应子账户') ?>', 'warning');
        return null;
    }

    return {
        dns_choice: dnsChoice,
        dns_provider: dnsProvider,
        dns_account_id: dnsAccountId,
        dns_nameservers: (document.getElementById('purchase-dialog-dns-nameservers').value || '').trim(),
        cdn_choice: cdnChoice,
        cdn_provider: cdnProvider,
        cdn_account_id: cdnAccountId,
        resolve_to_local: document.getElementById('purchase-dialog-resolve-to-local').checked ? 'yes' : 'no',
        subdomains: (document.getElementById('purchase-dialog-subdomains').value || '').trim() || '@,www',
        start_lifecycle: document.getElementById('purchase-dialog-start-lifecycle').checked ? '1' : '0'
    };
}

function checkDomainAvailability() {
    var accountId = document.getElementById('purchase-account-id').value;
    var domainsText = document.getElementById('purchase-domains-input').value.trim();

    if (!accountId) {
        showToast('<?= __('请先选择域名商账号') ?>', 'warning');
        return;
    }
    if (!domainsText) {
        showToast('<?= __('请输入域名') ?>', 'warning');
        return;
    }

    var container = document.getElementById('availability-results');
    container.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2"><?= __('正在检查域名可用性...') ?></p></div>';

    var formData = new FormData();
    formData.append('account_id', accountId);
    formData.append('domains', domainsText);

    fetch(checkAvailabilityUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            availabilityResults = data.data || [];
            renderAvailabilityResults(availabilityResults);
        } else {
            container.innerHTML = '<div class="alert alert-danger">' + (data.msg || '<?= __('检查失败') ?>') + '</div>';
        }
    })
    .catch(function(err) {
        container.innerHTML = '<div class="alert alert-danger"><?= __('请求失败') ?>: ' + err.message + '</div>';
    });
}

function renderAvailabilityResults(results) {
    var container = document.getElementById('availability-results');
    var availableCount = 0;
    var websitesJson = <?= json_encode($websites, JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

    var html = '<div class="table-responsive"><table class="table table-sm align-middle"><thead class="table-light"><tr>';
    html += '<th><?= __('域名') ?></th><th><?= __('状态') ?></th><th><?= __('价格') ?></th>';
    html += '<th><?= __('年限') ?></th><th><?= __('绑定站点') ?></th></tr></thead><tbody>';

    for (var i = 0; i < results.length; i++) {
        var r = results[i];
        var available = r.available;
        if (available) availableCount++;

        html += '<tr class="' + (available ? '' : 'table-secondary') + '">';
        html += '<td><strong>' + escapeHtml(r.domain) + '</strong></td>';
        html += '<td>' + (available
            ? '<span class="badge bg-success"><?= __('可用') ?></span>'
            : '<span class="badge bg-secondary"><?= __('不可用') ?></span>') + '</td>';
        html += '<td>' + (available && r.price ? (r.currency || '$') + r.price + '/yr' : '-') + '</td>';

        if (available) {
            html += '<td><input type="number" class="form-control form-control-sm purchase-years" data-index="' + i + '" value="1" min="1" max="10" style="width:70px;"></td>';
            html += '<td><select class="form-select form-select-sm purchase-bind-site" data-index="' + i + '" style="min-width:160px;">';
            html += '<option value=""><?= __('不绑定') ?></option>';
            html += '<option value="__auto__"><?= __('自动新建站点') ?></option>';
            for (var j = 0; j < websitesJson.length; j++) {
                var w = websitesJson[j];
                html += '<option value="' + w.website_id + '">' + escapeHtml(w.name || w.code) + '</option>';
            }
            html += '</select></td>';
        } else {
            html += '<td>-</td><td>' + (r.message ? '<small class="text-muted">' + escapeHtml(r.message) + '</small>' : '-') + '</td>';
        }
        html += '</tr>';
    }

    html += '</tbody></table></div>';
    container.innerHTML = html;

    // 显示/隐藏购买按钮区域
    var actionsDiv = document.getElementById('purchase-actions');
    var countText = document.getElementById('purchase-count-text');
    if (availableCount > 0) {
        actionsDiv.style.display = 'block';
        countText.textContent = availableCount + ' <?= __('个可用域名') ?>';
    } else {
        actionsDiv.style.display = 'none';
    }
}

function submitPurchase() {
    var accountId = document.getElementById('purchase-account-id').value;
    if (!accountId) {
        showToast('<?= __('请选择域名商账号') ?>', 'warning');
        return;
    }

    // 收集购买项
    var items = [];
    for (var i = 0; i < availabilityResults.length; i++) {
        var r = availabilityResults[i];
        if (!r.available) continue;

        var yearsInput = document.querySelector('.purchase-years[data-index="' + i + '"]');
        var bindSelect = document.querySelector('.purchase-bind-site[data-index="' + i + '"]');

        var years = yearsInput ? parseInt(yearsInput.value) || 1 : 1;
        var bindValue = bindSelect ? bindSelect.value : '';

        items.push({
            domain: r.domain,
            years: years,
            website_id: (bindValue && bindValue !== '__auto__') ? parseInt(bindValue) : 0,
            auto_create_site: bindValue === '__auto__' ? 'yes' : 'no'
        });
    }

    if (items.length === 0) {
        showToast('<?= __('没有可用的域名可以购买') ?>', 'warning');
        return;
    }

    openPurchaseConfigModal(accountId, items);
}

function executePurchase(accountId, items, dialogResult) {
    showToast('<?= __('正在提交购买请求...') ?>', 'info');

    dialogResult = dialogResult || {};
    var autoResolve = dialogResult.resolve_to_local === 'yes' ? '1' : '0';
    var subdomainsRaw = dialogResult.subdomains || '@,www';
    var subdomains = subdomainsRaw.split(',').map(function(s) { return (s || '').trim(); }).filter(Boolean);
    if (subdomains.length === 0) subdomains = ['@', 'www'];

    var formData = new FormData();
    formData.append('account_id', accountId);
    formData.append('items', JSON.stringify(items));
    formData.append('auto_resolve', autoResolve);
    formData.append('resolve_to_local', dialogResult.resolve_to_local || 'yes');
    formData.append('subdomains', JSON.stringify(subdomains));
    formData.append('dns_choice', dialogResult.dns_choice || 'follow_registrar');
    formData.append('dns_provider', dialogResult.dns_provider || '');
    formData.append('dns_account_id', dialogResult.dns_account_id || '');
    formData.append('dns_nameservers', dialogResult.dns_nameservers || '');
    formData.append('cdn_choice', dialogResult.cdn_choice || 'follow_registrar');
    formData.append('cdn_provider', dialogResult.cdn_provider || '');
    formData.append('cdn_account_id', dialogResult.cdn_account_id || '');
    formData.append('start_lifecycle', dialogResult.start_lifecycle || '1');

    fetch(purchaseUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            var msg = data.msg || '<?= __('购买请求已提交') ?>';
            if (autoResolve === '1') {
                msg += ' <?= __('（自动解析任务已创建）') ?>';
            }
            if (dialogResult.start_lifecycle === '1') {
                msg += ' <?= __('请前往域名状态页搜索当前根域名查看进度。') ?>';
            }
            showToast(msg, 'success');
            var results = (data.data && data.data.results) || [];
            var lifecycleFails = results.filter(function(r) {
                return r && r.success && r.lifecycle && r.lifecycle.attempted && !r.lifecycle.success;
            });
            if (lifecycleFails.length > 0) {
                showToast(
                    '<?= __('%{count} 个域名购买成功，但未成功创建生命周期跟踪订单，请确认 Weline_Saas 模块已启用，或前往域名状态页使用「补建生命周期订单」补救。') ?>'.replace('%{count}', lifecycleFails.length),
                    'warning'
                );
            }
            loadOrders();
        } else {
            showToast(
                window.WelineDomainPurchaseDialog
                    ? window.WelineDomainPurchaseDialog.buildErrorMessage(data.data || data, '<?= __('购买失败') ?>')
                    : (data.msg || '<?= __('购买失败') ?>'),
                'error'
            );
        }
    })
    .catch(function(err) {
        showToast('<?= __('请求失败') ?>: ' + err.message, 'error');
    });
}

function loadOrders() {
    fetch(ordersUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200 && data.data && data.data.length > 0) {
            var html = '<div class="table-responsive"><table class="table table-sm"><thead class="table-light"><tr>';
            html += '<th><?= __('订单号') ?></th><th><?= __('数量') ?></th><th><?= __('状态') ?></th><th><?= __('时间') ?></th></tr></thead><tbody>';
            for (var i = 0; i < data.data.length; i++) {
                var o = data.data[i];
                html += '<tr>';
                html += '<td>' + escapeHtml(o.order_no || '-') + '</td>';
                html += '<td>' + (o.total_count || 0) + '</td>';
                html += '<td>' + escapeHtml(o.status || '-') + '</td>';
                html += '<td>' + escapeHtml(o.created_at || '-') + '</td>';
                html += '</tr>';
            }
            html += '</tbody></table></div>';
            document.getElementById('purchase-orders-container').innerHTML = html;
        }
    });
}

function escapeHtml(text) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text || ''));
    return div.innerHTML;
}

document.addEventListener('DOMContentLoaded', function() {
    var dnsChoice = document.getElementById('purchase-dialog-dns-choice');
    var cdnChoice = document.getElementById('purchase-dialog-cdn-choice');
    var dnsProvider = document.getElementById('purchase-dialog-dns-provider');
    var cdnProvider = document.getElementById('purchase-dialog-cdn-provider');
    var confirmBtn = document.getElementById('purchase-dialog-confirm-btn');
    if (dnsChoice) {
        dnsChoice.addEventListener('change', syncPurchaseDialogSections);
    }
    if (cdnChoice) {
        cdnChoice.addEventListener('change', syncPurchaseDialogSections);
    }
    if (dnsProvider) {
        dnsProvider.addEventListener('change', function() {
            populateAccountSelect('dns', this.value);
        });
    }
    if (cdnProvider) {
        cdnProvider.addEventListener('change', function() {
            populateAccountSelect('cdn', this.value);
        });
    }
    if (confirmBtn) {
        confirmBtn.addEventListener('click', function() {
            if (!pendingPurchasePayload) {
                return;
            }
            var dialogResult = collectPurchaseDialogResult();
            if (!dialogResult) {
                return;
            }
            if (purchaseDialogModal) {
                purchaseDialogModal.hide();
            }
            executePurchase(pendingPurchasePayload.accountId, pendingPurchasePayload.items, dialogResult);
        });
    }
});
</script>
