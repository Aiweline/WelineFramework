            </div>
            <div class="mt-3">
                <label class="form-label small fw-bold"><?= __('子域名（逗号分隔，默认 @,www）') ?></label>
                <input type="text" class="form-control form-control-sm" id="purchase-subdomains"
                       placeholder="@, www" value="@, www">
                <div class="form-text small"><?= __('购买后入池并自动解析的子域名列表') ?></div>
            </div>
