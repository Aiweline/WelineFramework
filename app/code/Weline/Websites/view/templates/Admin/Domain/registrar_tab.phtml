<script>
var saveAccountUrl = '<?= $this->getUrl('*/admin/domain/save-account') ?>';
var deleteAccountUrl = '<?= $this->getUrl('*/admin/domain/account') ?>';
var testConnectionUrl = '<?= $this->getUrl('*/admin/domain/test-connection') ?>';

function resetAccountForm() {
    document.getElementById('form-account-id').value = '0';
    document.getElementById('form-registrar-code').value = '';
    document.getElementById('form-account-name').value = '';
    document.getElementById('form-api-key').value = '';
    document.getElementById('form-api-secret').value = '';
    document.getElementById('form-region').value = '';
    document.getElementById('form-status').value = 'active';
    document.getElementById('form-extra-config').value = '';
    document.getElementById('registrar-description').textContent = '';
    document.getElementById('accountFormModalLabel').textContent = '<?= __('添加域名商账号') ?>';
}

function editAccount(account) {
    document.getElementById('form-account-id').value = account.account_id || '0';
    document.getElementById('form-registrar-code').value = account.registrar_code || '';
    document.getElementById('form-account-name').value = account.account_name || '';
    document.getElementById('form-api-key').value = '';
    document.getElementById('form-api-secret').value = '';
    document.getElementById('form-region').value = account.region || '';
    document.getElementById('form-status').value = account.status || 'active';
    document.getElementById('form-extra-config').value = account.extra_config || '';
    document.getElementById('accountFormModalLabel').textContent = '<?= __('编辑域名商账号') ?>';

    var modal = new bootstrap.Modal(document.getElementById('accountFormModal'));
    modal.show();
}

function onRegistrarChange(code) {
    var select = document.getElementById('form-registrar-code');
    var option = select.options[select.selectedIndex];
    var desc = option ? option.getAttribute('data-description') : '';
    document.getElementById('registrar-description').textContent = desc || '';
}

function saveAccount() {
    var form = document.getElementById('account-form');
    var formData = new FormData(form);

    fetch(saveAccountUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            showToast(data.msg || '<?= __('保存成功') ?>', 'success');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            showToast(data.msg || '<?= __('保存失败') ?>', 'error');
        }
    })
    .catch(function(err) {
        showToast('<?= __('请求失败') ?>: ' + err.message, 'error');
    });
}

function removeAccount(accountId) {
    if (!accountId) return;
    Swal.fire({
        title: '<?= __('确认删除') ?>',
        text: '<?= __('删除后无法恢复，确定要删除此账号吗？') ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f46a6a',
        cancelButtonText: '<?= __('取消') ?>',
        confirmButtonText: '<?= __('确定删除') ?>'
    }).then(function(result) {
        if (result.isConfirmed) {
            var formData = new FormData();
            formData.append('account_id', accountId);
            fetch(deleteAccountUrl, {
                method: 'DELETE',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    showToast(data.msg || '<?= __('删除成功') ?>', 'success');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    showToast(data.msg || '<?= __('删除失败') ?>', 'error');
                }
            })
            .catch(function(err) {
                showToast('<?= __('请求失败') ?>: ' + err.message, 'error');
            });
        }
    });
}

function testAccountConnection(accountId, registrarCode) {
    showToast('<?= __('正在测试连接...') ?>', 'info');
    var formData = new FormData();
    formData.append('account_id', accountId);
    formData.append('registrar_code', registrarCode);

    fetch(testConnectionUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            showToast(data.msg || '<?= __('连接成功') ?>', 'success');
        } else {
            showToast(data.msg || '<?= __('连接失败') ?>', 'error');
        }
    })
    .catch(function(err) {
        showToast('<?= __('测试失败') ?>: ' + err.message, 'error');
    });
}
</script>
