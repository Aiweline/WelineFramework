<script>
(function() {
'use strict';

var saveAccountUrl = '<?= $this->getUrl('*/admin/domain/save-account') ?>';
var deleteAccountUrl = '<?= $this->getUrl('*/admin/domain/account') ?>';
var testConnectionUrl = '<?= $this->getUrl('*/admin/domain/test-connection') ?>';
var getRegistrarInfoUrl = '<?= $this->getUrl('*/admin/domain/registrar-info') ?>';

var currentConfigFields = [];

window.resetAccountForm = function() {
    document.getElementById('form-account-id').value = '0';
    document.getElementById('form-registrar-code').value = '';
    document.getElementById('form-account-name').value = '';
    document.getElementById('form-status').value = 'active';
    document.getElementById('registrar-description').textContent = '';
    document.getElementById('accountFormModalLabel').textContent = '<?= __('添加域名商账号') ?>';
    document.getElementById('dynamic-config-fields').innerHTML = '';
    document.getElementById('config-help-info').style.display = 'none';
    currentConfigFields = [];
};

var pendingEditData = null;

window.editAccount = function(account) {
    document.getElementById('form-account-id').value = account.account_id || '0';
    document.getElementById('form-registrar-code').value = account.registrar_code || '';
    document.getElementById('form-account-name').value = account.account_name || '';
    document.getElementById('form-status').value = account.status || 'active';
    document.getElementById('accountFormModalLabel').textContent = '<?= __('编辑域名商账号') ?>';

    // 保存待填充的数据
    var extraConfig = account.extra_config || {};
    if (typeof extraConfig === 'string') {
        try {
            extraConfig = JSON.parse(extraConfig);
        } catch (e) {
            extraConfig = {};
        }
    }
    
    pendingEditData = {
        region: account.region || '',
        extra_config: extraConfig
    };

    // 触发动态字段加载
    onRegistrarChange(account.registrar_code);

    var modal = new bootstrap.Modal(document.getElementById('accountFormModal'));
    modal.show();
};

window.onRegistrarChange = function(code) {
    var select = document.getElementById('form-registrar-code');
    var option = select.options[select.selectedIndex];
    var desc = option ? option.getAttribute('data-description') : '';
    document.getElementById('registrar-description').textContent = desc || '';
    
    var dynamicFieldsDiv = document.getElementById('dynamic-config-fields');
    var helpInfoDiv = document.getElementById('config-help-info');
    dynamicFieldsDiv.innerHTML = '';
    helpInfoDiv.style.display = 'none';
    currentConfigFields = [];
    
    if (!code) return;
    
    var formData = new FormData();
    formData.append('registrar_code', code);
    
    fetch(getRegistrarInfoUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
        if (res.code !== 200 || !res.data) return;
        
        var info = res.data;
        var fields = info.config_fields || [];
        var help = info.config_help || {};
        
        currentConfigFields = fields;
        
        var isEditMode = parseInt(document.getElementById('form-account-id').value) > 0;
        
        var html = '';
        var escapeCfgFieldHelp = function(t) {
            if (!t) return '';
            return String(t).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        };
        fields.forEach(function(field) {
            var fieldId = 'form-field-' + field.name;
            var mapping = field.mapping || field.name;
            var isRequired = field.required === true;
            var isPassword = field.type === 'password';
            
            html += '<div class="mb-3">';
            html += '<label class="form-label">' + (field.label || field.name);
            
            if (isEditMode && isPassword) {
                html += ' <span class="text-muted small"><?= __('（不修改请留空）') ?></span>';
            } else if (isRequired) {
                html += ' <span class="text-danger">*</span>';
            }
            html += '</label>';
            
            if (field.type === 'select' && field.options) {
                html += '<select id="' + fieldId + '" class="form-select config-input" data-field="' + field.name + '" data-mapping="' + mapping + '" data-required="' + isRequired + '">';
                field.options.forEach(function(opt) {
                    var selected = (field.default && field.default === opt.value) ? ' selected' : '';
                    html += '<option value="' + (opt.value || '') + '"' + selected + '>' + (opt.label || opt.value || '') + '</option>';
                });
                html += '</select>';
            } else {
                var inputType = isPassword ? 'password' : 'text';
                var placeholder = field.placeholder || '';
                if (isEditMode && isPassword) {
                    placeholder = '••••••••••••••••<?= __('（留空不修改）') ?>';
                }
                
                html += '<input type="' + inputType + '" id="' + fieldId + '" class="form-control config-input" data-field="' + field.name + '" data-mapping="' + mapping + '" data-required="' + isRequired + '"';
                if (placeholder) html += ' placeholder="' + placeholder + '"';
                html += '>';
            }
            if (field.help_text) {
                html += '<div class="form-text text-warning small mt-1">' + escapeCfgFieldHelp(field.help_text) + '</div>';
            }
            html += '</div>';
        });
        dynamicFieldsDiv.innerHTML = html;
        
        // 编辑模式下，回填已保存的值
        if (isEditMode && pendingEditData) {
            dynamicFieldsDiv.querySelectorAll('.config-input').forEach(function(el) {
                var mapping = el.dataset.mapping || el.dataset.field;
                var fieldName = el.dataset.field;
                var isPassword = el.type === 'password';
                var value = '';
                
                // 根据 mapping 获取值
                if (mapping === 'region') {
                    value = pendingEditData.region || '';
                } else if (mapping.indexOf('extra_config.') === 0) {
                    var extraKey = mapping.replace('extra_config.', '');
                    value = pendingEditData.extra_config[extraKey] || '';
                } else if (pendingEditData.extra_config[fieldName]) {
                    value = pendingEditData.extra_config[fieldName];
                }
                
                // 密码字段不回填（保持空白，表示不修改）
                if (!isPassword && value) {
                    el.value = value;
                }
            });
            pendingEditData = null;
        }
        
        // 渲染帮助信息（购买权限指引优先，便于填账号时对照）
        var purchaseSteps = help.purchase_help_steps || [];
        var generalSteps = help.help_steps || [];
        if (purchaseSteps.length || generalSteps.length) {
            var helpHtml = '';
            if (purchaseSteps.length) {
                helpHtml += '<div class="alert alert-info py-2 px-3 mb-3"><div class="fw-bold mb-2"><i class="mdi mdi-shopping me-1"></i><?= __('域名购买所需权限（批量购买前请核对）') ?></div><ol class="mb-0 ps-3 small">';
                purchaseSteps.forEach(function(step) {
                    helpHtml += '<li class="mb-1">' + step + '</li>';
                });
                helpHtml += '</ol></div>';
            }
            if (generalSteps.length) {
                helpHtml += '<strong>';
                if (help.help_url) {
                    helpHtml += '<a href="' + help.help_url + '" target="_blank">' + (help.help_title || '<?= __('配置获取指南') ?>') + ' <i class="mdi mdi-open-in-new"></i></a>';
                } else {
                    helpHtml += (help.help_title || '<?= __('配置获取指南') ?>');
                }
                helpHtml += '</strong><ol class="mb-0 mt-2 ps-3">';
                generalSteps.forEach(function(step) {
                    helpHtml += '<li>' + step + '</li>';
                });
                helpHtml += '</ol>';
            }
            helpInfoDiv.innerHTML = helpHtml;
            helpInfoDiv.style.display = 'block';
        }
    })
    .catch(function(err) {
        console.error('加载适配器配置失败:', err);
    });
};

window.saveAccount = function() {
    var isEditMode = parseInt(document.getElementById('form-account-id').value) > 0;
    
    // 校验必填字段
    var hasError = false;
    var missingFields = [];
    document.querySelectorAll('#dynamic-config-fields .config-input').forEach(function(el) {
        var isRequired = el.dataset.required === 'true';
        var value = el.value.trim();
        var fieldName = el.dataset.field;
        var isPassword = el.type === 'password';
        
        var label = fieldName;
        currentConfigFields.forEach(function(f) {
            if (f.name === fieldName) {
                label = f.label || fieldName;
            }
        });
        
        var skipValidation = isEditMode && isPassword;
        
        if (isRequired && !value && !skipValidation) {
            hasError = true;
            missingFields.push(label);
            el.classList.add('is-invalid');
        } else {
            el.classList.remove('is-invalid');
        }
    });
    
    if (hasError) {
        showToast('<?= __('请填写必填字段') ?>: ' + missingFields.join(', '), 'error');
        return;
    }
    
    // 收集数据
    var formData = new FormData();
    formData.append('account_id', document.getElementById('form-account-id').value);
    formData.append('registrar_code', document.getElementById('form-registrar-code').value);
    formData.append('account_name', document.getElementById('form-account-name').value);
    formData.append('status', document.getElementById('form-status').value);
    
    var extraConfig = {};
    document.querySelectorAll('#dynamic-config-fields .config-input').forEach(function(el) {
        var value = el.value.trim();
        var mapping = el.dataset.mapping || el.dataset.field;
        
        if (mapping === 'api_key') {
            formData.append('api_key', value);
        } else if (mapping === 'api_secret') {
            formData.append('api_secret', value);
        } else if (mapping === 'region') {
            formData.append('region', value);
        } else if (mapping.indexOf('extra_config.') === 0) {
            var extraKey = mapping.replace('extra_config.', '');
            if (value) extraConfig[extraKey] = value;
        } else {
            if (value) extraConfig[el.dataset.field] = value;
        }
    });
    
    formData.append('extra_config', JSON.stringify(extraConfig));

    fetch(saveAccountUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            showToast(data.msg || '<?= __('保存成功') ?>', 'success');
            setTimeout(function() { location.reload(); }, 800);
        } else {
            showToast(data.msg || '<?= __('保存失败') ?>', 'error');
        }
    })
    .catch(function(err) {
        showToast('<?= __('请求失败') ?>: ' + err.message, 'error');
    });
};

window.removeAccount = function(accountId) {
    if (!accountId) return;
    Swal.fire({
        title: '<?= __('确认删除') ?>',
        text: '<?= __('删除后无法恢复，确定要删除此账号吗？') ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f46a6a',
        cancelButtonText: '<?= __('取消') ?>',
        confirmButtonText: '<?= __('确定删除') ?>'
    }).then(function(result) {
        if (result.isConfirmed) {
            var formData = new FormData();
            formData.append('account_id', accountId);
            fetch(deleteAccountUrl, {
                method: 'DELETE',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    showToast(data.msg || '<?= __('删除成功') ?>', 'success');
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    showToast(data.msg || '<?= __('删除失败') ?>', 'error');
                }
            })
            .catch(function(err) {
                showToast('<?= __('请求失败') ?>: ' + err.message, 'error');
            });
        }
    });
};

window.testAccountConnection = function(accountId, registrarCode) {
    showToast('<?= __('正在测试连接...') ?>', 'info');
    var formData = new FormData();
    formData.append('account_id', accountId);
    formData.append('registrar_code', registrarCode);

    fetch(testConnectionUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.code === 200) {
            showToast(data.msg || '<?= __('连接成功') ?>', 'success');
        } else {
            showToast(data.msg || '<?= __('连接失败') ?>', 'error');
        }
    })
    .catch(function(err) {
        showToast('<?= __('测试失败') ?>: ' + err.message, 'error');
    });
};

document.addEventListener('click', function(event) {
    var trigger = event.target.closest('[data-domain-account-action]');
    if (!trigger) {
        return;
    }
    var action = trigger.getAttribute('data-domain-account-action');
    if (action === 'reset') {
        resetAccountForm();
        return;
    }

    event.preventDefault();
    if (action === 'test') {
        testAccountConnection(
            parseInt(trigger.getAttribute('data-account-id') || '0', 10) || 0,
            trigger.getAttribute('data-registrar-code') || ''
        );
    } else if (action === 'edit') {
        try {
            editAccount(JSON.parse(trigger.getAttribute('data-account-payload') || '{}'));
        } catch (e) {
            showToast('<?= __('请求失败') ?>', 'error');
        }
    } else if (action === 'remove') {
        removeAccount(parseInt(trigger.getAttribute('data-account-id') || '0', 10) || 0);
    } else if (action === 'save') {
        saveAccount();
    }
});

var registrarSelect = document.getElementById('form-registrar-code');
if (registrarSelect) {
    registrarSelect.addEventListener('change', function() {
        onRegistrarChange(this.value);
    });
}

})();
</script>
