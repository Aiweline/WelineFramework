    function loadDnsRecords(domainId) {
        var tbody = document.getElementById('weline-dns-records-body');
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4"><i class="mdi mdi-loading mdi-spin"></i></td></tr>';

        fetch(urls.dnsRecords + '?domain_id=' + domainId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    var providerBadge = document.getElementById('weline-dns-provider-badge');
                    providerBadge.textContent = data.data.dns_provider_name || data.data.dns_provider || '-';
                    providerBadge.className = 'weline-domain-dns-provider';
                    if (data.data.dns_provider === 'cloudflare') {
                        providerBadge.classList.add('weline-domain-dns-cloudflare');
                    } else if (data.data.is_original_provider) {
                        providerBadge.classList.add('weline-domain-dns-original');
                    } else {
                        providerBadge.classList.add('weline-domain-dns-other');
                    }

                    document.getElementById('weline-dns-server-ip').textContent = data.data.server_ip || '-';

                    renderDnsRecords(data.data.records || []);
                } else {
                    toast(data.msg || '<?= __('获取DNS记录失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4"><?= __('获取失败') ?></td></tr>';
                }
            })
            .catch(function() {
                toast('<?= __('请求失败') ?>', 'error');
            });
