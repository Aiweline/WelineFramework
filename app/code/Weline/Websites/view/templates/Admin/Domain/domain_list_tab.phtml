    function cleanupDnsProviderDomains() {
        if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
            BackendConfirm.show('<?= __('确定清理所有 DNS 服务商（如 Cloudflare）下误同步的域名？') ?>\n\n<?= __('这些域名不属于 DNS 服务商，只是托管在那里。清理后不会影响远程数据。') ?>', {
                title: '<?= __('清理 DNS 服务商域名') ?>',
                confirmText: '<?= __('确认清理') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    doCleanupDnsProviderDomains();
                }
            });
        } else {
            doCleanupDnsProviderDomains();
        }
