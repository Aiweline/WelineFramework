<script>
(function() {
    'use strict';

    var currentPage = 1;
    var pageSize = 20;
    var currentDomainId = null;
    var currentDomain = null;

    var urls = {
        domainList: '<?= $this->getUrl('*/admin/domain/get-domain-list') ?>',
        remoteDomains: '<?= $this->getUrl('*/admin/domain/get-remote-domains') ?>',
        importDomains: '<?= $this->getUrl('*/admin/domain/import-domains') ?>',
        checkResolve: '<?= $this->getUrl('*/admin/domain/check-resolve') ?>',
        batchCheckResolve: '<?= $this->getUrl('*/admin/domain/batch-check-resolve') ?>',
        autoResolve: '<?= $this->getUrl('*/admin/domain/auto-resolve') ?>',
        dnsRecords: '<?= $this->getUrl('*/admin/domain/get-dns-records') ?>',
        syncDnsRecords: '<?= $this->getUrl('*/admin/domain/sync-dns-records') ?>',
        addDnsRecord: '<?= $this->getUrl('*/admin/domain/add-dns-record') ?>',
        deleteDnsRecord: '<?= $this->getUrl('*/admin/domain/delete-dns-record') ?>',
        refreshServerIp: '<?= $this->getUrl('*/admin/domain/refresh-server-ip') ?>',
        transferToPool: '<?= $this->getUrl('*/admin/domain/transfer-to-pool') ?>',
        batchTransferToPool: '<?= $this->getUrl('*/admin/domain/batch-transfer-to-pool') ?>',
        batchTransferToPoolWithIpCheck: '<?= $this->getUrl('*/admin/domain/batch-transfer-to-pool-with-ip-check') ?>',
        batchResolveToLocal: '<?= $this->getUrl('*/admin/domain/batch-resolve-to-local') ?>',
        batchChangeNameservers: '<?= $this->getUrl('*/admin/domain/batch-change-nameservers') ?>',
        getRegistrarAccounts: '<?= $this->getUrl('*/admin/domain/get-registrar-accounts') ?>',
        getAccountNameservers: '<?= $this->getUrl('*/admin/domain/get-account-nameservers') ?>',
        batchSwitchToAccount: '<?= $this->getUrl('*/admin/domain/batch-switch-to-account') ?>',
        batchAddDnsRecords: '<?= $this->getUrl('*/admin/domain/batch-add-dns-records') ?>',
        detectDnsProvider: '<?= $this->getUrl('*/admin/domain/detect-dns-provider') ?>',
        cleanupDnsProviderDomains: '<?= $this->getUrl('*/admin/domain/cleanup-dns-provider-domains') ?>',
        batchSetAccounts: '<?= $this->getUrl('*/admin/domain/batch-set-accounts') ?>',
        getDnsAccounts: '<?= $this->getUrl('*/admin/domain/get-dns-accounts') ?>',
        createManualDomain: '<?= $this->getUrl('*/admin/domain/create-manual-domain') ?>',
        switchDnsAccount: '<?= $this->getUrl('*/admin/domain/switch-dns-account') ?>',
        dnsSwitchSse: '<?= $this->getUrl('*/admin/domain/dns-switch-sse') ?>',
        deleteDomains: '<?= $this->getUrl('*/admin/domain/delete-domains') ?>'
    };

    var importModal = null;
    var remoteDomainData = [];
    var hideImported = false;
    var pendingImportByAccount = {};
    var registrarAccountOptions = <?= $registrarAccountOptionsJson ?>;
    var manualNsProviderOptions = <?= $manualNsProviderOptionsJson ?>;

    function normalizeRegistrarOptions(items) {
        return (Array.isArray(items) ? items : []).map(function (item) {
            return {
                value: String(item && item.value !== undefined ? item.value : ''),
                label: String(item && item.label !== undefined ? item.label : (item && item.value !== undefined ? item.value : '')),
                group: String(item && item.group !== undefined ? item.group : ''),
                meta: String(item && item.meta !== undefined ? item.meta : ''),
                raw: item || null
            };
        }).filter(function (item) {
            return item.value !== '';
        });
    }

    function buildRegistrarAccountOptions(items, extraOptions) {
        var normalized = (Array.isArray(extraOptions) ? extraOptions.slice() : []);
        (Array.isArray(items) ? items : []).forEach(function (item) {
            var value = item && (item.account_id !== undefined ? item.account_id : item.id);
            if (value === undefined || value === null || value === '') {
                return;
            }
            var accountName = String(item.name || item.account_name || '');
            var registrarName = String(item.registrar_name || item.registrar_code || '');
            normalized.push({
                value: String(value),
                label: accountName !== '' ? accountName + (registrarName !== '' ? ' (' + registrarName + ')' : '') : registrarName,
                group: registrarName,
                meta: String(item.registrar_code || '')
            });
        });
        return normalized;
    }

    function buildRegistrarProviderOptions(items, extraOptions, defaultGroupLabel) {
        var normalized = (Array.isArray(extraOptions) ? extraOptions.slice() : []);
        (Array.isArray(items) ? items : []).forEach(function (item) {
            var value = item && (item.value !== undefined ? item.value : (item.code !== undefined ? item.code : ''));
            if (value === undefined || value === null || value === '') {
                return;
            }
            normalized.push({
                value: String(value),
                label: String(item.label || item.name || item.registrar_name || item.registrar_code || value),
                group: String(item.group || defaultGroupLabel || ''),
                meta: String(item.meta || item.registrar_code || value)
            });
        });
        return normalized;
    }

    function ensureRegistrarSelectInstance(id, onSelectFnName) {
        window.WelineRegistrarSelect = window.WelineRegistrarSelect || {};
        if (window.WelineRegistrarSelect[id]) {
            return window.WelineRegistrarSelect[id];
        }

        var wrapper = document.getElementById(id + '_wrapper');
        var trigger = document.getElementById(id + '_trigger');
        var dropdown = document.getElementById(id + '_dropdown');
        var search = document.getElementById(id + '_search');
        var list = document.getElementById(id + '_list');
        var tags = document.getElementById(id + '_tags');
        var hidden = document.getElementById(id + '_value');
        var multiple = wrapper && String(wrapper.getAttribute('data-multiple') || '').toLowerCase() === 'true';
        var emptyLabel = tags && tags.textContent ? tags.textContent.trim() : '';
        var selected = [];
        var options = [];

        if (!wrapper || !trigger || !dropdown || !search || !list || !tags || !hidden) {
            return null;
        }

        function readInitialSelection() {
            return String(hidden.value || '').split(',').map(function (value) {
                return value.trim();
            }).filter(Boolean);
        }

        function isPicked(value) {
            return selected.indexOf(String(value)) > -1;
        }

        function syncHidden() {
            hidden.value = selected.join(',');
        }

        function getSelected() {
            return selected.map(function (value) {
                return options.find(function (item) {
                    return item.value === value;
                }) || { value: value, label: value, group: '', meta: '', raw: null };
            });
        }

        function emitChange(item) {
            try {
                hidden.dispatchEvent(new Event('change', { bubbles: true }));
            } catch (error) {
            }

            if (onSelectFnName && typeof window[onSelectFnName] === 'function') {
                window[onSelectFnName](item || null, { selected: selected.slice() });
            }
        }

        function renderTags() {
            tags.innerHTML = '';
            if (selected.length === 0) {
                var placeholder = document.createElement('span');
                placeholder.id = id + '_display';
                placeholder.textContent = emptyLabel;
                tags.appendChild(placeholder);
                return;
            }

            selected.forEach(function (value) {
                var item = options.find(function (option) {
                    return option.value === value;
                });
                if (!item) {
                    return;
                }

                if (!multiple) {
                    var display = document.createElement('span');
                    display.id = id + '_display';
                    display.textContent = item.label;
                    tags.appendChild(display);
                    return;
                }

                var tag = document.createElement('span');
                tag.className = 'weline-registrar-tag';
                tag.textContent = item.label;
                tags.appendChild(tag);
            });
        }

        function renderList(keyword) {
            var normalizedKeyword = String(keyword || '').trim().toLowerCase();
            var filtered = options.filter(function (item) {
                return !normalizedKeyword
                    || item.label.toLowerCase().indexOf(normalizedKeyword) > -1
                    || item.group.toLowerCase().indexOf(normalizedKeyword) > -1
                    || item.meta.toLowerCase().indexOf(normalizedKeyword) > -1;
            });

            if (filtered.length === 0) {
                list.innerHTML = '<div class="weline-registrar-empty">' + escapeOptLabel('No matching account') + '</div>';
                return;
            }

            var grouped = {};
            filtered.forEach(function (item) {
                var groupKey = item.group || 'default';
                if (!grouped[groupKey]) {
                    grouped[groupKey] = [];
                }
                grouped[groupKey].push(item);
            });

            var html = '';
            Object.keys(grouped).forEach(function (groupKey) {
                if (groupKey !== 'default') {
                    html += '<div class="weline-registrar-group">' + escapeOptLabel(groupKey) + '</div>';
                }
                grouped[groupKey].forEach(function (item) {
                    var meta = item.meta ? '<div class="weline-registrar-item-meta">' + escapeOptLabel(item.meta) + '</div>' : '';
                    html += '<div class="weline-registrar-item' + (isPicked(item.value) ? ' active' : '') + '" data-value="' + escapeOptLabel(item.value) + '"><div>' + escapeOptLabel(item.label) + '</div>' + meta + '</div>';
                });
            });

            list.innerHTML = html;
            Array.prototype.slice.call(list.querySelectorAll('.weline-registrar-item')).forEach(function (element) {
                element.addEventListener('click', function () {
                    var value = this.getAttribute('data-value') || '';
                    var pickedItem = options.find(function (option) {
                        return option.value === value;
                    }) || null;
                    if (!value) {
                        return;
                    }

                    selected = multiple
                        ? (isPicked(value) ? selected.filter(function (picked) { return picked !== value; }) : selected.concat(value))
                        : [value];
                    dropdown.style.display = multiple ? 'block' : 'none';
                    syncHidden();
                    renderTags();
                    renderList(search.value || '');
                    emitChange(pickedItem);
                });
            });
        }

        function setOptions(nextOptions) {
            options = normalizeRegistrarOptions(nextOptions);
            selected = selected.filter(function (value) {
                return options.some(function (item) {
                    return item.value === value;
                });
            });
            if (!multiple && selected.length > 1) {
                selected = selected.slice(0, 1);
            }
            syncHidden();
            renderTags();
            renderList(search.value || '');
        }

        function setValue(value, emitEvent) {
            var values = Array.isArray(value) ? value.map(String) : String(value || '').split(',').map(function (item) {
                return item.trim();
            }).filter(Boolean);
            selected = multiple ? values : (values[0] ? [values[0]] : []);
            syncHidden();
            renderTags();
            renderList(search.value || '');
            if (emitEvent !== false) {
                emitChange(getSelected()[0] || null);
            }
        }

        trigger.addEventListener('click', function (event) {
            event.stopPropagation();
            dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
            if (dropdown.style.display === 'block') {
                renderList(search.value || '');
                search.focus();
            }
        });

        search.addEventListener('input', function () {
            renderList(search.value || '');
        });

        document.addEventListener('click', function (event) {
            if (!wrapper.contains(event.target)) {
                dropdown.style.display = 'none';
            }
        });

        selected = readInitialSelection();
        window.WelineRegistrarSelect[id] = {
            setOptions: setOptions,
            setValue: function (value) {
                setValue(value, true);
            },
            getValue: function () {
                return String(hidden.value || '');
            },
            getValues: function () {
                return selected.slice();
            },
            getSelected: getSelected
        };

        return window.WelineRegistrarSelect[id];
    }

    function getRegistrarSelectValue(id) {
        var instance = ensureRegistrarSelectInstance(id);
        if (instance && typeof instance.getValue === 'function') {
            return String(instance.getValue() || '');
        }
        var hidden = document.getElementById(id + '_value');
        return hidden ? String(hidden.value || '') : '';
    }

    function setRegistrarSelectValue(id, value, onSelectFnName) {
        var instance = ensureRegistrarSelectInstance(id, onSelectFnName);
        if (instance && typeof instance.setValue === 'function') {
            instance.setValue(String(value || ''));
            return;
        }
        var hidden = document.getElementById(id + '_value');
        if (hidden) {
            hidden.value = String(value || '');
        }
    }

    function setRegistrarSelectOptions(id, options, onSelectFnName) {
        var instance = ensureRegistrarSelectInstance(id, onSelectFnName);
        if (instance && typeof instance.setOptions === 'function') {
            instance.setOptions(Array.isArray(options) ? options : []);
        }
    }

    window.handleDomainFilterAccountChange = function () {
        if (window.WelineDomainList && typeof window.WelineDomainList.loadDomains === 'function') {
            window.WelineDomainList.loadDomains(1);
        }
    };

    window.handleImportAccountChange = function () {
        if (window.WelineDomainList && typeof window.WelineDomainList.fetchRemoteDomains === 'function') {
            window.WelineDomainList.fetchRemoteDomains();
        }
    };

    window.handleBatchNsAccountChange = function () {
        if (window.WelineDomainList && typeof window.WelineDomainList.onNsAccountChange === 'function') {
            window.WelineDomainList.onNsAccountChange();
        }
    };

    window.handleSwitchDnsProviderChange = function () {
        if (window.WelineDomainList && typeof window.WelineDomainList.onSwitchDnsProviderChange === 'function') {
            window.WelineDomainList.onSwitchDnsProviderChange();
        }
    };

    function hydrateStaticRegistrarSelects() {
        setRegistrarSelectOptions('weline-domain-filter-account', registrarAccountOptions, 'handleDomainFilterAccountChange');
        setRegistrarSelectOptions('weline-import-account-select', registrarAccountOptions, 'handleImportAccountChange');
        setRegistrarSelectOptions('weline-batch-ns-provider', manualNsProviderOptions, 'handleBatchNsProviderChange');
    }

    hydrateStaticRegistrarSelects();

    function escapeOptLabel(s) {
        if (!s) return '';
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
    }

    function loadImportDnsCdnSelects(callback) {
        fetch(urls.getDnsAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!document.getElementById('weline-import-bind-dns_wrapper') || !document.getElementById('weline-import-bind-cdn_wrapper')) {
                    if (callback) callback();
                    return;
                }
                var extraOptions = [{ value: '0', label: '<?= addslashes((string)__('不指定')) ?>', group: '', meta: '' }];
                if (data.code === 200 && data.data) {
                    setRegistrarSelectOptions('weline-import-bind-dns', buildRegistrarAccountOptions(data.data.dns_accounts || [], extraOptions), null);
                    setRegistrarSelectOptions('weline-import-bind-cdn', buildRegistrarAccountOptions(data.data.cdn_accounts || [], extraOptions), null);
                    setRegistrarSelectValue('weline-import-bind-dns', '0', null);
                    setRegistrarSelectValue('weline-import-bind-cdn', '0', null);
                }
                if (callback) callback();
            })
            .catch(function() {
                if (callback) callback();
            });
    }

    function runImportWithBinding(domainsByAccount, bindDns, bindCdn, resolveMode) {
        var accountIds = Object.keys(domainsByAccount);
        var importedCount = 0;
        var totalCount = 0;
        accountIds.forEach(function(aid) {
            totalCount += (domainsByAccount[aid] || []).length;
        });
        var errors = [];
        var done = 0;

        accountIds.forEach(function(accountId) {
            var domains = domainsByAccount[accountId];
            var fd = new FormData();
            fd.append('account_id', accountId);
            fd.append('resolve_mode', resolveMode);
            fd.append('bind_dns_account_id', String(bindDns));
            fd.append('bind_cdn_account_id', String(bindCdn));
            domains.forEach(function(d) { fd.append('domains[]', d); });

            fetch(urls.importDomains, { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.code === 200) {
                        importedCount += domains.length;
                    } else {
                        errors.push(data.msg || '<?= __('导入失败') ?>');
                    }
                })
                .catch(function() {
                    errors.push('<?= __('请求失败') ?>');
                })
                .finally(function() {
                    done++;
                    if (done >= accountIds.length) {
                        if (errors.length > 0) {
                            toast('<?= __('部分导入失败') ?>: ' + errors.join(', '), 'warning');
                        } else {
                            toast('<?= __('导入成功') ?> ' + importedCount + ' <?= __('个域名') ?>', 'success');
                        }
                        autoFetchTriggered = false;
                        remoteDomainsDisplayMode = false;
                        var tw = document.querySelector('#weline-domain-list-body');
                        if (tw && tw.closest('.table-responsive') && tw.closest('.table-responsive').parentElement) {
                            tw.closest('.table-responsive').parentElement.querySelectorAll('.alert').forEach(function(el) { el.remove(); });
                        }
                        loadDomains(1);
                    }
                });
        });
    }

    function toast(msg, type) {
        if (typeof BackendToast !== 'undefined') {
            BackendToast[type] ? BackendToast[type](msg) : BackendToast.info(msg);
        } else if (typeof showToast !== 'undefined') {
            showToast(msg, type);
        } else {
            console.log('[' + type + '] ' + msg);
        }
    }

    function getFilters() {
        return {
            account_id: getRegistrarSelectValue('weline-domain-filter-account'),
            resolve_status: document.getElementById('weline-domain-filter-resolve').value,
            https_status: document.getElementById('weline-domain-filter-https').value,
            search: document.getElementById('weline-domain-filter-search').value
        };
    }

    function loadDomains(page) {
        currentPage = page || 1;
        var filters = getFilters();
        var params = new URLSearchParams({
            page: currentPage,
            page_size: pageSize,
            account_id: filters.account_id,
            resolve_status: filters.resolve_status,
            https_status: filters.https_status,
            search: filters.search
        });

        var tbody = document.getElementById('weline-domain-list-body');
        tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty"><i class="mdi mdi-loading mdi-spin" style="font-size:2rem;"></i><p class="mt-2 mb-0"><?= __('加载中...') ?></p></td></tr>';

        fetch(urls.domainList + '?' + params.toString())
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    var d = data.data || {};
                    var items = d.items || [];
                    // API 返回 total/page/pages/limit，与 pagination 嵌套结构二选一兼容
                    var pagination = d.pagination && typeof d.pagination === 'object' ? d.pagination : {
                        total: d.total || 0,
                        current_page: d.page || 1,
                        last_page: d.pages || 1,
                        page_size: d.limit || pageSize
                    };
                    // 检查是否有筛选条件
                    var hasFilters = filters.account_id || filters.resolve_status || filters.https_status || filters.search;
                    // 仅在首次加载（第1页，无筛选条件）且本地无数据时自动获取远程域名
                    var shouldAutoFetch = (currentPage === 1 && !hasFilters && items.length === 0);
                    renderDomainList(items, shouldAutoFetch, hasFilters);
                    renderPagination(pagination);
                } else {
                    toast(data.msg || '<?= __('加载失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty"><i class="mdi mdi-alert-circle-outline" style="font-size:2rem;color:var(--backend-color-danger);"></i><p class="mt-2 mb-0">' + (data.msg || '<?= __('加载失败') ?>') + '</p></td></tr>';
                }
            })
            .catch(function(err) {
                toast('<?= __('请求失败') ?>', 'error');
                tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty"><i class="mdi mdi-alert-circle-outline" style="font-size:2rem;color:var(--backend-color-danger);"></i><p class="mt-2 mb-0"><?= __('请求失败') ?></p></td></tr>';
            });
    }

    var autoFetchTriggered = false;
    var allRemoteDomainsCache = [];
    var remoteDomainsDisplayMode = false;

    /**
     * 从所有账户获取远程域名并显示
     * 当本地没有已拉取的域名时，自动调用此函数
     */
    function loadRemoteDomainsForDisplay() {
        var accounts = <?= json_encode(array_map(function($a) { return ['id' => (int)($a['account_id'] ?? 0), 'name' => $a['account_name'] ?? '']; }, $accounts)) ?>;
        
        if (accounts.length === 0) {
            var tbody = document.getElementById('weline-domain-list-body');
            tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty">' +
                '<i class="mdi mdi-account-off-outline" style="font-size:2rem;"></i>' +
                '<p class="mt-2 mb-0"><?= __('请先添加域名商账户') ?></p></td></tr>';
            return;
        }

        allRemoteDomainsCache = [];
        remoteDomainsDisplayMode = true;
        var fetchedCount = 0;
        var totalAccounts = accounts.length;

        // 收集供应商错误
        var providerErrors = [];

        // 并行获取所有账户的远程域名
        accounts.forEach(function(acc) {
            if (!acc.id) {
                fetchedCount++;
                checkAllFetched();
                return;
            }
            fetch(urls.remoteDomains + '?account_id=' + acc.id)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.code === 200 && data.data && data.data.domains) {
                        data.data.domains.forEach(function(d) {
                            d._account_id = acc.id;
                            d._account_name = acc.name;
                            allRemoteDomainsCache.push(d);
                        });
                    } else if (data.code !== 200 || data.msg) {
                        // 记录供应商返回的错误
                        providerErrors.push({
                            account: acc.name || ('ID:' + acc.id),
                            error: data.msg || '<?= __('未知错误') ?>'
                        });
                    }
                })
                .catch(function(err) {
                    // 记录网络或解析错误
                    providerErrors.push({
                        account: acc.name || ('ID:' + acc.id),
                        error: err.message || '<?= __('网络请求失败') ?>'
                    });
                })
                .finally(function() {
                    fetchedCount++;
                    checkAllFetched();
                });
        });

        function checkAllFetched() {
            if (fetchedCount >= totalAccounts) {
                renderRemoteDomainsForDisplay(allRemoteDomainsCache, providerErrors);
            }
        }
    }

    /**
     * 渲染远程域名列表（未拉取状态）
     * @param {Array} domains - 域名列表
     * @param {Array} providerErrors - 供应商错误列表 [{account, error}]
     */
    function renderRemoteDomainsForDisplay(domains, providerErrors) {
        var tbody = document.getElementById('weline-domain-list-body');
        var tableWrapper = tbody.closest('.table-responsive');
        
        // 移除旧的提示框
        var existingAlerts = tableWrapper.parentElement.querySelectorAll('.alert');
        existingAlerts.forEach(function(el) { el.remove(); });
        
        // 显示供应商错误（如果有）
        if (providerErrors && providerErrors.length > 0) {
            var errorHtml = '<div class="alert alert-danger mb-3">' +
                '<div class="d-flex align-items-center mb-2">' +
                '<i class="mdi mdi-alert-circle me-2" style="font-size:1.2rem;"></i>' +
                '<strong><?= __('部分供应商获取域名失败') ?></strong></div>' +
                '<ul class="mb-0 ps-4">';
            providerErrors.forEach(function(e) {
                errorHtml += '<li><strong>' + (e.account || '<?= __('未知账户') ?>') + '</strong>: ' + (e.error || '<?= __('未知错误') ?>') + '</li>';
            });
            errorHtml += '</ul></div>';
            tableWrapper.insertAdjacentHTML('beforebegin', errorHtml);
        }
        
        if (!domains.length) {
            var emptyMsg = (providerErrors && providerErrors.length > 0)
                ? '<?= __('无法获取域名，请检查上方的错误信息') ?>'
                : '<?= __('域名商账户下暂无域名') ?>';
            tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty">' +
                '<i class="mdi mdi-earth-off" style="font-size:2rem;"></i>' +
                '<p class="mt-2 mb-0">' + emptyMsg + '</p></td></tr>';
            renderPagination({});
            return;
        }

        // 显示提示信息
        var infoHtml = '<div class="alert alert-info mb-3 d-flex align-items-center justify-content-between">' +
            '<span><i class="mdi mdi-information-outline me-2"></i><?= __('以下域名尚未拉取到本地，请选择域名后点击「导入选中」按钮') ?></span>' +
            '<button type="button" class="btn btn-primary btn-sm" onclick="WelineDomainList.importSelectedRemoteDomains()">' +
            '<i class="mdi mdi-import me-1"></i><?= __('导入选中') ?></button></div>';
        
        // 在表格前插入提示
        tableWrapper.insertAdjacentHTML('beforebegin', infoHtml);

        var html = '';
        domains.forEach(function(d) {
            var statusClass = d.status === 'active' ? 'weline-domain-status-resolved' : 'weline-domain-status-pending';
            var statusText = d.status === 'active' ? '<?= __('正常') ?>' : (d.status || '-');
            var localBadge = d.is_local
                ? '<span class="badge bg-success"><?= __('已拉取') ?></span>'
                : '<span class="badge bg-secondary"><?= __('未拉取') ?></span>';

            html += '<tr data-domain="' + (d.domain || '') + '" data-account-id="' + (d._account_id || '') + '">' +
                '<td><input type="checkbox" class="weline-remote-domain-checkbox" value="' + (d.domain || '') + '" data-account-id="' + (d._account_id || '') + '"' + (d.is_local ? ' disabled' : '') + '></td>' +
                '<td><span class="domain-name">' + (d.domain || '') + '</span></td>' +
                '<td><span class="badge bg-primary">' + (d._account_name || '-') + '</span></td>' +
                '<td><span class="weline-domain-status-badge ' + statusClass + '">' + statusText + '</span></td>' +
                '<td>' + (d.expires_at || '-') + '</td>' +
                '<td>' + localBadge + '</td>' +
                '<td>-</td>' +
                '<td class="text-end weline-domain-actions">' +
                    (d.is_local ? '-' : '<button type="button" class="btn btn-outline-primary btn-sm" title="<?= __('导入') ?>" onclick="WelineDomainList.importSingleRemoteDomain(\'' + (d.domain || '').replace(/'/g, "\\'") + '\', ' + (d._account_id || 0) + ')"><i class="mdi mdi-import"></i></button>') +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;

        // 更新分页信息
        var paginationInfo = document.getElementById('weline-domain-pagination-info');
        paginationInfo.textContent = '<?= __('共') ?> ' + domains.length + ' <?= __('个远程域名') ?>';
        document.getElementById('weline-domain-pagination-links').innerHTML = '';
    }

    /**
     * 导入选中的远程域名
     */
    function importSelectedRemoteDomains() {
        var checkboxes = document.querySelectorAll('.weline-remote-domain-checkbox:checked');
        if (checkboxes.length === 0) {
            toast('<?= __('请选择要导入的域名') ?>', 'warning');
            return;
        }

        pendingImportByAccount = {};
        checkboxes.forEach(function(cb) {
            var accountId = cb.dataset.accountId;
            if (!pendingImportByAccount[accountId]) {
                pendingImportByAccount[accountId] = [];
            }
            pendingImportByAccount[accountId].push(cb.value);
        });

        var hint = document.getElementById('weline-import-bind-hint');
        if (hint) { hint.classList.add('d-none'); }
        loadImportDnsCdnSelects(function() {
            var el = document.getElementById('weline-import-domain-modal');
            if (el && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                importModal = new bootstrap.Modal(el);
                importModal.show();
            }
        });
    }

    /**
     * 导入单个远程域名
     */
    function importSingleRemoteDomain(domain, accountId) {
        pendingImportByAccount = {};
        pendingImportByAccount[String(accountId)] = [domain];
        var hint = document.getElementById('weline-import-bind-hint');
        if (hint) { hint.classList.add('d-none'); }
        loadImportDnsCdnSelects(function() {
            var el = document.getElementById('weline-import-domain-modal');
            if (el && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                importModal = new bootstrap.Modal(el);
                importModal.show();
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('weline-import-confirm-btn');
        if (!btn) return;
        btn.addEventListener('click', function() {
            var dns = parseInt(getRegistrarSelectValue('weline-import-bind-dns'), 10) || 0;
            var cdn = parseInt(getRegistrarSelectValue('weline-import-bind-cdn'), 10) || 0;
            var hintEl = document.getElementById('weline-import-bind-hint');
            if (dns <= 0 && cdn <= 0) {
                if (hintEl) hintEl.classList.remove('d-none');
                return;
            }
            if (hintEl) hintEl.classList.add('d-none');
            var modeEl = document.querySelector('input[name="weline-import-resolve-mode"]:checked');
            var mode = modeEl ? modeEl.value : 'batch_to_local';
            var elModal = document.getElementById('weline-import-domain-modal');
            if (elModal && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                var inst = bootstrap.Modal.getInstance(elModal);
                if (inst) inst.hide();
            }
            runImportWithBinding(pendingImportByAccount, dns, cdn, mode);
            var singleRemote = Object.keys(pendingImportByAccount).length === 1 &&
                pendingImportByAccount[Object.keys(pendingImportByAccount)[0]].length === 1;
            if (singleRemote && typeof loadRemoteDomainsForDisplay === 'function') {
                setTimeout(function() { loadRemoteDomainsForDisplay(); }, 800);
            }
        });
    });

    function renderDomainList(items, autoFetchRemote, hasFilters) {
        var tbody = document.getElementById('weline-domain-list-body');
        
        // 先移除可能存在的所有提示条（包括错误和信息提示）
        var tableWrapper = tbody.closest('.table-responsive');
        if (tableWrapper && tableWrapper.parentElement) {
            var existingAlerts = tableWrapper.parentElement.querySelectorAll('.alert');
            existingAlerts.forEach(function(el) { el.remove(); });
        }
        
        if (!items.length) {
            // 如果有筛选条件且没有数据，提示用户切换到全部状态
            if (hasFilters) {
                tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty">' +
                    '<i class="mdi mdi-cloud-download-outline" style="font-size:2rem;color:var(--backend-color-primary);"></i>' +
                    '<p class="mt-2 mb-1"><?= __('当前筛选条件下暂无已拉取的域名') ?></p>' +
                    '<p class="text-muted small mb-2"><?= __('请切换筛选条件为「全部」，从线上选择域名拉取到本地') ?></p>' +
                    '<button type="button" class="btn btn-primary btn-sm" onclick="WelineDomainList.resetFilters()">' +
                    '<i class="mdi mdi-filter-off me-1"></i><?= __('查看全部状态') ?></button></td></tr>';
                return;
            }
            // 如果本地没有域名且允许自动拉取，则自动获取远程域名
            if (autoFetchRemote && !autoFetchTriggered) {
                autoFetchTriggered = true;
                tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty">' +
                    '<i class="mdi mdi-cloud-download-outline" style="font-size:2rem;color:var(--backend-color-primary);"></i>' +
                    '<p class="mt-2 mb-0"><?= __('本地暂无已拉取的域名，正在从域名商获取...') ?></p></td></tr>';
                loadRemoteDomainsForDisplay();
                return;
            }
            tbody.innerHTML = '<tr><td colspan="5" class="weline-domain-empty"><i class="mdi mdi-earth-off" style="font-size:2rem;"></i><p class="mt-2 mb-0"><?= __('暂无域名数据') ?></p></td></tr>';
            return;
        }
        autoFetchTriggered = false;
        remoteDomainsDisplayMode = false;

        var html = '';
        items.forEach(function(item) {
            var resolveClass = 'weline-domain-status-pending';
