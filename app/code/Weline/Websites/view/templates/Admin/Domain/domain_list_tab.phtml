                var accounts = data.data.dns_accounts;
                var seen = {};
                var providers = [];
                accounts.forEach(function (acc) {
                    var code = acc.registrar_code || '';
                    if (code && !seen[code]) {
                        seen[code] = true;
                        providers.push({ code: code, name: acc.registrar_name || code });
                    }
                });
                switchDnsAccountCache = { providers: providers, accounts: accounts };

                setRegistrarSelectOptions(
                    'weline-switch-dns-provider',
                    buildRegistrarProviderOptions(providers, [], '<?= addslashes((string)__('服务商')) ?>'),
                    'handleSwitchDnsProviderChange'
                );
