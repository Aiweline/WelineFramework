                resolveClass = 'weline-domain-status-resolved';
                resolveText = '<?= __('已解析') ?>';
            } else if (item.resolve_status === 'unresolved') {
                resolveClass = 'weline-domain-status-unresolved';
                resolveText = '<?= __('未解析') ?>';
            } else if (item.resolve_status === 'error') {
                resolveClass = 'weline-domain-status-error';
                resolveText = '<?= __('错误') ?>';
            }

            var httpsClass = 'weline-domain-https-none';
            var httpsText = '<?= __('无') ?>';
            if (item.https_status === 'valid') {
                httpsClass = 'weline-domain-https-valid';
                httpsText = '<?= __('有效') ?>';
            } else if (item.https_status === 'expiring') {
                httpsClass = 'weline-domain-https-expiring';
                httpsText = '<?= __('即将过期') ?>';
            } else if (item.https_status === 'expired') {
                httpsClass = 'weline-domain-status-error';
                httpsText = '<?= __('已过期') ?>';
            }

            var localBadge = item.is_local_server ? '<span class="weline-domain-local-badge"><?= __('本机') ?></span>' : '';
            var siteReady = item.site_ready
                ? '<span class="badge bg-success-subtle text-success"><i class="mdi mdi-check-circle-outline me-1"></i><?= __('可建站') ?></span>'
                : '<span class="badge bg-secondary-subtle text-secondary"><i class="mdi mdi-clock-outline me-1"></i><?= __('未就绪') ?></span>';
            var siteCreated = (item.site_created === 1 || item.site_created === true)
                ? '<span class="badge bg-info-subtle text-info"><i class="mdi mdi-earth me-1"></i><?= __('已建站') ?></span>'
                : '<span class="badge bg-secondary-subtle text-secondary"><i class="mdi mdi-earth-off me-1"></i><?= __('未建站') ?></span>';
            var connDetail = (item.connectivity_detail || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            var connTitle = connDetail || (item.connectivity_checked_at ? ('<?= __('检测于') ?> ' + (item.connectivity_checked_at || '')) : '<?= __('待检测') ?>');
            var connCell = '<span class="badge bg-light text-muted" title="' + connTitle + '"><i class="mdi mdi-radar me-1" aria-hidden="true"></i><?= __('连通性') ?></span>';

            // 构建服务商列（三行：注册商、DNS、CDN）
            var registrarName = item.registrar_name || item.account_name || '-';
