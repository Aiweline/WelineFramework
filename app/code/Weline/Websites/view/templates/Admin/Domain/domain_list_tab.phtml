    function onSwitchDnsProviderChange() {
        var provider = getRegistrarSelectValue('weline-switch-dns-provider');
        if (!provider || !switchDnsAccountCache.accounts) {
            setRegistrarSelectOptions('weline-switch-dns-account', [], null);
            setRegistrarSelectValue('weline-switch-dns-account', '', null);
            return;
        }

        var accounts = (switchDnsAccountCache.accounts || []).filter(function (acc) {
            return String(acc.registrar_code || '') === provider;
        });
        setRegistrarSelectOptions('weline-switch-dns-account', buildRegistrarAccountOptions(accounts, []), null);
        setRegistrarSelectValue('weline-switch-dns-account', '', null);
    }

    function loadDnsAccountsForBatchSet() {
        fetch(urls.getDnsAccounts)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.code === 200 && data.data) {
                    var dnsExtra = [{ value: '0', label: '<?= addslashes((string)__('清除（使用注册商账户）')) ?>', group: '', meta: '' }];
                    var cdnExtra = [{ value: '0', label: '<?= addslashes((string)__('清除')) ?>', group: '', meta: '' }];

                    setRegistrarSelectOptions('weline-batch-set-dns-account', buildRegistrarAccountOptions(data.data.dns_accounts || [], dnsExtra), null);
                    setRegistrarSelectOptions('weline-batch-set-cdn-account', buildRegistrarAccountOptions(data.data.cdn_accounts || [], cdnExtra), null);
                    setRegistrarSelectValue('weline-batch-set-dns-account', '', null);
                    setRegistrarSelectValue('weline-batch-set-cdn-account', '', null);
                }
            })
            .catch(function () {
                toast('<?= __('鍔犺浇璐︽埛鍒楄〃澶辫触') ?>', 'error');
            });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { loadDomains(1); });
    } else {
        loadDomains(1);
    }
})();
</script>
