    function fetchRemoteDomains() {
        var accountId = getRegistrarSelectValue('weline-import-account-select');
        var tbody = document.getElementById('weline-import-domain-list');

        if (!accountId) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4"><?= __('请选择域名商账户') ?></td></tr>';
            remoteDomainData = [];
            updateImportCount();
            return;
        }

        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4"><i class="mdi mdi-loading mdi-spin" style="font-size:1.5rem;"></i><p class="mt-2 mb-0"><?= __('正在获取远程域名列表...') ?></p></td></tr>';

        fetch(urls.remoteDomains + '?account_id=' + accountId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    remoteDomainData = data.data.domains || [];
                    renderImportDomainList();
                    toast(data.msg || '<?= __('获取成功') ?>', 'success');
                } else {
                    toast(data.msg || '<?= __('获取失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">' + (data.msg || '<?= __('获取失败') ?>') + '</td></tr>';
                    remoteDomainData = [];
                }
                updateImportCount();
            })
            .catch(function() {
                toast('<?= __('请求失败') ?>', 'error');
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4"><?= __('请求失败') ?></td></tr>';
                remoteDomainData = [];
                updateImportCount();
            });
    }

    function renderImportDomainList() {
        var tbody = document.getElementById('weline-import-domain-list');
        var domains = remoteDomainData;

        if (hideImported) {
            domains = domains.filter(function(d) { return !d.is_local; });
        }

        if (domains.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">' + (hideImported ? '<?= __('所有域名已导入') ?>' : '<?= __('没有域名') ?>') + '</td></tr>';
            return;
        }

        var html = '';
        domains.forEach(function(d) {
            var statusClass = d.status === 'active' ? 'weline-domain-status-resolved' : 'weline-domain-status-pending';
            var statusText = d.status === 'active' ? '<?= __('正常') ?>' : (d.status || '-');
            var localBadge = d.is_local
                ? '<span class="badge bg-success"><?= __('已导入') ?></span>'
                : '<span class="badge bg-secondary"><?= __('未导入') ?></span>';

            html += '<tr data-domain="' + (d.domain || '') + '">' +
                '<td><input type="checkbox" class="weline-import-checkbox" value="' + (d.domain || '') + '"' + (d.is_local ? ' disabled' : '') + '></td>' +
                '<td><strong>' + (d.domain || '') + '</strong></td>' +
                '<td><span class="weline-domain-status-badge ' + statusClass + '">' + statusText + '</span></td>' +
                '<td>' + (d.expires_at || '-') + '</td>' +
                '<td>' + localBadge + '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    function updateImportCount() {
        var total = remoteDomainData.length;
        var imported = remoteDomainData.filter(function(d) { return d.is_local; }).length;
        var el = document.getElementById('weline-import-count');
        if (total > 0) {
            el.textContent = '<?= __('共') ?> ' + total + ' <?= __('个域名') ?>，<?= __('已导入') ?> ' + imported + ' <?= __('个') ?>';
        } else {
            el.textContent = '';
