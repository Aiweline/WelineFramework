    function loadDnsAccountsForBatchSet() {
        fetch(urls.getDnsAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data) {
                    var dnsSelect = document.getElementById('weline-batch-set-dns-account');
                    var cdnSelect = document.getElementById('weline-batch-set-cdn-account');

                    // 清空旧选项（保留前两个）
                    while (dnsSelect.options.length > 2) {
                        dnsSelect.remove(2);
                    }
                    while (cdnSelect.options.length > 2) {
                        cdnSelect.remove(2);
                    }

                    // 添加 DNS 账户选项
                    (data.data.dns_accounts || []).forEach(function(acc) {
                        var opt = document.createElement('option');
                        opt.value = acc.account_id;
                        opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                        dnsSelect.appendChild(opt);
                    });

                    // 添加 CDN 账户选项
                    (data.data.cdn_accounts || []).forEach(function(acc) {
                        var opt = document.createElement('option');
                        opt.value = acc.account_id;
                        opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                        cdnSelect.appendChild(opt);
                    });
                }
            })
            .catch(function() {
                toast('<?= __('加载账户列表失败') ?>', 'error');
