    function showSwitchDnsAccountModal() {
        var selected = getSelectedDomainIds();
        if (selected.length === 0) {
            toast('<?= __('请先选择要切换 DNS 的根域名') ?>', 'warning');
            return;
        }
        switchDnsAccountSelectedIds = selected;
        var infoEl = document.getElementById('weline-switch-dns-selected-info');
