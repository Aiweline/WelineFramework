        var fd = new FormData();
        fd.append('domain_id', domainId);
        prefixes.forEach(function(p) { fd.append('prefixes[]', p); });
        fetch(urls.transferToPool, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    toast(data.msg || '<?= __('转存成功') ?>', 'success');
                } else {
                    toast(data.msg || '<?= __('转存失败') ?>', 'error');
