        document.getElementById('weline-batch-ns-manual-mode').style.display = 'none';
        document.getElementById('weline-batch-ns-provider').value = '';
        document.getElementById('weline-batch-ns-custom').value = '';
        document.getElementById('weline-batch-ns-custom-input').style.display = 'none';
        document.getElementById('weline-batch-ns-account-info').style.display = 'none';

        loadRegistrarAccounts();

        if (!batchChangeNsModal) {
            batchChangeNsModal = new bootstrap.Modal(document.getElementById('welineBatchChangeNsModal'));
            document.querySelectorAll('input[name="weline-ns-switch-mode"]').forEach(function(radio) {
                radio.addEventListener('change', onNsSwitchModeChange);
            });
            document.getElementById('weline-batch-ns-account').addEventListener('change', onNsAccountChange);
        }
        batchChangeNsModal.show();
    }

    function loadRegistrarAccounts() {
        var select = document.getElementById('weline-batch-ns-account');
        var accountModeRadio = document.getElementById('weline-ns-mode-account');
        var manualModeRadio = document.getElementById('weline-ns-mode-manual');
        var accountNoDataTip = document.getElementById('weline-batch-ns-account-no-data');
        
        select.innerHTML = '<option value=""><?= __('-- 加载中... --') ?></option>';
        if (accountNoDataTip) accountNoDataTip.style.display = 'none';

        fetch(urls.getRegistrarAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data && data.data.accounts) {
                    registrarAccountsCache = data.data.accounts;
                    if (data.data.accounts.length === 0) {
                        select.innerHTML = '<option value=""><?= __('-- 暂无可用账户 --') ?></option>';
                        select.disabled = true;
                        accountModeRadio.disabled = true;
                        if (accountNoDataTip) {
                            accountNoDataTip.style.display = 'block';
                        }
                        manualModeRadio.checked = true;
                        onNsSwitchModeChange();
                    } else {
                        select.disabled = false;
                        accountModeRadio.disabled = false;
                        var html = '<option value=""><?= __('-- 请选择目标账户 --') ?></option>';
                        data.data.accounts.forEach(function(acc) {
                            html += '<option value="' + acc.id + '" data-registrar="' + acc.registrar_code + '">' +
                                    acc.name + ' (' + acc.registrar_name + ')' +
                                    '</option>';
                        });
                        select.innerHTML = html;
                    }
                } else {
                    select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
                }
            })
            .catch(function() {
                select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
            });
    }

    function onNsSwitchModeChange() {
        var mode = document.querySelector('input[name="weline-ns-switch-mode"]:checked').value;
        document.getElementById('weline-batch-ns-account-mode').style.display = (mode === 'account') ? 'block' : 'none';
        document.getElementById('weline-batch-ns-manual-mode').style.display = (mode === 'manual') ? 'block' : 'none';
    }

    function onNsAccountChange() {
        var select = document.getElementById('weline-batch-ns-account');
        var accountId = select.value;
        var infoDiv = document.getElementById('weline-batch-ns-account-info');
        var nsSpan = document.getElementById('weline-batch-ns-account-ns');

        if (!accountId) {
            infoDiv.style.display = 'none';
            return;
        }

        infoDiv.style.display = 'block';
        nsSpan.textContent = '<?= __('正在获取DNS服务器...') ?>';

        var fd = new FormData();
        fd.append('account_id', accountId);
        fd.append('domains', JSON.stringify(batchChangeNsSelectedDomains.slice(0, 1)));

        fetch(urls.getAccountNameservers, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data) {
                    if (data.data.per_domain) {
                        nsSpan.textContent = '<?= __('Cloudflare 将为每个域名分配独立的 Nameserver') ?>';
                    } else if (data.data.nameservers && data.data.nameservers.length > 0) {
                        nsSpan.textContent = '<?= __('目标DNS') ?>: ' + data.data.nameservers.join(', ');
                    } else {
                        nsSpan.textContent = data.msg || '<?= __('该账户暂无可用DNS服务器') ?>';
                        infoDiv.className = 'alert alert-warning small';
                    }
                } else {
                    nsSpan.textContent = data.msg || '<?= __('获取失败') ?>';
                    infoDiv.className = 'alert alert-warning small';
                }
            })
            .catch(function() {
                nsSpan.textContent = '<?= __('获取失败') ?>';
                infoDiv.className = 'alert alert-warning small';
            });
    }

    function onNsProviderChange() {
        var provider = document.getElementById('weline-batch-ns-provider').value;
        var customInput = document.getElementById('weline-batch-ns-custom-input');

        customInput.style.display = (provider === 'custom') ? 'block' : 'none';
    }

    function doBatchChangeNs() {
        if (batchChangeNsSelectedIds.length === 0) {
            toast('<?= __('请选择要切换DNS的域名') ?>', 'warning');
            return;
        }

        var mode = document.querySelector('input[name="weline-ns-switch-mode"]:checked').value;
        var submitBtn = document.getElementById('weline-batch-ns-submit');

        if (mode === 'account') {
            var accountId = document.getElementById('weline-batch-ns-account').value;
            if (!accountId) {
                toast('<?= __('请选择目标账户') ?>', 'warning');
                return;
            }

            toast('<?= __('正在批量切换DNS服务器...') ?>', 'info');
            submitBtn.disabled = true;

            var fd = new FormData();
            fd.append('domain_ids', JSON.stringify(batchChangeNsSelectedIds));
            fd.append('target_account_id', accountId);

            fetch(urls.batchSwitchToAccount, { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    submitBtn.disabled = false;
                    if (data.code === 200) {
                        var msg = data.msg || '<?= __('切换完成') ?>';
                        toast(msg, 'success');
                        if (data.data && data.data.errors && data.data.errors.length > 0) {
                            console.log('<?= __('切换错误') ?>:', data.data.errors);
                        }
                        if (batchChangeNsModal) {
                            batchChangeNsModal.hide();
                        }
                        loadDomains(currentPage);
                    } else {
                        toast(data.msg || '<?= __('切换失败') ?>', 'error');
                    }
                })
                .catch(function() {
                    submitBtn.disabled = false;
                    toast('<?= __('请求失败') ?>', 'error');
                });
        } else {
            var provider = document.getElementById('weline-batch-ns-provider').value;
            var customNs = document.getElementById('weline-batch-ns-custom').value.trim();

            if (!provider) {
                toast('<?= __('请选择DNS服务商') ?>', 'warning');
                return;
            }

            if (provider === 'custom' && !customNs) {
                toast('<?= __('请输入自定义Nameserver') ?>', 'warning');
                return;
            }

            toast('<?= __('正在批量切换DNS服务器...') ?>', 'info');
            submitBtn.disabled = true;

            var fd = new FormData();
            fd.append('domain_ids', JSON.stringify(batchChangeNsSelectedIds));
            if (provider === 'custom') {
                fd.append('nameservers', customNs);
            } else {
                fd.append('target_provider', provider);
            }

            fetch(urls.batchChangeNameservers, { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    submitBtn.disabled = false;
                    if (data.code === 200) {
                        var msg = data.msg || '<?= __('切换完成') ?>';
                        toast(msg, 'success');
                        if (data.data && data.data.errors && data.data.errors.length > 0) {
                            console.log('<?= __('切换错误') ?>:', data.data.errors);
                        }
                        if (batchChangeNsModal) {
                            batchChangeNsModal.hide();
                        }
                        loadDomains(currentPage);
                    } else {
                        toast(data.msg || '<?= __('切换失败') ?>', 'error');
                    }
                })
                .catch(function() {
                    submitBtn.disabled = false;
                    toast('<?= __('请求失败') ?>', 'error');
                });
        }
    }

    // ========== 批量添加DNS记录相关函数 ==========
    var batchAddDnsSelectedIds = [];
    var batchAddDnsModal = null;

    function showBatchAddDnsRecordModal() {
        var selected = getSelectedDomainIds();
        if (selected.length === 0) {
            toast('<?= __('请先选择要添加DNS记录的域名') ?>', 'warning');
            return;
        }

        batchAddDnsSelectedIds = selected;
        var infoEl = document.getElementById('weline-batch-add-dns-selected-info');
        infoEl.innerHTML = '<?= __('已选择') ?> <strong>' + selected.length + '</strong> <?= __('个域名') ?>';

        document.getElementById('weline-batch-add-dns-type').value = 'A';
        document.getElementById('weline-batch-add-dns-host').value = '@';
        document.getElementById('weline-batch-add-dns-value').value = '';
        document.getElementById('weline-batch-add-dns-ttl').value = '600';
        document.getElementById('weline-batch-add-dns-use-server-ip').checked = false;
        onBatchAddDnsUseServerIpChange();

        fetch(urls.refreshServerIp)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data && data.data.ip) {
                    document.getElementById('weline-batch-add-dns-server-ip-display').textContent = data.data.ip;
                }
            });

        if (!batchAddDnsModal) {
            batchAddDnsModal = new bootstrap.Modal(document.getElementById('welineBatchAddDnsRecordModal'));
        }
        batchAddDnsModal.show();
    }

    function onBatchAddDnsUseServerIpChange() {
        var useServerIp = document.getElementById('weline-batch-add-dns-use-server-ip').checked;
        document.getElementById('weline-batch-add-dns-form-fields').style.display = useServerIp ? 'none' : 'block';
        document.getElementById('weline-batch-add-dns-server-ip-fields').style.display = useServerIp ? 'block' : 'none';
    }

    function doBatchAddDnsRecords() {
        if (batchAddDnsSelectedIds.length === 0) {
            toast('<?= __('请选择要添加DNS记录的域名') ?>', 'warning');
            return;
        }

        var useServerIp = document.getElementById('weline-batch-add-dns-use-server-ip').checked;
        var submitBtn = document.getElementById('weline-batch-add-dns-submit');
        var fd = new FormData();
        fd.append('domain_ids', JSON.stringify(batchAddDnsSelectedIds));
        fd.append('use_server_ip', useServerIp ? '1' : '0');

        if (useServerIp) {
            fd.append('host', document.getElementById('weline-batch-add-dns-host-server').value || '@');
            fd.append('ttl', document.getElementById('weline-batch-add-dns-ttl-server').value || 600);
        } else {
            var type = document.getElementById('weline-batch-add-dns-type').value;
            var host = document.getElementById('weline-batch-add-dns-host').value || '@';
            var value = document.getElementById('weline-batch-add-dns-value').value.trim();
            var ttl = document.getElementById('weline-batch-add-dns-ttl').value || 600;

            if (!value) {
                toast('<?= __('请输入记录值') ?>', 'warning');
                return;
            }

            fd.append('type', type);
            fd.append('host', host);
            fd.append('value', value);
            fd.append('ttl', ttl);
        }

        toast('<?= __('正在批量添加DNS记录...') ?>', 'info');
        submitBtn.disabled = true;

        fetch(urls.batchAddDnsRecords, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                submitBtn.disabled = false;
                if (data.code === 200 || data.code === 206) {
                    var msg = data.msg || '<?= __('添加完成') ?>';
                    toast(msg, data.code === 200 ? 'success' : 'warning');
                    if (data.data && data.data.errors && data.data.errors.length > 0) {
                        console.log('<?= __('添加错误') ?>:', data.data.errors);
                    }
                    if (batchAddDnsModal) {
                        batchAddDnsModal.hide();
                    }
                    loadDomains(currentPage);
                } else {
                    toast(data.msg || '<?= __('添加失败') ?>', 'error');
                }
            })
            .catch(function() {
                submitBtn.disabled = false;
                toast('<?= __('请求失败') ?>', 'error');
            });
    }

    window.WelineDomainList = {
        loadDomains: loadDomains,
        showImportModal: showImportModal,
        fetchRemoteDomains: fetchRemoteDomains,
        toggleImportSelectAll: toggleImportSelectAll,
        toggleShowImported: toggleShowImported,
        importSelectedDomains: importSelectedDomains,
        checkResolve: checkResolve,
        batchCheckResolve: batchCheckResolve,
        showDnsModal: showDnsModal,
        syncDnsRecords: syncDnsRecords,
        showAddDnsRecordForm: showAddDnsRecordForm,
        hideAddDnsRecordForm: hideAddDnsRecordForm,
        saveDnsRecord: saveDnsRecord,
        deleteDnsRecord: deleteDnsRecord,
        autoResolve: autoResolve,
        refreshServerIp: refreshServerIp,
        toggleSelectAll: toggleSelectAll,
        resetFilters: resetFilters,
        onSearchKeyup: onSearchKeyup,
        transferToPool: transferToPool,
        batchTransferToPool: batchTransferToPool,
        batchTransferToPoolWithIpCheck: batchTransferToPoolWithIpCheck,
        batchResolveToLocal: batchResolveToLocal,
        showBatchChangeNsModal: showBatchChangeNsModal,
        onNsProviderChange: onNsProviderChange,
        doBatchChangeNs: doBatchChangeNs,
        showBatchAddDnsRecordModal: showBatchAddDnsRecordModal,
        onBatchAddDnsUseServerIpChange: onBatchAddDnsUseServerIpChange,
        doBatchAddDnsRecords: doBatchAddDnsRecords,
        batchDetectDnsProvider: batchDetectDnsProvider,
        cleanupDnsProviderDomains: cleanupDnsProviderDomains,
        showBatchSetAccountsModal: showBatchSetAccountsModal,
        doBatchSetAccounts: doBatchSetAccounts
    };

    function getSelectedDomainIds() {
        var ids = [];
        document.querySelectorAll('.weline-domain-checkbox:checked').forEach(function(cb) {
            ids.push(cb.value);
        });
        return ids;
    }

    // ========== 批量设置账户相关函数 ==========
    var batchSetAccountsSelectedIds = [];
    var batchSetAccountsModal = null;

    function showBatchSetAccountsModal() {
        var selected = getSelectedDomainIds();
        if (selected.length === 0) {
            toast('<?= __('请先选择要设置的域名') ?>', 'warning');
            return;
        }

        batchSetAccountsSelectedIds = selected;
        var infoEl = document.getElementById('weline-batch-set-accounts-selected-info');
        infoEl.innerHTML = '<?= __('已选择') ?> <strong>' + selected.length + '</strong> <?= __('个域名') ?>';

        // 重置下拉框
        document.getElementById('weline-batch-set-dns-account').value = '';
        document.getElementById('weline-batch-set-cdn-account').value = '';

        // 加载可用账户列表
        loadDnsAccountsForBatchSet();

        if (!batchSetAccountsModal) {
            batchSetAccountsModal = new bootstrap.Modal(document.getElementById('welineBatchSetAccountsModal'));
        }
        batchSetAccountsModal.show();
    }

    function loadDnsAccountsForBatchSet() {
        fetch(urls.getDnsAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data) {
                    var dnsSelect = document.getElementById('weline-batch-set-dns-account');
                    var cdnSelect = document.getElementById('weline-batch-set-cdn-account');

                    // 清空旧选项（保留前两个）
                    while (dnsSelect.options.length > 2) {
                        dnsSelect.remove(2);
                    }
                    while (cdnSelect.options.length > 2) {
                        cdnSelect.remove(2);
                    }

                    // 添加 DNS 账户选项
                    (data.data.dns_accounts || []).forEach(function(acc) {
                        var opt = document.createElement('option');
                        opt.value = acc.account_id;
                        opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                        dnsSelect.appendChild(opt);
                    });

                    // 添加 CDN 账户选项
                    (data.data.cdn_accounts || []).forEach(function(acc) {
                        var opt = document.createElement('option');
                        opt.value = acc.account_id;
                        opt.textContent = acc.name + ' (' + acc.registrar_name + ')';
                        cdnSelect.appendChild(opt);
                    });
                }
            })
            .catch(function() {
                toast('<?= __('加载账户列表失败') ?>', 'error');
            });
    }

    function doBatchSetAccounts() {
        if (batchSetAccountsSelectedIds.length === 0) {
            toast('<?= __('请选择要设置的域名') ?>', 'warning');
            return;
        }

        var dnsAccountId = document.getElementById('weline-batch-set-dns-account').value;
        var cdnAccountId = document.getElementById('weline-batch-set-cdn-account').value;

        if (dnsAccountId === '' && cdnAccountId === '') {
            toast('<?= __('请至少选择一个账户进行设置') ?>', 'warning');
            return;
        }

        var submitBtn = document.getElementById('weline-batch-set-accounts-submit');
        var fd = new FormData();
        fd.append('domain_ids', JSON.stringify(batchSetAccountsSelectedIds));
        if (dnsAccountId !== '') {
            fd.append('dns_account_id', dnsAccountId);
        }
        if (cdnAccountId !== '') {
            fd.append('cdn_account_id', cdnAccountId);
        }

        toast('<?= __('正在设置账户...') ?>', 'info');
        submitBtn.disabled = true;

        fetch(urls.batchSetAccounts, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                submitBtn.disabled = false;
                if (data.code === 200) {
                    toast(data.msg || '<?= __('设置成功') ?>', 'success');
                    if (batchSetAccountsModal) {
                        batchSetAccountsModal.hide();
                    }
                    loadDomains(currentPage);
                } else {
                    toast(data.msg || '<?= __('设置失败') ?>', 'error');
                }
            })
            .catch(function() {
                submitBtn.disabled = false;
                toast('<?= __('请求失败') ?>', 'error');
            });
    }

    function batchDetectDnsProvider() {
        var ids = getSelectedDomainIds();
        if (ids.length === 0) {
            toast('<?= __('请选择要检测的域名') ?>', 'warning');
            return;
        }

        toast('<?= __('正在检测 DNS 服务商...') ?>', 'info');
        var fd = new FormData();
        fd.append('domain_ids', JSON.stringify(ids));

        fetch(urls.detectDnsProvider, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    toast(data.msg || '<?= __('检测完成') ?>', 'success');
                    loadDomains(currentPage);
                } else {
                    toast(data.msg || '<?= __('检测失败') ?>', 'error');
                }
            })
            .catch(function() { toast('<?= __('请求失败') ?>', 'error'); });
    }

    function cleanupDnsProviderDomains() {
        if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
            BackendConfirm.show('<?= __('确定清理所有 DNS 服务商（如 Cloudflare）下误同步的域名？') ?>\n\n<?= __('这些域名不属于 DNS 服务商，只是托管在那里。清理后不会影响远程数据。') ?>', {
                title: '<?= __('清理 DNS 服务商域名') ?>',
                confirmText: '<?= __('确认清理') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    doCleanupDnsProviderDomains();
                }
            });
        } else {
            doCleanupDnsProviderDomains();
        }
    }

    function doCleanupDnsProviderDomains() {
        toast('<?= __('正在清理 DNS 服务商域名...') ?>', 'info');

        fetch(urls.cleanupDnsProviderDomains, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    toast(data.msg || '<?= __('清理完成') ?>', 'success');
                    if (data.data && data.data.cleaned_accounts && data.data.cleaned_accounts.length > 0) {
                        console.log('<?= __('已清理的账户') ?>:', data.data.cleaned_accounts);
                    }
                    loadDomains(1);
                } else {
                    toast(data.msg || '<?= __('清理失败') ?>', 'error');
                }
            })
            .catch(function() { toast('<?= __('请求失败') ?>', 'error'); });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { loadDomains(1); });
    } else {
        loadDomains(1);
    }
})();
</script>
