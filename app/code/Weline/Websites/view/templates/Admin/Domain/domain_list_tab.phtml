    function loadRegistrarAccounts() {
        var accountModeRadio = document.getElementById('weline-ns-mode-account');
        var manualModeRadio = document.getElementById('weline-ns-mode-manual');
        var accountNoDataTip = document.getElementById('weline-batch-ns-account-no-data');
        
        select.innerHTML = '<option value=""><?= __('-- 加载中... --') ?></option>';
        if (accountNoDataTip) accountNoDataTip.style.display = 'none';

        fetch(urls.getRegistrarAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data && data.data.accounts) {
                    registrarAccountsCache = data.data.accounts;
                    if (data.data.accounts.length === 0) {
                        select.innerHTML = '<option value=""><?= __('-- 暂无可用账户 --') ?></option>';
                        select.disabled = true;
                        accountModeRadio.disabled = true;
                        if (accountNoDataTip) {
                            accountNoDataTip.style.display = 'block';
                        }
                        manualModeRadio.checked = true;
                        onNsSwitchModeChange();
                    } else {
                        select.disabled = false;
                        accountModeRadio.disabled = false;
                        var html = '<option value=""><?= __('-- 请选择目标账户 --') ?></option>';
                        data.data.accounts.forEach(function(acc) {
                            html += '<option value="' + acc.id + '" data-registrar="' + acc.registrar_code + '">' +
                                    acc.name + ' (' + acc.registrar_name + ')' +
                                    '</option>';
                        });
                        select.innerHTML = html;
                    }
                } else {
                    select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
                }
            })
            .catch(function() {
                select.innerHTML = '<option value=""><?= __('-- 加载失败 --') ?></option>';
            });
    }

    function onNsSwitchModeChange() {
