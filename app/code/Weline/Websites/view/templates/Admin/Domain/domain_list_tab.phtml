            var registrarClass = registrarName !== '-' ? 'weline-provider-registrar' : 'weline-provider-none';
            var dnsClass = dnsName !== '-' ? 'weline-provider-dns' : 'weline-provider-none';
            var cdnClass = cdnName !== '-' ? 'weline-provider-cdn' : 'weline-provider-none';

            var providerCell = '<div class="weline-domain-provider-cell">' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label"><?= __('注册') ?></span>' +
                    '<span class="weline-domain-provider-badge ' + registrarClass + '">' + registrarName + '</span>' +
                '</div>' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label">DNS</span>' +
                    '<span class="weline-domain-provider-badge ' + dnsClass + '">' + dnsName + '</span>' +
                '</div>' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label">CDN</span>' +
                    '<span class="weline-domain-provider-badge ' + cdnClass + '">' + cdnName + '</span>' +
                '</div>' +
            '</div>';
            var summaryCell = '<div class="weline-domain-summary-cell">' +
                '<div class="weline-domain-summary-row">' +
                    '<span class="weline-domain-status-badge ' + resolveClass + '">' + resolveText + '</span>' +
                    '<span class="weline-domain-status-badge ' + httpsClass + '">' + httpsText + '</span>' +
                '</div>' +
                '<div class="weline-domain-summary-meta">' +
                    '<span class="weline-domain-summary-code">' + (item.resolved_ip || '-') + '</span>' +
                    localBadge +
                '</div>' +
                '<div class="weline-domain-summary-row">' +
                    siteReady +
                    siteCreated +
                    connCell +
                '</div>' +
            '</div>';

            html += '<tr data-domain-id="' + item.domain_id + '">' +
                '<td><input type="checkbox" class="weline-domain-checkbox" value="' + item.domain_id + '" data-domain="' + (item.domain || '') + '"></td>' +
                '<td><span class="domain-name">' + (item.domain || '') + '</span></td>' +
                '<td>' + providerCell + '</td>' +
                '<td>' + summaryCell + '</td>' +
                '<td class="text-end weline-domain-actions">' +
                    '<button type="button" class="btn btn-outline-success btn-sm" title="<?= __('转存域名池') ?>" onclick="WelineDomainList.transferToPool(' + item.domain_id + ', \'' + (item.domain || '').replace(/'/g, "\\'") + '\')"><i class="mdi mdi-database-export"></i></button> ' +
                    '<button type="button" class="btn btn-outline-info btn-sm" title="<?= __('DNS管理') ?>" onclick="WelineDomainList.showDnsModal(' + item.domain_id + ', \'' + (item.domain || '').replace(/'/g, "\\'") + '\')"><i class="mdi mdi-dns"></i></button> ' +
                    '<button type="button" class="btn btn-outline-primary btn-sm" title="<?= __('检测解析') ?>" onclick="WelineDomainList.checkResolve(' + item.domain_id + ')"><i class="mdi mdi-refresh"></i></button> ' +
                    '<button type="button" class="btn btn-outline-danger btn-sm" title="<?= __('删除') ?>" onclick="WelineDomainList.deleteDomain(' + item.domain_id + ', \'' + (item.domain || '').replace(/'/g, "\\'") + '\')"><i class="mdi mdi-delete-outline"></i></button>' +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    function renderPagination(pagination) {
        var info = document.getElementById('weline-domain-pagination-info');
        var links = document.getElementById('weline-domain-pagination-links');

        var total = pagination.total || 0;
        var current = pagination.current_page || 1;
        var lastPage = pagination.last_page || 1;
        var ps = pagination.page_size || pageSize;
        var from = total === 0 ? 0 : ((current - 1) * ps) + 1;
        var to = Math.min(current * ps, total);

        if (total === 0) {
            info.textContent = '<?= __('共 0 条本地域名') ?>';
        } else {
            info.textContent = '<?= __('共') ?> ' + total + ' <?= __('条') ?> · <?= __('第') ?> ' + current + ' / ' + lastPage + ' <?= __('页') ?> · <?= __('每页') ?> ' + ps + ' <?= __('条') ?>';
            if (from > 0 && to > 0 && (from !== 1 || to !== total)) {
                info.textContent += ' （<?= __('本页') ?> ' + from + '–' + to + '）';
            }
        }

        var linksHtml = '';
        if (lastPage > 1) {
            linksHtml += '<li class="page-item ' + (current <= 1 ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + (current - 1) + ');return false;">&laquo;</a></li>';
            var start = Math.max(1, current - 2);
            var end = Math.min(lastPage, current + 2);
            if (start > 1) {
                linksHtml += '<li class="page-item"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(1);return false;">1</a></li>';
                if (start > 2) {
                    linksHtml += '<li class="page-item disabled"><span class="page-link">…</span></li>';
                }
            }
            for (var i = start; i <= end; i++) {
                linksHtml += '<li class="page-item ' + (i === current ? 'active' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + i + ');return false;">' + i + '</a></li>';
            }
            if (end < lastPage) {
                if (end < lastPage - 1) {
                    linksHtml += '<li class="page-item disabled"><span class="page-link">…</span></li>';
                }
                linksHtml += '<li class="page-item"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + lastPage + ');return false;">' + lastPage + '</a></li>';
            }
            linksHtml += '<li class="page-item ' + (current >= lastPage ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + (current + 1) + ');return false;">&raquo;</a></li>';
        } else if (total > 0) {
            linksHtml = '<li class="page-item disabled"><span class="page-link"><?= __('仅 1 页') ?></span></li>';
        }
        links.innerHTML = linksHtml;
    }

