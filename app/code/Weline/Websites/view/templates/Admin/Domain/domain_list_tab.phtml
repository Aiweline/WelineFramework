        document.getElementById('weline-switch-dns-form-area').style.display = 'block';
        document.getElementById('weline-switch-dns-progress-area').style.display = 'none';
        document.getElementById('weline-switch-dns-submit').style.display = '';
        document.getElementById('weline-switch-dns-cancel-btn').disabled = false;
        document.getElementById('weline-switch-dns-cancel-btn').textContent = '<?= __('取消') ?>';
        document.getElementById('weline-switch-dns-close-btn').style.display = '';

        loadDnsAccountsForSwitch();
