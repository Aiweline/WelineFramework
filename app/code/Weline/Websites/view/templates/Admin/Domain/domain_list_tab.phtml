    function onNsAccountChange() {
        var accountId = getRegistrarSelectValue('weline-batch-ns-account');
        var infoDiv = document.getElementById('weline-batch-ns-account-info');
        var nsSpan = document.getElementById('weline-batch-ns-account-ns');

        if (!accountId) {
            infoDiv.style.display = 'none';
            return;
        }

        infoDiv.style.display = 'block';
        nsSpan.textContent = '<?= __('正在获取DNS服务器...') ?>';

        var fd = new FormData();
        fd.append('account_id', accountId);
        fd.append('domains', JSON.stringify(batchChangeNsSelectedDomains.slice(0, 1)));

        fetch(urls.getAccountNameservers, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200 && data.data) {
                    if (data.data.per_domain) {
                        nsSpan.textContent = '<?= __('Cloudflare 通常会为每个接入的根域分配独立 Nameserver，请以控制台实际显示为准') ?>';
                    } else if (data.data.nameservers && data.data.nameservers.length > 0) {
                        nsSpan.textContent = '<?= __('目标DNS') ?>: ' + data.data.nameservers.join(', ');
                    } else {
                        nsSpan.textContent = data.msg || '<?= __('该账户暂无可用DNS服务器') ?>';
                        infoDiv.className = 'alert alert-warning small';
                    }
                } else {
                    nsSpan.textContent = data.msg || '<?= __('获取失败') ?>';
                    infoDiv.className = 'alert alert-warning small';
                }
            })
            .catch(function() {
                nsSpan.textContent = '<?= __('获取失败') ?>';
                infoDiv.className = 'alert alert-warning small';
            });
    }

