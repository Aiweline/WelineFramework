<script>
(function() {
    'use strict';

    var currentPage = 1;
    var pageSize = 20;
    var currentDomainId = null;
    var currentDomain = null;

    var urls = {
        domainList: '<?= $this->getUrl('*/admin/domain/get-domain-list') ?>',
        remoteDomains: '<?= $this->getUrl('*/admin/domain/get-remote-domains') ?>',
        importDomains: '<?= $this->getUrl('*/admin/domain/import-domains') ?>',
        checkResolve: '<?= $this->getUrl('*/admin/domain/check-resolve') ?>',
        batchCheckResolve: '<?= $this->getUrl('*/admin/domain/batch-check-resolve') ?>',
        autoResolve: '<?= $this->getUrl('*/admin/domain/auto-resolve') ?>',
        dnsRecords: '<?= $this->getUrl('*/admin/domain/get-dns-records') ?>',
        syncDnsRecords: '<?= $this->getUrl('*/admin/domain/sync-dns-records') ?>',
        addDnsRecord: '<?= $this->getUrl('*/admin/domain/add-dns-record') ?>',
        deleteDnsRecord: '<?= $this->getUrl('*/admin/domain/delete-dns-record') ?>',
        refreshServerIp: '<?= $this->getUrl('*/admin/domain/refresh-server-ip') ?>',
        transferToPool: '<?= $this->getUrl('*/admin/domain/transfer-to-pool') ?>',
        batchTransferToPool: '<?= $this->getUrl('*/admin/domain/batch-transfer-to-pool') ?>',
        batchTransferToPoolWithIpCheck: '<?= $this->getUrl('*/admin/domain/batch-transfer-to-pool-with-ip-check') ?>',
        batchResolveToLocal: '<?= $this->getUrl('*/admin/domain/batch-resolve-to-local') ?>',
        batchChangeNameservers: '<?= $this->getUrl('*/admin/domain/batch-change-nameservers') ?>',
        getRegistrarAccounts: '<?= $this->getUrl('*/admin/domain/get-registrar-accounts') ?>',
        getAccountNameservers: '<?= $this->getUrl('*/admin/domain/get-account-nameservers') ?>',
        batchSwitchToAccount: '<?= $this->getUrl('*/admin/domain/batch-switch-to-account') ?>',
        batchAddDnsRecords: '<?= $this->getUrl('*/admin/domain/batch-add-dns-records') ?>',
        detectDnsProvider: '<?= $this->getUrl('*/admin/domain/detect-dns-provider') ?>',
        cleanupDnsProviderDomains: '<?= $this->getUrl('*/admin/domain/cleanup-dns-provider-domains') ?>',
        batchSetAccounts: '<?= $this->getUrl('*/admin/domain/batch-set-accounts') ?>',
        getDnsAccounts: '<?= $this->getUrl('*/admin/domain/get-dns-accounts') ?>'
    };

    var importModal = null;
    var remoteDomainData = [];
    var hideImported = false;

    function toast(msg, type) {
        if (typeof BackendToast !== 'undefined') {
            BackendToast[type] ? BackendToast[type](msg) : BackendToast.info(msg);
        } else if (typeof showToast !== 'undefined') {
            showToast(msg, type);
        } else {
            console.log('[' + type + '] ' + msg);
        }
    }

    function getFilters() {
        return {
            account_id: document.getElementById('weline-domain-filter-account').value,
            resolve_status: document.getElementById('weline-domain-filter-resolve').value,
            https_status: document.getElementById('weline-domain-filter-https').value,
            search: document.getElementById('weline-domain-filter-search').value
        };
    }

    function loadDomains(page) {
        currentPage = page || 1;
        var filters = getFilters();
        var params = new URLSearchParams({
            page: currentPage,
            page_size: pageSize,
            account_id: filters.account_id,
            resolve_status: filters.resolve_status,
            https_status: filters.https_status,
            search: filters.search
        });

        var tbody = document.getElementById('weline-domain-list-body');
        tbody.innerHTML = '<tr><td colspan="8" class="weline-domain-empty"><i class="mdi mdi-loading mdi-spin" style="font-size:2rem;"></i><p class="mt-2 mb-0"><?= __('加载中...') ?></p></td></tr>';

        fetch(urls.domainList + '?' + params.toString())
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    renderDomainList(data.data.items || []);
                    renderPagination(data.data.pagination || {});
                } else {
                    toast(data.msg || '<?= __('加载失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="8" class="weline-domain-empty"><i class="mdi mdi-alert-circle-outline" style="font-size:2rem;color:var(--backend-color-danger);"></i><p class="mt-2 mb-0">' + (data.msg || '<?= __('加载失败') ?>') + '</p></td></tr>';
                }
            })
            .catch(function(err) {
                toast('<?= __('请求失败') ?>', 'error');
                tbody.innerHTML = '<tr><td colspan="8" class="weline-domain-empty"><i class="mdi mdi-alert-circle-outline" style="font-size:2rem;color:var(--backend-color-danger);"></i><p class="mt-2 mb-0"><?= __('请求失败') ?></p></td></tr>';
            });
    }

    function renderDomainList(items) {
        var tbody = document.getElementById('weline-domain-list-body');
        if (!items.length) {
            tbody.innerHTML = '<tr><td colspan="8" class="weline-domain-empty"><i class="mdi mdi-earth-off" style="font-size:2rem;"></i><p class="mt-2 mb-0"><?= __('暂无域名数据') ?></p></td></tr>';
            return;
        }

        var html = '';
        items.forEach(function(item) {
            var resolveClass = 'weline-domain-status-pending';
            var resolveText = '<?= __('待检测') ?>';
            if (item.resolve_status === 'resolved') {
                resolveClass = 'weline-domain-status-resolved';
                resolveText = '<?= __('已解析') ?>';
            } else if (item.resolve_status === 'unresolved') {
                resolveClass = 'weline-domain-status-unresolved';
                resolveText = '<?= __('未解析') ?>';
            } else if (item.resolve_status === 'error') {
                resolveClass = 'weline-domain-status-error';
                resolveText = '<?= __('错误') ?>';
            }

            var httpsClass = 'weline-domain-https-none';
            var httpsText = '<?= __('无') ?>';
            if (item.https_status === 'valid') {
                httpsClass = 'weline-domain-https-valid';
                httpsText = '<?= __('有效') ?>';
            } else if (item.https_status === 'expiring') {
                httpsClass = 'weline-domain-https-expiring';
                httpsText = '<?= __('即将过期') ?>';
            } else if (item.https_status === 'expired') {
                httpsClass = 'weline-domain-status-error';
                httpsText = '<?= __('已过期') ?>';
            }

            var localBadge = item.is_local_server ? '<span class="weline-domain-local-badge ms-1"><?= __('本机') ?></span>' : '';
            var siteReady = item.site_ready ? '<i class="mdi mdi-check-circle text-success"></i>' : '<i class="mdi mdi-close-circle text-muted"></i>';

            // 构建服务商列（三行：注册商、DNS、CDN）
            var registrarName = item.registrar_name || item.account_name || '-';
            var dnsName = item.dns_provider_name || item.dns_provider || '-';
            var cdnName = item.cdn_provider_name || item.cdn_provider || '-';

            var registrarClass = registrarName !== '-' ? 'weline-provider-registrar' : 'weline-provider-none';
            var dnsClass = dnsName !== '-' ? 'weline-provider-dns' : 'weline-provider-none';
            var cdnClass = cdnName !== '-' ? 'weline-provider-cdn' : 'weline-provider-none';

            var providerCell = '<div class="weline-domain-provider-cell">' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label"><?= __('注册') ?></span>' +
                    '<span class="weline-domain-provider-badge ' + registrarClass + '">' + registrarName + '</span>' +
                '</div>' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label">DNS</span>' +
                    '<span class="weline-domain-provider-badge ' + dnsClass + '">' + dnsName + '</span>' +
                '</div>' +
                '<div class="weline-domain-provider-row">' +
                    '<span class="weline-domain-provider-label">CDN</span>' +
                    '<span class="weline-domain-provider-badge ' + cdnClass + '">' + cdnName + '</span>' +
                '</div>' +
            '</div>';

            html += '<tr data-domain-id="' + item.domain_id + '">' +
                '<td><input type="checkbox" class="weline-domain-checkbox" value="' + item.domain_id + '" data-domain="' + (item.domain || '') + '"></td>' +
                '<td><span class="domain-name">' + (item.domain || '') + '</span></td>' +
                '<td>' + providerCell + '</td>' +
                '<td><span class="weline-domain-status-badge ' + resolveClass + '">' + resolveText + '</span></td>' +
                '<td>' + (item.resolved_ip || '-') + localBadge + '</td>' +
                '<td><span class="weline-domain-status-badge ' + httpsClass + '">' + httpsText + '</span></td>' +
                '<td>' + siteReady + '</td>' +
                '<td class="text-end weline-domain-actions">' +
                    '<button type="button" class="btn btn-outline-success btn-sm" title="<?= __('转存域名池') ?>" onclick="WelineDomainList.transferToPool(' + item.domain_id + ', \'' + (item.domain || '').replace(/'/g, "\\'") + '\')"><i class="mdi mdi-database-export"></i></button> ' +
                    '<button type="button" class="btn btn-outline-info btn-sm" title="<?= __('DNS管理') ?>" onclick="WelineDomainList.showDnsModal(' + item.domain_id + ', \'' + (item.domain || '').replace(/'/g, "\\'") + '\')"><i class="mdi mdi-dns"></i></button> ' +
                    '<button type="button" class="btn btn-outline-primary btn-sm" title="<?= __('检测解析') ?>" onclick="WelineDomainList.checkResolve(' + item.domain_id + ')"><i class="mdi mdi-refresh"></i></button>' +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    function renderPagination(pagination) {
        var info = document.getElementById('weline-domain-pagination-info');
        var links = document.getElementById('weline-domain-pagination-links');

        var total = pagination.total || 0;
        var current = pagination.current_page || 1;
        var lastPage = pagination.last_page || 1;
        var from = ((current - 1) * pageSize) + 1;
        var to = Math.min(current * pageSize, total);

        info.textContent = total > 0 ? '<?= __('显示') ?> ' + from + '-' + to + ' <?= __('共') ?> ' + total + ' <?= __('条') ?>' : '';

        var linksHtml = '';
        if (lastPage > 1) {
            linksHtml += '<li class="page-item ' + (current <= 1 ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + (current - 1) + ');return false;">&laquo;</a></li>';
            for (var i = 1; i <= lastPage && i <= 10; i++) {
                linksHtml += '<li class="page-item ' + (i === current ? 'active' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + i + ');return false;">' + i + '</a></li>';
            }
            linksHtml += '<li class="page-item ' + (current >= lastPage ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="WelineDomainList.loadDomains(' + (current + 1) + ');return false;">&raquo;</a></li>';
        }
        links.innerHTML = linksHtml;
    }

    function showImportModal() {
        if (!importModal) {
            importModal = new bootstrap.Modal(document.getElementById('welineImportDomainModal'));
        }
        document.getElementById('weline-import-account-select').value = '';
        document.getElementById('weline-import-domain-list').innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4"><?= __('请选择域名商账户') ?></td></tr>';
        document.getElementById('weline-import-count').textContent = '';
        remoteDomainData = [];
        hideImported = false;
        document.getElementById('weline-import-toggle-text').textContent = '<?= __('隐藏已导入') ?>';
        importModal.show();
    }

    function fetchRemoteDomains() {
        var accountId = document.getElementById('weline-import-account-select').value;
        var tbody = document.getElementById('weline-import-domain-list');

        if (!accountId) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4"><?= __('请选择域名商账户') ?></td></tr>';
            remoteDomainData = [];
            updateImportCount();
            return;
        }

        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4"><i class="mdi mdi-loading mdi-spin" style="font-size:1.5rem;"></i><p class="mt-2 mb-0"><?= __('正在获取远程域名列表...') ?></p></td></tr>';

        fetch(urls.remoteDomains + '?account_id=' + accountId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    remoteDomainData = data.data.domains || [];
                    renderImportDomainList();
                    toast(data.msg || '<?= __('获取成功') ?>', 'success');
                } else {
                    toast(data.msg || '<?= __('获取失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">' + (data.msg || '<?= __('获取失败') ?>') + '</td></tr>';
                    remoteDomainData = [];
                }
                updateImportCount();
            })
            .catch(function() {
                toast('<?= __('请求失败') ?>', 'error');
