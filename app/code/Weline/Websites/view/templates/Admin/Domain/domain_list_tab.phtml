    function deleteDnsRecord(recordId, type, host) {
        if (!currentDomainId) return;
        if (typeof BackendConfirm !== 'undefined') {
            BackendConfirm.show('<?= __('确定删除此DNS记录吗？') ?>').then(function(confirmed) {
                if (confirmed) doDeleteDnsRecord(recordId, type, host);
            });
        } else if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                text: '<?= __('确定删除此DNS记录吗？') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f46a6a',
                cancelButtonText: '<?= __('取消') ?>',
                confirmButtonText: '<?= __('删除') ?>'
            }).then(function(result) {
                if (result.isConfirmed) doDeleteDnsRecord(recordId, type, host);
            });
        } else {
            doDeleteDnsRecord(recordId, type, host);
        }
