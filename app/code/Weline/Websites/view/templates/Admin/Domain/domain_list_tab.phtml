    function loadDnsAccountsForSwitch() {
        fetch(urls.getDnsAccounts)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code !== 200 || !data.data || !data.data.dns_accounts) {
                    return;
                }
                var accounts = data.data.dns_accounts;
                var seen = {};
                var providers = [];
                accounts.forEach(function(acc) {
                    var code = acc.registrar_code || '';
                    if (code && !seen[code]) {
                        seen[code] = true;
                        providers.push({ code: code, name: acc.registrar_name || code });
                    }
                });
                switchDnsAccountCache = { providers: providers, accounts: accounts };

                var sel = document.getElementById('weline-switch-dns-provider');
                while (sel.options.length > 1) sel.remove(1);
                providers.forEach(function(p) {
                    var opt = document.createElement('option');
                    opt.value = p.code;
                    opt.textContent = p.name;
                    sel.appendChild(opt);
                });
            })
            .catch(function() { toast('<?= __('加载账户列表失败') ?>', 'error'); });
    }

    function onSwitchDnsProviderChange() {
        var provider = getRegistrarSelectValue('weline-switch-dns-provider');
        var accountSel = document.getElementById('weline-switch-dns-account');
        accountSel.innerHTML = '<option value=""><?= __('-- 请选择账户 --') ?></option>';
        if (!provider || !switchDnsAccountCache.accounts) return;
        switchDnsAccountCache.accounts.forEach(function(acc) {
            if ((acc.registrar_code || '') === provider) {
                var opt = document.createElement('option');
                opt.value = acc.account_id;
                opt.textContent = acc.name + ' (' + (acc.registrar_name || '') + ')';
                accountSel.appendChild(opt);
            }
        });
    }

    function doSwitchDnsAccount() {
        if (switchDnsAccountSelectedIds.length === 0) {
            toast('<?= __('请先选择要切换的根域名') ?>', 'warning');
            return;
        }
        var targetAccountId = getRegistrarSelectValue('weline-switch-dns-account');
        if (!targetAccountId) {
            toast('<?= __('请选择目标 DNS 服务账户') ?>', 'warning');
            return;
        }

        var formArea = document.getElementById('weline-switch-dns-form-area');
        var progressArea = document.getElementById('weline-switch-dns-progress-area');
        var logPanel = document.getElementById('weline-dns-switch-log');
        var progressBar = document.getElementById('weline-dns-switch-progress-bar');
        var progressBadge = document.getElementById('weline-dns-switch-progress-badge');
        var progressTitle = document.getElementById('weline-dns-switch-progress-title');
        var summaryEl = document.getElementById('weline-dns-switch-summary');
        var submitBtn = document.getElementById('weline-switch-dns-submit');
        var cancelBtn = document.getElementById('weline-switch-dns-cancel-btn');
        var closeBtn = document.getElementById('weline-switch-dns-close-btn');

        formArea.style.display = 'none';
        progressArea.style.display = 'block';
        logPanel.innerHTML = '';
        summaryEl.style.display = 'none';
        submitBtn.style.display = 'none';
        cancelBtn.disabled = true;
        closeBtn.style.display = 'none';

        var modalEl = document.getElementById('welineSwitchDnsAccountModal');
        if (switchDnsAccountModal) {
            switchDnsAccountModal._config.backdrop = 'static';
            switchDnsAccountModal._config.keyboard = false;
        }

        var sseUrl = urls.dnsSwitchSse
            + '?domain_ids=' + encodeURIComponent(JSON.stringify(switchDnsAccountSelectedIds))
            + '&target_account_id=' + encodeURIComponent(targetAccountId);

        var totalDomains = switchDnsAccountSelectedIds.length;
        var completedDomains = 0;

        var eventIcons = {
            'init': '<i class="mdi mdi-information-outline" style="color:var(--backend-color-primary,#0d6efd);"></i>',
            'sync_records': '<i class="mdi mdi-sync" style="color:var(--backend-color-info,#0dcaf0);"></i>',
            'sync_records_done': '<i class="mdi mdi-check" style="color:var(--backend-color-success,#198754);"></i>',
            'add_zone': '<i class="mdi mdi-cloud-outline" style="color:var(--backend-color-info,#0dcaf0);"></i>',
            'add_zone_done': '<i class="mdi mdi-check" style="color:var(--backend-color-success,#198754);"></i>',
            'switch_ns': '<i class="mdi mdi-swap-horizontal" style="color:var(--backend-color-warning,#ffc107);"></i>',
            'switch_ns_done': '<i class="mdi mdi-check-circle" style="color:var(--backend-color-success,#198754);"></i>',
            'push_records': '<i class="mdi mdi-upload" style="color:var(--backend-color-info,#0dcaf0);"></i>',
            'update_domain': '<i class="mdi mdi-database-edit" style="color:var(--backend-color-info,#0dcaf0);"></i>',
            'update_pool': '<i class="mdi mdi-database-check" style="color:var(--backend-color-info,#0dcaf0);"></i>',
            'domain_done': '<i class="mdi mdi-check-all" style="color:var(--backend-color-success,#198754);"></i>',
            'step_error': '<i class="mdi mdi-alert-circle" style="color:var(--backend-color-danger,#dc3545);"></i>',
            'step_skip': '<i class="mdi mdi-skip-next" style="color:var(--backend-color-text-tertiary,#999);"></i>',
            'error': '<i class="mdi mdi-close-circle" style="color:var(--backend-color-danger,#dc3545);"></i>',
            'done': '<i class="mdi mdi-flag-checkered" style="color:var(--backend-color-success,#198754);"></i>'
        };

        var appendLog = function(eventType, data) {
            var icon = eventIcons[eventType] || '<i class="mdi mdi-circle-small"></i>';
            var time = (data && data.time) ? data.time : '';
            var msg = (data && data.message) ? data.message : (typeof data === 'string' ? data : JSON.stringify(data));
            var domainTag = (data && data.domain) ? '<strong>[' + data.domain + ']</strong> ' : '';
            var item = document.createElement('div');
            item.className = 'weline-dns-log-item';
            item.innerHTML = '<span class="weline-dns-log-time">' + time + '</span>'
                + '<span class="weline-dns-log-icon">' + icon + '</span>'
                + '<span class="weline-dns-log-msg">' + domainTag + msg + '</span>';
            logPanel.appendChild(item);
            logPanel.scrollTop = logPanel.scrollHeight;
        };

        var updateProgress = function(current, total) {
            var pct = total > 0 ? Math.round(current / total * 100) : 0;
            progressBar.style.width = pct + '%';
            progressBar.setAttribute('aria-valuenow', pct);
            progressBadge.textContent = current + '/' + total;
        };

        var es = new EventSource(sseUrl);

        var allEvents = ['init','sync_records','sync_records_done','add_zone','add_zone_done',
            'switch_ns','switch_ns_done','push_records','update_domain','update_pool',
            'domain_done','step_error','step_skip','error','done'];

        allEvents.forEach(function(evtName) {
            es.addEventListener(evtName, function(e) {
                var data = {};
                try { data = JSON.parse(e.data); } catch(_) { data = { message: e.data }; }

                appendLog(evtName, data);

                if (evtName === 'domain_done' || evtName === 'step_error' || evtName === 'step_skip') {
                    completedDomains++;
                    updateProgress(completedDomains, totalDomains);
                }

                if (evtName === 'init' && data.total) {
                    totalDomains = data.total;
                    updateProgress(0, totalDomains);
                }

                if (evtName === 'done') {
                    es.close();
                    progressTitle.textContent = '<?= __('切换完成') ?>';
                    updateProgress(totalDomains, totalDomains);
                    progressBar.style.background = 'var(--backend-color-success, #198754)';

                    var s = (data.success || 0);
                    var sk = (data.skipped || 0);
                    var f = (data.failed || 0);
                    summaryEl.innerHTML = '<div class="alert mb-0" style="background:var(--backend-color-bg-tertiary,#e9ecef);color:var(--backend-color-text-primary,#333);border:1px solid var(--backend-color-border-default,#dee2e6);">'
                        + '<i class="mdi mdi-check-circle me-1" style="color:var(--backend-color-success,#198754);"></i>'
                        + '<strong>' + (data.message || '') + '</strong>'
                        + '</div>';
                    summaryEl.style.display = 'block';

                    cancelBtn.disabled = false;
                    cancelBtn.textContent = '<?= __('关闭') ?>';
                    closeBtn.style.display = '';
                    if (switchDnsAccountModal) {
                        switchDnsAccountModal._config.backdrop = true;
                        switchDnsAccountModal._config.keyboard = true;
                    }
                    loadDomains(currentPage);
                }

                if (evtName === 'error') {
                    es.close();
                    progressTitle.textContent = '<?= __('切换异常') ?>';
                    progressBar.style.background = 'var(--backend-color-danger, #dc3545)';
                    cancelBtn.disabled = false;
                    cancelBtn.textContent = '<?= __('关闭') ?>';
                    closeBtn.style.display = '';
                    if (switchDnsAccountModal) {
                        switchDnsAccountModal._config.backdrop = true;
                        switchDnsAccountModal._config.keyboard = true;
                    }
                }
            });
        });

        es.onerror = function() {
            es.close();
            appendLog('error', { message: '<?= __('SSE 连接中断') ?>', time: new Date().toLocaleTimeString() });
            cancelBtn.disabled = false;
            cancelBtn.textContent = '<?= __('关闭') ?>';
            closeBtn.style.display = '';
            if (switchDnsAccountModal) {
                switchDnsAccountModal._config.backdrop = true;
                switchDnsAccountModal._config.keyboard = true;
            }
        };
    }

