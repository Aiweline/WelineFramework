    function submitManualDomain() {
        var domain = (document.getElementById('weline-manual-domain').value || '').trim();
        if (!domain) {
            toast('<?= __('请输入域名') ?>', 'warning');
            return;
        }
        var submitBtn = document.getElementById('weline-manual-domain-submit');
        var fd = new FormData();
        fd.append('domain', domain);
        fd.append('description', document.getElementById('weline-manual-description').value || '');
        fd.append('dns_account_id', getRegistrarSelectValue('weline-manual-dns-account') || '0');
        fd.append('cdn_account_id', getRegistrarSelectValue('weline-manual-cdn-account') || '0');
        fd.append('https_mode', document.getElementById('weline-manual-https-mode').value || 'none');
        fd.append('https_email', document.getElementById('weline-manual-https-email').value || '');
        fd.append('cert_fullchain_text', document.getElementById('weline-manual-cert-text').value || '');
        fd.append('cert_private_key_text', document.getElementById('weline-manual-key-text').value || '');
        fd.append('cert_chain_text', document.getElementById('weline-manual-chain-text').value || '');
        fd.append('cert_pfx_password', document.getElementById('weline-manual-pfx-password').value || '');
        var certFile = document.getElementById('weline-manual-cert-file');
        var keyFile = document.getElementById('weline-manual-key-file');
        var chainFile = document.getElementById('weline-manual-chain-file');
        var pfxFile = document.getElementById('weline-manual-pfx-file');
        if (certFile && certFile.files && certFile.files[0]) fd.append('cert_file', certFile.files[0]);
        if (keyFile && keyFile.files && keyFile.files[0]) fd.append('key_file', keyFile.files[0]);
        if (chainFile && chainFile.files && chainFile.files[0]) fd.append('chain_file', chainFile.files[0]);
        if (pfxFile && pfxFile.files && pfxFile.files[0]) fd.append('pfx_file', pfxFile.files[0]);

        submitBtn.disabled = true;
        toast('<?= __('正在创建域名...') ?>', 'info');
        fetch(urls.createManualDomain, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
