    function importSelectedDomains() {
        var checkboxes = document.querySelectorAll('.weline-import-checkbox:checked');
        var domains = [];
        checkboxes.forEach(function(cb) { domains.push(cb.value); });

        if (domains.length === 0) {
            toast('<?= __('请选择要导入的域名') ?>', 'warning');
            return;
        }

        var accountId = getRegistrarSelectValue('weline-import-account-select');
        if (!accountId) {
            toast('<?= __('请选择域名商账户') ?>', 'warning');
            return;
        }

        var modeRadio = document.querySelector('input[name="weline-import-resolve-mode"]:checked');
        var resolveMode = (modeRadio && modeRadio.value) || 'batch_to_local';
        var autoResolve = resolveMode === 'batch_to_local';

        toast('<?= __('正在导入域名...') ?>', 'info');
        var fd = new FormData();
        fd.append('account_id', accountId);
        fd.append('resolve_mode', resolveMode);
        fd.append('auto_resolve', autoResolve ? '1' : '0');
        domains.forEach(function(d) { fd.append('domains[]', d); });

        fetch(urls.importDomains, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    var msg = data.msg || '<?= __('导入成功') ?>';
                    if (autoResolve && (data.data && data.data.auto_resolve_queued)) {
                        msg += ' <?= __('（自动解析任务已创建）') ?>';
                    }
                    toast(msg, 'success');
                    fetchRemoteDomains();
                    loadDomains(1);
                } else {
                    toast(data.msg || '<?= __('导入失败') ?>', 'error');
                }
            })
            .catch(function() { toast('<?= __('请求失败') ?>', 'error'); });
    }

