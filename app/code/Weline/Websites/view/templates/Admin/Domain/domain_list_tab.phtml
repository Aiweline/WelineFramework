    function loadDnsRecords(domainId) {
        var tbody = document.getElementById('weline-dns-records-body');
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4"><i class="mdi mdi-loading mdi-spin"></i></td></tr>';

        fetch(urls.dnsRecords + '?domain_id=' + domainId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code === 200) {
                    var providerBadge = document.getElementById('weline-dns-provider-badge');
                    providerBadge.textContent = data.data.dns_provider_name || data.data.dns_provider || '-';
                    providerBadge.className = 'weline-domain-dns-provider';
                    if (data.data.dns_provider === 'cloudflare') {
                        providerBadge.classList.add('weline-domain-dns-cloudflare');
                    } else if (data.data.is_original_provider) {
                        providerBadge.classList.add('weline-domain-dns-original');
                    } else {
                        providerBadge.classList.add('weline-domain-dns-other');
                    }

                    document.getElementById('weline-dns-server-ip').textContent = data.data.server_ip || '-';

                    renderDnsRecords(data.data.records || []);
                } else {
                    toast(data.msg || '<?= __('获取DNS记录失败') ?>', 'error');
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4"><?= __('获取失败') ?></td></tr>';
                }
            })
            .catch(function() {
                toast('<?= __('请求失败') ?>', 'error');
            });
    }

    function renderDnsRecords(records) {
        var tbody = document.getElementById('weline-dns-records-body');
        if (!records.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4"><?= __('暂无DNS记录') ?></td></tr>';
            return;
        }

        var html = '';
        records.forEach(function(rec) {
            var statusClass = 'weline-domain-status-pending';
            var statusText = '<?= __('待同步') ?>';
            if (rec.resolve_status === 'ok') {
                statusClass = 'weline-domain-status-resolved';
                statusText = '<?= __('正常') ?>';
            } else if (rec.resolve_status === 'error') {
                statusClass = 'weline-domain-status-error';
                statusText = '<?= __('异常') ?>';
            }

            var localBadge = rec.is_local_ip ? ' <span class="weline-domain-local-badge"><?= __('本机') ?></span>' : '';

            html += '<tr>' +
                '<td><span class="badge bg-secondary">' + (rec.record_type || rec.type || 'A') + '</span></td>' +
                '<td>' + (rec.host || '@') + '</td>' +
                '<td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;" title="' + (rec.value || '') + '">' + (rec.value || '') + localBadge + '</td>' +
                '<td>' + (rec.ttl || 600) + '</td>' +
                '<td><span class="weline-domain-status-badge ' + statusClass + '">' + statusText + '</span></td>' +
                '<td class="text-end">' +
                    '<button type="button" class="btn btn-outline-danger btn-sm" title="<?= __('删除') ?>" onclick="WelineDomainList.deleteDnsRecord(\'' + (rec.remote_record_id || rec.record_id || '') + '\', \'' + (rec.record_type || rec.type || 'A') + '\', \'' + (rec.host || '@') + '\')"><i class="mdi mdi-delete"></i></button>' +
                '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

