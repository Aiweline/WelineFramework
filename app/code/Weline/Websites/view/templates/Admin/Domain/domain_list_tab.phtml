/**
 * 域名列表 Tab 内容
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $domains 域名列表
 * @var array $accounts 域名商账号列表
 */
$domains = $domains ?? [];
$accounts = $accounts ?? [];
$registrarAccountOptions = [];
foreach ($accounts as $account) {
    $accountId = (int)($account['account_id'] ?? 0);
    if ($accountId <= 0) {
        continue;
    }
    $registrarName = \trim((string)($account['registrar_name'] ?? $account['registrar_code'] ?? ''));
    $accountName = \trim((string)($account['account_name'] ?? ''));
    $registrarAccountOptions[] = [
        'value' => (string)$accountId,
        'label' => $accountName !== '' ? $accountName . ($registrarName !== '' ? ' (' . $registrarName . ')' : '') : $registrarName,
        'group' => $registrarName !== '' ? $registrarName : (string)__('Other'),
        'meta' => (string)($account['registrar_code'] ?? ''),
    ];
}
$registrarAccountOptionsJson = \json_encode($registrarAccountOptions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
$manualNsProviderOptions = [
    ['value' => 'dnspod', 'label' => 'DNSPod', 'group' => (string)__('DNS 服务商'), 'meta' => 'ns1.dnspod.net, ns2.dnspod.net'],
    ['value' => 'alidns', 'label' => (string)__('阿里云 DNS'), 'group' => (string)__('DNS 服务商'), 'meta' => 'ns1.alidns.com, ns2.alidns.com'],
    ['value' => 'custom', 'label' => (string)__('自定义'), 'group' => (string)__('DNS 服务商'), 'meta' => (string)__('手动输入 Nameserver')],
];
$manualNsProviderOptionsJson = \json_encode($manualNsProviderOptions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
