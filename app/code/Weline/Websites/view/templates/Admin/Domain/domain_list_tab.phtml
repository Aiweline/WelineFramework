    function doBatchChangeNs() {
        if (batchChangeNsSelectedIds.length === 0) {
            toast('<?= __('请选择要切换DNS的域名') ?>', 'warning');
            return;
        }

        var mode = document.querySelector('input[name="weline-ns-switch-mode"]:checked').value;
        var submitBtn = document.getElementById('weline-batch-ns-submit');

        if (mode === 'account') {
            var accountId = getRegistrarSelectValue('weline-batch-ns-account');
            if (!accountId) {
                toast('<?= __('请选择目标账户') ?>', 'warning');
                return;
            }

            toast('<?= __('正在批量切换DNS服务器...') ?>', 'info');
            submitBtn.disabled = true;

            var fd = new FormData();
            fd.append('domain_ids', JSON.stringify(batchChangeNsSelectedIds));
            fd.append('target_account_id', accountId);

            fetch(urls.batchSwitchToAccount, { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    submitBtn.disabled = false;
                    if (data.code === 200) {
                        var msg = data.msg || '<?= __('切换完成') ?>';
                        toast(msg, 'success');
                        if (data.data && data.data.errors && data.data.errors.length > 0) {
                            console.log('<?= __('切换错误') ?>:', data.data.errors);
                        }
                        if (batchChangeNsModal) {
                            batchChangeNsModal.hide();
                        }
                        loadDomains(currentPage);
                    } else {
                        toast(data.msg || '<?= __('切换失败') ?>', 'error');
                    }
                })
                .catch(function() {
                    submitBtn.disabled = false;
                    toast('<?= __('请求失败') ?>', 'error');
                });
        } else {
            var provider = getRegistrarSelectValue('weline-batch-ns-provider');
            var customNs = document.getElementById('weline-batch-ns-custom').value.trim();

            if (!provider) {
                toast('<?= __('请选择DNS服务商') ?>', 'warning');
                return;
            }

            if (provider === 'custom' && !customNs) {
                toast('<?= __('请输入自定义Nameserver') ?>', 'warning');
                return;
            }

            toast('<?= __('正在批量切换DNS服务器...') ?>', 'info');
            submitBtn.disabled = true;

            var fd = new FormData();
            fd.append('domain_ids', JSON.stringify(batchChangeNsSelectedIds));
            if (provider === 'custom') {
                fd.append('nameservers', customNs);
            } else {
                fd.append('target_provider', provider);
            }

            fetch(urls.batchChangeNameservers, { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    submitBtn.disabled = false;
                    if (data.code === 200) {
                        var msg = data.msg || '<?= __('切换完成') ?>';
                        toast(msg, 'success');
                        if (data.data && data.data.errors && data.data.errors.length > 0) {
                            console.log('<?= __('切换错误') ?>:', data.data.errors);
                        }
                        if (batchChangeNsModal) {
                            batchChangeNsModal.hide();
                        }
                        loadDomains(currentPage);
                    } else {
                        toast(data.msg || '<?= __('切换失败') ?>', 'error');
                    }
                })
                .catch(function() {
                    submitBtn.disabled = false;
                    toast('<?= __('请求失败') ?>', 'error');
                });
        }
    }

