<script>
    (function () {
        'use strict';

        document.addEventListener('keydown', function (event) {
            var target = event.target;
            if (!(target instanceof Element)) {
                return;
            }

            if (!target.closest('[data-app-search-form]')) {
                return;
            }

            if (typeof window.appSearch === 'function') {
                window.appSearch(event);
            }
        });
    })();

    (function () {
        'use strict';

        var sidebarToggle = document.getElementById('vertical-menu-btn');
        if (!sidebarToggle || sidebarToggle.dataset.welineSidebarToggleBound === '1') {
            return;
        }

        sidebarToggle.dataset.welineSidebarToggleBound = '1';
        sidebarToggle.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopImmediatePropagation();

            document.body.classList.toggle('sidebar-enable');
            if (window.innerWidth >= 992) {
                document.body.classList.toggle('vertical-collpsed');
            } else {
                document.body.classList.remove('vertical-collpsed');
            }
        }, true);
    })();

    (function () {
        return;

        var topbar = document.getElementById('page-topbar');
        if (!topbar || typeof window.bootstrap === 'undefined' || !window.bootstrap.Dropdown) {
            return;
        }

        var Dropdown = window.bootstrap.Dropdown;
        // Bootstrap 新版会自动处理 data-bs-toggle="dropdown"，
        // 仅在旧版缺失 getOrCreateInstance 时做兜底，避免双重 toggle 导致无法展开。
        if (Dropdown && typeof Dropdown.getOrCreateInstance === 'function') {
            return;
        }

        var triggers = topbar.querySelectorAll('[data-bs-toggle="dropdown"]');
        triggers.forEach(function (trigger) {
            if (trigger.dataset.welineDropdownBound === '1') {
                return;
            }
            trigger.dataset.welineDropdownBound = '1';
            trigger.addEventListener('click', function (event) {
                event.preventDefault();
                var config = {autoClose: true};
                var instance = null;
                if (Dropdown && typeof Dropdown.getInstance === 'function') {
                    instance = Dropdown.getInstance(trigger);
                    if (!instance) {
                        instance = new Dropdown(trigger, config);
                    }
                } else {
                    instance = new Dropdown(trigger, config);
                }
                instance.toggle();
            });
        });
    })();
</script>
