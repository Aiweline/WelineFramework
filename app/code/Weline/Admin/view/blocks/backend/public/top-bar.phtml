$toBackendLogoUrl = static function (string $path, int $width, int $height): string {
    $path = trim($path);
    if ($path === '') {
        return '';
    }
    if (str_starts_with($path, 'http') || str_starts_with($path, '//') || str_starts_with($path, '/static/')) {
        return $path;
    }

    $relative = ltrim($path, '/\\');
    foreach (['pub/media/', 'media/'] as $prefix) {
        if (str_starts_with($relative, $prefix)) {
            $relative = substr($relative, strlen($prefix));
            break;
        }
    }

    $mediaFile = defined('PUB') ? PUB . 'media' . DS . str_replace(['/', '\\'], DS, $relative) : '';
    if ($relative !== '' && $mediaFile !== '' && is_file($mediaFile)) {
        return '/media/' . str_replace('\\', '/', $relative);
    }

    return ImageHelper::pathToMediaUrl($path, $width, $height);
};
$resolveBackendLogo = static function (string $configKey, string $defaultSource, int $width, int $height) use ($backendConfig, $template, $toBackendLogoUrl): string {
    $configured = $backendConfig->getConfig($configKey, 'Weline_Backend') ?: '';
    if ($configured !== '') {
        return $toBackendLogoUrl($configured, $width, $height);
    }

    return $template->fetchTagSourceFile('statics', $defaultSource)
        ?: $template->fetchTagSourceFile('statics', 'Weline_Backend::img/logo.png')
        ?: '/static/Weline/Admin/assets/images/logo-weline-default.svg';
};

