<script>
    (function () {
        var topbar = document.getElementById('page-topbar');
        if (!topbar) {
            return;
        }

        var triggers = topbar.querySelectorAll('[data-bs-toggle="dropdown"]');
        if (!triggers.length) {
            return;
        }

        var hasBootstrapDropdown = !!(window.bootstrap && window.bootstrap.Dropdown);

        function closeManualDropdowns(exclude) {
            triggers.forEach(function (btn) {
                var menu = btn.nextElementSibling;
                if (!menu || !menu.classList.contains('dropdown-menu')) {
                    return;
                }
                if (exclude && btn === exclude) {
                    return;
                }
                menu.classList.remove('show');
                btn.setAttribute('aria-expanded', 'false');
            });
        }

        triggers.forEach(function (trigger) {
            if (trigger.dataset.welineDropdownBound === '1') {
                return;
            }
            trigger.dataset.welineDropdownBound = '1';

            trigger.addEventListener('click', function (event) {
                if (hasBootstrapDropdown) {
                    var dropdown = window.bootstrap.Dropdown.getOrCreateInstance(trigger);
                    dropdown.toggle();
                    return;
                }

                event.preventDefault();
                event.stopPropagation();
                var menu = trigger.nextElementSibling;
                if (!menu || !menu.classList.contains('dropdown-menu')) {
                    return;
                }
                var willOpen = !menu.classList.contains('show');
                closeManualDropdowns(trigger);
                menu.classList.toggle('show', willOpen);
                trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            });
        });

        document.addEventListener('click', function (event) {
            if (topbar.contains(event.target)) {
                return;
            }
            closeManualDropdowns();
        }, true);

        var themeToggle = document.getElementById('theme-mode-toggle');
        if (!themeToggle) {
            return;
        }

        function getThemeMode() {
            var body = document.body;
            var root = document.documentElement;
            var mode = body.getAttribute('data-topbar')
                || body.getAttribute('data-sidebar')
                || root.getAttribute('data-theme-mode')
                || root.getAttribute('data-bs-theme');
            return mode === 'dark' ? 'dark' : 'light';
        }

        function updateThemeToggleIcon(mode) {
            var icon = themeToggle.querySelector('i');
            if (!icon) {
                return;
            }
            icon.className = mode === 'dark' ? 'ri-sun-line' : 'ri-moon-clear-line';
        }

        function applyThemeMode(mode) {
            var normalizedMode = mode === 'dark' ? 'dark' : 'light';
            var body = document.body;
            var root = document.documentElement;

            body.setAttribute('data-topbar', normalizedMode);
            body.setAttribute('data-sidebar', normalizedMode);
            body.setAttribute('data-bs-theme', normalizedMode);
            root.setAttribute('data-theme-mode', normalizedMode);
            root.setAttribute('data-bs-theme', normalizedMode);

            updateThemeToggleIcon(normalizedMode);
        }

        applyThemeMode(getThemeMode());

        themeToggle.addEventListener('click', function (event) {
            event.preventDefault();

            var nextMode = getThemeMode() === 'dark' ? 'light' : 'dark';
            applyThemeMode(nextMode);

            if (typeof window.setThemeConfig === 'function') {
                window.setThemeConfig({
                    layouts: {
                        'data-topbar': nextMode,
                        'data-sidebar': nextMode
                    },
                    'theme-mode-switch': nextMode,
                    'rtl-mode-switch': false
                });
            }
        });
    })();
</script>
