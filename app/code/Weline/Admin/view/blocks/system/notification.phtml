                <button type="button" class="weline-notif-mark-read"><?= __('全部已读') ?></button>
            <?php endif; ?>
        </div>
        <div class="weline-notif-list">
            <?php if (empty($notices)): ?>
                <div class="weline-notif-empty">
                    <i class="ri-notification-off-line"></i>
                    <span><?= __('暂无通知') ?></span>
                </div>
            <?php else: ?>
                <?php
                /**@var \Weline\Admin\Model\System\SystemNotification $notice */
                foreach ($notices as $notice):
                    $iconClass = 'weline-notif-icon--info';
                    $type = strtolower($notice->getData('type') ?? 'info');
                    if (in_array($type, ['primary', 'success', 'warning', 'info', 'danger'])) {
                        $iconClass = 'weline-notif-icon--' . $type;
                    }
                    $noticeUrl = $notice->getData('url') ?? '';
                    $source = $notice->getData('source') ?? '';
                    ?>
                    <a href="<?= $noticeUrl ? htmlspecialchars($noticeUrl) : '#' ?>"
                       class="weline-notif-item"
                        <?= $noticeUrl ? '' : 'data-notification-empty-link="1"' ?>>
                        <div class="weline-notif-icon <?= $iconClass ?>">
                            <?php if ($notice->getIsIcon()): ?>
                                <i class="<?= htmlspecialchars($notice->getAvatar()) ?>"></i>
                            <?php else:
                                $avatar = $notice->getAvatar() ? $this->fetchTagSourceFile('static', 'Weline_Admin::' . $notice->getAvatar()) : '';
                                if ($avatar): ?>
                                    <img src="<?= $avatar ?>" alt="">
                                <?php else: ?>
                                    <i class="ri-notification-3-line"></i>
                                <?php endif;
                            endif; ?>
                        </div>
                        <div class="weline-notif-content">
                            <h6 class="weline-notif-title"><?= htmlspecialchars($notice->getTitle()) ?></h6>
                            <p class="weline-notif-desc"><?= $notice->getContent() ?></p>
                            <div class="weline-notif-meta">
                                <i class="ri-time-line"></i>
                                <span><?= $notice->getData('create_time') ?? '' ?></span>
                                <?php if ($source): ?>
                                    <span class="weline-notif-tag">
                                        <i class="ri-apps-line"></i>
                                        <?= htmlspecialchars($source) ?>
                                    </span>
                                <?php endif; ?>
                            </div>
                        </div>
                    </a>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>
