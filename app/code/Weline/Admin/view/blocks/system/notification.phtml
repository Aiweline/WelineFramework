<script>
(function() {
    'use strict';

    document.addEventListener('click', function(event) {
        var target = event.target;
        if (!(target instanceof Element)) {
            return;
        }

        if (target.closest('[data-notification-empty-link]')) {
            event.preventDefault();
        }
    });
})();
</script>
