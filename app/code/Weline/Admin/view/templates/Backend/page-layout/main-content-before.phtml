<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \Weline\Backend\Block\ThemeConfig $themeConfig */
$themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);

$logStage = static function (string $stage, float $startedAt, string $html = ''): void {
    if (!defined('DEV') || !DEV || !class_exists(\Weline\Server\Log\WlsLogger::class)) {
        return;
    }

    if (!(bool)\Weline\Framework\App\Env::get('wls.debug.backend_layout_trace', false)) {
        return;
    }

    \Weline\Server\Log\WlsLogger::warning_('[BackendLayout::before] ' . $stage, [
        'elapsed_ms' => round((microtime(true) - $startedAt) * 1000, 2),
        'html_bytes' => strlen($html),
    ]);
};

$stageStartedAt = microtime(true);
$headHtml = $this->fetchTagHtml('templates', 'Weline_Admin::common/head.phtml');
$logStage('head', $stageStartedAt, $headHtml);

$stageStartedAt = microtime(true);
$loadingHtml = $this->fetchTagHtml('templates', 'Weline_Admin::common/page/loading.phtml');
$logStage('loading', $stageStartedAt, $loadingHtml);

$stageStartedAt = microtime(true);
$topbarBlock = \Weline\Framework\Manager\ObjectManager::make(\Weline\Admin\Block\Backend\Page\Topbar::class);
$topbarHtml = $topbarBlock->render();
$logStage('topbar', $stageStartedAt, $topbarHtml);

$stageStartedAt = microtime(true);
$topnavBlock = \Weline\Framework\Manager\ObjectManager::make(\Weline\Admin\Block\Backend\Page\Topnav::class);
$topnavHtml = $topnavBlock->render();
$logStage('topnav', $stageStartedAt, $topnavHtml);

$stageStartedAt = microtime(true);
$leftSidebarHtml = $this->fetchTagHtml('templates', 'Weline_Admin::common/left-sidebar.phtml');
$logStage('left_sidebar', $stageStartedAt, $leftSidebarHtml);
?>
