<!-- 角色分配列表 -->
<div class='row'>
    <div class='col-12'>
        <div class='card'>
            <div class='card-body'>
                <h4 class='card-title'><lang>管理员角色分配</lang></h4>
                <p class='card-title-desc'><lang>调整管理员角色</lang></p>
                <div class='row'>
                    <div class='col-6'>
                        <div class='col-md-6'>
                            <block class='Weline\Component\Block\Form\Search' id='admin-user-search'
                                   action='*/backend/user'
                                   method='get'
                                   keyword='search' value=''
                                   params=''
                                   placeholder='请输入搜索词'></block>
                        </div>
                    </div>
                    <div class='col-6'>
                        <a class='btn btn-primary pull-right mt-1 mb-1' href="@backend-url('*/backend/user/listing')">
                            <lang>返回</lang>
                        </a>
                    </div>
                </div>

                <div class='table-rep-plugin'>
                    <div class='table-responsive mb-0' data-pattern='priority-columns'>
                        <table id='tech-companies-1' class='table table-striped table-bordered'>
                            <thead>
                            <tr>
                                <th data-priority='1'><lang>ID</lang></th>
                                <th data-priority='1'><lang>管理员</lang></th>
                                <th data-priority='1'><lang>邮箱</lang></th>
                                <th data-priority='1'><lang>角色分配</lang></th>
                                <th data-priority='1'><lang>创建于</lang></th>
                                <th data-priority='1'><lang>更新于</lang></th>
                                <th data-priority='1'><lang>操作</lang></th>
                            </tr>
                            </thead>
                            <tbody>
                            <foreach name='users' item='user' key='key'>
                                <form action="@backend-url('*/backend/user/assignrole')" method="post">
                                    <tr>
                                        <td class='co-name'>{{user.user_id}}</td>
                                        <td class='co-name'>{{user.username}}</td>
                                        <td class='co-name'>{{user.email}}</td>
                                        <td class='co-name'>
                                            <input type="hidden" name="user_id" value="{{user.user_id}}">
                                            <select class="form-control" name="role_id" id="role_id">
                                                <option selected><lang>未分配角色</lang></option>
                                                <foreach name='roles' item='role'>
                                                    <if condition="user.role_id === role.role_id">
                                                        <option selected value='{{role.role_id}}'>{{role.role_name}}</option>
                                                        <else/>
                                                        <option value='{{role.role_id}}'>{{role.role_name}}</option>
                                                    </if>
                                                </foreach>
                                            </select>
                                        </td>
                                        <td class='co-name'>{{user.create_time}}</td>
                                        <td class='co-name'>{{user.update_time}}</td>
                                        <td class='co-name'>
                                            <if condition='user.user_id !== current_user.user_id'>
                                                <div class='d-grid gap-2 d-md-flex'>
                                                    <input type="submit" class="btn btn-primary" value="@lang{分配}">
                                                </div>
                                            </if>
                                        </td>
                                    </tr>
                                </form>
                            </foreach>
                            <empty name='users'>
                                <tr>
                                    <td colspan='5' class='text-center'><lang>暂无记录</lang></td>
                                </tr>
                            </empty>
                            </tbody>
                        </table>
                        {{pagination}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

