<!-- 组件脚本 -->
<script>
(function() {
    'use strict';

    var config = {
        apiAssign: '<?= $this->getBackendUrl("*/backend/user/api-assign-role") ?>',
        text: {
            assignSuccess: '<?= addslashes(__("角色分配成功")) ?>',
            assignFail: '<?= addslashes(__("角色分配失败")) ?>',
            networkError: '<?= addslashes(__("网络错误，请检查网络后重试")) ?>',
            cannotAssignSelf: '<?= addslashes(__("不能修改自己的角色")) ?>'
        }
    };

    function showSaving(selector) {
        selector.querySelector('.weline-role-saving').classList.remove('d-none');
        selector.querySelector('.weline-role-saved').classList.add('d-none');
        selector.closest('tr').classList.add('is-saving');
    }

    function showSaved(selector) {
        selector.querySelector('.weline-role-saving').classList.add('d-none');
        selector.querySelector('.weline-role-saved').classList.remove('d-none');
        selector.closest('tr').classList.remove('is-saving');
        
        setTimeout(function() {
            selector.querySelector('.weline-role-saved').classList.add('d-none');
        }, 2000);
    }

    function hideSaving(selector) {
        selector.querySelector('.weline-role-saving').classList.add('d-none');
        selector.closest('tr').classList.remove('is-saving');
    }

    function handleRoleChange(e) {
        var select = e.target;
        var userId = select.dataset.userId;
        var roleId = select.value;
        var selector = select.closest('.weline-role-selector');
        
        showSaving(selector);
        
        var url = config.apiAssign;
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ user_id: userId, role_id: roleId }) };
        window.Weline.Api.request(url, opts)
        .then(function(res) {
            var result = (res && res.data) !== undefined ? res.data : res;
            if (result.success) {
                showSaved(selector);
                BackendToast.success(result.msg || config.text.assignSuccess);
                
                var row = select.closest('tr');
                var statusCell = row.querySelector('.weline-assign-status');
                if (statusCell) {
                    var assignedBadge = statusCell.querySelector('.weline-status-assigned');
                    var unassignedBadge = statusCell.querySelector('.weline-status-unassigned');
                    if (roleId) {
                        assignedBadge.style.display = 'inline-block';
                        unassignedBadge.style.display = 'none';
                    } else {
                        assignedBadge.style.display = 'none';
                        unassignedBadge.style.display = 'inline-block';
                    }
                }
                
                selector.dataset.currentRole = roleId;
            } else {
                hideSaving(selector);
                BackendToast.error(result.msg || config.text.assignFail);
                
                var originalRole = selector.dataset.currentRole || '';
                select.value = originalRole;
            }
        })
        .catch(function(error) {
            hideSaving(selector);
            BackendToast.error(config.text.networkError + (error.message ? ': ' + error.message : ''));
            
            var originalRole = selector.dataset.currentRole || '';
            select.value = originalRole;
        });
    }

    function init() {
        document.querySelectorAll('.weline-role-select').forEach(function(select) {
            select.addEventListener('change', handleRoleChange);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
