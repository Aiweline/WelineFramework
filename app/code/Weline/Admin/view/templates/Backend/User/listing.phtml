<!-- 组件脚本 -->
<script>
(function() {
    'use strict';

    var config = {
        apiSave: '<?= $this->getBackendUrl("*/backend/user/api-save") ?>',
        apiDelete: '<?= $this->getBackendUrl("*/backend/user/api-delete") ?>',
        apiToggle: '<?= $this->getBackendUrl("*/backend/user/api-toggle") ?>',
        text: {
            addTitle: '<?= addslashes(__("新增管理员")) ?>',
            editTitle: '<?= addslashes(__("编辑管理员")) ?>',
            saveSuccess: '<?= addslashes(__("保存成功")) ?>',
            saveFail: '<?= addslashes(__("保存失败")) ?>',
            deleteConfirm: '<?= addslashes(__("确定要删除用户「%{1}」吗？此操作不可恢复。")) ?>',
            deleteSuccess: '<?= addslashes(__("删除成功")) ?>',
            deleteFail: '<?= addslashes(__("删除失败")) ?>',
            enableConfirm: '<?= addslashes(__("确定要激活此用户吗？")) ?>',
            disableConfirm: '<?= addslashes(__("确定要禁用此用户吗？禁用后该用户将无法登录。")) ?>',
            toggleSuccess: '<?= addslashes(__("操作成功")) ?>',
            toggleFail: '<?= addslashes(__("操作失败")) ?>',
            networkError: '<?= addslashes(__("网络错误，请检查网络后重试")) ?>',
            validationError: '<?= addslashes(__("请填写必填项")) ?>'
        }
    };

    var offcanvasEl = document.getElementById('welineUserOffcanvas');
    var offcanvas = null;
    var form = document.getElementById('welineUserForm');
    var isEditMode = false;

    function initOffcanvas() {
        if (typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            offcanvas = new bootstrap.Offcanvas(offcanvasEl);
        }
    }

    function openOffcanvas(mode, userData) {
        isEditMode = mode === 'edit';
        var title = isEditMode ? config.text.editTitle : config.text.addTitle;
        document.getElementById('welineUserOffcanvasTitle').textContent = title;
        
        form.reset();
        form.classList.remove('was-validated');
        
        if (isEditMode && userData) {
            document.getElementById('weline-user-id').value = userData.userId;
            document.getElementById('weline-user-username').value = userData.username;
            document.getElementById('weline-user-email').value = userData.email;
            document.getElementById('weline-user-password').removeAttribute('required');
            document.querySelector('.weline-password-required').style.display = 'none';
            document.querySelector('.weline-password-hint').style.display = 'block';
        } else {
            document.getElementById('weline-user-id').value = '';
            document.getElementById('weline-user-password').setAttribute('required', '');
            document.querySelector('.weline-password-required').style.display = 'inline';
            document.querySelector('.weline-password-hint').style.display = 'none';
        }
        
        if (offcanvas) {
            offcanvas.show();
        }
    }

    function closeOffcanvas() {
        if (offcanvas) {
            offcanvas.hide();
        }
    }

    function setLoading(loading) {
        var btn = document.getElementById('weline-user-submit');
        btn.disabled = loading;
        btn.querySelector('.weline-submit-text').classList.toggle('d-none', loading);
        btn.querySelector('.weline-submit-loading').classList.toggle('d-none', !loading);
    }

    function handleSave(e) {
        e.preventDefault();
        
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            BackendToast.warning(config.text.validationError);
            return;
        }
        
        setLoading(true);
        
        var formData = new FormData(form);
        var data = {};
        formData.forEach(function(value, key) {
            data[key] = value;
        });
        
        fetch(config.apiSave, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(data)
        })
        .then(function(response) { return response.json(); })
        .then(function(result) {
            setLoading(false);
            if (result.success) {
                BackendToast.success(result.msg || config.text.saveSuccess);
                closeOffcanvas();
                setTimeout(function() { location.reload(); }, 800);
            } else {
                BackendToast.error(result.msg || config.text.saveFail);
            }
        })
        .catch(function(error) {
            setLoading(false);
            BackendToast.error(config.text.networkError + (error.message ? ': ' + error.message : ''));
        });
    }

    function handleDelete(userId, username) {
        var message = config.text.deleteConfirm.replace('%{1}', username);
        
        BackendConfirm.show(message, {
            title: '<?= addslashes(__("确认删除")) ?>',
            confirmText: '<?= addslashes(__("删除")) ?>',
            cancelText: '<?= addslashes(__("取消")) ?>',
            type: 'danger'
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            fetch(config.apiDelete, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ id: userId })
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    BackendToast.success(result.msg || config.text.deleteSuccess);
                    var row = document.querySelector('tr[data-user-id="' + userId + '"]');
                    if (row) {
                        row.style.transition = 'opacity 0.3s';
                        row.style.opacity = '0';
                        setTimeout(function() { row.remove(); }, 300);
                    }
                } else {
                    BackendToast.error(result.msg || config.text.deleteFail);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error.message ? ': ' + error.message : ''));
            });
        });
    }

    function handleToggle(userId, action) {
        var message = action === 'enable' ? config.text.enableConfirm : config.text.disableConfirm;
        var type = action === 'enable' ? 'info' : 'warning';
        
        BackendConfirm.show(message, {
            title: action === 'enable' ? '<?= addslashes(__("激活用户")) ?>' : '<?= addslashes(__("禁用用户")) ?>',
            confirmText: '<?= addslashes(__("确定")) ?>',
            cancelText: '<?= addslashes(__("取消")) ?>',
            type: type
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            fetch(config.apiToggle, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ id: userId, action: action })
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    BackendToast.success(result.msg || config.text.toggleSuccess);
                    setTimeout(function() { location.reload(); }, 800);
                } else {
                    BackendToast.error(result.msg || config.text.toggleFail);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error.message ? ': ' + error.message : ''));
            });
        });
    }

    function togglePasswordVisibility(btn) {
        var input = btn.closest('.input-group').querySelector('input');
        var icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('mdi-eye');
            icon.classList.add('mdi-eye-off');
        } else {
            input.type = 'password';
            icon.classList.remove('mdi-eye-off');
            icon.classList.add('mdi-eye');
        }
    }

    function init() {
        initOffcanvas();
        
        var addBtn = document.getElementById('weline-user-add-btn');
        if (addBtn) {
            addBtn.addEventListener('click', function() {
                openOffcanvas('add');
            });
        }
        
        document.querySelectorAll('.weline-user-edit-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                openOffcanvas('edit', {
                    userId: this.dataset.userId,
                    username: this.dataset.username,
                    email: this.dataset.email
                });
            });
        });
        
        document.querySelectorAll('.weline-user-delete-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                handleDelete(this.dataset.userId, this.dataset.username);
            });
        });
        
        document.querySelectorAll('.weline-user-toggle-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                handleToggle(this.dataset.userId, this.dataset.action);
            });
        });
        
        document.querySelectorAll('.weline-toggle-password').forEach(function(btn) {
            btn.addEventListener('click', function() {
                togglePasswordVisibility(this);
            });
        });
        
        form.addEventListener('submit', handleSave);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
