<?php
/** @var \Weline\Framework\View\Template $this */

$loginSiteName = (string)($this->getData('login_site_name') ?: 'Weline');
$themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);
$themeModel = (string)$themeConfig->getThemeModel();
$themeCssSuffix = $themeModel !== '' ? '-' . $themeModel : '';
$currentLang = (string)\w_env('user.lang', 'zh_Hans_CN');
$currentCurrency = (string)\w_env('user.currency', 'CNY');
$defaultCurrency = \w_env('website.currency', '') ?: \Weline\Framework\App\Env::get('currency', 'CNY') ?: 'CNY';
$availableCurrencies = [];
try {
    if (class_exists(\Weline\Websites\Data\WebsiteData::class)) {
        foreach (\Weline\Websites\Data\WebsiteData::getCurrencyCodes() as $currencyCode) {
            $currencyCode = strtoupper(trim((string)$currencyCode));
            if ($currencyCode !== '') {
                $availableCurrencies[] = $currencyCode;
            }
        }
    }
} catch (\Throwable) {
    $availableCurrencies = [];
}
$defaultCurrency = strtoupper(trim((string)$defaultCurrency)) ?: 'CNY';
$availableCurrencies[] = $defaultCurrency;
$availableCurrencies = array_values(array_unique($availableCurrencies));
$currentCurrency = strtoupper(trim((string)$currentCurrency));
if (!\Weline\Framework\App\State::isAllowedCurrencyCode($currentCurrency)) {
    $currentCurrency = $defaultCurrency;
}
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
?>
<base href="@backend-url('/')">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
<meta name="description" content="<?= htmlspecialchars((string)__('后台登录'), ENT_QUOTES, 'UTF-8') ?>">
<meta name="author" content="<?= htmlspecialchars($loginSiteName, ENT_QUOTES, 'UTF-8') ?>">
<title><?= htmlspecialchars((string)__('登录 %{name} 管理面板', ['name' => $loginSiteName]), ENT_QUOTES, 'UTF-8') ?></title>
<link rel="Shortcut Icon" href="@static(Weline_Backend::img/favicon.png)">
<link rel="Bookmark" href="@static(Weline_Backend::img/favicon.png)">
<link rel="icon" type="image/png" sizes="128x128" href="@static(Weline_Backend::img/favicon.png)">
<link href="<?= $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/bootstrap' . $themeCssSuffix . '.min.css') ?>" rel="stylesheet" type="text/css">
<css>Weline_Admin::assets/css/icons.min.css</css>
<link href="<?= $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/app' . $themeCssSuffix . '.min.css') ?>" rel="stylesheet" type="text/css">
<theme:css>Weline_Theme::theme/backend/variables/_colors.css</theme:css>
<theme:css>Weline_Theme::theme/backend/variables/_typography.css</theme:css>
<theme:css>Weline_Theme::theme/backend/variables/_spacing.css</theme:css>
<theme:css>Weline_Theme::theme/backend/variables/_borders.css</theme:css>
<theme:css>Weline_Theme::theme/backend/variables/_shadows.css</theme:css>
<theme:css>Weline_Theme::theme/backend/colors/_default.css</theme:css>
<theme:css>Weline_Theme::theme/backend/assets/css/theme.css</theme:css>
<theme:css>Weline_Theme::theme/backend/colors/_dark.css</theme:css>
<script data-no-extract="true">
window.__WelineLoginConfig = <?= json_encode([
    'currentLang' => $currentLang,
    'currentCurrency' => $currentCurrency,
    'defaultCurrency' => $defaultCurrency,
    'availableCurrencies' => $availableCurrencies,
    'themeMode' => $themeModel === '' ? 'light' : $themeModel,
], $jsonForScriptFlags) ?>;
</script>
