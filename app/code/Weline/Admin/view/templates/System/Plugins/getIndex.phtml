                                    <i class="mdi mdi-<?= $isDisabled ? 'close-circle' : 'check-circle' ?>"></i>
                                    <?= $statusText ?>
                                </span>
                            </td>
                            <td>
                                <span class="weline-plugin-sort"><?= htmlspecialchars($instance['plugins']['sort'] ?? '0') ?></span>
                            </td>
                            <td>
                                <?php if ($module): ?>
                                <span class="weline-plugin-module"><?= htmlspecialchars($module) ?></span>
                                <?php else: ?>
                                <span style="color: var(--backend-color-text-tertiary);">-</span>
                                <?php endif; ?>
                            </td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endforeach; ?>
    <?php endif; ?>
</div>

<script>
(function() {
    'use strict';
    
    var searchTimeout = null;
    
    window.togglePluginFile = function(header) {
        var body = header.nextElementSibling;
        header.classList.toggle('collapsed');
        body.classList.toggle('collapsed');
    };
    
    document.getElementById('expand-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-plugin-file-header').forEach(function(header) {
            header.classList.remove('collapsed');
            header.nextElementSibling.classList.remove('collapsed');
        });
    });
    
    document.getElementById('collapse-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-plugin-file-header').forEach(function(header) {
            header.classList.add('collapsed');
            header.nextElementSibling.classList.add('collapsed');
        });
    });
    
    document.getElementById('plugin-search').addEventListener('keyup', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() {
            filterPlugins();
        }, 300);
    });
    
    document.getElementById('plugin-search-clear').addEventListener('click', function() {
        document.getElementById('plugin-search').value = '';
        filterPlugins();
    });
    
    document.getElementById('plugin-filter-status').addEventListener('change', filterPlugins);
    document.getElementById('plugin-filter-module').addEventListener('change', filterPlugins);
    
    function filterPlugins() {
        var searchVal = document.getElementById('plugin-search').value.trim().toLowerCase();
        var statusFilter = document.getElementById('plugin-filter-status').value;
        var moduleFilter = document.getElementById('plugin-filter-module').value;
        
        var visibleFiles = 0;
        var visibleInterceptors = 0;
        
        document.querySelectorAll('.weline-plugin-file-card').forEach(function(card) {
            var fileText = card.getAttribute('data-file') || '';
            var fileVisible = false;
            
            card.querySelectorAll('.weline-plugin-table tbody tr').forEach(function(row) {
                var rowSearchable = row.getAttribute('data-searchable') || '';
                var rowStatus = row.getAttribute('data-status') || '';
                var rowModule = row.getAttribute('data-module') || '';
                
                var searchMatch = !searchVal || fileText.includes(searchVal) || rowSearchable.includes(searchVal);
                var statusMatch = !statusFilter || rowStatus === statusFilter;
                var moduleMatch = !moduleFilter || rowModule === moduleFilter;
                
                if (searchMatch && statusMatch && moduleMatch) {
                    row.style.display = '';
                    fileVisible = true;
                    visibleInterceptors++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            if (fileVisible) {
                card.style.display = '';
                visibleFiles++;
                
                if (searchVal || statusFilter || moduleFilter) {
                    var header = card.querySelector('.weline-plugin-file-header');
                    var body = card.querySelector('.weline-plugin-file-body');
                    header.classList.remove('collapsed');
                    body.classList.remove('collapsed');
                }
            } else {
                card.style.display = 'none';
            }
        });
        
        var resultInfo = document.getElementById('plugin-result-info');
        var resultText = document.getElementById('plugin-result-text');
        
        if (searchVal || statusFilter || moduleFilter) {
            resultText.textContent = '<?= __("找到") ?> ' + visibleInterceptors + ' <?= __("个拦截器，来自") ?> ' + visibleFiles + ' <?= __("个配置文件") ?>';
            resultInfo.classList.add('visible');
        } else {
            resultInfo.classList.remove('visible');
        }
    }
    
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && (e.key === 'f' || e.key === 'F')) {
            e.preventDefault();
            document.getElementById('plugin-search').focus();
        }
    });
})();
</script>
