<?php
/**
 * 插件管理页面
 *
 * @var \Weline\Framework\View\Template $this
 */

$plugins = $this->getData('plugins') ?: [];

$totalFiles = count($plugins);
$totalPlugins = 0;
$totalInterceptors = 0;
$enabledPlugins = 0;
$disabledPlugins = 0;
$moduleSet = [];

foreach ($plugins as $file => $pluginGroups) {
    foreach ($pluginGroups as $name => $instances) {
        $totalPlugins++;
        foreach ($instances as $instance) {
            $totalInterceptors++;
            $disabled = $instance['plugins']['disabled'] ?? 'false';
            if ($disabled === 'true' || $disabled === true || $disabled === '1') {
                $disabledPlugins++;
            } else {
                $enabledPlugins++;
            }
            if (!empty($instance['plugins']['module'])) {
                $moduleSet[$instance['plugins']['module']] = true;
            }
        }
    }
}
$moduleCount = count($moduleSet);
?>

