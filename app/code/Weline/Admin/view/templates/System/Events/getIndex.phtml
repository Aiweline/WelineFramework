                    <span class="weline-event-observer-count"><?= count($observers) ?> <?= __('个观察者') ?></span>
                </div>
                <table class="weline-event-table">
                    <thead>
                        <tr>
                            <th style="width: 150px;"><?= __('观察者名') ?></th>
                            <th><?= __('实例类') ?></th>
                            <th style="width: 90px;"><?= __('状态') ?></th>
                            <th style="width: 90px;"><?= __('共享') ?></th>
                            <th style="width: 70px;"><?= __('排序') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($observers as $observer): ?>
                        <?php
                        $disabled = $observer['disabled'] ?? 'false';
                        $isDisabled = ($disabled === 'true' || $disabled === true || $disabled === '1');
                        $statusClass = $isDisabled ? 'disabled' : 'enabled';
                        $statusText = $isDisabled ? __('已禁用') : __('已启用');
                        
                        $shared = $observer['shared'] ?? 'true';
                        $isShared = ($shared === 'true' || $shared === true || $shared === '1');
                        $sharedClass = $isShared ? 'yes' : 'no';
                        $sharedText = $isShared ? __('共享') : __('独占');
                        ?>
                        <tr data-status="<?= $statusClass ?>" data-searchable="<?= htmlspecialchars(strtolower(($observer['name'] ?? '') . ' ' . ($observer['instance'] ?? '') . ' ' . $eventName)) ?>">
                            <td>
                                <span class="weline-event-observer-name"><?= htmlspecialchars($observer['name'] ?? '-') ?></span>
                            </td>
                            <td>
                                <span class="weline-event-instance" title="<?= htmlspecialchars($observer['instance'] ?? '-') ?>"><?= htmlspecialchars($observer['instance'] ?? '-') ?></span>
                            </td>
                            <td>
                                <span class="weline-event-status <?= $statusClass ?>">
                                    <i class="mdi mdi-<?= $isDisabled ? 'close-circle' : 'check-circle' ?>"></i>
                                    <?= $statusText ?>
                                </span>
                            </td>
                            <td>
                                <span class="weline-event-shared <?= $sharedClass ?>">
                                    <i class="mdi mdi-<?= $isShared ? 'share-variant' : 'lock' ?>"></i>
                                    <?= $sharedText ?>
                                </span>
                            </td>
                            <td>
                                <span class="weline-event-sort"><?= htmlspecialchars($observer['sort'] ?? '10000') ?></span>
                            </td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endforeach; ?>
    <?php endif; ?>
</div>

<script>
(function() {
    'use strict';
    
    var searchTimeout = null;
    
    window.toggleEventFile = function(header) {
        var body = header.nextElementSibling;
        header.classList.toggle('collapsed');
        body.classList.toggle('collapsed');
    };

    document.querySelectorAll('[data-event-file-toggle]').forEach(function(header) {
        header.addEventListener('click', function() {
            window.toggleEventFile(header);
        });
    });
    
    document.getElementById('expand-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-event-file-header').forEach(function(header) {
            header.classList.remove('collapsed');
            header.nextElementSibling.classList.remove('collapsed');
        });
    });
    
    document.getElementById('collapse-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-event-file-header').forEach(function(header) {
            header.classList.add('collapsed');
            header.nextElementSibling.classList.add('collapsed');
        });
    });
    
    document.getElementById('event-search').addEventListener('keyup', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() {
            filterEvents();
        }, 300);
    });
    
    document.getElementById('event-search-clear').addEventListener('click', function() {
        document.getElementById('event-search').value = '';
        filterEvents();
    });
    
    document.getElementById('event-filter-status').addEventListener('change', filterEvents);
    document.getElementById('event-filter-module').addEventListener('change', filterEvents);
    document.getElementById('event-filter-event').addEventListener('change', filterEvents);
    
    function filterEvents() {
        var searchVal = document.getElementById('event-search').value.trim().toLowerCase();
        var statusFilter = document.getElementById('event-filter-status').value;
        var moduleFilter = document.getElementById('event-filter-module').value;
        var eventFilter = document.getElementById('event-filter-event').value.toLowerCase();
        
        var visibleFiles = 0;
        var visibleObservers = 0;
        
        document.querySelectorAll('.weline-event-file-card').forEach(function(card) {
            var fileText = card.getAttribute('data-file') || '';
            var cardModule = card.getAttribute('data-module') || '';
            
            if (moduleFilter && cardModule !== moduleFilter) {
                card.style.display = 'none';
                return;
            }
            
            var fileVisible = false;
            
            card.querySelectorAll('.weline-event-group').forEach(function(group) {
                var groupEventName = group.getAttribute('data-event-name') || '';
                var groupVisible = false;
                
                if (eventFilter && groupEventName !== eventFilter.toLowerCase()) {
                    group.style.display = 'none';
                    return;
                }
                
                group.querySelectorAll('.weline-event-table tbody tr').forEach(function(row) {
                    var rowSearchable = row.getAttribute('data-searchable') || '';
                    var rowStatus = row.getAttribute('data-status') || '';
                    
                    var searchMatch = !searchVal || fileText.includes(searchVal) || rowSearchable.includes(searchVal);
                    var statusMatch = !statusFilter || rowStatus === statusFilter;
                    
                    if (searchMatch && statusMatch) {
                        row.style.display = '';
                        groupVisible = true;
                        visibleObservers++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                if (groupVisible) {
                    group.style.display = '';
                    fileVisible = true;
                } else {
                    group.style.display = 'none';
                }
            });
            
            if (fileVisible) {
                card.style.display = '';
                visibleFiles++;
                
                if (searchVal || statusFilter || moduleFilter || eventFilter) {
                    var header = card.querySelector('.weline-event-file-header');
                    var body = card.querySelector('.weline-event-file-body');
                    header.classList.remove('collapsed');
                    body.classList.remove('collapsed');
                }
            } else {
                card.style.display = 'none';
            }
        });
        
        var resultInfo = document.getElementById('event-result-info');
        var resultText = document.getElementById('event-result-text');
        
        if (searchVal || statusFilter || moduleFilter || eventFilter) {
            resultText.textContent = '<?= __("找到") ?> ' + visibleObservers + ' <?= __("个观察者，来自") ?> ' + visibleFiles + ' <?= __("个配置文件") ?>';
            resultInfo.classList.add('visible');
        } else {
            resultInfo.classList.remove('visible');
        }
    }
    
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && (e.key === 'f' || e.key === 'F')) {
            e.preventDefault();
            document.getElementById('event-search').focus();
        }
    });
})();
</script>
