<?php
/**
 * 系统事件管理页面
 *
 * @var \Weline\Framework\View\Template $this
 */

$events = $this->getData('events') ?: [];

$totalFiles = count($events);
$totalEvents = 0;
$totalObservers = 0;
$enabledObservers = 0;
$disabledObservers = 0;
$sharedObservers = 0;
$eventNames = [];
$moduleSet = [];

foreach ($events as $file => $eventGroups) {
    $moduleName = explode('::', $file)[0] ?? '';
    if ($moduleName) {
        $moduleSet[$moduleName] = true;
    }
    foreach ($eventGroups as $name => $observers) {
        $totalEvents++;
        $eventNames[$name] = ($eventNames[$name] ?? 0) + count($observers);
        foreach ($observers as $observer) {
            $totalObservers++;
            $disabled = $observer['disabled'] ?? 'false';
            if ($disabled === 'true' || $disabled === true || $disabled === '1') {
                $disabledObservers++;
            } else {
                $enabledObservers++;
            }
            $shared = $observer['shared'] ?? 'true';
            if ($shared === 'true' || $shared === true || $shared === '1') {
                $sharedObservers++;
            }
        }
    }
}
$moduleCount = count($moduleSet);
$uniqueEventCount = count($eventNames);
?>

