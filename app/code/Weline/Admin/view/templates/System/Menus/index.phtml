<script>
(function() {
    'use strict';
    
    document.querySelectorAll('.menu-delete').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var menuId = this.dataset.id;
            
            if (typeof AdminConfirm !== 'undefined') {
                AdminConfirm.show({
                    title: '<?= __("确认删除") ?>',
                    message: '<?= __("确定要删除这个菜单吗？") ?>',
                    confirmText: '<?= __("确定删除") ?>',
                    cancelText: '<?= __("取消") ?>',
                    type: 'danger',
                    onConfirm: function() {
                        deleteMenu(menuId);
                    }
                });
            } else {
                deleteMenu(menuId);
            }
        });
    });
    
    function deleteMenu(menuId) {
        fetch('<?= $this->getBackendUrl("backend/system/menus/delete") ?>?id=' + menuId, {
            method: 'POST'
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success(data.message || '<?= __("删除成功") ?>');
                }
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __("删除失败") ?>');
                }
            }
        })
        .catch(function(error) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __("请求失败") ?>');
            }
        });
    }
})();
</script>
