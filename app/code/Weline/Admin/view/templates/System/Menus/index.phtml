<script>
(function() {
    'use strict';

    var menuModal = null;
    var saveUrl = '<?= $this->getBackendUrl('admin/system/menus/save') ?>';
    var deleteUrl = '<?= $this->getBackendUrl('admin/system/menus/delete') ?>';
    var detailUrl = '<?= $this->getBackendUrl('admin/system/menus/detail') ?>';

    function init() {
        menuModal = new bootstrap.Modal(document.getElementById('menuEditModal'));
        bindEvents();
    }

    function bindEvents() {
        document.querySelectorAll('.weline-menu-tree-toggle').forEach(function(toggle) {
            toggle.addEventListener('click', function(e) {
                e.stopPropagation();
                toggleNode(this);
            });
        });

        document.querySelectorAll('.weline-menu-tree-node').forEach(function(node) {
            node.addEventListener('dblclick', function(e) {
                var toggle = this.querySelector('.weline-menu-tree-toggle');
                if (toggle && !toggle.classList.contains('no-children')) {
                    toggleNode(toggle);
                }
            });
        });

        document.getElementById('weline-menu-expand-all').addEventListener('click', function() {
            document.querySelectorAll('.weline-menu-tree-toggle:not(.no-children)').forEach(function(toggle) {
                toggle.classList.add('expanded');
                var children = toggle.closest('.weline-menu-tree-item').querySelector('.weline-menu-tree-children');
                if (children) children.classList.add('expanded');
            });
        });

        document.getElementById('weline-menu-collapse-all').addEventListener('click', function() {
            document.querySelectorAll('.weline-menu-tree-toggle').forEach(function(toggle) {
                toggle.classList.remove('expanded');
                var children = toggle.closest('.weline-menu-tree-item').querySelector('.weline-menu-tree-children');
                if (children) children.classList.remove('expanded');
            });
        });

        document.getElementById('weline-menu-add').addEventListener('click', function() {
            openAddModal();
        });

        document.querySelectorAll('.weline-menu-add-child').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                openAddModal(this.dataset.parentSource);
            });
        });

        document.querySelectorAll('.weline-menu-edit').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                openEditModal(this.dataset.id);
            });
        });

        document.querySelectorAll('.weline-menu-delete').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                deleteMenu(this.dataset.id, this.dataset.name);
            });
        });

        document.getElementById('menuSaveBtn').addEventListener('click', saveMenu);

        document.getElementById('menu_icon').addEventListener('input', function() {
            var icon = this.value.trim() || 'mdi mdi-menu';
            document.querySelector('#menu_icon_preview i').className = icon;
        });
    }

    function toggleNode(toggle) {
        toggle.classList.toggle('expanded');
        var children = toggle.closest('.weline-menu-tree-item').querySelector('.weline-menu-tree-children');
        if (children) {
            children.classList.toggle('expanded');
        }
    }

    function openAddModal(parentSource) {
        document.getElementById('menuEditModalTitle').textContent = '<?= __("新增菜单") ?>';
        document.getElementById('menuEditForm').reset();
        document.getElementById('menu_id').value = '';
        if (parentSource) {
            document.getElementById('menu_parent_source').value = parentSource;
        }
        document.querySelector('#menu_icon_preview i').className = 'mdi mdi-menu';
        menuModal.show();
    }

    function openEditModal(menuId) {
        document.getElementById('menuEditModalTitle').textContent = '<?= __("编辑菜单") ?>';
        
        fetch(detailUrl + '?id=' + menuId)
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.code === 200 && result.data) {
                    var data = result.data;
                    document.getElementById('menu_id').value = data.menu_id || '';
                    document.getElementById('menu_name').value = data.name || '';
                    document.getElementById('menu_title').value = data.title || '';
                    document.getElementById('menu_source').value = data.source || '';
                    document.getElementById('menu_parent_source').value = data.parent_source || '';
                    document.getElementById('menu_action').value = data.action || '';
                    document.getElementById('menu_module').value = data.module || '';
                    document.getElementById('menu_icon').value = data.icon || '';
                    document.getElementById('menu_order').value = data.order || 0;
                    document.getElementById('menu_is_enable').value = data.is_enable || 1;
                    
                    var icon = data.icon || 'mdi mdi-menu';
                    document.querySelector('#menu_icon_preview i').className = icon;
                    
                    menuModal.show();
                } else {
                    BackendToast.error(result.msg || '<?= __("获取菜单信息失败") ?>');
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __("请求失败") ?>: ' + error.message);
            });
    }

    function saveMenu() {
        var form = document.getElementById('menuEditForm');
        var formData = new FormData(form);
        var data = {};
        
        formData.forEach(function(value, key) {
            data[key] = value;
        });

        if (!data.name || !data.title || !data.source || !data.module) {
            BackendToast.warning('<?= __("请填写必填项") ?>');
            return;
        }

        fetch(saveUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        })
        .then(function(response) { return response.json(); })
        .then(function(result) {
            if (result.success || result.code === 200) {
                BackendToast.success('<?= __("保存成功") ?>');
                menuModal.hide();
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                BackendToast.error(result.message || result.msg || '<?= __("保存失败") ?>');
            }
        })
        .catch(function(error) {
            BackendToast.error('<?= __("请求失败") ?>: ' + error.message);
        });
    }

    function deleteMenu(menuId, menuName) {
        BackendConfirm.show('<?= __("确定要删除菜单") ?> "' + menuName + '" <?= __("吗？") ?>', {
            title: '<?= __("确认删除") ?>',
            type: 'danger',
            confirmText: '<?= __("删除") ?>',
            cancelText: '<?= __("取消") ?>'
        }).then(function(confirmed) {
            if (!confirmed) return;

            var formData = new FormData();
            formData.append('id', menuId);

            fetch(deleteUrl, {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.code === 200) {
                    BackendToast.success(result.msg || '<?= __("删除成功") ?>');
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(result.msg || '<?= __("删除失败") ?>');
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __("请求失败") ?>: ' + error.message);
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

})();
</script>
