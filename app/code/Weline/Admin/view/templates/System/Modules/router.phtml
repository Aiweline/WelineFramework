        echo '<div style="margin-top: 16px;">' . $pagination['html'] . '</div>';
    }
    ?>
</div>

<script>
(function() {
    'use strict';
    
    var searchTimeout = null;
    
    window.toggleModule = function(header) {
        var body = header.nextElementSibling;
        header.classList.toggle('collapsed');
        body.classList.toggle('collapsed');
    };

    document.querySelectorAll('[data-router-module-toggle]').forEach(function(header) {
        header.addEventListener('click', function() {
            window.toggleModule(header);
        });
    });
    
    document.getElementById('expand-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-router-module-header').forEach(function(header) {
            header.classList.remove('collapsed');
            header.nextElementSibling.classList.remove('collapsed');
        });
    });
    
    document.getElementById('collapse-all').addEventListener('click', function() {
        document.querySelectorAll('.weline-router-module-header').forEach(function(header) {
            header.classList.add('collapsed');
            header.nextElementSibling.classList.add('collapsed');
        });
    });
    
    document.getElementById('router-search').addEventListener('keyup', function() {
        var searchVal = this.value.trim().toLowerCase();
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() {
            filterRoutes();
        }, 300);
    });
    
    document.getElementById('router-search-clear').addEventListener('click', function() {
        document.getElementById('router-search').value = '';
        filterRoutes();
    });
    
    document.getElementById('router-filter-module').addEventListener('change', filterRoutes);
    document.getElementById('router-filter-method').addEventListener('change', filterRoutes);
    
    function filterRoutes() {
        var searchVal = document.getElementById('router-search').value.trim().toLowerCase();
        var moduleFilter = document.getElementById('router-filter-module').value;
        var methodFilter = document.getElementById('router-filter-method').value.toUpperCase();
        
        var visibleModules = 0;
        var visibleRoutes = 0;
        
        document.querySelectorAll('.weline-router-module-card').forEach(function(card) {
            var cardModule = card.getAttribute('data-module');
            
            if (moduleFilter && cardModule !== moduleFilter) {
                card.style.display = 'none';
                return;
            }
            
            var rows = card.querySelectorAll('tbody tr');
            var moduleVisible = false;
            var moduleRouteCount = 0;
            
            rows.forEach(function(row) {
                var path = row.getAttribute('data-path') || '';
                var method = row.getAttribute('data-method') || '';
                var rowText = row.textContent.toLowerCase();
                
                var searchMatch = !searchVal || path.includes(searchVal) || rowText.includes(searchVal);
                var methodMatch = !methodFilter || method === methodFilter;
                
                if (searchMatch && methodMatch) {
                    row.style.display = '';
                    moduleVisible = true;
                    moduleRouteCount++;
                    visibleRoutes++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            if (moduleVisible) {
                card.style.display = '';
                visibleModules++;
                
                if (searchVal || methodFilter) {
                    var header = card.querySelector('.weline-router-module-header');
                    var body = card.querySelector('.weline-router-module-body');
                    header.classList.remove('collapsed');
                    body.classList.remove('collapsed');
                }
            } else {
                card.style.display = 'none';
            }
        });
        
        var resultInfo = document.getElementById('router-result-info');
        var resultText = document.getElementById('router-result-text');
        
        if (searchVal || moduleFilter || methodFilter) {
            resultText.textContent = '<?= __("找到") ?> ' + visibleRoutes + ' <?= __("条路由，来自") ?> ' + visibleModules + ' <?= __("个模块") ?>';
            resultInfo.classList.add('visible');
        } else {
            resultInfo.classList.remove('visible');
        }
    }
    
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && (e.key === 'f' || e.key === 'F')) {
            e.preventDefault();
            document.getElementById('router-search').focus();
        }
    });
})();
</script>
