<?php
/**
 * 路由管理页面
 *
 * @var \Weline\Framework\View\Template $this
 */

$routers = $this->getData('routers') ?: [];

$totalRoutes = 0;
$moduleCount = count($routers);
$getRoutes = 0;
$postRoutes = 0;

foreach ($routers as $module => $routes) {
    foreach ($routes as $path => $info) {
        $totalRoutes++;
        if (str_contains($path, '::GET') || !str_contains($path, '::')) {
            $getRoutes++;
        }
        if (str_contains($path, '::POST')) {
            $postRoutes++;
        }
    }
}
