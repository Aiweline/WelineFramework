                            collapseContent(e);
                            return;
                        }
                        // 检查鼠标是否还在相关区域内
                        if (!($stickySection.length && $stickySection[0].contains(currentTarget)) &&
                            !($tabsContent.length && $tabsContent[0].contains(currentTarget)) &&
                            !$(currentTarget).closest('.menu-search-item, .menu-search-submenu, .menu-search-content').length) {
                            isHovering = false;
                            // 停止搜索保护机制
                            if (typeof stopSearchMenuProtection === 'function') {
                                stopSearchMenuProtection();
                            }
                            collapseContent(e);
                        }
                    }, 300);
                });
                
                // 收起内容的统一函数
                function collapseContent(mouseEvent) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    
                    // 如果提供了鼠标事件，检查鼠标是否在相关区域内
                    if (mouseEvent && mouseEvent.clientX !== undefined && mouseEvent.clientY !== undefined) {
                        var mouseTarget = document.elementFromPoint(mouseEvent.clientX, mouseEvent.clientY);
                        if (mouseTarget) {
                            var $mouseTarget = $(mouseTarget);
                            var isInSearchArea = $mouseTarget.closest('.menu-search-item, .menu-search-submenu, .menu-search-content, .menu-tabs-content.expanded-right, #sticky-menu-section').length > 0;
                            if (isInSearchArea) {
                                return; // 鼠标还在相关区域内，不执行收起
                            }
                        }
                    }
                    
                    // 停止搜索保护机制
                    if (typeof stopSearchMenuProtection === 'function') {
                        stopSearchMenuProtection();
                    }
                    
                    // 折叠状态下，menu-search-submenu由CSS的hover控制显示/隐藏，不需要JS控制
                    // menu-search-content不需要任何隐藏控制
                    
                    // 收起搜索框（如果展开）
                    var $searchInput = MenuController.getSearchInput();
                    var $searchTabContainer = $('#search-tab-container');
                    if ($searchTabContainer && $searchTabContainer.length && $searchTabContainer.hasClass('expanded')) {
                        // 如果输入框为空，则收起
                        if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
