                            searchHoverTimer = setTimeout(function() {
                                var $searchInput = $('#menu-search-input');
                                var $searchTabContainer = $('#search-tab-container');
                                // 如果输入框为空，则收起搜索框
                                if ($searchInput && $searchInput.length && $searchInput.val().trim() === '' && 
                                    $searchTabContainer && $searchTabContainer.hasClass('expanded')) {
                                    $searchTabContainer.removeClass('expanded');
                                    $searchInput.blur();
                                }
                            }, 200);
                        }
                    }
                }
                
                $searchTab.on('mouseleave.menuTabsHover', handleSearchMouseLeave);
                // 为搜索容器也添加mouseleave事件
                if ($searchTabContainer && $searchTabContainer.length) {
                    $searchTabContainer.on('mouseleave.menuTabsHover', handleSearchMouseLeave)
