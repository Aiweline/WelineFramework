                    }, 300);
                });
                
                // 鼠标离开搜索菜单区域（折叠状态下）
                $(document).on('mouseleave.menuSticky', '.menu-search-item, .menu-search-submenu, .menu-search-content', function(e) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    if (!isCollapsed) return; // 仅折叠状态下有效
                    
                    var relatedTarget = e.relatedTarget || e.toElement;
                    var $stickySection = $('#sticky-menu-section');
                    var $tabsContent = $('.menu-tabs-content.expanded-right');
                    
                    // 检查鼠标是否移到了sticky区域或弹出层
                    if (($stickySection.length && $stickySection[0].contains(relatedTarget)) ||
                        ($tabsContent.length && $tabsContent[0].contains(relatedTarget)) ||
                        $(relatedTarget).closest('.menu-search-item, .menu-search-submenu, .menu-search-content').length) {
                        return; // 如果移到了相关区域，保持展开
                    }
                    
                    // 延迟收起
                    hoverTimer = setTimeout(function() {
                        var currentTarget = document.elementFromPoint(e.clientX || 0, e.clientY || 0);
                        if (!currentTarget) {
                            isHovering = false;
                            // 停止搜索保护机制
                            if (typeof stopSearchMenuProtection === 'function') {
                                stopSearchMenuProtection();
