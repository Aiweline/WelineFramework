                    // 监听菜单状态变化，如果搜索菜单被意外关闭，立即重新打开（仅在搜索输入框有内容时）
                    var searchMenuCheckInterval = null;
                    var isMouseInSearchArea = false;
                    
                    function startSearchMenuProtection() {
                        if (searchMenuCheckInterval) return;
                        searchMenuCheckInterval = setInterval(function() {
                            var searchText = $searchInputMenu.val().trim();
                            // menu-search-submenu的显示/隐藏由CSS的hover控制，不需要JS强制显示
                            // 这里只保留基本的类操作，CSS会通过hover自动显示
                            if (!searchText && searchMenuCheckInterval) {
                                // 搜索输入框为空，停止保护
                                clearInterval(searchMenuCheckInterval);
                                searchMenuCheckInterval = null;
                            }
                        }, 100);
                    }
                    
                    function stopSearchMenuProtection() {
                        if (searchMenuCheckInterval) {
                            clearInterval(searchMenuCheckInterval);
                            searchMenuCheckInterval = null;
                        }
                    }
                    
                    // 监听鼠标进入搜索区域（仅用于保护机制，显示/隐藏由CSS hover控制）
                    $(document).on('mouseenter.menuSearchArea', '.menu-search-item, .menu-search-submenu, .menu-search-content', function() {
                        isMouseInSearchArea = true;
                        // menu-search-submenu的显示/隐藏由CSS的hover控制，不需要JS设置
                        // menu-search-content不需要任何隐藏控制
                    });
                    
                    // 监听鼠标离开搜索区域
                    $(document).on('mouseleave.menuSearchArea', '.menu-search-item, .menu-search-submenu, .menu-search-content', function() {
                        isMouseInSearchArea = false;
                    });
                    
                    // 当输入框有内容时启动保护
                    $searchInputMenu.on('input', function() {
                        var searchText = $(this).val().trim();
                        if (searchText) {
                            startSearchMenuProtection();
                        } else {
                            stopSearchMenuProtection();
                        }
                    });
                    
                    // 当输入框失去焦点且无内容时停止保护
                    $searchInputMenu.on('blur', function() {
                        var searchText = $(this).val().trim();
                        if (!searchText) {
                            stopSearchMenuProtection();
                        }
                    });
                }
                
                // 全局键盘快捷键：Ctrl+K 或 / 打开搜索
                $(document).on('keydown.menuSearch', function(e) {
                    // 如果当前焦点在输入框、文本域或内容可编辑元素上，不触发快捷键
                    var $target = $(e.target);
                    if ($target.is('input:not([type="text"]), textarea, [contenteditable="true"]')) {
                        return;
                    }
                    
                    // Ctrl+K 或 / 键打开搜索
                    if ((e.ctrlKey && e.key === 'k') || (e.key === '/' && !$target.is('input, textarea'))) {
                        e.preventDefault();
                        var $body = $('body');
                        if ($body.hasClass('vertical-collpsed')) {
                            // 折叠状态下，聚焦菜单形式的搜索框
                            if ($searchInputMenu && $searchInputMenu.length) {
                                // 展开搜索菜单项
                                var $searchItem = $('#menu-search-item');
                                if ($searchItem.length) {
                                    $searchItem.find('> a').trigger('click');
                                    setTimeout(function() {
                                        $searchInputMenu.focus();
                                    }, 100);
                                }
                            }
                        } else {
                            // 正常状态下，使用sticky区域
                            if ($searchInput && $searchInput.length) {
                                MenuController.expandSearch();
                            }
                        }
                    }
                });
                
                // 点击搜索容器外部时，如果输入框为空则收起（仅针对sticky区域）
                $(document).on('click.menuSearch', function(e) {
                    if ($searchTabContainer && !$searchTabContainer.is(e.target) && $searchTabContainer.has(e.target).length === 0) {
                        if ($searchInput && $searchInput.length && $searchInput.val().trim() === '' && $searchTabContainer.hasClass('expanded')) {
                            MenuController.collapseSearch();
                        }
                    }
                });
                
                // 键盘事件处理（统一处理两个输入框）
                function handleSearchKeydown(e) {
                    var matchedItems = MenuController.getMatchedMenuItems();
                    var selectedIndex = MenuController.getCurrentSelectedIndex();
                    var $input = $(this);
                    
                    if (e.key === 'Escape') {
                        MenuController.setCurrentSelectedIndex(-1);
                        MenuController.setMatchedMenuItems([]);
                        var $body = $('body');
                        if ($body.hasClass('vertical-collpsed')) {
                            // 折叠状态下，清空输入框
                            $input.val('');
                            handleSearchInput($input, '');
                        } else {
                            // 正常状态下，收起搜索
                            MenuController.collapseSearch();
                        }
                    } else if (e.key === 'ArrowDown') {
                        // 向下箭头：选择下一个结果
                        e.preventDefault();
                        if (matchedItems.length > 0) {
                            var newIndex = (selectedIndex + 1) % matchedItems.length;
                            MenuController.setCurrentSelectedIndex(newIndex);
                            highlightSelectedItem();
                        }
                    } else if (e.key === 'ArrowUp') {
                        // 向上箭头：选择上一个结果
                        e.preventDefault();
                        if (matchedItems.length > 0) {
                            var newIndex = selectedIndex <= 0 ? matchedItems.length - 1 : selectedIndex - 1;
                            MenuController.setCurrentSelectedIndex(newIndex);
                            highlightSelectedItem();
                        }
                    } else if (e.key === 'Enter') {
                        // Enter键：打开选中的菜单项
                        if (selectedIndex >= 0 && selectedIndex < matchedItems.length) {
                            e.preventDefault();
                            var itemData = matchedItems[selectedIndex];
                            var $selectedItem = itemData.$item ? itemData.$item : itemData; // 兼容新旧数据结构
                            var $link = $selectedItem.find('a').first();
                            if ($link.length && $link.attr('href') && $link.attr('href') !== 'javascript: void(0);') {
                                window.location.href = $link.attr('href');
                            } else {
                                // 如果是可展开的菜单，展开它
                                $link.trigger('click');
                            }
                        }
                    }
                }
                
                if ($searchInput && $searchInput.length) {
                    $searchInput.on('keydown', handleSearchKeydown);
                }
                
                if ($searchInputMenu && $searchInputMenu.length) {
                    $searchInputMenu.on('keydown', handleSearchKeydown);
                }
                
                // 高亮选中的菜单项并滚动到可视区域
                function highlightSelectedItem() {
                    var $menuItems = MenuController.getMenuItems();
                    var matchedItems = MenuController.getMatchedMenuItems();
                    var selectedIndex = MenuController.getCurrentSelectedIndex();
                    
                    if (!$menuItems || !$menuItems.length) {
                        return;
                    }
                    
                    // 移除所有高亮
                    $menuItems.removeClass('menu-item-keyboard-selected');
                    
                    if (selectedIndex >= 0 && selectedIndex < matchedItems.length) {
                        var itemData = matchedItems[selectedIndex];
                        var $selected = itemData.$item ? itemData.$item : itemData; // 兼容新旧数据结构
                        $selected.addClass('menu-item-keyboard-selected');
                        
                        // 平滑滚动到选中项
                        var offsetTop = $selected.offset().top;
                        var sidebarTop = $('#sidebar-menu').offset().top;
                        var sidebarHeight = $('#sidebar-menu').height();
                        
                        if (offsetTop < sidebarTop || offsetTop > sidebarTop + sidebarHeight) {
                            $('html, body').animate({
                                scrollTop: $selected.offset().top - 200
                            }, 200);
                        }
                    }
                }
            }
            
            // 搜索菜单函数
            function searchMenus(searchText, $menuItems, $frequentMenusSection, $searchResultsContainer, $searchResultsText) {
                var matchCount = 0;
                var matchedItems = [];
                var firstMatchedItem = null;
                var $body = $('body');
                var isCollapsed = $body.hasClass('vertical-collpsed');
                
                // 在折叠状态下，先确保右侧弹出层保持显示，避免鼠标丢失焦点
                if (isCollapsed) {
                    var $tabsContent = $('.menu-tabs-content');
                    var $searchInputMenu = $('#menu-search-input-menu');
                    // 只要是在搜索（有搜索文本），就确保右侧弹出层显示
                    if ($tabsContent && $tabsContent.length && searchText && searchText.trim() !== '') {
                        // 保持右侧弹出层显示
                        var expandedTop = calculateExpandedTop();
                        $tabsContent.addClass('expanded-right').show().css({
                            'display': 'block',
                            'position': 'fixed',
                            'left': '70px',
                            'top': expandedTop,
                            'min-width': '280px',
                            'max-width': '320px',
                            'z-index': '1050',
                            'background-color': ($body.attr('data-sidebar') === 'dark') ? '#1b2c3f' : '#ffffff',
                            'opacity': '1',
                            'visibility': 'visible'
                        });
                        // 显示搜索Tab内容
                        $('#search-tab-pane').show();
                        $('#search-menu-tab').addClass('active');
                        $('#frequent-menu-tab').removeClass('active');
                        // 展开搜索输入框
                        var $searchTabContainer = $('#search-tab-container');
                        if ($searchTabContainer && $searchTabContainer.length && !$searchTabContainer.hasClass('expanded')) {
                            $searchTabContainer.addClass('expanded');
                        }
                    }
                }
                
                // 隐藏常用菜单区域
                if ($frequentMenusSection && $frequentMenusSection.length) {
                    $frequentMenusSection.hide();
                }
                
                // 确保搜索结果容器显示（仅正常状态下，折叠状态下使用菜单形式的容器）
                if (!isCollapsed && $searchResultsContainer && $searchResultsContainer.length) {
                    $searchResultsContainer.show();
                }
                
                // 移除所有高亮
                if ($menuItems && $menuItems.length) {
                    $menuItems.removeClass('menu-item-keyboard-selected');
                }
                
                // 只搜索主菜单，不搜索常用菜单和搜索菜单项
                // 在折叠状态下，不隐藏菜单项（因为菜单本身是隐藏的），只在正常状态下过滤显示
                if ($menuItems && $menuItems.length) {
                    $menuItems.each(function() {
                        var $item = $(this);
                        // 跳过搜索菜单项和常用菜单项
                        if ($item.hasClass('menu-search-item') || $item.hasClass('menu-frequent-item')) {
                            return true; // continue
                        }
                        var menuText = '';
                        var isMenuTitle = $item.hasClass('menu-title');
                        
                        // 跳过menu-title，只搜索实际菜单项
                        if (isMenuTitle) {
                            // menu-title需要检查其后面的子菜单是否有匹配
                            var $nextSiblings = $item.nextUntil('.menu-title');
                            var hasSiblingMatch = false;
                            
                            $nextSiblings.each(function() {
                                var siblingText = $(this).find('a span').text().toLowerCase();
                                if (siblingText.indexOf(searchText) !== -1) {
                                    hasSiblingMatch = true;
                                    return false; // break
                                }
                                
                                // 检查子菜单
                                $(this).find('li a span').each(function() {
                                    if ($(this).text().toLowerCase().indexOf(searchText) !== -1) {
                                        hasSiblingMatch = true;
                                        return false; // break
                                    }
                                });
                            });
                            
                            // 只在正常状态下隐藏不匹配的菜单项
                            if (!isCollapsed) {
                                if (hasSiblingMatch) {
                                    $item.removeClass('menu-item-hidden');
                                } else {
                                    $item.addClass('menu-item-hidden');
                                }
                            } else {
                                // 折叠状态下，移除隐藏类，让所有菜单项可见（用于搜索高亮）
                                $item.removeClass('menu-item-hidden');
                            }
                            return; // 继续下一个
                        }
                        
                        // 获取菜单文本
                        menuText = $item.find('a span').text().toLowerCase();
                        
                        // 检查是否匹配
                        if (menuText && menuText.indexOf(searchText) !== -1) {
                            $item.removeClass('menu-item-hidden').addClass('menu-item-matched');
                            // 延迟展开父级菜单，避免DOM重排导致鼠标焦点丢失
                            setTimeout(function() {
                                expandParentMenu($item);
                            }, 0);
                            matchCount++;
                            // 检查是否有子菜单
                            var $subMenu = $item.find('> ul.sub-menu');
                            var hasChildren = $subMenu.length > 0;
                            // 存储菜单项信息，包括是否有子菜单
                            matchedItems.push({
                                $item: $item,
                                hasChildren: hasChildren,
                                sourceId: $item.attr('data-source') || ''
                            });
                            if (!firstMatchedItem) {
                                firstMatchedItem = $item;
                            }
                        } else {
                            // 检查子菜单 - 注意：现在使用 sub-menu 类名
                            var $children = $item.find('> ul.sub-menu > li');
                            var hasChildMatch = false;
                            
                            $children.each(function() {
                                var $child = $(this);
                                var childText = $child.find('a span').text().toLowerCase();
                                
                                if (childText && childText.indexOf(searchText) !== -1) {
                                    hasChildMatch = true;
                                    matchCount++;
                                    $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                                    // 延迟展开父级菜单
                                    setTimeout(function() {
                                        expandParentMenu($child);
                                    }, 0);
                                    // 检查子菜单项是否有子菜单
                                    var $childSubMenu = $child.find('> ul.sub-menu');
                                    var childHasChildren = $childSubMenu.length > 0;
                                    matchedItems.push({
                                        $item: $child,
                                        hasChildren: childHasChildren,
                                        sourceId: $child.attr('data-source') || ''
                                    });
                                    if (!firstMatchedItem) {
                                        firstMatchedItem = $child;
                                    }
                                    // 展开子菜单的父级
                                    $item.removeClass('menu-item-hidden');
                                    var $subMenu = $item.find('> ul.sub-menu');
                                    if ($subMenu.length) {
                                        $subMenu.attr('aria-expanded', 'true').addClass('mm-show');
                                        $item.find('> a').parent('li').addClass('mm-active');
                                    }
                                } else {
                                    $child.removeClass('menu-item-matched');
                                    // 递归检查更深层的子菜单
                                    $child.find('li a span').each(function() {
                                        if ($(this).text().toLowerCase().indexOf(searchText) !== -1) {
                                            hasChildMatch = true;
                                            matchCount++;
                                            $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                                            // 延迟展开父级菜单
                                            setTimeout(function() {
                                                expandParentMenu($child);
                                            }, 0);
                                            // 检查子菜单项是否有子菜单
                                            var $childSubMenu = $child.find('> ul.sub-menu');
                                            var childHasChildren = $childSubMenu.length > 0;
                                            matchedItems.push({
                                                $item: $child,
                                                hasChildren: childHasChildren,
                                                sourceId: $child.attr('data-source') || ''
                                            });
                                            if (!firstMatchedItem) {
                                                firstMatchedItem = $child;
                                            }
                                            var $parentSubMenu = $item.find('> ul.sub-menu');
                                            if ($parentSubMenu.length) {
                                                $parentSubMenu.attr('aria-expanded', 'true').addClass('mm-show');
                                                $item.find('> a').parent('li').addClass('mm-active');
                                            }
                                            return false; // break
                                        }
                                    });
                                }
                            });
                            
                            // 只在正常状态下隐藏不匹配的菜单项
                            if (!isCollapsed) {
                                if (hasChildMatch) {
                                    $item.removeClass('menu-item-hidden');
                                } else {
                                    $item.removeClass('menu-item-matched').addClass('menu-item-hidden');
                                }
                            } else {
                                // 折叠状态下，移除隐藏类和高亮类，让菜单项保持原样
                                $item.removeClass('menu-item-hidden menu-item-matched');
                            }
                        }
                    });
                }
                
                // 搜索完成后，补充有子菜单的匹配项的子菜单项
                // 创建一个新的数组来存储补充后的结果
                var finalMatchedItems = matchedItems.slice(); // 复制原数组
                var addedChildrenCount = 0;
                
                // 遍历所有匹配的菜单项
                matchedItems.forEach(function(itemData) {
                    var $item = itemData.$item ? itemData.$item : itemData;
                    var hasChildren = itemData.hasChildren || false;
                    
                    // 如果这个菜单项有子菜单，补充其子菜单项
                    if (hasChildren) {
                        // 展开子菜单
                        var $subMenu = $item.find('> ul.sub-menu');
                        if ($subMenu.length === 0) {
                            $subMenu = $item.find('ul.sub-menu').first();
                        }
                        
                        if ($subMenu.length > 0) {
                            $subMenu.attr('aria-expanded', 'true').addClass('mm-show').css({
                                'display': 'block',
                                'visibility': 'visible'
                            });
                            $item.find('> a').parent('li').addClass('mm-active');
                            
                            // 递归函数：添加所有子菜单项
                            function addChildrenToResults($parentItem) {
                                var $parentSubMenu = $parentItem.find('> ul.sub-menu');
                                if ($parentSubMenu.length === 0) {
                                    $parentSubMenu = $parentItem.find('ul.sub-menu').first();
                                }
                                
                                if ($parentSubMenu.length > 0) {
                                    var $children = $parentSubMenu.find('> li');
                                    
                                    $children.each(function() {
                                        var $child = $(this);
                                        
                                        // 跳过menu-title类型的项
                                        if ($child.hasClass('menu-title')) {
                                            return true; // continue
                                        }
                                        
                                        // 检查是否已经添加过，避免重复
                                        var isAlreadyAdded = false;
                                        for (var i = 0; i < finalMatchedItems.length; i++) {
                                            var existingItem = finalMatchedItems[i];
                                            var existing$item = existingItem.$item ? existingItem.$item : existingItem;
                                            if (existing$item[0] === $child[0]) {
                                                isAlreadyAdded = true;
                                                break;
                                            }
                                        }
                                        
                                        if (!isAlreadyAdded) {
                                            matchCount++;
                                            addedChildrenCount++;
                                            $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                                            
                                            // 检查子菜单项是否还有子菜单
                                            var $childSubMenu = $child.find('> ul.sub-menu');
                                            var childHasChildren = $childSubMenu.length > 0;
                                            
                                            finalMatchedItems.push({
                                                $item: $child,
                                                hasChildren: childHasChildren,
                                                sourceId: $child.attr('data-source') || ''
                                            });
                                            
                                            // 如果子菜单项还有子菜单，递归添加
                                            if (childHasChildren) {
                                                $childSubMenu.attr('aria-expanded', 'true').addClass('mm-show').css({
                                                    'display': 'block',
                                                    'visibility': 'visible'
                                                });
                                                $child.find('> a').parent('li').addClass('mm-active');
                                                addChildrenToResults($child);
                                            }
                                        }
                                    });
                                }
                            }
                            
                            // 添加子菜单项
                            addChildrenToResults($item);
                        }
                    }
                });
                
                // 使用补充后的数组
                matchedItems = finalMatchedItems;
                
                // 更新匹配的菜单项列表（供键盘导航使用）
                MenuController.setMatchedMenuItems(matchedItems);
                
                // 填充搜索结果到容器中的函数
                function fillSearchResults($resultsContainer, $resultsList, matchCount, matchedItems, isMenuForm) {
                    if (!$resultsContainer || !$resultsContainer.length) {
                        return;
                    }
                    
                    // 确保menu-search-content和搜索输入框区域始终可见（仅菜单形式）
                    if (isMenuForm) {
                        var $searchContent = $('#menu-search-content');
                        var $searchInputWrapper = $('.search-menu-input-wrapper');
                        if ($searchContent && $searchContent.length) {
                            $searchContent.show().css({
                                'display': 'block',
                                'visibility': 'visible',
                                'opacity': '1',
                                'height': 'auto',
                                'min-height': 'auto'
                            });
                        }
                        if ($searchInputWrapper && $searchInputWrapper.length) {
                            $searchInputWrapper.show().css({
                                'display': 'block',
                                'visibility': 'visible',
                                'opacity': '1'
                            });
                        }
                    }
                    
                    // 清空之前的搜索结果
                    if ($resultsList && $resultsList.length) {
                        $resultsList.empty();
                    } else {
                        // 如果没有结果列表容器，创建一个
                        var listClass = isMenuForm ? 'search-results-list-menu' : 'search-results-list';
                        $resultsList = $('<div class="' + listClass + '"></div>');
                        $resultsContainer.append($resultsList);
                    }
                    
                    if (matchCount > 0) {
                        // 首先构建一个包含层级信息的数组
                        var itemsWithLevel = [];
                        matchedItems.forEach(function(itemData) {
                            // 兼容旧的数据结构（直接是jQuery对象）
                            var $item, hasChildren = false, sourceId = '';
                            if (itemData.$item) {
                                $item = itemData.$item;
                                hasChildren = itemData.hasChildren || false;
                                sourceId = itemData.sourceId || '';
                            } else {
                                $item = itemData;
                                hasChildren = $item.find('> ul.sub-menu').length > 0;
                                sourceId = $item.attr('data-source') || '';
                            }
                            
                            // 计算菜单项的层级深度
                            var level = 0;
                            var $parent = $item.parent('ul.sub-menu');
                            while ($parent.length > 0) {
                                level++;
                                $parent = $parent.parent('li').parent('ul.sub-menu');
                            }
                            
                            itemsWithLevel.push({
                                $item: $item,
                                hasChildren: hasChildren,
                                sourceId: sourceId,
                                level: level
                            });
                        });
                        
                        // 按层级和父子关系排序，确保父菜单项在子菜单项之前
                        itemsWithLevel.sort(function(a, b) {
                            var $aItem = a.$item;
                            var $bItem = b.$item;
                            
                            // 检查是否有父子关系
                            // 如果a是b的父菜单（b的父ul是a的子菜单）
                            var $bParent = $bItem.parent('ul.sub-menu');
                            if ($bParent.length > 0) {
                                var $bParentLi = $bParent.parent('li');
                                if ($bParentLi.length > 0 && $bParentLi[0] === $aItem[0]) {
                                    return -1; // a在b前面
                                }
                            }
                            
                            // 如果b是a的父菜单（a的父ul是b的子菜单）
                            var $aParent = $aItem.parent('ul.sub-menu');
                            if ($aParent.length > 0) {
                                var $aParentLi = $aParent.parent('li');
                                if ($aParentLi.length > 0 && $aParentLi[0] === $bItem[0]) {
                                    return 1; // b在a前面
                                }
                            }
                            
                            // 如果没有直接父子关系，按层级排序
                            if (a.level !== b.level) {
                                return a.level - b.level;
                            }
                            
                            // 如果层级相同，按DOM中的位置排序
                            var aIndex = matchedItems.findIndex(function(item) {
                                var item$item = item.$item ? item.$item : item;
                                return item$item[0] === a.$item[0];
                            });
                            var bIndex = matchedItems.findIndex(function(item) {
                                var item$item = item.$item ? item.$item : item;
                                return item$item[0] === b.$item[0];
                            });
                            return aIndex - bIndex;
                        });
                        
                        // 填充搜索结果
                        itemsWithLevel.forEach(function(itemData) {
                            var $item = itemData.$item;
                            var hasChildren = itemData.hasChildren;
                            var sourceId = itemData.sourceId;
                            var level = itemData.level;
                            
                            // 尝试多种方式获取链接和文本
                            var $link = $item.find('> a').first();
                            if (!$link.length) {
                                $link = $item.find('a').first();
                            }
                            
                            if ($link.length) {
                                var menuText = $link.find('span').text();
                                if (!menuText) {
                                    menuText = $link.text().trim();
                                }
                                var menuIcon = $link.find('i').first().attr('class') || 'mdi mdi-circle';
                                var menuHref = $link.attr('href') || '#';
                                
                                // 根据层级添加缩进
                                var indentStyle = '';
                                if (level > 0) {
                                    indentStyle = 'padding-left: ' + (20 + level * 20) + 'px;';
                                }
                                
                                var $resultItem = $('<div class="search-result-item px-3 py-2" data-source="' + sourceId + '" style="' + indentStyle + '"></div>');
                                var $resultLink = $('<a href="' + menuHref + '" class="d-flex align-items-center waves-effect search-result-link"></a>');
                                $resultLink.append('<i class="' + menuIcon + ' me-2"></i>');
                                $resultLink.append('<span>' + menuText + '</span>');
                                
                                $resultItem.append($resultLink);
                                $resultsList.append($resultItem);
                                
                                // 阻止搜索结果链接点击导致弹出层隐藏（仅在折叠状态下）
                                var $body = $('body');
                                if ($body.hasClass('vertical-collpsed') && isMenuForm) {
                                    $resultLink.on('click', function(e) {
                                        // 阻止事件冒泡，防止触发collapseContent
                                        e.stopPropagation();
                                        // 确保右侧弹出层保持显示
                                        var $tabsContent = $('.menu-tabs-content');
                                        if ($tabsContent && $tabsContent.length) {
                                            $tabsContent.addClass('expanded-right').show().css({
                                                'opacity': '1',
                                                'visibility': 'visible'
                                            });
                                        }
                                    });
                                }
                            } else {
                                // 如果找不到链接，尝试直接获取文本（可能是menu-title类型）
                                var menuText = $item.find('span').text();
                                if (!menuText) {
                                    menuText = $item.text().trim();
                                }
                                if (menuText) {
                                    var menuIcon = $item.find('i').first().attr('class') || 'mdi mdi-circle';
                                    var indentStyle = '';
                                    if (level > 0) {
                                        indentStyle = 'padding-left: ' + (20 + level * 20) + 'px;';
                                    }
                                    
                                    var $resultItem = $('<div class="search-result-item px-3 py-2" data-source="' + sourceId + '" style="' + indentStyle + '"></div>');
                                    var $resultText = $('<div class="d-flex align-items-center">');
                                    $resultText.append('<i class="' + menuIcon + ' me-2"></i>');
                                    $resultText.append('<span>' + menuText + '</span>');
                                    
                                    $resultItem.append($resultText);
                                    $resultsList.append($resultItem);
                                }
                            }
                        });
                    }
                }
                
                // 更新搜索结果文本和填充结果列表
                var $searchResultsText = $('#search-results-text');
                var $searchResultsList = $('#search-results-list');
                var $searchResultsTextMenu = $('#search-results-text-menu');
                var $searchResultsListMenu = $('#search-results-list-menu');
                
                if (matchCount > 0) {
                    // 更新文本
                    if ($searchResultsText && $searchResultsText.length && !isCollapsed) {
                        $searchResultsText.text('搜索结果 (' + matchCount + ')');
                    }
                    if ($searchResultsTextMenu && $searchResultsTextMenu.length) {
                        $searchResultsTextMenu.text('搜索结果 (' + matchCount + ')');
                    }
                    
                    // 根据折叠状态填充不同的容器
                    if (isCollapsed) {
                        // 折叠状态下，先确保右侧弹出层显示搜索内容
                        var $tabsContent = $('.menu-tabs-content');
                        if ($tabsContent && $tabsContent.length && searchText && searchText.trim() !== '') {
                            var expandedTop = calculateExpandedTop();
                            $tabsContent.addClass('expanded-right').show().css({
                                'display': 'block',
                                'position': 'fixed',
                                'left': '70px',
                                'top': expandedTop,
                                'min-width': '280px',
                                'max-width': '320px',
                                'z-index': '1050',
                                'background-color': ($body.attr('data-sidebar') === 'dark') ? '#1b2c3f' : '#ffffff',
                                'opacity': '1',
                                'visibility': 'visible'
                            });
                            // 显示搜索Tab内容
                            $('#search-tab-pane').show();
                            $('#search-menu-tab').addClass('active');
                            $('#frequent-menu-tab').removeClass('active');
                            // 展开搜索输入框
                            var $searchTabContainer = $('#search-tab-container');
                            if ($searchTabContainer && $searchTabContainer.length && !$searchTabContainer.hasClass('expanded')) {
                                $searchTabContainer.addClass('expanded');
                            }
                            // 填充sticky区域的搜索结果容器（显示在右侧弹出层中）
                            if ($searchResultsContainer && $searchResultsContainer.length) {
                                $searchResultsContainer.show();
                                fillSearchResults($searchResultsContainer, $searchResultsList, matchCount, matchedItems, false);
                            }
                        }
                        // 同时填充菜单形式的容器（显示在菜单项的子菜单中）
                        var $searchResultsContainerMenu = $('#search-results-container-menu');
                        if ($searchResultsContainerMenu && $searchResultsContainerMenu.length) {
                            fillSearchResults($searchResultsContainerMenu, $searchResultsListMenu, matchCount, matchedItems, true);
                        }
                    } else {
                        // 正常状态下，填充sticky区域的容器
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            fillSearchResults($searchResultsContainer, $searchResultsList, matchCount, matchedItems, false);
                        }
                    }
                    
                    // 平滑滚动到第一个匹配项（仅在正常状态下）
                    if (firstMatchedItem && firstMatchedItem.length && !$('body').hasClass('vertical-collpsed')) {
                        setTimeout(function() {
                            var $sidebar = $('.vertical-menu [data-simplebar]');
                            if ($sidebar.length && $sidebar[0].simpleBar) {
                                // 使用simplebar的滚动方法
                                var scrollTop = firstMatchedItem.offset().top - $sidebar.offset().top + $sidebar[0].simpleBar.getScrollElement().scrollTop - 150;
                                $sidebar[0].simpleBar.getScrollElement().scrollTo({
                                    top: scrollTop,
                                    behavior: 'smooth'
                                });
                            } else {
                                // 降级方案：使用jQuery动画
                                var scrollTop = firstMatchedItem.offset().top - $('#sidebar-menu').offset().top + $('#sidebar-menu').scrollTop() - 100;
                                $('.vertical-menu').animate({
                                    scrollTop: scrollTop
                                }, 300);
                            }
                        }, 150);
                    }
                } else {
                    // 无结果
                    if ($searchResultsText && $searchResultsText.length) {
                        $searchResultsText.text('未找到匹配的菜单');
                    }
                    if ($searchResultsTextMenu && $searchResultsTextMenu.length) {
                        $searchResultsTextMenu.text('未找到匹配的菜单');
                    }
                    if ($searchResultsList && $searchResultsList.length) {
                        $searchResultsList.empty();
                    }
                    if ($searchResultsListMenu && $searchResultsListMenu.length) {
                        $searchResultsListMenu.empty();
                    }
                }
            }
            
            // 展开父级菜单 - 注意：现在使用 sub-menu 类名
            function expandParentMenu($item) {
                var $parent = $item.parent('ul');
                if ($parent.length > 0 && $parent.hasClass('sub-menu')) {
                    $parent.attr('aria-expanded', 'true').addClass('mm-show');
                    var $parentLi = $parent.prev('a').parent('li');
                    $parentLi.addClass('mm-active');
                    expandParentMenu($parentLi);
                    
                    // 确保右侧弹出层保持显示（折叠状态下，搜索时有内容时）
                    var $body = $('body');
                    if ($body.hasClass('vertical-collpsed')) {
                        var $searchInputMenu = $('#menu-search-input-menu');
                        if ($searchInputMenu && $searchInputMenu.length && $searchInputMenu.val().trim() !== '') {
                            var $tabsContent = $('.menu-tabs-content');
                            if ($tabsContent && $tabsContent.length) {
                                $tabsContent.addClass('expanded-right').show().css({
                                    'opacity': '1',
                                    'visibility': 'visible',
                                    'display': 'block'
                                });
                            }
                        }
                    }
                }
            }
            
            // 初始化侧边栏折叠适配
            function initSidebarCollapse() {
                var $body = $('body');
                var $stickySection = $('#sticky-menu-section');
                
                // 监听折叠按钮点击（通过监听body类变化）
                var observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                            handleSidebarCollapse();
                        }
                    });
                });
                
                // 观察body元素的class变化
                if ($body.length) {
                    observer.observe($body[0], {
                        attributes: true,
                        attributeFilter: ['class']
                    });
                }
                
                // 初始检查
                handleSidebarCollapse();
                
                // 处理折叠状态
                function handleSidebarCollapse() {
                    if ($body.hasClass('vertical-collpsed')) {
                        // 折叠状态：收起搜索框和常用菜单，只显示图标
                        var $searchTabContainer = $('#search-tab-container');
                        if ($searchTabContainer && $searchTabContainer.length) {
                            $searchTabContainer.removeClass('expanded');
                        }
                        var $searchInput = MenuController.getSearchInput();
                        if ($searchInput && $searchInput.length) {
                            $searchInput.val('').blur();
                        }
                        MenuController.resetMenuDisplay();
                        var $searchResultsContainer = MenuController.getSearchResultsContainer();
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            $searchResultsContainer.hide();
                        }
                        var $tabsContent = $('.menu-tabs-content');
                        if ($tabsContent && $tabsContent.length) {
                            $tabsContent.hide();
                        }
                    } else {
                        // 展开状态：恢复正常的搜索功能
                        var $tabsContent = $('.menu-tabs-content');
                        if ($tabsContent && $tabsContent.length) {
                            $tabsContent.show();
                        }
                    }
                }
                
                // 监听折叠按钮的直接点击（作为备用）
                $(document).on('click', '#vertical-menu-btn', function() {
                    setTimeout(function() {
                        handleSidebarCollapse();
                    }, 100);
                });
            }
            
            // 公共工具函数 - 计算展开区域的top位置
            function calculateExpandedTop($targetElement) {
                var $stickySection = $targetElement || $('#sticky-menu-section');
                if ($stickySection && $stickySection.length) {
                    var offset = $stickySection.offset();
                    var scrollTop = $(window).scrollTop();
                    return (offset ? offset.top - scrollTop : 0) + 'px';
                }
                return '0px';
            }
            
            // 公共工具函数 - 设置内容区域CSS样式
            function setTabsContentStyle($tabsContent, expandedTop) {
                var $body = $('body');
                $tabsContent.addClass('expanded-right').show().css({
                    'display': 'block',
                    'position': 'fixed',
                    'left': '70px',
                    'top': expandedTop || calculateExpandedTop(),
                    'min-width': '280px',
                    'max-width': '320px',
                    'z-index': '1050',
                    'background-color': ($body.attr('data-sidebar') === 'dark') ? '#1b2c3f' : '#ffffff',
                    'opacity': '1',
                    'visibility': 'visible'
                });
            }
            
            // 公共工具函数 - 切换Tab状态
            function switchTab(tabType, $searchTab, $frequentTab, $frequentPane, $searchTabContainer) {
                if (tabType === 'search') {
                    $frequentPane.hide();
                    $searchTab.addClass('active');
                    $frequentTab.removeClass('active');
                    if (!$searchTabContainer.hasClass('expanded')) {
                        $searchTabContainer.addClass('expanded');
                    }
                } else if (tabType === 'frequent') {
                    $frequentPane.show();
                    $frequentTab.addClass('active');
                    $searchTab.removeClass('active');
                    if ($searchTabContainer.hasClass('expanded')) {
                        $searchTabContainer.removeClass('expanded');
                    }
                }
            }
            
            // 初始化
            $(document).ready(function() {
                initMenuTabs();
                initMenuSearch();
                initStickyMenu();
                initSidebarCollapse();
            });
            
            // Tab切换功能
            function initMenuTabs() {
                var $frequentTab = $('#frequent-menu-tab');
                var $searchTab = $('#search-menu-tab');
                var $frequentPane = $('#frequent-tab-pane');
                var $body = $('body');
                
                // 默认显示搜索Tab（已通过HTML设置active类）
                // 默认展开搜索框（仅在非折叠状态下）
                setTimeout(function() {
                    if (!$body.hasClass('vertical-collpsed')) {
                        MenuController.expandSearch();
                    }
                }, 300);
                
                var $searchTabContainer = $('#search-tab-container');
                var $searchInput = $('#menu-search-input');
                
                // 搜索Tab展开处理函数（公共函数，供点击和hover使用）
                function handleSearchTabExpand() {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    
                    // 切换Tab
                    $searchTab.addClass('active');
                    $frequentTab.removeClass('active');
                    
                    // 展开搜索Tab（折叠状态下会向右展开）
                    MenuController.expandSearch();
                    
                    // 隐藏常用菜单
                    if ($frequentPane && $frequentPane.length) {
                        $frequentPane.hide();
                    }
                    
                    // 折叠状态下，确保内容区域向右展开
                    if (isCollapsed) {
                        var $tabsContent = $('.menu-tabs-content');
                        if ($tabsContent && $tabsContent.length) {
                            setTabsContentStyle($tabsContent);
                        }
                    } else {
                        // 正常状态下，展开搜索输入框
                        if ($searchTabContainer && $searchTabContainer.length && !$searchTabContainer.hasClass('expanded')) {
                            $searchTabContainer.addClass('expanded');
                            setTimeout(function() {
                                if ($searchInput && $searchInput.length) {
                                    $searchInput.focus();
                                }
                            }, 100);
                        }
                    }
                }
                
                // 搜索Tab hover事件
                $searchTab.on('mouseenter.menuTabsHover', function(e) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    if (isCollapsed) {
                        // 折叠状态下，hover触发和点击相同的逻辑
                        handleSearchTabExpand();
                    } else {
                        // 正常状态下，只选中搜索tab，不展开输入框
                        // 只有当鼠标真的在搜索tab按钮上时才选中，不是整个容器
                        var target = e.target || e.currentTarget;
                        // 确保鼠标是在搜索tab按钮上，而不是在输入框或其他元素上
                        if ($(target).is('#search-menu-tab') || $(target).closest('#search-menu-tab').length) {
                            // 检查鼠标是否从sticky-section外部进入
                            var relatedTarget = e.relatedTarget || e.fromElement;
                            var $relatedTarget = relatedTarget ? $(relatedTarget) : null;
                            // 如果鼠标是从sticky-section外部进入的，并且常用tab已经被选中，不改变选中状态
                            if ($relatedTarget && $relatedTarget.length && 
                                !$relatedTarget.closest('#sticky-menu-section').length &&
                                $frequentTab.hasClass('active')) {
                                // 从外部进入，且常用tab已选中，保持状态不变
                                return;
                            }
                            $searchTab.addClass('active');
                            $frequentTab.removeClass('active');
                        }
                    }
                });
                
                // 搜索Tab点击
                $searchTab.on('click.menuTabs', function(e) {
                    e.stopPropagation();
                    // 直接调用公共函数
                    handleSearchTabExpand();
                });
                
                // 搜索Tab和搜索容器mouseleave事件 - 正常状态下收起搜索框（如果为空）
                var searchHoverTimer = null;
                function handleSearchMouseLeave(e) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
