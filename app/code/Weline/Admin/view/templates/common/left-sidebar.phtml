                searchResultsText: $('#search-results-text'),
                searchResultsMenu: $('#search-results-container-menu'),
                searchResultsListMenu: $('#search-results-list-menu'),
                searchResultsTextMenu: $('#search-results-text-menu'),
                frequentSection: $('#frequent-menus-section'),
                simplebar: $('.vertical-menu [data-simplebar]'),
                menuItems: $('#sidebar-menu li'),
                searchMenuItem: $('#menu-search-item'),
                searchSubmenu: $('#menu-search-submenu')
            };
        }

        // ==================== Utility ====================
        function isCollapsed() { return $el.body.hasClass(COLLAPSED_CLS); }
        function isDarkSidebar() { return $el.body.attr('data-sidebar') === 'dark'; }
        function panelBg() { return isDarkSidebar() ? '#1b2c3f' : '#ffffff'; }

        function calculateTop($target) {
            var $s = $target || $el.stickySection;
            if ($s.length) {
                var offset = $s.offset();
                return offset ? (offset.top - $(window).scrollTop()) + 'px' : '0px';
            }
            return '0px';
        }

        function getScrollElement() {
            if ($el.simplebar.length && $el.simplebar[0].simpleBar) {
                return $el.simplebar[0].simpleBar.getScrollElement();
            }
            var $wrapper = $el.simplebar.find('.simplebar-content-wrapper');
            return $wrapper.length ? $wrapper[0] : null;
        }

        function showPanel(top) {
            clearTimer('panelHideTimer');
            state.panelVisible = true;
            if (isCollapsed()) {
                $el.stickySection.css({
                    display: 'block',
                    visibility: 'visible',
                    height: '0',
                    overflow: 'visible',
                    opacity: '1',
                    position: 'static',
                    width: '0'
                });
            }
            $el.tabsContent.stop(true, true).show().addClass('expanded-right').css({
                display: 'block',
                position: 'fixed',
                left: '70px',
                top: top || calculateTop(),
                'min-width': '280px',
                'max-width': '320px',
                'z-index': '1050',
                'background-color': panelBg()
            });
            requestAnimationFrame(function() {
                $el.tabsContent.css({ opacity: '1', visibility: 'visible' });
            });
        }

        function hidePanel(immediate) {
            clearTimer('panelHideTimer');
            state.panelVisible = false;
            if (immediate) {
                if (isCollapsed()) {
                    $el.stickySection.attr('style', '');
                }
                $el.tabsContent.removeClass('expanded-right').hide().css({ opacity: '0', visibility: 'hidden' });
                return;
            }
            $el.tabsContent.stop(true, true).css({ opacity: '0', visibility: 'hidden' });
            state.panelHideTimer = setTimeout(function() {
                if (!state.panelVisible) {
                    if (isCollapsed()) {
                        $el.stickySection.attr('style', '');
                    }
                    $el.tabsContent.removeClass('expanded-right').hide();
                }
            }, 180);
        }

        function activateTab(type) {
            if (type === 'search') {
                $el.frequentPane.hide();
                $el.searchTab.addClass('active');
                $el.frequentTab.removeClass('active');
                if (!$el.searchTabContainer.hasClass('expanded')) {
                    $el.searchTabContainer.addClass('expanded');
                }
            } else {
                $el.frequentPane.show();
                $el.frequentTab.addClass('active');
                $el.searchTab.removeClass('active');
                $el.searchTabContainer.removeClass('expanded');
            }
        }

        function isInArea(target, selectors) {
            return target ? $(target).closest(selectors).length > 0 : false;
        }

        // ==================== State ====================
        var state = {
            isSticky: false, lastScrollTop: 0,
            matchedItems: [], selectedIndex: -1,
            hoverTimer: null, scrollTimer: null, isHovering: false,
            panelVisible: false, panelHideTimer: null,
            searchTimer: null, bodyObserver: null
        };

        function clearTimer(key) {
            if (state[key]) { clearTimeout(state[key]); state[key] = null; }
        }

        function cancelQueuedSearch() {
            clearTimer('searchTimer');
        }

        function focusSearchInput($input, delay) {
            if (!$input || !$input.length) return;
            setTimeout(function() {
                $input.trigger('focus');
                if ($input[0] && typeof $input[0].select === 'function') {
                    $input[0].select();
                }
            }, delay || 0);
        }

        function clearScrollAnimations() {
            var scrollEl = getScrollElement();
            if (scrollEl) $(scrollEl).stop(true, false);
            $('html, body').stop(true, false);
        }

        function collapseMenuItem($li) {
            if (!$li || !$li.length) return;
            var $sub = $li.children('ul.sub-menu');
            if ($sub.length) {
                $sub.removeClass('mm-show mm-collapsing').addClass('mm-collapse')
                    .css({ height: '', display: '', visibility: '' })
                    .attr('aria-expanded', 'false');
                $sub.children('li').each(function() {
                    collapseMenuItem($(this));
                });
            }
            $li.removeClass('mm-active');
            $li.children('a.has-arrow').attr('aria-expanded', 'false');
        }

        function calculatePathMatchScore(currentPath, menuPath) {
            function getPathname(url) {
                try {
                    var a = document.createElement('a');
                    a.href = url;
                    return a.pathname.replace(/\/+$/, '');
                } catch (e) {
                    return url.replace(/\/+$/, '');
                }
            }

            var currentPathname = getPathname(currentPath);
            var menuPathname = getPathname(menuPath);

            if (currentPathname === menuPathname) return Number.MAX_SAFE_INTEGER;

            var currentSegments = currentPathname.split('/').filter(function(s) { return s.length > 0; });
            var menuSegments = menuPathname.split('/').filter(function(s) { return s.length > 0; });

            if (menuSegments.length > currentSegments.length) return -1;

            var matchCount = 0;
            var minLength = Math.min(currentSegments.length, menuSegments.length);

            for (var i = 0; i < minLength; i++) {
                if (menuSegments[i] !== currentSegments[i]) break;
                matchCount++;
            }

            if (matchCount === menuSegments.length) return matchCount;
            if (menuSegments.length === currentSegments.length && matchCount === menuSegments.length - 1) return matchCount;
            return -1;
        }

        function initActiveMenu() {
            if (!$el.sideMenu.length) return;

            var pageUrl = window.location.href.split(/[?#]/)[0];
            var bestMatch = null;
            var bestScore = -1;
            var $mainMenuLinks = $el.sideMenu.find('a').not(function() {
                return $(this).closest('.menu-search-item, .menu-frequent-item').length > 0;
            });
            var $mainMenu = $el.sideMenu.children('li').not('.menu-search-item, .menu-frequent-item');

            $mainMenu.add($mainMenu.find('li')).removeClass('mm-active');
            $mainMenu.find('a').removeClass('active mm-active');
            $mainMenu.find('ul.sub-menu').removeClass('mm-show').attr('aria-expanded', 'false');

            $mainMenuLinks.each(function() {
                var menuUrl = this.href;
                if (!menuUrl || menuUrl === '#' || menuUrl.indexOf('javascript:') === 0) return;

                var score = calculatePathMatchScore(pageUrl, menuUrl);
                if (score === Number.MAX_SAFE_INTEGER) {
                    bestMatch = $(this);
                    bestScore = score;
                    return false;
                }
                if (score > bestScore) {
                    bestScore = score;
                    bestMatch = $(this);
                }
            });

            if (!bestMatch || bestScore <= 0) return;

            bestMatch.addClass('active');
            var $current = bestMatch.closest('li');
            while ($current.length && $current.closest('#side-menu').length) {
                $current.addClass('mm-active');
                var $sub = $current.children('ul.sub-menu');
                if ($sub.length) {
                    $sub.addClass('mm-show').attr('aria-expanded', 'true');
                }
                var $parentSub = $current.parent('ul.sub-menu');
                if ($parentSub.length) {
                    $parentSub.addClass('mm-show').attr('aria-expanded', 'true');
                }
                $current = $parentSub.parent('li');
            }
        }

        function destroyMetisMenu() {
            if (!$el.sideMenu.length) return;
            var instance = $el.sideMenu.data('metisMenu');
            if (instance && typeof instance.dispose === 'function') {
                instance.dispose();
            }
            $el.sideMenu.off('show.metisMenu');
            $el.sideMenu.off('shown.metisMenu');
            $el.sideMenu.off('hide.metisMenu');
            $el.sideMenu.off('hidden.metisMenu');
            $el.sideMenu.off('.leftSidebarMenu');
            $el.sideMenu.removeData('metisMenu');
        }

        function initSidebarAccordion() {
            if (!$el.sideMenu.length) return;
            $el.sideMenu.off('.leftSidebarMenu');
            $el.sideMenu.on('show.metisMenu.leftSidebarMenu', function(e) {
                var $targetMenu = $(e.target);
                var $topLevelLi = $targetMenu.parent('li').closest('#side-menu > li');
                if (!$topLevelLi.length) return;

                $('#sidebar-menu a.active').removeClass('active');

                $el.sideMenu.children('li').each(function() {
                    var $top = $(this);
                    if ($top[0] === $topLevelLi[0]) return;
                    if ($top.hasClass('menu-search-item') || $top.hasClass('menu-frequent-item') || $top.hasClass('menu-title')) return;
                    if ($top.hasClass('mm-active')) collapseMenuItem($top);
                });
            });
        }

        function initMetisMenu() {
            if (!$el.sideMenu.length) return;

            destroyMetisMenu();
            if (isCollapsed()) {
                $el.sideMenu.find('ul.sub-menu').removeClass('mm-show mm-collapsing')
                    .addClass('mm-collapse')
                    .css({ height: '', display: '', visibility: '' });
                $el.sideMenu.find('li').removeClass('mm-active');
                $el.sideMenu.find('a.has-arrow').attr('aria-expanded', 'false');
                return;
            }

            initActiveMenu();
            $el.sideMenu.metisMenu({ toggle: true });
            initSidebarAccordion();
        }

        function handleCollapseStateChange() {
            cancelQueuedSearch();
            clearTimer('hoverTimer');
            clearTimer('panelHideTimer');
            clearScrollAnimations();

            if (isCollapsed()) {
                $el.searchTabContainer.removeClass('expanded');
                $el.searchInput.val('').blur();
                $el.searchInputMenu.val('');
                resetMenuDisplay();
                $el.searchResults.hide();
                $el.searchResultsMenu.hide();
                hidePanel(true);
            } else {
                initMetisMenu();
                $el.tabsContent.show();
                if ($el.searchTab.hasClass('active')) {
                    expandSearch();
                }
            }
        }

        function initLeftMenuCollapse() {
            $(document).off('click.leftSidebarToggle', '#vertical-menu-btn').on('click.leftSidebarToggle', '#vertical-menu-btn', function() {
                setTimeout(function() {
                    cacheDOM();
                    handleCollapseStateChange();
                }, 140);
            });

            if ($el.body.length && !state.bodyObserver) {
                state.bodyObserver = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.attributeName === 'class') {
                            cacheDOM();
                            handleCollapseStateChange();
                        }
                    });
                });
                state.bodyObserver.observe($el.body[0], { attributes: true, attributeFilter: ['class'] });
            }
        }

        // ==================== Search Core ====================
        function expandSearch() {
            if (!$el.searchTabContainer.length) return;
            if (isCollapsed()) {
                showPanel();
                activateTab('search');
                $el.searchTabContainer.addClass('expanded');
                focusSearchInput($el.searchInputMenu, 80);
            } else {
                $el.searchTab.addClass('active');
                $el.frequentTab.removeClass('active');
                if (!$el.searchTabContainer.hasClass('expanded')) {
                    $el.searchTabContainer.addClass('expanded');
                    $el.frequentPane.hide();
                    $el.frequentTab.removeClass('active');
                }
                focusSearchInput($el.searchInput, 70);
            }
        }

        function collapseSearch(keepValue) {
            if ($el.searchTabContainer.hasClass('expanded')) {
                $el.searchTabContainer.removeClass('expanded');
                if (!keepValue) {
                    $el.searchInput.val('');
                    $el.searchInputMenu.val('');
                }
                $el.searchInput.blur();
                $el.searchInputMenu.blur();
                $el.searchResults.hide();
                $el.searchResultsMenu.hide();
                resetMenuDisplay();
            }
        }

        function resetMenuDisplay() {
            if (!$el.menuItems.length) $el.menuItems = $('#sidebar-menu li');
            $el.menuItems.removeClass('menu-item-hidden menu-item-matched menu-item-keyboard-selected');
            $el.frequentSection.show();
            $el.searchResults.hide();
        }

        function handleSearch($input) {
            var text = $input.val().toLowerCase().trim();
            state.selectedIndex = -1;
            state.matchedItems = [];

            // 同步两个搜索输入框
            var $other = $input.attr('id') === 'menu-search-input' ? $el.searchInputMenu : $el.searchInput;
            $other.val(text);

            if (!text) {
                $el.searchResults.hide();
                $el.searchResultsMenu.hide();
                resetMenuDisplay();
                return;
            }

            $el.searchResults.show();
            $el.searchResultsMenu.show();
            if (isCollapsed()) { showPanel(); activateTab('search'); }

            performSearch(text);
        }

        function queueSearch($input) {
            cancelQueuedSearch();
            state.searchTimer = setTimeout(function() {
                handleSearch($input);
            }, 70);
        }

        function performSearch(text) {
            var matchCount = 0, matchedItems = [], firstMatch = null;
            var collapsed = isCollapsed();

            $el.frequentSection.hide();
            $el.menuItems.removeClass('menu-item-keyboard-selected');

            $el.menuItems.each(function() {
                var $item = $(this);
                if ($item.hasClass('menu-search-item') || $item.hasClass('menu-frequent-item')) return;

                // 菜单分组标题
                if ($item.hasClass('menu-title')) {
                    var hasMatch = false;
                    $item.nextUntil('.menu-title').each(function() {
                        $(this).find('a span').each(function() {
                            if ($(this).text().toLowerCase().indexOf(text) !== -1) { hasMatch = true; return false; }
                        });
                        if (hasMatch) return false;
                    });
                    if (!collapsed) $item.toggleClass('menu-item-hidden', !hasMatch);
                    return;
                }

                var menuText = $item.find('> a span').text().toLowerCase();
                if (menuText && menuText.indexOf(text) !== -1) {
                    // 直接匹配
                    $item.removeClass('menu-item-hidden').addClass('menu-item-matched');
                    expandParentMenu($item);
                    matchCount++;
                    matchedItems.push({ $item: $item, hasChildren: $item.find('> ul.sub-menu').length > 0 });
                    if (!firstMatch) firstMatch = $item;
                } else {
                    // 搜索子菜单
                    var childMatch = false;
                    $item.find('ul.sub-menu li').each(function() {
                        var $child = $(this);
                        if ($child.hasClass('menu-title')) return;
                        var childText = $child.find('> a span').text().toLowerCase();
                        if (childText && childText.indexOf(text) !== -1) {
                            childMatch = true;
                            matchCount++;
                            $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                            expandParentMenu($child);
                            matchedItems.push({ $item: $child, hasChildren: $child.find('> ul.sub-menu').length > 0 });
                            if (!firstMatch) firstMatch = $child;
                            // 确保父级可见且展开
                            $item.removeClass('menu-item-hidden');
                            var $sub = $item.find('> ul.sub-menu');
                            if ($sub.length) {
                                $sub.addClass('mm-show').attr('aria-expanded', 'true');
                                $item.addClass('mm-active');
                            }
                        }
                    });
                    if (!collapsed) {
                        if (!childMatch) $item.removeClass('menu-item-matched').addClass('menu-item-hidden');
                        else $item.removeClass('menu-item-hidden');
                    }
                }
            });

            // 展开匹配的父菜单项的子菜单
            var finalItems = matchedItems.slice();
            matchedItems.forEach(function(data) {
                if (data.hasChildren) expandMatchedChildren(data.$item, finalItems);
            });
            matchCount = finalItems.length;

            state.matchedItems = finalItems;
            updateSearchResults(matchCount, finalItems, firstMatch, text);
        }

        function expandMatchedChildren($item, items) {
            var $sub = $item.find('> ul.sub-menu');
            if (!$sub.length) return;
            $sub.addClass('mm-show').attr('aria-expanded', 'true').css({ display: 'block', visibility: 'visible' });
            $item.addClass('mm-active');

            $sub.find('> li').each(function() {
                var $child = $(this);
                if ($child.hasClass('menu-title')) return;
                var isDup = items.some(function(d) { return d.$item[0] === $child[0]; });
                if (!isDup) {
                    $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                    var hasChildren = $child.find('> ul.sub-menu').length > 0;
                    items.push({ $item: $child, hasChildren: hasChildren });
                    if (hasChildren) expandMatchedChildren($child, items);
                }
            });
        }

        function updateSearchResults(count, items, firstMatch, searchText) {
            var collapsed = isCollapsed();
            if (count > 0) {
                var resultText = '搜索结果 (' + count + ')';
                if (!collapsed) $el.searchResultsText.text(resultText);
                $el.searchResultsTextMenu.text(resultText);

                if (collapsed) {
                    showPanel();
                    activateTab('search');
                    $el.searchResults.show();
                    fillResults($el.searchResultsList, items);
                    fillResults($el.searchResultsListMenu, items);
                } else {
                    fillResults($el.searchResultsList, items);
                }

                // 滚动到第一个匹配项（正常模式下）
                if (firstMatch && !collapsed) {
                    setTimeout(function() {
                        var scrollEl = getScrollElement();
                        if (scrollEl) {
                            var top = firstMatch.offset().top - $(scrollEl).offset().top + scrollEl.scrollTop - 150;
                            $(scrollEl).animate({ scrollTop: top }, 300);
                        }
                    }, 150);
                }
            } else {
                var noResult = '未找到匹配的菜单';
                $el.searchResultsText.text(noResult);
                $el.searchResultsTextMenu.text(noResult);
                $el.searchResultsList.empty();
                $el.searchResultsListMenu.empty();
            }
        }

        function fillResults($list, items) {
            if (!$list.length) return;
            $list.empty();

            // 计算层级并排序（父级在子级前面）
            var sorted = items.map(function(d) {
                var level = 0, $p = d.$item.parent('ul.sub-menu');
                while ($p.length) { level++; $p = $p.parent('li').parent('ul.sub-menu'); }
                return { $item: d.$item, level: level };
            }).sort(function(a, b) {
                // 父子关系：父在前
                if (b.$item.closest(a.$item).length) return -1;
                if (a.$item.closest(b.$item).length) return 1;
                return a.level - b.level;
            });

            sorted.forEach(function(d) {
                var $link = d.$item.find('> a').first();
                if (!$link.length) return;
                var text = $link.find('span').text() || $link.text().trim();
                var icon = $link.find('i').first().attr('class') || 'mdi mdi-circle';
                var href = $link.attr('href') || '#';
                var pad = d.level > 0 ? 'padding-left:' + (20 + d.level * 20) + 'px;' : '';

                $list.append(
                    '<div class="search-result-item px-3 py-2" style="' + pad + '">' +
                    '<a href="' + href + '" class="d-flex align-items-center waves-effect search-result-link">' +
                    '<i class="' + icon + ' me-2"></i><span>' + text + '</span></a></div>'
                );
            });
        }

        function expandParentMenu($item) {
            var $parent = $item.parent('ul.sub-menu');
            if ($parent.length) {
                $parent.addClass('mm-show').attr('aria-expanded', 'true');
                var $parentLi = $parent.parent('li');
                $parentLi.addClass('mm-active');
                expandParentMenu($parentLi);
            }
        }

        function highlightSelected() {
            $el.menuItems.removeClass('menu-item-keyboard-selected');
            if (state.selectedIndex >= 0 && state.selectedIndex < state.matchedItems.length) {
                var $sel = state.matchedItems[state.selectedIndex].$item;
                $sel.addClass('menu-item-keyboard-selected');
                var scrollEl = getScrollElement();
                if (scrollEl && $sel.length) {
                    var rect = $sel[0].getBoundingClientRect();
                    var containerRect = scrollEl.getBoundingClientRect();
                    if (rect.top < containerRect.top || rect.bottom > containerRect.bottom) {
                        var target = scrollEl.scrollTop + (rect.top - containerRect.top) - (scrollEl.clientHeight / 2) + (($sel.outerHeight() || 40) / 2);
                        $(scrollEl).stop(true, false).animate({ scrollTop: Math.max(0, target) }, 140);
                    }
                }
            }
        }

        function handleSearchKeydown(e) {
            var items = state.matchedItems, idx = state.selectedIndex;
            if (e.key === 'Escape') {
                state.selectedIndex = -1;
                state.matchedItems = [];
                if (isCollapsed()) { $(this).val(''); handleSearch($(this)); }
                else collapseSearch();
            } else if (e.key === 'ArrowDown' && items.length) {
                e.preventDefault();
                state.selectedIndex = (idx + 1) % items.length;
                highlightSelected();
            } else if (e.key === 'ArrowUp' && items.length) {
                e.preventDefault();
                state.selectedIndex = idx <= 0 ? items.length - 1 : idx - 1;
                highlightSelected();
            } else if (e.key === 'Enter' && idx >= 0 && idx < items.length) {
                e.preventDefault();
                var $link = items[idx].$item.find('a').first();
                var href = $link.attr('href');
                if (href && href !== 'javascript: void(0);') window.location.href = href;
                else $link.trigger('click');
            }
        }

        // ==================== Init: Search ====================
        function initSearch() {
            $el.searchInput.off('.leftSidebarSearch');
            $el.searchInputMenu.off('.leftSidebarSearch');
            $el.searchTab.off('.leftSidebarSearch');
            $('#search-tab-close-icon').off('.leftSidebarSearch');
            $('#menu-search-link').off('.leftSidebarSearch');
            $('#menu-search-content').off('.leftSidebarSearch');
            $el.searchMenuItem.off('.leftSidebarSearch');
            $el.searchSubmenu.off('.leftSidebarSearch');
            $(document).off('.leftSidebarSearch');

            // Sticky 区域搜索输入框
            $el.searchInput.on('input.leftSidebarSearch', function() { queueSearch($(this)); });
            $el.searchInput.on('keydown.leftSidebarSearch', handleSearchKeydown);

            // 折叠模式下的菜单形式搜索输入框
            $el.searchInputMenu.on('input.leftSidebarSearch', function(e) { e.stopPropagation(); queueSearch($(this)); });
            $el.searchInputMenu.on('keydown.leftSidebarSearch', handleSearchKeydown);
            $el.searchInputMenu.on('click.leftSidebarSearch mousedown.leftSidebarSearch', function(e) { e.stopPropagation(); });

            // 搜索Tab按钮点击
            $el.searchTab.on('click.leftSidebarSearch', function(e) { e.stopPropagation(); expandSearch(); });

            // 关闭图标
            $('#search-tab-close-icon').on('click.leftSidebarSearch', function(e) { e.stopPropagation(); collapseSearch(); });

            // 折叠模式下搜索链接
            $('#menu-search-link').on('click.leftSidebarSearch', function(e) {
                e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
                showPanel();
                activateTab('search');
                focusSearchInput($el.searchInputMenu, 60);
                return false;
            });

            // 阻止搜索内容区域事件冒泡
            $('#menu-search-content').on('click.leftSidebarSearch mousedown.leftSidebarSearch', function(e) { e.stopPropagation(); });

            // 折叠模式下搜索菜单项hover
            $el.searchMenuItem.on('mouseenter.leftSidebarSearch', function() {
                if (isCollapsed()) {
                    $el.searchMenuItem.addClass('mm-active');
                    $el.searchSubmenu.attr('aria-expanded', 'true');
                }
            });

            $el.searchMenuItem.add($el.searchSubmenu).on('mouseleave.leftSidebarSearch', function(e) {
                if (!isCollapsed()) return;
                if (isInArea(e.relatedTarget, '.menu-search-item, .menu-search-submenu, .menu-search-content')) return;
                if ($el.searchInputMenu.is(':focus')) return;
                setTimeout(function() {
                    if (!$el.searchInputMenu.is(':focus')) {
                        $el.searchMenuItem.removeClass('mm-active');
                        $el.searchSubmenu.attr('aria-expanded', 'false');
                    }
                }, 100);
            });

            // 折叠模式下搜索输入框焦点管理
            $el.searchInputMenu.on('focus.leftSidebarSearch', function() {
                if (isCollapsed()) {
                    $el.searchMenuItem.addClass('mm-active');
                    $el.searchSubmenu.attr('aria-expanded', 'true');
                }
            }).on('blur.leftSidebarSearch', function() {
                if (isCollapsed()) {
                    setTimeout(function() {
                        if (!$(document.activeElement).closest('.menu-search-item').length) {
                            $el.searchMenuItem.removeClass('mm-active');
                            $el.searchSubmenu.attr('aria-expanded', 'false');
                        }
                    }, 100);
                }
            });

            // 全局快捷键: Ctrl+K 或 /
            $(document).on('keydown.leftSidebarSearch', function(e) {
                var $t = $(e.target);
                if ($t.is('input, textarea, [contenteditable="true"]')) return;
                if ((e.ctrlKey && e.key === 'k') || e.key === '/') {
                    e.preventDefault();
                    if (isCollapsed()) {
                        showPanel();
                        activateTab('search');
                        focusSearchInput($el.searchInputMenu, 60);
                    } else {
                        expandSearch();
                    }
                }
            });

            // 点击外部收起搜索
            $(document).on('click.leftSidebarSearch', function(e) {
                if (!$el.searchTabContainer.is(e.target) && !$el.searchTabContainer.has(e.target).length) {
                    if ($el.searchInput.val().trim() === '' && $el.searchTabContainer.hasClass('expanded')) {
                        collapseSearch();
                    }
                }
            });
        }

        // ==================== Init: Tabs ====================
        function initTabs() {
            var searchHoverTimer = null;

            $el.searchTab.off('.leftSidebarTabs');
            $el.searchTabContainer.off('.leftSidebarTabs');
            $el.frequentTab.off('.leftSidebarTabs');
            $(document).off('.leftSidebarTabs');

            // 默认展开搜索（正常模式下）
            setTimeout(function() { if (!isCollapsed()) expandSearch(); }, 300);

            // 搜索Tab hover
            $el.searchTab.on('mouseenter.leftSidebarTabs', function(e) {
                if (isCollapsed()) {
                    expandSearch();
                } else {
                    var rt = e.relatedTarget;
                    if (rt && !$(rt).closest('#sticky-menu-section').length && $el.frequentTab.hasClass('active')) return;
                    $el.searchTab.addClass('active');
                    $el.frequentTab.removeClass('active');
                }
            });

            // 搜索Tab/容器鼠标离开（正常模式下收起空搜索框）
            function handleSearchLeave(e) {
                if (isCollapsed()) return;
                if (isInArea(e.relatedTarget, '#search-tab-container, .menu-tabs-content, #search-results-container')) return;
                clearTimeout(searchHoverTimer);
                searchHoverTimer = setTimeout(function() {
                    if ($el.searchInput.val().trim() === '' && $el.searchTabContainer.hasClass('expanded')) {
                        $el.searchTabContainer.removeClass('expanded');
                        $el.searchInput.blur();
                    }
                }, HOVER_DELAY);
            }
            $el.searchTab.on('mouseleave.leftSidebarTabs', handleSearchLeave);
            $el.searchTabContainer.on('mouseleave.leftSidebarTabs', handleSearchLeave)
                .on('mouseenter.leftSidebarTabs', function() { clearTimeout(searchHoverTimer); });

            // 保持内容展开
            $(document).on('mouseenter.leftSidebarTabs', '#menu-search-input, #search-tab-container, #frequent-tab-pane', function() {
                if (!isCollapsed()) clearTimeout(searchHoverTimer);
            });

            // 常用菜单Tab hover
            $el.frequentTab.on('mouseenter.leftSidebarTabs', function() {
                if (isCollapsed()) { showPanel(); activateTab('frequent'); }
                else { $el.frequentTab.addClass('active'); $el.searchTab.removeClass('active'); }
            });

            // 常用菜单Tab点击
            $el.frequentTab.on('click.leftSidebarTabs', function() {
                activateTab('frequent');
                collapseSearch(true);
                $el.searchResults.hide();
                if (isCollapsed()) showPanel();
            });
        }

        // ==================== Init: Sticky ====================
        function initSticky() {
            $el.stickySection.off('.leftSidebarSticky');
            $('.menu-tab-btn').off('.leftSidebarSticky');
            $(document).off('.leftSidebarSticky');

            // Sticky区域hover
            $el.stickySection.on('mouseenter.leftSidebarSticky', function() {
                state.isHovering = true;
                clearTimer('hoverTimer');
                if (isCollapsed()) {
                    showPanel();
                    activateTab('search');
                } else {
                    if ($el.searchTab.hasClass('active')) {
                        if (!$el.searchTabContainer.hasClass('expanded')) {
                            $el.searchTabContainer.addClass('expanded');
                            focusSearchInput($el.searchInput, 60);
                        }
                    } else if ($el.frequentTab.hasClass('active')) {
                        $el.frequentPane.show();
                        $el.searchTabContainer.removeClass('expanded');
                    }
                }
            });

            // 展开面板hover
            $(document).on('mouseenter.leftSidebarSticky', '.menu-tabs-content.expanded-right', function() {
                state.isHovering = true;
                clearTimer('hoverTimer');
            });

            // 统一的鼠标离开处理
            function handleLeave(e) {
                var rt = e.relatedTarget;
                if (isInArea(rt, RELATED_AREAS)) return;
                state.hoverTimer = setTimeout(function() {
                    var ct = document.elementFromPoint(e.clientX || 0, e.clientY || 0);
                    if (isInArea(ct, RELATED_AREAS)) return;
                    state.isHovering = false;
                    collapseContent();
                }, isCollapsed() ? 100 : HOVER_DELAY);
            }

            $el.stickySection.on('mouseleave.leftSidebarSticky', handleLeave);
            $(document).on('mouseleave.leftSidebarSticky', '.menu-tabs-content.expanded-right', handleLeave);
            $(document).on('mouseleave.leftSidebarSticky', '.menu-search-item, .menu-search-submenu, .menu-search-content', function(e) {
                if (isCollapsed()) handleLeave(e);
            });

            function collapseContent() {
                if (isCollapsed()) {
                    hidePanel();
                } else {
                    if ($el.searchTabContainer.hasClass('expanded') && $el.searchInput.val().trim() === '') {
                        $el.searchTabContainer.removeClass('expanded');
                        $el.searchInput.blur();
                    }
                    $el.frequentPane.hide();
                }
                if ($el.searchInput.val().trim() === '') $el.searchResults.hide();
            }

            // Tab按钮点击
            $('.menu-tab-btn').on('click.leftSidebarSticky', function() {
                state.isHovering = true;
                if (isCollapsed()) showPanel();
                else $el.tabsContent.removeClass('collapsed');
                clearTimer('hoverTimer');
                clearTimer('scrollTimer');
            });

            // 滚动监听
            var scrollEl = getScrollElement();
            if (scrollEl) $(scrollEl).off('scroll.leftSidebarSticky').on('scroll.leftSidebarSticky', checkSticky);
            else $(window).off('scroll.leftSidebarSticky').on('scroll.leftSidebarSticky', checkSticky);
            setTimeout(checkSticky, 100);
        }

        function checkSticky() {
            var scrollEl = getScrollElement();
            var scrollTop = scrollEl ? scrollEl.scrollTop : $(window).scrollTop();

            if (scrollTop > 10) {
                if (!state.isSticky) { state.isSticky = true; $el.stickySection.addClass('sticky-active'); }
                if (scrollTop > state.lastScrollTop + 2) $el.tabsContent.addClass('collapsed');
                else if (scrollTop < state.lastScrollTop - 2 && scrollTop < 50) $el.tabsContent.removeClass('collapsed');
            } else if (state.isSticky) {
                state.isSticky = false;
                $el.stickySection.removeClass('sticky-active');
                $el.tabsContent.removeClass('collapsed');
            }

            state.lastScrollTop = scrollTop;
            clearTimer('scrollTimer');
            state.scrollTimer = setTimeout(function() {
                var cur = scrollEl ? scrollEl.scrollTop : $(window).scrollTop();
                if (state.isSticky && cur < 100) $el.tabsContent.removeClass('collapsed');
            }, 500);
        }

        // ==================== Init: Sidebar Collapse ====================
        function initSidebarCollapse() {
            initLeftMenuCollapse();
            handleCollapseStateChange();
        }

        // ==================== Active Menu: Expansion & Scroll ====================
        // 菜单定位：负责 #side-menu 内部激活项的展开和滚动居中
        window.scrollToActiveMenu = function(retryCount) {
            retryCount = retryCount || 0;
            if (!$el.sideMenu || !$el.sideMenu.length) return;

            // 找到最深层的激活叶子链接（a.active 且不带 has-arrow 标识为叶子节点）
            var $activeLink = $el.sideMenu.find('a.active').not('.has-arrow').first();
            var $activeMenu;

            if ($activeLink.length) {
                $activeMenu = $activeLink.closest('li');
            } else {
                // 后备方案：取最深层的 mm-active li（DOM 中最后一个 = 最深层级）
                $activeMenu = $el.sideMenu.find('li.mm-active').last();
            }

            if (!$activeMenu || !$activeMenu.length) return;

            var scrollElement = getScrollElement();
            if (!scrollElement) {
                if (retryCount < 1) setTimeout(function() { window.scrollToActiveMenu(1); }, 400);
                return;
            }

            setTimeout(function() {
                try {
                    // 确保所有父级菜单都已展开（修复三级菜单展开问题）
                    $activeMenu.parents('li').each(function() {
                        var $li = $(this);
                        if (!$li.closest('#side-menu').length) return false;
                        $li.addClass('mm-active');
                        var $sub = $li.find('> ul.sub-menu');
                        if ($sub.length) $sub.addClass('mm-show').attr('aria-expanded', 'true');
                        $li.find('> a.has-arrow').addClass('mm-active');
                    });
                    $activeMenu.addClass('mm-active');

                    // 滚动到激活项居中
                    setTimeout(function() {
                        try {
                            var el = $activeMenu[0];
                            if (!el) return;
                            var mRect = el.getBoundingClientRect();
                            var cRect = scrollElement.getBoundingClientRect();
                            var mH = $activeMenu.outerHeight() || 40;
                            var target = scrollElement.scrollTop + (mRect.top - cRect.top) - (scrollElement.clientHeight / 2) + (mH / 2);
                            target = Math.max(0, Math.min(target, scrollElement.scrollHeight - scrollElement.clientHeight));
                            $(scrollElement).animate({ scrollTop: target }, 400);
                        } catch (e) { console.warn('菜单定位滚动出错:', e); }
                    }, 300);
                } catch (e) { console.warn('菜单定位展开出错:', e); }
            }, 200);
        };

        // ==================== Bootstrap ====================
        $(document).ready(function() {
            cacheDOM();
            initMetisMenu();
            initTabs();
            initSearch();
            initSticky();
            initSidebarCollapse();
            scrollToActiveMenu();

            // 监听 mm-active 变化，自动滚动到新激活的菜单
            if (typeof MutationObserver !== 'undefined' && $el.sideMenu[0]) {
                var scrollDebounce = null, lastActiveId = null;
                new MutationObserver(function(muts) {
                    var shouldScroll = false, activeId = null;
                    muts.forEach(function(m) {
                        if (m.attributeName !== 'class') return;
                        var old = m.oldValue || '', cur = m.target.className || '';
                        if (old.indexOf('mm-active') === -1 && cur.indexOf('mm-active') !== -1 && $(m.target).is('li')) {
                            var $li = $(m.target);
                            if ($li.closest('#side-menu').length) {
                                var $a = $li.find('> a.active, .active').first();
                                activeId = ($a.length ? $a.attr('href') : $li.find('> a').first().attr('href')) || $li.text();
                                if (activeId && activeId !== lastActiveId) shouldScroll = true;
                            }
                        }
                    });
                    if (shouldScroll) {
                        lastActiveId = activeId;
                        clearTimeout(scrollDebounce);
                        scrollDebounce = setTimeout(function() {
                            if (typeof window.scrollToActiveMenu === 'function') window.scrollToActiveMenu();
                        }, 300);
                    }
                }).observe($el.sideMenu[0], {
                    attributes: true, attributeFilter: ['class'], subtree: true, attributeOldValue: true
                });
            }
        });

        // DOMContentLoaded 后备
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(function() { if (typeof window.scrollToActiveMenu === 'function') window.scrollToActiveMenu(); }, 300);
            });
        } else {
            setTimeout(function() { if (typeof window.scrollToActiveMenu === 'function') window.scrollToActiveMenu(); }, 300);
        }

    })(jQuery);
    </script>
