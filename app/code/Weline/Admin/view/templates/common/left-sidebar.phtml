            transition: all 0.2s;
        }
        
        #sidebar-menu ul li:not(.menu-title) > a:hover {
            color: #0bb197 !important;
            background-color: #f8f9fa;
            border-left-color: #0bb197;
        }
        
        #sidebar-menu ul li:not(.menu-title) > a:hover i {
            color: #0bb197 !important;
        }
        
        /* 深色主题下的主菜单hover样式 */
        body[data-sidebar="dark"] #sidebar-menu ul li:not(.menu-title) > a:hover {
            color: #d7e4ec !important;
            background-color: rgba(255, 255, 255, 0.1);
            border-left-color: #d7e4ec;
        }
        
        body[data-sidebar="dark"] #sidebar-menu ul li:not(.menu-title) > a:hover i {
            color: #d7e4ec !important;
        }
        
        /* 搜索结果键盘选中样式 */
        .menu-item-keyboard-selected {
            background-color: rgba(11, 177, 151, 0.2) !important;
            outline: 2px solid #0bb197;
            outline-offset: -2px;
        }
        
        body[data-sidebar="dark"] .menu-item-keyboard-selected {
            background-color: rgba(215, 228, 236, 0.2) !important;
            outline-color: #d7e4ec;
        }
        
        /* 搜索无结果提示 */
        .search-no-results {
            padding: 2rem 1rem;
            text-align: center;
            color: #6c757d;
        }
        
        body[data-sidebar="dark"] .search-no-results {
            color: #8590a5;
        }
    </style>

    <script>
        (function($) {
            'use strict';
            
            // 菜单搜索和悬浮功能控制器 - 使用闭包封装，避免全局污染
            var MenuController = (function() {
                // 私有变量
                var $searchTabContainer = null;
                var $searchInput = null;
                var $menuItems = null;
                var $frequentMenusSection = null;
                var $searchResultsContainer = null;
                var $stickySection = null;
                var $tabsContent = null;
                var $simplebarContainer = null;
                var $sidebarMenu = null;
                
                // 滚动控制变量
                var isSticky = false;
                var lastScrollTop = 0;
                var scrollTimer = null;
                var isScrolling = false;
                
                // 搜索相关变量
                var matchedMenuItems = [];
                var currentSelectedIndex = -1;
                
                // 初始化DOM元素引用
                function initElements() {
                    $searchTabContainer = $('#search-tab-container');
                    $searchInput = $('#menu-search-input');
                    $menuItems = $('#side-menu li');
                    $frequentMenusSection = $('#frequent-menus-section');
                    $searchResultsContainer = $('#search-results-container');
                    $stickySection = $('#sticky-menu-section');
                    $tabsContent = $('.menu-tabs-content');
                    $simplebarContainer = $('.vertical-menu [data-simplebar]');
                    $sidebarMenu = $('#sidebar-menu');
                }
                
                // 展开搜索Tab
                function expandSearch() {
                    if (!$searchTabContainer || !$searchTabContainer.length) {
                        return;
                    }
                    
                    if (!$searchTabContainer.hasClass('expanded')) {
                        $searchTabContainer.addClass('expanded');
                        $('#frequent-tab-pane').hide();
                        $('#frequent-menu-tab').removeClass('active');
                        
                        setTimeout(function() {
                            if ($searchInput && $searchInput.length) {
                                $searchInput.focus();
                            }
                        }, 250);
                    } else {
                        if ($searchInput && $searchInput.length) {
                            $searchInput.focus();
                        }
                    }
                }
                
                // 收起搜索Tab
                function collapseSearch() {
                    if (!$searchTabContainer || !$searchTabContainer.length) {
                        return;
                    }
                    
                    if ($searchTabContainer.hasClass('expanded')) {
                        $searchTabContainer.removeClass('expanded');
                        if ($searchInput && $searchInput.length) {
                            $searchInput.val('').blur();
                        }
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            $searchResultsContainer.hide();
                        }
                        resetMenuDisplay();
                    }
                }
                
                // 重置菜单显示（修复null检查）
                function resetMenuDisplay() {
                    if (!$menuItems || !$menuItems.length) {
                        $menuItems = $('#side-menu li');
                    }
                    if (!$frequentMenusSection || !$frequentMenusSection.length) {
                        $frequentMenusSection = $('#frequent-menus-section');
                    }
                    if (!$menuItems || !$menuItems.length) {
                        return;
                    }
                    
                    $menuItems.removeClass('menu-item-hidden menu-item-matched');
                    if ($frequentMenusSection && $frequentMenusSection.length) {
                        $frequentMenusSection.show();
                    }
                    if ($searchResultsContainer && $searchResultsContainer.length) {
                        $searchResultsContainer.hide();
                    }
                }
                
                // 检查并更新悬浮状态
                function checkSticky() {
                    if (!$stickySection || !$stickySection.length || !$tabsContent || !$tabsContent.length) {
                        return;
                    }
                    
                    // 获取滚动位置
                    var scrollTop = 0;
                    if ($simplebarContainer && $simplebarContainer.length && $simplebarContainer[0].simpleBar) {
                        scrollTop = $simplebarContainer[0].simpleBar.getScrollElement().scrollTop;
                    } else if ($sidebarMenu && $sidebarMenu.length) {
                        scrollTop = $sidebarMenu.scrollTop() || 0;
                    } else {
                        scrollTop = $(window).scrollTop() || 0;
                    }
                    
                    // 标记正在滚动
                    isScrolling = true;
                    
                    // 清除之前的定时器
                    if (scrollTimer) {
                        clearTimeout(scrollTimer);
                    }
                    
                    // 当滚动超过初始位置时，激活悬浮
                    if (scrollTop > 10) {
                        if (!isSticky) {
                            isSticky = true;
                            $stickySection.addClass('sticky-active');
                        }
                        
                        // 检测滚动方向：向下滚动时收起，向上滚动时判断
                        if (scrollTop > lastScrollTop + 2) {
                            // 向下滚动 - 收起内容
                            $tabsContent.addClass('collapsed');
                        } else if (scrollTop < lastScrollTop - 2) {
                            // 向上滚动
                            if (scrollTop < 50) {
                                // 接近顶部时展开内容
                                $tabsContent.removeClass('collapsed');
                            }
                        }
                    } else {
                        // 回到顶部时取消悬浮状态
                        if (isSticky) {
                            isSticky = false;
                            $stickySection.removeClass('sticky-active');
                            $tabsContent.removeClass('collapsed');
                        }
                    }
                    
                    lastScrollTop = scrollTop;
                    
                    // 滚动停止后延迟展开内容（仅在接近顶部时）
                    scrollTimer = setTimeout(function() {
                        isScrolling = false;
                        // 重新获取当前滚动位置
                        var currentScrollTop = 0;
                        if ($simplebarContainer && $simplebarContainer.length && $simplebarContainer[0].simpleBar) {
                            currentScrollTop = $simplebarContainer[0].simpleBar.getScrollElement().scrollTop;
                        } else if ($sidebarMenu && $sidebarMenu.length) {
                            currentScrollTop = $sidebarMenu.scrollTop() || 0;
                        } else {
                            currentScrollTop = $(window).scrollTop() || 0;
                        }
                        
                        if (isSticky && currentScrollTop < 100 && !isScrolling && $tabsContent && $tabsContent.length) {
                            $tabsContent.removeClass('collapsed');
                        }
                    }, 500);
                }
                
                // 返回公共接口
                return {
                    init: function() {
                        initElements();
                    },
                    expandSearch: expandSearch,
                    collapseSearch: collapseSearch,
                    resetMenuDisplay: resetMenuDisplay,
                    checkSticky: checkSticky,
                    getMatchedMenuItems: function() {
                        return matchedMenuItems;
                    },
                    setMatchedMenuItems: function(items) {
                        matchedMenuItems = items;
                        currentSelectedIndex = -1;
                    },
                    getCurrentSelectedIndex: function() {
                        return currentSelectedIndex;
                    },
                    setCurrentSelectedIndex: function(index) {
                        currentSelectedIndex = index;
                    },
                    getSearchInput: function() {
                        return $searchInput;
                    },
                    getMenuItems: function() {
                        return $menuItems;
                    },
                    getFrequentMenusSection: function() {
                        return $frequentMenusSection;
                    },
                    getSearchResultsContainer: function() {
                        return $searchResultsContainer;
                    },
                    clearScrollTimer: function() {
                        if (scrollTimer) {
                            clearTimeout(scrollTimer);
                            scrollTimer = null;
                        }
                    }
                };
            })();
            
            // 初始化控制器
            MenuController.init();
            
            // 菜单搜索功能
            function initMenuSearch() {
                var $searchTabBtn = $('#search-menu-tab');
                var $searchTabContainer = $('#search-tab-container');
                var $searchInput = MenuController.getSearchInput();
                var $searchCloseIcon = $('#search-tab-close-icon');
                var $menuItems = MenuController.getMenuItems();
                var $frequentMenusSection = MenuController.getFrequentMenusSection();
                var $searchResultsContainer = MenuController.getSearchResultsContainer();
                var $searchResultsText = $('#search-results-text');
                
                if (!$searchInput || !$searchInput.length) {
                    return;
                }
                
                // 点击搜索Tab按钮展开
                $searchTabBtn.on('click', function(e) {
                    e.stopPropagation();
                    if ($searchTabContainer && !$searchTabContainer.hasClass('expanded')) {
                        MenuController.expandSearch();
                    }
                });
                
                // 点击关闭图标收起
                $searchCloseIcon.on('click', function(e) {
                    e.stopPropagation();
                    MenuController.collapseSearch();
                });
                
                // 全局键盘快捷键：Ctrl+K 或 / 打开搜索（仅此一个全局暴露）
                $(document).on('keydown.menuSearch', function(e) {
                    // 如果当前焦点在输入框、文本域或内容可编辑元素上，不触发快捷键
                    var $target = $(e.target);
                    if ($target.is('input:not([type="text"]), textarea, [contenteditable="true"]')) {
                        return;
                    }
                    
                    // Ctrl+K 或 / 键打开搜索
                    if ((e.ctrlKey && e.key === 'k') || (e.key === '/' && !$target.is('input, textarea'))) {
                        e.preventDefault();
                        MenuController.expandSearch();
                    }
                });
                
                // 点击搜索容器外部时，如果输入框为空则收起
                $(document).on('click.menuSearch', function(e) {
                    if ($searchTabContainer && !$searchTabContainer.is(e.target) && $searchTabContainer.has(e.target).length === 0) {
                        if ($searchInput && $searchInput.val().trim() === '' && $searchTabContainer.hasClass('expanded')) {
                            MenuController.collapseSearch();
                        }
                    }
                });
                
                // 搜索输入事件
                $searchInput.on('input', function() {
                    var searchText = $(this).val().toLowerCase().trim();
                    MenuController.setCurrentSelectedIndex(-1);
                    MenuController.setMatchedMenuItems([]);
                    
                    if (searchText === '') {
                        // 清空搜索，隐藏搜索结果，显示所有菜单
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            $searchResultsContainer.hide();
                        }
                        MenuController.resetMenuDisplay();
                    } else {
                        // 显示搜索结果容器
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            $searchResultsContainer.show();
                        }
                        // 执行搜索
                        searchMenus(searchText, $menuItems, $frequentMenusSection, $searchResultsContainer, $searchResultsText);
                    }
                });
                
                // 键盘事件处理
                $searchInput.on('keydown', function(e) {
                    var matchedItems = MenuController.getMatchedMenuItems();
                    var selectedIndex = MenuController.getCurrentSelectedIndex();
                    
                    if (e.key === 'Escape') {
                        MenuController.setCurrentSelectedIndex(-1);
                        MenuController.setMatchedMenuItems([]);
                        MenuController.collapseSearch();
                    } else if (e.key === 'ArrowDown') {
                        // 向下箭头：选择下一个结果
                        e.preventDefault();
                        if (matchedItems.length > 0) {
                            var newIndex = (selectedIndex + 1) % matchedItems.length;
                            MenuController.setCurrentSelectedIndex(newIndex);
                            highlightSelectedItem();
                        }
                    } else if (e.key === 'ArrowUp') {
                        // 向上箭头：选择上一个结果
                        e.preventDefault();
                        if (matchedItems.length > 0) {
                            var newIndex = selectedIndex <= 0 ? matchedItems.length - 1 : selectedIndex - 1;
                            MenuController.setCurrentSelectedIndex(newIndex);
                            highlightSelectedItem();
                        }
                    } else if (e.key === 'Enter') {
                        // Enter键：打开选中的菜单项
                        if (selectedIndex >= 0 && selectedIndex < matchedItems.length) {
                            e.preventDefault();
                            var $selectedItem = matchedItems[selectedIndex];
                            var $link = $selectedItem.find('a').first();
                            if ($link.length && $link.attr('href') && $link.attr('href') !== 'javascript: void(0);') {
                                window.location.href = $link.attr('href');
                            } else {
                                // 如果是可展开的菜单，展开它
                                $link.trigger('click');
                            }
                        }
                    }
                });
                
                // 高亮选中的菜单项并滚动到可视区域
                function highlightSelectedItem() {
                    var $menuItems = MenuController.getMenuItems();
                    var matchedItems = MenuController.getMatchedMenuItems();
                    var selectedIndex = MenuController.getCurrentSelectedIndex();
                    
                    if (!$menuItems || !$menuItems.length) {
                        return;
                    }
                    
                    // 移除所有高亮
                    $menuItems.removeClass('menu-item-keyboard-selected');
                    
                    if (selectedIndex >= 0 && selectedIndex < matchedItems.length) {
                        var $selected = matchedItems[selectedIndex];
                        $selected.addClass('menu-item-keyboard-selected');
                        
                        // 平滑滚动到选中项
                        var offsetTop = $selected.offset().top;
                        var sidebarTop = $('#sidebar-menu').offset().top;
                        var sidebarHeight = $('#sidebar-menu').height();
                        
                        if (offsetTop < sidebarTop || offsetTop > sidebarTop + sidebarHeight) {
                            $('html, body').animate({
                                scrollTop: $selected.offset().top - 200
                            }, 200);
                        }
                    }
                }
            }
            
            // 搜索菜单函数
            function searchMenus(searchText, $menuItems, $frequentMenusSection, $searchResultsContainer, $searchResultsText) {
                var matchCount = 0;
                var matchedItems = [];
                var firstMatchedItem = null;
                
                // 隐藏常用菜单区域
                if ($frequentMenusSection.length) {
                    $frequentMenusSection.hide();
                }
                
                // 确保搜索结果容器显示
                if ($searchResultsContainer.length) {
                    $searchResultsContainer.show();
                }
                
                // 移除所有高亮
                $menuItems.removeClass('menu-item-keyboard-selected');
                
                // 只搜索主菜单，不搜索常用菜单
                $menuItems.each(function() {
                    var $item = $(this);
                    var menuText = '';
                    var isMenuTitle = $item.hasClass('menu-title');
                    
                    // 跳过menu-title，只搜索实际菜单项
                    if (isMenuTitle) {
                        // menu-title需要检查其后面的子菜单是否有匹配
                        var $nextSiblings = $item.nextUntil('.menu-title');
                        var hasSiblingMatch = false;
                        
                        $nextSiblings.each(function() {
                            var siblingText = $(this).find('a span').text().toLowerCase();
                            if (siblingText.indexOf(searchText) !== -1) {
                                hasSiblingMatch = true;
                                return false; // break
                            }
                            
                            // 检查子菜单
                            $(this).find('li a span').each(function() {
                                if ($(this).text().toLowerCase().indexOf(searchText) !== -1) {
                                    hasSiblingMatch = true;
                                    return false; // break
                                }
                            });
                        });
                        
                        if (hasSiblingMatch) {
                            $item.removeClass('menu-item-hidden');
                        } else {
                            $item.addClass('menu-item-hidden');
                        }
                        return; // 继续下一个
                    }
                    
                    // 获取菜单文本
                    menuText = $item.find('a span').text().toLowerCase();
                    
                    // 检查是否匹配
                    if (menuText && menuText.indexOf(searchText) !== -1) {
                        $item.removeClass('menu-item-hidden').addClass('menu-item-matched');
                        // 展开父级菜单
                        expandParentMenu($item);
                        matchCount++;
                        matchedItems.push($item);
                        if (!firstMatchedItem) {
                            firstMatchedItem = $item;
                        }
                    } else {
                        // 检查子菜单
                        var $children = $item.find('> ul.sub-acl > li');
                        var hasChildMatch = false;
                        
                        $children.each(function() {
                            var $child = $(this);
                            var childText = $child.find('a span').text().toLowerCase();
                            
                            if (childText && childText.indexOf(searchText) !== -1) {
                                hasChildMatch = true;
                                matchCount++;
                                $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                                expandParentMenu($child);
                                matchedItems.push($child);
                                if (!firstMatchedItem) {
                                    firstMatchedItem = $child;
                                }
                                // 展开子菜单的父级
                                $item.removeClass('menu-item-hidden');
                                var $subMenu = $item.find('> ul.sub-acl');
                                if ($subMenu.length) {
                                    $subMenu.attr('aria-expanded', 'true').addClass('mm-show');
                                    $item.find('> a').parent('li').addClass('mm-active');
                                }
                            } else {
                                $child.removeClass('menu-item-matched');
                                // 递归检查更深层的子菜单
                                $child.find('li a span').each(function() {
                                    if ($(this).text().toLowerCase().indexOf(searchText) !== -1) {
                                        hasChildMatch = true;
                                        matchCount++;
                                        $child.removeClass('menu-item-hidden').addClass('menu-item-matched');
                                        expandParentMenu($child);
                                        matchedItems.push($child);
                                        if (!firstMatchedItem) {
                                            firstMatchedItem = $child;
                                        }
                                        var $parentSubMenu = $item.find('> ul.sub-acl');
                                        if ($parentSubMenu.length) {
                                            $parentSubMenu.attr('aria-expanded', 'true').addClass('mm-show');
                                            $item.find('> a').parent('li').addClass('mm-active');
                                        }
                                        return false; // break
                                    }
                                });
                            }
                        });
                        
                        if (hasChildMatch) {
                            $item.removeClass('menu-item-hidden');
                        } else {
                            $item.removeClass('menu-item-matched').addClass('menu-item-hidden');
                        }
                    }
                });
                
                // 更新匹配的菜单项列表（供键盘导航使用）
                MenuController.setMatchedMenuItems(matchedItems);
                
                // 更新搜索结果文本
                var $searchResultsText = $('#search-results-text');
                if ($searchResultsText.length) {
                    if (matchCount > 0) {
                        $searchResultsText.text('搜索结果 (' + matchCount + ')');
                        // 平滑滚动到第一个匹配项
                        if (firstMatchedItem && firstMatchedItem.length) {
                            setTimeout(function() {
                                var $sidebar = $('.vertical-menu [data-simplebar]');
                                if ($sidebar.length && $sidebar[0].simpleBar) {
                                    // 使用simplebar的滚动方法
                                    var scrollTop = firstMatchedItem.offset().top - $sidebar.offset().top + $sidebar[0].simpleBar.getScrollElement().scrollTop - 150;
                                    $sidebar[0].simpleBar.getScrollElement().scrollTo({
                                        top: scrollTop,
                                        behavior: 'smooth'
                                    });
                                } else {
                                    // 降级方案：使用jQuery动画
                                    var scrollTop = firstMatchedItem.offset().top - $('#sidebar-menu').offset().top + $('#sidebar-menu').scrollTop() - 100;
                                    $('.vertical-menu').animate({
                                        scrollTop: scrollTop
                                    }, 300);
                                }
                            }, 150);
                        }
                    } else {
                        $searchResultsText.text('未找到匹配的菜单');
                    }
                }
            }
            
            // 展开父级菜单
            function expandParentMenu($item) {
                var $parent = $item.parent('ul');
                if ($parent.length > 0 && $parent.hasClass('sub-acl')) {
                    $parent.attr('aria-expanded', 'true').addClass('mm-show');
                    var $parentLi = $parent.prev('a').parent('li');
                    $parentLi.addClass('mm-active');
                    expandParentMenu($parentLi);
                }
            }
            
            // 初始化
            $(document).ready(function() {
                initMenuTabs();
                initMenuSearch();
                initStickyMenu();
            });
            
            // Tab切换功能
            function initMenuTabs() {
                var $frequentTab = $('#frequent-menu-tab');
                var $searchTab = $('#search-menu-tab');
                var $frequentPane = $('#frequent-tab-pane');
                
                // 默认显示搜索Tab（已通过HTML设置active类）
                // 默认展开搜索框
                setTimeout(function() {
                    MenuController.expandSearch();
                }, 300);
                
                // 搜索Tab点击
                $searchTab.on('click.menuTabs', function() {
                    if (!$(this).hasClass('active')) {
                        // 切换Tab
                        $searchTab.addClass('active');
                        $frequentTab.removeClass('active');
                        
                        // 展开搜索Tab
                        MenuController.expandSearch();
                        // 隐藏常用菜单
                        if ($frequentPane && $frequentPane.length) {
                            $frequentPane.hide();
                        }
                    }
                });
                
                // 常用菜单Tab点击
                $frequentTab.on('click.menuTabs', function() {
                    if (!$(this).hasClass('active')) {
                        // 切换Tab
                        $frequentTab.addClass('active');
                        $searchTab.removeClass('active');
                        $frequentPane.show();
                        
                        // 收起搜索Tab
                        MenuController.collapseSearch();
                        // 隐藏搜索结果
                        var $searchResultsContainer = MenuController.getSearchResultsContainer();
                        if ($searchResultsContainer && $searchResultsContainer.length) {
                            $searchResultsContainer.hide();
                        }
                    }
                });
            }
            
            // 悬浮菜单功能
            function initStickyMenu() {
                var $simplebarContainer = $('.vertical-menu [data-simplebar]');
                var $sidebarMenu = $('#sidebar-menu');
                var $stickySection = $('#sticky-menu-section');
                var hoverTimer = null;
                var isHovering = false;
                
                // 鼠标进入悬浮区域
                $stickySection.on('mouseenter.menuSticky', function() {
                    isHovering = true;
                    // 清除可能存在的收起定时器
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                    
                    // 展开内容区域（如果已收起）
                    var $tabsContent = $('.menu-tabs-content');
                    if ($tabsContent && $tabsContent.length && $tabsContent.hasClass('collapsed')) {
                        $tabsContent.removeClass('collapsed');
                    }
                    
                    // 如果搜索Tab已激活且已展开，重新触发展开动画
                    var $searchTabContainer = $('#search-tab-container');
                    var $searchTab = $('#search-menu-tab');
                    if ($searchTab && $searchTab.length && $searchTab.hasClass('active')) {
                        if ($searchTabContainer && $searchTabContainer.length && $searchTabContainer.hasClass('expanded')) {
                            // 重新触发展开动画：先移除expanded类，然后重新添加
                            $searchTabContainer.removeClass('expanded');
                            // 使用requestAnimationFrame确保DOM更新后再添加类
                            requestAnimationFrame(function() {
                                setTimeout(function() {
                                    $searchTabContainer.addClass('expanded');
                                }, 10);
                            });
                        } else {
                            // 如果未展开，直接展开
                            MenuController.expandSearch();
                        }
                    }
                });
                
                // 鼠标离开悬浮区域
                $stickySection.on('mouseleave.menuSticky', function(e) {
                    // 检查鼠标是否移到了子元素上（搜索结果区域等）
                    var relatedTarget = e.relatedTarget || e.toElement;
                    if (relatedTarget && $stickySection[0].contains(relatedTarget)) {
                        return; // 如果还在sticky区域内，不执行收起
                    }
                    
                    isHovering = false;
                    // 延迟收起，避免鼠标快速移过时误收起
                    hoverTimer = setTimeout(function() {
                        if (!isHovering) {
                            // 收起搜索框（如果展开）
                            var $searchTabContainer = $('#search-tab-container');
                            var $searchInput = MenuController.getSearchInput();
                            if ($searchTabContainer && $searchTabContainer.length && $searchTabContainer.hasClass('expanded')) {
                                // 如果输入框为空，则收起
                                if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
                                    MenuController.collapseSearch();
                                }
                            }
                            
                            // 收起tab内容区域（如果已展开）
                            var $tabsContent = $('.menu-tabs-content');
                            if ($tabsContent && $tabsContent.length && !$tabsContent.hasClass('collapsed')) {
                                $tabsContent.addClass('collapsed');
                            }
                            
                            // 隐藏搜索结果容器
                            var $searchResultsContainer = MenuController.getSearchResultsContainer();
                            if ($searchResultsContainer && $searchResultsContainer.length && $searchResultsContainer.is(':visible')) {
                                // 只有在输入框为空时才隐藏搜索结果
                                if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
                                    $searchResultsContainer.hide();
                                }
                            }
                        }
                    }, 100); // 100ms延迟，快速响应
                });
                
                // 点击Tab栏时展开内容（如果已收起）
                $('.menu-tab-btn').on('click.menuSticky', function() {
                    isHovering = true;
                    var $tabsContent = $('.menu-tabs-content');
                    if ($tabsContent && $tabsContent.length && $tabsContent.hasClass('collapsed')) {
                        $tabsContent.removeClass('collapsed');
                    }
                    // 清除定时器，避免干扰手动展开
                    MenuController.clearScrollTimer();
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                });
                
                // 监听simplebar滚动
                if ($simplebarContainer.length && $simplebarContainer[0].simpleBar) {
                    var scrollElement = $simplebarContainer[0].simpleBar.getScrollElement();
                    $(scrollElement).on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                } else if ($sidebarMenu.length) {
                    // 降级方案：监听侧边栏滚动
                    $sidebarMenu.on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                } else {
                    // 监听窗口滚动（备用）
                    $(window).on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                }
                
                // 初始化检查
                setTimeout(function() {
                    MenuController.checkSticky();
                }, 100);
            }
            
            
        })(jQuery);
    </script>
<?php
endif; ?>
