                                });
                                // 显示搜索Tab内容
                                $('#search-tab-pane').show();
                                $('#search-menu-tab').addClass('active');
                                $('#frequent-menu-tab').removeClass('active');
                                // 展开搜索输入框
                                var $searchTabContainer = $('#search-tab-container');
                                if ($searchTabContainer && $searchTabContainer.length && !$searchTabContainer.hasClass('expanded')) {
                                    $searchTabContainer.addClass('expanded');
                                }
                            }
                        }
                    }
                    // 确保展开区域保持显示
                    $(this).addClass('expanded-right').show();
                });
                
                // 检查鼠标是否在相关区域内
                function isMouseInRelatedArea(target) {
                    if (!target) return false;
                    
                    var $stickySection = $('#sticky-menu-section');
                    var $expandedContent = $('.menu-tabs-content.expanded-right');
                    
                    // 检查是否在sticky区域内
                    if ($stickySection.length && $stickySection[0].contains(target)) {
                        return true;
                    }
                    
                    // 检查是否在展开的内容区域内
                    if ($expandedContent.length && $expandedContent[0].contains(target)) {
                        return true;
                    }
                    
                    return false;
                }
                
                // Tab按钮离开事件 - 统一处理（折叠状态下不再需要，因为使用菜单形式）
                // 注释掉，因为折叠状态下使用的是菜单形式的搜索和常用菜单，不需要hover展开
                
                // 鼠标离开悬浮区域
                $stickySection.on('mouseleave.menuSticky', function(e) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    var relatedTarget = e.relatedTarget || e.toElement;
                    
                    // 如果正在切换tab，不执行收起
                    if (isHovering && $(relatedTarget).closest('.menu-tab-btn').length) {
                        return;
                    }
                    
                    // 检查鼠标是否移到了展开的内容区域、tab按钮或搜索菜单区域
                    if (isMouseInRelatedArea(relatedTarget) || 
                        $(relatedTarget).closest('.menu-tab-btn').length ||
                        $(relatedTarget).closest('.menu-tabs-nav').length ||
                        $(relatedTarget).closest('.menu-search-content').length ||
                        $(relatedTarget).closest('.menu-search-submenu').length ||
                        $(relatedTarget).closest('.menu-search-item').length) {
                        return; // 如果还在相关区域内，不执行收起
                    }
                    
                    // 正常状态下，收起内容
                    if (!isCollapsed) {
                        // 检查鼠标是否移到了搜索输入框或常用内容区域
                        if ($(relatedTarget).closest('#search-tab-container, #frequent-tab-pane, .menu-tabs-content').length) {
                            return; // 如果移到了这些区域，不收起
                        }
                        
                        var $searchTabContainer = $('#search-tab-container');
                        var $searchInput = $('#menu-search-input');
                        var $frequentPane = $('#frequent-tab-pane');
                        
                        // 延迟收起，给用户时间移到相关内容区域
                        setTimeout(function() {
                            var currentTarget = document.elementFromPoint(e.clientX || 0, e.clientY || 0);
                            if (!currentTarget) {
                                // 如果输入框为空，则收起搜索框
                                if ($searchTabContainer && $searchTabContainer.hasClass('expanded')) {
                                    if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
                                        $searchTabContainer.removeClass('expanded');
                                        if ($searchInput && $searchInput.length) {
                                            $searchInput.blur();
                                        }
                                    }
                                }
                                // 隐藏常用菜单
                                if ($frequentPane && $frequentPane.length) {
                                    $frequentPane.hide();
                                }
                                return;
                            }
                            // 再次检查是否在相关内容区域
                            if (!$(currentTarget).closest('#search-tab-container, #frequent-tab-pane, .menu-tabs-content').length) {
                                // 如果输入框为空，则收起搜索框
                                if ($searchTabContainer && $searchTabContainer.hasClass('expanded')) {
                                    if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
                                        $searchTabContainer.removeClass('expanded');
                                        if ($searchInput && $searchInput.length) {
                                            $searchInput.blur();
                                        }
                                    }
                                }
                                // 隐藏常用菜单
                                if ($frequentPane && $frequentPane.length) {
                                    $frequentPane.hide();
                                }
                            }
                        }, 200);
                    }
                    
                    // 延迟收起（折叠状态下）
                    if (isCollapsed) {
                        hoverTimer = setTimeout(function() {
                            var currentTarget = document.elementFromPoint(e.clientX || 0, e.clientY || 0);
                            if (!currentTarget) {
                                isHovering = false;
                                // 停止搜索保护机制
                                if (typeof stopSearchMenuProtection === 'function') {
                                    stopSearchMenuProtection();
                                }
                                collapseContent(e);
                                return;
                            }
                            // 检查鼠标是否还在相关区域内
                            if (!isMouseInRelatedArea(currentTarget) && 
                                !$(currentTarget).closest('.menu-tab-btn').length &&
                                !$(currentTarget).closest('.menu-tabs-nav').length &&
                                !$(currentTarget).closest('.menu-search-content').length &&
                                !$(currentTarget).closest('.menu-search-submenu').length &&
                                !$(currentTarget).closest('.menu-search-item').length) {
                                isHovering = false;
                                // 停止搜索保护机制
                                if (typeof stopSearchMenuProtection === 'function') {
                                    stopSearchMenuProtection();
                                }
                                collapseContent(e);
                            }
                        }, 100);
                    }
                });
                
                // 鼠标离开展开的内容区域
                $(document).on('mouseleave.menuSticky', '.menu-tabs-content.expanded-right', function(e) {
