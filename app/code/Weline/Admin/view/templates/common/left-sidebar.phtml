                        if (!$(relatedTarget).closest('#search-tab-container, .menu-tabs-content, #search-results-container').length) {
                            // 延迟执行，避免鼠标快速移动时误触发
                            if (searchHoverTimer) {
                                clearTimeout(searchHoverTimer);
