                    // 清除可能存在的收起定时器
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                    
                    // 确保搜索面板保持显示
                    var isCollapsed = $body.hasClass('vertical-collpsed');
