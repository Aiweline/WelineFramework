            // 悬浮菜单功能
            function initStickyMenu() {
                var $simplebarContainer = $('.vertical-menu [data-simplebar]');
                var $sidebarMenu = $('#sidebar-menu');
                var $stickySection = $('#sticky-menu-section');
                var $body = $('body');
                var hoverTimer = null;
                var isHovering = false;
                
                // 缓存DOM元素引用
                var $searchTab = $('#search-menu-tab');
                var $frequentTab = $('#frequent-menu-tab');
                var $frequentPane = $('#frequent-tab-pane');
                var $searchTabContainer = $('#search-tab-container');
                
                // 在折叠状态下向右展开内容的辅助函数
                function expandContentRight($tabsContent, activeTab) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    if (!isCollapsed) {
                        if ($tabsContent.hasClass('collapsed')) {
                            $tabsContent.removeClass('collapsed');
                        }
                        return;
                    }
                    setTabsContentStyle($tabsContent);
                    switchTab(activeTab, $searchTab, $frequentTab, $frequentPane, $searchTabContainer);
                    
                    // 如果有搜索内容，确保搜索结果容器显示
                    if (activeTab === 'search') {
                        var $searchInputMenu = $('#menu-search-input-menu');
                        if ($searchInputMenu && $searchInputMenu.length && $searchInputMenu.val().trim() !== '') {
                            var $searchResultsContainer = $('#search-results-container');
                            if ($searchResultsContainer && $searchResultsContainer.length) {
                                $searchResultsContainer.show();
                            }
                        }
                    }
                }
                
                // Tab按钮hover事件处理函数
                function handleTabHover(tabType, $hoveredElement) {
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    if (!isCollapsed) return;
                    
                    isHovering = true;
                    
                    // 清除可能存在的收起定时器
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                    
                    // 向右展开内容
                    var $tabsContent = $('.menu-tabs-content');
                    if (!$tabsContent || !$tabsContent.length) {
                        console.warn('MenuController: tabs content not found');
                        return;
                    }
                    
                    // 获取被hover的tab按钮元素，用于计算位置
                    var $targetTab = null;
                    if (tabType === 'search') {
                        $targetTab = $hoveredElement ? $hoveredElement.closest('#search-menu-tab, #search-tab-container') : $('#search-menu-tab');
                    } else if (tabType === 'frequent') {
                        $targetTab = $hoveredElement ? $hoveredElement.closest('#frequent-menu-tab') : $('#frequent-menu-tab');
                    }
                    
                    // 计算展开位置：基于tab按钮的位置
                    var expandedTop = '0px';
                    
                    // 获取侧边栏滚动位置（如果有simplebar）
                    var sidebarScrollTop = 0;
                    var $simplebarContainer = $('.vertical-menu [data-simplebar]');
                    if ($simplebarContainer.length && $simplebarContainer[0].simpleBar) {
                        sidebarScrollTop = $simplebarContainer[0].simpleBar.getScrollElement().scrollTop;
                    } else {
                        sidebarScrollTop = $(window).scrollTop();
                    }
                    
                    if ($targetTab && $targetTab.length) {
                        var offset = $targetTab.offset();
                        if (offset) {
                            // 使用tab按钮的顶部位置，考虑窗口和侧边栏的滚动
                            var windowScrollTop = $(window).scrollTop();
                            expandedTop = (offset.top - windowScrollTop) + 'px';
                        }
                    } else {
                        // 降级方案：使用sticky section的位置
                        var $stickySection = $('#sticky-menu-section');
                        if ($stickySection && $stickySection.length) {
                            var offset = $stickySection.offset();
                            var windowScrollTop = $(window).scrollTop();
                            expandedTop = (offset ? offset.top - windowScrollTop : 0) + 'px';
                        }
                    }
                    
                    $tabsContent
                        .addClass('expanded-right')
                        .css({
                            'display': 'block',
                            'position': 'fixed',
                            'left': '70px',
                            'top': expandedTop,
                            'min-width': '280px',
                            'max-width': '320px',
