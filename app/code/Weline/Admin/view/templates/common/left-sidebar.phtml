                        } else {
                            // 正常状态下，添加collapsed类
                            if (!$tabsContent.hasClass('collapsed')) {
                                $tabsContent.addClass('collapsed');
                            }
                        }
                    }
                    
                    // 隐藏搜索结果容器
                    var $searchResultsContainer = MenuController.getSearchResultsContainer();
                    if ($searchResultsContainer && $searchResultsContainer.length && $searchResultsContainer.is(':visible')) {
                        // 只有在输入框为空时才隐藏搜索结果
                        if (!$searchInput || !$searchInput.length || $searchInput.val().trim() === '') {
                            $searchResultsContainer.hide();
                        }
                    }
                }
                
                // 点击Tab栏时展开内容（如果已收起）
                $('.menu-tab-btn').on('click.menuSticky', function() {
                    isHovering = true;
                    var isCollapsed = $body.hasClass('vertical-collpsed');
                    var $tabsContent = $('.menu-tabs-content');
                    
                    if ($tabsContent && $tabsContent.length) {
                        if (isCollapsed) {
                            // 折叠状态下，向右展开
                            var expandedTop = calculateExpandedTop();
                            $tabsContent
                                .addClass('expanded-right')
                                .show()
                                .css({
                                    'display': 'block',
                                    'position': 'fixed',
                                    'left': '70px',
                                    'top': expandedTop,
                                    'min-width': '280px',
                                    'max-width': '320px',
                                    'z-index': '1050',
                                    'background-color': $body.hasClass('data-sidebar') && $body.attr('data-sidebar') === 'dark' ? '#1b2c3f' : '#ffffff'
                                });
                        } else {
                            // 正常状态下，移除collapsed类
                            if ($tabsContent.hasClass('collapsed')) {
                                $tabsContent.removeClass('collapsed');
                            }
                        }
                    }
                    
                    // 清除定时器，避免干扰手动展开
                    MenuController.clearScrollTimer();
                    if (hoverTimer) {
                        clearTimeout(hoverTimer);
                        hoverTimer = null;
                    }
                });
                
                // 监听simplebar滚动
                if ($simplebarContainer.length && $simplebarContainer[0].simpleBar) {
                    var scrollElement = $simplebarContainer[0].simpleBar.getScrollElement();
                    $(scrollElement).on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                } else if ($sidebarMenu.length) {
                    // 降级方案：监听侧边栏滚动
                    $sidebarMenu.on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                } else {
                    // 监听窗口滚动（备用）
                    $(window).on('scroll.menuSticky', function() {
                        MenuController.checkSticky();
                    });
                }
                
                // 初始化检查
                setTimeout(function() {
                    MenuController.checkSticky();
                }, 100);
            }
            
            // 菜单定位：仅负责 #side-menu 内部激活项在侧栏滚动容器中的可见/居中，不处理 window 或其他区域
            window.scrollToActiveMenu = function scrollToActiveMenu(retryCount) {
                retryCount = retryCount || 0;
                var $sideMenu = $('#side-menu');
                if (!$sideMenu.length) return;

                // 只在 #side-menu 内查找激活项
                var $activeLink = $('#side-menu .mm-active .active, #side-menu .mm-active > a.active, #side-menu li.mm-active > a.active');
                var $activeMenu = $activeLink.length > 0 ? $activeLink.closest('li') : $('#side-menu li.mm-active').first();
                if (!$activeMenu || !$activeMenu.length) return;

                // 滚动容器：仅使用包裹 #side-menu 的 simplebar（不降级到 window 或 #sidebar-menu）
                var $simplebarContainer = $('#side-menu').closest('.vertical-menu').find('[data-simplebar]');
                var scrollElement = null;
                if ($simplebarContainer.length) {
                    if ($simplebarContainer[0].simpleBar) {
                        scrollElement = $simplebarContainer[0].simpleBar.getScrollElement();
                    } else {
                        var $wrapper = $simplebarContainer.find('.simplebar-content-wrapper');
                        if ($wrapper.length) scrollElement = $wrapper[0];
                    }
                }
                if (!scrollElement) {
                    if (retryCount < 1) setTimeout(function() { window.scrollToActiveMenu(1); }, 400);
                    return;
                }

                setTimeout(function() {
                    try {
                        $activeMenu.parents('li').each(function() {
                            var $parent = $(this);
                            var $sub = $parent.find('> .sub-menu').first();
                            if ($sub.length && $sub.attr('aria-expanded') === 'false') {
                                $parent.find('> a.has-arrow').first().trigger('click');
                            }
                        });
                        setTimeout(function() {
                            try {
                                var el = $activeMenu[0];
                                if (!el) return;
                                var scrollTop = scrollElement.scrollTop;
                                var containerHeight = scrollElement.clientHeight;
                                var menuHeight = $activeMenu.outerHeight() || 40;
                                var menuRect = el.getBoundingClientRect();
                                var containerRect = scrollElement.getBoundingClientRect();
                                var offsetFromVisibleTop = menuRect.top - containerRect.top;
                                var targetScrollTop = scrollTop + offsetFromVisibleTop - (containerHeight / 2) + (menuHeight / 2);
                                var maxScrollTop = scrollElement.scrollHeight - scrollElement.clientHeight;
                                targetScrollTop = Math.max(0, Math.min(targetScrollTop, maxScrollTop));
                                $(scrollElement).animate({ scrollTop: targetScrollTop }, 400);
                            } catch (e) {
                                console.warn('菜单定位滚动计算出错:', e);
                            }
                        }, 300);
                    } catch (e) {
                        console.warn('菜单定位展开父级出错:', e);
                    }
                }, 200);
            };
            
            // 页面加载完成后执行滚动
            $(document).ready(function() {
                // 确保函数已定义后再调用
                if (typeof window.scrollToActiveMenu === 'function') {
                    window.scrollToActiveMenu();
                } else {
                    // 如果函数还未定义，延迟执行
                    setTimeout(function() {
                        if (typeof window.scrollToActiveMenu === 'function') {
                            window.scrollToActiveMenu();
                        }
                    }, 500);
                }
                
                // 监听菜单激活状态变化，当菜单锁定功能激活菜单后自动滚动
                if (typeof MutationObserver !== 'undefined') {
                    var scrollTimer = null;
                    var lastActiveMenuId = null;
                    
                    var menuObserver = new MutationObserver(function(mutations) {
                        var shouldScroll = false;
                        var currentActiveMenuId = null;
                        
                        mutations.forEach(function(mutation) {
                            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                                var target = mutation.target;
                                var oldValue = mutation.oldValue || '';
                                var newValue = target.className || '';
                                
                                // 检查是否是菜单项添加了 mm-active 类（之前没有，现在有了）
                                var hadMmActive = oldValue.indexOf('mm-active') !== -1;
                                var hasMmActive = newValue.indexOf('mm-active') !== -1;
                                
                                if (!hadMmActive && hasMmActive && $(target).is('li')) {
                                    var $menuItem = $(target);
                                    if ($menuItem.closest('#side-menu').length > 0) {
                                        var $link = $menuItem.find('> a.active, .active').first();
                                        currentActiveMenuId = ($link.length ? $link.attr('href') : $menuItem.find('> a').first().attr('href')) || $menuItem.text();
                                        if (currentActiveMenuId && currentActiveMenuId !== lastActiveMenuId) shouldScroll = true;
                                    }
                                }
                            }
                        });
                        
                        if (shouldScroll) {
                            lastActiveMenuId = currentActiveMenuId;
                            
                            // 清除之前的定时器，实现防抖
                            if (scrollTimer) {
                                clearTimeout(scrollTimer);
                            }
                            
                            // 延迟执行，确保菜单状态已完全更新
                            scrollTimer = setTimeout(function() {
                                if (typeof window.scrollToActiveMenu === 'function') {
                                    window.scrollToActiveMenu();
                                }
                            }, 300);
                        }
                    });
                    
                    // 只观察 #side-menu 内 class 变化
                    var $sideMenuEl = $('#side-menu')[0];
                    if ($sideMenuEl) {
                        menuObserver.observe($sideMenuEl, {
                            attributes: true,
                            attributeFilter: ['class'],
                            subtree: true,
                            attributeOldValue: true
                        });
                    }
                }
            });
            
            // 如果使用 jQuery 的 ready 事件，也监听 DOMContentLoaded
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', scrollToActiveMenu);
            } else {
                // DOM 已经加载完成，直接执行
                setTimeout(scrollToActiveMenu, 300);
            }
            
            
        })(jQuery);
    </script>
<?php
endif; ?>