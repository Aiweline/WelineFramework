<?php
/**
 * 供应商脚本模板
 * 用于在页面底部加载第三方供应商的 JavaScript 库
 * 
 * @var \Weline\Framework\View\Template $this
 */
?>

<!-- 供应商脚本区域 -->
<!-- 可以在这里加载第三方 JavaScript 库，如 DataTables、Chart.js、Select2 等 -->

<!-- 示例：如果需要加载特定的供应商脚本，可以在这里添加 -->
<?php
// 允许通过数据传递的方式动态加载供应商脚本
$vendorScripts = $this->getData('vendor_scripts');
if ($vendorScripts && is_array($vendorScripts)) {
    foreach ($vendorScripts as $script) {
        if (is_string($script)) {
            echo '<script src="' . htmlspecialchars($script, ENT_QUOTES, 'UTF-8') . '"></script>' . PHP_EOL;
        } elseif (is_array($script) && isset($script['src'])) {
            $attributes = '';
            if (isset($script['attributes']) && is_array($script['attributes'])) {
                foreach ($script['attributes'] as $attr => $value) {
                    $attributes .= ' ' . htmlspecialchars($attr, ENT_QUOTES, 'UTF-8') . '="' . htmlspecialchars($value, ENT_QUOTES, 'UTF-8') . '"';
                }
            }
            echo '<script src="' . htmlspecialchars($script['src'], ENT_QUOTES, 'UTF-8') . '"' . $attributes . '></script>' . PHP_EOL;
        }
    }
}
?>

<!-- 页面特定的初始化脚本 -->
<?php
// 允许页面传递自定义初始化脚本
$pageInitScript = $this->getData('page_init_script');
if ($pageInitScript) {
    echo '<script>' . PHP_EOL;
    echo $pageInitScript;
    echo PHP_EOL . '</script>' . PHP_EOL;
}
?>

