$previewContextService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Service\PreviewContextService::class);
if ($previewContextService->shouldUseStoredContext()) {
    $previewContext = $previewContextService->getCurrentContext();
    $previewThemeId = $previewContextService->getThemeIdForArea('backend', $previewContext, false);
    if ($previewThemeId > 0) {
        $themeContext = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Service\ThemeContextService::class);
        $theme = $themeContext->resolveTheme('backend');
        if ($theme && $theme->getId()) {
        // 加载色系CSS文件
        $themeMode = \Weline\Theme\Helper\LayoutScanner::getColorConfig($theme, 'backend');
        if ($themeMode && $themeMode !== 'light'): ?>
<theme:css>Weline_Theme::theme/backend/colors/_<?= $themeMode ?>.css</theme:css>
<?php 
        endif;
        
        // 加载变量CSS文件
        $variables = \Weline\Theme\Helper\LayoutScanner::getVariablesConfig($theme, 'backend');
        foreach ($variables as $variable) {
            if ($variable): ?>
                <theme:css>Weline_Theme::theme/backend/variables/_<?= $variable ?>.css</theme:css>
<?php 
            endif;
        }
    }
    }
}
