<!-- Live Preview postMessage listener for Visual Editor -->
<script data-no-extract="true">
(function() {
    'use strict';
    // 监听来自Visual Editor的postMessage (Live Preview支持)
    window.addEventListener('message', function(event) {
        if (event.data && event.data.type === 'WELINE_THEME_UPDATE') {
            var cssVars = event.data.cssVars || {};
            var root = document.documentElement;
            for (var varName in cssVars) {
                if (cssVars.hasOwnProperty(varName)) {
                    root.style.setProperty(varName, cssVars[varName]);
                }
            }
            console.log('[Theme] Live preview updated:', Object.keys(cssVars).length, 'variables');
        }
    });
})();
</script>
