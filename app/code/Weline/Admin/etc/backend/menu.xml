    <!-- ==================== 菜单与路由分组 ==================== -->
    
    <!-- 菜单管理 - 归入系统管理 > 菜单与路由 -->
    <menu source="Weline_Admin::system_menu_manager" name="system_menu_manager" title="菜单管理" action="admin/system/menus"
         parent="Weline_Backend::menu_route_group" icon="mdi mdi-menu" order="10"/>
    
    <!-- 路由管理 -->
    <menu source="Weline_Admin::system_modules_router" name="system_modules_router" title="路由管理" action="admin/system/modules/router"
