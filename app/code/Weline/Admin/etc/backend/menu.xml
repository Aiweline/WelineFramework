<?xml version="1.0" encoding="UTF-8"?>
<menus xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
       xs:noNamespaceSchemaLocation="urn:weline:module:Weline_Backend::etc/xsd/menu.xsd"
       xs:schemaLocation="urn:weline:module:Weline_Backend::etc/xsd/menu.xsd">
    
    <!-- ==================== 用户与权限分组 ==================== -->
    
    <!-- 用户管理入口 - 直接挂载到 Backend 定义的用户管理菜单下 -->
    <menu source="Weline_Admin::system_user_listing" name="system_user_listing" title="用户列表" action="admin/backend/user/listing"
         parent="Weline_Backend::user_management" icon="mdi mdi-account-multiple-outline" order="10"/>
    <menu source="Weline_Admin::system_user_assign_role" name="system_user_assign_role" title="角色归配" action="admin/backend/user/assign-role"
