<script>
(function() {
    'use strict';
    var senderIndex = <?= count($senders) ?>;

    function collectSenders() {
        var list = [];
        document.querySelectorAll('.smtp-sender-card').forEach(function(card) {
            var code = (card.querySelector('.smtp-code') && card.querySelector('.smtp-code').value) || '';
            if (!code) return;
            var pwd = card.querySelector('.smtp-password');
            list.push({
                code: code,
                name: (card.querySelector('.smtp-name') && card.querySelector('.smtp-name').value) || code,
                smtp_host: (card.querySelector('.smtp-host') && card.querySelector('.smtp-host').value) || '',
                smtp_port: (card.querySelector('.smtp-port') && card.querySelector('.smtp-port').value) || '465',
                smtp_secure: (card.querySelector('.smtp-secure') && card.querySelector('.smtp-secure').value) || 'ssl',
                smtp_auth: (card.querySelector('.smtp-auth') && card.querySelector('.smtp-auth').value) || '1',
                smtp_username: (card.querySelector('.smtp-username') && card.querySelector('.smtp-username').value) || '',
                smtp_password: (pwd && pwd.value) ? pwd.value : (card.getAttribute('data-pwd') || ''),
                smtp_test_address: ''
            });
        });
        return list;
    }

    function collectContacts() {
        var obj = {};
        document.querySelectorAll('.smtp-sender-card').forEach(function(card) {
            var code = (card.querySelector('.smtp-code') && card.querySelector('.smtp-code').value) || '';
            var contact = (card.querySelector('.smtp-contact') && card.querySelector('.smtp-contact').value) || '';
            if (code) obj[code] = contact;
        });
        return obj;
    }

    function addSenderCard() {
        var tpl = '<div class="card mb-3 smtp-sender-card" data-index="' + senderIndex + '">' +
            '<div class="card-header d-flex align-items-center justify-content-between py-2">' +
            '<h6 class="mb-0">' + '<?= __("新发件人") ?>' + ' <code class="small new-code"></code></h6>' +
            '<div><button type="button" class="btn btn-sm btn-outline-info btn-test-sender" data-code="" title="<?= __("测试") ?>"><i class="mdi mdi-send"></i> <?= __("测试") ?></button> ' +
            '<button type="button" class="btn btn-sm btn-outline-danger btn-remove-sender"><i class="mdi mdi-delete-outline"></i></button></div></div>' +
            '<div class="card-body"><div class="row g-2">' +
            '<div class="col-md-3"><label class="form-label small"><?= __("标识 code") ?> *</label><input type="text" class="form-control form-control-sm smtp-code" name="code" placeholder="notification" required></div>' +
            '<div class="col-md-3"><label class="form-label small"><?= __("显示名称") ?></label><input type="text" class="form-control form-control-sm smtp-name" name="name" placeholder="<?= __("默认发件人") ?>"></div>' +
            '<div class="col-md-3"><label class="form-label small"><?= __("SMTP 主机") ?> *</label><input type="text" class="form-control form-control-sm smtp-host" name="smtp_host" placeholder="smtp.example.com"></div>' +
            '<div class="col-md-2"><label class="form-label small"><?= __("端口") ?></label><input type="number" class="form-control form-control-sm smtp-port" name="smtp_port" value="465"></div>' +
            '<div class="col-md-3"><label class="form-label small"><?= __("加密方式") ?></label><select class="form-select form-select-sm smtp-secure" name="smtp_secure"><option value="ssl"><?= __("SMTPS / SSL") ?></option><option value="tls"><?= __("STARTTLS / TLS") ?></option><option value="none"><?= __("无加密") ?></option></select></div>' +
            '<div class="col-md-3"><label class="form-label small"><?= __("需要认证") ?></label><select class="form-select form-select-sm smtp-auth" name="smtp_auth"><option value="1"><?= __("是") ?></option><option value="0"><?= __("否") ?></option></select></div>' +
            '<div class="col-md-4"><label class="form-label small"><?= __("发件邮箱 / 用户名") ?> *</label><input type="text" class="form-control form-control-sm smtp-username" name="smtp_username" placeholder="noreply@example.com"></div>' +
            '<div class="col-md-4"><label class="form-label small"><?= __("密码") ?></label><input type="password" class="form-control form-control-sm smtp-password" name="smtp_password" placeholder="<?= __("留空则不修改") ?>"></div>' +
            '<div class="col-md-4"><label class="form-label small"><?= __("默认联系人（收件邮箱）") ?></label><input type="email" class="form-control form-control-sm smtp-contact" name="default_to_email" placeholder="<?= __("该发件人默认收件人") ?>"></div>' +
            '</div></div></div>';
        document.getElementById('sendersList').insertAdjacentHTML('beforeend', tpl);
        senderIndex++;
    }

    document.getElementById('btnAddSender').addEventListener('click', addSenderCard);

    document.getElementById('sendersList').addEventListener('click', function(e) {
        var rm = e.target.closest('.btn-remove-sender');
        if (rm) {
            var card = rm.closest('.smtp-sender-card');
            if (!card) {
                return;
            }
            if (document.querySelectorAll('.smtp-sender-card').length > 1) {
                card.remove();
                return;
            }
            var removeMessage = '<?= __("确定删除最后一个发件人吗？删除后仍可重新添加。") ?>';
            if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
                BackendConfirm.show(removeMessage).then(function(confirmed) {
                    if (confirmed) {
                        card.remove();
                    }
                });
            } else if (confirm(removeMessage)) {
                card.remove();
            }
        }
    });

    var testModal = null;
    document.getElementById('sendersList').addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-test-sender');
        if (!btn) return;
        var code = btn.getAttribute('data-code') || (btn.closest('.smtp-sender-card') && btn.closest('.smtp-sender-card').querySelector('.smtp-code') && btn.closest('.smtp-sender-card').querySelector('.smtp-code').value);
        document.getElementById('testSenderCode').value = code || '';
        document.getElementById('testEmailTo').value = '';
        if (typeof bootstrap !== 'undefined') {
            if (!testModal) testModal = new bootstrap.Modal(document.getElementById('testEmailModal'));
            testModal.show();
        }
    });

    document.getElementById('btnDoTest').addEventListener('click', function() {
        var code = document.getElementById('testSenderCode').value;
        var to = document.getElementById('testEmailTo').value.trim();
        if (!to) {
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("请输入收件邮箱") ?>');
            return;
        }
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '<?= $this->getBackendUrl('smtp/backend/config/posttest') ?>';
        var c = document.createElement('input'); c.type = 'hidden'; c.name = 'smtp_test_address'; c.value = to;
        form.appendChild(c);
        if (code) {
            var sc = document.createElement('input'); sc.type = 'hidden'; sc.name = 'sender_code'; sc.value = code;
            form.appendChild(sc);
        }
        document.body.appendChild(form);
        form.submit();
    });

    document.getElementById('smtpSendersForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var senders = collectSenders();
        var contacts = collectContacts();
        if (senders.length === 0) {
            if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("请至少添加一个发件人") ?>');
            return;
        }
        var url = '<?= $this->getBackendUrl('smtp/backend/config/saveSenders') ?>';
        var body = 'senders=' + encodeURIComponent(JSON.stringify(senders)) + '&sender_contacts=' + encodeURIComponent(JSON.stringify(contacts));
        window.Weline.Api.request(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body })
            .then(function(res) {
                var d = (res && res.data) !== undefined ? res.data : res;
                if (d.success && typeof BackendToast !== 'undefined') {
                    BackendToast.success(d.message);
                    setTimeout(function() { window.location.reload(); }, 800);
                } else if (!d.success && typeof BackendToast !== 'undefined') {
                    BackendToast.error(d.message || '<?= __("保存失败") ?>');
                }
            })
            .catch(function() {
                if (typeof BackendToast !== 'undefined') BackendToast.error('<?= __("保存失败") ?>');
            });
    });

    if (document.querySelectorAll('.smtp-sender-card').length === 0) {
        addSenderCard();
    }
})();
</script>
