    <li role="none"><a href="@url{'customer/account/index'}#security" role="menuitem"><?= __('安全设置') ?></a></li>
    <li role="none"><a href="@url{'customer/account/logout'}" role="menuitem" data-account-logout-confirm><?= __('退出登录') ?></a></li>
<?php else: ?>
    <li role="none"><a href="@url{'customer/account/login'}" role="menuitem"><?= __('登录') ?></a></li>
