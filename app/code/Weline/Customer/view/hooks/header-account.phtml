<?php
/**
 * 
 * @hook-priority 50   Hook优先级：50（默认值）
 * @hook-sort-order 0  Hook排序顺序：0（默认值）
 * @hook-solo false    Hook独享：false（不独占）
 */

use Weline\Customer\Session\CustomerSession;
use Weline\Framework\Manager\ObjectManager;

// 获取 CustomerSession
/** @var CustomerSession $session */
$session = ObjectManager::getInstance(CustomerSession::class);

// 获取前端URL（使用模板的 getUrl 方法更安全）
$frontendUrl = $this->getUrl('');

// 检查是否登录
$isLoggedIn = $session->isLogin();
$customer = null;

if ($isLoggedIn) {
    /** @var \Weline\Customer\Model\Customer $customer */
    $customer = $session->getLoginUser();
}
?>

<?php if ($isLoggedIn && $customer): ?>
    <!-- 已登录状态：显示用户信息 -->
    <a href="<?= $frontendUrl ?>customer/account/index" class="action-link" title="<?= __('我的账户') ?>" aria-label="<?= __('我的账户') ?>">
        <span class="action-line-1"><?= __('您好, %{1}', [$customer->getUsername() ?? __('用户')]) ?></span>
        <span class="action-line-2"><?= __('我的账户') ?></span>
    </a>
<?php else: ?>
    <!-- 未登录状态：显示登录链接 -->
    <a href="<?= $frontendUrl ?>customer/account/login" class="action-link" title="<?= __('账户') ?>" aria-label="<?= __('账户及心愿单') ?>">
        <span class="action-line-1"><?= __('您好, 登录') ?></span>
        <span class="action-line-2"><?= __('账户及心愿单') ?></span>
    </a>
<?php endif; ?>

