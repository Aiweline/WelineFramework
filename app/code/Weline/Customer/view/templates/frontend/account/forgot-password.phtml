<script>
(function() {
    'use strict';

    $(document).ready(function() {
        var $form = $('form[class="auth-form__body"]');
        var $submitBtn = $('#submitBtn');

        // 输入框焦点效果
        $('.auth-form__input').on('focus', function() {
            $(this).closest('.auth-form__input-wrapper').addClass('auth-form__input-wrapper--focused');
        }).on('blur', function() {
            $(this).closest('.auth-form__input-wrapper').removeClass('auth-form__input-wrapper--focused');
        });

        document.querySelectorAll('.auth-form__password-toggle[data-password-target]').forEach(function(btn) {
            var targetId = btn.getAttribute('data-password-target');
            var pwdInput = targetId ? document.getElementById(targetId) : null;
            if (!pwdInput) {
                return;
            }
            var showLabel = btn.getAttribute('data-label-show') || '';
            var hideLabel = btn.getAttribute('data-label-hide') || '';
            var iconWrap = btn.querySelector('.auth-form__password-toggle-icon');
            btn.addEventListener('click', function() {
                var wasPassword = pwdInput.type === 'password';
                pwdInput.type = wasPassword ? 'text' : 'password';
                var nowPlain = pwdInput.type === 'text';
                btn.setAttribute('aria-pressed', nowPlain ? 'true' : 'false');
                btn.setAttribute('aria-label', nowPlain ? hideLabel : showLabel);
                if (iconWrap) {
                    var svgShow = iconWrap.querySelector('.auth-form__pwd-svg--show');
                    var svgHide = iconWrap.querySelector('.auth-form__pwd-svg--hide');
                    if (svgShow && svgHide) {
                        if (nowPlain) {
                            svgShow.setAttribute('hidden', 'hidden');
                            svgHide.removeAttribute('hidden');
                        } else {
                            svgShow.removeAttribute('hidden');
                            svgHide.setAttribute('hidden', 'hidden');
                        }
                    }
                }
            });
        });

        $form.on('submit', function(e) {
            e.preventDefault();

            var $password = $('#password');
            var $passwordConfirm = $('#password_confirm');
            var $email = $('#email');

            // 重置模式验证
            if ($password.length && $passwordConfirm.length) {
                if ($password.val().length < 8) {
                    showError('<lang>密码长度至少为8位</lang>');
                    $password.focus();
                    return;
                }
                if ($password.val() !== $passwordConfirm.val()) {
                    showError('<lang>两次输入的密码不一致</lang>');
                    $passwordConfirm.focus();
                    return;
                }
            }

            // 邮箱验证
            if ($email.length && !$email.val().trim()) {
                showError('<lang>请输入邮箱地址</lang>');
                $email.focus();
                return;
            }

            // 禁用按钮，显示加载状态
            $submitBtn.prop('disabled', true).addClass('auth-form__submit--loading');
            var originalText = $submitBtn.html();
            $submitBtn.html('<i class="fas fa-spinner fa-spin me-2"></i><lang>处理中...</lang>');

            // 提交表单
            var formData = new FormData(this);
            fetch($form.attr('action'), {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    showSuccess(data.message || '<lang>操作成功！</lang>');
                    if (data.redirect) {
                        setTimeout(function() {
                            window.location.href = data.redirect;
                        }, 1500);
                    }
                } else {
                    showError(data.message || '<lang>操作失败，请稍后重试</lang>');
                    $submitBtn.prop('disabled', false).removeClass('auth-form__submit--loading');
                    $submitBtn.html(originalText);
                }
            })
            .catch(function() {
                showError('<lang>请求失败，请稍后重试</lang>');
                $submitBtn.prop('disabled', false).removeClass('auth-form__submit--loading');
                $submitBtn.html(originalText);
            });
        });

        function ensureErrorMsg() {
            var $el = $('#errorMessage');
            if ($el.length === 0) {
                $el = $('<div class="auth-form__alert auth-form__alert--danger" id="errorMessage"></div>');
                $form.prepend($el);
            }
            return $el;
        }

        function ensureSuccessMsg() {
            var $el = $('#successMessage');
            if ($el.length === 0) {
                $el = $('<div class="auth-form__alert auth-form__alert--success" id="successMessage"></div>');
                $form.prepend($el);
            }
            return $el;
        }

        function showError(message) {
            var $errorMsg = ensureErrorMsg();
            $errorMsg.html(message);
            $('html, body').animate({ scrollTop: $errorMsg.offset().top - 100 }, 300);
        }

        function showSuccess(message) {
            var $successMsg = ensureSuccessMsg();
            $successMsg.html(message);
        }
    });
})();
</script>
