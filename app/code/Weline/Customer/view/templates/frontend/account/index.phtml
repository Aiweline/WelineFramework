<script>
(function() {
    // 仅绑定带 data-section 的侧栏项（个人资料/安全设置等），避免把「退出登录」等普通链接
    // 也套上 preventDefault + 错误的 href 解析；目标 ID 用 data-section，避免依赖 #fragment。
    // 每次点击重新查询 .account-index__section，避免初始化时 NodeList 为空导致「只展开一块、不隐藏其它块」。
    var navLinks = document.querySelectorAll('.account-sidebar__nav-link[data-section]');

    function showAccountSection(targetId) {
        if (!targetId) {
            return;
        }
        var sections = document.querySelectorAll('.account-index__section');
        var targetSection = document.getElementById(targetId + '-section');
        sections.forEach(function(section) {
            section.classList.add('d-none');
        });
        if (targetSection) {
            targetSection.classList.remove('d-none');
        }
    }

    navLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var targetId = link.getAttribute('data-section');
            if (!targetId) {
                return;
            }

            navLinks.forEach(function(nav) {
                nav.classList.remove('account-sidebar__nav-link--active');
            });
            link.classList.add('account-sidebar__nav-link--active');

            showAccountSection(targetId);
            try {
                history.replaceState(null, '', '#' + targetId);
            } catch (err) {}
        });
    });

    (function syncInitialHash() {
        var raw = window.location.hash ? window.location.hash.replace(/^#/, '') : '';
        if (!raw) {
            return;
        }
        var hasNav = Array.prototype.some.call(navLinks, function(a) {
            return a.getAttribute('data-section') === raw;
        });
        if (!hasNav) {
            return;
        }
        navLinks.forEach(function(nav) {
            nav.classList.toggle('account-sidebar__nav-link--active', nav.getAttribute('data-section') === raw);
        });
        showAccountSection(raw);
    })();

    var previewBtn = document.getElementById('previewAvatarBtn');
    if (previewBtn) {
        previewBtn.addEventListener('click', function() {
            var avatarUrl = document.getElementById('avatar').value;
            var avatarPreview = document.getElementById('avatarPreview');
            var avatarFallback = document.getElementById('avatarFallback');
            if (avatarUrl && avatarPreview) {
                avatarPreview.src = avatarUrl;
                avatarPreview.style.display = 'block';
                if (avatarFallback) {
                    avatarFallback.style.display = 'none';
                }
            }
        });
    }

    var profileForm = document.getElementById('profileForm');
    if (profileForm) {
        profileForm.addEventListener('submit', function(e) {
            e.preventDefault();
            var btn = this.querySelector('button[type="submit"]');
            var originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="ri-loader-4-line"></i> <?= htmlspecialchars((string) __('保存中...'), ENT_QUOTES) ?>';

            var successMsg = document.getElementById('profileSuccessMsg');
            var errorMsg = document.getElementById('profileErrorMsg');
            successMsg.textContent = '';
            errorMsg.textContent = '';

            var formData = new FormData(this);
            fetch('/customer/account/update', {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    errorMsg.textContent = '';
                    successMsg.textContent = data.message || '';
                } else {
                    successMsg.textContent = '';
                    errorMsg.textContent = data.message || '<?= htmlspecialchars((string) __('更新失败，请稍后重试'), ENT_QUOTES) ?>';
                }
            })
            .catch(function() {
                successMsg.textContent = '';
                errorMsg.textContent = '<?= htmlspecialchars((string) __('更新失败，请稍后重试'), ENT_QUOTES) ?>';
            })
            .finally(function() {
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        });
    }

    var securityForm = document.getElementById('securityForm');
    if (securityForm) {
        securityForm.addEventListener('submit', function(e) {
            e.preventDefault();

            var successMsg = document.getElementById('securitySuccessMsg');
            var errorMsg = document.getElementById('securityErrorMsg');
            successMsg.textContent = '';
            errorMsg.textContent = '';

            var oldPassword = document.getElementById('old_password').value;
            var newPassword = document.getElementById('new_password').value;
            var confirmPassword = document.getElementById('confirm_password').value;

            if (!oldPassword || !newPassword || !confirmPassword) {
                errorMsg.textContent = '<?= htmlspecialchars((string) __('请填写所有字段'), ENT_QUOTES) ?>';
                return;
            }

            if (newPassword.length < 6) {
                errorMsg.textContent = '<?= htmlspecialchars((string) __('新密码长度不能少于6位'), ENT_QUOTES) ?>';
                return;
            }

            if (newPassword !== confirmPassword) {
                errorMsg.textContent = '<?= htmlspecialchars((string) __('两次输入的新密码不一致'), ENT_QUOTES) ?>';
                return;
            }

            var btn = this.querySelector('button[type="submit"]');
            var originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="ri-loader-4-line"></i> <?= htmlspecialchars((string) __('修改中...'), ENT_QUOTES) ?>';

            var formData = new FormData(this);
            fetch('/customer/account/update', {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    errorMsg.textContent = '';
                    successMsg.textContent = data.message || '';
                    document.getElementById('old_password').value = '';
                    document.getElementById('new_password').value = '';
                    document.getElementById('confirm_password').value = '';
                } else {
                    successMsg.textContent = '';
                    errorMsg.textContent = data.message || '<?= htmlspecialchars((string) __('修改失败，请稍后重试'), ENT_QUOTES) ?>';
                }
            })
            .catch(function() {
                successMsg.textContent = '';
                errorMsg.textContent = '<?= htmlspecialchars((string) __('修改失败，请稍后重试'), ENT_QUOTES) ?>';
            })
            .finally(function() {
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        });
    }
})();
</script>
