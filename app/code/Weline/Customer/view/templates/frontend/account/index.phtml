<script>
$(document).ready(function() {
    // 标签页切换
    $('.nav-link').on('click', function(e) {
        e.preventDefault();
        
        // 移除所有活动状态
        $('.nav-link').removeClass('active');
        $('.content-section').addClass('d-none');
        
        // 添加当前活动状态
        $(this).addClass('active');
        
        // 显示对应内容
        const targetId = $(this).attr('href').substring(1);
        $('#' + targetId + '-section').removeClass('d-none');
    });
    
    // 头像预览
    $('#previewAvatarBtn').on('click', function() {
        const avatarUrl = $('#avatar').val();
        if (avatarUrl) {
            $('#avatarPreview').attr('src', avatarUrl).show();
            $('#avatarFallback').hide();
        }
    });
    
    // 个人资料表单提交
    $('#profileForm').on('submit', function(e) {
        e.preventDefault();
        
        // 显示加载状态
        const $btn = $(this).find('button[type="submit"]');
        const originalText = $btn.html();
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> ' + __('保存中...'));
        
        // 隐藏之前的消息
        $('#profileSuccessMsg, #profileErrorMsg').addClass('d-none');
        
        // 发送AJAX请求
        $.ajax({
            url: '/customer/account/update',
            method: 'POST',
            data: $(this).serialize(),
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    $('#profileSuccessMsg').text(response.message).removeClass('d-none');
                } else {
                    $('#profileErrorMsg').text(response.message).removeClass('d-none');
                }
            },
            error: function() {
                $('#profileErrorMsg').text('<lang>更新失败，请稍后重试</lang>').removeClass('d-none');
            },
            complete: function() {
                // 恢复按钮状态
                $btn.prop('disabled', false).html(originalText);
            }
        });
    });
    
    // 密码修改表单提交
    $('#securityForm').on('submit', function(e) {
        e.preventDefault();
        
        // 基本验证
        const oldPassword = $('#old_password').val();
        const newPassword = $('#new_password').val();
        const confirmPassword = $('#confirm_password').val();
        
        if (!oldPassword || !newPassword || !confirmPassword) {
            $('#securityErrorMsg').text('<lang>请填写所有字段</lang>').removeClass('d-none');
            return;
        }
        
        if (newPassword.length < 6) {
            $('#securityErrorMsg').text('<lang>新密码长度不能少于6位</lang>').removeClass('d-none');
            return;
        }
        
        if (newPassword !== confirmPassword) {
            $('#securityErrorMsg').text('<lang>两次输入的新密码不一致</lang>').removeClass('d-none');
            return;
        }
        
        // 显示加载状态
        const $btn = $(this).find('button[type="submit"]');
        const originalText = $btn.html();
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> ' + __('修改中...'));
        
        // 隐藏之前的消息
        $('#securitySuccessMsg, #securityErrorMsg').addClass('d-none');
        
        // 发送AJAX请求
        $.ajax({
            url: '/customer/account/update',
            method: 'POST',
            data: $(this).serialize(),
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    $('#securitySuccessMsg').text(response.message).removeClass('d-none');
                    // 清空密码字段
                    $('#old_password, #new_password, #confirm_password').val('');
                } else {
                    $('#securityErrorMsg').text(response.message).removeClass('d-none');
                }
            },
            error: function() {
                $('#securityErrorMsg').text('<lang>修改失败，请稍后重试</lang>').removeClass('d-none');
            },
            complete: function() {
                // 恢复按钮状态
                $btn.prop('disabled', false).html(originalText);
            }
        });
    });
});
</script>
