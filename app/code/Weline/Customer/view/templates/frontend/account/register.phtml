<script>
(function() {
    'use strict';

    $(document).ready(function() {
        var $form = $('form[action="/customer/account/register"]');
        var $password = $('#password');
        var $confirmPassword = $('#confirm_password');

        function toggleInputFocus() {
            $('.auth-form__input').on('focus', function() {
                $(this).closest('.auth-form__input-wrapper').addClass('auth-form__input-wrapper--focused');
            }).on('blur', function() {
                $(this).closest('.auth-form__input-wrapper').removeClass('auth-form__input-wrapper--focused');
            });
        }

        toggleInputFocus();

        $form.on('submit', function(e) {
            var password = $password.val();
            var confirmPassword = $confirmPassword.val();

            if (password !== confirmPassword) {
                e.preventDefault();
                $('#register-form-error').text('<lang>两次输入的密码不一致</lang>').removeClass('d-none');
                $confirmPassword.focus();
                return false;
            }

            if (password.length < 8) {
                e.preventDefault();
                $('#register-form-error').text('<lang>密码长度至少为8位</lang>').removeClass('d-none');
                $password.focus();
                return false;
            }
        });
    });
})();
</script>
