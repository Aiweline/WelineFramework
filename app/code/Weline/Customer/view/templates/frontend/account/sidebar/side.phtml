    <header class="account-sidebar__header">
        <div class="account-sidebar__avatar">
            <?php if ($avatar): ?>
                <img src="<?= htmlspecialchars($avatar) ?>" alt="<?= htmlspecialchars($username) ?>" class="account-sidebar__avatar-img" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="account-sidebar__avatar-fallback"><?= $avatarInitial ?></div>
            <?php else: ?>
                <div class="account-sidebar__avatar-fallback"><?= $avatarInitial ?></div>
            <?php endif; ?>
        </div>
        <div class="account-sidebar__user-info">
            <h4 class="account-sidebar__username"><?= htmlspecialchars($username) ?></h4>
            <?php if ($email): ?>
                <p class="account-sidebar__email"><?= htmlspecialchars($email) ?></p>
            <?php endif; ?>
        </div>
    </header>
    <nav class="account-sidebar__nav">
        <a class="account-sidebar__nav-link account-sidebar__nav-link--active" href="#profile" data-section="profile">
