<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \Weline\Customer\Model\Customer $user */
$user = $user ?? $this->getData('user');
if (!$user instanceof \Weline\Customer\Model\Customer) {
    try {
        $sessionUser = \Weline\Framework\Session\SessionFactory::getInstance()->createFrontendSession()->getUser();
        if ($sessionUser instanceof \Weline\Customer\Model\Customer) {
            $user = $sessionUser;
        }
    } catch (\Throwable) {
    }
}
$avatar = is_object($user) && method_exists($user, 'getAvatar') ? (string)($user->getAvatar() ?? '') : '';
$username = is_object($user) && method_exists($user, 'getUsername') ? (string)($user->getUsername() ?? '') : '';
$email = is_object($user) && method_exists($user, 'getEmail') ? (string)($user->getEmail() ?? '') : '';
if ($username === '' && $email !== '') {
    $username = $email;
}
$avatarInitial = $username !== '' ? strtoupper(mb_substr($username, 0, 1)) : '?';
$accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
if (!is_string($accountIndexPath) || $accountIndexPath === '') {
    $accountIndexPath = '/customer/account/index';
}
$accountIndexPath = rtrim($accountIndexPath, '/');
$accountSidebarAssetVersion = '20260520-wls-account-assets-1';
?>
<link rel="stylesheet" href="@static(Weline_Customer::css/account-sidebar.css)?v=<?= $accountSidebarAssetVersion ?>">
<div class="account-sidebar-wrapper">
    <header class="account-sidebar__header">
        <div class="account-sidebar__avatar">
            <img src="<?= htmlspecialchars($avatar) ?>" alt="<?= htmlspecialchars($username) ?>" id="sidebarAvatarPreview" class="account-sidebar__avatar-img"<?= $avatar ? '' : ' hidden' ?>>
            <div class="account-sidebar__avatar-fallback" id="sidebarAvatarFallback"<?= $avatar ? ' hidden' : '' ?>><?= $avatarInitial ?></div>
        </div>
        <div class="account-sidebar__user-info">
            <h4 class="account-sidebar__username"><?= htmlspecialchars($username) ?></h4>
            <?php if ($email): ?>
                <p class="account-sidebar__email"><?= htmlspecialchars($email) ?></p>
            <?php endif; ?>
        </div>
    </header>

    <nav class="account-sidebar__nav">
        <a class="account-sidebar__nav-link" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#profile" data-section="profile" data-account-nav-link="true">
            <span><lang>个人资料</lang></span>
        </a>
        <a class="account-sidebar__nav-link" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#security" data-section="security" data-account-nav-link="true">
            <span><lang>安全设置</lang></span>
        </a>

        <w:hook name="account.sidebar"/>

        <a class="account-sidebar__nav-link account-sidebar__nav-link--logout" href="/customer/account/logout">
            <span><lang>退出登录</lang></span>
        </a>
    </nav>
</div>

