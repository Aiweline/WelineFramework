<script>
(function() {
    'use strict';

    function initAccountSidebarMenu() {
        var root = document.querySelector('.account-sidebar-wrapper');
        if (!root) {
            return;
        }

        var toggle = root.querySelector('[data-account-sidebar-toggle]');
        var current = root.querySelector('[data-account-sidebar-current]');
        if (!toggle || !current) {
            return;
        }

        var mobileQuery = window.matchMedia ? window.matchMedia('(max-width: 767px)') : null;

        function isMobile() {
            return mobileQuery ? mobileQuery.matches : window.innerWidth <= 767;
        }

        function getActiveLabel() {
            var active = root.querySelector('[data-account-nav-link].account-sidebar__nav-link--active, [data-account-nav-link].is-active');
            if (!active && window.location.hash) {
                Array.prototype.some.call(root.querySelectorAll('[data-account-nav-link][href]'), function(link) {
                    var href = link.getAttribute('href') || '';
                    if (href.slice(-window.location.hash.length) === window.location.hash) {
                        active = link;
                        return true;
                    }
                    return false;
                });
            }
            var titleNode = active ? (active.querySelector('.account-hook-nav-link__text strong') || active.querySelector('strong') || active.querySelector('span')) : null;
            var text = titleNode ? (titleNode.innerText || titleNode.textContent || '') : (active ? (active.innerText || active.textContent || '') : '');
            text = text.replace(/\s+/g, ' ').trim();
            return text || toggle.getAttribute('data-fallback-label') || '账户菜单';
        }

        function setOpen(open) {
            root.classList.toggle('is-menu-open', open);
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }

        function refresh() {
            var mobile = isMobile();
            root.classList.toggle('is-mobile-menu-ready', mobile);
            current.textContent = getActiveLabel();
            if (!mobile) {
                setOpen(true);
            } else if (!root.getAttribute('data-account-menu-touched')) {
                setOpen(false);
            }
        }

        toggle.setAttribute('data-fallback-label', toggle.innerText.replace(/\s+/g, ' ').trim() || '账户菜单');
        toggle.addEventListener('click', function() {
            root.setAttribute('data-account-menu-touched', '1');
            setOpen(!root.classList.contains('is-menu-open'));
        });

        root.addEventListener('click', function(event) {
            var link = event.target && event.target.closest ? event.target.closest('[data-account-nav-link]') : null;
            if (link && isMobile()) {
                setOpen(false);
                window.setTimeout(refresh, 80);
            }
        });

        window.addEventListener('hashchange', function() {
            window.setTimeout(refresh, 80);
        });
        window.addEventListener('weline:account-sidebar-content-loaded', refresh);
        if (mobileQuery && mobileQuery.addEventListener) {
            mobileQuery.addEventListener('change', refresh);
        }

        window.setTimeout(refresh, 0);
        window.setTimeout(refresh, 160);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAccountSidebarMenu);
    } else {
        initAccountSidebarMenu();
    }
})();
</script>

