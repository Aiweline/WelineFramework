<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \Weline\Customer\Model\Customer $user */
$user = $user ?? $this->getData('user');
if (!$user instanceof \Weline\Customer\Model\Customer) {
    try {
        $sessionUser = \Weline\Framework\Session\SessionFactory::getInstance()->createFrontendSession()->getUser();
        if ($sessionUser instanceof \Weline\Customer\Model\Customer) {
            $user = $sessionUser;
        }
    } catch (\Throwable) {
    }
}
$avatar = is_object($user) && method_exists($user, 'getAvatar') ? (string)($user->getAvatar() ?? '') : '';
$username = is_object($user) && method_exists($user, 'getUsername') ? (string)($user->getUsername() ?? '') : '';
$email = is_object($user) && method_exists($user, 'getEmail') ? (string)($user->getEmail() ?? '') : '';
if ($username === '' && $email !== '') {
    $username = $email;
}
$avatarInitial = $username !== '' ? strtoupper(mb_substr($username, 0, 1)) : '?';
$accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
if (!is_string($accountIndexPath) || $accountIndexPath === '') {
    $accountIndexPath = '/customer/account/index';
}
$accountIndexPath = rtrim($accountIndexPath, '/');
$accountLogoutPath = parse_url($this->getFrontendUrl('customer/account/logout'), PHP_URL_PATH);
if (!is_string($accountLogoutPath) || $accountLogoutPath === '') {
    $accountLogoutPath = '/customer/account/logout';
}
$accountSidebarAssetVersion = '20260701-account-responsive-5';
$accountLogoutConfigJson = json_encode([
    'title' => (string) __('退出登录'),
    'message' => (string) __('确定要退出登录吗？'),
    'confirmText' => (string) __('确认退出'),
    'cancelText' => (string) __('取消'),
], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);
if (!is_string($accountLogoutConfigJson) || $accountLogoutConfigJson === '') {
    $accountLogoutConfigJson = '{}';
}
