<script>
(function() {
    'use strict';

    $(document).ready(function() {
        var $form = $('form[action="/customer/account/challenge"]');
        var $codeInput = $('#code');
        var $verifyBtn = $('#verifyBtn');

        // 只允许输入数字
        $codeInput.on('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        // 输入框焦点效果
        $codeInput.on('focus', function() {
            $(this).closest('.auth-form__input-wrapper').addClass('auth-form__input-wrapper--focused');
        }).on('blur', function() {
            $(this).closest('.auth-form__input-wrapper').removeClass('auth-form__input-wrapper--focused');
        });

        $form.on('submit', function(e) {
            e.preventDefault();

            var digits = $codeInput.val().trim().replace(/[^0-9]/g, '');
            var $errorMsg = $('#errorMessage');
            var $successMsg = $('#successMessage');

            if ($errorMsg.length) {
                $errorMsg.addClass('d-none').removeClass('show');
            }
            if ($successMsg.length) {
                $successMsg.addClass('d-none').removeClass('show');
            }

            // 6 位：TOTP；8 位：备用恢复码（存储格式为 ####-####，需带连字符才能命中）
            if (!digits || (digits.length !== 6 && digits.length !== 8)) {
                ensureErrorMsg().html('<lang>请输入6位身份验证器验证码，或8位数字备用恢复码</lang>');
                $codeInput.focus();
                return;
            }

            var codeForSubmit = digits.length === 8
                ? digits.slice(0, 4) + '-' + digits.slice(4, 8)
                : digits;
            $codeInput.val(codeForSubmit);

            // 禁用按钮，显示加载状态
            $verifyBtn.prop('disabled', true);
            var originalText = $verifyBtn.html();
            $verifyBtn.html('<i class="fas fa-spinner fa-spin me-2"></i><lang>验证中...</lang>');

            // 提交表单
            var formData = new FormData(this);
            fetch($form.attr('action'), {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    ensureSuccessMsg().html('<i class="fas fa-check-circle me-2"></i>' + (data.message || '<lang>验证成功！</lang>'));
                    $verifyBtn.removeClass('auth-form__submit').addClass('auth-form__submit--success');
                    $verifyBtn.html('<i class="fas fa-check me-2"></i><lang>验证成功！</lang>');

                    if (data.redirect) {
                        setTimeout(function() {
                            window.location.href = data.redirect;
                        }, 1000);
                    }
                } else {
                    ensureErrorMsg().html(data.message || '<lang>验证码错误，请重试</lang>');
                    $verifyBtn.prop('disabled', false);
                    $verifyBtn.html(originalText);
                    $codeInput.focus();
                }
            })
            .catch(function() {
                ensureErrorMsg().html('<lang>请求失败，请稍后重试</lang>');
                $verifyBtn.prop('disabled', false);
                $verifyBtn.html(originalText);
            });
        });

        function ensureErrorMsg() {
            var $el = $('#errorMessage');
            if ($el.length === 0) {
                $el = $('<div class="auth-form__alert auth-form__alert--danger" id="errorMessage"></div>');
                $form.prepend($el);
            }
            return $el;
        }

        function ensureSuccessMsg() {
            var $el = $('#successMessage');
            if ($el.length === 0) {
                $el = $('<div class="auth-form__alert auth-form__alert--success" id="successMessage"></div>');
                $form.prepend($el);
            }
            return $el;
        }

        // 自动聚焦到验证码输入框
        $codeInput.focus();
    });
})();
</script>
