<script>
$(document).ready(function() {
    const $form = $('#loginForm');
    const $errorMsg = $('#errorMessage');
    const $errorText = $('#errorText');
    const $loginBtn = $('#loginBtn');
    const $loginText = $('#loginText');
    const $loginSpinner = $('#loginSpinner');
    const $username = $('#username');
    const $password = $('#password');

    // 输入框焦点效果
    $username.on('focus', function() {
        $(this).closest('.form-input-wrapper').addClass('focused');
    }).on('blur', function() {
        $(this).closest('.form-input-wrapper').removeClass('focused');
    });

    $password.on('focus', function() {
        $(this).closest('.form-input-wrapper').addClass('focused');
    }).on('blur', function() {
        $(this).closest('.form-input-wrapper').removeClass('focused');
    });

    // 表单验证
    $form.on('submit', function(e) {
        e.preventDefault();
        
        // 清除之前的错误
        $errorMsg.addClass('d-none').removeClass('show');
        
        // 基本验证
        if (!$username.val().trim()) {
            $errorText.text('<lang>请输入用户名或邮箱</lang>');
            $errorMsg.removeClass('d-none').addClass('show');
            $username.focus();
            return;
        }
        
        if (!$password.val()) {
            $errorText.text('<lang>请输入密码</lang>');
            $errorMsg.removeClass('d-none').addClass('show');
            $password.focus();
            return;
        }

        // 设置加载状态
        $loginBtn.prop('disabled', true).addClass('btn-loading');
        $loginText.hide();
        $loginSpinner.removeClass('d-none').show();

        // 发送登录请求（使用 Weline.Api）
        window.Weline.Api.request('/customer/account/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: $form.serialize()
        })
        .then(function(response) {
            var resp = response.data;
            if (response.ok && resp && resp.success) {
                    $loginBtn.removeClass('btn-loading').addClass('btn-success');
                    $loginSpinner.addClass('d-none').hide();
                    $loginText.html('<i class="fas fa-check-circle me-2"></i><lang>登录成功！</lang>').show();
                    
                    // 添加成功动画
                    $loginBtn.css({
                        'transform': 'scale(1.05)',
                        'transition': 'transform 0.3s'
                    });
                    
                    setTimeout(function() {
                        window.location.href = (resp.redirect || '/customer/account');
                    }, 800);
                } else {
                    handleLoginError((resp && resp.message) || '<lang>登录失败，请检查用户名和密码</lang>');
                }
        })
        .catch(function(error) {
            var errorMsg = (error && error.response && error.response.data && (error.response.data.message || error.response.data.msg)) || (error && error.message) || '<lang>登录请求失败，请稍后重试</lang>';
            handleLoginError(errorMsg);
        });
    });

    // 处理登录错误
    function handleLoginError(message) {
        $errorText.text(message);
        $errorMsg.removeClass('d-none').addClass('show');
        
        // 滚动到错误提示
        $('html, body').animate({
            scrollTop: $errorMsg.offset().top - 100
        }, 300);
        
        // 恢复按钮状态
        $loginBtn.prop('disabled', false)
            .removeClass('btn-loading btn-success')
            .css('transform', '');
        $loginSpinner.addClass('d-none').hide();
        $loginText.text('<lang>登录</lang>').show();
        
        // 添加错误动画
        $form.addClass('error-shake');
        setTimeout(function() {
            $form.removeClass('error-shake');
        }, 500);
    }

    // Enter 键快速登录
    $username.on('keypress', function(e) {
        if (e.which === 13) {
            $password.focus();
        }
    });

    $password.on('keypress', function(e) {
        if (e.which === 13 && !$loginBtn.prop('disabled')) {
            $form.submit();
        }
    });
});
</script>

