<script>
(function() {
    'use strict';

    $(document).ready(function() {
        var $form = $('#loginForm');
        var $errorMsg = $('#errorMessage');
        var $errorText = $('#errorText');
        var $loginBtn = $('#loginBtn');
        var $loginText = $('#loginText');
        var $loginSpinner = $('#loginSpinner');
        var $username = $('#username');
        var $password = $('#password');

        function ensureErrorMsg() {
            if ($errorMsg.length === 0) {
                var alertHtml = '<div class="alert alert-danger" id="errorMessage" role="alert">' +
                    '<i class="fa fa-exclamation-circle me-2"></i>' +
                    '<span id="errorText"></span></div>';
                $form.before(alertHtml);
                $errorMsg = $('#errorMessage');
                $errorText = $('#errorText');
            }
            return $errorMsg;
        }

        $username.on('focus', function() {
            $(this).closest('.auth-form__input-wrapper').addClass('auth-form__input-wrapper--focused');
        }).on('blur', function() {
            $(this).closest('.auth-form__input-wrapper').removeClass('auth-form__input-wrapper--focused');
        });

        $password.on('focus', function() {
            $(this).closest('.auth-form__input-wrapper').addClass('auth-form__input-wrapper--focused');
        }).on('blur', function() {
            $(this).closest('.auth-form__input-wrapper').removeClass('auth-form__input-wrapper--focused');
        });

        $form.on('submit', function(e) {
            e.preventDefault();

            if ($errorMsg.length) {
                $errorMsg.addClass('d-none').removeClass('show');
            }

            if (!$username.val().trim()) {
                ensureErrorMsg();
                $errorText.text('<lang>请输入用户名或邮箱</lang>');
                $username.focus();
                return;
            }

            if (!$password.val()) {
                ensureErrorMsg();
                $errorText.text('<lang>请输入密码</lang>');
                $password.focus();
                return;
            }

            $loginBtn.prop('disabled', true).addClass('auth-form__submit--loading');
            $loginText.hide();
            $loginSpinner.removeClass('d-none').show();

            window.Weline.Api.request('/customer/account/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: $form.serialize()
            })
            .then(function(response) {
                var resp = response.data;
                if (response.ok && resp && resp.success) {
                    $loginBtn.removeClass('auth-form__submit--loading').addClass('auth-form__submit--success');
                    $loginSpinner.addClass('d-none').hide();
                    $loginText.html('<i class="fas fa-check-circle me-2"></i><lang>登录成功！</lang>').show();

                    $loginBtn.css({
                        'transform': 'scale(1.05)',
                        'transition': 'transform 0.3s'
                    });

                    setTimeout(function() {
                        window.location.href = (resp.redirect || '/customer/account');
                    }, 800);
                } else {
                    handleLoginError((resp && resp.message) || '<lang>登录失败，请检查用户名和密码</lang>');
                }
            })
            .catch(function(error) {
                var errorMsg = (error && error.response && error.response.data && (error.response.data.message || error.response.data.msg)) || (error && error.message) || '<lang>登录请求失败，请稍后重试</lang>';
                handleLoginError(errorMsg);
            });
        });

        function handleLoginError(message) {
            var $errEl = ensureErrorMsg();
            $errorText.html(message);

            $('html, body').animate({
                scrollTop: $errEl.offset().top - 100
            }, 300);

            $loginBtn.prop('disabled', false)
                .removeClass('auth-form__submit--loading auth-form__submit--success')
                .css('transform', '');
            $loginSpinner.addClass('d-none').hide();
            $loginText.text('<lang>登录</lang>').show();

            $form.addClass('auth-form--shake');
            setTimeout(function() {
                $form.removeClass('auth-form--shake');
            }, 500);
        }

        $username.on('keypress', function(e) {
            if (e.which === 13) {
                $password.focus();
            }
        });

    $password.on('keypress', function(e) {
        if (e.which === 13 && !$loginBtn.prop('disabled')) {
            $form.submit();
        }
    });
    });
})();
</script>
