<script>
(function() {
    'use strict';

    function closest(el, selector) {
        while (el && el.nodeType === 1) {
            if (el.matches(selector)) {
                return el;
            }
            el = el.parentElement;
        }
        return null;
    }

    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('loginForm');
        var loginBtn = document.getElementById('loginBtn');
        var loginIdleLabel = document.getElementById('loginIdleLabel');
        var loginBusyLabel = document.getElementById('loginBusyLabel');
        var username = document.getElementById('username');
        var password = document.getElementById('password');

        if (!form || !loginBtn || !username || !password) {
            return;
        }

        document.querySelectorAll('.auth-form__password-toggle[data-password-target]').forEach(function(btn) {
            var targetId = btn.getAttribute('data-password-target');
            var pwdInput = targetId ? document.getElementById(targetId) : null;
            if (!pwdInput) {
                return;
            }
            var showLabel = btn.getAttribute('data-label-show') || '';
            var hideLabel = btn.getAttribute('data-label-hide') || '';
            var iconWrap = btn.querySelector('.auth-form__password-toggle-icon');
            btn.addEventListener('click', function() {
                var wasPassword = pwdInput.type === 'password';
                pwdInput.type = wasPassword ? 'text' : 'password';
                var nowPlain = pwdInput.type === 'text';
                btn.setAttribute('aria-pressed', nowPlain ? 'true' : 'false');
                btn.setAttribute('aria-label', nowPlain ? hideLabel : showLabel);
                if (iconWrap) {
                    var svgShow = iconWrap.querySelector('.auth-form__pwd-svg--show');
                    var svgHide = iconWrap.querySelector('.auth-form__pwd-svg--hide');
                    if (svgShow && svgHide) {
                        if (nowPlain) {
                            svgShow.setAttribute('hidden', 'hidden');
                            svgHide.removeAttribute('hidden');
                        } else {
                            svgShow.removeAttribute('hidden');
                            svgHide.setAttribute('hidden', 'hidden');
                        }
                    }
                }
            });
        });

        function ensureErrorMsg() {
            var msg = document.getElementById('errorMessage');
            if (!msg) {
                msg = document.createElement('div');
                msg.className = 'wflash wflash--danger auth-form__client-error';
                msg.id = 'errorMessage';
                msg.setAttribute('role', 'alert');
                msg.innerHTML = '<i class="fas fa-exclamation-circle" aria-hidden="true"></i>' +
                    '<span class="wflash__body" id="errorText"></span>';
                form.parentNode.insertBefore(msg, form);
            }
            return msg;
        }

        function bindInputFocusWrap(input) {
            input.addEventListener('focus', function() {
                var wrap = closest(input, '.auth-form__input-wrapper');
                if (wrap) {
                    wrap.classList.add('auth-form__input-wrapper--focused');
                }
            });
            input.addEventListener('blur', function() {
                var wrap = closest(input, '.auth-form__input-wrapper');
                if (wrap) {
                    wrap.classList.remove('auth-form__input-wrapper--focused');
                }
            });
        }

        bindInputFocusWrap(username);
        bindInputFocusWrap(password);

        function normalizeLoginPayload(raw) {
            if (raw == null) {
                return null;
            }
            if (typeof raw === 'object' && raw !== null && !Array.isArray(raw)) {
                if (
                    typeof raw.success !== 'undefined' ||
                    typeof raw.redirect !== 'undefined' ||
                    raw.status === 'authenticated' ||
                    raw.status === 'challenge_required'
                ) {
                    return raw;
                }
                if (raw.data && typeof raw.data === 'object') {
                    return normalizeLoginPayload(raw.data);
                }
            }
            if (typeof raw === 'string') {
                var t = raw.trim();
                if (t.charAt(0) === '{' || t.charAt(0) === '[') {
                    try {
                        return normalizeLoginPayload(JSON.parse(t));
                    } catch (e) {
                        return null;
                    }
                }
            }
            return null;
        }

        function isLoginSuccessPayload(payload) {
            if (!payload || typeof payload !== 'object') {
                return false;
            }
            if (payload.success === true || payload.success === 'true') {
                return true;
            }
            return payload.status === 'authenticated';
        }

        var accountApiPromise = null;

        function getAccountApi() {
            if (!accountApiPromise) {
                if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
                    accountApiPromise = window.Weline.Api.resource('account');
                } else if (window.Weline && typeof window.Weline.load === 'function') {
                    accountApiPromise = window.Weline.load('api').then(function() {
                        if (!window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
                            throw new Error('Weline.Api is unavailable.');
                        }
                        return window.Weline.Api.resource('account');
                    });
                } else {
                    accountApiPromise = Promise.reject(new Error('Weline.Api is unavailable.'));
                }
            }
            return accountApiPromise;
        }

        function formDataToObject(formData) {
            var payload = {};
            formData.forEach(function(value, key) {
                payload[key] = value;
            });
            delete payload.form_key;
            if (Object.prototype.hasOwnProperty.call(payload, 'remember_duration')) {
                payload.remember_duration = Number(payload.remember_duration || 0);
            }
            return payload;
        }

        function postLoginRequest(payload) {
            return getAccountApi().then(function(AccountApi) {
                return AccountApi.login(payload, {silent: true});
            }).then(function(data) {
                return {
                    ok: data && data.success !== false,
                    data: data
                };
            });
        }

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            var existingErr = document.getElementById('errorMessage');
            if (existingErr) {
                existingErr.hidden = true;
            }

            var userVal = (username.value || '').trim();
            if (!userVal) {
                ensureErrorMsg();
                var tUser = document.getElementById('errorText');
                if (tUser) {
                    tUser.innerHTML = '<lang>请输入用户名或邮箱</lang>';
                }
                username.focus();
                return;
            }

            if (!password.value) {
                ensureErrorMsg();
                var tPwd = document.getElementById('errorText');
                if (tPwd) {
                    tPwd.innerHTML = '<lang>请输入密码</lang>';
                }
                password.focus();
                return;
            }

            loginBtn.disabled = true;
            loginBtn.classList.add('auth-form__submit--busy');
            loginBtn.setAttribute('aria-busy', 'true');

            var body = formDataToObject(new FormData(form));

            postLoginRequest(body)
            .then(function(response) {
                var resp = normalizeLoginPayload(response.data);
                if (response.ok && resp && resp.status === 'challenge_required' && resp.redirect) {
                    window.location.href = resp.redirect;
                    return;
                }
                if (response.ok && isLoginSuccessPayload(resp)) {
                    loginBtn.classList.remove('auth-form__submit--busy');
                    loginBtn.classList.add('auth-form__submit--success');
                    loginBtn.setAttribute('aria-busy', 'false');
                    if (loginBusyLabel) {
                        loginBusyLabel.setAttribute('aria-hidden', 'true');
                    }
                    if (loginIdleLabel) {
                        loginIdleLabel.innerHTML = '<i class="fas fa-check-circle"></i> <lang>登录成功！</lang>';
                    }

                    loginBtn.style.transform = 'scale(1.05)';
                    loginBtn.style.transition = 'transform 0.3s';

                    setTimeout(function() {
                        window.location.href = (resp.redirect || '/customer/account');
                    }, 800);
                } else {
                    handleLoginError((resp && resp.message) || '<lang>登录失败，请检查用户名和密码</lang>');
                }
            })
            .catch(function(error) {
                var errData = error && error.response ? error.response.data : null;
                var parsedErr = normalizeLoginPayload(errData);
                var errorMsg = (parsedErr && parsedErr.message) ||
                    (errData && typeof errData === 'object' && (errData.message || errData.msg)) ||
                    (error && error.message) ||
                    '<lang>登录请求失败，请稍后重试</lang>';
                handleLoginError(errorMsg);
            });
        });

        function handleLoginError(message) {
            var errEl = ensureErrorMsg();
            errEl.removeAttribute('hidden');
            var errText = document.getElementById('errorText');
            if (errText) {
                errText.innerHTML = message;
            }

            var rect = errEl.getBoundingClientRect();
            var scrollTop = window.scrollY + rect.top - 100;
            window.scrollTo({ top: Math.max(0, scrollTop), behavior: 'smooth' });

            loginBtn.disabled = false;
            loginBtn.classList.remove('auth-form__submit--busy', 'auth-form__submit--success');
            loginBtn.setAttribute('aria-busy', 'false');
            loginBtn.style.transform = '';
            loginBtn.style.transition = '';
            if (loginBusyLabel) {
                loginBusyLabel.setAttribute('aria-hidden', 'true');
            }
            if (loginIdleLabel) {
                loginIdleLabel.innerHTML = '<lang>登录</lang>';
            }

            form.classList.add('auth-form--shake');
            setTimeout(function() {
                form.classList.remove('auth-form--shake');
            }, 500);
        }

        username.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                password.focus();
            }
        });

        password.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !loginBtn.disabled) {
                form.requestSubmit();
            }
        });
    });
})();
</script>
