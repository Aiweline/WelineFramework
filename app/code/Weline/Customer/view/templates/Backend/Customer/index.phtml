                        <?= __('重置密码后将自动注销该客户的所有会话与令牌。') ?>
                    </div>
                    <div id="passwordResult" class="alert alert-info d-none">
                        <strong><?= __('新密码：') ?></strong> <span id="passwordGenerated"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal"><?= __('关闭') ?></button>
                    <button type="submit" class="btn btn-primary"><?= __('提交') ?></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
const CUSTOMERS = <?= $customersJson ?>;
const CUSTOMER_SAVE_URL = '<?= $this->getBackendUrl('customer/backend/customer/save') ?>';
const CUSTOMER_DETAIL_URL = '<?= $this->getBackendUrl('customer/backend/customer/detail') ?>';
const CUSTOMER_DELETE_URL = '<?= $this->getBackendUrl('customer/backend/customer/delete') ?>';
const CUSTOMER_RESET_TOKEN_URL = '<?= $this->getBackendUrl('customer/backend/customer/resetToken') ?>';
const CUSTOMER_RESET_PASSWORD_URL = '<?= $this->getBackendUrl('customer/backend/customer/resetPassword') ?>';

let customerModalInstance = null;
let passwordModalInstance = null;
const MESSAGE_TYPE_MAP = {
    success: 'success',
    error: 'danger',
    warning: 'warning',
    info: 'info'
};

document.addEventListener('DOMContentLoaded', () => {
    customerModalInstance = new bootstrap.Modal(document.getElementById('customerModal'));
    passwordModalInstance = new bootstrap.Modal(document.getElementById('passwordModal'));
});

function showPageMessage(type, message) {
    const container = document.getElementById('page-message-container');
    if (!container) {
        console.warn('page message container not found');
        return;
    }
    const alertType = MESSAGE_TYPE_MAP[type] || 'info';
    const alert = document.createElement('div');
    alert.className = `alert alert-${alertType} alert-dismissible fade show`;
    alert.setAttribute('role', 'alert');
    alert.innerHTML = `
        <span>${message}</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    container.appendChild(alert);
    setTimeout(() => {
        try {
            const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
            bsAlert.close();
        } catch (e) {
            alert.remove();
        }
    }, 4000);
}

function openCreateModal() {
    document.getElementById('customerForm').reset();
    document.getElementById('customer_id').value = '0';
    document.getElementById('customer_password_required').classList.remove('text-muted');
    document.getElementById('customer_is_sandbox').checked = false;
    document.getElementById('customerModalTitle').textContent = '<?= __('新增客户') ?>';
    customerModalInstance.show();
}

function openEditModal(userId) {
    fetch(`${CUSTOMER_DETAIL_URL}?user_id=${userId}`)
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                showPageMessage('error', data.message || '<?= __('操作失败') ?>');
                return;
            }
            const user = data.data.user;
            document.getElementById('customer_id').value = user.user_id;
            document.getElementById('customer_username').value = user.username;
            document.getElementById('customer_avatar').value = user.avatar || '';
            document.getElementById('customer_password').value = '';
            document.getElementById('customer_reset_attempts').checked = false;
            document.getElementById('customer_is_sandbox').checked = !!user.is_sandbox;
            document.getElementById('customer_password_required').classList.add('text-muted');
            document.getElementById('customerModalTitle').textContent = '<?= __('编辑客户') ?>';
            customerModalInstance.show();
        })
        .catch(() => {
            showPageMessage('error', '<?= __('操作失败') ?>');
        });
}

function submitCustomerForm(event) {
    event.preventDefault();
    const form = event.target;
    const formData = new FormData(form);
    fetch(CUSTOMER_SAVE_URL, {
        method: 'POST',
        body: formData
    })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showPageMessage('success', data.message || '<?= __('操作成功') ?>');
                customerModalInstance.hide();
                setTimeout(() => location.reload(), 800);
            } else {
                showPageMessage('error', data.message || '<?= __('操作失败') ?>');
            }
        })
        .catch(() => {
            showPageMessage('error', '<?= __('操作失败') ?>');
        });
}

function openPasswordModal(userId) {
    document.getElementById('passwordForm').reset();
    document.getElementById('password_user_id').value = userId;
    document.getElementById('passwordResult').classList.add('d-none');
    document.getElementById('passwordGenerated').textContent = '';
    passwordModalInstance.show();
}

function submitPasswordForm(event) {
    event.preventDefault();
    const formData = new FormData(event.target);
    fetch(CUSTOMER_RESET_PASSWORD_URL, {
        method: 'POST',
        body: formData
    })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showPageMessage('success', data.message || '<?= __('操作成功') ?>');
                if (data.data && data.data.new_password) {
                    document.getElementById('passwordGenerated').textContent = data.data.new_password;
                    document.getElementById('passwordResult').classList.remove('d-none');
                }
                setTimeout(() => location.reload(), 1000);
            } else {
                showPageMessage('error', data.message || '<?= __('操作失败') ?>');
            }
        })
        .catch(() => {
            showPageMessage('error', '<?= __('操作失败') ?>');
        });
}

function resetTokens(userId) {
    if (!confirm('<?= __('确定要重置该客户的令牌吗？此操作会强制该客户重新登录。') ?>')) {
        return;
    }
    const formData = new FormData();
    formData.append('user_id', userId);
    fetch(CUSTOMER_RESET_TOKEN_URL, {
        method: 'POST',
        body: formData
    })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showPageMessage('success', data.message || '<?= __('操作成功') ?>');
                setTimeout(() => location.reload(), 800);
            } else {
                showPageMessage('error', data.message || '<?= __('操作失败') ?>');
            }
        })
        .catch(() => {
            showPageMessage('error', '<?= __('操作失败') ?>');
        });
}

function deleteCustomer(userId) {
    if (!confirm('<?= __('确定要删除该客户吗？此操作不可撤销。') ?>')) {
        return;
    }
    const formData = new FormData();
    formData.append('user_id', userId);
    fetch(CUSTOMER_DELETE_URL, {
        method: 'POST',
        body: formData
    })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showPageMessage('success', data.message || '<?= __('操作成功') ?>');
                setTimeout(() => location.reload(), 800);
            } else {
                showPageMessage('error', data.message || '<?= __('操作失败') ?>');
            }
        })
        .catch(() => {
            showPageMessage('error', '<?= __('操作失败') ?>');
        });
}
</script>

