<!--
布局：客户联系我们页面

Weline_Customer 联系我们页面专属布局，只负责页面框架、公共 partial、内容插槽和页面级视觉结构。

@meta.name {default="客户联系我们页面",name="客户联系我们页面",description="Weline_Customer 联系我们页面布局"}
@meta.description {default="包含 header、breadcrumb、contact 内容区、footer",name="描述",description="联系我们页面专属布局"}
@preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="联系我们页面允许访客访问"}
@param.title {default="联系我们",name="页面标题",description="页面标题"}
@param.content {default="",name="主要内容",description="联系我们页面内容 HTML"}
@param.showHeader {default=true,name="是否显示 header",description="是否显示站点头部"}
@param.showFooter {default=true,name="是否显示 footer",description="是否显示站点底部"}
@param.class {default="",name="额外 CSS 类",description="主内容额外 CSS 类"}
-->
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Customer::frontend::layouts::contact::head-after</w:hook>
    <style>
        body.customer-contact-layout {
            margin: 0;
            min-height: 100vh;
            background:
                radial-gradient(circle at 12% 18%, rgba(27, 107, 255, .12), transparent 28rem),
                linear-gradient(180deg, #f8fafc 0%, #ffffff 42%, #f6f8fb 100%);
            color: #172033;
        }

        .customer-contact-layout__page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .customer-contact-layout__breadcrumb {
            background: rgba(255, 255, 255, .86);
            border-bottom: 1px solid #e4e8f0;
            backdrop-filter: blur(12px);
        }

        .customer-contact-layout__main {
            flex: 1 0 auto;
            width: 100%;
        }

        .customer-contact-page {
            --customer-contact-ink: #172033;
            --customer-contact-muted: #687286;
            --customer-contact-line: #e4e8f0;
            --customer-contact-accent: #1b6bff;
            max-width: 1120px;
            margin: 0 auto;
            padding: 54px 20px 72px;
            color: var(--customer-contact-ink);
        }

        .customer-contact-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(280px, .8fr);
            gap: 26px;
            align-items: stretch;
            margin-bottom: 28px;
        }

        .customer-contact-hero__main,
        .customer-contact-card {
            border: 1px solid var(--customer-contact-line);
            border-radius: 26px;
            background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
            box-shadow: 0 18px 45px rgba(23, 32, 51, .08);
        }

        .customer-contact-hero__main {
            padding: 38px;
            position: relative;
            overflow: hidden;
        }

        .customer-contact-hero__main::after {
            content: "";
            position: absolute;
            width: 210px;
            height: 210px;
            right: -70px;
            top: -76px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(27, 107, 255, .18), rgba(27, 107, 255, 0) 66%);
            pointer-events: none;
        }

        .customer-contact-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(27, 107, 255, .1);
            color: var(--customer-contact-accent);
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 18px;
        }

        .customer-contact-page h1 {
            margin: 0;
            font-size: clamp(34px, 5vw, 58px);
            line-height: .96;
            letter-spacing: -.05em;
        }

        .customer-contact-lead {
            max-width: 660px;
            margin: 20px 0 0;
            color: var(--customer-contact-muted);
            font-size: 17px;
            line-height: 1.8;
        }

        .customer-contact-hero__side {
            padding: 30px;
            border-radius: 26px;
            background: #172033;
            color: #fff;
            box-shadow: 0 18px 45px rgba(23, 32, 51, .18);
        }

        .customer-contact-hero__side h2 {
            margin: 0 0 14px;
            font-size: 24px;
        }

        .customer-contact-hero__side p {
            margin: 0 0 24px;
            color: rgba(255, 255, 255, .78);
            line-height: 1.7;
        }

        .customer-contact-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 28px;
        }

        .customer-contact-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 0 18px;
            border-radius: 999px;
            border: 1px solid transparent;
            text-decoration: none;
            font-weight: 800;
            transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        }

        .customer-contact-button:hover {
            transform: translateY(-2px);
            text-decoration: none;
        }

        .customer-contact-button--primary {
            background: var(--customer-contact-accent);
            color: #fff;
            box-shadow: 0 14px 26px rgba(27, 107, 255, .24);
        }

        .customer-contact-button--secondary {
            background: #fff;
            color: var(--customer-contact-ink);
            border-color: var(--customer-contact-line);
        }

        .customer-contact-button--dark {
            width: 100%;
            background: #fff;
            color: #172033;
        }

        .customer-contact-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .customer-contact-card {
            padding: 26px;
        }

        .customer-contact-card__icon {
            width: 46px;
            height: 46px;
            display: grid;
            place-items: center;
            border-radius: 16px;
            background: rgba(27, 107, 255, .1);
            color: var(--customer-contact-accent);
            margin-bottom: 18px;
        }

        .customer-contact-card__icon svg {
            width: 24px;
            height: 24px;
            fill: currentColor;
        }

        .customer-contact-card h3 {
            margin: 0 0 10px;
            font-size: 20px;
        }

        .customer-contact-card p {
            margin: 0;
            color: var(--customer-contact-muted);
            line-height: 1.7;
        }

        @media (max-width: 820px) {
            .customer-contact-hero,
            .customer-contact-grid {
                grid-template-columns: 1fr;
            }

            .customer-contact-hero__main {
                padding: 30px 24px;
            }
        }
    </style>
</head>
<body class="customer-contact-layout">
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Customer::frontend::layouts::contact::body-start</w:hook>

    <div class="customer-contact-layout__page">
        <if condition="meta.showHeader">
            <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
            <w:hook>Weline_Customer::frontend::layouts::contact::header-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
            <w:hook>Weline_Customer::frontend::layouts::contact::header-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
        </if>

        <div class="customer-contact-layout__breadcrumb">
            <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-before</w:hook>
            <w:hook>Weline_Customer::frontend::layouts::contact::breadcrumb-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="breadcrumb" default-option="default"/>
            <w:hook>Weline_Customer::frontend::layouts::contact::breadcrumb-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-after</w:hook>
        </div>

        <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
        <w:hook>Weline_Customer::frontend::layouts::contact::content-before</w:hook>
        <main class="customer-contact-layout__main <?= htmlspecialchars(($meta['class'] ?? '')) ?>" id="main-content" data-layout="customer_contact">
            <if condition="meta.content">
                {{meta.content}}
                <elseif condition="content"/>
                {{content}}
                <elseif condition="meta.contentTemplate"/>
                <?php echo $this->fetch($this->getData("meta.contentTemplate")); ?>
                <else/>
                <?= $this->getChildHtml('content') ?>
            </if>
        </main>
        <w:hook>Weline_Customer::frontend::layouts::contact::content-after</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>

        <if condition="meta.showFooter">
            <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
            <w:hook>Weline_Customer::frontend::layouts::contact::footer-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
            <w:hook>Weline_Customer::frontend::layouts::contact::footer-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
        </if>
    </div>

    <w:hook>Weline_Customer::frontend::layouts::contact::body-end</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
</body>
</html>
