<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- CDN缓存清理事件 -->
    <event name="Weline_Cdn::clear">
        <observer name="Weline_Cdn::clear_observer" 
                  instance="Weline\Cdn\Observer\Clear" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN预热URL投递事件 -->
    <event name="Weline_Cdn::send_warmup">
        <observer name="Weline_Cdn::send_warmup_observer" 
                  instance="Weline\Cdn\Observer\WarmupSend" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN规则推送事件 -->
    <event name="Weline_Cdn::push_rules">
        <observer name="Weline_Cdn::push_rules_cloudflare" 
                  instance="Weline\Cdn\Observer\PushRules" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- 系统升级后自动收集规则 -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Cdn::collect_rules_after_upgrade" 
                  instance="Weline\Cdn\Observer\CollectRules" 
                  disabled="false" 
                  shared="true" 
                  sort="100"/>
    </event>
    
    <!-- CDN统一请求事件 -->
    <event name="Weline_Cdn::request">
        <observer name="Weline_Cdn::request_handler" 
                  instance="Weline\Cdn\Observer\CdnRequest" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN攻击检测信号事件 -->
    <!-- 由 Server Cron 定时任务检测攻击信号文件后触发 -->
    <!-- 处理逻辑：接收信号 → 向各 CDN 服务商广播开启攻击防护模式 -->
    <event name="Weline_Cdn::security::attack_detected">
        <observer name="Weline_Cdn::attack_signal_handler" 
                  instance="Weline\Cdn\Observer\AttackSignalHandler" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN攻击恢复信号事件 -->
    <!-- 由 Server Cron 定时任务检测到攻击恢复（无新攻击超时）后触发 -->
    <!-- 处理逻辑：接收恢复信号 → 向各 CDN 服务商广播关闭攻击防护模式 -->
    <event name="Weline_Cdn::security::attack_recovered">
        <observer name="Weline_Cdn::attack_recovery_handler" 
                  instance="Weline\Cdn\Observer\AttackRecoveryHandler" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>

    <!-- Framework 解析客户端真实 IP 前，注册 CDN 专有 Header keys -->
    <event name="Weline_Framework_Http::integration::client_ip_keys">
        <observer name="Weline_Cdn::client_ip_keys"
                  instance="Weline\Cdn\Observer\ClientIpKeysObserver"
                  disabled="false"
                  shared="true"
                  sort="10"/>
    </event>

    <!-- WLS 安全规则更新后，触发 CDN 规则同步 -->
    <event name="Weline_Server::integration::security_rules_updated">
        <observer name="Weline_Cdn::sync_security_rules_to_cdn"
                  instance="Weline\Cdn\Observer\SyncSecurityRulesToCdn"
                  disabled="false"
                  shared="true"
                  sort="10"/>
    </event>
</config>

