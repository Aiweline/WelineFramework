<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- CDN缓存清理事件 -->
    <event name="Weline_Cdn::clear">
        <observer name="Weline_Cdn::clear_observer" 
                  instance="Weline\Cdn\Observer\Clear" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN预热URL投递事件 -->
    <event name="Weline_Cdn::send_warmup">
        <observer name="Weline_Cdn::send_warmup_observer" 
                  instance="Weline\Cdn\Observer\WarmupSend" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- CDN规则推送事件 -->
    <event name="Weline_Cdn::push_rules">
        <observer name="Weline_Cdn::push_rules_cloudflare" 
                  instance="Weline\Cdn\Observer\PushRules" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- 系统升级后自动收集规则 -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Cdn::collect_rules_after_upgrade" 
                  instance="Weline\Cdn\Observer\CollectRules" 
                  disabled="false" 
                  shared="true" 
                  sort="100"/>
    </event>
</config>

