<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
const deleteUrl = '<?= $this->getBackendUrl("*/backend/attackLog/delete") ?>';
const batchDeleteUrl = '<?= $this->getBackendUrl("*/backend/attackLog/batchDelete") ?>';
const cleanupUrl = '<?= $this->getBackendUrl("*/backend/attackLog/cleanup") ?>';

function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.log-checkbox');
    checkboxes.forEach(cb => cb.checked = selectAll.checked);
}

function getSelectedIds() {
    const checkboxes = document.querySelectorAll('.log-checkbox:checked');
    return Array.from(checkboxes).map(cb => cb.value);
}

function deleteLog(id) {
    Swal.fire({
        title: '<?= __("确定删除？") ?>',
        text: '<?= __("此操作不可恢复！") ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<?= __("确定删除") ?>',
        cancelButtonText: '<?= __("取消") ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(deleteUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __("成功") ?>',
                        text: data.message,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
                }
            });
        }
    });
}

function batchDelete() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        Swal.fire({ icon: 'warning', title: '<?= __("请先选择要删除的日志") ?>' });
        return;
    }
    
    Swal.fire({
        title: '<?= __("确定批量删除？") ?>',
        text: '<?= __("将删除 ") ?>' + ids.length + '<?= __(" 条日志，此操作不可恢复！") ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<?= __("确定删除") ?>',
        cancelButtonText: '<?= __("取消") ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            const formData = new FormData();
            ids.forEach(id => formData.append('ids[]', id));
            
            fetch(batchDeleteUrl, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __("成功") ?>',
                        text: data.message,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
                }
            });
        }
    });
}

function cleanupLogs() {
    const days = document.getElementById('cleanupDays').value;
    
    fetch(cleanupUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'days=' + days
    })
    .then(response => response.json())
    .then(data => {
        bootstrap.Modal.getInstance(document.getElementById('cleanupModal')).hide();
        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: '<?= __("成功") ?>',
                text: data.message,
                timer: 1500,
                showConfirmButton: false
            }).then(() => location.reload());
        } else {
            Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
        }
    });
}
</script>

