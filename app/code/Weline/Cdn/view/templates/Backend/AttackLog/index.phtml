<js:part>
(function() {
    'use strict';
    
    var deleteUrl = '<?= $this->getBackendUrl("*/backend/attackLog/delete") ?>';
    var batchDeleteUrl = '<?= $this->getBackendUrl("*/backend/attackLog/batchDelete") ?>';
    var cleanupUrl = '<?= $this->getBackendUrl("*/backend/attackLog/cleanup") ?>';
    
    function getSelectedIds() {
        var checkboxes = document.querySelectorAll('.log-checkbox:checked');
        return Array.from(checkboxes).map(function(cb) { return cb.value; });
    }
    
    window.CdnAttackLogManager = {
        toggleSelectAll: function() {
            var selectAll = document.getElementById('selectAll');
            var checkboxes = document.querySelectorAll('.log-checkbox');
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
        },
        
        deleteLog: function(id) {
            Swal.fire({
                title: '<?= __("确定删除？") ?>',
                text: '<?= __("此操作不可恢复！") ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<?= __("确定删除") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(deleteUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'id=' + id
                    })
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __("成功") ?>',
                                text: data.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function() { location.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
                        }
                    });
                }
            });
        },
        
        batchDelete: function() {
            var ids = getSelectedIds();
            if (ids.length === 0) {
                Swal.fire({ icon: 'warning', title: '<?= __("请先选择要删除的日志") ?>' });
                return;
            }
            
            Swal.fire({
                title: '<?= __("确定批量删除？") ?>',
                text: '<?= __("将删除 ") ?>' + ids.length + '<?= __(" 条日志，此操作不可恢复！") ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<?= __("确定删除") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    var formData = new FormData();
                    ids.forEach(function(id) { formData.append('ids[]', id); });
                    
                    fetch(batchDeleteUrl, {
                        method: 'POST',
                        body: formData
                    })
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __("成功") ?>',
                                text: data.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function() { location.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
                        }
                    });
                }
            });
        },
        
        cleanupLogs: function() {
            var days = document.getElementById('cleanupDays').value;
            
            fetch(cleanupUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'days=' + days
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                bootstrap.Modal.getInstance(document.getElementById('cleanupModal')).hide();
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __("成功") ?>',
                        text: data.message,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(function() { location.reload(); });
                } else {
                    Swal.fire({ icon: 'error', title: '<?= __("失败") ?>', text: data.message });
                }
            });
        }
    };
})();
</js:part>
