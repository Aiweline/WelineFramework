<?php
/**
 * 账户关联域名列表页
 *
 * @var \Weline\Framework\View\Template $this
 */

$account = $this->getData('account');
$domains = $this->getData('domains') ?: [];
?>

<!-- 消息提示 -->
<div class='row mb-3'>
    <template>Weline_Component::message.phtml</template>
</div>

<!-- 域名列表 -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="mdi mdi-web text-primary"></i> 
            <?= __('账户关联域名') ?>: <?= htmlspecialchars($account->getData('name')) ?>
        </h5>
    </div>
    <div class="card-body">
        <?php if (empty($domains)): ?>
            <div class="alert alert-info">
                <i class="mdi mdi-information"></i> <?= __('该账户暂无关联的域名') ?>
            </div>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th><?= __('域名ID') ?></th>
                            <th><?= __('域名名称') ?></th>
                            <th><?= __('适配器') ?></th>
                            <th><?= __('状态') ?></th>
                            <th><?= __('操作') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($domains as $domain): ?>
                            <tr>
                                <td><?= $domain->getData('domain_id') ?></td>
                                <td><?= htmlspecialchars($domain->getData('domain_name')) ?></td>
                                <td>
                                    <span class="badge bg-info"><?= htmlspecialchars($domain->getData('adapter')) ?></span>
                                </td>
                                <td>
                                    <?php if ($domain->getData('enabled')): ?>
                                        <span class="badge bg-success"><?= __('启用') ?></span>
                                    <?php else: ?>
                                        <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td>
                                    <a href="<?= $this->getBackendUrl('*/backend/domain/form', ['id' => $domain->getData('domain_id')]) ?>" 
                                       class="btn btn-sm btn-primary">
                                        <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                                    </a>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>

        <div class="mt-3">
            <a href="<?= $this->getBackendUrl('*/backend/account/index') ?>" class="btn btn-secondary">
                <i class="mdi mdi-arrow-left"></i> <?= __('返回') ?>
            </a>
        </div>
    </div>
</div>
