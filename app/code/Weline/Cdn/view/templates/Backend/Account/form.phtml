<js:part>
(function() {
    'use strict';
    
    var indexUrl = '<?php echo $this->getBackendUrl('*/backend/account/index'); ?>';
    
    var adapterSelect = document.getElementById('adapterSelect');
    var accountNameInput = document.getElementById('accountNameInput');
    var permissionsInfo = document.getElementById('adapterPermissionsInfo');
    var accountForm = document.getElementById('accountForm');
    
    function updatePermissionsInfo() {
        if (!adapterSelect || !permissionsInfo) return;
        
        var selectedOption = adapterSelect.options[adapterSelect.selectedIndex];
        
        if (selectedOption && selectedOption.value === 'cloudflare') {
            permissionsInfo.style.display = 'block';
        } else {
            permissionsInfo.style.display = 'none';
        }
        
        if (selectedOption && selectedOption.value && accountNameInput) {
            var adapterName = selectedOption.getAttribute('data-adapter-name');
            if (adapterName && (!accountNameInput.value || accountNameInput.value.trim() === '')) {
                accountNameInput.value = adapterName;
            }
        }
    }
    
    if (adapterSelect) {
        adapterSelect.addEventListener('change', updatePermissionsInfo);
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        if (adapterSelect && adapterSelect.value === 'cloudflare') {
            updatePermissionsInfo();
        }
    });
    
    if (accountForm) {
        accountForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            var formData = new FormData(this);
            
            fetch(this.action, {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?php echo __('成功'); ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() {
                            window.location.href = data.redirect || indexUrl;
                        });
                    } else {
                        AdminToast.success(data.message);
                        setTimeout(function() {
                            window.location.href = data.redirect || indexUrl;
                        }, 1500);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?php echo __('保存失败'); ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        AdminToast.error(data.message);
                    }
                }
            })
            .catch(function(error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?php echo __('请求失败'); ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    AdminToast.error(error.message);
                }
            });
        });
    }
})();
</js:part>
