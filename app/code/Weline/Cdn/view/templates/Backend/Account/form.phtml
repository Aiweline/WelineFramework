<script>
// 适配器选择变化时自动填充账户名称和显示权限说明
document.getElementById('adapterSelect')?.addEventListener('change', function() {
    const adapterSelect = this;
    const accountNameInput = document.getElementById('accountNameInput');
    const selectedOption = adapterSelect.options[adapterSelect.selectedIndex];
    const permissionsInfo = document.getElementById('adapterPermissionsInfo');
    
    // 显示或隐藏权限说明（如果是Cloudflare）
    if (permissionsInfo) {
        if (selectedOption && selectedOption.value === 'cloudflare') {
            permissionsInfo.style.display = 'block';
        } else {
            permissionsInfo.style.display = 'none';
        }
    }
    
    // 如果选择了适配器且账户名称为空，则自动填充
    if (selectedOption && selectedOption.value && accountNameInput) {
        const adapterName = selectedOption.getAttribute('data-adapter-name');
        if (adapterName && (!accountNameInput.value || accountNameInput.value.trim() === '')) {
            accountNameInput.value = adapterName;
        }
    }
});

// 页面加载时检查当前选中的适配器
document.addEventListener('DOMContentLoaded', function() {
    const adapterSelect = document.getElementById('adapterSelect');
    if (adapterSelect && adapterSelect.value === 'cloudflare') {
        const permissionsInfo = document.getElementById('adapterPermissionsInfo');
        if (permissionsInfo) {
            permissionsInfo.style.display = 'block';
        }
    }
});

// 表单提交
document.getElementById('accountForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    fetch(this.action, {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            if (data.redirect) {
                window.location.href = data.redirect;
            } else {
                window.location.href = '<?= $this->getBackendUrl('*/backend/account/index') ?>';
            }
        } else {
            alert('<?= __('保存失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    });
});
</script>

