<js:part name="w-delete"/>

<js:part>
(function() {
    'use strict';
    
    var setDefaultUrl = '<?php echo $this->getBackendUrl('*/backend/account/setDefault'); ?>';
    
    window.CdnAccountManager = {
        setDefault: function(id) {
            if (!confirm('<?= __('确定要设置此账户为默认账户吗？') ?>')) {
                return;
            }
            
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'id=' + id };
            var req = window.Weline.Api.request(setDefaultUrl, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        BackendToast.success(data.message);
                        setTimeout(function() { location.reload(); }, 1500);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('操作失败') ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        BackendToast.error(data.message);
                    }
                }
            });
        }
    };
})();
</js:part>
