<script>
function setDefault(id) {
    if (!confirm('<?= __('确定要设置此账户为默认账户吗？') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/account/setDefault') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

</script>

