<js:part>
(function() {
    'use strict';
    
    var currentDomainId = <?= $jsonForScript($selectedDomainId) ?>;
    var getDomainRulesUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/getDomainRules')) ?>;
    var getGlobalRulesUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/getGlobalRules')) ?>;
    var saveDomainRulesUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/saveDomainRules')) ?>;
    var saveGlobalRulesUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/saveGlobalRules')) ?>;
    var importUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/import')) ?>;
    var getDomainsUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/getDomains')) ?>;
    var pushUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/rules/push')) ?>;

    function escapeHtml(value) {
        var div = document.createElement('div');
        div.textContent = value == null ? '' : String(value);
        return div.innerHTML;
    }
    
    function addLog(type, message) {
        var logContainer = document.getElementById('pushLogContainer');
        var timestamp = new Date().toLocaleTimeString();
        
        var typeClass = 'text-muted';
        if (type === 'success') typeClass = 'text-success';
        else if (type === 'error') typeClass = 'text-danger';
        else if (type === 'warning') typeClass = 'text-warning';
        else if (type === 'info') typeClass = 'text-info';
        
        var logHtml = '<div class="mb-1 ' + typeClass + '"><strong>[' + timestamp + ']</strong> ' + escapeHtml(message) + '</div>';
        logContainer.insertAdjacentHTML('beforeend', logHtml);
        logContainer.scrollTop = logContainer.scrollHeight;
    }
    
    function updateProgressBar(progress) {
        var progressBar = document.getElementById('pushProgressBar');
        var overallProgress = document.getElementById('pushOverallProgress');
        
        progressBar.style.width = progress + '%';
        progressBar.setAttribute('aria-valuenow', progress);
        progressBar.textContent = progress.toFixed(1) + '%';
        overallProgress.textContent = progress.toFixed(1) + '%';
    }
    
    function showPushProgressModal() {
        document.getElementById('pushProgressBar').style.width = '0%';
        document.getElementById('pushProgressBar').textContent = '0%';
        document.getElementById('pushProgressBar').classList.add('progress-bar-animated');
        document.getElementById('pushOverallProgress').textContent = '0%';
        document.getElementById('pushTotal').textContent = '0';
        document.getElementById('pushSuccess').textContent = '0';
        document.getElementById('pushFail').textContent = '0';
        document.getElementById('pushLogContainer').innerHTML = '<div class="text-muted"><?= __('正在推送...') ?></div>';
        document.getElementById('pushCloseBtn').disabled = true;
        
        var modal = new bootstrap.Modal(document.getElementById('pushProgressModal'));
        modal.show();
    }

    document.addEventListener('change', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-rules-action]')
            : null;
        if (!target || target.dataset.cdnRulesAction !== 'load') {
            return;
        }
        window.CdnRulesManager.loadRules();
    });

    document.addEventListener('click', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-rules-action]')
            : null;
        if (!target) {
            return;
        }

        if (target.dataset.cdnRulesAction === 'save') {
            window.CdnRulesManager.saveRules();
            return;
        }

        if (target.dataset.cdnRulesAction === 'import') {
            window.CdnRulesManager.importRules();
            return;
        }

        if (target.dataset.cdnRulesAction === 'push') {
            window.CdnRulesManager.pushRules();
        }
    });
    
    window.CdnRulesManager = {
        loadRules: function() {
            var domainId = document.getElementById('domainSelect').value;
            currentDomainId = domainId;
            
            var url = domainId 
                ? getDomainRulesUrl + '?domain_id=' + encodeURIComponent(domainId)
                : getGlobalRulesUrl;
            
            window.Weline.Api.get(url, { silent: true })
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    var rules = data.data || {};
                    document.getElementById('rulesTextarea').value = JSON.stringify(rules, null, 2);
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('加载失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(function(error) {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        },
        
        saveRules: function() {
            var rulesText = document.getElementById('rulesTextarea').value;
            var rules;
            
            try {
                rules = JSON.parse(rulesText);
            } catch (e) {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('JSON格式错误') ?>',
                    text: e.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
                return;
            }
            
            var url = currentDomainId ? saveDomainRulesUrl : saveGlobalRulesUrl;
            
            var formData = new FormData();
            formData.append('rules', JSON.stringify(rules));
            if (currentDomainId) {
                formData.append('domain_id', currentDomainId);
            }
            
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(function(error) {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        },
        
        importRules: function() {
            if (!currentDomainId) {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择域名') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
                return;
            }
            
            Swal.fire({
                title: '<?= __('确认导入') ?>',
                text: '<?= __('确定要从CDN导入规则吗？这将覆盖当前规则。') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定导入") ?>',
                cancelButtonText: '<?= __("取消") ?>',
                confirmButtonColor: '#ff9800'
            }).then(function(result) {
                if (result.isConfirmed) {
                    var impUrl = importUrl + '?domain_id=' + encodeURIComponent(currentDomainId);
                    var impOpts = { method: 'POST' };
                    window.Weline.Api.request(impUrl, impOpts)
                    .then(function(res) {
                        var data = (res && res.data) !== undefined ? res.data : res;
                        if (data.success) {
                            document.getElementById('rulesTextarea').value = JSON.stringify(data.data || {}, null, 2);
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: data.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('导入失败') ?>',
                                text: data.message,
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('请求失败') ?>',
                            text: error.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        },
        
        pushRules: async function() {
            showPushProgressModal();
            
            var progressBar = document.getElementById('pushProgressBar');
            var closeBtn = document.getElementById('pushCloseBtn');
            
            addLog('info', '<?= __('正在获取域名列表...') ?>');
            
            try {
                var domainsResponse = await fetch(getDomainsUrl);
                var domainsData = await domainsResponse.json();
                
                if (!domainsData.success || !domainsData.domains || domainsData.domains.length === 0) {
                    addLog('error', domainsData.message || '<?= __('没有可推送的域名') ?>');
                    closeBtn.disabled = false;
                    progressBar.classList.remove('progress-bar-animated');
                    return;
                }
                
                var domains = domainsData.domains;
                var total = domains.length;
                var successCount = 0;
                var failCount = 0;
                
                document.getElementById('pushTotal').textContent = total;
                
                var startMsg = '<?= __('开始推送规则到 %{1} 个域名...') ?>';
                addLog('info', startMsg.replace(/%\{1\}/g, String(total || 0)));
                
                for (var index = 0; index < domains.length; index++) {
                    var domain = domains[index];
                    var currentIndex = index + 1;
                    var progress = Math.round((currentIndex / total) * 100);
                    
                    var domainName = (domain.domain_name && String(domain.domain_name).trim()) || '未知域名';
                    var domainId = (domain.domain_id && String(domain.domain_id)) || '未知ID';
                    
                    updateProgressBar(progress);
                    
                    addLog('info', '[' + currentIndex + '/' + total + '] <?= __('正在推送域名') ?>: ' + domainName + ' (ID: ' + domainId + ')');
                    
                    try {
                        var formData = new FormData();
                        formData.append('id', domain.domain_id);
                        
                        var pushResponse = await fetch(pushUrl, {
                            method: 'POST',
                            body: formData
                        });
                        
                        var pushData = await pushResponse.json();
                        var finalDomainName = (pushData.domain_name && String(pushData.domain_name).trim()) || domainName;
                        
                        if (pushData.success) {
                            successCount++;
                            addLog('success', '[' + currentIndex + '/' + total + '] ✓ <?= __('推送成功') ?>: ' + finalDomainName + ' - ' + (pushData.message || '<?= __('推送成功') ?>'));
                        } else {
                            failCount++;
                            addLog('error', '[' + currentIndex + '/' + total + '] ✗ <?= __('推送失败') ?>: ' + finalDomainName + ' - ' + (pushData.message || '<?= __('推送失败') ?>'));
                        }
                        
                        document.getElementById('pushSuccess').textContent = successCount;
                        document.getElementById('pushFail').textContent = failCount;
                        
                    } catch (error) {
                        failCount++;
                        addLog('error', '[' + currentIndex + '/' + total + '] ✗ <?= __('推送失败') ?>: ' + domainName + ' - <?= __('请求失败：') ?>' + error.message);
                        document.getElementById('pushFail').textContent = failCount;
                    }
                }
                
                updateProgressBar(100);
                progressBar.classList.remove('progress-bar-animated');
                closeBtn.disabled = false;
                
                var summaryType = failCount === 0 ? 'success' : 'warning';
                var summaryMsg = '<?= __('推送完成：总共 %{1} 个，成功 %{2} 个，失败 %{3} 个') ?>';
                addLog(summaryType, summaryMsg.replace(/%\{1\}/g, String(total || 0)).replace(/%\{2\}/g, String(successCount || 0)).replace(/%\{3\}/g, String(failCount || 0)));
                
            } catch (error) {
                addLog('error', '<?= __('获取域名列表失败：') ?>' + error.message);
                closeBtn.disabled = false;
                progressBar.classList.remove('progress-bar-animated');
            }
        }
    };
    
    window.addEventListener('DOMContentLoaded', function() {
        window.CdnRulesManager.loadRules();
    });
})();
</js:part>
