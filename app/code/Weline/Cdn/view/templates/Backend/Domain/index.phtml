<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
function toggleEnable(id, enabled) {
    fetch('<?= $this->getBackendUrl('*/backend/domain/toggleEnable') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id + '&enabled=' + enabled
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log(data.message);
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('操作失败：') ?>' + data.message);
            }
        }
    });
}

function clearCache(id) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认清理缓存') ?>',
            text: '<?= __('确定要清理该域名的所有缓存吗？') ?>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定清理") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#ff9800'
        }).then((result) => {
            if (result.isConfirmed) {
                performClearCache(id);
            }
        });
    } else {
        if (!confirm('<?= __('确定要清理该域名的所有缓存吗？') ?>')) {
            return;
        }
        performClearCache(id);
    }
}

function performClearCache(id) {
    fetch('<?= $this->getBackendUrl('*/backend/domain/clearCache') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id + '&mode=everything'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log(data.message);
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('清理失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('清理失败：') ?>' + data.message);
            }
        }
    });
}

</script>

