<?php
/**
 * CDN域名管理列表页
 *
 * @var \Weline\Framework\View\Template $this
 */

$domains = $this->getData('domains') ?: [];
$total = (int)$this->getData('total');
$page = (int)$this->getData('page');
$pageSize = (int)$this->getData('pageSize');
$totalPages = (int)$this->getData('totalPages');
$search = $this->getData('search') ?: '';
$adapter = $this->getData('adapter') ?: '';
$enabled = $this->getData('enabled') !== '' ? $this->getData('enabled') : '';
$adapters = $this->getData('adapters') ?: [];
$websites = $this->getData('websites') ?: [];
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT;
$jsonForScript = static function (mixed $value) use ($jsonForScriptFlags): string {
    $json = json_encode((string)$value, $jsonForScriptFlags);
    return is_string($json) ? $json : '""';
};
$escapeAttr = static function (mixed $value): string {
    return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
};
?>

<!-- 消息提示 -->
<div class='row mb-3'>
    <template>Weline_Component::message.phtml</template>
</div>

<!-- 操作栏 -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a href="<?= $this->getBackendUrl('*/backend/domain/form') ?>" class="btn btn-primary">
            <i class="mdi mdi-plus"></i> <?= __('添加域名') ?>
        </a>
        <w:hook>Weline_Cdn::backend::partials::domain::toolbar-after</w:hook>
    </div>
    <div>
        <form method="get" class="d-inline-flex gap-2">
            <input type="text" name="search" class="form-control form-control-sm" 
                   placeholder="<?= __('搜索域名') ?>" 
                   value="<?= htmlspecialchars($search) ?>">
            <select name="adapter" class="form-select form-select-sm">
                <option value=""><?= __('所有适配器') ?></option>
                <?php foreach ($adapters as $adapterCode => $adapterInstance): ?>
                    <option value="<?= $adapterCode ?>" <?= $adapter === $adapterCode ? 'selected' : '' ?>>
                        <?= htmlspecialchars($adapterInstance->getAdapterName()) ?>
                    </option>
                <?php endforeach; ?>
            </select>
            <select name="enabled" class="form-select form-select-sm">
                <option value=""><?= __('全部状态') ?></option>
                <option value="1" <?= $enabled === '1' ? 'selected' : '' ?>><?= __('启用') ?></option>
                <option value="0" <?= $enabled === '0' ? 'selected' : '' ?>><?= __('禁用') ?></option>
            </select>
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="mdi mdi-magnify"></i> <?= __('搜索') ?>
            </button>
            <a href="<?= $this->getBackendUrl('*/backend/domain/index') ?>" class="btn btn-sm btn-secondary">
                <i class="mdi mdi-refresh"></i> <?= __('重置') ?>
            </a>
        </form>
    </div>
</div>

<!-- 域名列表 -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><?= __('ID') ?></th>
                        <th><?= __('域名名称') ?></th>
                        <th><?= __('网站名称') ?></th>
                        <th><?= __('适配器') ?></th>
                        <th><?= __('Zone ID') ?></th>
                        <th><?= __('状态') ?></th>
                        <th><?= __('创建时间') ?></th>
                        <th><?= __('操作') ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php if (empty($domains)): ?>
                        <tr>
                            <td colspan="8" class="text-center py-4"><?= __('暂无数据') ?></td>
                        </tr>
                    <?php else: ?>
                        <?php foreach ($domains as $domain): ?>
                            <?php
                            $siteId = (int)$domain->getData('site_id');
                            $website = $websites[$siteId] ?? null;
                            $websiteName = $website ? htmlspecialchars((string)($website['name'] ?? __('未知网站'))) : __('未知网站');
                            ?>
                            <tr>
                                <td><?= $domain->getData('domain_id') ?></td>
                                <td><?= htmlspecialchars($domain->getData('domain_name')) ?></td>
                                <td><?= $websiteName ?></td>
                                <td>
                                    <span class="badge bg-info"><?= htmlspecialchars($domain->getData('adapter')) ?></span>
                                </td>
                                <td><code><?= htmlspecialchars($domain->getData('zone_id')) ?></code></td>
                                <td>
                                    <?php if ($domain->getData('enabled')): ?>
                                        <span class="badge bg-success"><?= __('启用') ?></span>
                                    <?php else: ?>
                                        <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= date('Y-m-d H:i:s', $domain->getData('created_at')) ?></td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="<?= $this->getBackendUrl('*/backend/domain/form', ['id' => $domain->getData('domain_id')]) ?>" 
                                           class="btn btn-primary">
                                            <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                                        </a>
                                        <button type="button" class="btn btn-<?= $domain->getData('enabled') ? 'warning' : 'success' ?>" 
                                                data-cdn-domain-action="toggle-enable"
                                                data-domain-id="<?= $escapeAttr($domain->getData('domain_id')) ?>"
                                                data-enabled="<?= $domain->getData('enabled') ? '0' : '1' ?>">
                                            <i class="mdi mdi-<?= $domain->getData('enabled') ? 'close' : 'check' ?>"></i> 
                                            <?= $domain->getData('enabled') ? __('禁用') : __('启用') ?>
                                        </button>
                                        <button type="button" class="btn btn-info" 
                                                data-cdn-domain-action="clear-cache"
                                                data-domain-id="<?= $escapeAttr($domain->getData('domain_id')) ?>">
                                            <i class="mdi mdi-delete-sweep"></i> <?= __('清理缓存') ?>
                                        </button>
                                        <button type="button"
                                                class="btn btn-danger"
                                                w-delete="true"
                                                w-url="<?= $this->getBackendUrl('*/backend/domain/postDelete') ?>"
                                                w-method="POST"
                                                w-var-id="<?= $domain->getData('domain_id') ?>"
                                                w-msg="<?= __('确定要删除域名 "%{1}" 吗？此操作不可恢复！', htmlspecialchars($domain->getData('domain_name'))) ?>">
                                            <i class="mdi mdi-delete"></i> <?= __('删除') ?>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- 分页 -->
    <?php if ($totalPages > 1): ?>
        <div class="card-footer">
            <nav>
                <ul class="pagination justify-content-center mb-0">
                    <?php if ($page > 1): ?>
                        <li class="page-item">
                            <a class="page-link" href="?page=<?= $page - 1 ?>&search=<?= urlencode($search) ?>&adapter=<?= urlencode($adapter) ?>&enabled=<?= urlencode($enabled) ?>">
                                <?= __('上一页') ?>
                            </a>
                        </li>
                    <?php endif; ?>
                    <?php for ($i = 1; $i <= $totalPages; $i++): ?>
                        <li class="page-item <?= $i === $page ? 'active' : '' ?>">
                            <a class="page-link" href="?page=<?= $i ?>&search=<?= urlencode($search) ?>&adapter=<?= urlencode($adapter) ?>&enabled=<?= urlencode($enabled) ?>">
                                <?= $i ?>
                            </a>
                        </li>
                    <?php endfor; ?>
                    <?php if ($page < $totalPages): ?>
                        <li class="page-item">
                            <a class="page-link" href="?page=<?= $page + 1 ?>&search=<?= urlencode($search) ?>&adapter=<?= urlencode($adapter) ?>&enabled=<?= urlencode($enabled) ?>">
                                <?= __('下一页') ?>
                            </a>
                        </li>
                    <?php endif; ?>
                </ul>
            </nav>
            <div class="text-center text-muted mt-2">
                <?= __('共 %{1} 条记录，第 %{2}/%{3} 页', [$total, $page, $totalPages]) ?>
            </div>
        </div>
    <?php endif; ?>
</div>

<js:part name="w-delete"/>

<js:part>
(function() {
    'use strict';
    
    var toggleEnableUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/domain/toggleEnable')) ?>;
    var clearCacheUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/domain/clearCache')) ?>;

    function confirmAction(message, onConfirm) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(message).then(function(confirmed) {
                if (confirmed) {
                    onConfirm();
                }
            });
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.error === 'function') {
            window.BackendToast.error('<?= __('确认组件不可用，请刷新页面后重试。') ?>');
        }
    }

    document.addEventListener('click', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-domain-action]')
            : null;
        if (!target) {
            return;
        }

        if (target.dataset.cdnDomainAction === 'toggle-enable') {
            window.CdnDomainManager.toggleEnable(target.dataset.domainId || '', target.dataset.enabled || '0');
            return;
        }

        if (target.dataset.cdnDomainAction === 'clear-cache') {
            window.CdnDomainManager.clearCache(target.dataset.domainId || '');
        }
    });

    window.CdnDomainManager = {
        toggleEnable: function(id, enabled) {
            window.Weline.Api.request(toggleEnableUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, enabled: enabled }).toString()
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        BackendToast.success(data.message);
                        setTimeout(function() { location.reload(); }, 1500);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('操作失败') ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        BackendToast.error(data.message);
                    }
                }
            });
        },
        
        clearCache: function(id) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '<?= __('确认清理缓存') ?>',
                    text: '<?= __('确定要清理该域名的所有缓存吗？') ?>',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: '<?= __("确定清理") ?>',
                    cancelButtonText: '<?= __("取消") ?>',
                    confirmButtonColor: '#ff9800'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        window.CdnDomainManager.performClearCache(id);
                    }
                });
            } else {
                confirmAction('<?= __('确定要清理该域名的所有缓存吗？') ?>', function() {
                    window.CdnDomainManager.performClearCache(id);
                });
            }
        },
        
        performClearCache: function(id) {
            window.Weline.Api.request(clearCacheUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, mode: 'everything' }).toString()
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        BackendToast.success(data.message);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('清理失败') ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        BackendToast.error(data.message);
                    }
                }
            });
        }
    };
})();
</js:part>
