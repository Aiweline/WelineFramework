<script>
document.getElementById('domainForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    fetch(this.action, {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            if (data.redirect) {
                window.location.href = data.redirect;
            } else {
                window.location.href = '<?= $this->getBackendUrl('*/backend/domain/index') ?>';
            }
        } else {
            alert('<?= __('保存失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    });
});

// 账户数据（按适配器分组）
const accountsByAdapter = <?= json_encode($accounts, JSON_UNESCAPED_UNICODE) ?>;
const currentDomainAccountId = <?= $domain && $domain->getData('account_id') ? (int)$domain->getData('account_id') : 'null' ?>;

// 更新账户选择框
function updateAccountSelect(adapterCode) {
    const accountSelect = document.getElementById('accountSelect');
    const inheritDefault = document.getElementById('inheritDefault');
    
    // 清空现有选项
    accountSelect.innerHTML = '<option value=""><?= __('请选择账户（可选）') ?></option>';
    
    if (!adapterCode) {
        accountSelect.disabled = true;
        accountSelect.innerHTML = '<option value=""><?= __('请先选择适配器') ?></option>';
        return;
    }
    
    // 获取该适配器的账户列表
    const accounts = accountsByAdapter[adapterCode] || [];
    
    if (accounts.length === 0) {
        accountSelect.disabled = false;
        accountSelect.innerHTML = '<option value=""><?= __('该适配器暂无可用账户') ?></option>';
        return;
    }
    
    // 填充账户选项
    accounts.forEach(function(account) {
        const option = document.createElement('option');
        option.value = account.account_id;
        option.textContent = account.name + (account.is_default ? ' (默认)' : '');
        
        // 如果是编辑模式且当前域名使用此账户，则选中
        if (currentDomainAccountId && currentDomainAccountId == account.account_id) {
            option.selected = true;
        }
        
        accountSelect.appendChild(option);
    });
    
    // 启用选择框（如果未勾选继承默认账户）
    accountSelect.disabled = inheritDefault.checked;
}

// 适配器选择变化时更新账户列表
document.getElementById('adapterSelect').addEventListener('change', function() {
    updateAccountSelect(this.value);
});

// 继承默认账户时禁用账户选择
document.getElementById('inheritDefault').addEventListener('change', function() {
    const accountSelect = document.getElementById('accountSelect');
    accountSelect.disabled = this.checked;
});

// 页面加载时，如果已选择适配器，初始化账户列表
document.addEventListener('DOMContentLoaded', function() {
    const adapterSelect = document.getElementById('adapterSelect');
    if (adapterSelect.value) {
        updateAccountSelect(adapterSelect.value);
    }
});

// 选择网站时自动填充域名名称
document.getElementById('siteSelect').addEventListener('change', function() {
    const selectedOption = this.options[this.selectedIndex];
    const siteUrl = selectedOption.getAttribute('data-url');
    const domainNameInput = document.getElementById('domainNameInput');
    
    if (siteUrl && domainNameInput && !domainNameInput.value) {
        try {
            // 从 URL 中提取域名
            const url = new URL(siteUrl);
            const hostname = url.hostname;
            
            // 如果 hostname 存在，自动填充域名名称
            if (hostname) {
                domainNameInput.value = hostname;
            }
        } catch (e) {
            // 如果 URL 解析失败，尝试从 URL 中提取域名部分
            const match = siteUrl.match(/^(?:https?:\/\/)?(?:www\.)?([^\/]+)/i);
            if (match && match[1]) {
                domainNameInput.value = match[1];
            }
        }
    }
});
</script>

