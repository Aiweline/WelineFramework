<js:part>
(function() {
    'use strict';
    
    var indexUrl = '<?= $this->getBackendUrl('*/backend/domain/index') ?>';
    var accountsByAdapter = <?= json_encode($accounts, $jsonForScriptFlags) ?>;
    var currentDomainAccountId = <?= $domain && $domain->getData('account_id') ? (int)$domain->getData('account_id') : 'null' ?>;
    
    var domainForm = document.getElementById('domainForm');
    var adapterSelect = document.getElementById('adapterSelect');
    var accountSelect = document.getElementById('accountSelect');
    var inheritDefault = document.getElementById('inheritDefault');
    var siteSelect = document.getElementById('siteSelect');
    var domainNameInput = document.getElementById('domainNameInput');
    
    function updateAccountSelect(adapterCode) {
        accountSelect.innerHTML = '<option value=""><?= __('请选择账户（可选）') ?></option>';
        
        if (!adapterCode) {
            accountSelect.disabled = true;
            accountSelect.innerHTML = '<option value=""><?= __('请先选择适配器') ?></option>';
            return;
        }
        
        var accounts = accountsByAdapter[adapterCode] || [];
        
        if (accounts.length === 0) {
            accountSelect.disabled = false;
            accountSelect.innerHTML = '<option value=""><?= __('该适配器暂无可用账户') ?></option>';
            return;
        }
        
        accounts.forEach(function(account) {
            var option = document.createElement('option');
            option.value = account.account_id;
            option.textContent = account.name + (account.is_default ? ' (默认)' : '');
            
            if (currentDomainAccountId && currentDomainAccountId == account.account_id) {
                option.selected = true;
            }
            
            accountSelect.appendChild(option);
        });
        
        accountSelect.disabled = inheritDefault.checked;
    }
    
    if (adapterSelect) {
        adapterSelect.addEventListener('change', function() {
            updateAccountSelect(this.value);
        });
    }
    
    if (inheritDefault) {
        inheritDefault.addEventListener('change', function() {
            accountSelect.disabled = this.checked;
        });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        if (adapterSelect && adapterSelect.value) {
            updateAccountSelect(adapterSelect.value);
        }
    });
    
    if (siteSelect) {
        siteSelect.addEventListener('change', function() {
            var selectedOption = this.options[this.selectedIndex];
            var siteUrl = selectedOption.getAttribute('data-url');
            
            if (siteUrl && domainNameInput && !domainNameInput.value) {
                try {
                    var url = new URL(siteUrl);
                    var hostname = url.hostname;
                    
                    if (hostname) {
                        domainNameInput.value = hostname;
                    }
                } catch (e) {
                    var match = siteUrl.match(/^(?:https?:\/\/)?(?:www\.)?([^\/]+)/i);
                    if (match && match[1]) {
                        domainNameInput.value = match[1];
                    }
                }
            }
        });
    }
    
    if (domainForm) {
        domainForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            var formData = new FormData(this);
            
            var url = this.action;
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() {
                            window.location.href = data.redirect || indexUrl;
                        });
                    } else {
                        BackendToast.success(data.message);
                        setTimeout(function() {
                            window.location.href = data.redirect || indexUrl;
                        }, 1500);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        BackendToast.error(data.message);
                    }
                }
            })
            .catch(function(error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('请求失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    BackendToast.error(error.message);
                }
            });
        });
    }
})();
</js:part>
