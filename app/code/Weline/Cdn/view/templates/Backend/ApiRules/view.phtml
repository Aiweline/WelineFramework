<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
function toggleRule(ruleId, enabled) {
    fetch('<?= $this->getBackendUrl('*/backend/api-rules/toggle') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: ruleId,
            enabled: enabled ? 1 : 0
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => window.location.reload());
            } else {
                console.log(data.message);
                window.location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: data.message || '<?= __('操作失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('操作失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('操作失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('操作失败') ?>');
        }
    });
}

function deleteRule(ruleId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认删除') ?>',
            text: '<?= __('确定要删除这条规则吗？') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定删除") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#d33'
        }).then((result) => {
            if (result.isConfirmed) {
                performDelete(ruleId);
            }
        });
    } else {
        if (!confirm('<?= __('确定要删除这条规则吗？') ?>')) {
            return;
        }
        performDelete(ruleId);
    }
}

function performDelete(ruleId) {
    fetch('<?= $this->getBackendUrl('*/backend/api-rules/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: ruleId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '<?= $this->getBackendUrl('*/backend/api-rules/index') ?>';
                });
            } else {
                console.log(data.message);
                window.location.href = '<?= $this->getBackendUrl('*/backend/api-rules/index') ?>';
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('删除失败') ?>',
                    text: data.message || '<?= __('删除失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('删除失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('删除失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('删除失败') ?>');
        }
    });
}
</script>

