<js:part>
(function() {
    'use strict';
    
    var toggleUrl = '<?= $this->getBackendUrl('*/backend/api-rules/toggle') ?>';
    var deleteUrl = '<?= $this->getBackendUrl('*/backend/api-rules/delete') ?>';
    var indexUrl = '<?= $this->getBackendUrl('*/backend/api-rules/index') ?>';
    
    window.CdnApiRuleDetailManager = {
        toggleRule: function(ruleId, enabled) {
            fetch(toggleUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    id: ruleId,
                    enabled: enabled ? 1 : 0
                })
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function() { window.location.reload(); });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message || '<?= __('操作失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(function(error) {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        },
        
        deleteRule: function(ruleId) {
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                text: '<?= __('确定要删除这条规则吗？') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定删除") ?>',
                cancelButtonText: '<?= __("取消") ?>',
                confirmButtonColor: '#d33'
            }).then(function(result) {
                if (result.isConfirmed) {
                    fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ id: ruleId })
                    })
                    .then(function(response) { return response.json(); })
                    .then(function(data) {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: data.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() {
                                window.location.href = indexUrl;
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('删除失败') ?>',
                                text: data.message || '<?= __('删除失败') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('删除失败') ?>',
                            text: '<?= __('请重试') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        }
    };
})();
</js:part>
