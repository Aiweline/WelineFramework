<js:part>
(function() {
    'use strict';
    
    var indexUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/api-rules/index')) ?>;
    var collectUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/api-rules/collect')) ?>;
    var toggleUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/api-rules/toggle')) ?>;
    var viewUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/api-rules/view')) ?>;
    var deleteUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/api-rules/delete')) ?>;

    document.addEventListener('change', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-api-rules-action]')
            : null;
        if (!target) {
            return;
        }

        if (target.dataset.cdnApiRulesAction === 'filter') {
            window.CdnApiRulesManager.filterRules();
            return;
        }

        if (target.dataset.cdnApiRulesAction === 'toggle') {
            window.CdnApiRulesManager.toggleRule(target.dataset.ruleId || '', target.checked);
        }
    });

    document.addEventListener('click', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-api-rules-action]')
            : null;
        if (!target) {
            return;
        }

        if (target.dataset.cdnApiRulesAction === 'collect') {
            window.CdnApiRulesManager.collectRules();
            return;
        }

        if (target.dataset.cdnApiRulesAction === 'view') {
            window.CdnApiRulesManager.viewRule(target.dataset.ruleId || '');
            return;
        }

        if (target.dataset.cdnApiRulesAction === 'delete') {
            window.CdnApiRulesManager.deleteRule(target.dataset.ruleId || '');
        }
    });

    window.CdnApiRulesManager = {
        filterRules: function() {
            var module = document.getElementById('moduleFilter').value;
            var trigger = document.getElementById('triggerFilter').value;
            var params = new URLSearchParams();
            if (module) params.append('module', module);
            if (trigger) params.append('trigger', trigger);
            window.location.href = indexUrl + (params.toString() ? '?' + params.toString() : '');
        },
        
        collectRules: function() {
            Swal.fire({
                title: '<?= __('确认收集规则') ?>',
                text: '<?= __('确定要重新收集规则吗？这将扫描所有Api和Controller目录。') ?>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定收集") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    window.Weline.Api.request(collectUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function(response) {
                        var data = response.data;
                        if (response.ok && data && data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: data.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() { window.location.reload(); });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('收集失败') ?>',
                                text: (data && data.message) || '<?= __('收集失败') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('收集失败') ?>',
                            text: (error && error.message) || '<?= __('请重试') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        },
        
        toggleRule: function(ruleId, enabled) {
            window.Weline.Api.request(toggleUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    id: ruleId,
                    enabled: enabled ? 1 : 0
                })
            })
            .then(function(response) {
                var data = response.data;
                if (!(response.ok && data && data.success)) {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message || '<?= __('操作失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                    document.getElementById('rule_' + ruleId).checked = !enabled;
                }
            })
            .catch(function(error) {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
                document.getElementById('rule_' + ruleId).checked = !enabled;
            });
        },
        
        viewRule: function(ruleId) {
            window.location.href = viewUrl + '?id=' + encodeURIComponent(ruleId);
        },
        
        deleteRule: function(ruleId) {
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                text: '<?= __('确定要删除这条规则吗？') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定删除") ?>',
                cancelButtonText: '<?= __("取消") ?>',
                confirmButtonColor: '#d33'
            }).then(function(result) {
                if (result.isConfirmed) {
                    window.Weline.Api.request(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ id: ruleId })
                    })
                    .then(function(response) {
                        var data = response.data;
                        if (response.ok && data && data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: data.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() { window.location.reload(); });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('删除失败') ?>',
                                text: data.message || '<?= __('删除失败') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('删除失败') ?>',
                            text: (error && error.message) || '<?= __('请重试') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        }
    };
})();
</js:part>
