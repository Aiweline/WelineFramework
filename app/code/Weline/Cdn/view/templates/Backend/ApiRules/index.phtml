$groupedRules = $this->getData('groupedRules') ?: [];
$rules = $this->getData('rules') ?: [];
$module = $this->getData('module') ?: '';
$trigger = $this->getData('trigger') ?: '';
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT;
$jsonForScript = static function (mixed $value) use ($jsonForScriptFlags): string {
    $json = json_encode((string)$value, $jsonForScriptFlags);
    return is_string($json) ? $json : '""';
};
$escapeAttr = static function (mixed $value): string {
    return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
};
?>

