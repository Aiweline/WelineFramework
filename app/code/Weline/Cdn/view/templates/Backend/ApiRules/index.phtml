<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
function filterRules() {
    const module = document.getElementById('moduleFilter').value;
    const trigger = document.getElementById('triggerFilter').value;
    const params = new URLSearchParams();
    if (module) params.append('module', module);
    if (trigger) params.append('trigger', trigger);
    window.location.href = '<?= $this->getBackendUrl('*/backend/api-rules/index') ?>' + (params.toString() ? '?' + params.toString() : '');
}

function collectRules() {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认收集规则') ?>',
            text: '<?= __('确定要重新收集规则吗？这将扫描所有Api和Controller目录。') ?>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定收集") ?>',
            cancelButtonText: '<?= __("取消") ?>'
        }).then((result) => {
            if (result.isConfirmed) {
                performCollect();
            }
        });
    } else {
        if (!confirm('<?= __('确定要重新收集规则吗？这将扫描所有Api和Controller目录。') ?>')) {
            return;
        }
        performCollect();
    }
}

function performCollect() {
    fetch('<?= $this->getBackendUrl('*/backend/api-rules/collect') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => window.location.reload());
            } else {
                console.log(data.message);
                window.location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('收集失败') ?>',
                    text: data.message || '<?= __('收集失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('收集失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('收集失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('收集失败') ?>');
        }
    });
}

function toggleRule(ruleId, enabled) {
    fetch('<?= $this->getBackendUrl('*/backend/api-rules/toggle') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: ruleId,
            enabled: enabled ? 1 : 0
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 可以显示成功提示
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: data.message || '<?= __('操作失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('操作失败') ?>');
            }
            // 恢复状态
            document.getElementById('rule_' + ruleId).checked = !enabled;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('操作失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('操作失败') ?>');
        }
        document.getElementById('rule_' + ruleId).checked = !enabled;
    });
}

function viewRule(ruleId) {
    window.location.href = '<?= $this->getBackendUrl('*/backend/api-rules/view') ?>?id=' + ruleId;
}

function deleteRule(ruleId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认删除') ?>',
            text: '<?= __('确定要删除这条规则吗？') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定删除") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#d33'
        }).then((result) => {
            if (result.isConfirmed) {
                performDelete(ruleId);
            }
        });
    } else {
        if (!confirm('<?= __('确定要删除这条规则吗？') ?>')) {
            return;
        }
        performDelete(ruleId);
    }
}

function performDelete(ruleId) {
    fetch('<?= $this->getBackendUrl('*/backend/api-rules/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: ruleId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => window.location.reload());
            } else {
                console.log(data.message);
                window.location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('删除失败') ?>',
                    text: data.message || '<?= __('删除失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('删除失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('删除失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('删除失败') ?>');
        }
    });
}
</script>

