<script>
function executeWarmup() {
    if (!confirm('<?= __('确定要执行预热吗？这将处理所有待处理的URL。') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/warmup/execute') ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('执行失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    });
}

function toggleEnable(id, enabled) {
    fetch('<?= $this->getBackendUrl('*/backend/warmup/toggleEnable') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id + '&enabled=' + enabled
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

function deleteUrl(id) {
    if (!confirm('<?= __('确定要删除此URL吗？') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/warmup/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('删除失败：') ?>' + data.message);
        }
    });
}
</script>

