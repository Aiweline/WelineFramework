<js:part>
(function() {
    'use strict';
    
    var executeUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/warmup/execute')) ?>;
    var toggleEnableUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/warmup/toggleEnable')) ?>;
    var deleteUrl = <?= $jsonForScript($this->getBackendUrl('*/backend/warmup/delete')) ?>;

    function confirmAction(message, onConfirm) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(message).then(function(confirmed) {
                if (confirmed) {
                    onConfirm();
                }
            });
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.error === 'function') {
            window.BackendToast.error('<?= __('确认组件不可用，请刷新页面后重试。') ?>');
        }
    }

    document.addEventListener('click', function(event) {
        var target = event.target instanceof Element
            ? event.target.closest('[data-cdn-warmup-action]')
            : null;
        if (!target) {
            return;
        }

        if (target.dataset.cdnWarmupAction === 'execute') {
            window.CdnWarmupManager.executeWarmup();
            return;
        }

        if (target.dataset.cdnWarmupAction === 'toggle-enable') {
            window.CdnWarmupManager.toggleEnable(target.dataset.urlId || '', target.dataset.enabled || '0');
            return;
        }

        if (target.dataset.cdnWarmupAction === 'delete') {
            window.CdnWarmupManager.deleteUrl(target.dataset.urlId || '');
        }
    });
    
    window.CdnWarmupManager = {
        executeWarmup: function() {
            Swal.fire({
                title: '<?= __('确认执行预热') ?>',
                text: '<?= __('确定要执行预热吗？这将处理所有待处理的URL。') ?>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定执行") ?>',
                cancelButtonText: '<?= __("取消") ?>',
                confirmButtonColor: '#28a745'
            }).then(function(result) {
                if (result.isConfirmed) {
                    window.Weline.Api.request(executeUrl, { method: 'POST' })
                    .then(function(response) {
                        var data = response.data;
                        if (response.ok && data && data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: data.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() { location.reload(); });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('执行失败') ?>',
                                text: data.message,
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    })
                    .catch(function(error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('请求失败') ?>',
                            text: error.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    });
                }
            });
        },
        
        toggleEnable: function(id, enabled) {
            window.Weline.Api.request(toggleEnableUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, enabled: enabled }).toString()
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function() { location.reload(); });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            });
        },
        
        deleteUrl: function(id) {
            confirmAction('<?= __('确定要删除此URL吗？') ?>', function() {
                window.Weline.Api.request(deleteUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ id: id }).toString()
                })
                .then(function(response) {
                    var data = response.data;
                    if (response.ok && data && data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('删除失败') ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    }
                });
            });
        }
    };
})();
</js:part>
