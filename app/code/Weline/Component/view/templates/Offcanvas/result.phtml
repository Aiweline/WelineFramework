<?php
$jsonEncodeFlags = JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT;
?>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
</head>
<body data-offcanvas-result="<?= htmlspecialchars((string)($type ?? 'success'), ENT_QUOTES, 'UTF-8') ?>">
<script>
(function() {
    'use strict';
    var type = <?= json_encode($type ?? 'success', $jsonEncodeFlags) ?>;
    var msg = <?= json_encode($msg ?? '', $jsonEncodeFlags) ?>;
    var url = <?= json_encode($url ?? '', $jsonEncodeFlags) ?>;
    var reload = <?= json_encode(!empty($reload), $jsonEncodeFlags) ?>;
    var parentWin = window.parent;
    var Toast = parentWin && parentWin.BackendToast;
    if (Toast) {
        if (type === 'error') {
            Toast.error(msg);
        } else if (type === 'info') {
            Toast.info(msg);
        } else {
            Toast.success(msg);
        }
    }
    try {
        var closeBtn = parentWin.document.querySelector('.offcanvas .offcanvas-header .btn-close');
        if (closeBtn) closeBtn.click();
        if (reload) {
            parentWin.location.reload();
        } else if (url) {
            parentWin.location.href = url;
        }
    } catch (e) {
        console.log('Offcanvas result:', e);
    }
})();
</script>
</body>
</html>
