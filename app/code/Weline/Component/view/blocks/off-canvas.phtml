<{{target_tag}} class='{{target_button_class}}' type='button' data-bs-toggle='offcanvas'
data-bs-target='#{{id}}' aria-controls='{{id}}' title='{{title|""}}'>
<?php if (!empty($icon)): ?>
    <i class='<?= $icon ?>'></i>
<?php endif; ?>
<lang>{{target_button_text|''}}</lang>
</{{target_tag}}>
<!-- {{id}} -->
<div class='offcanvas {{class_names}}' tabindex='-1' id='{{id}}'
     aria-labelledby='{{id}}Label'>
    <div class='offcanvas-header'>
        <h5 id='{{id}}Label'>
            <?php if (!empty($icon)): ?>
                <i class='<?= $icon ?>'></i>
            <?php endif; ?>
            <lang>{{title|''}}</lang>
        </h5>
        <has name='close_button_show'>
            <button type='button' class='btn-close text-reset {{submit_button_class}}' data-bs-dismiss='offcanvas'
                    aria-label='{{close_button_text}}'></button>
        </has>
    </div>
    <div class='offcanvas-body'>
        <div class='position-relative w-100 h-100'>
            <if condition='flush || save'>
                <div class='btn btn-group-justified sticky-top pull-right gap-2 d-flex'>
                    <if condition='flush'>
                        <button class='{{flush_button_class}} pull-right ' onclick='{{id}}flushIframe()'>
                            <lang>{{flush_button_text}}</lang>
                        </button>
                    </if>
                    <if condition='save'>
                        <button class='{{submit_button_class}} pull-right' id="{{id}}Save">
                            <lang>{{submit_button_text|'保存'}}</lang>
                        </button>
                    </if>
                </div>
            </if>
            <iframe id='{{id}}Iframe' class='w-100 h-100'
                    data-src='{{action}}'
                    frameborder='0'></iframe>
        </div>
    </div>
</div>
<script>
    //show.bs.offcanvas
    $(function () {
        $('#{{id}}').on('show.bs.offcanvas', function () {
            var Iframe = $('#{{id}}Iframe')
            Iframe.attr('src', Iframe.attr('data-src'))
            if ('{{save}}' === '1') {
                // Iframe加载完成后
                Iframe.on('load', function () {
                    try {
                        // 优先看 iframe 内 body 是否有 data-offcanvas-result（success/error 模板会输出），有则一律不检测 form
                        try {
                            var resultAttr = Iframe.contents().find('body').attr('data-offcanvas-result');
                            if (resultAttr === 'success' || resultAttr === 'error') {
                                return;
                            }
                        } catch (e) {}
                        // 再按 URL 判断：成功/错误页（前端或后端路由）不检测 form
                        var iframeSrc = Iframe.attr('src') || '';
                        var iframeLocation = '';
                        try { iframeLocation = Iframe[0].contentWindow.location.href || ''; } catch (e) {}
                        var u = iframeSrc + ' ' + iframeLocation;
                        var isOffcanvasResultPage = u.indexOf('/component/offcanvas/') !== -1 ||
                                                    u.indexOf('/component/backend/offcanvas/') !== -1 ||
                                                    /offcanvas\/(getSuccess|getError|success|error)([\?\/\s]|$)/i.test(u);
                        if (isOffcanvasResultPage) {
                            return;
                        }
                        
                        <?php if (isset($save_form) and $save_form): ?>
                        var form = Iframe.contents().find('body').find('{{save_form}}');
                        form = (form && form.length > 0) ? form : undefined;
                        <?php else: ?>
                        var form = Iframe.contents().find('body').find('form');
                        form = (form && form.length > 0) ? form : undefined;
                        <?php endif; ?>
                        if (form !== undefined && form.length > 0) {
                            for (var i = 0; i < form.length; i++) {
                                // 触发原生表单校验
                                if ($(form[i]).find(':submit').length === 0) {
                                    form[i].insertAdjacentHTML('beforeend', '<input type="submit" class="sr-only">')
                                }
                            }
                        } else {
                            <?php if (DEBUG) {
                           $msg = __("DEBUG模式：初始化错误,请检查表单是否正确!block【Weline\\Component\\Block\\OffCanvas】指定提交form表单未找到：%{1}}", $save_form ?? '');
                           // 转义一下
                           $msg = htmlspecialchars($msg);
                           echo " confirm('{$msg}');";
                            }
                            ?>
                        }
                    } catch (e) {
                        // 跨域或其他错误时忽略
                        console.log('OffCanvas form check skipped:', e);
                    }
                })
            }
        })
    })
</script>
<if condition='flush'>
    <script>
        $(function () {
            window['{{id}}flushIframe'] = function () {
                showLoading();
                let iframe = $('#{{id}}Iframe');
                iframe.attr('src', iframe.attr('src'))
                hideLoading();
            }
        })
    </script>
</if>
<if condition='save'>
    <script>
        $(function () {
            $('#{{id}}Save').on('click', function () {
                let iframe = $('#{{id}}Iframe');
                <?php if ($save_form): ?>
                var form = iframe.contents().find('body').find('{{save_form}}');
                form = (form && form.length > 0) ? form : undefined;
                <?php else: ?>
                var form = iframe.contents().find('body').find('form');
                form = (form && form.length > 0) ? form : undefined;
                <?php endif; ?>

                try {
                    // 优先看 body 的 data-offcanvas-result 标记，有则不检测 form
                    try {
                        var resultAttr = iframe.contents().find('body').attr('data-offcanvas-result');
                        if (resultAttr === 'success' || resultAttr === 'error') {
                            return;
                        }
                    } catch (e) {}
                    var iframeSrc = iframe.attr('src') || '';
                    var iframeLocation = '';
                    try { iframeLocation = iframe[0].contentWindow.location.href || ''; } catch (e) {}
                    var u = iframeSrc + ' ' + iframeLocation;
                    var isOffcanvasResultPage = u.indexOf('/component/offcanvas/') !== -1 ||
                                                u.indexOf('/component/backend/offcanvas/') !== -1 ||
                                                /offcanvas\/(getSuccess|getError|success|error)([\?\/\s]|$)/i.test(u);
                    if (isOffcanvasResultPage) {
                        return;
                    }
                    
                    if (form !== undefined && form.length > 0) {
                        for (var i = 0; i < form.length; i++) {
                            let sub_form = $(form[i])
                            sub_form.find(':submit').click()
                            showLoading();
                        }
                        hideLoading();
                    } else {
                        <?php if (DEBUG) {
                        $msg = __("DEBUG模式：保存出错！请检查表单是否正确!block【Weline\\Component\\Block\\OffCanvas】指定提交form表单未找到：%{1}}", $save_form ?? '');
                        // 转义一下
                        $msg = htmlspecialchars($msg);
                       echo " confirm('{$msg}');";
                    }
                        ?>
                    }
                } catch (e) {
                    // 跨域或其他错误时忽略
                    console.log('OffCanvas form submit check skipped:', e);
                }
            })
        })
    </script>
</if>
