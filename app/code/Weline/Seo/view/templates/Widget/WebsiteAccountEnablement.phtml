$fieldName = static function (string $path, bool $isArray = false) use ($fieldPrefix): string {
    if ($fieldPrefix === '') {
        return $path . ($isArray ? '[]' : '');
    }

    $name = $fieldPrefix;
    foreach (explode('.', $path) as $part) {
        if ($part === '') {
            continue;
        }
        $name .= '[' . $part . ']';
    }

    return $name . ($isArray ? '[]' : '');
};

