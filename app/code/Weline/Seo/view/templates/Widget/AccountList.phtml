<?php
/**
 * SEO 账户列表 Widget 模板
 * 
 * 可复用的 SEO 账户列表展示组件
 * 支持按 scope/module 过滤，以只读方式展示账户信息
 * 
 * @var \Weline\Framework\View\Template $this
 * @var string $widget_id Widget 唯一ID
 * @var string $scope 业务 scope
 * @var string $module 模块名
 * @var bool $readonly 是否只读模式
 * @var string $title 标题
 * @var array $accounts 账户列表
 * @var string $manage_url SEO 管理页面链接
 * @var bool $show_manage_link 是否显示管理链接
 * @var bool $has_accounts 是否有账户
 */
?>
<div id="<?= htmlspecialchars($widget_id, ENT_QUOTES) ?>" class="seo-account-widget card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="mdi mdi-account-key me-2"></i><?= htmlspecialchars($title, ENT_QUOTES) ?>
        </h5>
        <?php if ($show_manage_link): ?>
        <a href="<?= htmlspecialchars($manage_url, ENT_QUOTES) ?>" 
           class="btn btn-sm btn-outline-primary"
           target="_blank">
            <i class="mdi mdi-cog me-1"></i>
            <lang>前往SEO管理配置</lang>
        </a>
        <?php endif; ?>
    </div>
    <div class="card-body">
        <?php if (!$has_accounts): ?>
        <div class="alert alert-info mb-0">
            <i class="mdi mdi-information-outline me-2"></i>
            <lang>暂无SEO账户配置</lang>
            <?php if ($show_manage_link): ?>
            <a href="<?= htmlspecialchars($manage_url, ENT_QUOTES) ?>" class="alert-link ms-2" target="_blank">
                <lang>点击前往配置</lang>
            </a>
            <?php endif; ?>
        </div>
        <?php else: ?>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th width="60"><lang>ID</lang></th>
                        <th><lang>名称</lang></th>
                        <th><lang>供应商</lang></th>
                        <th width="80" class="text-center"><lang>状态</lang></th>
                        <th width="100" class="text-center"><lang>URL推送</lang></th>
                        <th width="100" class="text-center"><lang>Sitemap提交</lang></th>
                        <?php if (!$readonly): ?>
                        <th width="80" class="text-center"><lang>操作</lang></th>
                        <?php endif; ?>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($accounts as $account): ?>
                    <tr>
                        <td><?= (int)($account['account_id'] ?? 0) ?></td>
                        <td>
                            <strong><?= htmlspecialchars((string)($account['name'] ?? ''), ENT_QUOTES) ?></strong>
                            <?php if (!empty($account['description'])): ?>
                            <br><small class="text-muted"><?= htmlspecialchars((string)$account['description'], ENT_QUOTES) ?></small>
                            <?php endif; ?>
                        </td>
                        <td>
                            <code><?= htmlspecialchars((string)($account['provider'] ?? ''), ENT_QUOTES) ?></code>
                        </td>
                        <td class="text-center">
                            <?php if ((int)($account['is_active'] ?? 0) === 1): ?>
                            <span class="badge bg-success"><lang>启用</lang></span>
                            <?php else: ?>
                            <span class="badge bg-secondary"><lang>禁用</lang></span>
                            <?php endif; ?>
                        </td>
                        <td class="text-center">
                            <?php if ((int)($account['enable_cron_push_urls'] ?? 0) === 1): ?>
                            <span class="badge bg-success"><i class="mdi mdi-check"></i></span>
                            <?php else: ?>
                            <span class="badge bg-light text-dark"><i class="mdi mdi-close"></i></span>
                            <?php endif; ?>
                        </td>
                        <td class="text-center">
                            <?php if ((int)($account['enable_cron_sitemap'] ?? 0) === 1): ?>
                            <span class="badge bg-success"><i class="mdi mdi-check"></i></span>
                            <?php else: ?>
                            <span class="badge bg-light text-dark"><i class="mdi mdi-close"></i></span>
                            <?php endif; ?>
                        </td>
                        <?php if (!$readonly): ?>
                        <td class="text-center">
                            <a href="<?= $this->getBackendUrl('seo/backend/account/form', [
                                'id' => (int)($account['account_id'] ?? 0),
                                'scope' => $scope
                            ]) ?>"
                               class="btn btn-sm btn-outline-primary"
                               target="_blank">
                                <lang>编辑</lang>
                            </a>
                        </td>
                        <?php endif; ?>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
        
        <div class="mt-3 text-muted small">
            <i class="mdi mdi-information-outline me-1"></i>
            <lang>共</lang> <?= count($accounts) ?> <lang>个账户</lang>
            <?php if ($scope || $module): ?>
            <span class="ms-2">
                (<lang>过滤条件</lang>: 
                <?php if ($scope): ?>scope=<code><?= htmlspecialchars($scope, ENT_QUOTES) ?></code><?php endif; ?>
                <?php if ($scope && $module): ?>, <?php endif; ?>
                <?php if ($module): ?>module=<code><?= htmlspecialchars($module, ENT_QUOTES) ?></code><?php endif; ?>
                )
            </span>
            <?php endif; ?>
        </div>
        <?php endif; ?>
    </div>
</div>
