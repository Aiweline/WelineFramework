<script>
// 友好的消息提示函数
function showMessage(type, message, title = null) {
    // 优先使用 SweetAlert2
    if (typeof Swal !== 'undefined') {
        const config = {
            icon: type === 'success' ? 'success' : type === 'error' ? 'error' : 'warning',
            title: title || (type === 'success' ? '<?= __("操作成功") ?>' : '<?= __("操作失败") ?>'),
            text: message,
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: type === 'success' ? 3000 : 5000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer);
                toast.addEventListener('mouseleave', Swal.resumeTimer);
            }
        };
        Swal.fire(config);
    } else {
        // 降级使用 Bootstrap Toast
        const toastContainer = document.getElementById('toast-container') || createToastContainer();
        const toastId = 'toast-' + Date.now();
        const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-warning';
        const icon = type === 'success' ? 'mdi-check-circle' : type === 'error' ? 'mdi-alert-circle' : 'mdi-alert';
        
        const toastHtml = `
            <div id="${toastId}" class="toast ${bgClass} text-white" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 300px;">
                <div class="toast-header ${bgClass} text-white border-0">
                    <i class="mdi ${icon} me-2"></i>
                    <strong class="me-auto">${title || (type === 'success' ? '<?= __("操作成功") ?>' : '<?= __("操作失败") ?>')}</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    ${message}
                </div>
            </div>
        `;
        
        toastContainer.insertAdjacentHTML('beforeend', toastHtml);
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, {
            autohide: true,
            delay: type === 'success' ? 3000 : 5000
        });
        toast.show();
        
        toastElement.addEventListener('hidden.bs.toast', () => {
            toastElement.remove();
        });
    }
}

// 创建 Toast 容器
function createToastContainer() {
    const container = document.createElement('div');
    container.id = 'toast-container';
    container.className = 'toast-container position-fixed top-0 end-0 p-3';
    container.style.zIndex = '9999';
    document.body.appendChild(container);
    return container;
}

// 加载SEO账户表单
function loadSeoAccountForm(accountId) {
    const container = document.getElementById('seoAccountFormContainer');
    const titleElement = document.getElementById('offcanvasTitle');
    
    // 更新标题
    if (accountId > 0) {
        titleElement.textContent = '<?= __("编辑SEO账户") ?> #' + accountId;
    } else {
        titleElement.textContent = '<?= __("新增SEO账户") ?>';
    }
    
    // 显示加载状态
    container.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden"><?= __("加载中...") ?></span>
            </div>
            <p class="mt-2 text-muted"><?= __("正在加载表单...") ?></p>
        </div>
    `;
    
    // 构建URL
    const url = '<?= $this->getBackendUrl('seo/backend/account/form', ['scope' => $scope]) ?>' + 
                (accountId > 0 ? '&id=' + accountId : '');
    
    // 加载表单内容
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('HTTP error! status: ' + response.status);
        }
        return response.text();
    })
    .then(html => {
        container.innerHTML = html;
        // 重新绑定表单提交事件
        const form = document.getElementById('seoAccountForm');
        if (form) {
            form.onsubmit = function(e) {
                saveSeoAccount(e);
                return false;
            };
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle me-2"></i>
                <?= __("加载表单失败，请刷新页面重试") ?>
            </div>
        `;
    });
}

// 保存SEO账户
function saveSeoAccount(event) {
    event.preventDefault();
    const form = document.getElementById('seoAccountForm');
    if (!form) {
        showMessage('error', '<?= __("表单不存在") ?>');
        return;
    }
    
    const formData = new FormData(form);
    
    // 处理复选框
    formData.set('is_active', document.getElementById('is_active')?.checked ? '1' : '0');
    formData.set('enable_cron_push_urls', document.getElementById('enable_cron_push_urls')?.checked ? '1' : '0');
    formData.set('enable_cron_sitemap', document.getElementById('enable_cron_sitemap')?.checked ? '1' : '0');
    
    const data = {};
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalBtnHtml = submitBtn ? submitBtn.innerHTML : '';
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("保存中...") ?>';
    }
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
    .then(response => response.json())
    .then(resp => {
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnHtml;
        }
        
        if (resp.success) {
            showMessage('success', resp.message || '<?= __("账户保存成功") ?>');
            // 关闭 offcanvas
            const offcanvasElement = document.getElementById('seoAccountOffcanvas');
            if (offcanvasElement) {
                const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
                if (offcanvas) {
                    offcanvas.hide();
                }
            }
            // 刷新列表
            setTimeout(() => {
                window.location.reload();
            }, 800);
        } else {
            const errorMsg = resp.message || '<?= __("保存失败") ?>';
            showMessage('error', errorMsg);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnHtml;
        }
        showMessage('error', '<?= __("请求失败，请检查网络连接后重试") ?>');
    });
}

// Offcanvas 关闭时清理
document.getElementById('seoAccountOffcanvas')?.addEventListener('hidden.bs.offcanvas', function() {
    const container = document.getElementById('seoAccountFormContainer');
    if (container) {
        container.innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden"><?= __("加载中...") ?></span>
                </div>
                <p class="mt-2 text-muted"><?= __("正在加载表单...") ?></p>
            </div>
        `;
    }
});

// ==================== 站点绑定功能 ====================

let currentAccountId = 0;
let allWebsites = [];
let selectedWebsiteIds = [];

// 加载站点绑定表单
function loadWebsiteBindingForm(accountId) {
    currentAccountId = accountId;
    const container = document.getElementById('websiteBindingContainer');
    const titleElement = document.getElementById('websiteBindingTitle');
    
    titleElement.innerHTML = '<i class="mdi mdi-web me-2"></i><?= __("绑定站点") ?> <small class="text-muted">(<?= __("账户") ?> #' + accountId + ')</small>';
    
    // 显示加载状态
    container.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden"><?= __("加载中...") ?></span>
            </div>
            <p class="mt-2 text-muted"><?= __("正在加载站点列表...") ?></p>
        </div>
    `;
    
    // 加载站点列表和已绑定信息
    const url = '<?= $this->getBackendUrl('seo/backend/account/websites') ?>' + '?account_id=' + accountId;
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            allWebsites = data.websites || [];
            selectedWebsiteIds = data.bound_website_ids || [];
            renderWebsiteList(allWebsites);
        } else {
            container.innerHTML = `
                <div class="alert alert-danger m-3">
                    <i class="mdi mdi-alert-circle me-2"></i>
                    ${data.message || '<?= __("加载站点列表失败") ?>'}
                </div>
            `;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        container.innerHTML = `
            <div class="alert alert-danger m-3">
                <i class="mdi mdi-alert-circle me-2"></i>
                <?= __("加载站点列表失败，请刷新页面重试") ?>
            </div>
        `;
    });
}

// 渲染站点列表
