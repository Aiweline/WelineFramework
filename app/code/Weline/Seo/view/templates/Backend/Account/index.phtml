    const container = document.getElementById('websiteBindingContainer');
    
    if (!websites || websites.length === 0) {
        container.innerHTML = `
            <div class="text-center py-5 text-muted">
                <i class="mdi mdi-web-off" style="font-size: 48px;"></i>
                <p class="mt-3"><?= __("暂无可绑定的站点") ?></p>
            </div>
        `;
        return;
    }
    
    let html = `
        <div class="p-3 border-bottom bg-white sticky-top" style="z-index: 10;">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="mdi mdi-magnify"></i>
                </span>
                <input type="text" 
                       class="form-control" 
                       id="websiteSearchInput"
                       placeholder="<?= __("搜索站点名称或域名...") ?>"
                       onkeyup="searchWebsites(this.value)">
            </div>
            <div class="mt-2">
                <small class="text-muted">
                    <i class="mdi mdi-check-circle text-success me-1"></i>
                    <?= __("已选择") ?>: <strong id="selectedCount">${selectedWebsiteIds.length}</strong> <?= __("个站点") ?>
                </small>
                ${selectedWebsiteIds.length > 0 ? `
                <button type="button" class="btn btn-sm btn-link text-danger float-end" onclick="clearAllSelections()">
                    <i class="mdi mdi-close-circle me-1"></i><?= __("清空选择") ?>
                </button>
                ` : ''}
            </div>
        </div>
        <div id="websiteListContainer" class="p-3">
    `;
    
    websites.forEach(website => {
        const isSelected = selectedWebsiteIds.includes(website.website_id);
        html += `
            <div class="website-item card mb-2 ${isSelected ? 'border-success' : ''}" data-website-id="${website.website_id}" data-website-name="${website.name.toLowerCase()}" data-website-domain="${website.domain.toLowerCase()}">
                <div class="card-body p-3">
                    <div class="form-check">
                        <input class="form-check-input" 
                               type="checkbox" 
                               id="website_${website.website_id}" 
                               value="${website.website_id}"
                               ${isSelected ? 'checked' : ''}
                               onchange="toggleWebsiteSelection(${website.website_id}, this.checked)">
                        <label class="form-check-label d-flex justify-content-between align-items-start w-100" for="website_${website.website_id}">
                            <div class="flex-grow-1">
                                <div class="fw-bold">${website.name}</div>
                                <div class="text-muted small">
                                    <i class="mdi mdi-web me-1"></i>
                                    ${website.domain}
                                </div>
                                ${website.is_default ? '<span class="badge bg-info mt-1"><?= __("默认站点") ?></span>' : ''}
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        `;
    });
    
    html += `
        </div>
    `;
    
    container.innerHTML = html;
}

// 搜索站点
function searchWebsites(keyword) {
    keyword = keyword.toLowerCase().trim();
    const items = document.querySelectorAll('.website-item');
    let visibleCount = 0;
    
    items.forEach(item => {
        const name = item.dataset.websiteName || '';
        const domain = item.dataset.websiteDomain || '';
        
        if (name.includes(keyword) || domain.includes(keyword)) {
            item.style.display = '';
            visibleCount++;
        } else {
            item.style.display = 'none';
        }
    });
    
    // 显示搜索结果提示
    const container = document.getElementById('websiteListContainer');
    let noResultDiv = container.querySelector('.no-result-message');
    
    if (visibleCount === 0 && keyword !== '') {
        if (!noResultDiv) {
            noResultDiv = document.createElement('div');
            noResultDiv.className = 'no-result-message text-center text-muted py-4';
            noResultDiv.innerHTML = `
                <i class="mdi mdi-magnify-close" style="font-size: 48px;"></i>
                <p class="mt-2"><?= __("未找到匹配的站点") ?></p>
            `;
            container.appendChild(noResultDiv);
        }
    } else {
        if (noResultDiv) {
            noResultDiv.remove();
        }
    }
}

// 切换站点选择
function toggleWebsiteSelection(websiteId, isChecked) {
    if (isChecked) {
        if (!selectedWebsiteIds.includes(websiteId)) {
            selectedWebsiteIds.push(websiteId);
        }
        // 添加边框高亮
        const item = document.querySelector(`[data-website-id="${websiteId}"]`);
        if (item) {
            item.classList.add('border-success');
        }
    } else {
        const index = selectedWebsiteIds.indexOf(websiteId);
        if (index > -1) {
            selectedWebsiteIds.splice(index, 1);
        }
        // 移除边框高亮
        const item = document.querySelector(`[data-website-id="${websiteId}"]`);
        if (item) {
            item.classList.remove('border-success');
        }
    }
    
    // 更新计数
    const countElement = document.getElementById('selectedCount');
    if (countElement) {
        countElement.textContent = selectedWebsiteIds.length;
    }
}

// 清空所有选择
function clearAllSelections() {
    if (!confirm('<?= __("确定要清空所有选择吗？") ?>')) {
        return;
    }
    
    selectedWebsiteIds = [];
    
    // 取消所有复选框
    document.querySelectorAll('#websiteBindingContainer input[type="checkbox"]').forEach(checkbox => {
        checkbox.checked = false;
    });
    
    // 移除所有边框高亮
    document.querySelectorAll('.website-item').forEach(item => {
        item.classList.remove('border-success');
    });
    
    // 更新计数并重新渲染
    renderWebsiteList(allWebsites);
}

// 保存站点绑定
function saveWebsiteBindings() {
    // 如果没有选择任何站点，询问是否要解绑所有站点
    if (selectedWebsiteIds.length === 0) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: '<?= __("确认解绑") ?>',
                text: '<?= __("您没有选择任何站点，这将解绑该账户下的所有站点。确定要继续吗？") ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '<?= __("确认解绑") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then((result) => {
                if (result.isConfirmed) {
                    doSaveWebsiteBindings([]);
                }
            });
        } else {
            if (confirm('<?= __("您没有选择任何站点，这将解绑该账户下的所有站点。确定要继续吗？") ?>')) {
                doSaveWebsiteBindings([]);
            }
        }
        return;
    }
    
    doSaveWebsiteBindings(selectedWebsiteIds);
}

// 实际执行保存绑定
function doSaveWebsiteBindings(websiteIds) {
    const data = {
        account_id: currentAccountId,
        website_ids: websiteIds
    };
    
    // 禁用保存按钮
    const saveBtn = document.getElementById('saveWebsiteBindingsBtn');
    if (!saveBtn) {
        return;
    }
    const originalBtnHtml = saveBtn.innerHTML;
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("保存中...") ?>';
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/saveWebsiteBindings') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(resp => {
        saveBtn.disabled = false;
        saveBtn.innerHTML = originalBtnHtml;
        
        if (resp.success) {
            showMessage('success', resp.message || '<?= __("站点绑定成功") ?>');
            
            // 关闭 offcanvas
            const offcanvasElement = document.getElementById('websiteBindingOffcanvas');
            if (offcanvasElement) {
                const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement);
                if (offcanvas) {
                    offcanvas.hide();
                }
            }
        } else {
            showMessage('error', resp.message || '<?= __("保存失败") ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        saveBtn.disabled = false;
        saveBtn.innerHTML = originalBtnHtml;
        showMessage('error', '<?= __("请求失败，请检查网络连接后重试") ?>');
    });
}

// 站点绑定 Offcanvas 关闭时清理
document.getElementById('websiteBindingOffcanvas')?.addEventListener('hidden.bs.offcanvas', function() {
    currentAccountId = 0;
    allWebsites = [];
    selectedWebsiteIds = [];
    
    const container = document.getElementById('websiteBindingContainer');
    if (container) {
        container.innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden"><?= __("加载中...") ?></span>
                </div>
                <p class="mt-2 text-muted"><?= __("正在加载站点列表...") ?></p>
            </div>
        `;
    }
});

// ==================== 统计数据同步 ====================

// 同步账户统计数据
function syncAccountStats(accountId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __("同步统计数据") ?>',
            text: '<?= __("正在从搜索引擎平台获取最新统计数据...") ?>',
            icon: 'info',
            allowOutsideClick: false,
            showConfirmButton: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });
    } else {
        showMessage('info', '<?= __("正在同步...") ?>');
    }
    
    const formData = new FormData();
    formData.append('account_id', accountId);
    
    fetch('<?= $this->getBackendUrl('seo/backend/account/syncStats') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(resp => {
        if (typeof Swal !== 'undefined') {
            Swal.close();
        }
        
        if (resp.success) {
            showMessage('success', resp.message || '<?= __("同步成功") ?>');
            // 刷新页面以显示新数据
            setTimeout(() => {
                window.location.reload();
            }, 1500);
        } else {
            showMessage('error', resp.message || '<?= __("同步失败") ?>');
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.close();
        }
        console.error('Error:', error);
        showMessage('error', '<?= __("请求失败，请检查网络连接") ?>');
    });
}
</script>

