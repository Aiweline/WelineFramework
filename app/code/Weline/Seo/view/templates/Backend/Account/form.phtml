<script>
function saveSeoAccount(event) {
    event.preventDefault();
    const form = document.getElementById('seoAccountForm');
    const formData = new FormData(form);

    formData.set('is_active', document.getElementById('is_active').checked ? '1' : '0');
    formData.set('enable_cron_push_urls', document.getElementById('enable_cron_push_urls').checked ? '1' : '0');
    formData.set('enable_cron_sitemap', document.getElementById('enable_cron_sitemap').checked ? '1' : '0');

    const data = {};
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }

    fetch('<?= $this->getBackendUrl('seo/backend/account/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
        .then(response => response.json())
        .then(resp => {
            if (resp.success) {
                showPageMessage('success', resp.message);
                setTimeout(() => {
                    window.location.href = '<?= $this->getBackendUrl('seo/backend/account/index', ['scope' => $scope, 'module' => $module]) ?>';
                }, 800);
            } else {
                showPageMessage('error', resp.message || '保存失败');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showPageMessage('error', '请求失败');
        });
}
</script>

