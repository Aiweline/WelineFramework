<script>
// 表单提交处理（仅非AJAX模式）
function saveSeoAccount(event) {
    event.preventDefault();
    const form = document.getElementById('seoAccountForm');
    const formData = new FormData(form);

    formData.set('is_active', document.getElementById('is_active').checked ? '1' : '0');
    formData.set('enable_cron_push_urls', document.getElementById('enable_cron_push_urls').checked ? '1' : '0');
    formData.set('enable_cron_sitemap', document.getElementById('enable_cron_sitemap').checked ? '1' : '0');

    const data = {};
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalBtnHtml = submitBtn ? submitBtn.innerHTML : '';
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __("保存中...") ?>';
    }

    fetch('<?= $this->getBackendUrl('seo/backend/account/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
        .then(response => response.json())
        .then(resp => {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHtml;
            }
            
            if (resp.success) {
                // 显示消息并跳转
                if (typeof showMessage === 'function') {
                    showMessage('success', resp.message || '<?= __('账户保存成功') ?>');
                } else if (typeof showPageMessage === 'function') {
                    showPageMessage('success', resp.message);
                }
                setTimeout(() => {
                    window.location.href = '<?= $this->getBackendUrl('seo/backend/account/index', ['scope' => $scope]) ?>';
                }, 800);
            } else {
                const errorMsg = resp.message || '<?= __('保存失败') ?>';
                if (typeof showMessage === 'function') {
                    showMessage('error', errorMsg);
                } else if (typeof showPageMessage === 'function') {
                    showPageMessage('error', errorMsg);
                } else if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("错误") ?>',
                        text: errorMsg
                    });
                } else {
                    console.error(errorMsg);
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHtml;
            }
            const errorMsg = '<?= __('请求失败，请检查网络连接后重试') ?>';
            if (typeof showMessage === 'function') {
                showMessage('error', errorMsg);
            } else if (typeof showPageMessage === 'function') {
                showPageMessage('error', errorMsg);
            } else if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("请求失败") ?>',
                    text: errorMsg
                });
            } else {
                console.error(errorMsg);
            }
        });
}
</script>

</body>
</html>
<?php else: ?>
<!-- AJAX模式：不需要额外的脚本，表单提交由主页面的 handleAccountFormSubmit 处理 -->
