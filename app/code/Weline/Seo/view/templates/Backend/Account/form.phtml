                <!-- 平台配置 JavaScript（必须在表单之前定义） -->
                <script>
                // ==================== 平台配置数据 ====================
                const PLATFORM_DATA = <?= json_encode($platformFeatures, $jsonForScriptFlags) ?>;
                let currentSelectedPlatform = <?= json_encode($platform, $jsonForScriptFlags) ?>;

                // ==================== 通用工具函数 ====================
                
                /**
                 * 显示消息提示
                 */
                function showMessage(type, message, title = null) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: type === 'success' ? 'success' : type === 'error' ? 'error' : 'warning',
                            title: title || (type === 'success' ? '<?= __("成功") ?>' : type === 'error' ? '<?= __("错误") ?>' : '<?= __("提示") ?>'),
                            text: message,
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: type === 'success' ? 3000 : 5000,
                            timerProgressBar: true
                        });
                    } else if (typeof showPageMessage === 'function') {
                        showPageMessage(type, message);
                    } else {
                        console.log('[' + type + '] ' + message);
                    }
                }
                
                /**
                 * 显示确认对话框
                 */
                function showConfirm(message, onConfirm, onCancel) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'question',
                            title: '<?= __("确认操作") ?>',
                            text: message,
                            showCancelButton: true,
                            confirmButtonText: '<?= __("确定") ?>',
                            cancelButtonText: '<?= __("取消") ?>',
                            confirmButtonColor: '#3085d6',
                            cancelButtonColor: '#d33'
                        }).then((result) => {
                            if (result.isConfirmed && onConfirm) {
                                onConfirm();
                            } else if (result.isDismissed && onCancel) {
                                onCancel();
                            }
                        });
                    } else {
                        const box = document.createElement('div');
                        box.className = 'alert alert-warning d-flex align-items-center justify-content-between gap-3';
                        box.style.position = 'sticky';
                        box.style.top = '0';
                        box.style.zIndex = '1080';
                        const text = document.createElement('span');
                        text.textContent = message;
                        const actions = document.createElement('span');
                        actions.className = 'd-inline-flex gap-2';
                        const ok = document.createElement('button');
                        ok.type = 'button';
                        ok.className = 'btn btn-sm btn-warning';
                        ok.textContent = '<?= __("确定") ?>';
                        const cancel = document.createElement('button');
                        cancel.type = 'button';
                        cancel.className = 'btn btn-sm btn-outline-secondary';
                        cancel.textContent = '<?= __("取消") ?>';
                        actions.appendChild(ok);
                        actions.appendChild(cancel);
                        box.appendChild(text);
                        box.appendChild(actions);
                        document.body.prepend(box);
                        ok.addEventListener('click', function() {
                            box.remove();
                            if (onConfirm) onConfirm();
                        });
                        cancel.addEventListener('click', function() {
                            box.remove();
                            if (onCancel) onCancel();
                        });
                    }
                }

                // ==================== 核心功能函数 ====================

                /**
                 * 处理平台选择变化
                 */
                function syncPlatformCards(platformCode) {
                    document.querySelectorAll('[data-seo-platform-card]').forEach(function(card) {
                        const active = card.getAttribute('data-seo-platform-card') === platformCode;
                        card.classList.toggle('active', active);
                        card.setAttribute('aria-pressed', active ? 'true' : 'false');
                    });
                }

                function selectPlatformCard(platformCode) {
                    const select = document.getElementById('platformSelect');
                    if (!select) {
                        return;
                    }
                    select.value = platformCode;
                    handlePlatformChange(platformCode);
                }

                function handlePlatformChange(platformCode) {
                    console.log('平台选择:', platformCode);
                    currentSelectedPlatform = platformCode;
                    syncPlatformCards(platformCode);
                    
                    if (!platformCode || !PLATFORM_DATA[platformCode]) {
                        hideAllPlatformInfo();
                        syncSubmitToggles(null);
                        return;
                    }
                    
                    showPlatformInfo(platformCode);
                }

                /**
                 * 隐藏所有平台信息
                 */
                function hideAllPlatformInfo() {
                    document.getElementById('platformFeaturesInfo').style.display = 'none';
                    document.getElementById('platformGuideInfo').style.display = 'none';
                    document.getElementById('fillTemplateBtn').style.display = 'none';
                }

                /**
                 * 根据平台能力控制自动提交开关
                 */
                function syncSubmitToggles(platform) {
                    const supportsUrlPush = !!(platform && platform.supports_url_push);
                    const supportsSitemapSubmit = !!(platform && platform.supports_sitemap_submit);
                    const pushToggle = document.getElementById('enable_cron_push_urls');
                    const sitemapToggle = document.getElementById('enable_cron_sitemap');

                    if (pushToggle) {
                        pushToggle.disabled = !supportsUrlPush;
                        if (!supportsUrlPush) {
                            pushToggle.checked = false;
                        }
                    }
                    if (sitemapToggle) {
                        sitemapToggle.disabled = !supportsSitemapSubmit;
                        if (!supportsSitemapSubmit) {
                            sitemapToggle.checked = false;
                        }
                    }
                }

                /**
                 * 显示平台信息
                 */
                function showPlatformInfo(platformCode) {
                    const platform = PLATFORM_DATA[platformCode];
                    
                    // 显示功能说明
                    document.getElementById('platformFeaturesInfo').style.display = 'block';
                    document.getElementById('platformFeaturesTitle').textContent = platform.name;
                    
                    const featuresList = document.getElementById('platformFeaturesList');
                    featuresList.replaceChildren();
                    platform.features.forEach(function(feature) {
                        const item = document.createElement('li');
                        item.textContent = feature;
                        featuresList.appendChild(item);
                    });
                    
                    document.getElementById('platformConfigHint').textContent = platform.config_hint;
                    
                    // 显示配置指南（默认展开）
                    document.getElementById('platformGuideInfo').style.display = 'block';
                    document.getElementById('platformGuideTitle').textContent = platform.guide_title;
                    
                    const guideSteps = document.getElementById('platformGuideSteps');
                    guideSteps.replaceChildren();
                    platform.guide_steps.forEach(function(step) {
                        const item = document.createElement('li');
                        item.textContent = step;
                        guideSteps.appendChild(item);
                    });
                    
                    document.getElementById('platformConfigTemplate').textContent = 
                        JSON.stringify(platform.config_template, null, 2);
                    
                    // 默认展开指南内容
                    document.getElementById('platformGuideContent').style.display = 'block';
                    document.getElementById('guideToggleIcon').style.transform = 'rotate(180deg)';
                    
                    // 显示填充模板按钮
                    document.getElementById('fillTemplateBtn').style.display = 'inline-block';
                    
                    // 更新配置框 placeholder
                    const configTextarea = document.getElementById('configJsonTextarea');
                    if (!configTextarea.value.trim()) {
                        configTextarea.placeholder = JSON.stringify(platform.config_template, null, 2);
                    }

                    syncSubmitToggles(platform);
                }

                /**
                 * 切换指南内容展开/收起
                 */
                function toggleGuideContent() {
                    const content = document.getElementById('platformGuideContent');
                    const icon = document.getElementById('guideToggleIcon');
                    const isVisible = content.style.display !== 'none';
                    
                    content.style.display = isVisible ? 'none' : 'block';
                    icon.style.transform = isVisible ? 'rotate(0deg)' : 'rotate(180deg)';
                }

                /**
                 * 填充配置模板
                 */
                function fillConfigTemplate() {
                    if (!currentSelectedPlatform || !PLATFORM_DATA[currentSelectedPlatform]) {
                        showMessage('warning', '请先选择平台');
                        return;
                    }
                    
                    const configTextarea = document.getElementById('configJsonTextarea');
                    const template = PLATFORM_DATA[currentSelectedPlatform].config_template;
                    
                    if (configTextarea.value.trim() !== '') {
                        showConfirm('当前已有配置内容，是否覆盖？', function() {
                            configTextarea.value = JSON.stringify(template, null, 2);
                            configTextarea.focus();
                        });
                        return;
                    }
                    
                    configTextarea.value = JSON.stringify(template, null, 2);
                    configTextarea.focus();
                }

                /**
                 * 处理 JSON 文件上传
                 */
                function handleJsonFileUpload(input) {
                    const file = input.files[0];
                    if (!file) {
                        return;
                    }
                    
                    // 检查文件类型
                    if (!file.name.endsWith('.json') && file.type !== 'application/json') {
                        showMessage('error', '请上传 JSON 文件');
                        input.value = '';
                        return;
                    }
                    
                    // 检查文件大小（限制 5MB）
                    if (file.size > 5 * 1024 * 1024) {
                        showMessage('error', '文件大小不能超过 5MB');
                        input.value = '';
                        return;
                    }
                    
                    const configTextarea = document.getElementById('configJsonTextarea');
                    
                    // 如果已有内容，确认是否覆盖
                    if (configTextarea.value.trim() !== '') {
                        showConfirm('当前已有配置内容，是否覆盖？', function() {
                            readAndFillJsonFile(file, configTextarea, input);
                        }, function() {
                            input.value = '';
                        });
                        return;
                    }
                    
                    readAndFillJsonFile(file, configTextarea, input);
                }
                
                /**
                 * 读取并填充 JSON 文件
                 */
                function readAndFillJsonFile(file, configTextarea, input) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        try {
                            const content = e.target.result;
                            // 验证是否是有效的 JSON
                            const jsonObj = JSON.parse(content);
                            // 格式化后填充到 textarea
                            configTextarea.value = JSON.stringify(jsonObj, null, 2);
                            configTextarea.focus();
                            showMessage('success', 'JSON 文件上传成功');
                        } catch (err) {
                            showMessage('error', 'JSON 文件格式错误: ' + err.message);
                        }
                        // 清空 input，允许再次上传同一文件
                        input.value = '';
                    };
                    reader.onerror = function() {
                        showMessage('error', '文件读取失败，请重试');
                        input.value = '';
                    };
                    reader.readAsText(file);
                }

                if (!window.__seoAccountFormActionsBound) {
                    window.__seoAccountFormActionsBound = true;

                    document.addEventListener('submit', function(event) {
                        if (event.target && event.target.id === 'seoAccountForm' && typeof window.saveSeoAccount === 'function') {
                            window.saveSeoAccount(event);
                        }
                    });

                    document.addEventListener('change', function(event) {
                        if (!event.target) {
                            return;
                        }
                        if (event.target.matches('#platformSelect')) {
                            handlePlatformChange(event.target.value);
                            return;
                        }
                        if (event.target.matches('#jsonFileInput')) {
                            handleJsonFileUpload(event.target);
                        }
                    });

                    document.addEventListener('click', function(event) {
                        const platformCard = event.target.closest('[data-seo-platform-card]');
                        if (platformCard) {
                            event.preventDefault();
                            selectPlatformCard(platformCard.getAttribute('data-seo-platform-card') || '');
                            return;
                        }

                        const guideToggle = event.target.closest('[data-seo-guide-toggle]');
                        if (guideToggle) {
                            event.preventDefault();
                            toggleGuideContent();
                            return;
                        }

                        const fillTemplate = event.target.closest('[data-seo-fill-template]');
                        if (fillTemplate) {
                            event.preventDefault();
                            fillConfigTemplate();
                            return;
                        }

                        const uploadTrigger = event.target.closest('[data-seo-json-upload-trigger]');
                        if (uploadTrigger) {
                            event.preventDefault();
                            const input = document.getElementById('jsonFileInput');
                            if (input) {
                                input.click();
                            }
                        }
                    });

                    document.addEventListener('keydown', function(event) {
                        const guideToggle = event.target.closest('[data-seo-guide-toggle]');
                        if (!guideToggle || (event.key !== 'Enter' && event.key !== ' ')) {
                            return;
                        }
                        event.preventDefault();
                        toggleGuideContent();
                    });
                }

                // ==================== 页面初始化 ====================
                window.addEventListener('DOMContentLoaded', function() {
                    // 页面加载完成后，如果已选择平台，显示信息
                    if (currentSelectedPlatform) {
                        handlePlatformChange(currentSelectedPlatform);
                    }
                });
                </script>

