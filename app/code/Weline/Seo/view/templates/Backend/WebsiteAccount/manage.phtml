<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars(__('管理站点 SEO 账户启用'), ENT_QUOTES, 'UTF-8') ?> - <?= htmlspecialchars($websiteName, ENT_QUOTES, 'UTF-8') ?></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">
</head>
<body style="padding:20px;background:#f6f8fb;">
<?php endif; ?>

<?= framework_view_process_block([
    'class' => \Weline\Seo\Block\Widget\WebsiteAccountEnablement::class,
    'website_id' => $websiteId,
    'website' => $website,
    'scope' => $scope,
    'mode' => 'standalone',
    'field_prefix' => '',
    'show_submit' => true,
]) ?>

<?php if (!$isAjax): ?>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
