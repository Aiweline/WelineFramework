<?php endif; ?>
    <script>
    // 切换账户配置区域
    function toggleAccountConfig(accountId) {
        const checkbox = document.querySelector(`input[value="${accountId}"]`);
        const item = document.getElementById(`account-item-${accountId}`);
        
        if (checkbox.checked) {
            item.classList.add('selected');
        } else {
            item.classList.remove('selected');
        }
    }

    // 处理表单提交
    function handleSubmit(event) {
        event.preventDefault();
        
        const submitBtn = document.getElementById('submitBtn');
        const originalHtml = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __("保存中...") ?>';
        
        const formData = new FormData(event.target);
        
        var url = '<?= $this->getBackendUrl('seo/backend/websiteaccount/save') ?>';
        var opts = { method: 'POST', body: formData };
        window.Weline.Api.request(url, opts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            if (data.success) {
                // 显示成功消息
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __("保存成功") ?>',
                        text: data.message || '<?= __("绑定配置已更新") ?>',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
                
                // 触发自定义事件，通知父页面刷新
                if (window.parent) {
                    const event = new CustomEvent('websiteBindingSaved', { 
                        detail: { success: true, message: data.message }
                    });
                    window.parent.document.dispatchEvent(event);
                }
                
                // 延迟刷新或关闭
                setTimeout(() => {
                    if (window.opener && !window.opener.closed) {
                        window.opener.location.reload();
                        window.close();
                    } else if (!window.parent || window.parent === window) {
                        location.reload();
                    }
                }, 1500);
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("保存失败") ?>',
                        text: data.message || '<?= __("请检查输入后重试") ?>'
                    });
                } else {
                    alert(data.message || '<?= __("保存失败") ?>');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
            }
        })
        .catch(error => {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("请求失败") ?>',
                    text: error.message || '<?= __("网络连接失败，请重试") ?>'
                });
            } else {
                alert('<?= __("请求失败") ?>: ' + error.message);
            }
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalHtml;
        });
        
        return false;
    }
    </script>

<?php if (!$isAjax): ?>
</body>
</html>
