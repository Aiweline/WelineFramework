    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const saveUrl = '<?= $this->getUrl('*/backend/embed/save') ?>';
        const deleteUrl = '<?= $this->getUrl('*/backend/embed/delete') ?>';
        
        // 添加主体表单提交
        document.getElementById('addSubjectForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            
            fetch(saveUrl, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message || '<?= __('保存成功') ?>');
                    location.reload();
                } else {
                    alert(data.message || '<?= __('保存失败') ?>');
                }
            })
            .catch(error => {
                alert('<?= __('请求失败') ?>: ' + error.message);
            });
        });
        
        // 删除按钮
        document.querySelectorAll('.btn-delete').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const subjectId = this.dataset.subjectId;
                if (!confirm('<?= __('确定要删除该SEO主体吗？') ?>')) {
                    return;
                }
                
                const formData = new FormData();
                formData.append('subject_id', subjectId);
                
                fetch(deleteUrl, {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // 移除卡片
                        this.closest('.subject-card').remove();
                    } else {
                        alert(data.message || '<?= __('删除失败') ?>');
                    }
                })
                .catch(error => {
                    alert('<?= __('请求失败') ?>: ' + error.message);
                });
            });
        });
    });
    </script>
