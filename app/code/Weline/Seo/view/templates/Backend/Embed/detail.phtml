    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const saveUrl = '<?= $this->getUrl('*/backend/embed/save') ?>';
        const refreshUrl = '<?= $this->getUrl('*/backend/embed/refreshSuggestion') ?>';
        const subjectId = <?= (int)($subject['subject_id'] ?? 0) ?>;
        
        // 编辑按钮
        document.getElementById('btnEdit').addEventListener('click', function() {
            const modal = new bootstrap.Modal(document.getElementById('editModal'));
            modal.show();
        });
        
        // 编辑表单提交
        document.getElementById('editForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(saveUrl, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    alert(data.message || '<?= __('保存成功') ?>');
                    location.reload();
                } else {
                    alert(data.message || '<?= __('保存失败') ?>');
                }
            })
            .catch(error => {
                alert('<?= __('请求失败') ?>: ' + error.message);
            });
        });
        
        // 生成AI建议
        document.getElementById('btnRefreshSuggestion').addEventListener('click', function() {
            const suggestionContent = document.getElementById('suggestionContent');
            const noSuggestion = document.getElementById('noSuggestion');
            const loading = document.getElementById('suggestionLoading');
            
            if (suggestionContent) suggestionContent.style.display = 'none';
            if (noSuggestion) noSuggestion.style.display = 'none';
            loading.style.display = 'block';
            
            const formData = new FormData();
            formData.append('subject_id', subjectId);
            
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(refreshUrl, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                loading.style.display = 'none';
                
                if (data.success && data.data && data.data.suggestion) {
                    if (!suggestionContent) {
                        // 创建内容元素
                        const contentDiv = document.createElement('div');
                        contentDiv.id = 'suggestionContent';
                        contentDiv.className = 'suggestion-content';
                        contentDiv.innerHTML = data.data.suggestion.content.replace(/\n/g, '<br>');
                        loading.parentNode.insertBefore(contentDiv, loading);
                    } else {
                        suggestionContent.innerHTML = data.data.suggestion.content.replace(/\n/g, '<br>');
                        suggestionContent.style.display = 'block';
                    }
                    if (noSuggestion) noSuggestion.remove();
                } else {
                    if (noSuggestion) noSuggestion.style.display = 'block';
                    else if (suggestionContent) suggestionContent.style.display = 'block';
                    alert(data.message || '<?= __('生成建议失败') ?>');
                }
            })
            .catch(error => {
                loading.style.display = 'none';
                if (noSuggestion) noSuggestion.style.display = 'block';
                else if (suggestionContent) suggestionContent.style.display = 'block';
                alert('<?= __('请求失败') ?>: ' + error.message);
            });
        });
    });
    </script>
