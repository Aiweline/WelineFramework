$escapeAttr = static function ($value): string {
    return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
};

// 获取前台根 URL（后台上下文中需要使用 getBaseHost 获取纯域名）
$request = $this->getRequest();
$frontendBaseUrl = $request->getBaseHost();
if (!preg_match('/^https?:\/\//i', $frontendBaseUrl)) {
    $scheme = $request->isSecure() ? 'https' : 'http';
    $host = $request->getHttpHost();
    $frontendBaseUrl = $scheme . '://' . $host;
}
$frontendBaseUrl = rtrim($frontendBaseUrl, '/');
