<script>
(function () {
    'use strict';

    if (window.__seoSitemapActionsBound) {
        return;
    }
    window.__seoSitemapActionsBound = true;

    document.addEventListener('click', function (event) {
        var actionTrigger = event.target.closest('[data-seo-sitemap-action]');
        if (actionTrigger) {
            var action = actionTrigger.getAttribute('data-seo-sitemap-action');

            if (action === 'copy-url') {
                event.preventDefault();
                event.stopPropagation();
                if (typeof window.copyToClipboard === 'function') {
                    window.copyToClipboard(actionTrigger.getAttribute('data-copy-url') || '');
                }
                return;
            }

            if (action === 'generate' && typeof window.generateSitemap === 'function') {
                event.preventDefault();
                window.generateSitemap();
                return;
            }

            if (action === 'generate-provider' && typeof window.generateByProvider === 'function') {
                event.preventDefault();
                window.generateByProvider(actionTrigger.getAttribute('data-provider-module') || '');
                return;
            }

            if (action === 'generate-all' && typeof window.generateByAllProviders === 'function') {
                event.preventDefault();
                window.generateByAllProviders();
                return;
            }
        }

        var toggleTrigger = event.target.closest('[data-seo-sitemap-toggle]');
        if (!toggleTrigger) {
            return;
        }

        var toggleType = toggleTrigger.getAttribute('data-seo-sitemap-toggle');
        if (toggleType === 'website' && typeof window.toggleWebsite === 'function') {
            window.toggleWebsite(toggleTrigger);
            return;
        }
        if (toggleType === 'scope' && typeof window.toggleScope === 'function') {
            window.toggleScope(toggleTrigger);
        }
    });
})();
</script>

