<div class="offcanvas offcanvas-end" tabindex="-1" id="roleAddOffcanvas" aria-labelledby="roleAddOffcanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="roleAddOffcanvasLabel">
            <lang>添加角色</lang>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="roleAddForm" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="role_name" class="form-label">
                    <lang>角色名</lang> <span class="text-danger">*</span>
                </label>
                <input type="text" class="form-control" id="role_name" name="role_name" required placeholder="@lang{请输入角色名}">
                <div class="invalid-feedback">
                    <lang>请输入角色名称</lang>
                </div>
            </div>
            <div class="mb-3">
                <label for="role_description" class="form-label">
                    <lang>角色描述</lang> <span class="text-danger">*</span>
                </label>
                <textarea class="form-control" id="role_description" name="role_description" rows="3" required placeholder="@lang{请输入角色描述}"></textarea>
                <div class="invalid-feedback">
                    <lang>请输入角色描述</lang>
                </div>
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <lang>提交</lang>
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">
                    <lang>取消</lang>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var form = document.getElementById('roleAddForm');
    var offcanvasElement = document.getElementById('roleAddOffcanvas');
    var offcanvas = null;
    
    // 延迟初始化 offcanvas，确保 Bootstrap 已加载
    function getOffcanvas() {
        if (!offcanvas && typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement) || new bootstrap.Offcanvas(offcanvasElement);
        }
        return offcanvas;
    }
    
    form.addEventListener('submit', function(event) {
        event.preventDefault();
        event.stopPropagation();
        
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        
        var formData = new FormData(form);
        var data = {};
        for (var pair of formData.entries()) {
            data[pair[0]] = pair[1];
        }
        
        // 禁用提交按钮防止重复提交
        var submitBtn = form.querySelector('button[type="submit"]');
        var originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在创建...') ?>';
        
        BackendToast.info('<?= __('正在创建角色...') ?>');
        
        fetch('<?= $this->getBackendUrl("*/backend/acl/role/add") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(data)
        })
        .then(function(response) {
            // 检查 HTTP 状态码
            if (!response.ok) {
                throw new Error('HTTP <?= __('错误') ?>: ' + response.status + ' ' + response.statusText);
            }
            return response.text();
        })
        .then(function(text) {
            // 尝试解析 JSON
            try {
                return JSON.parse(text);
            } catch (e) {
                console.error('JSON parse error, response:', text);
                throw new Error('<?= __('服务器返回格式错误，请检查后台日志') ?>');
            }
        })
        .then(function(result) {
            if (result.success) {
                BackendToast.success(result.message || '<?= __('角色创建成功！') ?>');
                var oc = getOffcanvas();
                if (oc) oc.hide();
                form.reset();
                form.classList.remove('was-validated');
                setTimeout(function() {
                    window.location.reload();
                }, 1500);
            } else {
                BackendToast.error(result.message || '<?= __('角色创建失败，请检查输入后重试') ?>');
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            BackendToast.error('<?= __('请求失败：') ?>' + error.message);
        })
        .finally(function() {
            // 恢复提交按钮
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    });
    
    offcanvasElement.addEventListener('hidden.bs.offcanvas', function() {
        form.reset();
        form.classList.remove('was-validated');
    });
})();
</script>
