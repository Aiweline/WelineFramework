<script>
(function() {
    'use strict';
    
    // 获取表单和 offcanvas
    const form = document.getElementById('roleAddForm');
    const offcanvasElement = document.getElementById('roleAddOffcanvas');
    const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement) || new bootstrap.Offcanvas(offcanvasElement);
    
    // 表单提交处理
    form.addEventListener('submit', function(event) {
        event.preventDefault();
        event.stopPropagation();
        
        // 验证表单
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        
        // 获取表单数据
        const formData = new FormData(form);
        const data = {};
        for (let [key, value] of formData.entries()) {
            data[key] = value;
        }
        
        // 显示加载提示
        Swal.fire({
            title: '<?= __('处理中') ?>',
            text: '<?= __('正在创建角色...') ?>',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });
        
        // 发送 AJAX 请求
        fetch('@backend-url("*/backend/acl/role/add")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                // 成功提示
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: result.message || '<?= __('角色创建成功！') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    // 关闭 offcanvas
                    offcanvas.hide();
                    // 重置表单
                    form.reset();
                    form.classList.remove('was-validated');
                    // 刷新页面
                    window.location.reload();
                });
            } else {
                // 失败提示
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('失败') ?>',
                    text: result.message || '<?= __('角色创建失败！') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
        })
        .catch(error => {
            console.error('Error:', error);
            Swal.fire({
                icon: 'error',
                title: '<?= __('错误') ?>',
                text: '<?= __('请求失败：') ?>' + error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        });
    });
    
    // 当 offcanvas 关闭时重置表单
    offcanvasElement.addEventListener('hidden.bs.offcanvas', function() {
        form.reset();
        form.classList.remove('was-validated');
    });
})();
</script>
