<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- 
        控制器模板获取前事件 - 根据 layoutType 自动加载主题布局
        
        功能：
        1. 检测控制器的 layoutType 属性
        2. 根据 layoutType 和主题配置构建布局模板路径
        3. 将模板路径重写为布局模板路径
        4. 设置主题相关数据（colors、meta等）
    -->
    <event name="Weline_Framework_Controller::fetch_file_before">
        <observer name="Weline_Theme::controller_fetch_file_before"
                  instance="Weline\Theme\Observer\ControllerFetchFileBefore"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    
    <!-- 
        控制器模板获取后事件 - 处理布局插槽替换
        
        功能：
        1. 检测渲染后的 HTML 中的 data-wslot / widget-slot-area 元素
        2. 从数据库获取该页面的部件布局配置
        3. 渲染部件并填充到对应插槽
        4. 返回最终的 HTML
        
        注意：使用 fetch_file_after 事件而非 after_render 事件
        因为 after_render 事件在框架中未被触发，而 fetch_file_after 
        在控制器渲染完成后可靠触发
    -->
    <event name="Weline_Framework_Controller::fetch_file_after">
        <observer name="Weline_Theme::layout_slot_renderer"
                  instance="Weline\Theme\Observer\LayoutSlotRenderer"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    
</config>
