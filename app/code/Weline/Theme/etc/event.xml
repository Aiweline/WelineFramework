<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- 
        主题注册安装器事件 - 处理主题类型的注册
        
        功能：
        1. 拦截 register_installer 事件
        2. 当注册类型为 THEME 时，使用 Theme 模块的安装器
    -->
    <event name="Weline_Framework_Register::register_installer">
        <observer name="Weline_Theme::register_installer"
                  instance="Weline\Theme\Observer\Register"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <!-- 在模块 Router 链（sort=0）之前改写带 preview_theme 的首页路径，进入 Theme 前台预览网关 -->
    <event name="Weline_Framework_Router::process_uri_before">
        <observer name="Weline_Theme::process_preview_theme_uri_before"
                  instance="Weline\Theme\Observer\ProcessPreviewThemeUriBefore"
                  disabled="false"
                  shared="true"
                  sort="-7"/>
    </event>

    <event name="Weline_Framework::App::run_after">
        <observer name="Weline_Theme::clear_scoped_preview_state_after"
                  instance="Weline\Theme\Observer\ClearScopedPreviewStateAfter"
                  disabled="false"
                  shared="true"
                  sort="900"/>
    </event>
    
    <!-- 
        模板文件获取事件 - 解析主题文件路径
        
        功能：
        1. 拦截模板文件获取事件
        2. 根据当前主题（激活主题或预览主题）解析实际文件路径
        3. 支持主题继承链查找（子主题 -> 父主题 -> 默认主题）
        
        注意：sort=0 确保最先执行，让其他 Observer 能拿到正确的主题文件路径
    -->
    <event name="Weline_Framework_View::fetch_file">
        <observer name="Weline_Theme::template_fetch_file"
                  instance="Weline\Theme\Observer\TemplateFetchFile"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <event name="Weline_Framework_View::resolve_theme_asset_url">
        <observer name="Weline_Theme::resolve_theme_asset_url"
                  instance="Weline\Theme\Observer\ResolveThemeAssetUrl"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <event name="Weline_Framework_View::resolve_preview_token">
        <observer name="Weline_Theme::resolve_preview_token"
                  instance="Weline\Theme\Observer\ResolvePreviewToken"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <event name="Weline_Framework_View::resolve_theme_cache_suffix">
        <observer name="Weline_Theme::resolve_theme_cache_suffix"
                  instance="Weline\Theme\Observer\ResolveThemeCacheSuffix"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>
    
    <!-- 
        控制器模板获取前事件 - 根据 layoutType 自动加载主题布局
        
        功能：
        1. 检测控制器的 layoutType 属性
        2. 根据 layoutType 和主题配置构建布局模板路径
        3. 将模板路径重写为布局模板路径
        4. 设置主题相关数据（colors、meta等）
    -->
    <event name="Weline_Framework_Controller::fetch_file_before">
        <observer name="Weline_Theme::controller_fetch_file_before"
                  instance="Weline\Theme\Observer\ControllerFetchFileBefore"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    
    <!-- 
        控制器模板获取后事件 - 处理布局插槽替换
        
        功能：
        1. 检测渲染后的 HTML 中的 data-wslot / widget-slot-area 元素
        2. 从数据库获取该页面的部件布局配置
        3. 渲染部件并填充到对应插槽
        4. 返回最终的 HTML
        
        注意：使用 fetch_file_after 事件而非 after_render 事件
        因为 after_render 事件在框架中未被触发，而 fetch_file_after 
        在控制器渲染完成后可靠触发
    -->
    <event name="Weline_Framework_Controller::fetch_file_after">
        <observer name="Weline_Theme::controller_fetch_file_after"
                  instance="Weline\Theme\Observer\ControllerFetchFileAfter"
                  disabled="false"
                  shared="true"
                  sort="90"/>
        <observer name="Weline_Theme::layout_slot_renderer"
                  instance="Weline\Theme\Observer\LayoutSlotRenderer"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    
    <!-- 
        系统升级后事件 - 推送预览绕过规则到 CDN
        
        功能：
        1. 在模块安装或升级后触发
        2. 推送 CDN 规则以绕过包含预览 Token 的请求缓存
    -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Theme::setup_upgrade_after"
                  instance="Weline\Theme\Observer\SetupUpgradeAfter"
                  disabled="false"
                  shared="true"
                  sort="200"/>
    </event>

    <event name="Weline_Widget::registry_refresh_after">
        <observer name="Weline_Theme::apply_widget_default_injections"
                  instance="Weline\Theme\Observer\ApplyWidgetDefaultInjections"
                  disabled="false"
                  shared="true"
                  sort="10"/>
    </event>

    <event name="Weline_Framework_Runtime::worker_bootstrap_after">
        <observer name="Weline_Theme::worker_bootstrap_warmup"
                  instance="Weline\Theme\Observer\WorkerBootstrapWarmup"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>

    <event name="Weline_Framework_Template::compile_decision">
        <observer name="Weline_Theme::layout_critical_css_compile_decision"
                  instance="Weline\Theme\Observer\LayoutCriticalCssCompileDecision"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

    <event name="Weline_Framework_Template::before_compile">
        <observer name="Weline_Theme::layout_critical_css_before_compile"
                  instance="Weline\Theme\Observer\LayoutCriticalCssBeforeCompile"
                  disabled="false"
                  shared="true"
                  sort="0"/>
    </event>

</config>
