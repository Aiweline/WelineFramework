                        $groupLabel = (string)($group['label'] ?? $type ?? '');
                        $groupWidgets = $group['widgets'] ?? [];
                    ?>
                        <div class="widget-group" data-type="<?= htmlspecialchars((string)($type ?? '')) ?>">
                            <div class="widget-group-header" data-toggle="collapse">
                                <i class="ri-arrow-down-s-line toggle-icon"></i>
                                <span><?= htmlspecialchars($groupLabel) ?></span>
                                <span class="widget-count"><?= count($groupWidgets) ?></span>
                            </div>
                            <div class="widget-group-content">
                                <?php foreach ($groupWidgets as $widget): 
                                    if (!is_array($widget)) continue;
                                    $wCode = (string)($widget['code'] ?? '');
                                    $wModule = (string)($widget['module'] ?? '');
                                    $wType = (string)($widget['type'] ?? '');
                                    $wName = (string)($widget['name'] ?? $wCode ?? '');
                                    $wDesc = (string)($widget['description'] ?? '');
                                    $wPosition = $widget['position'] ?? [];
                                    $wCompatible = $widget['compatible'] ?? false;
                                    $wSlot = (string)($widget['slot'] ?? '');
                                    $wPageLayouts = $widget['page_layouts'] ?? ['*'];
                                    $wIsContainer = $widget['is_container'] ?? false;
                                    // 独占属性：部件定义中明确设置 exclusive=true，或者在独占插槽列表中
                                    $exclusiveSlots = ['logo', 'search', 'main-nav', 'header-container', 'footer-container', 'content-container'];
                                    $wExclusive = ($widget['exclusive'] ?? false) || (!empty($wSlot) && in_array($wSlot, $exclusiveSlots));
                                ?>
                                    <div class="widget-item draggable <?= $wIsContainer ? 'widget-container' : '' ?> <?= $wExclusive ? 'widget-exclusive' : '' ?>" 
                                         draggable="true"
                                         data-widget-code="<?= htmlspecialchars($wCode) ?>"
                                         data-widget-module="<?= htmlspecialchars($wModule) ?>"
                                         data-widget-type="<?= htmlspecialchars($wType) ?>"
                                         data-widget-name="<?= htmlspecialchars($wName) ?>"
                                         data-widget-position='<?= json_encode($wPosition) ?>'
                                         data-widget-compatible="<?= $wCompatible ? '1' : '0' ?>"
                                         data-widget-slot="<?= htmlspecialchars($wSlot) ?>"
                                         data-widget-exclusive="<?= $wExclusive ? '1' : '0' ?>"
                                         data-widget-page-layouts='<?= json_encode($wPageLayouts) ?>'
                                         data-widget-is-container="<?= $wIsContainer ? '1' : '0' ?>">
                                        <div class="widget-preview">
                                            <div class="widget-preview-canvas">
                                                <?= $widget['preview_html'] ?? '' ?>
                                            </div>
                                            <div class="widget-preview-overlay">
