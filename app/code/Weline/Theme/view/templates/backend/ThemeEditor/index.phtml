/* ========================================
   Collapsible push panels / CMS embed shell
   ======================================== */
.editor-floating-panel-actions,
.editor-panel-toggle {
    display: none;
}

.editor-floating-panel-actions {
    position: absolute;
    inset: 0;
    z-index: 100;
    pointer-events: none;
}

.editor-panel-toggle {
    pointer-events: auto;
    position: absolute;
    top: 50%;
    min-width: 34px;
    min-height: 72px;
    padding: 8px 5px;
    border: 1px solid var(--te-border);
    background: var(--te-bg-card);
    color: var(--te-text-primary);
    box-shadow: var(--te-shadow-md);
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    align-items: center;
    justify-content: center;
    gap: 4px;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease, left 0.2s ease, right 0.2s ease;
}

.editor-panel-toggle:hover {
    background: var(--te-bg-active);
    border-color: var(--te-accent);
}

.editor-panel-toggle .panel-toggle-arrow {
    display: inline-flex;
    font-size: 16px;
    line-height: 1;
    transition: transform 0.2s ease;
}

.editor-panel-toggle-config {
    left: 0;
    transform: translateY(-50%);
    border-left: 0;
    border-radius: 0 8px 8px 0;
}

.editor-panel-toggle-widget {
    right: 0;
    transform: translateY(-50%);
    border-right: 0;
    border-radius: 8px 0 0 8px;
}

.theme-editor-container.panel-config-open .editor-panel-toggle-config {
    left: var(--te-config-panel-width);
}

.theme-editor-container.panel-widget-open .editor-panel-toggle-widget {
    right: var(--te-widget-panel-width);
}

.theme-editor-container.panel-config-collapsed {
    --te-active-config-panel-width: 0px;
}

.theme-editor-container.panel-widget-collapsed {
    --te-active-widget-panel-width: 0px;
}

.theme-editor-container:is(.editor-compact-mode, .panel-config-collapsed, .panel-widget-collapsed) .editor-floating-panel-actions {
    display: block;
}

.theme-editor-container:is(.editor-compact-mode, .panel-config-collapsed) .editor-panel-toggle-config,
.theme-editor-container:is(.editor-compact-mode, .panel-widget-collapsed) .editor-panel-toggle-widget {
    display: inline-flex;
}

.theme-editor-container.panel-config-open .editor-panel-toggle-config .panel-toggle-arrow {
    transform: rotate(180deg);
}

.theme-editor-container.panel-widget-open .editor-panel-toggle-widget .panel-toggle-arrow {
    transform: rotate(180deg);
}

.theme-editor-container.panel-config-collapsed .editor-config-panel {
    opacity: 0;
    pointer-events: none;
    border-right-color: transparent;
    box-shadow: none;
}

.theme-editor-container.panel-widget-collapsed .editor-widget-panel {
    opacity: 0;
    pointer-events: none;
    border-left-color: transparent;
    box-shadow: none;
}

.theme-editor-container .panel-close-widget {
    display: inline-flex;
}

