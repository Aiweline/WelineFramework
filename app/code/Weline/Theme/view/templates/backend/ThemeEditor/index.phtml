<?php
/**
 * 主题可视化编辑器
 * 
 * @var \Weline\Framework\View\Template $this
 * @var int $theme_id
 * @var \Weline\Theme\Model\WelineTheme $theme
 * @var array $themes
 * @var string $page_type
 * @var array $page_types
 * @var array $areas
 * @var array $layout
 * @var array $available_widgets
 */

$theme_id = (int)($this->getData('theme_id') ?: 0);
$theme = $this->getData('theme');
$themes = $this->getData('themes') ?: [];
$page_type = $this->getData('page_type') ?: 'homepage';
$page_types = $this->getData('page_types') ?: [];
$layout_option = (string)($this->getData('layout_option') ?: 'default');
$layout_options_by_type = $this->getData('layout_options_by_type') ?: [];
$installed_locales = $this->getData('installed_locales') ?: [];
$installed_locales = is_array($installed_locales) ? $installed_locales : [];
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
$current_layout_options = $layout_options_by_type[$page_type] ?? [];
if (empty($current_layout_options)) {
    $current_layout_options = [[
        'value' => $layout_option,
        'label' => $layout_option === 'default' ? (string)__('Default') : $layout_option,
        'description' => '',
        'file' => '',
    ]];
}
$layout_options_json = json_encode($layout_options_by_type, $jsonForScriptFlags) ?: '{}';
$installed_locales_json = json_encode($installed_locales, $jsonForScriptFlags) ?: '[]';
$areas = $this->getData('areas') ?: [];
$editor_area = $this->getData('editor_area') ?: 'frontend';
$theme_has_backend = (bool)$this->getData('theme_has_backend');
$layout = $this->getData('layout') ?: [];
$available_widgets = $this->getData('available_widgets') ?: [];
$preview_context = $this->getData('preview_context') ?: [];
$preview_status = is_array($preview_context) ? (string)($preview_context['status'] ?? 'draft') : 'draft';
$layout_editor_lock = $this->getData('layout_editor_lock') ?: ['enabled' => false];
$layout_editor_lock = is_array($layout_editor_lock) ? $layout_editor_lock : ['enabled' => false];
$layout_editor_locked = !empty($layout_editor_lock['enabled']);
$layout_lock_source = strtolower(trim((string)($layout_editor_lock['lock_source'] ?? '')));
$editorShellClasses = ['theme-editor-container'];
if ($layout_editor_locked) {
    $editorShellClasses[] = 'theme-editor-locked';
}
if ($layout_lock_source === 'cms') {
    $editorShellClasses[] = 'theme-editor-cms-embed';
}
$layout_editor_lock_json = json_encode($layout_editor_lock, $jsonForScriptFlags) ?: '{"enabled":false}';
$frontend_theme_id = (int)($this->getData('frontend_theme_id') ?: ($editor_area === 'frontend' ? $theme_id : 0));
$backend_theme_id = (int)($this->getData('backend_theme_id') ?: ($editor_area === 'backend' ? $theme_id : 0));
$default_locale = \Weline\Framework\App\Env::default_LANGUAGE_CODE;
$previewParams = [
    'theme_id' => $theme_id,
    'page_type' => $page_type,
    'layout_type' => $page_type,
    'layout_option' => $layout_option,
    'editor_mode' => '1',
    'preview_mode' => 'live',
    'status' => $preview_status,
    'editor_area' => $editor_area,
    'preview_area' => $editor_area,
    'frontend_theme_id' => $frontend_theme_id,
    'backend_theme_id' => $backend_theme_id,
    'locale' => (string)$this->request->getParam('locale', $default_locale),
    '_t' => time(),
];
if ($layout_editor_locked) {
    $previewParams['scope'] = (string)($layout_editor_lock['scope'] ?? ($preview_context['scope'] ?? 'default'));
    $previewTargetType = trim((string)($layout_editor_lock['target_type'] ?? ''));
    $previewTargetId = (int)($layout_editor_lock['target_id'] ?? 0);
    if ($previewTargetType !== '' && $previewTargetType !== 'global' && $previewTargetId > 0) {
        $previewParams['theme_layout_target_type'] = $previewTargetType;
        $previewParams['theme_layout_target_id'] = $previewTargetId;
        $previewParams['theme_layout_source_target_type'] = $previewTargetType;
        $previewParams['theme_layout_source_target_id'] = $previewTargetId;
    }
} else {
    $previewScope = trim((string)($preview_context['scope'] ?? $this->request->getParam('scope', '')));
    if ($previewScope !== '') {
        $previewParams['scope'] = $previewScope;
    }
    $previewTargetType = trim((string)(
        $preview_context['theme_layout_target_type']
        ?? $this->request->getParam('theme_layout_target_type', '')
    ));
    $previewTargetId = (int)(
        $preview_context['theme_layout_target_id']
        ?? $this->request->getParam('theme_layout_target_id', 0)
    );
    if ($previewTargetType !== '' && $previewTargetType !== 'global' && $previewTargetId > 0) {
        $previewParams['theme_layout_target_type'] = $previewTargetType;
        $previewParams['theme_layout_target_id'] = $previewTargetId;
        $previewParams['theme_layout_source_target_type'] = trim((string)(
            $preview_context['theme_layout_source_target_type']
            ?? $this->request->getParam('theme_layout_source_target_type', $previewTargetType)
        ));
        $previewParams['theme_layout_source_target_id'] = (int)(
            $preview_context['theme_layout_source_target_id']
            ?? $this->request->getParam('theme_layout_source_target_id', $previewTargetId)
        );
    }
}
$initialPreviewUrl = 'about:blank';
if ($theme_id) {
    $initialPreviewUrl = $editor_area === 'frontend'
        ? $this->getFrontendUrl('theme/frontend/theme-preview/content', $previewParams)
        : $this->getUrl('theme/backend/theme-editor/layout-preview', $previewParams);
}

// 根据后台配置获取文件管理器连接器 URL
$fileManagerCode = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Model\BackendUserConfig::class)->getConfig('file_manager') ?: 'weline_media';
$fileManagerConnectorUrl = match ($fileManagerCode) {
    'weline_media' => $this->getBackendUrl('media/backend/manager/iframe'),
    'elfinder' => $this->getBackendUrl('elfinder/backend/connector/manager'),
    default => $this->getBackendUrl('media/backend/manager/iframe'),
};

// 辅助：获取部件图标（闭包，避免模板多次包含时重复声明）
$getWidgetIcon = function ($type) {
    $icons = [
        'header' => 'ri-layout-top-line',
        'footer' => 'ri-layout-bottom-line',
        'sidebar' => 'ri-layout-left-line',
        'banner' => 'ri-image-line',
        'carousel' => 'ri-slideshow-line',
        'slider' => 'ri-slideshow-line',
        'product' => 'ri-shopping-bag-line',
        'category' => 'ri-folder-line',
        'navigation' => 'ri-menu-line',
        'search' => 'ri-search-line',
        'breadcrumb' => 'ri-route-line',
        'pagination' => 'ri-more-line',
        'social' => 'ri-share-line',
        'newsletter' => 'ri-mail-line',
        'testimonial' => 'ri-chat-quote-line',
        'faq' => 'ri-question-answer-line',
        'video' => 'ri-video-line',
        'content' => 'ri-file-text-line',
    ];
    return $icons[$type] ?? 'ri-widgets-line';
};
