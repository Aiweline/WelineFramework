<script>
(function () {
    document.addEventListener('click', function (event) {
        const actionButton = event.target.closest('[data-theme-editor-action]');
        if (!actionButton) {
            return;
        }

        const action = actionButton.getAttribute('data-theme-editor-action');
        if (action === 'toggle-version-panel' && typeof window.toggleVersionPanel === 'function') {
            window.toggleVersionPanel();
            return;
        }

        if (action === 'save-new-version') {
            document.getElementById('btnSave')?.click();
        }
    });
})();
</script>
