        syncing: '<?= htmlspecialchars((string)__('正在同步数据'), ENT_QUOTES, 'UTF-8') ?>',
        messageTitle: '<?= htmlspecialchars((string)__('操作完成'), ENT_QUOTES, 'UTF-8') ?>',
        messageBody: '<?= htmlspecialchars((string)__('数据已保存，可以继续编辑。'), ENT_QUOTES, 'UTF-8') ?>',
        modalTitle: '<?= htmlspecialchars((string)__('确认发布'), ENT_QUOTES, 'UTF-8') ?>',
        modalBody: '<?= htmlspecialchars((string)__('公开后同站点后台用户可见。'), ENT_QUOTES, 'UTF-8') ?>',
        cancel: '<?= htmlspecialchars((string)__('取消'), ENT_QUOTES, 'UTF-8') ?>',
        confirm: '<?= htmlspecialchars((string)__('确认'), ENT_QUOTES, 'UTF-8') ?>',
        previous: '<?= htmlspecialchars((string)__('上一页'), ENT_QUOTES, 'UTF-8') ?>',
        next: '<?= htmlspecialchars((string)__('下一页'), ENT_QUOTES, 'UTF-8') ?>',
        tabOverview: '<?= htmlspecialchars((string)__('概览'), ENT_QUOTES, 'UTF-8') ?>',
        tabSettings: '<?= htmlspecialchars((string)__('设置'), ENT_QUOTES, 'UTF-8') ?>',
        sectionTitle: '<?= htmlspecialchars((string)__('精选区块'), ENT_QUOTES, 'UTF-8') ?>',
        sectionSubtitle: '<?= htmlspecialchars((string)__('Section'), ENT_QUOTES, 'UTF-8') ?>',
        sectionBody: '<?= htmlspecialchars((string)__('拖入卡片、文本、图片或表单组件'), ENT_QUOTES, 'UTF-8') ?>',
        gridItem: '<?= htmlspecialchars((string)__('栅格项'), ENT_QUOTES, 'UTF-8') ?>',
        textTitle: '<?= htmlspecialchars((string)__('清晰表达你的页面主张'), ENT_QUOTES, 'UTF-8') ?>',
        textBody: '<?= htmlspecialchars((string)__('用标题和段落快速搭建页面内容。'), ENT_QUOTES, 'UTF-8') ?>',
        imageAlt: '<?= htmlspecialchars((string)__('图片媒体'), ENT_QUOTES, 'UTF-8') ?>',
        dividerLabel: '<?= htmlspecialchars((string)__('内容分隔'), ENT_QUOTES, 'UTF-8') ?>',
        spacerLabel: '<?= htmlspecialchars((string)__('留白间距'), ENT_QUOTES, 'UTF-8') ?>'
    };

    function normalizeCode(code) {
        const parts = String(code || '').replace(/\\/g, '/').toLowerCase().split('/').filter(Boolean);
        return parts.length ? parts[parts.length - 1] : '';
    }

    function previewHtml(code) {
        switch (normalizeCode(code)) {
            case 'alert':
                return '<div class="te-component-preview te-component-preview-alert"><div class="w-alert w-alert-info" role="alert"><i class="ri-information-line me-2"></i><strong>' + labels.alertTitle + '</strong><span>' + labels.alertBody + '</span></div></div>';
            case 'badge':
                return '<div class="te-component-preview te-component-preview-badge"><span class="w-badge w-badge-success">' + labels.enabled + '</span><span class="w-badge w-badge-info">' + labels.backend + '</span></div>';
            case 'button':
                return '<div class="te-component-preview te-component-preview-button"><button type="button" class="w-btn w-btn-primary w-btn-md"><i class="ri-flashlight-line"></i> ' + labels.primary + '</button><button type="button" class="w-btn w-btn-secondary w-btn-sm">' + labels.secondary + '</button></div>';
            case 'card':
                return '<div class="te-component-preview te-component-preview-card"><div class="w-card"><div class="w-card-header"><h3 class="w-card-title">' + labels.cardTitle + '</h3><p class="w-card-subtitle">' + labels.cardSubtitle + '</p></div><div class="w-card-body">' + labels.cardBody + '</div></div></div>';
            case 'dropdown':
                return '<div class="te-component-preview te-component-preview-dropdown"><div class="w-dropdown dropdown"><button type="button" class="w-btn w-btn-secondary w-dropdown-toggle dropdown-toggle">' + labels.action + '</button><div class="w-dropdown-menu dropdown-menu show"><a class="w-dropdown-item dropdown-item" href="#">' + labels.detail + '</a><a class="w-dropdown-item dropdown-item" href="#">' + labels.copy + '</a></div></div></div>';
            case 'section':
                return '<div class="te-component-preview te-component-preview-section"><section class="w-builder-section w-builder-section--subtle"><header class="w-builder-section__header"><p class="w-builder-section__eyebrow">' + labels.sectionSubtitle + '</p><h2 class="w-builder-section__title">' + labels.sectionTitle + '</h2><p class="w-builder-section__description">' + labels.sectionBody + '</p></header><div class="w-builder-slot-placeholder">' + labels.sectionBody + '</div></section></div>';
            case 'grid':
                return '<div class="te-component-preview te-component-preview-grid"><div class="w-builder-grid"><div class="w-card"><div class="w-card-body">' + labels.gridItem + ' 1</div></div><div class="w-card"><div class="w-card-body">' + labels.gridItem + ' 2</div></div><div class="w-card"><div class="w-card-body">' + labels.gridItem + ' 3</div></div></div></div>';
            case 'text':
                return '<div class="te-component-preview te-component-preview-text"><div class="w-builder-text w-builder-text--sm"><p class="w-builder-text__eyebrow">Text</p><h2 class="w-builder-text__title">' + labels.textTitle + '</h2><p class="w-builder-text__body">' + labels.textBody + '</p></div></div>';
            case 'image':
                return '<div class="te-component-preview te-component-preview-image"><figure class="w-builder-image w-builder-image--16x9"><div class="w-builder-image__placeholder">' + labels.imageAlt + '</div></figure></div>';
            case 'divider':
                return '<div class="te-component-preview te-component-preview-divider"><div class="w-builder-divider"><span class="w-builder-divider__label">' + labels.dividerLabel + '</span></div></div>';
            case 'spacer':
                return '<div class="te-component-preview te-component-preview-spacer"><div class="w-builder-spacer w-builder-spacer--md"></div><span>' + labels.spacerLabel + '</span></div>';
            case 'form-group':
                return '<div class="te-component-preview te-component-preview-form-group"><label class="w-form-label">' + labels.label + '</label><input class="w-form-control" type="text" value="' + labels.username + '" placeholder="' + labels.placeholder + '"></div>';
            case 'loading':
                return '<div class="te-component-preview te-component-preview-loading"><span class="w-loading-spinner"></span><span>' + labels.syncing + '</span></div>';
            case 'message':
                return '<div class="te-component-preview te-component-preview-message"><div class="w-message w-message-success"><i class="ri-checkbox-circle-line"></i><div><strong>' + labels.messageTitle + '</strong><span>' + labels.messageBody + '</span></div></div></div>';
            case 'modal':
                return '<div class="te-component-preview te-component-preview-modal"><div class="w-modal-preview"><div class="w-modal-header"><strong>' + labels.modalTitle + '</strong><span aria-hidden="true">×</span></div><div class="w-modal-body">' + labels.modalBody + '</div><div class="w-modal-footer"><button type="button" class="w-btn w-btn-secondary w-btn-sm">' + labels.cancel + '</button><button type="button" class="w-btn w-btn-primary w-btn-sm">' + labels.confirm + '</button></div></div></div>';
            case 'pagination':
                return '<div class="te-component-preview te-component-preview-pagination"><nav class="w-pagination"><a href="#">' + labels.previous + '</a><a href="#">1</a><a class="active" href="#">2</a><a href="#">3</a><a href="#">' + labels.next + '</a></nav></div>';
            case 'table':
                return '<div class="te-component-preview te-component-preview-table"><table class="w-table w-table-striped"><thead><tr><th>' + labels.metric + '</th><th>' + labels.status + '</th><th>' + labels.trend + '</th></tr></thead><tbody><tr><td>' + labels.order + '</td><td>' + labels.ok + '</td><td>+12%</td></tr><tr><td>' + labels.payment + '</td><td>' + labels.stable + '</td><td>+4%</td></tr></tbody></table></div>';
            case 'tabs':
                return '<div class="te-component-preview te-component-preview-tabs"><div class="w-tabs"><div class="w-tab-list"><button type="button" class="active">' + labels.tabOverview + '</button><button type="button">' + labels.tabSettings + '</button></div><div class="w-tab-panel">' + labels.cardBody + '</div></div></div>';
            default:
                return '';
        }
    }

    function patchCanvases(root) {
        (root || document).querySelectorAll('.widget-preview-canvas').forEach(function (canvas) {
            const item = canvas.closest('.widget-item[data-widget-code]');
            const code = canvas.getAttribute('data-widget-code') || (item ? item.getAttribute('data-widget-code') : '');
            const html = previewHtml(code);
            if (!html || (canvas.firstElementChild && canvas.firstElementChild.classList.contains('te-component-preview'))) {
                return;
            }
            if (code && !canvas.getAttribute('data-widget-code')) {
                canvas.setAttribute('data-widget-code', code);
            }
            canvas.innerHTML = html;
            canvas.dataset.previewLoaded = '1';
        });
    }

    function patchModalPreview() {
        const code = window.__welineComponentPreviewCode || '';
        const html = previewHtml(code);
        if (!html) {
            return;
        }
        document.querySelectorAll('#componentPreviewModal .component-preview-inner').forEach(function (inner) {
            inner.innerHTML = html;
        });
    }

    document.addEventListener('click', function (event) {
        const button = event.target.closest('.btn-preview-component[data-widget-code]');
        if (button) {
            window.__welineComponentPreviewCode = button.getAttribute('data-widget-code') || '';
            window.setTimeout(patchModalPreview, 120);
            window.setTimeout(patchModalPreview, 600);
            window.setTimeout(patchModalPreview, 1400);
        }
    }, true);

    function bootPreviewPatch() {
        patchCanvases(document);
        window.setTimeout(function () { patchCanvases(document); }, 300);
        window.setTimeout(function () { patchCanvases(document); }, 1200);
        window.setTimeout(function () { patchCanvases(document); }, 2400);
        let patchTimer = null;
        const observer = new MutationObserver(function (records) {
            let shouldPatchDocument = false;
            records.forEach(function (record) {
                record.addedNodes.forEach(function (node) {
                    if (node && node.nodeType === 1) {
                        patchCanvases(node);
                        shouldPatchDocument = true;
                    }
                });
            });
            if (shouldPatchDocument) {
                window.clearTimeout(patchTimer);
                patchTimer = window.setTimeout(function () {
                    patchCanvases(document);
                    patchModalPreview();
                }, 80);
            }
        });
        observer.observe(document.body, {childList: true, subtree: true});
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootPreviewPatch);
    } else {
        bootPreviewPatch();
    }
})();
</script>
