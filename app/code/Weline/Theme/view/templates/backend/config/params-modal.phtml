<!-- 参数配置模态框 -->
<div class="modal fade" id="paramsModal" tabindex="-1" aria-labelledby="paramsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paramsModalLabel"><?= __('参数配置') ?></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<?= __('关闭') ?>"></button>
            </div>
            <div class="modal-body">
                <form id="paramsForm">
                    <!-- 参数表单将动态生成 -->
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('取消') ?></button>
                <button type="button" class="btn btn-primary" data-params-save><?= __('保存') ?></button>
            </div>
        </div>
    </div>
</div>
<script>
(function () {
    document.addEventListener('click', function (event) {
        const saveButton = event.target.closest('[data-params-save]');
        if (!saveButton) {
            return;
        }

        if (typeof window.saveParams === 'function') {
            window.saveParams();
        }
    });
})();
</script>
