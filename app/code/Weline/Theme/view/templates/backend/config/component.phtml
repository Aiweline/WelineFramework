    if (($area ?? 'frontend') === 'backend') {
        // 后端资源
        ?>
        <css>Weline_Admin::backend/lib/bootstrap-5.1.3-dist/css/bootstrap.min.css</css>
        <css>Weline_Admin::backend/lib/font-awesome-4.7.0/css/font-awesome.min.css</css>
        <js>Weline_Backend::/backend/lib/jquery/3.6.0/jquery.js</js>
        <?php
    } else {
        // 前端资源
        ?>
        <css>Weline_Frontend::libs/bootstrap-5.1.3-dist/css/bootstrap.min.css</css>
        <css>Weline_Frontend::/libs/font-awesome-4.7.0/css/font-awesome.min.css</css>
        <js>Weline_Frontend::/libs/jquery/3.6.0/jquery.js</js>
        <?php
    }
    ?>
    
    <style>
        body {
            background-color: #f5f5f5;
            padding: 20px;
        }
        .component-preview-container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
