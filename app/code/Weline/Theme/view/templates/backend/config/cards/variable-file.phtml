<?php
/** @var \Weline\Framework\View\Template $this */
/** @var \Weline\Theme\Model\WelineTheme $theme */
/** @var string $area */
/** @var string $scope */
/** @var array $variables 变量数组，按文件分组，格式：['file' => ['name' => '...', 'variables' => [...], 'variable_count' => 10, 'configured_count' => 5], ...] */
?>
<div class="row g-3" id="variable-files-container">
    <?php foreach ($variables as $fileName => $variable): 
        $name = $variable['name'] ?? ucfirst($fileName);
        $description = $variable['description'] ?? '';
        $variableCount = $variable['variable_count'] ?? 0;
        $configuredCount = $variable['configured_count'] ?? 0;
        $configProgress = $variableCount > 0 ? round(($configuredCount / $variableCount) * 100) : 0;
    ?>
        <div class="col-md-6 col-lg-4">
            <div class="card variable-file-card h-100" 
                 data-file-name="<?= htmlspecialchars((string)$fileName, ENT_QUOTES, 'UTF-8') ?>"
                 style="cursor: pointer; transition: all 0.2s;">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <h6 class="card-title mb-0"><?= htmlspecialchars($name) ?></h6>
                        <span class="badge bg-info"><?= $variableCount ?> <?= __('变量') ?></span>
                    </div>
                    <?php if (!empty($description)): ?>
                        <p class="card-text text-muted small mb-2"><?= htmlspecialchars($description) ?></p>
                    <?php endif; ?>
                    
                    <!-- 配置进度 -->
                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-muted"><?= __('配置进度') ?></small>
                            <small class="text-muted"><?= $configuredCount ?>/<?= $variableCount ?></small>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar" role="progressbar" 
                                 style="width: <?= $configProgress ?>%" 
                                 aria-valuenow="<?= $configProgress ?>" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                            </div>
                        </div>
                    </div>
                    
                    <button type="button" 
                            class="btn btn-sm btn-primary w-100"
                            data-file-name="<?= htmlspecialchars((string)$fileName, ENT_QUOTES, 'UTF-8') ?>"
                            data-variable-file-config-trigger>
                        <i class="mdi mdi-cog"></i> <?= __('配置变量') ?>
                    </button>
                </div>
            </div>
        </div>
    <?php endforeach; ?>
</div>
<small class="text-muted d-block mt-3">
    <i class="mdi mdi-information-outline"></i>
    <?= __('点击"配置变量"按钮编辑变量文件中的变量值') ?>
</small>

<?php
$themeId = $theme && is_object($theme) && method_exists($theme, 'getId') ? $theme->getId() : ($theme['id'] ?? $theme['identity_id'] ?? null);
$getUrl = $this->getUrl('theme/backend/config/layout/getVariableFileData');
$modalUrl = $this->getUrl('theme/backend/config/layout/getVariableFileModal');
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
?>
<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    const themeId = <?= json_encode($themeId, $jsonForScriptFlags) ?>;
    const area = <?= json_encode($area, $jsonForScriptFlags) ?>;
    const scope = <?= json_encode($scope, $jsonForScriptFlags) ?>;
    const getUrl = <?= json_encode($getUrl, $jsonForScriptFlags) ?>;
    const modalUrl = <?= json_encode($modalUrl, $jsonForScriptFlags) ?>;
    const selectThemeTitle = <?= json_encode((string)__('提示'), $jsonForScriptFlags) ?>;
    const selectThemeText = <?= json_encode((string)__('请先选择主题'), $jsonForScriptFlags) ?>;
    const confirmButtonText = <?= json_encode((string)__('确定'), $jsonForScriptFlags) ?>;
    const loadFailedText = <?= json_encode((string)__('加载失败'), $jsonForScriptFlags) ?>;
    const networkErrorText = <?= json_encode((string)__('网络错误'), $jsonForScriptFlags) ?>;

    function renderAlert(target, className, message) {
        if (!target) {
            return;
        }
        const alert = document.createElement('div');
        alert.className = className;
        alert.textContent = String(message || '');
        target.innerHTML = '';
        target.appendChild(alert);
    }

    const variableFilesContainer = document.getElementById('variable-files-container');
    if (variableFilesContainer) {
        variableFilesContainer.addEventListener('click', function(event) {
            const configButton = event.target.closest('[data-variable-file-config-trigger]');
            if (!configButton || !variableFilesContainer.contains(configButton)) {
                return;
            }

            event.preventDefault();
            event.stopPropagation();
            const fileName = configButton.getAttribute('data-file-name');
            if (fileName) {
                window.openVariableFileConfigModal(fileName);
            }
        });
    }
    
    window.openVariableFileConfigModal = function(fileName) {
        if (!themeId) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: selectThemeTitle,
                    text: selectThemeText,
                    confirmButtonText: confirmButtonText
                });
            } else {
                console.error(selectThemeText);
            }
            return;
        }
        
        // 显示加载状态
        const loadingHtml = `
            <div class="modal fade" id="variableFileConfigModal" tabindex="-1">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><?= __('配置变量文件') ?></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden"><?= __('加载中...') ?></span>
                            </div>
                            <p class="mt-3"><?= __('正在加载变量数据...') ?></p>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        // 移除现有弹窗
        const existingModal = document.getElementById('variableFileConfigModal');
        if (existingModal) {
            existingModal.remove();
        }
        
        // 添加加载弹窗
        document.body.insertAdjacentHTML('beforeend', loadingHtml);
        const modal = document.getElementById('variableFileConfigModal');
        const bsModal = new bootstrap.Modal(modal);
        bsModal.show();
        
        // 获取数据并加载弹窗
        const formData = new FormData();
        formData.append('theme_id', themeId);
        formData.append('area', area);
        formData.append('scope', scope);
        formData.append('file_name', fileName);
        
        window.Weline.Api.request(getUrl, { method: 'POST', body: formData })
        .then(function(response) {
            var data = response.data;
            if (response.ok && data && data.code === 200 && data.data && data.data.variable) {
                var variableJson = encodeURIComponent(JSON.stringify(data.data.variable));
                var loadUrl = modalUrl + '?variable=' + variableJson + '&file_name=' + encodeURIComponent(fileName) + '&area=' + area + '&scope=' + scope + '&theme_id=' + themeId;
                return window.Weline.Api.request(loadUrl, { method: 'GET' }).then(function(r2) {
                    var html = (r2.data && typeof r2.data === 'string') ? r2.data : (r2.data ? String(r2.data) : '');
                    var modalContent = modal.querySelector('.modal-content');
                    if (modalContent && html) {
                        modalContent.outerHTML = html;
                        var newModal = document.getElementById('variableFileConfigModal');
                        if (newModal) {
                            var newBsModal = new bootstrap.Modal(newModal);
                            newBsModal.show();
                        }
                    }
                });
            } else {
                renderAlert(modal.querySelector('.modal-body'), 'alert alert-danger', (data && (data.msg || data.message)) || loadFailedText);
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            var msg = error && error.message ? error.message : networkErrorText;
            renderAlert(modal.querySelector('.modal-body'), 'alert alert-danger', msg);
        });
    };
})();
</script>

