$discardPreviewScopeUrl = $this->getUrl('theme/backend/config/themeConfig/discardPreviewScope');

$themeIdValue = 0;
$themeNameValue = __('未选择主题');
if (is_object($theme)) {
    if (method_exists($theme, 'getId')) {
        $themeIdValue = (int)$theme->getId();
    }
    if (method_exists($theme, 'getName') && $theme->getName()) {
        $themeNameValue = (string)$theme->getName();
    }
} elseif (is_array($theme)) {
    $themeIdValue = (int)($theme['id'] ?? 0);
    if (!empty($theme['name'])) {
        $themeNameValue = (string)$theme['name'];
    }
}
$hasTheme = $themeIdValue > 0;
