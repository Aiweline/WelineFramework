<?php
$themeId = $theme && is_object($theme) && method_exists($theme, 'getId') ? $theme->getId() : ($theme['id'] ?? $theme['identity_id'] ?? null);
$saveUrl = $this->getUrl('theme/backend/config/layout/saveColorPalette');
$saveVariablesUrl = $this->getUrl('theme/backend/config/layout/saveColorPaletteVariables');
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
?>
<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    const themeId = <?= json_encode($themeId, $jsonForScriptFlags) ?>;
    const area = <?= json_encode($area, $jsonForScriptFlags) ?>;
    const scope = <?= json_encode($scope, $jsonForScriptFlags) ?>;
    const saveUrl = <?= json_encode($saveUrl, $jsonForScriptFlags) ?>;
    const saveVariablesUrl = <?= json_encode($saveVariablesUrl, $jsonForScriptFlags) ?>;
    const selectThemeText = <?= json_encode((string)__('请先选择主题'), $jsonForScriptFlags) ?>;
    const loadFailedText = <?= json_encode((string)__('加载失败'), $jsonForScriptFlags) ?>;
    const loadModalFailedText = <?= json_encode((string)__('加载弹窗失败'), $jsonForScriptFlags) ?>;
    const networkErrorText = <?= json_encode((string)__('网络错误'), $jsonForScriptFlags) ?>;

    function renderAlert(target, className, message) {
        if (!target) {
            return;
        }
        const alert = document.createElement('div');
        alert.className = className;
        alert.textContent = String(message || '');
        target.innerHTML = '';
        target.appendChild(alert);
    }
    
    // 色盘选择处理
    document.addEventListener('DOMContentLoaded', function() {
        const container = document.getElementById('color-palette-container');
        if (!container) return;
        
        container.addEventListener('click', function(e) {
            const configButton = e.target.closest('[data-palette-config-trigger]');
            if (configButton && container.contains(configButton)) {
                e.preventDefault();
                e.stopPropagation();
                const paletteName = configButton.getAttribute('data-palette-name');
                if (paletteName) {
                    window.openColorPaletteConfigModal(paletteName);
                }
                return;
            }

            const card = e.target.closest('.color-palette-wheel-card');
            if (!card || e.target.closest('.color-wheel-config-btn')) {
                return;
            }
            
            const paletteName = card.getAttribute('data-palette-name');
            if (!paletteName) return;
            
            // 保存色盘选择
            saveColorPalette(paletteName);
        });
    });

    function saveColorPalette(paletteName) {
        if (!themeId) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择主题') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请先选择主题') ?>');
            }
            return;
        }
        
        const formData = new FormData();
        formData.append('theme_id', themeId);
        formData.append('area', area);
        formData.append('scope', scope);
        formData.append('palette_name', paletteName);
        
        var opts = { method: 'POST', body: formData };
        window.Weline.Api.request(saveUrl, opts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            if (data.code === 200) {
                // 更新选中状态
                document.querySelectorAll('.color-palette-wheel-card').forEach(card => {
                    card.classList.remove('selected');
                });
                const selectedCard = Array.from(document.querySelectorAll('.color-palette-wheel-card'))
                    .find(card => card.getAttribute('data-palette-name') === paletteName);
                if (selectedCard) {
                    selectedCard.classList.add('selected');
                    // 添加选中标记
                    if (!selectedCard.querySelector('.color-wheel-check')) {
                        const check = document.createElement('div');
                        check.className = 'color-wheel-check';
                        check.innerHTML = '<i class="mdi mdi-check-circle"></i>';
                        selectedCard.querySelector('.color-wheel-wrapper').appendChild(check);
                    }
                }
                
                // 触发预览刷新
                if (typeof refreshPreview === 'function') {
                    refreshPreview();
                }
                
                // 显示成功提示
                if (typeof showSaveToast === 'function') {
                    showSaveToast('<?= __('色盘选择已保存') ?>', 'success');
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.msg || '<?= __('保存失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error(data.msg || '<?= __('保存失败') ?>');
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('保存失败') ?>: ' + error.message);
            }
        });
    }

    window.openColorPaletteConfigModal = function(paletteName) {
        if (!themeId) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择主题') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(selectThemeText);
            }
            return;
        }
        
        const getUrl = <?= json_encode($this->getUrl('theme/backend/config/layout/getColorPaletteVariables'), $jsonForScriptFlags) ?>;
        const modalUrl = <?= json_encode($this->getUrl('theme/backend/config/layout/getColorPaletteModal'), $jsonForScriptFlags) ?>;
        
        // 显示加载状态
        const loadingHtml = `
            <div class="modal fade" id="colorPaletteVariablesModal" tabindex="-1">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><?= __('配置色系变量') ?></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden"><?= __('加载中...') ?></span>
                            </div>
                            <p class="mt-3"><?= __('正在加载色盘变量...') ?></p>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        // 移除现有弹窗
        const existingModal = document.getElementById('colorPaletteVariablesModal');
        if (existingModal) {
            existingModal.remove();
        }
        
        // 添加加载弹窗
        document.body.insertAdjacentHTML('beforeend', loadingHtml);
        const modal = document.getElementById('colorPaletteVariablesModal');
        const bsModal = new bootstrap.Modal(modal);
        bsModal.show();
        
        // 获取数据
        const formData = new FormData();
        formData.append('theme_id', themeId);
        formData.append('area', area);
        formData.append('scope', scope);
        formData.append('palette_name', paletteName);
        
        var getOpts = { method: 'POST', body: formData };
        window.Weline.Api.request(getUrl, getOpts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            if (data.code === 200 && data.data && data.data.palette) {
                // 使用AJAX加载弹窗内容
                const paletteJson = encodeURIComponent(JSON.stringify(data.data.palette));
                var modalFetchUrl = modalUrl + '?palette=' + paletteJson + '&palette_name=' + encodeURIComponent(paletteName) + '&area=' + area + '&scope=' + scope + '&theme_id=' + themeId;
                fetch(modalFetchUrl, { method: 'GET' })
                .then(function(r) { return r.text(); })
                .then(html => {
                    const modalContent = modal.querySelector('.modal-content');
                    if (modalContent) {
                        modalContent.outerHTML = html;
                        const newModal = document.getElementById('colorPaletteVariablesModal');
                        if (newModal) {
                            const newBsModal = new bootstrap.Modal(newModal);
                            newBsModal.show();
                        }
                    }
                })
                .catch(error => {
                    console.error('Error loading modal:', error);
                    renderAlert(modal.querySelector('.modal-body'), 'alert alert-danger', loadModalFailedText + ': ' + (error && error.message ? error.message : ''));
                });
            } else {
                renderAlert(modal.querySelector('.modal-body'), 'alert alert-danger', (data && data.msg) || loadFailedText);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            renderAlert(modal.querySelector('.modal-body'), 'alert alert-danger', networkErrorText + ': ' + (error && error.message ? error.message : ''));
        });
    };
})();
</script>

