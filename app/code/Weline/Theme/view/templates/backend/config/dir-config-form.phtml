                // 计算文本颜色（根据背景色亮度）
                function getContrastColor($hexColor) {
                    $hexColor = ltrim($hexColor, '#');
                    if (strlen($hexColor) === 3) {
                        $hexColor = $hexColor[0] . $hexColor[0] . $hexColor[1] . $hexColor[1] . $hexColor[2] . $hexColor[2];
                    }
                    $r = hexdec(substr($hexColor, 0, 2));
                    $g = hexdec(substr($hexColor, 2, 2));
                    $b = hexdec(substr($hexColor, 4, 2));
                    $brightness = ($r * 299 + $g * 587 + $b * 114) / 1000;
                    return $brightness > 128 ? '#000' : '#fff';
                }
                
                // 生成色盘颜色数组（从主色和次色生成渐变色）
                function generateColorPalette($primaryColor, $secondaryColor) {
                    $colors = [$primaryColor];
                    if ($secondaryColor) {
                        $colors[] = $secondaryColor;
                    }
                    // 生成一些中间色
                    if (count($colors) < 6) {
                        $colors = array_merge($colors, [
                            $primaryColor,
                            $secondaryColor ?: $primaryColor,
                            $primaryColor,
                            $secondaryColor ?: $primaryColor
                        ]);
                    }
                    return array_slice($colors, 0, 6);
                }
                
                foreach ($options as $option): 
                    $isSelected = (isset($config[$type]) && $config[$type] === $option['value']);
                    $itemName = $option['label'] ?? ucfirst($option['value']);
                    $itemDescription = $option['meta']['description'] ?? '';
                    $themeIdentifier = $option['meta']['theme'] ?? $option['value'];
                    $primaryColor = $option['meta']['primary_color'] ?? '';
                    $secondaryColor = $option['meta']['secondary_color'] ?? '';
                    
                    // 根据主题标识设置默认颜色
                    if (empty($primaryColor)) {
                        switch ($themeIdentifier) {
                            case 'light':
                                $primaryColor = '#ffffff';
                                $secondaryColor = '#f8f9fa';
                                break;
                            case 'dark':
                                $primaryColor = '#1a1a1a';
                                $secondaryColor = '#2d2d2d';
                                break;
                            case 'amazon':
                                $primaryColor = '#ff9900';
                                $secondaryColor = '#131921';
                                break;
                            default:
                                $primaryColor = '#0d6efd';
                                $secondaryColor = '#6c757d';
                        }
                    }
                    
                    $colorPalette = generateColorPalette($primaryColor, $secondaryColor);
                    
                    // 生成色盘渐变色（使用主色和次色生成更丰富的渐变）
                    $gradientColors = [];
                    if ($secondaryColor && $secondaryColor !== $primaryColor) {
                        // 如果有次色，生成从主色到次色的渐变
                        $gradientColors = [
                            $primaryColor . ' 0deg',
                            $primaryColor . ' 45deg',
                            $secondaryColor . ' 90deg',
                            $secondaryColor . ' 135deg',
                            $primaryColor . ' 180deg',
                            $primaryColor . ' 225deg',
                            $secondaryColor . ' 270deg',
                            $secondaryColor . ' 315deg',
                            $primaryColor . ' 360deg'
                        ];
                    } else {
                        // 如果只有主色，生成单色渐变
                        $gradientColors = [
                            $primaryColor . ' 0deg',
                            $primaryColor . ' 120deg',
                            $primaryColor . ' 240deg',
                            $primaryColor . ' 360deg'
                        ];
                    }
                    $gradientString = implode(', ', $gradientColors);
                ?>
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="color-palette-wheel-card <?= $isSelected ? 'selected' : '' ?>" 
                             data-colors-value="<?= htmlspecialchars($option['value']) ?>"
