    <script>
    // 卡片选择初始化 - 使用直接绑定方式
    (function() {
        var type = '<?= $type ?>';
        var cardClass, valueAttr, valueInputId;
        
        if (type === 'colors') {
            cardClass = '.color-palette-wheel-card';
            valueAttr = 'data-colors-value';
            valueInputId = 'colors-value';
        } else {
            cardClass = '.' + type + '-card';
            valueAttr = 'data-' + type + '-value';
            valueInputId = type + '-value';
        }
        
        // 检查是否是需要卡片选择的类型
        if (['layout', 'partial', 'component', 'colors'].indexOf(type) === -1) {
            return;
        }
        
        // 直接查找并绑定事件到所有卡片
        var cards = document.querySelectorAll('#dir-config-form ' + cardClass);
        console.log('[dir-config-form] 查找卡片:', cardClass, '找到:', cards.length);
        
        cards.forEach(function(card) {
            card.style.cursor = 'pointer';
            card.onclick = function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                var cardValue = card.getAttribute(valueAttr);
                console.log('[dir-config-form] 点击卡片:', cardValue);
                
                if (!cardValue) {
                    console.warn('[dir-config-form] 卡片缺少属性:', valueAttr);
                    return;
                }
                
                // 移除所有卡片的选中状态
                cards.forEach(function(c) {
                    if (type === 'colors') {
                        c.classList.remove('selected');
                        var checkMark = c.querySelector('.color-wheel-check');
                        if (checkMark) {
                            checkMark.remove();
                        }
                    } else {
                        c.classList.remove('border-primary', 'shadow-sm');
                        c.style.borderWidth = '';
                        var badge = c.querySelector('.badge.bg-primary');
                        if (badge && badge.textContent === '<?= __('已选中') ?>') {
                            badge.remove();
                        }
                    }
                });
                
                // 设置当前卡片为选中状态
                if (type === 'colors') {
                    card.classList.add('selected');
                    // 添加选中标记
                    var wheelWrapper = card.querySelector('.color-wheel-wrapper');
                    if (wheelWrapper && !wheelWrapper.querySelector('.color-wheel-check')) {
                        var checkMark = document.createElement('div');
                        checkMark.className = 'color-wheel-check';
                        checkMark.innerHTML = '<i class="mdi mdi-check-circle"></i>';
                        wheelWrapper.appendChild(checkMark);
                    }
                } else {
                    card.classList.add('border-primary', 'shadow-sm');
                    card.style.borderWidth = '2px';
                    
                    // 添加选中徽章
                    var cardTitle = card.querySelector('.card-title');
                    if (cardTitle && !card.querySelector('.badge.bg-primary')) {
                        var badge = document.createElement('span');
                        badge.className = 'badge bg-primary';
                        badge.textContent = '<?= __('已选中') ?>';
                        cardTitle.parentElement.insertBefore(badge, cardTitle.nextSibling);
                    }
                }
                
                // 更新隐藏字段的值
                var valueInput = document.getElementById(valueInputId);
                if (valueInput) {
                    valueInput.value = cardValue;
                    console.log('[dir-config-form] 更新隐藏字段:', valueInputId, '=', cardValue);
                } else {
                    console.error('[dir-config-form] 未找到隐藏字段:', valueInputId);
                }
            };
        });
        
        console.log('[dir-config-form] 卡片事件绑定完成, type=' + type + ', cards=' + cards.length);
        
        // 初始化已选中的卡片状态
        if (type === 'colors') {
            cards.forEach(function(card) {
                if (card.classList.contains('selected')) {
                    var wheelWrapper = card.querySelector('.color-wheel-wrapper');
                    if (wheelWrapper && !wheelWrapper.querySelector('.color-wheel-check')) {
                        var checkMark = document.createElement('div');
                        checkMark.className = 'color-wheel-check';
                        checkMark.innerHTML = '<i class="mdi mdi-check-circle"></i>';
                        wheelWrapper.appendChild(checkMark);
                    }
                }
            });
            
            // 绑定配置按钮点击事件
            var configBtns = document.querySelectorAll('#dir-config-form .color-wheel-config-btn');
            configBtns.forEach(function(btn) {
                btn.onclick = function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    var colorFile = btn.getAttribute('data-color-file');
                    var colorValue = btn.getAttribute('data-color-value');
                    var themeId = document.querySelector('input[name="theme_id"]')?.value || 
                                  document.querySelector('input[name="identity_id"]')?.value;
                    var area = document.querySelector('input[name="area"]')?.value || 'frontend';
                    var scope = document.querySelector('input[name="scope"]')?.value || 'default';
                    
                    if (!colorFile || !colorValue || !themeId) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: '<?= __('提示') ?>',
                                text: '<?= __('缺少必要参数') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        } else {
                            console.error('<?= __('缺少必要参数') ?>');
                        }
                        return;
                    }
                    
                    // 打开配置弹窗
                    openColorConfigModal({
                        themeId: themeId,
                        area: area,
                        scope: scope,
                        colorFile: colorFile,
                        colorValue: colorValue
                    });
                };
            });
        }
        
        // 打开色系配置弹窗
        function openColorConfigModal(params) {
            var modalId = 'color-config-modal';
            var existingModal = document.getElementById(modalId);
            if (existingModal) {
                existingModal.remove();
            }
            
            // 创建模态框
            var modal = document.createElement('div');
            modal.id = modalId;
            modal.className = 'modal fade';
            modal.setAttribute('tabindex', '-1');
            modal.innerHTML = `
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="mdi mdi-palette me-2"></i>
                                <?= __('配置色系') ?>: <span id="color-config-name"></span>
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden"><?= __('加载中...') ?></span>
                                </div>
                                <p class="mt-2"><?= __('正在读取颜色变量...') ?></p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('取消') ?></button>
                            <button type="button" class="btn btn-primary" id="save-color-config-btn" disabled>
                                <i class="mdi mdi-content-save me-1"></i>
                                <?= __('保存配置') ?>
                            </button>
                        </div>
                    </div>
                </div>
            `;
            
            document.body.appendChild(modal);
            var bsModal = new bootstrap.Modal(modal);
            bsModal.show();
            
            // 加载颜色变量
            loadColorVariables(params, modal);
            
            // 清理：模态框关闭时移除
            modal.addEventListener('hidden.bs.modal', function() {
                modal.remove();
            });
        }
        
        // 加载颜色变量
        function loadColorVariables(params, modal) {
            var url = '<?= $this->getUrl("theme/backend/config/layout/getColorVariables") ?? "/theme/backend/config/layout/getColorVariables" ?>';
            var formData = new FormData();
            formData.append('theme_id', params.themeId);
            formData.append('area', params.area);
            formData.append('scope', params.scope);
            formData.append('color_file', params.colorFile);
            formData.append('color_value', params.colorValue);
            
            fetch(url, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    renderColorConfigForm(data.data, modal, params);
                } else {
                    showError(data.msg || '<?= __('加载失败') ?>', modal);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showError('<?= __('网络错误') ?>', modal);
            });
        }
        
        // 渲染颜色配置表单
        function renderColorConfigForm(data, modal, params) {
            var modalBody = modal.querySelector('.modal-body');
            var colorName = data.colorName || params.colorValue;
            document.getElementById('color-config-name').textContent = colorName;
            
            var variables = data.variables || [];
            if (variables.length === 0) {
                modalBody.innerHTML = '<div class="alert alert-info"><?= __('未找到颜色变量') ?></div>';
                return;
            }
            
            // 按分类组织变量
            var grouped = {};
            variables.forEach(function(variable) {
                var category = variable.category || '其他';
                if (!grouped[category]) {
                    grouped[category] = [];
                }
                grouped[category].push(variable);
            });
            
            var html = '<div class="color-variables-config">';
            for (var category in grouped) {
                html += '<div class="color-category mb-4">';
                html += '<h6 class="mb-3"><i class="mdi mdi-folder-outline me-1"></i>' + category + '</h6>';
                html += '<div class="row g-3">';
                
                grouped[category].forEach(function(variable) {
                    html += '<div class="col-md-6 col-lg-4">';
                    html += '<div class="color-variable-item">';
                    html += '<label class="form-label small">' + variable.name + '</label>';
                    html += '<div class="input-group">';
                    html += '<input type="color" class="form-control form-control-color" value="' + variable.value + '" data-var-name="' + variable.name + '" style="width: 60px;">';
                    html += '<input type="text" class="form-control" value="' + variable.value + '" data-var-name="' + variable.name + '" placeholder="#000000">';
                    html += '</div>';
                    if (variable.description) {
                        html += '<small class="text-muted">' + variable.description + '</small>';
                    }
                    html += '</div>';
                    html += '</div>';
                });
                
                html += '</div>';
                html += '</div>';
            }
            html += '</div>';
            
            modalBody.innerHTML = html;
            
            // 绑定颜色选择器和文本输入框的同步
            modalBody.querySelectorAll('input[type="color"]').forEach(function(colorInput) {
                var inputGroup = colorInput.closest('.input-group');
                var textInput = inputGroup ? inputGroup.querySelector('input[type="text"][data-var-name]') : null;
                if (textInput) {
                    colorInput.addEventListener('input', function() {
                        textInput.value = this.value.toUpperCase();
                    });
                }
            });
            
            modalBody.querySelectorAll('input[type="text"][data-var-name]').forEach(function(textInput) {
                var inputGroup = textInput.closest('.input-group');
                var colorInput = inputGroup ? inputGroup.querySelector('input[type="color"]') : null;
                if (colorInput) {
                    textInput.addEventListener('input', function() {
                        var value = this.value.trim();
                        if (/^#[0-9A-Fa-f]{6}$/i.test(value)) {
                            colorInput.value = value.toUpperCase();
                        }
                    });
                    textInput.addEventListener('blur', function() {
                        var value = this.value.trim();
                        if (!/^#[0-9A-Fa-f]{6}$/i.test(value) && value !== '') {
                            // 如果不是有效的颜色值，尝试转换或恢复
                            if (/^#[0-9A-Fa-f]{3}$/i.test(value)) {
                                // 3位转6位
                                var hex = value.substring(1);
                                value = '#' + hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
                                this.value = value.toUpperCase();
                                colorInput.value = value.toUpperCase();
                            } else {
                                // 恢复为颜色选择器的值
                                this.value = colorInput.value;
                            }
                        }
                    });
                }
            });
            
            // 启用保存按钮
            var saveBtn = document.getElementById('save-color-config-btn');
            saveBtn.disabled = false;
            saveBtn.onclick = function() {
                saveColorConfig(modal, params);
            };
        }
        
        // 保存颜色配置
        function saveColorConfig(modal, params) {
            var variables = {};
            modal.querySelectorAll('input[type="text"][data-var-name]').forEach(function(input) {
                var varName = input.getAttribute('data-var-name');
                var varValue = input.value.trim();
                if (varName && varValue) {
                    variables[varName] = varValue;
                }
            });
            
            var saveBtn = document.getElementById('save-color-config-btn');
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __('保存中...') ?>';
            
            var url = '<?= $this->getUrl("theme/backend/config/layout/saveColorVariables") ?? "/theme/backend/config/layout/saveColorVariables" ?>';
            var formData = new FormData();
            formData.append('theme_id', params.themeId);
            formData.append('area', params.area);
            formData.append('scope', params.scope);
            formData.append('color_file', params.colorFile);
            formData.append('color_value', params.colorValue);
            formData.append('variables', JSON.stringify(variables));
            
            fetch(url, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: '<?= __('配置保存成功') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        console.log('<?= __('配置保存成功') ?>');
                    }
                    bootstrap.Modal.getInstance(modal).hide();
                    // 可以刷新页面或更新色盘显示
                    if (typeof window.location !== 'undefined') {
                        window.location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: data.msg || '<?= __('保存失败') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(data.msg || '<?= __('保存失败') ?>');
                    }
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = '<i class="mdi mdi-content-save me-1"></i><?= __('保存配置') ?>';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('网络错误') ?>',
                        text: '<?= __('请重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('网络错误') ?>');
                }
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="mdi mdi-content-save me-1"></i><?= __('保存配置') ?>';
            });
        }
        
        // 显示错误
        function showError(message, modal) {
            var modalBody = modal.querySelector('.modal-body');
            modalBody.innerHTML = '<div class="alert alert-danger">' + message + '</div>';
        }
    })();
    </script>
    
