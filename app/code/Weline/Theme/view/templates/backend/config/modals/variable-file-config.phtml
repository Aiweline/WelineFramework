<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    const saveUrl = <?= json_encode($saveUrl) ?>;
    const modal = document.getElementById('variableFileConfigModal');
    if (!modal) return;
    
    // 颜色选择器和文本输入框同步
    modal.querySelectorAll('.variable-color-input').forEach(function(colorInput) {
        const textInput = colorInput.nextElementSibling;
        if (textInput) {
            colorInput.addEventListener('input', function() {
                textInput.value = this.value;
            });
            textInput.addEventListener('input', function() {
                if (/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/i.test(this.value)) {
                    colorInput.value = this.value;
                }
            });
        }
    });
    
    // 搜索和筛选功能（与色盘弹窗相同）
    const searchInput = document.getElementById('variable-search');
    const categoryFilter = document.getElementById('variable-category-filter');
    
    function filterVariables() {
        const searchTerm = (searchInput?.value || '').toLowerCase();
        const selectedCategory = categoryFilter?.value || '';
        
        modal.querySelectorAll('.variable-item').forEach(function(item) {
            const varName = (item.getAttribute('data-var-name') || '').toLowerCase();
            const category = item.getAttribute('data-category') || '';
            
            const matchesSearch = !searchTerm || varName.includes(searchTerm);
            const matchesCategory = !selectedCategory || category === selectedCategory;
            
            if (matchesSearch && matchesCategory) {
                item.style.display = '';
            } else {
                item.style.display = 'none';
            }
        });
        
        modal.querySelectorAll('.category-group').forEach(function(group) {
            const visibleItems = group.querySelectorAll('.variable-item[style=""], .variable-item:not([style*="display: none"])');
            if (visibleItems.length === 0) {
                group.style.display = 'none';
            } else {
                group.style.display = '';
            }
        });
    }
    
    if (searchInput) {
        searchInput.addEventListener('input', filterVariables);
    }
    if (categoryFilter) {
        categoryFilter.addEventListener('change', filterVariables);
    }
    
    // 重置功能
    modal.querySelectorAll('.reset-to-default').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const varName = this.getAttribute('data-var-name');
            const defaultValue = this.getAttribute('data-default-value');
            const textInput = modal.querySelector(`input[name="variables[${varName}]"]`);
            const colorInput = modal.querySelector(`.variable-color-input[data-var-name="${varName}"]`);
            
            if (textInput) {
                textInput.value = defaultValue;
            }
            if (colorInput) {
                colorInput.value = defaultValue;
            }
        });
    });
    
    const resetAllBtn = document.getElementById('reset-all-variables-btn');
    if (resetAllBtn) {
        resetAllBtn.addEventListener('click', function() {
            modal.querySelectorAll('.variable-item').forEach(function(item) {
                const defaultInput = item.querySelector('[data-default-value]');
                if (defaultInput) {
                    const defaultValue = defaultInput.getAttribute('data-default-value');
                    const textInput = item.querySelector('input[name*="variables"]');
                    const colorInput = item.querySelector('.variable-color-input');
                    
                    if (textInput) {
                        textInput.value = defaultValue;
                    }
                    if (colorInput) {
                        colorInput.value = defaultValue;
                    }
                }
            });
        });
    }
    
    // 保存配置
    function saveVariables(showPreview) {
        const form = document.getElementById('variable-file-form');
        if (!form) return;
        
        const formData = new FormData(form);
        if (showPreview) {
            formData.append('preview', '1');
        }
        
        const saveBtn = document.getElementById('save-variables-btn');
        const originalText = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __('保存中...') ?>';
        
        fetch(saveUrl, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.code === 200) {
                if (typeof showSaveToast === 'function') {
                    showSaveToast(data.msg || '<?= __('配置保存成功') ?>', 'success');
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: data.msg || '<?= __('配置保存成功') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        console.log(data.msg || '<?= __('配置保存成功') ?>');
                    }
                }
                
                if (showPreview && data.data && data.data.preview_url) {
                    if (typeof refreshPreview === 'function') {
                        refreshPreview();
                    }
                }
                
                const bsModal = bootstrap.Modal.getInstance(modal);
                if (bsModal) {
                    bsModal.hide();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.msg || '<?= __('保存失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error(data.msg || '<?= __('保存失败') ?>');
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('保存失败') ?>: ' + error.message);
            }
        })
        .finally(() => {
            saveBtn.disabled = false;
            saveBtn.innerHTML = originalText;
        });
    }
    
    const saveBtn = document.getElementById('save-variables-btn');
    if (saveBtn) {
        saveBtn.addEventListener('click', function() {
            saveVariables(false);
        });
    }
    
    const saveAndPreviewBtn = document.getElementById('save-and-preview-btn');
    if (saveAndPreviewBtn) {
        saveAndPreviewBtn.addEventListener('click', function() {
            saveVariables(true);
        });
    }
})();
</script>

