                        <?php elseif ($var['type'] === 'spacing'): ?>
                        <!-- 间距变量：数字+单位 -->
                        <?php
                        $spacingValue = $var['value'] ?: $var['default'];
                        // 处理var()引用
                        if (strpos($spacingValue, 'var(') === 0) {
                            $spacingNum = '';
                            $spacingUnit = 'rem';
                        } else {
                            $spacingMatch = preg_match('/^(\d+(?:\.\d+)?)(rem|px|em|%)?$/', trim($spacingValue), $matches);
                            $spacingNum = $spacingMatch ? $matches[1] : '';
                            $spacingUnit = $spacingMatch && isset($matches[2]) ? $matches[2] : 'rem';
                        }
                        ?>
                        <input type="number" 
                               step="0.01"
                               id="var-<?= htmlspecialchars($var['cssName']) ?>-num"
                               value="<?= htmlspecialchars($spacingNum) ?>"
                               onchange="updateSpacingValue('<?= htmlspecialchars($var['cssName']) ?>')"
                               placeholder="1">
                        <select id="var-<?= htmlspecialchars($var['cssName']) ?>-unit"
                                onchange="updateSpacingValue('<?= htmlspecialchars($var['cssName']) ?>')">
                            <option value="rem" <?= $spacingUnit === 'rem' ? 'selected' : '' ?>>rem</option>
                            <option value="px" <?= $spacingUnit === 'px' ? 'selected' : '' ?>>px</option>
                            <option value="em" <?= $spacingUnit === 'em' ? 'selected' : '' ?>>em</option>
                            <option value="%" <?= $spacingUnit === '%' ? 'selected' : '' ?>>%</option>
                        </select>
                        <input type="hidden" 
                               id="var-<?= htmlspecialchars($var['cssName']) ?>"
                               data-meta-identify="<?= htmlspecialchars($var['meta_identify']) ?>"
