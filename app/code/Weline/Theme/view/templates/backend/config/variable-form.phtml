<body>
    @template(Weline_Admin::common/body.phtml)
    
    <div class="variable-form-container">
        <div class="variable-form-header">
            <h1><lang>配置变量</lang> - <?= htmlspecialchars($fileName) ?></h1>
            <div>
                <span><lang>主题：</lang><?= htmlspecialchars($theme->getName() ?? '') ?></span>
                <span style="margin-left: 20px;"><lang>区域：</lang><?= htmlspecialchars($area) ?></span>
                <span style="margin-left: 20px;"><lang>作用域：</lang><?= htmlspecialchars($scope) ?></span>
