                <div class="category-group-title"><?= htmlspecialchars($category) ?></div>
                
                <?php foreach ($vars as $var): ?>
                <div class="variable-item" data-var-name="<?= htmlspecialchars(strtolower($var['cssName'])) ?>" data-category="<?= htmlspecialchars($category) ?>">
                    <label for="var-<?= htmlspecialchars($var['cssName']) ?>">
                        <code><?= htmlspecialchars($var['cssName']) ?></code>
                    </label>
                    
                    <div class="variable-input-group">
                        <?php if ($var['is_color']): ?>
                        <!-- 颜色变量：使用颜色选择器 -->
                        <input type="color" 
                               id="var-<?= htmlspecialchars($var['cssName']) ?>"
                               data-meta-identify="<?= htmlspecialchars($var['meta_identify']) ?>"
                               value="<?= htmlspecialchars($var['value'] ?: $var['default']) ?>"
                               onchange="updateColorValue(this)"
                               title="<?= htmlspecialchars($var['description'] ?? '') ?>">
                        <input type="text" 
                               class="color-text-input"
