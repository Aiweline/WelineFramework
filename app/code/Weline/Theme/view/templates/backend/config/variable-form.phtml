    <!-- SweetAlert2 CSS -->
    <link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
    <!-- SweetAlert2 JS -->
    <script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
    <script>
        // 保存所有变量
        function saveAllVariables() {
            const form = document.getElementById('variable-form');
            const formData = new FormData(form);
            
            // 收集所有变量值
            const variables = {};
            document.querySelectorAll('[data-meta-identify]').forEach(input => {
                const metaIdentify = input.getAttribute('data-meta-identify');
                let value = input.value;
                
                // 如果是间距变量的隐藏输入，需要从数字和单位输入组合
                if (input.type === 'hidden' && input.id.includes('var-') && !input.id.includes('-num') && !input.id.includes('-unit')) {
                    const cssName = input.id.replace('var-', '');
                    const numInput = document.getElementById('var-' + cssName + '-num');
                    const unitSelect = document.getElementById('var-' + cssName + '-unit');
                    if (numInput && unitSelect && numInput.value !== '') {
                        value = numInput.value + unitSelect.value;
                    }
                }
                
                if (metaIdentify && value !== null && value !== '') {
                    variables[metaIdentify] = value;
                }
            });
            
            formData.append('variables', JSON.stringify(variables));
            
            fetch('<?= $saveUrl ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: '<?= __('保存成功') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        console.log('保存成功！');
                    }
                    if (data.preview_url) {
                        refreshPreview(data.preview_url);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: data.msg || '<?= __('未知错误') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('保存失败：' + (data.msg || '未知错误'));
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: '<?= __('网络错误') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('保存失败：网络错误');
                }
            });
        }
        
        // 保存单个变量（实时保存）
        function saveVariable(metaIdentify, value) {
            const formData = new FormData();
            formData.append('theme_id', '<?= $theme->getId() ?>');
            formData.append('area', '<?= htmlspecialchars($area) ?>');
            formData.append('scope', '<?= htmlspecialchars($scope) ?>');
            formData.append('meta_identify', metaIdentify);
            formData.append('value', value);
            
            fetch('<?= $saveVariableUrl ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 200 && data.preview_url) {
                    // 实时更新预览
                    refreshPreview(data.preview_url);
                }
            })
            .catch(error => {
                console.error('Error saving variable:', error);
            });
        }
        
        // 更新颜色值
        function updateColorValue(colorInput) {
            const textInput = document.querySelector('[data-color-input="' + colorInput.id + '"]');
            if (textInput) {
                textInput.value = colorInput.value;
            }
            const metaIdentify = colorInput.getAttribute('data-meta-identify');
            if (metaIdentify) {
                saveVariable(metaIdentify, colorInput.value);
            }
        }
        
        // 从文本更新颜色
        function updateColorFromText(textInput) {
            const colorInputId = textInput.getAttribute('data-color-input');
            const colorInput = document.getElementById(colorInputId);
            if (colorInput && /^#[0-9a-fA-F]{6}$/.test(textInput.value)) {
                colorInput.value = textInput.value;
                const metaIdentify = colorInput.getAttribute('data-meta-identify');
                if (metaIdentify) {
                    saveVariable(metaIdentify, textInput.value);
                }
            }
        }
        
        // 更新间距值
        function updateSpacingValue(cssName) {
            const numInput = document.getElementById('var-' + cssName + '-num');
            const unitSelect = document.getElementById('var-' + cssName + '-unit');
            const hiddenInput = document.getElementById('var-' + cssName);
            
            if (numInput && unitSelect && hiddenInput) {
                const numValue = numInput.value;
                const unitValue = unitSelect.value;
                if (numValue !== '') {
                    const value = numValue + unitValue;
                    hiddenInput.value = value;
                    const metaIdentify = hiddenInput.getAttribute('data-meta-identify');
                    if (metaIdentify) {
                        saveVariable(metaIdentify, value);
                    }
                }
            }
        }
        
        // 更新变量值（文本输入）
        function updateVariableValue(input) {
            const metaIdentify = input.getAttribute('data-meta-identify');
            if (metaIdentify) {
                saveVariable(metaIdentify, input.value);
            }
        }
        
        // 保存并预览
        function saveAndPreview() {
            const form = document.getElementById('variable-form');
            const formData = new FormData(form);
            
            // 收集所有变量值
            const variables = {};
            document.querySelectorAll('[data-meta-identify]').forEach(input => {
                const metaIdentify = input.getAttribute('data-meta-identify');
                let value = input.value;
                
                // 如果是间距变量的隐藏输入，需要从数字和单位输入组合
                if (input.type === 'hidden' && input.id.includes('var-') && !input.id.includes('-num') && !input.id.includes('-unit')) {
                    const cssName = input.id.replace('var-', '');
                    const numInput = document.getElementById('var-' + cssName + '-num');
                    const unitSelect = document.getElementById('var-' + cssName + '-unit');
                    if (numInput && unitSelect && numInput.value !== '') {
                        value = numInput.value + unitSelect.value;
                    }
                }
                
                if (metaIdentify && value !== null && value !== '') {
                    variables[metaIdentify] = value;
                }
            });
            
            formData.append('variables', JSON.stringify(variables));
            
            fetch('<?= $saveUrl ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    if (data.preview_url) {
                        refreshPreview(data.preview_url);
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: '<?= __('保存成功，预览已更新') ?>',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            console.log('保存成功！预览已更新。');
                        }
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('成功') ?>',
                                text: '<?= __('保存成功') ?>',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            console.log('保存成功！');
                        }
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: data.msg || '<?= __('未知错误') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('保存失败：' + (data.msg || '未知错误'));
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: '<?= __('网络错误') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('保存失败：网络错误');
                }
            });
        }
        
        // 刷新预览
        function refreshPreview(previewUrl) {
            const iframe = document.getElementById('preview-iframe');
            if (iframe && previewUrl) {
                iframe.classList.remove('hidden');
                iframe.src = previewUrl;
            }
        }
        
        // 重置为默认值
        function resetToDefaults() {
            document.querySelectorAll('[data-meta-identify]').forEach(input => {
                const defaultValue = input.closest('.variable-item').querySelector('.default-value').textContent.replace('默认：', '').trim();
                if (input.type === 'color') {
                    input.value = defaultValue;
                    const textInput = document.querySelector('[data-color-input="' + input.id + '"]');
                    if (textInput) {
                        textInput.value = defaultValue;
                    }
                } else if (input.type === 'hidden' && input.id.includes('var-') && !input.id.includes('-num') && !input.id.includes('-unit')) {
                    // 间距变量（检查是否有对应的num和unit输入）
                    const cssName = input.id.replace('var-', '');
                    const numInput = document.getElementById('var-' + cssName + '-num');
                    const unitSelect = document.getElementById('var-' + cssName + '-unit');
                    if (numInput && unitSelect) {
                        const match = defaultValue.match(/^(\d+(?:\.\d+)?)(rem|px|em|%)?$/);
                        if (match) {
                            numInput.value = match[1];
                            unitSelect.value = match[2] || 'rem';
                            input.value = defaultValue;
                        }
                    } else {
                        input.value = defaultValue;
                    }
                } else {
                    input.value = defaultValue;
                }
            });
            
            saveAllVariables();
        }
        
        // 筛选变量
        function filterVariables() {
            const searchText = document.getElementById('search-input').value.toLowerCase();
            const categoryFilter = document.getElementById('category-filter').value;
            
            document.querySelectorAll('.variable-item').forEach(item => {
                const varName = item.getAttribute('data-var-name') || '';
                const category = item.getAttribute('data-category') || '';
                
                const matchesSearch = !searchText || varName.includes(searchText);
                const matchesCategory = !categoryFilter || category === categoryFilter;
                
                if (matchesSearch && matchesCategory) {
                    item.style.display = 'grid';
                } else {
                    item.style.display = 'none';
                }
            });
            
            // 隐藏空的分类组
            document.querySelectorAll('.category-group').forEach(group => {
                const visibleItems = group.querySelectorAll('.variable-item[style*="grid"], .variable-item:not([style*="none"])');
                if (visibleItems.length === 0) {
                    group.style.display = 'none';
                } else {
                    group.style.display = 'block';
                }
            });
        }
    </script>
</body>
</html>

