<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 处理表单提交
document.getElementById('layout-config-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const themeId = document.getElementById('theme-id').value;
    
    // 收集前端配置
    const frontendLayouts = {};
    const frontendLayoutSelects = document.querySelectorAll('#frontend-config-card select[data-layout-type]');
    frontendLayoutSelects.forEach(select => {
        const layoutType = select.getAttribute('data-layout-type');
        frontendLayouts[layoutType] = select.value;
    });
    
    // 收集后端配置
    const backendLayouts = {};
    const backendLayoutSelects = document.querySelectorAll('#backend-config-card select[data-layout-type]');
    backendLayoutSelects.forEach(select => {
        const layoutType = select.getAttribute('data-layout-type');
        backendLayouts[layoutType] = select.value;
    });
    
    // 保存前端配置
    const frontendData = new FormData();
    frontendData.append('theme_id', themeId);
    frontendData.append('area', 'frontend');
    Object.keys(frontendLayouts).forEach(key => {
        frontendData.append(`layouts[${key}]`, frontendLayouts[key]);
    });
    
    // 保存后端配置
    const backendData = new FormData();
    backendData.append('theme_id', themeId);
    backendData.append('area', 'backend');
    Object.keys(backendLayouts).forEach(key => {
        backendData.append(`layouts[${key}]`, backendLayouts[key]);
    });
    
    // 先保存前端配置
    fetch('<?= $this->getUrl('theme/backend/config/layout/save') ?>', {
        method: 'POST',
        body: frontendData
    }).then(response => response.json()).then(data => {
        if (data.status === 'success') {
            // 再保存后端配置
            return fetch('<?= $this->getUrl('theme/backend/config/layout/save') ?>', {
                method: 'POST',
                body: backendData
            });
        } else {
            throw new Error(data.message || '<?= __('保存失败') ?>');
        }
    }).then(response => response.json()).then(data => {
        if (data.status === 'success') {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('配置保存成功') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log('<?= __('配置保存成功') ?>');
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message || '<?= __('保存失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('保存失败') ?>');
            }
        }
    }).catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('保存失败') ?>: ' + error.message);
        }
    });
});
</script>

