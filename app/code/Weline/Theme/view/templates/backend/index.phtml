    async function createAiVirtualThemeDraft() {
        const modal = aiVirtualThemeModalElement;
        const select = document.getElementById('aiVirtualThemeBaseTheme');
        const instructions = document.getElementById('aiVirtualThemeInstructions');
        const resultEl = document.getElementById('aiVirtualThemeResult');
        const themeId = select ? Number(select.value || 0) : 0;

        if (!themeId) {
            setAiVirtualThemeStatus('warning', '<?= __('请选择参照主题') ?>');
            return;
        }

        setAiVirtualThemeBusy(true);
        setAiVirtualThemeStatus('info', '<?= __('正在按参照主题全部布局类型创建虚拟主题草稿...') ?>');
        if (resultEl) {
            resultEl.style.display = 'none';
            resultEl.innerHTML = '';
        }

        try {
            const payload = {
                theme_id: themeId,
                area: 'frontend',
                page_type: 'all',
                layout_type: 'all',
                layout_option: 'all',
                all_layout_types: true,
                request_id: 'theme-manage-ai-create-' + themeId + '-' + Date.now(),
                instructions: instructions ? instructions.value : '',
                selected_skill_codes: readCheckedValues(modal, 'input[name="ai_virtual_theme_skill"]'),
                selected_style_codes: readCheckedValues(modal, 'input[name="ai_virtual_theme_style"]'),
                use_ai: true
            };
            const data = await runAiVirtualThemeTask(payload, function(progress) {
                const current = Number(progress.current || 0);
                const total = Number(progress.total || 0);
                setAiVirtualThemeStatus('info', total > 0
                    ? '<?= __('正在创建虚拟主题草稿') ?> (' + current + '/' + total + ')'
                    : '<?= __('正在创建虚拟主题草稿...') ?>');
            });
            const layoutOption = data.layout_option || 'default';
            const layoutTypes = Array.isArray(data.layout_types) ? data.layout_types : [];
            const previewLayoutType = layoutTypes.indexOf('homepage') !== -1
                ? 'homepage'
                : (layoutTypes[0] || 'homepage');
            const createdCount = Number(data.created_count || (Array.isArray(data.results) ? data.results.length : 0));
            const editorUrl = buildThemeEditorUrl(themeId, previewLayoutType, layoutOption);
            setAiVirtualThemeStatus('success', '<?= __('虚拟主题草稿已创建') ?>');
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML =
                    '<div class="alert alert-success mb-0">' +
                    '<div class="d-flex flex-wrap align-items-center justify-content-between gap-2">' +
                    '<span><i class="mdi mdi-check-circle me-1"></i>' + escapeHtml('<?= __('已创建虚拟主题草稿') ?>') +
                    ' <code>' + escapeHtml(layoutOption) + '</code>' +
                    (createdCount > 0 ? ' <small class="text-muted ms-1"><?= __('已覆盖布局类型') ?> ' + createdCount + '</small>' : '') +
                    '</span>' +
                    '<a class="btn btn-sm btn-primary" href="' + escapeHtml(editorUrl) + '">' +
                    '<i class="mdi mdi-palette-swatch"></i> <?= __('打开可视化编辑') ?></a>' +
                    '</div>' +
                    '</div>';
            }
            showToast('success', '<?= __('虚拟主题草稿已创建') ?>');
        } catch (error) {
            const message = error.message || '<?= __('虚拟主题创建失败') ?>';
            setAiVirtualThemeStatus('danger', message);
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(message) + '</div>';
            }
        } finally {
            setAiVirtualThemeBusy(false);
        }
    }

    function findThemeCard(themeId, area) {
        return Array.from(document.querySelectorAll('.theme-card')).find(function(card) {
            return card.dataset.themeId === String(themeId) && card.dataset.area === area;
        }) || null;
    }

    function appendPreviewCacheBuster(url) {
        if (!url) {
            return '';
        }

        return url + (url.indexOf('?') === -1 ? '?' : '&') + 't=' + Date.now();
    }

    function updatePreviewActionButton(card, hasPreview) {
        if (!card) {
            return;
        }

        const button = card.querySelector('.preview-action-btn');
        const icon = button ? button.querySelector('i') : null;
        card.dataset.hasPreview = hasPreview ? '1' : '0';
        card.dataset.needsPreview = hasPreview ? '0' : '1';

        if (!button) {
            return;
        }

        button.dataset.force = hasPreview ? '1' : '0';
        button.title = hasPreview ? '<?= __('刷新预览图') ?>' : '<?= __('生成预览图') ?>';
        button.classList.remove('btn-primary', 'btn-outline-light', 'preview-action-btn--generate', 'preview-action-btn--refresh');
        button.classList.add(hasPreview ? 'btn-outline-light' : 'btn-primary');
        button.classList.add(hasPreview ? 'preview-action-btn--refresh' : 'preview-action-btn--generate');

        if (icon) {
            icon.className = 'mdi ' + (hasPreview ? 'mdi-refresh' : 'mdi-camera');
        }
    }

    function setThemeCardStatus(card, type, message) {
        if (!card) {
            return;
        }

        const badge = card.querySelector('.theme-preview-status-badge');
        if (!badge) {
            return;
        }

        if (!message) {
            badge.textContent = '';
            badge.className = 'theme-preview-status-badge d-none';
            return;
        }

        badge.textContent = message;
        badge.className = 'theme-preview-status-badge preview-status--' + type;
    }

    function setThemeCardGenerating(card, generating) {
        if (!card) {
            return;
        }

        card.classList.toggle('is-generating', generating);
        const button = card.querySelector('.preview-action-btn');
        if (button) {
            button.disabled = generating;
        }
    }

    function showThemePreviewPlaceholder(image, placeholder) {
        if (!image) {
            return;
        }

        const targetSelector = image.getAttribute('data-fallback-target') || '.theme-preview-placeholder';
        const target = placeholder || (image.parentNode ? image.parentNode.querySelector(targetSelector) : null);
        image.classList.add('d-none');
        if (target) {
            target.classList.remove('d-none');
        }
    }

    function bindThemePreviewImageFallback(image, placeholder) {
        if (!image || image.dataset.fallbackBound === '1') {
            return;
        }

        image.dataset.fallbackBound = '1';
        image.addEventListener('error', function() {
            showThemePreviewPlaceholder(image, placeholder);
        });
    }

    document.querySelectorAll('.theme-preview-image[data-fallback-target]').forEach(function(image) {
        bindThemePreviewImageFallback(image);
    });

    function updateThemeCardPreview(card, imageUrl) {
        if (!card || !imageUrl) {
            return;
        }

        const preview = card.querySelector('.theme-preview');
        let image = card.querySelector('.theme-preview-image');
        const placeholder = card.querySelector('.theme-preview-placeholder');

        if (!image && preview) {
            image = document.createElement('img');
            image.alt = '<?= __('主题预览') ?>';
            image.className = 'theme-preview-image';
            image.setAttribute('data-fallback-target', '.theme-preview-placeholder');
            bindThemePreviewImageFallback(image, placeholder);
            preview.insertBefore(image, preview.firstChild);
        } else {
            bindThemePreviewImageFallback(image, placeholder);
        }

        if (image) {
            image.src = appendPreviewCacheBuster(imageUrl);
            image.classList.remove('d-none');
        }

        if (placeholder) {
            placeholder.classList.add('d-none');
        }

        updatePreviewActionButton(card, true);
    }

    function previewTargetKey(themeId, area) {
        return 'theme_' + Number(themeId) + '_' + area;
    }

    function setSinglePreviewModalState(type, message) {
        const spinner = document.getElementById('singleSpinner');
        const status = document.getElementById('singleStatus');
        if (spinner) {
            spinner.style.display = type === 'working' ? 'block' : 'none';
        }
        if (!status) {
            return;
        }
        if (type === 'success') {
            status.innerHTML = '<span class="text-success"><i class="mdi mdi-check-circle"></i> ' + escapeHtml(message) + '</span>';
        } else if (type === 'error') {
            status.innerHTML = '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> ' + escapeHtml(message) + '</span>';
        } else {
            status.textContent = message;
        }
    }

    function applySinglePreviewResult(descriptor, result) {
        const card = findThemeCard(descriptor.theme_id, descriptor.area);
        const success = !!(result && result.success);
        const message = success
            ? (descriptor.success_message || '<?= __('预览图已更新') ?>')
            : String(result?.error || descriptor.error_message || '<?= __('生成失败') ?>');
        if (card && success) {
            updateThemeCardPreview(card, result.image_url || '');
            setThemeCardStatus(card, 'success', message);
            window.setTimeout(function() {
                setThemeCardStatus(card, '', '');
            }, 1800);
        } else if (card) {
            setThemeCardStatus(card, 'error', message);
        }
        if (descriptor.show_modal) {
            setSinglePreviewModalState(success ? 'success' : 'error', message);
            if (success && singleGenerateModal) {
                window.setTimeout(function() {
                    singleGenerateModal.hide();
                }, 800);
            }
        }
        return success;
    }

    async function attachSinglePreviewTask(api, task, descriptor) {
        if (activePreviewStreams.has(task.task_id)) {
            return null;
        }
        const targetKey = previewTargetKey(descriptor.theme_id, descriptor.area);
        const card = findThemeCard(descriptor.theme_id, descriptor.area);
        const stream = createThemePreviewStream(api, task);
        activePreviewStreams.set(task.task_id, stream);
        activePreviewTargets.add(targetKey);
        activeSingleTaskId = task.task_id;
        setPreviewCancelButton('cancelSinglePreviewTask', true);
        if (card) {
            setThemeCardGenerating(card, true);
            setThemeCardStatus(card, 'info', descriptor.status_message || '<?= __('正在生成') ?>');
        }

        let finished = false;
        let resolveCompletion;
        const completion = new Promise(function(resolve) {
            resolveCompletion = resolve;
        });
        const finish = function(outcome) {
            if (finished) {
                return;
            }
            finished = true;
            activePreviewStreams.delete(task.task_id);
            activePreviewTargets.delete(targetKey);
            clearPreviewTask(task.task_id);
            if (activeSingleTaskId === task.task_id) {
                activeSingleTaskId = null;
                setPreviewCancelButton('cancelSinglePreviewTask', false);
            }
            if (card) {
                setThemeCardGenerating(card, false);
            }
            resolveCompletion(outcome);
        };
        const resultForTarget = function(payload) {
            const results = payload?.result?.results;
            return Array.isArray(results)
                ? results.find(function(item) { return item && item.key === targetKey; })
                : null;
        };

        stream.addEventListener('progress', function(event) {
            const payload = streamPayload(event);
            if (Number(payload.theme_id) === Number(descriptor.theme_id) && payload.area === descriptor.area
                && payload.success === false && card) {
                setThemeCardStatus(card, 'error', String(payload.error || payload.message || descriptor.error_message || '<?= __('生成失败') ?>'));
            }
        });
        stream.addEventListener('runtime_snapshot', function(event) {
            const state = streamPayload(event)?.checkpoint?.state || {};
            const result = state.results ? state.results[targetKey] : null;
            if (result) {
                applySinglePreviewResult(descriptor, result);
            }
        });
        stream.addEventListener('completed', function(event) {
            const result = resultForTarget(streamPayload(event));
            const success = applySinglePreviewResult(descriptor, result || {
                success: false,
                error: '<?= __('未找到预览图任务结果') ?>',
            });
            finish({ success: success });
        });
        const terminalFailure = function(event, fallback) {
            const message = taskFailureMessage(streamPayload(event), fallback);
            applySinglePreviewResult(descriptor, { success: false, error: message });
            finish({ success: false, error: message });
        };
        stream.addEventListener('failed', function(event) {
            terminalFailure(event, '<?= __('预览图生成失败') ?>');
        });
        stream.addEventListener('cancelled', function(event) {
            terminalFailure(event, '<?= __('预览图生成已取消') ?>');
        });
        stream.addEventListener('expired', function(event) {
            terminalFailure(event, '<?= __('客户端失联超时，预览图任务已停止') ?>');
        });
        stream.addEventListener('recovery_unsafe', function(event) {
            terminalFailure(event, '<?= __('预览图任务无法安全恢复') ?>');
        });
        stream.addEventListener('event_backlog_limit', function(event) {
            terminalFailure(event, '<?= __('预览图任务事件达到资源上限') ?>');
        });
        stream.addEventListener('terminal', function() {
            finish({ success: false });
        });
        stream.addEventListener('error', function() {
            if (descriptor.show_modal) {
                setSinglePreviewModalState('working', '<?= __('连接暂时中断，正在重连…') ?>');
            }
        });

        await stream.start();
        return completion;
    }

    async function generateSinglePreview(themeId, area, options = {}) {
        const config = Object.assign({
            force: true,
            showModal: false,
            card: null,
            title: '',
            statusMessage: '',
            successMessage: '',
            errorMessage: '',
        }, options);
        const normalizedThemeId = Number(themeId);
        const targetKey = previewTargetKey(normalizedThemeId, area);
        if (!normalizedThemeId || activePreviewTargets.has(targetKey)) {
            return null;
        }

        const card = config.card || findThemeCard(normalizedThemeId, area);
        if (config.showModal && singleGenerateModal) {
            document.getElementById('singleGenerateTitle').innerText = config.title || '<?= __('生成预览图') ?>';
            setSinglePreviewModalState('working', config.statusMessage || '<?= __('正在生成预览图，请稍候...') ?>');
            singleGenerateModal.show();
        }
        if (card) {
            setThemeCardGenerating(card, true);
            setThemeCardStatus(card, 'info', config.statusMessage || '<?= __('正在生成') ?>');
        }
        try {
            const started = await startThemePreviewTask({
                request_id: createPreviewRequestId('theme-preview'),
                scope: 'single',
                theme_id: normalizedThemeId,
                area: area,
                force: config.force,
            });
            const descriptor = {
                kind: 'single',
                theme_id: normalizedThemeId,
                area: area,
                show_modal: !!config.showModal,
                status_message: config.statusMessage || '',
                success_message: config.successMessage || '',
                error_message: config.errorMessage || '',
            };
            persistPreviewTask(started.task, descriptor);
            return await attachSinglePreviewTask(started.api, started.task, descriptor);
        } catch (error) {
            const message = (config.errorMessage || '<?= __('无法启动预览图任务') ?>') + ': ' + (error?.message || '');
            if (card) {
                setThemeCardGenerating(card, false);
                setThemeCardStatus(card, 'error', message);
            }
            if (config.showModal) {
                setSinglePreviewModalState('error', message);
            }
            return null;
        }
    }

    async function autoGenerateMissingPreviews() {
        const cards = Array.from(document.querySelectorAll('.theme-card[data-needs-preview="1"]'));
        if (cards.length === 0 || activeBatchTaskId) {
            return;
        }

        cards.forEach(function(card) {
            setThemeCardGenerating(card, true);
            setThemeCardStatus(
                card,
                'info',
                '<?= __('自动生成中') ?>' + ' ' + ((card.dataset.area || 'frontend') === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>')
            );
        });

        try {
            // One silent batch with force=false: existing preview files are skipped,
            // missing ones are created, and empty DB paths are filled from disk.
            const started = await startThemePreviewTask({
                request_id: createPreviewRequestId('theme-preview-auto'),
                scope: 'all',
                force: false,
            });
            const descriptor = {
                kind: 'batch',
                silent: true,
                auto_missing: true,
            };
            persistPreviewTask(started.task, descriptor);
            await attachBatchPreviewTask(started.api, started.task, descriptor);
        } catch (error) {
            const message = '<?= __('自动生成失败') ?>: ' + (error?.message || '');
            cards.forEach(function(card) {
                setThemeCardGenerating(card, false);
                setThemeCardStatus(card, 'error', message);
            });
        }
    }

    function batchPreviewElements() {
        return {
            status: document.getElementById('batchStatus'),
            count: document.getElementById('batchCount'),
            result: document.getElementById('batchResult'),
            bar: document.querySelector('#batchProgress .progress-bar'),
        };
    }

    function setBatchPreviewProgress(payload) {
        const elements = batchPreviewElements();
        const current = Number(payload.current || 0);
        const total = Number(payload.total || 0);
        const progress = Number(payload.progress || (total > 0 ? (current / total) * 100 : 0));
        if (elements.bar) {
            elements.bar.style.width = Math.max(0, Math.min(100, progress)) + '%';
        }
        if (elements.status) {
            elements.status.textContent = String(payload.message || '<?= __('正在批量生成预览图，请稍候...') ?>');
        }
        if (elements.count) {
            elements.count.textContent = current + ' / ' + total;
        }
    }

    function renderBatchPreviewSummary(result) {
        const elements = batchPreviewElements();
        const success = Number(result?.success || 0);
        const failed = Number(result?.failed || 0);
        const items = Array.isArray(result?.results) ? result.results : [];
        items.forEach(function(item) {
            const card = findThemeCard(item?.theme_id, item?.area);
            if (!card) {
                return;
            }
            if (item.success) {
                updateThemeCardPreview(card, item.image_url || '');
                setThemeCardStatus(card, 'success', '<?= __('预览图已更新') ?>');
            } else {
                setThemeCardStatus(card, 'error', String(item.error || '<?= __('生成失败') ?>'));
            }
            setThemeCardGenerating(card, false);
        });
        if (elements.bar) {
            elements.bar.style.width = '100%';
        }
        if (elements.status) {
            elements.status.textContent = failed > 0
                ? '<?= __('批量生成已完成，但存在失败项') ?>'
                : '<?= __('批量生成完成') ?>';
        }
        if (elements.count) {
            elements.count.textContent = '<?= __('成功') ?> ' + success + ' / <?= __('失败') ?> ' + failed;
        }
        if (failed > 0 && elements.result) {
            const messages = items.filter(function(item) {
                return item && !item.success;
            }).map(function(item) {
                return '<li>' + escapeHtml(String(item.error || (item.theme_id + ' ' + item.area))) + '</li>';
            }).join('');
            elements.result.style.display = 'block';
            elements.result.innerHTML = '<div class="alert alert-warning mb-0"><ul class="mb-0">' + messages + '</ul></div>';
        }
    }

    async function attachBatchPreviewTask(api, task, descriptor) {
        if (activePreviewStreams.has(task.task_id)) {
            return null;
        }
        const stream = createThemePreviewStream(api, task);
        activePreviewStreams.set(task.task_id, stream);
        activeBatchTaskId = task.task_id;
        setPreviewCancelButton('cancelBatchPreviewTask', true);
        let finished = false;
        let resolveCompletion;
        const completion = new Promise(function(resolve) {
            resolveCompletion = resolve;
        });
        const finish = function(outcome) {
            if (finished) {
                return;
            }
            finished = true;
            activePreviewStreams.delete(task.task_id);
            clearPreviewTask(task.task_id);
            if (activeBatchTaskId === task.task_id) {
                activeBatchTaskId = null;
                setPreviewCancelButton('cancelBatchPreviewTask', false);
            }
            resolveCompletion(outcome);
        };
        const silent = !!descriptor.silent;
        stream.addEventListener('start', function(event) {
            if (!silent) {
                setBatchPreviewProgress(streamPayload(event));
            }
        });
        stream.addEventListener('progress', function(event) {
            const payload = streamPayload(event);
            if (!silent) {
                setBatchPreviewProgress(payload);
            }
            const card = findThemeCard(payload?.theme_id, payload?.area);
            if (!card) {
                return;
            }
            if (payload?.success) {
                updateThemeCardPreview(card, payload.image_url || '');
                setThemeCardStatus(card, 'success', '<?= __('自动生成完成') ?>');
                setThemeCardGenerating(card, false);
            } else if (payload?.error) {
                setThemeCardStatus(card, 'error', String(payload.error));
                setThemeCardGenerating(card, false);
            } else {
                setThemeCardStatus(card, 'info', String(payload?.message || '<?= __('自动生成中') ?>'));
            }
        });
        stream.addEventListener('runtime_snapshot', function(event) {
            const state = streamPayload(event)?.checkpoint?.state || {};
            if (!silent) {
                setBatchPreviewProgress({
                    current: state.next_index || 0,
                    total: Number(state.total || Object.keys(state.results || {}).length),
                    message: '<?= __('已恢复预览图任务订阅') ?>',
                });
            }
        });
        stream.addEventListener('completed', function(event) {
            const result = streamPayload(event)?.result || {};
            if (!silent) {
                renderBatchPreviewSummary(result);
            } else {
                renderBatchPreviewSummary(result);
                document.querySelectorAll('.theme-card.is-generating').forEach(function(card) {
                    setThemeCardGenerating(card, false);
                });
            }
            finish({ success: Number(result.failed || 0) === 0 });
        });
        const terminalFailure = function(event, fallback) {
            const elements = batchPreviewElements();
            const message = taskFailureMessage(streamPayload(event), fallback);
            if (!silent) {
                if (elements.status) {
                    elements.status.textContent = message;
                }
                if (elements.result) {
                    elements.result.style.display = 'block';
                    elements.result.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(message) + '</div>';
                }
            } else {
                document.querySelectorAll('.theme-card[data-needs-preview="1"]').forEach(function(card) {
                    setThemeCardGenerating(card, false);
                    setThemeCardStatus(card, 'error', message);
                });
            }
            finish({ success: false, error: message });
        };
        stream.addEventListener('failed', function(event) {
            terminalFailure(event, '<?= __('批量预览图生成失败') ?>');
        });
        stream.addEventListener('cancelled', function(event) {
            terminalFailure(event, '<?= __('批量预览图生成已取消') ?>');
        });
        stream.addEventListener('expired', function(event) {
            terminalFailure(event, '<?= __('客户端失联超时，批量预览图任务已停止') ?>');
        });
        stream.addEventListener('recovery_unsafe', function(event) {
            terminalFailure(event, '<?= __('批量预览图任务无法安全恢复') ?>');
        });
        stream.addEventListener('event_backlog_limit', function(event) {
            terminalFailure(event, '<?= __('批量预览图任务事件达到资源上限') ?>');
        });
        stream.addEventListener('terminal', function() {
            finish({ success: false });
        });
        await stream.start();
        return completion;
    }

    async function runBatchPreviewGeneration() {
        if (!batchGenerateModal) {
            return;
        }
        const elements = batchPreviewElements();
        batchGenerateModal.show();
        if (elements.bar) {
            elements.bar.style.width = '0%';
        }
        if (elements.status) {
            elements.status.textContent = '<?= __('正在批量生成预览图，请稍候...') ?>';
        }
        if (elements.count) {
            elements.count.textContent = '';
        }
        if (elements.result) {
            elements.result.style.display = 'none';
            elements.result.innerHTML = '';
        }
        try {
            const started = await startThemePreviewTask({
                request_id: createPreviewRequestId('theme-preview-batch'),
                scope: 'all',
                force: true,
            });
            const descriptor = { kind: 'batch' };
            persistPreviewTask(started.task, descriptor);
            return await attachBatchPreviewTask(started.api, started.task, descriptor);
        } catch (error) {
            const message = '<?= __('无法启动批量预览图任务') ?>: ' + (error?.message || '');
            if (elements.status) {
                elements.status.textContent = message;
            }
            if (elements.result) {
                elements.result.style.display = 'block';
                elements.result.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(message) + '</div>';
            }
            return null;
        }
    }

    async function restoreActivePreviewTasks() {
        const entries = storedPreviewTasks();
        if (entries.length === 0) {
            return;
        }
        let api;
        try {
            api = await getRuntimeApi();
        } catch (error) {
            return;
        }
        entries.forEach(function(entry) {
            if (activePreviewStreams.has(entry.task.task_id)) {
                return;
            }
            const restore = entry.descriptor.kind === 'single'
                ? attachSinglePreviewTask(api, entry.task, entry.descriptor)
                : attachBatchPreviewTask(api, entry.task, entry.descriptor);
            restore.catch(function(error) {
                console.warn('Unable to restore Theme preview task stream', error);
            });
        });
    }

    document.getElementById('batchGeneratePreviews')?.addEventListener('click', function() {
        runBatchPreviewGeneration();
    });

    document.getElementById('cancelBatchPreviewTask')?.addEventListener('click', function() {
        if (!activeBatchTaskId) {
            return;
        }
        setPreviewCancelButton('cancelBatchPreviewTask', false);
        cancelThemePreviewTask(activeBatchTaskId, '<?= addslashes(__('用户取消批量预览图任务')) ?>').catch(function(error) {
            setPreviewCancelButton('cancelBatchPreviewTask', true);
            showToast('error', error?.message || '<?= __('取消任务失败') ?>');
        });
    });

    document.getElementById('cancelSinglePreviewTask')?.addEventListener('click', function() {
        if (!activeSingleTaskId) {
            return;
        }
        setPreviewCancelButton('cancelSinglePreviewTask', false);
        cancelThemePreviewTask(activeSingleTaskId, '<?= addslashes(__('用户取消预览图任务')) ?>').catch(function(error) {
            setPreviewCancelButton('cancelSinglePreviewTask', true);
            showToast('error', error?.message || '<?= __('取消任务失败') ?>');
        });
    });

    document.getElementById('openAiVirtualThemeModal')?.addEventListener('click', function() {
        const themeId = this.dataset.themeId || document.getElementById('aiVirtualThemeBaseTheme')?.value || '';
        openAiVirtualThemeDialog(themeId, '');
    });

    document.getElementById('createAiVirtualTheme')?.addEventListener('click', function() {
        createAiVirtualThemeDraft();
    });

    document.querySelectorAll('.activate-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            if (this.disabled) {
                return;
            }

            const themeId = this.dataset.themeId;
            const area = this.dataset.area || 'frontend';
            const areaLabel = area === 'frontend' ? '<?= __('前台') ?>' : '<?= __('后台') ?>';

            getApi().then(function(api) {
                return api.resource('theme').activateTheme({
                    theme_id: Number(themeId),
                    area: area
                }, { silent: true });
            }).then(function(result) {
                if (isSuccessResponse(result)) {
                    showToast('success', '<?= __('主题已设置为 %{1} 主题') ?>'.replace('%{1}', areaLabel));
                    window.location.reload();
                    return;
                }

                showToast('error', result?.message || '<?= __('激活失败') ?>');
            }).catch(function(error) {
                showToast('error', '<?= __('激活失败') ?>: ' + (error.message || ''));
            });
        });
    });

    document.querySelectorAll('.preview-action-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            const themeId = this.dataset.themeId;
            const themeName = this.dataset.themeName;
            const area = this.dataset.area || 'frontend';
            const force = this.dataset.force === '1';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';
            const actionText = force ? '<?= __('刷新') ?>' : '<?= __('生成') ?>';

            generateSinglePreview(themeId, area, {
                force: force,
                showModal: true,
                card: findThemeCard(themeId, area),
                title: actionText + ' "' + themeName + '" ' + areaLabel + ' <?= __('预览图') ?>',
                statusMessage: actionText + '<?= __('中...') ?>',
                successMessage: force ? '<?= __('预览图已刷新') ?>' : '<?= __('预览图生成成功') ?>',
                errorMessage: force ? '<?= __('刷新失败') ?>' : '<?= __('生成失败') ?>',
            });
        });
    });

    restoreActivePreviewTasks().finally(function() {
        window.setTimeout(autoGenerateMissingPreviews, 300);
    });
})();
</script>

