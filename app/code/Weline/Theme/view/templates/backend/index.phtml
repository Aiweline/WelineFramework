        // 初始化iframe加载状态管理
        function initIframeLoading(iframeId) {
            const iframe = document.getElementById(iframeId);
            if (!iframe) return;
            
            const loadingDiv = iframe.parentElement.querySelector('.iframe-loading');
            if (!loadingDiv) return;
            
            let isLoaded = false;
            let slowLoadTimeout = null;
            let finalTimeout = null;
            
            // 3秒后显示慢速加载提示
            slowLoadTimeout = setTimeout(() => {
                if (!isLoaded && loadingDiv.style.display !== 'none') {
                    const originalContent = loadingDiv.innerHTML;
                    loadingDiv.innerHTML = originalContent + '<div class="alert alert-info mt-3" style="max-width: 400px; text-align: left; font-size: 0.875rem;"><i class="mdi mdi-information-outline me-2"></i><?= __('加载时间较长，可能是主题包含海外跨境请求的资源，请开启VPN或调整主题资源，以加快主题访问。') ?></div>';
                }
            }, 3000);
            
            // 30秒后如果还没加载完成，显示最终错误
            finalTimeout = setTimeout(() => {
                if (!isLoaded && loadingDiv.style.display !== 'none') {
                    loadingDiv.style.display = 'flex';
                    loadingDiv.innerHTML = '<div class="alert alert-warning"><?= __('加载时间过长，请检查网络连接或预览URL') ?></div>';
                }
            }, 30000);
            
            // 监听iframe加载完成
            iframe.addEventListener('load', function() {
                isLoaded = true;
                clearTimeout(slowLoadTimeout);
                clearTimeout(finalTimeout);
                
                // 尝试隐藏iframe内部的滚动条（但保留滚动功能）
                try {
                    const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
                    if (iframeDoc) {
                        // 添加样式到iframe的head（隐藏滚动条但保留滚动功能）
                        const style = iframeDoc.createElement('style');
                        style.textContent = 'body, html { scrollbar-width: none !important; -ms-overflow-style: none !important; overflow-y: auto !important; overflow-x: auto !important; } body::-webkit-scrollbar, html::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; } body::-webkit-scrollbar-track, html::-webkit-scrollbar-track { display: none !important; }';
                        iframeDoc.head.appendChild(style);
                    }
                } catch (e) {
                    // 跨域限制，无法访问iframe内容，忽略错误
                    console.debug('无法访问iframe内容（可能是跨域限制）:', e);
                }
                
                // 延迟隐藏加载状态，确保内容已渲染
                setTimeout(() => {
                    loadingDiv.style.opacity = '0';
                    setTimeout(() => {
                        loadingDiv.style.display = 'none';
                        loadingDiv.style.opacity = '1';
                    }, 300);
                }, 500);
            }, { once: true });
            
            // 监听iframe加载错误
            iframe.addEventListener('error', function() {
                isLoaded = true;
                clearTimeout(slowLoadTimeout);
                clearTimeout(finalTimeout);
                loadingDiv.style.display = 'flex';
                loadingDiv.innerHTML = '<div class="alert alert-danger"><?= __('加载失败，请检查预览URL是否正确') ?></div>';
            }, { once: true });
        }
        
        // 为所有iframe初始化加载状态
        setTimeout(() => {
            if (data.preview_url_frontend) {
                initIframeLoading('themePreviewIframeFrontend');
            }
            if (data.preview_url_backend) {
