<script type="text/plain" id="theme-manage-legacy-script">
(function() {
    'use strict';

    // 配置
    const BASE_URL = '<?= $this->getBaseUrl() ?>';
    const CSRF_TOKEN = '<?= $this->getFormKeyValue() ?>';
    const GENERATE_PREVIEW_URL = '<?= $url->getBackendUrl('theme/backend/index/postGeneratePreviewImage') ?>';
    const singleGenerateModalElement = document.getElementById('singleGenerateModal');
    const singleGenerateModal = singleGenerateModalElement ? new bootstrap.Modal(singleGenerateModalElement) : null;

    // 全局变量
    let batchTotal = 0;
    let batchProcessed = 0;

    // 批量生成按钮点击事件
    document.getElementById('batchGeneratePreviews')?.addEventListener('click', function() {
        const modal = new bootstrap.Modal(document.getElementById('batchGenerateModal'));
        modal.show();
        
        // 准备批量生成
        batchTotal = <?= count($themes) ?>;
        batchProcessed = 0;
        
        document.getElementById('batchStatus').innerText = '正在准备生成 ' + batchTotal + ' 个主题的预览图...';
        document.getElementById('batchCount').innerText = '0 / ' + batchTotal;
        document.getElementById('batchResult').style.display = 'none';
        
        startBatchPreviewsSse(modal);
    });

    function startBatchPreviewsSse(modal) {
        const streamUrl = '<?= $url->getBackendUrl('theme/backend/index/postGenerateAllPreviewsSse') ?>';
        const term = window.WelineSseTerminal && window.WelineSseTerminal['theme-batch-preview-terminal'];
        if (!term) {
            console.error('SSE Terminal not found');
            return;
        }

        // 清理旧输出
        if (typeof term.clear === 'function') term.clear();

        // 辅助函数：解析 SSE 事件数据
        function parseSseData(e) {
            if (!e) return null;
            // 如果是字符串，直接解析
            if (typeof e === 'string') {
                try {
                    return JSON.parse(e);
                } catch (err) {
                    return e;
                }
            }
            // SSE Event 对象有 data 属性（字符串）
            if (typeof e.data === 'string') {
                try {
                    return JSON.parse(e.data);
                } catch (err) {
                    return e.data;
                }
            }
            // 如果 data 已经是对象，直接返回
            if (typeof e.data === 'object' && e.data !== null) {
                return e.data;
            }
            // 尝试直接解析整个 e
            if (typeof e === 'object') {
                return e;
            }
            return null;
        }

        // 监听 start 事件获取总任务数
        term.on('start', function(e) {
            console.log('SSE start event:', e);
            const data = parseSseData(e);
            console.log('SSE start parsed data:', data);
            if (data) {
                batchTotal = data.total || 0;
                const statusEl = document.getElementById('batchStatus');
                const countEl = document.getElementById('batchCount');
                const msg = data.message || ('开始生成 ' + batchTotal + ' 个预览图');
                if (statusEl) statusEl.innerText = msg + '（并发数：' + (data.concurrency || 4) + '）';
                if (countEl) countEl.innerText = '0 / ' + batchTotal;

                // 在终端内容区域显示开始消息
                if (typeof term.log === 'function') {
                    term.log(msg);
                }
            }
        });

        // 监听 progress 事件更新进度
        term.on('progress', function(e) {
            console.log('SSE progress event:', e);
            const data = parseSseData(e);
            console.log('SSE progress parsed data:', data);
            if (data) {
                batchProcessed = data.current || 0;
                batchTotal = data.total || batchTotal;

                // 更新进度条
                const progressBar = document.querySelector('#batchProgress .progress-bar');
                if (progressBar) {
                    progressBar.style.width = (data.progress || 0) + '%';
                }

                // 更新计数
                const countEl = document.getElementById('batchCount');
                if (countEl) countEl.innerText = batchProcessed + ' / ' + batchTotal;

                // 更新状态消息
                const statusEl = document.getElementById('batchStatus');
                if (statusEl && data.message) {
                    statusEl.innerText = data.message;
                }

                // 在终端内容区域显示详细消息
                if (data.message && typeof term.log === 'function') {
                    term.log(data.message);
                }
            }
        });

        // 事件结束后关闭弹窗并刷新页面
        term.on('done', function(e) {
            const data = parseSseData(e) || {};
            const detail = data.data && typeof data.data === 'object' ? data.data : {};
            const failed = Number(detail.failed || 0);
            const success = Number(detail.success || 0);
            const total = Number(detail.total || batchTotal || 0);
            const doneMessage = data.message || (failed > 0 ? '批量生成完成（存在失败）' : '全部预览图生成完成！');

            if (typeof term.log === 'function') {
                term.log(doneMessage);
                if (total > 0) {
                    term.log('结果：成功 ' + success + ' / 失败 ' + failed + ' / 总计 ' + total);
                }
            }

            const statusEl = document.getElementById('batchStatus');
            const countEl = document.getElementById('batchCount');
            if (statusEl) {
                statusEl.innerText = doneMessage;
            }
            if (countEl && total > 0) {
                countEl.innerText = success + ' / ' + total + '（失败 ' + failed + '）';
            }

            if (failed > 0) {
                const resultEl = document.getElementById('batchResult');
                if (resultEl) {
                    resultEl.style.display = 'block';
                    resultEl.innerHTML = '<div class="alert alert-warning mb-0">' +
                        '<i class="mdi mdi-alert-circle-outline me-1"></i>' +
                        '仍有 ' + failed + ' 个预览图生成失败，请查看终端日志中的超时/错误项后重试。' +
                        '</div>';
                }
                return;
            }

            modal.hide();
            location.reload();
        });
        term.on('error', function(e) {
            // 在终端内容区域显示错误消息
            const data = parseSseData(e);
            if (data && data.message && typeof term.log === 'function') {
                term.log('错误: ' + data.message);
            }
            modal.hide();
        });

        const fd = new FormData();
        fd.append('form_key', CSRF_TOKEN);

        fd.append('concurrency', '2');
        term.start(streamUrl, { method: 'POST', body: fd });
    }

    // 批量生成预览图
    async function fetchBatchPreviews() {
        try {
            const response = await fetch('<?= $url->getBackendUrl('theme/backend/index/postGenerateAllPreviews') ?>', {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'form_key': CSRF_TOKEN
                })
            });

            const result = await response.json();
            
            if (result.success === true || result.status === 'success' || result.status === 'warning') {
                document.getElementById('batchStatus').innerHTML = 
                    '<span class="text-success"><i class="mdi mdi-check-circle"></i> 生成完成！</span>';
                document.getElementById('batchCount').innerHTML = 
                    '✓ ' + result.data.success + ' 个成功，' + (result.data.failed || 0) + ' 个失败';
                
                // 显示详细结果
                if (result.data.messages && result.data.messages.length > 0) {
                    let html = '<div class="alert alert-warning"><h6>失败详情：</h6><ul class="mb-0">';
                    result.data.messages.forEach(msg => {
                        html += '<li>' + escapeHtml(msg) + '</li>';
                    });
                    html += '</ul></div>';
                    document.getElementById('batchResult').innerHTML = html;
                    document.getElementById('batchResult').style.display = 'block';
                }
                
                // 3秒后自动刷新页面
                setTimeout(() => {
                    modal.hide();
                    location.reload();
                }, 3000);
            } else {
                document.getElementById('batchStatus').innerHTML = 
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> 生成失败：' + 
                    escapeHtml(result.message) + '</span>';
            }
        } catch (error) {
            console.error('批量生成预览图失败:', error);
            document.getElementById('batchStatus').innerHTML = 
                '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> 网络错误：' + 
                escapeHtml(error.message) + '</span>';
        }
    }

    // 激活主题按钮（按区域）
    document.querySelectorAll('.activate-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            if (this.disabled) return;
            const themeId = this.dataset.themeId;
            const themeName = this.dataset.themeName;
            const area = this.dataset.area || 'frontend';
            const areaLabel = area === 'frontend' ? '<?= __('前台') ?>' : '<?= __('后台') ?>';
            fetch('<?= $url->getBackendUrl('theme/backend/index/postActivate') ?>', {
                method: 'POST',
                credentials: 'include',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ form_key: CSRF_TOKEN, theme_id: themeId, area: area })
            }).then(r => r.json()).then(function(result) {
                const isSuccess = result && (
                    result.status === 'success' ||
                    result.success === true ||
                    result.success === 1 ||
                    result.success === '1' ||
                    result.code === 200 ||
                    result.code === '200'
                );

                if (isSuccess) {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success('<?= __('主题已设为%{1}主题') ?>'.replace('%{1}', areaLabel));
                        location.reload();
                    } else if (typeof BackendConfirm !== 'undefined') {
                        BackendConfirm.show('<?= __('主题激活成功') ?>', { type: 'success' }).then(function () {
                            location.reload();
                        });
                    } else {
                        location.reload();
                    }
                } else {
                    const msg = result.message || '<?= __('激活失败') ?>';
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(msg);
                    } else {
                        if (typeof BackendConfirm !== 'undefined') {
                            BackendConfirm.show(msg, { type: 'danger' });
                        } else {
                            console.error(msg);
                        }
                    }
                }
            }).catch(function(err) {
                const msg = '<?= __('网络错误') ?>: ' + (err.message || '');
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error(msg);
                } else {
                    if (typeof BackendConfirm !== 'undefined') {
                        BackendConfirm.show(msg, { type: 'danger' });
                    } else {
                        console.error(msg);
                    }
                }
            });
        });
    });

    // 单个主题生成按钮点击事件
    document.querySelectorAll('.generate-preview-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const themeId = this.dataset.themeId;
            const themeName = this.dataset.themeName;
            const area = this.dataset.area || 'frontend';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';
            
            // 显示弹窗
            const modal = new bootstrap.Modal(document.getElementById('singleGenerateModal'));
            modal.show();
            
            // 更新标题
            document.getElementById('singleGenerateTitle').innerText = '生成 "' + themeName + '" 的 ' + areaLabel + ' 预览图';
            
            // 显示进度
            document.getElementById('singleStatus').innerHTML = '正在生成预览图，请稍候...';
            document.getElementById('singleSpinner').style.display = 'block';
            
            // 发送生成请求
            generateSinglePreview(themeId, area);
        });
    });

    // 生成单个主题预览图
    async function generateSinglePreview(themeId, area) {
        try {
            const response = await fetch('<?= $url->getBackendUrl('theme/backend/index/postGeneratePreviewImage') ?>', {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'form_key': CSRF_TOKEN,
                    'theme_id': themeId,
                    'area': area,
                    'force': '1'
                })
            });

            const result = await response.json();
            
            document.getElementById('singleSpinner').style.display = 'none';
            
            if (result.status === 'success') {
                document.getElementById('singleStatus').innerHTML = 
                    '<span class="text-success"><i class="mdi mdi-check-circle"></i> 预览图生成成功！</span>';
                
                // 1秒后刷新页面
                setTimeout(() => {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('singleGenerateModal'));
                    modal.hide();
                    location.reload();
                }, 1000);
            } else {
                document.getElementById('singleStatus').innerHTML = 
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> 生成失败：' + 
                    escapeHtml(result.message) + '</span>';
            }
        } catch (error) {
            console.error('生成预览图失败:', error);
            document.getElementById('singleSpinner').style.display = 'none';
            document.getElementById('singleStatus').innerHTML = 
                '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> 网络错误：' + 
                escapeHtml(error.message) + '</span>';
        }
    }

    // HTML转义函数
    function findThemeCard(themeId, area) {
        return Array.from(document.querySelectorAll('.theme-card')).find(function(card) {
            return card.dataset.themeId === String(themeId) && card.dataset.area === area;
        }) || null;
    }

    function appendPreviewCacheBuster(url) {
        if (!url) {
            return '';
        }

        return url + (url.indexOf('?') === -1 ? '?' : '&') + 't=' + Date.now();
    }

    function updatePreviewActionButton(card, hasPreview) {
        if (!card) {
            return;
        }

        const button = card.querySelector('.preview-action-btn');
        const icon = button ? button.querySelector('i') : null;
        card.dataset.hasPreview = hasPreview ? '1' : '0';
        card.dataset.needsPreview = hasPreview ? '0' : '1';

        if (!button) {
            return;
        }

        button.dataset.force = hasPreview ? '1' : '0';
        button.title = hasPreview ? '<?= __('刷新预览图') ?>' : '<?= __('生成预览图') ?>';
        button.classList.remove('btn-primary', 'btn-outline-light', 'preview-action-btn--generate', 'preview-action-btn--refresh');
        button.classList.add(hasPreview ? 'btn-outline-light' : 'btn-primary');
        button.classList.add(hasPreview ? 'preview-action-btn--refresh' : 'preview-action-btn--generate');

        if (icon) {
            icon.className = 'mdi ' + (hasPreview ? 'mdi-refresh' : 'mdi-camera');
        }
    }

    function setThemeCardStatus(card, type, message) {
        if (!card) {
            return;
        }

        const badge = card.querySelector('.theme-preview-status-badge');
        if (!badge) {
            return;
        }

        if (!message) {
            badge.textContent = '';
            badge.className = 'theme-preview-status-badge d-none';
            return;
        }

        badge.textContent = message;
        badge.className = 'theme-preview-status-badge preview-status--' + type;
    }

    function setThemeCardGenerating(card, generating) {
        if (!card) {
            return;
        }

        card.classList.toggle('is-generating', generating);
        const button = card.querySelector('.preview-action-btn');
        if (button) {
            button.disabled = generating;
        }
    }

    function updateThemeCardPreview(card, imageUrl) {
        if (!card || !imageUrl) {
            return;
        }

        const preview = card.querySelector('.theme-preview');
        let image = card.querySelector('.theme-preview-image');
        const placeholder = card.querySelector('.theme-preview-placeholder');

        if (!image && preview) {
            image = document.createElement('img');
            image.alt = '<?= __('主题预览') ?>';
            image.className = 'theme-preview-image';
            image.onerror = function() {
                this.classList.add('d-none');
                if (placeholder) {
                    placeholder.classList.remove('d-none');
                }
            };
            preview.insertBefore(image, preview.firstChild);
        }

        if (image) {
            image.src = appendPreviewCacheBuster(imageUrl);
            image.classList.remove('d-none');
        }

        if (placeholder) {
            placeholder.classList.add('d-none');
        }

        updatePreviewActionButton(card, true);
    }

    async function generateSinglePreview(themeId, area, options = {}) {
        const config = Object.assign({
            force: true,
            showModal: false,
            card: null,
            themeName: '',
            statusMessage: '',
            successMessage: '',
            errorMessage: '',
        }, options);

        const card = config.card || findThemeCard(themeId, area);

        if (config.showModal && singleGenerateModal) {
            singleGenerateModal.show();
            document.getElementById('singleGenerateTitle').innerText = config.themeName || '';
            document.getElementById('singleStatus').innerHTML = config.statusMessage || '<?= __('正在生成预览图，请稍候...') ?>';
            document.getElementById('singleSpinner').style.display = 'block';
        }

        if (card) {
            setThemeCardGenerating(card, true);
            setThemeCardStatus(card, 'info', config.statusMessage || '<?= __('正在生成') ?>');
        }

        try {
            const response = await fetch(GENERATE_PREVIEW_URL, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'form_key': CSRF_TOKEN,
                    'theme_id': themeId,
                    'area': area,
                    'force': config.force ? '1' : '0'
                })
            });

            const result = await response.json();

            if (result.status === 'success') {
                const imageUrl = result?.data?.image_url || '';
                if (card) {
                    updateThemeCardPreview(card, imageUrl);
                    setThemeCardStatus(card, 'success', config.successMessage || '<?= __('预览图已更新') ?>');
                    window.setTimeout(function() {
                        setThemeCardStatus(card, '', '');
                    }, 1800);
                }

                if (config.showModal) {
                    document.getElementById('singleSpinner').style.display = 'none';
                    document.getElementById('singleStatus').innerHTML =
                        '<span class="text-success"><i class="mdi mdi-check-circle"></i> ' +
                        escapeHtml(config.successMessage || '<?= __('预览图生成成功') ?>') +
                        '</span>';
                    window.setTimeout(function() {
                        singleGenerateModal.hide();
                    }, 800);
                }

                return result;
            }

            const errorMessage = (result && result.message) ? result.message : (config.errorMessage || '<?= __('生成失败') ?>');
            if (card) {
                setThemeCardStatus(card, 'error', errorMessage);
            }
            if (config.showModal) {
                document.getElementById('singleSpinner').style.display = 'none';
                document.getElementById('singleStatus').innerHTML =
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> ' +
                    escapeHtml(errorMessage) +
                    '</span>';
            }

            return null;
        } catch (error) {
            const message = (config.errorMessage || '<?= __('网络错误') ?>') + ': ' + (error.message || '');
            console.error('Theme preview generation failed', error);
            if (card) {
                setThemeCardStatus(card, 'error', message);
            }
            if (config.showModal) {
                document.getElementById('singleSpinner').style.display = 'none';
                document.getElementById('singleStatus').innerHTML =
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> ' +
                    escapeHtml(message) +
                    '</span>';
            }

            return null;
        } finally {
            if (card) {
                setThemeCardGenerating(card, false);
            }
        }
    }

    async function autoGenerateMissingPreviews() {
        const cards = Array.from(document.querySelectorAll('.theme-card[data-needs-preview="1"]'));
        if (!cards.length) {
            return;
        }

        for (const card of cards) {
            const themeId = card.dataset.themeId;
            const area = card.dataset.area || 'frontend';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';

            await generateSinglePreview(themeId, area, {
                force: false,
                showModal: false,
                card: card,
                statusMessage: '<?= __('自动生成中') ?>' + ' ' + areaLabel,
                successMessage: '<?= __('自动生成完成') ?>',
                errorMessage: '<?= __('自动生成失败') ?>',
            });
        }
    }

    document.querySelectorAll('.preview-action-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const themeId = this.dataset.themeId;
            const themeName = this.dataset.themeName;
            const area = this.dataset.area || 'frontend';
            const force = this.dataset.force === '1';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';
            const actionText = force ? '<?= __('刷新') ?>' : '<?= __('生成') ?>';

            generateSinglePreview(themeId, area, {
                force: force,
                showModal: true,
                card: findThemeCard(themeId, area),
                themeName: actionText + ' "' + themeName + '" ' + areaLabel + ' <?= __('预览图') ?>',
                statusMessage: actionText + '<?= __('中...') ?>',
                successMessage: force ? '<?= __('预览图已刷新') ?>' : '<?= __('预览图生成成功') ?>',
                errorMessage: force ? '<?= __('刷新失败') ?>' : '<?= __('生成失败') ?>',
            });
        });
    });

    window.setTimeout(autoGenerateMissingPreviews, 300);

    function escapeHtml(text) {
        if (!text) return '';
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }
})();
</script>

<script>
(function() {
    'use strict';

    const CSRF_TOKEN = '<?= $this->getFormKeyValue() ?>';
    const ACTIVATE_URL = '<?= $url->getBackendUrl('theme/backend/index/postActivate') ?>';
    const GENERATE_PREVIEW_URL = '<?= $url->getBackendUrl('theme/backend/index/postGeneratePreviewImage') ?>';
    const BATCH_GENERATE_URL = '<?= $url->getBackendUrl('theme/backend/index/postGenerateAllPreviews') ?>';
    const AI_CATALOG_URL = '<?= $url->getBackendUrl('theme/backend/virtual-theme/ai-catalog') ?>';
    const AI_CREATE_DRAFT_URL = '<?= $url->getBackendUrl('theme/backend/virtual-theme/create-draft') ?>';
    const THEME_EDITOR_URL = '<?= $url->getBackendUrl('theme/backend/theme-editor') ?>';
    const batchGenerateModalElement = document.getElementById('batchGenerateModal');
    const singleGenerateModalElement = document.getElementById('singleGenerateModal');
    const aiVirtualThemeModalElement = document.getElementById('aiVirtualThemeModal');

    function createModalAdapter(element) {
        if (!element) {
            return null;
        }

        const adapter = window.bootstrap && window.bootstrap.Modal ? new window.bootstrap.Modal(element) : {
            show: function() {
                element.classList.add('show');
                element.style.display = 'block';
                element.removeAttribute('aria-hidden');
                element.setAttribute('aria-modal', 'true');
                document.body.classList.add('modal-open');
            },
            hide: function() {
                element.classList.remove('show');
                element.style.display = 'none';
                element.setAttribute('aria-hidden', 'true');
                element.removeAttribute('aria-modal');
                document.body.classList.remove('modal-open');
                document.querySelectorAll('.modal-backdrop').forEach(function(backdrop) {
                    backdrop.remove();
                });
            }
        };

        element.querySelectorAll('[data-bs-dismiss="modal"], [data-dismiss="modal"]').forEach(function(button) {
            button.addEventListener('click', function(event) {
                event.preventDefault();
                adapter.hide();
            });
        });

        return adapter;
    }

    const batchGenerateModal = createModalAdapter(batchGenerateModalElement);
    const singleGenerateModal = createModalAdapter(singleGenerateModalElement);
    const aiVirtualThemeModal = createModalAdapter(aiVirtualThemeModalElement);
    let aiVirtualThemeCatalogPromise = null;

    function escapeHtml(text) {
        if (!text) {
            return '';
        }

        return String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function showToast(type, message) {
        if (typeof BackendToast !== 'undefined' && typeof BackendToast[type] === 'function') {
            BackendToast[type](message);
            return;
        }

        if (typeof BackendConfirm !== 'undefined') {
            const confirmType = type === 'success' ? 'success' : 'danger';
            BackendConfirm.show(message, { type: confirmType });
            return;
        }

        console.log(message);
    }

    function isSuccessResponse(result) {
        return !!result && (
            result.status === 'success' ||
            result.success === true ||
            result.success === 1 ||
            result.success === '1' ||
            result.code === 200 ||
            result.code === '200'
        );
    }

    function normalizeAiCatalogItems(items) {
        if (items && typeof items === 'object' && !Array.isArray(items) && Array.isArray(items.items)) {
            items = items.items;
        }

        if (!Array.isArray(items)) {
            return [];
        }

        return items.map(function(item) {
            if (!item || typeof item !== 'object') {
                return null;
            }

            return {
                code: String(item.code || item.value || ''),
                name: String(item.name || item.label || item.code || item.value || ''),
                description: String(item.description || item.summary || item.name || item.label || ''),
                locked: !!item.locked,
                manual: !!item.manual,
                readonly: !!item.readonly
            };
        }).filter(function(item) {
            return item && item.code;
        });
    }

    function renderAiVirtualThemeSkills(items) {
        if (!items.length) {
            return '<span class="text-muted small"><?= __('暂无可选技能') ?></span>';
        }

        return items.map(function(item) {
            const checked = item.locked || item.manual ? 'checked' : '';
            const disabled = item.readonly && !item.locked && !item.manual ? 'disabled' : '';
            return '<label class="ai-virtual-theme-choice">' +
                '<input type="checkbox" name="ai_virtual_theme_skill" value="' + escapeHtml(item.code) + '" ' + checked + ' ' + disabled + '>' +
                '<span><strong>' + escapeHtml(item.name || item.code) + '</strong><small>' + escapeHtml(item.description || item.code) + '</small></span>' +
                '</label>';
        }).join('');
    }

    function renderAiVirtualThemeStyles(items) {
        const auto = '<label class="ai-virtual-theme-choice">' +
            '<input type="radio" name="ai_virtual_theme_style" value="" checked>' +
            '<span><strong><?= __('自动匹配') ?></strong><small><?= __('由 Theme AI 根据当前指令选择方向') ?></small></span>' +
            '</label>';

        if (!items.length) {
            return auto;
        }

        return auto + items.map(function(item) {
            return '<label class="ai-virtual-theme-choice">' +
                '<input type="radio" name="ai_virtual_theme_style" value="' + escapeHtml(item.code) + '">' +
                '<span><strong>' + escapeHtml(item.name || item.code) + '</strong><small>' + escapeHtml(item.description || item.code) + '</small></span>' +
                '</label>';
        }).join('');
    }

    function readCheckedValues(root, selector) {
        if (!root) {
            return [];
        }

        return Array.from(root.querySelectorAll(selector))
            .filter(function(input) {
                return input.checked && !input.disabled;
            })
            .map(function(input) {
                return String(input.value || '').trim();
            })
            .filter(Boolean);
    }

    function setAiVirtualThemeStatus(type, message) {
        const status = document.getElementById('aiVirtualThemeStatus');
        if (!status) {
            return;
        }

        const classType = type === 'danger' || type === 'success' || type === 'warning' || type === 'info'
            ? type
            : 'light';
        status.className = 'alert alert-' + classType + ' border mt-3 mb-0';
        status.innerHTML = '<i class="mdi mdi-information-outline me-1"></i>' + escapeHtml(message);
    }

    function setAiVirtualThemeBusy(busy) {
        const button = document.getElementById('createAiVirtualTheme');
        if (!button) {
            return;
        }

        button.disabled = !!busy;
        button.innerHTML = busy
            ? '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span><?= __('正在创建') ?>'
            : '<i class="mdi mdi-auto-fix"></i> <?= __('创建虚拟主题') ?>';
    }

    async function loadAiVirtualThemeCatalog() {
        if (!aiVirtualThemeCatalogPromise) {
            aiVirtualThemeCatalogPromise = fetch(AI_CATALOG_URL, {
                method: 'GET',
                credentials: 'include',
                headers: {
                    'Accept': 'application/json'
                }
            }).then(function(response) {
                return response.json();
            }).then(function(result) {
                if (!isSuccessResponse(result)) {
                    throw new Error(result?.message || '<?= __('AI目录加载失败') ?>');
                }

                const data = result.data || result;
                return {
                    skills: normalizeAiCatalogItems(data.skills || []),
                    styles: normalizeAiCatalogItems(data.styles || data.directions || [])
                };
            });
        }

        return aiVirtualThemeCatalogPromise;
    }

    async function renderAiVirtualThemeCatalog() {
        const skillsEl = document.getElementById('aiVirtualThemeSkills');
        const stylesEl = document.getElementById('aiVirtualThemeStyles');
        if (!skillsEl || !stylesEl) {
            return;
        }

        skillsEl.innerHTML = '<span class="text-muted small"><?= __('正在加载...') ?></span>';
        try {
            const catalog = await loadAiVirtualThemeCatalog();
            skillsEl.innerHTML = renderAiVirtualThemeSkills(catalog.skills);
            stylesEl.innerHTML = renderAiVirtualThemeStyles(catalog.styles);
        } catch (error) {
            skillsEl.innerHTML = '<span class="text-danger small">' + escapeHtml(error.message || '<?= __('AI目录加载失败') ?>') + '</span>';
            stylesEl.innerHTML = renderAiVirtualThemeStyles([]);
        }
    }

    function buildThemeEditorUrl(themeId, layoutType, layoutOption) {
        const url = new URL(THEME_EDITOR_URL, window.location.origin);
        url.searchParams.set('theme_id', String(themeId));
        url.searchParams.set('page_type', layoutType || 'homepage');
        url.searchParams.set('layout_type', layoutType || 'homepage');
        url.searchParams.set('layout_option', layoutOption || 'default');
        return url.toString();
    }

    function openAiVirtualThemeDialog(themeId, themeName) {
        if (!aiVirtualThemeModalElement || !aiVirtualThemeModal) {
            return;
        }

        const select = document.getElementById('aiVirtualThemeBaseTheme');
        const title = document.getElementById('aiVirtualThemeTitle');
        const result = document.getElementById('aiVirtualThemeResult');
        const instructions = document.getElementById('aiVirtualThemeInstructions');

        if (select && themeId) {
            select.value = String(themeId);
        }
        if (title) {
            title.innerText = themeName
                ? '<?= __('AI创建虚拟主题') ?> - ' + themeName
                : '<?= __('AI创建虚拟主题') ?>';
        }
        if (instructions) {
            instructions.value = '';
        }
        if (result) {
            result.style.display = 'none';
            result.innerHTML = '';
        }

        setAiVirtualThemeStatus('light', '<?= __('AI 会完全参照默认主题全部默认布局源码生成虚拟主题草稿，发布前不会影响前台渲染。') ?>');
        renderAiVirtualThemeCatalog();
        aiVirtualThemeModal.show();
        window.setTimeout(function() {
            instructions?.focus();
        }, 180);
    }

    async function createAiVirtualThemeDraft() {
        const modal = aiVirtualThemeModalElement;
        const select = document.getElementById('aiVirtualThemeBaseTheme');
        const instructions = document.getElementById('aiVirtualThemeInstructions');
        const resultEl = document.getElementById('aiVirtualThemeResult');
        const themeId = select ? Number(select.value || 0) : 0;

        if (!themeId) {
            setAiVirtualThemeStatus('warning', '<?= __('请选择参照主题') ?>');
            return;
        }

        setAiVirtualThemeBusy(true);
        setAiVirtualThemeStatus('info', '<?= __('正在按参照主题全部布局类型创建虚拟主题草稿...') ?>');
        if (resultEl) {
            resultEl.style.display = 'none';
            resultEl.innerHTML = '';
        }

        try {
            const payload = {
                form_key: CSRF_TOKEN,
                theme_id: themeId,
                area: 'frontend',
                page_type: 'all',
                layout_type: 'all',
                layout_option: 'all',
                all_layout_types: true,
                request_id: 'theme-manage-ai-create-' + themeId + '-' + Date.now(),
                instructions: instructions ? instructions.value : '',
                selected_skill_codes: readCheckedValues(modal, 'input[name="ai_virtual_theme_skill"]'),
                selected_style_codes: readCheckedValues(modal, 'input[name="ai_virtual_theme_style"]'),
                use_ai: 1
            };

            const response = await fetch(AI_CREATE_DRAFT_URL, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (!isSuccessResponse(result)) {
                throw new Error(result?.message || '<?= __('虚拟主题创建失败') ?>');
            }

            const data = result.data || result;
            const layoutOption = data.layout_option || 'default';
            const layoutTypes = Array.isArray(data.layout_types) ? data.layout_types : [];
            const previewLayoutType = layoutTypes.indexOf('homepage') !== -1
                ? 'homepage'
                : (layoutTypes[0] || 'homepage');
            const createdCount = Number(data.created_count || (Array.isArray(data.results) ? data.results.length : 0));
            const editorUrl = buildThemeEditorUrl(themeId, previewLayoutType, layoutOption);
            setAiVirtualThemeStatus('success', result.message || '<?= __('虚拟主题草稿已创建') ?>');
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML =
                    '<div class="alert alert-success mb-0">' +
                    '<div class="d-flex flex-wrap align-items-center justify-content-between gap-2">' +
                    '<span><i class="mdi mdi-check-circle me-1"></i>' + escapeHtml('<?= __('已创建虚拟主题草稿') ?>') +
                    ' <code>' + escapeHtml(layoutOption) + '</code>' +
                    (createdCount > 0 ? ' <small class="text-muted ms-1"><?= __('已覆盖布局类型') ?> ' + createdCount + '</small>' : '') +
                    '</span>' +
                    '<a class="btn btn-sm btn-primary" href="' + escapeHtml(editorUrl) + '">' +
                    '<i class="mdi mdi-palette-swatch"></i> <?= __('打开可视化编辑') ?></a>' +
                    '</div>' +
                    '</div>';
            }
            showToast('success', '<?= __('虚拟主题草稿已创建') ?>');
        } catch (error) {
            const message = error.message || '<?= __('虚拟主题创建失败') ?>';
            setAiVirtualThemeStatus('danger', message);
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(message) + '</div>';
            }
        } finally {
            setAiVirtualThemeBusy(false);
        }
    }

    function findThemeCard(themeId, area) {
        return Array.from(document.querySelectorAll('.theme-card')).find(function(card) {
            return card.dataset.themeId === String(themeId) && card.dataset.area === area;
        }) || null;
    }

    function appendPreviewCacheBuster(url) {
        if (!url) {
            return '';
        }

        return url + (url.indexOf('?') === -1 ? '?' : '&') + 't=' + Date.now();
    }

    function updatePreviewActionButton(card, hasPreview) {
        if (!card) {
            return;
        }

        const button = card.querySelector('.preview-action-btn');
        const icon = button ? button.querySelector('i') : null;
        card.dataset.hasPreview = hasPreview ? '1' : '0';
        card.dataset.needsPreview = hasPreview ? '0' : '1';

        if (!button) {
            return;
        }

        button.dataset.force = hasPreview ? '1' : '0';
        button.title = hasPreview ? '<?= __('刷新预览图') ?>' : '<?= __('生成预览图') ?>';
        button.classList.remove('btn-primary', 'btn-outline-light', 'preview-action-btn--generate', 'preview-action-btn--refresh');
        button.classList.add(hasPreview ? 'btn-outline-light' : 'btn-primary');
        button.classList.add(hasPreview ? 'preview-action-btn--refresh' : 'preview-action-btn--generate');

        if (icon) {
            icon.className = 'mdi ' + (hasPreview ? 'mdi-refresh' : 'mdi-camera');
        }
    }

    function setThemeCardStatus(card, type, message) {
        if (!card) {
            return;
        }

        const badge = card.querySelector('.theme-preview-status-badge');
        if (!badge) {
            return;
        }

        if (!message) {
            badge.textContent = '';
            badge.className = 'theme-preview-status-badge d-none';
            return;
        }

        badge.textContent = message;
        badge.className = 'theme-preview-status-badge preview-status--' + type;
    }

    function setThemeCardGenerating(card, generating) {
        if (!card) {
            return;
        }

        card.classList.toggle('is-generating', generating);
        const button = card.querySelector('.preview-action-btn');
        if (button) {
            button.disabled = generating;
        }
    }

    function updateThemeCardPreview(card, imageUrl) {
        if (!card || !imageUrl) {
            return;
        }

        const preview = card.querySelector('.theme-preview');
        let image = card.querySelector('.theme-preview-image');
        const placeholder = card.querySelector('.theme-preview-placeholder');

        if (!image && preview) {
            image = document.createElement('img');
            image.alt = '<?= __('主题预览') ?>';
            image.className = 'theme-preview-image';
            image.onerror = function() {
                this.classList.add('d-none');
                if (placeholder) {
                    placeholder.classList.remove('d-none');
                }
            };
            preview.insertBefore(image, preview.firstChild);
        }

        if (image) {
            image.src = appendPreviewCacheBuster(imageUrl);
            image.classList.remove('d-none');
        }

        if (placeholder) {
            placeholder.classList.add('d-none');
        }

        updatePreviewActionButton(card, true);
    }

    async function generateSinglePreview(themeId, area, options = {}) {
        const config = Object.assign({
            force: true,
            showModal: false,
            card: null,
            title: '',
            statusMessage: '',
            successMessage: '',
            errorMessage: '',
        }, options);

        const card = config.card || findThemeCard(themeId, area);

        if (config.showModal && singleGenerateModal) {
            document.getElementById('singleGenerateTitle').innerText = config.title || '<?= __('生成预览图') ?>';
            document.getElementById('singleStatus').innerHTML = escapeHtml(config.statusMessage || '<?= __('正在生成预览图，请稍候...') ?>');
            document.getElementById('singleSpinner').style.display = 'block';
            singleGenerateModal.show();
        }

        if (card) {
            setThemeCardGenerating(card, true);
            setThemeCardStatus(card, 'info', config.statusMessage || '<?= __('正在生成') ?>');
        }

        try {
            const response = await fetch(GENERATE_PREVIEW_URL, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'form_key': CSRF_TOKEN,
                    'theme_id': themeId,
                    'area': area,
                    'force': config.force ? '1' : '0'
                })
            });

            const result = await response.json();
            if (isSuccessResponse(result)) {
                const imageUrl = result?.data?.image_url || result?.image_url || '';
                if (card) {
                    updateThemeCardPreview(card, imageUrl);
                    setThemeCardStatus(card, 'success', config.successMessage || '<?= __('预览图已更新') ?>');
                    window.setTimeout(function() {
                        setThemeCardStatus(card, '', '');
                    }, 1800);
                }

                if (config.showModal && singleGenerateModal) {
                    document.getElementById('singleSpinner').style.display = 'none';
                    document.getElementById('singleStatus').innerHTML =
                        '<span class="text-success"><i class="mdi mdi-check-circle"></i> ' +
                        escapeHtml(config.successMessage || '<?= __('预览图生成成功') ?>') +
                        '</span>';
                    window.setTimeout(function() {
                        singleGenerateModal.hide();
                    }, 800);
                }

                return result;
            }

            const errorMessage = result?.message || config.errorMessage || '<?= __('生成失败') ?>';
            if (card) {
                setThemeCardStatus(card, 'error', errorMessage);
            }
            if (config.showModal) {
                document.getElementById('singleSpinner').style.display = 'none';
                document.getElementById('singleStatus').innerHTML =
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> ' +
                    escapeHtml(errorMessage) +
                    '</span>';
            }
            return null;
        } catch (error) {
            const message = (config.errorMessage || '<?= __('网络错误') ?>') + ': ' + (error.message || '');
            console.error('Theme preview generation failed', error);
            if (card) {
                setThemeCardStatus(card, 'error', message);
            }
            if (config.showModal) {
                document.getElementById('singleSpinner').style.display = 'none';
                document.getElementById('singleStatus').innerHTML =
                    '<span class="text-danger"><i class="mdi mdi-alert-circle"></i> ' +
                    escapeHtml(message) +
                    '</span>';
            }
            return null;
        } finally {
            if (card) {
                setThemeCardGenerating(card, false);
            }
        }
    }

    async function autoGenerateMissingPreviews() {
        const cards = Array.from(document.querySelectorAll('.theme-card[data-needs-preview="1"]'));
        for (const card of cards) {
            const themeId = card.dataset.themeId;
            const area = card.dataset.area || 'frontend';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';

            await generateSinglePreview(themeId, area, {
                force: false,
                showModal: false,
                card: card,
                statusMessage: '<?= __('自动生成中') ?>' + ' ' + areaLabel,
                successMessage: '<?= __('自动生成完成') ?>',
                errorMessage: '<?= __('自动生成失败') ?>',
            });
        }
    }

    async function runBatchPreviewGeneration() {
        if (!batchGenerateModal) {
            return;
        }

        const statusEl = document.getElementById('batchStatus');
        const countEl = document.getElementById('batchCount');
        const resultEl = document.getElementById('batchResult');

        batchGenerateModal.show();
        if (statusEl) {
            statusEl.innerText = '<?= __('正在批量生成预览图，请稍候...') ?>';
        }
        if (countEl) {
            countEl.innerText = '';
        }
        if (resultEl) {
            resultEl.style.display = 'none';
            resultEl.innerHTML = '';
        }

        try {
            const response = await fetch(BATCH_GENERATE_URL, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'form_key': CSRF_TOKEN
                })
            });

            const result = await response.json();
            const successCount = Number(result?.data?.success || 0);
            const failedCount = Number(result?.data?.failed || 0);

            if (result.status === 'success' || result.status === 'warning' || result.success === true) {
                if (statusEl) {
                    statusEl.innerText = failedCount > 0 ? '<?= __('批量生成已完成，但存在失败项') ?>' : '<?= __('批量生成完成') ?>';
                }
                if (countEl) {
                    countEl.innerText = '<?= __('成功') ?> ' + successCount + ' / <?= __('失败') ?> ' + failedCount;
                }

                if (failedCount > 0 && resultEl) {
                    resultEl.style.display = 'block';
                    const messages = Array.isArray(result?.data?.messages) ? result.data.messages : [];
                    const html = messages.map(function(message) {
                        return '<li>' + escapeHtml(message) + '</li>';
                    }).join('');
                    resultEl.innerHTML = '<div class="alert alert-warning mb-0"><ul class="mb-0">' + html + '</ul></div>';
                    return;
                }

                window.setTimeout(function() {
                    window.location.reload();
                }, 1000);
                return;
            }

            const message = result?.message || '<?= __('批量生成失败') ?>';
            if (statusEl) {
                statusEl.innerText = message;
            }
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(message) + '</div>';
            }
        } catch (error) {
            console.error('Batch preview generation failed:', error);
            if (statusEl) {
                statusEl.innerText = '<?= __('网络错误') ?>';
            }
            if (resultEl) {
                resultEl.style.display = 'block';
                resultEl.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(error.message || '') + '</div>';
            }
        }
    }

    document.getElementById('batchGeneratePreviews')?.addEventListener('click', function() {
        runBatchPreviewGeneration();
    });

    document.getElementById('openAiVirtualThemeModal')?.addEventListener('click', function() {
        const themeId = this.dataset.themeId || document.getElementById('aiVirtualThemeBaseTheme')?.value || '';
        openAiVirtualThemeDialog(themeId, '');
    });

    document.getElementById('createAiVirtualTheme')?.addEventListener('click', function() {
        createAiVirtualThemeDraft();
    });

    document.querySelectorAll('.activate-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            if (this.disabled) {
                return;
            }

            const themeId = this.dataset.themeId;
            const area = this.dataset.area || 'frontend';
            const areaLabel = area === 'frontend' ? '<?= __('前台') ?>' : '<?= __('后台') ?>';

            fetch(ACTIVATE_URL, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: new URLSearchParams({
                    form_key: CSRF_TOKEN,
                    theme_id: themeId,
                    area: area
                })
            }).then(function(response) {
                return response.json();
            }).then(function(result) {
                if (isSuccessResponse(result)) {
                    showToast('success', '<?= __('主题已设置为 %{1} 主题') ?>'.replace('%{1}', areaLabel));
                    window.location.reload();
                    return;
                }

                showToast('error', result?.message || '<?= __('激活失败') ?>');
            }).catch(function(error) {
                showToast('error', '<?= __('网络错误') ?>: ' + (error.message || ''));
            });
        });
    });

    document.querySelectorAll('.preview-action-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            const themeId = this.dataset.themeId;
            const themeName = this.dataset.themeName;
            const area = this.dataset.area || 'frontend';
            const force = this.dataset.force === '1';
            const areaLabel = area === 'backend' ? '<?= __('后台') ?>' : '<?= __('前台') ?>';
            const actionText = force ? '<?= __('刷新') ?>' : '<?= __('生成') ?>';

            generateSinglePreview(themeId, area, {
                force: force,
                showModal: true,
                card: findThemeCard(themeId, area),
                title: actionText + ' "' + themeName + '" ' + areaLabel + ' <?= __('预览图') ?>',
                statusMessage: actionText + '<?= __('中...') ?>',
                successMessage: force ? '<?= __('预览图已刷新') ?>' : '<?= __('预览图生成成功') ?>',
                errorMessage: force ? '<?= __('刷新失败') ?>' : '<?= __('生成失败') ?>',
            });
        });
    });

    window.setTimeout(autoGenerateMissingPreviews, 300);
})();
</script>

