    // 初始化主题色系切换功能
    function initThemeColorSwitcher() {
        // 监听tab切换事件，更新主题色系按钮的area属性
        const tabButtons = document.querySelectorAll('#themeActivateModal [data-bs-toggle="tab"]');
        const themeColorButtons = document.querySelectorAll('#themeActivateModal .theme-color-btn');
        
        tabButtons.forEach(tabBtn => {
            tabBtn.addEventListener('shown.bs.tab', function(e) {
                const area = this.getAttribute('data-area');
                // 更新所有主题色系按钮的area属性
                themeColorButtons.forEach(btn => {
                    btn.setAttribute('data-area', area);
                });
                
                // 获取当前激活的主题色系按钮
                const activeThemeBtn = Array.from(themeColorButtons).find(btn => 
                    btn.getAttribute('data-area') === area && btn.classList.contains('active')
                );
                
                // 如果找到了激活的主题色系按钮，更新预览容器的主题色系
                // 如果没有找到，则使用外部主题
                if (activeThemeBtn) {
                    const themeColor = activeThemeBtn.getAttribute('data-theme-color');
                    updatePreviewContainerTheme(themeColor, area);
                } else {
                    // 如果没有激活的按钮，使用外部主题
                    const externalTheme = detectExternalTheme();
                    updatePreviewContainerTheme(externalTheme, area);
                    // 同时更新按钮状态
                    themeColorButtons.forEach(btn => {
                        if (btn.getAttribute('data-area') === area) {
                            btn.classList.remove('active');
                            if (btn.getAttribute('data-theme-color') === externalTheme) {
                                btn.classList.add('active');
                            }
                        }
                    });
                }
            });
        });
        
        // 监听主题色系切换按钮点击事件
        themeColorButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                const themeColor = this.getAttribute('data-theme-color');
                const area = this.getAttribute('data-area');
                
                // 更新按钮状态
                themeColorButtons.forEach(b => {
                    if (b.getAttribute('data-area') === area) {
                        b.classList.remove('active');
                    }
                });
                this.classList.add('active');
                
                // 更新预览容器的主题色系
                updatePreviewContainerTheme(themeColor, area);
                
                // 切换iframe中的主题色系
                switchThemeColorInIframe(themeColor, area);
            });
        });
    }
    
    // 更新预览容器的主题色系
    function updatePreviewContainerTheme(themeColor, area) {
        // 找到当前激活的预览容器
        const tabPane = document.querySelector('#preview-' + area + '.active, #preview-' + area + '.show.active');
        if (!tabPane) return;
        
        const previewContainer = tabPane.querySelector('.preview-container');
        if (!previewContainer) return;
        
        // 更新主题色系属性和背景色
        previewContainer.setAttribute('data-theme-color', themeColor);
        previewContainer.classList.remove('preview-container-light', 'preview-container-dark');
        
        const isDark = themeColor === 'dark';
        if (isDark) {
            previewContainer.classList.add('preview-container-dark');
            previewContainer.style.background = '#1a1a1a'; // 暗色背景
        } else {
            previewContainer.classList.add('preview-container-light');
            previewContainer.style.background = '#f5f5f5'; // 亮色背景
        }
        
        // 更新设备外框颜色（调用设备外框更新函数）
        const deviceFrameWrapper = tabPane.querySelector('.device-frame-wrapper');
        const activeDeviceBtn = tabPane.querySelector('.device-selector .device-btn.active');
        if (deviceFrameWrapper && activeDeviceBtn) {
            const currentDevice = deviceFrameWrapper.getAttribute('data-device') || activeDeviceBtn.getAttribute('data-device');
            const deviceWidth = activeDeviceBtn.getAttribute('data-width');
            // 使用全局的 updateDeviceFrame 函数（如果存在）
            if (typeof window.updateDeviceFrame === 'function') {
                window.updateDeviceFrame(currentDevice, deviceWidth, area, isDark);
            } else {
                // 否则直接更新外框样式
                const deviceScreen = tabPane.querySelector('.device-screen');
                const deviceNotch = tabPane.querySelector('.device-notch');
                
                if (deviceScreen) {
                    if (currentDevice === 'desktop') {
                        // 电脑外框：动态相对模拟1920x1080（16:9比例）
                        const deviceFrame = tabPane.querySelector('.device-frame');
                        if (deviceFrame) {
                            deviceFrame.style.width = '100%';
                            deviceFrame.style.maxWidth = '100%';
                            deviceFrame.style.aspectRatio = '16/9';
                            deviceFrame.style.position = 'relative';
                        }
                        deviceScreen.style.width = '100%';
                        deviceScreen.style.height = '100%';
                        deviceScreen.style.boxSizing = 'border-box';
                        const borderColor = isDark ? '#4a5568' : '#2c3e50';
                        const shadowColor = isDark ? '#1a1a1a' : '#34495e';
                        deviceScreen.style.border = '8px solid ' + borderColor;
                        deviceScreen.style.boxShadow = '0 0 0 2px ' + shadowColor + ', 0 10px 40px rgba(0,0,0,' + (isDark ? '0.5' : '0.3') + ')';
                        // 更新iframe尺寸
                        const iframe = tabPane.querySelector('iframe');
                        if (iframe) {
                            iframe.style.width = '100%';
                            iframe.style.height = '100%';
                        }
                        if (deviceNotch) deviceNotch.style.display = 'none';
                    } else if (currentDevice === 'tablet') {
                        const borderColor = isDark ? '#2d3748' : '#1a1a1a';
                        const shadowColor = isDark ? '#1a1a1a' : '#333';
                        deviceScreen.style.border = '12px solid ' + borderColor;
                        deviceScreen.style.boxShadow = '0 0 0 2px ' + shadowColor + ', 0 8px 30px rgba(0,0,0,' + (isDark ? '0.6' : '0.4') + ')';
                        if (deviceNotch) deviceNotch.style.display = 'none';
                    } else if (currentDevice === 'mobile') {
                        const borderColor = isDark ? '#2d3748' : '#1a1a1a';
                        const shadowColor = isDark ? '#1a1a1a' : '#333';
                        deviceScreen.style.border = '8px solid ' + borderColor;
                        deviceScreen.style.boxShadow = '0 0 0 2px ' + shadowColor + ', 0 6px 25px rgba(0,0,0,' + (isDark ? '0.6' : '0.4') + ')';
                        if (deviceNotch) {
                            deviceNotch.style.display = 'block';
                            deviceNotch.style.background = isDark ? '#2d3748' : '#1a1a1a';
                        }
                    }
                }
            }
        }
    }
    
    // 在iframe中切换主题色系
    function switchThemeColorInIframe(themeColor, area) {
        let iframeId = '';
        if (area === 'frontend') {
            iframeId = 'themePreviewIframeFrontend';
        } else if (area === 'backend') {
            iframeId = 'themePreviewIframeBackend';
        }
        
        if (!iframeId) return;
        
        const iframe = document.getElementById(iframeId);
        if (!iframe || !iframe.contentWindow) return;
        
        try {
            // 尝试使用postMessage方式（推荐）
            iframe.contentWindow.postMessage({
                type: 'switchThemeColor',
                themeColor: themeColor,
                area: area
            }, '*');
            
            // 同时尝试直接调用Weline.Theme.switch（如果iframe已加载）
            setTimeout(() => {
                try {
                    const iframeWindow = iframe.contentWindow;
                    if (iframeWindow && iframeWindow.Weline && iframeWindow.Weline.Theme && typeof iframeWindow.Weline.Theme.switch === 'function') {
                        iframeWindow.Weline.Theme.switch(themeColor);
                    }
                } catch (e) {
                    // 跨域或iframe未加载完成，忽略错误
                    console.debug('直接调用Theme.switch失败，使用postMessage:', e);
                }
            }, 100);
        } catch (e) {
            console.error('切换主题色系失败:', e);
        }
    }
    
    // 监听iframe的postMessage响应（用于双向通信）
    window.addEventListener('message', function(event) {
        // 可以在这里处理iframe发送回来的消息
        if (event.data && event.data.type === 'themeColorSwitched') {
            console.debug('主题色系已切换:', event.data.themeColor);
        }
    });
    
    // 确认激活主题
    document.getElementById('confirmActivateThemeBtn').addEventListener('click', function() {
        if (!currentThemeId) return;
        
        const btn = this;
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __('激活中...') ?>';
        
        // 发送激活请求
        const formData = new FormData();
        formData.append('theme_id', currentThemeId);
        
        fetch('<?= $this->getUrl('theme/backend/index/activate') ?>', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            // 检查响应格式：code === 200 表示成功
            if (data.code === 200) {
                // 关闭Modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('themeActivateModal'));
                modal.hide();
                
                // 更新所有主题的状态
                document.querySelectorAll('[data-theme-id]').forEach(row => {
                    const rowThemeId = row.getAttribute('data-theme-id');
                    const statusBadge = row.querySelector('.theme-status-badge');
                    const activateBtn = row.querySelector('.activate-theme-btn');
                    
                    if (rowThemeId === currentThemeId) {
                        // 当前激活的主题
                        if (statusBadge) {
                        statusBadge.className = 'badge bg-success theme-status-badge';
                        statusBadge.textContent = '<?= __('激活') ?>';
                        }
                        if (activateBtn) {
                        activateBtn.disabled = true;
                        }
                        
                        // 更新主题名称旁的徽章
                        const nameBadge = row.querySelector('td:first-child .badge');
                        if (!nameBadge) {
                            const nameCell = row.querySelector('td:first-child');
                            if (nameCell) {
                            const badge = document.createElement('span');
                            badge.className = 'badge bg-success ms-2';
                            badge.textContent = '<?= __('已激活') ?>';
                            nameCell.appendChild(badge);
                            }
                        }
                    } else {
                        // 其他主题
                        if (statusBadge) {
                        statusBadge.className = 'badge bg-secondary theme-status-badge';
                        statusBadge.textContent = '<?= __('未激活') ?>';
                        }
                        if (activateBtn) {
                        activateBtn.disabled = false;
                        }
                        
                        // 移除主题名称旁的徽章
                        const nameBadge = row.querySelector('td:first-child .badge');
                        if (nameBadge) {
                            nameBadge.remove();
                        }
                    }
                });
                
                // 显示成功消息 Modal
                const successModal = new bootstrap.Modal(document.getElementById('themeActivateSuccessModal'));
                const successMessage = document.getElementById('themeActivateSuccessModalMessage');
                if (successMessage) {
                    successMessage.textContent = data.msg || '<?= __('主题已成功激活，页面将自动刷新以应用新主题。') ?>';
                }
                successModal.show();
            } else {
                // 显示错误消息 Modal
                const errorModal = new bootstrap.Modal(document.getElementById('themeActivateErrorModal'));
                const errorMessage = document.getElementById('themeActivateErrorModalMessage');
                if (errorMessage) {
                    errorMessage.textContent = data.msg || '<?= __('主题激活失败，请重试。') ?>';
                }
                errorModal.show();
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            // 显示错误消息 Modal
            const errorModal = new bootstrap.Modal(document.getElementById('themeActivateErrorModal'));
            const errorMessage = document.getElementById('themeActivateErrorModalMessage');
            if (errorMessage) {
                errorMessage.textContent = '<?= __('激活失败') ?>: ' + error.message;
            }
            errorModal.show();
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
    });
    
