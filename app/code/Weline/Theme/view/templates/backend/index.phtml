        // 初始化预览URL
        const themeId = data.theme.id;
        
        // 构建预览URL
        function buildPreviewUrl(area, header, layouts, color, partials, variables, autoLogin = '1') {
            const baseUrl = layoutPreviewUrl;
            const params = new URLSearchParams();
            params.append('theme_id', themeId);
            params.append('area', area);
            params.append('auto_login', autoLogin || '1'); // 默认开启自动登录
            if (header) {
                params.append('header', header);
            }
            if (layouts && Object.keys(layouts).length > 0) {
                Object.keys(layouts).forEach(layoutType => {
                    params.append('layouts[' + layoutType + ']', layouts[layoutType]);
                });
            }
            if (color) {
                params.append('color', color);
            }
            if (partials && Object.keys(partials).length > 0) {
                Object.keys(partials).forEach(partialType => {
                    params.append('partials[' + partialType + ']', partials[partialType]);
                });
            }
            if (variables && variables.length > 0) {
                variables.forEach(variable => {
                    params.append('variables[]', variable);
                });
            }
            const scopePath = layoutScopes[area] || (area + '/' + DEFAULT_SCOPE);
            if (scopePath) {
                params.append('scope', scopePath);
            }
            return baseUrl + '?' + params.toString();
        }
        
        // 获取当前配置值
        function getCurrentConfig(area) {
            const headerSelect = document.getElementById('header-' + area);
            const header = headerSelect ? headerSelect.value : '';
            const layouts = {};
            
            // 优先从布局选项卡片获取选中的布局值
            const selectedCards = container.querySelectorAll('.layout-option-card[data-area="' + area + '"].border-primary');
            selectedCards.forEach(card => {
                const layoutType = card.getAttribute('data-layout-type');
                const layoutValue = card.getAttribute('data-layout-value');
                if (layoutType && layoutValue) {
                    layouts[layoutType] = layoutValue;
                }
            });
            
            // 如果没有选中的卡片，则从下拉框获取（兼容旧格式）
            if (Object.keys(layouts).length === 0) {
                const layoutSelects = container.querySelectorAll('select[data-area="' + area + '"][data-type="layout"]');
                layoutSelects.forEach(select => {
                    const layoutType = select.getAttribute('data-layout-type');
                    if (layoutType && select.value) {
                        layouts[layoutType] = select.value;
                    }
                });
            }
            
            // 获取色系配置
            const colorCard = container.querySelector('.color-option-card[data-area="' + area + '"].border-primary');
            const color = colorCard ? colorCard.getAttribute('data-color-value') : '';
            
            // 获取部件配置
            const partials = {};
            const selectedPartials = container.querySelectorAll('.partial-option-card[data-area="' + area + '"].border-primary');
            selectedPartials.forEach(card => {
                const partialType = card.getAttribute('data-partial-type');
                const partialValue = card.getAttribute('data-partial-value');
                if (partialType && partialValue) {
                    partials[partialType] = partialValue;
                }
            });
            
            // 获取变量配置（多选）
            const variables = [];
            const selectedVariables = container.querySelectorAll('.variable-option-card[data-area="' + area + '"].border-primary');
            selectedVariables.forEach(card => {
                const variableValue = card.getAttribute('data-variable-value');
                if (variableValue) {
                    variables.push(variableValue);
                }
            });
            
            return { header, layouts, color, partials, variables };
        }
        
        // 更新预览
        function updatePreview(area, overrideLayouts = null) {
            const config = getCurrentConfig(area);
            if (overrideLayouts) {
                config.layouts = overrideLayouts;
            }
            const autoLoginSwitch = container.querySelector('.auto-login-switch-layout[data-area="' + area + '"]');
            const autoLogin = autoLoginSwitch && autoLoginSwitch.checked ? '1' : '0';
            const previewUrl = buildPreviewUrl(area, config.header, config.layouts, config.color, config.partials, config.variables, autoLogin);
            const previewFrames = container.querySelectorAll('.config-preview-iframe[data-area="' + area + '"]');
            
            if (!previewFrames.length) {
                return;
            }
            
            previewFrames.forEach(frame => {
                const loadingId = frame.getAttribute('data-loading-id');
                const loadingDiv = loadingId ? document.getElementById(loadingId) : null;
                
                if (loadingDiv) {
                    loadingDiv.style.display = 'flex';
                    loadingDiv.style.opacity = '1';
                }
                
                frame.src = previewUrl;
                
                const handleLoad = function() {
                    try {
                        const iframeDoc = frame.contentDocument || frame.contentWindow.document;
                        if (iframeDoc) {
                            const style = iframeDoc.createElement('style');
                            style.textContent = 'body, html { scrollbar-width: none !important; -ms-overflow-style: none !important; overflow-y: auto !important; overflow-x: auto !important; } body::-webkit-scrollbar, html::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; } body::-webkit-scrollbar-track, html::-webkit-scrollbar-track { display: none !important; }';
                            iframeDoc.head.appendChild(style);
                        }
                    } catch (e) {
                        console.debug('无法访问iframe内容（可能是跨域限制）:', e);
                    }
                    
                    if (loadingDiv) {
                        setTimeout(() => {
                            loadingDiv.style.opacity = '0';
                            setTimeout(() => {
                                loadingDiv.style.display = 'none';
                                loadingDiv.style.opacity = '1';
                            }, 300);
                        }, 300);
                    }
                    
                    frame.removeEventListener('load', handleLoad);
                };
                
                frame.addEventListener('load', handleLoad);
            });
        }
        
        // 绑定配置选择改变事件
        const configSelects = container.querySelectorAll('.layout-config-select');
        configSelects.forEach(select => {
            select.addEventListener('change', function() {
                const area = this.getAttribute('data-area');
                updatePreview(area);
            });
        });
        
