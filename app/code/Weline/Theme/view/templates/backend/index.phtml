<!-- 激活确认 Modal -->
<div class="modal fade" id="activateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><?= __('激活主题') ?></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><?= __('确定要激活主题') ?> <strong id="activateThemeName"></strong> <?= __('吗？') ?></p>
                <p class="text-muted small"><?= __('激活后，当前主题将被替换为新主题。') ?></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('取消') ?></button>
                <button type="button" class="btn btn-success" id="confirmActivateBtn">
                    <i class="mdi mdi-check-circle"></i> <?= __('确认激活') ?>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const activateModal = new bootstrap.Modal(document.getElementById('activateModal'));
    let currentThemeId = null;

    // 激活按钮点击
    document.querySelectorAll('.activate-btn:not([disabled])').forEach(function(btn) {
        btn.addEventListener('click', function() {
            currentThemeId = this.dataset.themeId;
            document.getElementById('activateThemeName').textContent = this.dataset.themeName;
            activateModal.show();
        });
    });

    // 确认激活
    document.getElementById('confirmActivateBtn').addEventListener('click', function() {
        if (!currentThemeId) return;

        const btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __('激活中...') ?>';

        fetch('<?= $url->getBackendUrl('theme/backend/index/activate') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'theme_id=' + currentThemeId
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success' || data.success) {
                activateModal.hide();
                // 显示成功提示并刷新
                setTimeout(function() {
                    window.location.reload();
                }, 500);
            } else {
                alert(data.message || '<?= __('激活失败') ?>');
                btn.disabled = false;
                btn.innerHTML = '<i class="mdi mdi-check-circle"></i> <?= __('确认激活') ?>';
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __('激活失败，请重试') ?>');
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-check-circle"></i> <?= __('确认激活') ?>';
        });
    });
});
</script>

