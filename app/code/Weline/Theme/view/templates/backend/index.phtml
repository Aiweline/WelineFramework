<script>
(function() {
    'use strict';

    const THEME_EDITOR_URL = '<?= $url->getBackendUrl('theme/backend/theme-editor') ?>';
    const batchGenerateModalElement = document.getElementById('batchGenerateModal');
    const singleGenerateModalElement = document.getElementById('singleGenerateModal');
    const aiVirtualThemeModalElement = document.getElementById('aiVirtualThemeModal');

    function createModalAdapter(element) {
        if (!element) {
            return null;
        }

        const adapter = window.bootstrap && window.bootstrap.Modal ? new window.bootstrap.Modal(element) : {
            show: function() {
                element.classList.add('show');
                element.style.display = 'block';
                element.removeAttribute('aria-hidden');
                element.setAttribute('aria-modal', 'true');
                document.body.classList.add('modal-open');
            },
            hide: function() {
                element.classList.remove('show');
                element.style.display = 'none';
                element.setAttribute('aria-hidden', 'true');
                element.removeAttribute('aria-modal');
                document.body.classList.remove('modal-open');
                document.querySelectorAll('.modal-backdrop').forEach(function(backdrop) {
                    backdrop.remove();
                });
            }
        };

        element.querySelectorAll('[data-bs-dismiss="modal"], [data-dismiss="modal"]').forEach(function(button) {
            button.addEventListener('click', function(event) {
                event.preventDefault();
                adapter.hide();
            });
        });

        return adapter;
    }

    const batchGenerateModal = createModalAdapter(batchGenerateModalElement);
    const singleGenerateModal = createModalAdapter(singleGenerateModalElement);
    const aiVirtualThemeModal = createModalAdapter(aiVirtualThemeModalElement);
    let aiVirtualThemeCatalogPromise = null;
    let apiPromise = null;
    let runtimeApiPromise = null;
    const PREVIEW_TASK_STORAGE_PREFIX = 'weline.theme.preview.task.';
    const activePreviewStreams = new Map();
    const activeVirtualThemeStreams = new Map();
    const activePreviewTargets = new Set();
    let activeBatchTaskId = null;
    let activeSingleTaskId = null;

    function resolveFullApiModule(api) {
        if (window.WelineApiModule
            && window.WelineApiModule.__full === true
            && typeof window.WelineApiModule.resource === 'function') {
            return window.WelineApiModule;
        }
        return api;
    }

    function getApi() {
        if (!apiPromise) {
            apiPromise = (async function() {
                if (!window.Weline || typeof window.Weline.load !== 'function') {
                    throw new Error('<?= addslashes(__('加载失败')) ?>');
                }
                const Weline = window.Weline;
                const api = resolveFullApiModule(await Weline.load('api'));
                if (!api || typeof api.resource !== 'function') {
                    throw new Error('<?= addslashes(__('加载失败')) ?>');
                }
                if (window.Weline) {
                    window.Weline.Api = api;
                }
                return api;
            })();
        }
        return apiPromise;
    }

    function getRuntimeApi() {
        if (!runtimeApiPromise) {
            runtimeApiPromise = getApi().then(function(api) {
                api = resolveFullApiModule(api);
                if (typeof api.createStream !== 'function') {
                    throw new Error('<?= addslashes(__('可恢复任务 API 不可用。')) ?>');
                }
                return api;
            });
        }
        return runtimeApiPromise;
    }

    function createPreviewRequestId(prefix) {
        if (window.crypto && typeof window.crypto.getRandomValues === 'function') {
            const bytes = new Uint8Array(16);
            window.crypto.getRandomValues(bytes);
            return prefix + '-' + Array.from(bytes, function(byte) {
                return byte.toString(16).padStart(2, '0');
            }).join('');
        }
        return prefix + '-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 14);
    }

    function streamPayload(event) {
        if (!event) {
            return {};
        }
        if (event.data && typeof event.data === 'object') {
            return event.data;
        }
        try {
            const value = JSON.parse(String(event.data || '{}'));
            return value && typeof value === 'object' ? value : {};
        } catch (error) {
            return {};
        }
    }

    function normalizeRuntimeTaskHandle(value) {
        if (!value || typeof value !== 'object'
            || typeof value.task_id !== 'string' || !value.task_id
            || typeof value.lease_id !== 'string' || !value.lease_id
            || typeof value.stream_channel !== 'string' || !value.stream_channel) {
            throw new Error('<?= addslashes(__('后台任务启动响应无效。')) ?>');
        }
        return {
            task_id: value.task_id,
            lease_id: value.lease_id,
            stream_channel: value.stream_channel,
        };
    }

    function previewTaskStorageKey(taskId) {
        return PREVIEW_TASK_STORAGE_PREFIX + taskId;
    }

    function persistPreviewTask(task, descriptor) {
        try {
            window.sessionStorage.setItem(previewTaskStorageKey(task.task_id), JSON.stringify({
                task_id: task.task_id,
                lease_id: task.lease_id,
                stream_channel: task.stream_channel,
                descriptor: descriptor,
            }));
        } catch (error) {
            // StreamHandle persists its cursor/lease independently when storage is available.
        }
    }

    function clearPreviewTask(taskId) {
        try {
            window.sessionStorage.removeItem(previewTaskStorageKey(taskId));
        } catch (error) {
            // Storage is optional and never controls task lifetime.
        }
    }

    function storedPreviewTasks() {
        const tasks = [];
        try {
            for (let index = 0; index < window.sessionStorage.length; index++) {
                const key = window.sessionStorage.key(index);
                if (!key || key.indexOf(PREVIEW_TASK_STORAGE_PREFIX) !== 0) {
                    continue;
                }
                const value = JSON.parse(window.sessionStorage.getItem(key) || '{}');
                if (!value || typeof value !== 'object' || !value.descriptor) {
                    continue;
                }
                tasks.push({
                    task: normalizeRuntimeTaskHandle(value),
                    descriptor: value.descriptor,
                });
            }
        } catch (error) {
            return [];
        }
        return tasks;
    }

    function taskFailureMessage(payload, fallback) {
        return String(payload?.reason || payload?.message || payload?.error_code || fallback);
    }

    function setPreviewCancelButton(id, enabled) {
        const button = document.getElementById(id);
        if (button) {
            button.disabled = !enabled;
        }
    }

    async function startThemePreviewTask(input) {
        const api = await getRuntimeApi();
        const taskApi = api.resource('runtime_task');
        const payload = Object.assign({
            capture_base_url: window.location.origin,
        }, input || {});
        const task = normalizeRuntimeTaskHandle(await taskApi.start({
            type_code: 'theme.preview_batch',
            input: payload,
        }, { silent: true }));
        return { api: api, task: task };
    }

    function createThemePreviewStream(api, task) {
        return api.createStream(task.stream_channel, {
            task_id: task.task_id,
            lease_id: task.lease_id,
        }, {
            eventTypes: [
                'start', 'progress', 'runtime_reset', 'runtime_snapshot',
                'completed', 'failed', 'cancelled', 'expired',
                'recovery_unsafe', 'event_backlog_limit',
            ],
            storageKey: 'theme-preview:' + task.task_id,
        });
    }

    async function runAiVirtualThemeTask(payload, onProgress) {
        const api = await getRuntimeApi();
        const task = normalizeRuntimeTaskHandle(await api.resource('runtime_task').start({
            type_code: 'theme.virtual_theme_generation',
            input: payload
        }, { silent: true }));
        const stream = api.createStream(task.stream_channel, {
            task_id: task.task_id,
            lease_id: task.lease_id
        }, {
            eventTypes: [
                'start', 'progress', 'runtime_reset', 'runtime_snapshot',
                'completed', 'failed', 'cancelled', 'expired',
                'recovery_unsafe', 'event_backlog_limit'
            ],
            storageKey: 'theme-virtual-theme:' + task.task_id
        });
        activeVirtualThemeStreams.set(task.task_id, stream);

        return new Promise(function(resolve, reject) {
            let settled = false;
            const finish = function(callback, value) {
                if (settled) {
                    return;
                }
                settled = true;
                activeVirtualThemeStreams.delete(task.task_id);
                stream.close();
                callback(value);
            };
            stream.addEventListener('progress', function(event) {
                onProgress?.(streamPayload(event));
            });
            stream.addEventListener('completed', function(event) {
                const terminal = streamPayload(event);
                finish(resolve, terminal.result || terminal.data || {});
            });
            ['failed', 'cancelled', 'expired', 'recovery_unsafe', 'event_backlog_limit'].forEach(function(type) {
                stream.addEventListener(type, function(event) {
                    const terminal = streamPayload(event);
                    finish(reject, new Error(taskFailureMessage(terminal, '<?= addslashes(__('虚拟主题任务失败')) ?>')));
                });
            });
            stream.start().catch(function(error) {
                finish(reject, error);
            });
        });
    }

    async function cancelThemePreviewTask(taskId, reason) {
        const stream = activePreviewStreams.get(taskId);
        if (!stream) {
            return;
        }
        await stream.cancel(reason || '<?= addslashes(__('用户明确取消')) ?>');
    }

    window.addEventListener('pagehide', function() {
        activePreviewStreams.forEach(function(stream) {
            stream.close(); // detach only; task cancellation is always explicit
        });
        activeVirtualThemeStreams.forEach(function(stream) {
            stream.close(); // detach only; VirtualTheme task lifetime is lease based
        });
    });

    function escapeHtml(text) {
        if (!text) {
            return '';
        }

        return String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function showToast(type, message) {
        if (typeof BackendToast !== 'undefined' && typeof BackendToast[type] === 'function') {
            BackendToast[type](message);
            return;
        }

        if (typeof BackendConfirm !== 'undefined') {
            const confirmType = type === 'success' ? 'success' : 'danger';
            BackendConfirm.show(message, { type: confirmType });
            return;
        }

        console.log(message);
    }

    function isSuccessResponse(result) {
        return !!result && (
            result.status === 'success' ||
            result.success === true ||
            result.success === 1 ||
            result.success === '1' ||
            result.code === 200 ||
            result.code === '200'
        );
    }

    function normalizeAiCatalogItems(items) {
        if (items && typeof items === 'object' && !Array.isArray(items) && Array.isArray(items.items)) {
            items = items.items;
        }

        if (!Array.isArray(items)) {
            return [];
        }

        return items.map(function(item) {
            if (!item || typeof item !== 'object') {
                return null;
            }

            return {
                code: String(item.code || item.value || ''),
                name: String(item.name || item.label || item.code || item.value || ''),
                description: String(item.description || item.summary || item.name || item.label || ''),
                locked: !!item.locked,
                manual: !!item.manual,
                readonly: !!item.readonly
            };
        }).filter(function(item) {
            return item && item.code;
        });
    }

    function renderAiVirtualThemeSkills(items) {
        if (!items.length) {
            return '<span class="text-muted small"><?= __('暂无可选技能') ?></span>';
        }

        return items.map(function(item) {
            const checked = item.locked || item.manual ? 'checked' : '';
            const disabled = item.readonly && !item.locked && !item.manual ? 'disabled' : '';
            return '<label class="ai-virtual-theme-choice">' +
                '<input type="checkbox" name="ai_virtual_theme_skill" value="' + escapeHtml(item.code) + '" ' + checked + ' ' + disabled + '>' +
                '<span><strong>' + escapeHtml(item.name || item.code) + '</strong><small>' + escapeHtml(item.description || item.code) + '</small></span>' +
                '</label>';
        }).join('');
    }

    function renderAiVirtualThemeStyles(items) {
        const auto = '<label class="ai-virtual-theme-choice">' +
            '<input type="radio" name="ai_virtual_theme_style" value="" checked>' +
            '<span><strong><?= __('自动匹配') ?></strong><small><?= __('由 Theme AI 根据当前指令选择方向') ?></small></span>' +
            '</label>';

        if (!items.length) {
            return auto;
        }

        return auto + items.map(function(item) {
            return '<label class="ai-virtual-theme-choice">' +
                '<input type="radio" name="ai_virtual_theme_style" value="' + escapeHtml(item.code) + '">' +
                '<span><strong>' + escapeHtml(item.name || item.code) + '</strong><small>' + escapeHtml(item.description || item.code) + '</small></span>' +
                '</label>';
        }).join('');
    }

    function readCheckedValues(root, selector) {
        if (!root) {
            return [];
        }

        return Array.from(root.querySelectorAll(selector))
            .filter(function(input) {
                return input.checked && !input.disabled;
            })
            .map(function(input) {
                return String(input.value || '').trim();
            })
            .filter(Boolean);
    }

    function setAiVirtualThemeStatus(type, message) {
        const status = document.getElementById('aiVirtualThemeStatus');
        if (!status) {
            return;
        }

        const classType = type === 'danger' || type === 'success' || type === 'warning' || type === 'info'
            ? type
            : 'light';
        status.className = 'alert alert-' + classType + ' border mt-3 mb-0';
        status.innerHTML = '<i class="mdi mdi-information-outline me-1"></i>' + escapeHtml(message);
    }

    function setAiVirtualThemeBusy(busy) {
        const button = document.getElementById('createAiVirtualTheme');
        if (!button) {
            return;
        }

        button.disabled = !!busy;
        button.innerHTML = busy
            ? '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span><?= __('正在创建') ?>'
            : '<i class="mdi mdi-auto-fix"></i> <?= __('创建虚拟主题') ?>';
    }

    async function loadAiVirtualThemeCatalog() {
        if (!aiVirtualThemeCatalogPromise) {
            aiVirtualThemeCatalogPromise = getRuntimeApi().then(function(api) {
                return api.resource('theme').virtual_theme_catalog({}, { silent: true });
            }).then(function(result) {
                if (!isSuccessResponse(result)) {
                    throw new Error(result?.message || '<?= __('AI目录加载失败') ?>');
                }

                const data = result.data || result;
                return {
                    skills: normalizeAiCatalogItems(data.skills || []),
                    styles: normalizeAiCatalogItems(data.styles || data.directions || [])
                };
            });
        }

        return aiVirtualThemeCatalogPromise;
    }

    async function renderAiVirtualThemeCatalog() {
        const skillsEl = document.getElementById('aiVirtualThemeSkills');
        const stylesEl = document.getElementById('aiVirtualThemeStyles');
        if (!skillsEl || !stylesEl) {
            return;
        }

        skillsEl.innerHTML = '<span class="text-muted small"><?= __('正在加载...') ?></span>';
        try {
            const catalog = await loadAiVirtualThemeCatalog();
            skillsEl.innerHTML = renderAiVirtualThemeSkills(catalog.skills);
            stylesEl.innerHTML = renderAiVirtualThemeStyles(catalog.styles);
        } catch (error) {
            skillsEl.innerHTML = '<span class="text-danger small">' + escapeHtml(error.message || '<?= __('AI目录加载失败') ?>') + '</span>';
            stylesEl.innerHTML = renderAiVirtualThemeStyles([]);
        }
    }

    function buildThemeEditorUrl(themeId, layoutType, layoutOption) {
        const url = new URL(THEME_EDITOR_URL, window.location.origin);
        url.searchParams.set('theme_id', String(themeId));
        url.searchParams.set('page_type', layoutType || 'homepage');
        url.searchParams.set('layout_type', layoutType || 'homepage');
        url.searchParams.set('layout_option', layoutOption || 'default');
        return url.toString();
    }

    function openAiVirtualThemeDialog(themeId, themeName) {
        if (!aiVirtualThemeModalElement || !aiVirtualThemeModal) {
            return;
        }

        const select = document.getElementById('aiVirtualThemeBaseTheme');
        const title = document.getElementById('aiVirtualThemeTitle');
