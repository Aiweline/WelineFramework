                    variableCard.classList.add('border-primary');
                    const cardBody = variableCard.querySelector('.card-body');
                    if (cardBody && !cardBody.querySelector('.mdi-check-circle')) {
                        const flexContainer = cardBody.querySelector('.d-flex');
                        if (flexContainer) {
                            const checkDiv = document.createElement('div');
                            checkDiv.className = 'flex-shrink-0';
                            const checkIcon = document.createElement('i');
                            checkIcon.className = 'mdi mdi-check-circle text-primary';
                            checkDiv.appendChild(checkIcon);
                            flexContainer.appendChild(checkDiv);
                        }
                    }
                }
                
                // 更新预览
                updatePreview(area);
                return;
            }
            
        });
        
        // 绑定tab切换事件，切换时更新预览
        const configTabs = container.querySelectorAll('#config-frontend-tab, #config-backend-tab');
        configTabs.forEach(tab => {
            tab.addEventListener('shown.bs.tab', function(e) {
                const targetId = e.target.getAttribute('data-bs-target');
                const area = targetId.includes('frontend') ? 'frontend' : 'backend';
                updatePreview(area);
            });
        });
        
        // 设备外框切换函数（布局配置专用）
        function updateDeviceFrameLayout(device, deviceWidth, area, deviceHeight = null) {
            const tabPane = container.querySelector('#config-' + area);
            if (!tabPane) return;
            
            const deviceFrameWrapper = tabPane.querySelector('.device-frame-wrapper-layout');
            const deviceFrame = tabPane.querySelector('.device-frame-layout');
            const deviceScreen = tabPane.querySelector('.device-screen-layout');
            
            if (!deviceFrameWrapper || !deviceFrame || !deviceScreen) return;
            
            // 更新设备类型
            deviceFrameWrapper.setAttribute('data-device', device);
            deviceFrame.className = 'device-frame-layout device-' + device + '-layout';
            
            // 根据设备类型设置外框样式
            if (device === 'desktop') {
                // 电脑外框：动态相对模拟1920x1080（16:9比例）
                deviceFrameWrapper.style.display = 'flex';
                deviceFrameWrapper.style.justifyContent = 'center';
                deviceFrameWrapper.style.alignItems = 'center';
                deviceFrameWrapper.style.width = '100%';
                deviceFrameWrapper.style.maxWidth = '100%';
                
                deviceFrame.style.width = '100%';
                deviceFrame.style.maxWidth = '100%';
                deviceFrame.style.aspectRatio = '16/9';
                deviceFrame.style.position = 'relative';
                
                deviceScreen.style.width = '100%';
                deviceScreen.style.height = '100%';
                deviceScreen.style.boxSizing = 'border-box';
                deviceScreen.style.border = '8px solid #2c3e50';
                deviceScreen.style.borderRadius = '8px';
                deviceScreen.style.boxShadow = '0 0 0 2px #34495e, 0 10px 40px rgba(0,0,0,0.3)';
                
                // 隐藏手机刘海
                const notch = deviceScreen.querySelector('.device-notch-layout');
                if (notch) notch.style.display = 'none';
            } else if (device === 'tablet') {
                // 平板外框：动态相对模拟768x1024（3:4比例）
                deviceFrameWrapper.style.display = 'flex';
                deviceFrameWrapper.style.justifyContent = 'center';
                deviceFrameWrapper.style.alignItems = 'center';
                deviceFrameWrapper.style.width = '100%';
                deviceFrameWrapper.style.maxWidth = '100%';
                
                // 计算最大宽度，保持768px的比例，但不超过容器
                const previewContainer = deviceFrameWrapper.closest('.preview-container-layout');
                const containerWidth = previewContainer ? previewContainer.clientWidth : 768;
                const maxTabletWidth = Math.min(parseInt(deviceWidth), containerWidth - 40); // 减去padding
                
                deviceFrame.style.width = maxTabletWidth + 'px';
                deviceFrame.style.maxWidth = maxTabletWidth + 'px';
                deviceFrame.style.aspectRatio = '3/4'; // 768:1024 = 3:4
                deviceFrame.style.position = 'relative';
                
                deviceScreen.style.width = '100%';
                deviceScreen.style.height = '100%';
                deviceScreen.style.boxSizing = 'border-box';
                deviceScreen.style.border = '12px solid #1a1a1a';
                deviceScreen.style.borderRadius = '16px';
                deviceScreen.style.boxShadow = '0 0 0 2px #333, 0 8px 30px rgba(0,0,0,0.4)';
                
                // 隐藏手机刘海
                const notch = deviceScreen.querySelector('.device-notch-layout');
                if (notch) notch.style.display = 'none';
            } else if (device === 'mobile') {
                // 手机外框：动态相对模拟375x812（约9:19.5比例）
                deviceFrameWrapper.style.display = 'flex';
                deviceFrameWrapper.style.justifyContent = 'center';
                deviceFrameWrapper.style.alignItems = 'center';
                deviceFrameWrapper.style.width = '100%';
                deviceFrameWrapper.style.maxWidth = '100%';
                
                // 计算最大宽度，保持375px的比例，但不超过容器
                const previewContainer = deviceFrameWrapper.closest('.preview-container-layout');
                const containerWidth = previewContainer ? previewContainer.clientWidth : 375;
                const maxMobileWidth = Math.min(parseInt(deviceWidth), containerWidth - 40); // 减去padding
                
                deviceFrame.style.width = maxMobileWidth + 'px';
                deviceFrame.style.maxWidth = maxMobileWidth + 'px';
                deviceFrame.style.aspectRatio = '375/812'; // 约9:19.5
                deviceFrame.style.position = 'relative';
                
                deviceScreen.style.width = '100%';
                deviceScreen.style.height = '100%';
                deviceScreen.style.boxSizing = 'border-box';
                deviceScreen.style.border = '8px solid #1a1a1a';
                deviceScreen.style.borderRadius = '24px';
                deviceScreen.style.boxShadow = '0 0 0 2px #333, 0 6px 25px rgba(0,0,0,0.4)';
                
                // 添加/显示手机刘海
                let notch = deviceScreen.querySelector('.device-notch-layout');
                if (!notch) {
                    notch = document.createElement('div');
                    notch.className = 'device-notch-layout';
                    deviceScreen.insertBefore(notch, deviceScreen.firstChild);
                }
                notch.style.display = 'block';
                notch.style.position = 'absolute';
                notch.style.top = '0';
                notch.style.left = '50%';
                notch.style.transform = 'translateX(-50%)';
                notch.style.width = '150px';
                notch.style.height = '25px';
                notch.style.background = '#1a1a1a';
                notch.style.borderRadius = '0 0 15px 15px';
                notch.style.zIndex = '1';
            }
        }
        
        // 绑定设备选择按钮事件
        const deviceSelectorsLayout = container.querySelectorAll('.device-selector-layout');
        deviceSelectorsLayout.forEach(selector => {
            const deviceButtons = selector.querySelectorAll('.device-btn-layout');
            const area = selector.getAttribute('data-area');
            
            // 初始化默认设备外框
            const defaultDeviceBtn = Array.from(deviceButtons).find(btn => btn.classList.contains('active'));
            if (defaultDeviceBtn) {
                const deviceWidth = defaultDeviceBtn.getAttribute('data-width');
                const deviceHeight = defaultDeviceBtn.getAttribute('data-height');
                const device = defaultDeviceBtn.getAttribute('data-device');
                setTimeout(() => {
                    updateDeviceFrameLayout(device, deviceWidth, area, deviceHeight);
                }, 150);
            }
            
            deviceButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    // 更新按钮状态
                    deviceButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    
                    // 获取设备信息
                    const deviceWidth = this.getAttribute('data-width');
                    const deviceHeight = this.getAttribute('data-height');
                    const device = this.getAttribute('data-device');
                    
                    // 更新设备外框
                    updateDeviceFrameLayout(device, deviceWidth, area, deviceHeight);
                });
            });
        });
        
        // 监听窗口大小改变，重新计算设备外框大小
        let resizeTimeout;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(function() {
                deviceSelectorsLayout.forEach(selector => {
                    const deviceButtons = selector.querySelectorAll('.device-btn-layout');
                    const area = selector.getAttribute('data-area');
                    const activeBtn = Array.from(deviceButtons).find(btn => btn.classList.contains('active'));
                    if (activeBtn) {
                        const deviceWidth = activeBtn.getAttribute('data-width');
                        const deviceHeight = activeBtn.getAttribute('data-height');
                        const device = activeBtn.getAttribute('data-device');
                        updateDeviceFrameLayout(device, deviceWidth, area, deviceHeight);
                    }
                });
            }, 250);
        });
        
        // 初始化主题色系切换功能（布局配置专用）
        function initThemeColorSwitcherLayout() {
            const themeColorButtons = container.querySelectorAll('.theme-color-btn-layout');
            
            themeColorButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const area = this.getAttribute('data-area');
                    const themeColor = this.getAttribute('data-theme-color');
                    
                    // 更新按钮状态
                    container.querySelectorAll('.theme-color-btn-layout[data-area="' + area + '"]').forEach(b => {
                        b.classList.remove('active');
                    });
                    this.classList.add('active');
                    
                    // 更新预览容器主题色系
                    updatePreviewContainerThemeLayout(themeColor, area);
                });
            });
        }
        
        // 更新预览容器主题色系（布局配置专用）
        function updatePreviewContainerThemeLayout(themeColor, area) {
            const tabPane = container.querySelector('#config-' + area);
            if (!tabPane) return;
            
            const previewContainer = tabPane.querySelector('.preview-container-layout');
            const deviceScreen = tabPane.querySelector('.device-screen-layout');
            
            if (previewContainer) {
                previewContainer.setAttribute('data-theme-color', themeColor);
                const bgColor = themeColor === 'dark' ? '#1a1a1a' : '#f5f5f5';
                previewContainer.style.background = bgColor;
                previewContainer.className = 'preview-container-layout ' + (themeColor === 'dark' ? 'preview-container-dark-layout' : 'preview-container-light-layout');
            }
            
            if (deviceScreen) {
                const borderColor = themeColor === 'dark' ? '#4a5568' : '#2c3e50';
                const shadowColor = themeColor === 'dark' ? '#1a1a1a' : '#34495e';
                deviceScreen.style.border = '8px solid ' + borderColor;
                deviceScreen.style.boxShadow = '0 0 0 2px ' + shadowColor + ', 0 10px 40px rgba(0,0,0,' + (themeColor === 'dark' ? '0.5' : '0.3') + ')';
            }
        }
        
        // 刷新预览功能（布局配置专用）
        const refreshBtnsLayout = container.querySelectorAll('.refresh-preview-btn-layout');
        refreshBtnsLayout.forEach(btn => {
            // 移除之前可能绑定的事件监听器，避免重复绑定
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            btn = newBtn;
            
            btn.addEventListener('click', function() {
                const btnElement = this; // 保存按钮引用
                const area = this.getAttribute('data-area');
                const iframeId = area === 'frontend' ? 'layoutPreviewIframeFrontend' : 'layoutPreviewIframeBackend';
                const loadingId = area === 'frontend' ? 'iframeLoadingFrontendConfig' : 'iframeLoadingBackendConfig';
                const iframe = document.getElementById(iframeId);
                const loadingDiv = document.getElementById(loadingId);
                
                if (iframe && loadingDiv) {
                    // 添加旋转动画
                    const icon = btnElement.querySelector('i');
                    if (icon) {
                        icon.classList.add('mdi-spin');
                    }
                    btnElement.disabled = true;
                    
                    // 显示加载状态
                    loadingDiv.style.display = 'flex';
                    loadingDiv.style.opacity = '1';
                    
                    // 获取自动登录开关状态
                    const autoLoginSwitch = container.querySelector('.auto-login-switch-layout[data-area="' + area + '"]');
                    const autoLogin = autoLoginSwitch && autoLoginSwitch.checked ? '1' : '0';
                    
                    // 重新加载iframe（更新自动登录参数）
                    const url = new URL(iframe.src);
                    url.searchParams.set('auto_login', autoLogin);
                    url.searchParams.set('_refresh', Date.now().toString());
                    iframe.src = '';
                    setTimeout(() => {
                        iframe.src = url.toString();
                    }, 100);
                    
                    // 监听iframe加载完成
                    const onLoad = function() {
                        // 尝试隐藏iframe内部的滚动条（但保留滚动功能）
                        try {
                            const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
                            if (iframeDoc) {
                                // 添加样式到iframe的head（隐藏滚动条但保留滚动功能）
                                const style = iframeDoc.createElement('style');
                                style.textContent = 'body, html { scrollbar-width: none !important; -ms-overflow-style: none !important; overflow-y: auto !important; overflow-x: auto !important; } body::-webkit-scrollbar, html::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; } body::-webkit-scrollbar-track, html::-webkit-scrollbar-track { display: none !important; }';
                                iframeDoc.head.appendChild(style);
                            }
                        } catch (e) {
                            // 跨域限制，无法访问iframe内容，忽略错误
                            console.debug('无法访问iframe内容（可能是跨域限制）:', e);
                        }
                        
                        if (icon) {
                            icon.classList.remove('mdi-spin');
                        }
                        btnElement.disabled = false; // 使用保存的按钮引用
                        loadingDiv.style.opacity = '0';
                        setTimeout(() => {
                            loadingDiv.style.display = 'none';
                            loadingDiv.style.opacity = '1';
                        }, 300);
                        iframe.removeEventListener('load', onLoad);
                    };
                    iframe.addEventListener('load', onLoad);
                }
            });
        });
        
        // 全屏预览功能（布局配置专用）
        const fullscreenBtnsLayout = container.querySelectorAll('.fullscreen-preview-btn-layout');
        fullscreenBtnsLayout.forEach(btn => {
            btn.addEventListener('click', function() {
                const area = this.getAttribute('data-area');
                const config = getCurrentConfig(area);
                // 获取自动登录开关状态
                const autoLoginSwitch = container.querySelector('.auto-login-switch-layout[data-area="' + area + '"]');
                const autoLogin = autoLoginSwitch && autoLoginSwitch.checked ? '1' : '0';
                const previewUrl = buildPreviewUrl(area, config.header, config.layouts, '', {}, {}, autoLogin);
                
                if (!previewUrl) return;
                
                // 根据预览类型确定窗口标题
                const windowTitle = area === 'frontend' ? '<?= __('前端预览') ?>' : '<?= __('后端预览') ?>';
                
                // 打开新窗口进行全屏预览
                const windowFeatures = 'width=' + screen.width + ',height=' + screen.height + ',left=0,top=0,resizable=yes,scrollbars=yes';
                const fullscreenWindow = window.open(previewUrl, '_blank', windowFeatures);
                
                if (fullscreenWindow) {
                    // 尝试最大化窗口（如果浏览器支持）
                    try {
                        fullscreenWindow.moveTo(0, 0);
                        fullscreenWindow.resizeTo(screen.width, screen.height);
                    } catch (e) {
                        // 某些浏览器可能不允许自动调整窗口大小，忽略错误
                        console.debug('无法自动调整窗口大小:', e);
                    }
                    
                    // 聚焦到新窗口
                    fullscreenWindow.focus();
                } else {
                    // 如果弹窗被阻止，提示用户
                    alert('<?= __('请允许弹出窗口以进行全屏预览') ?>');
                }
            });
        });
        
        // 初始化主题色系切换
        initThemeColorSwitcherLayout();
        
        // 绑定布局类型Tab切换事件，检测默认选中项并更新预览
        const frontendLayoutTabs = container.querySelectorAll('#frontend-layout-tabs button[data-bs-toggle="tab"]');
        frontendLayoutTabs.forEach(tab => {
            tab.addEventListener('shown.bs.tab', function(e) {
                const targetId = e.target.getAttribute('data-bs-target');
                const tabPane = container.querySelector(targetId);
                if (tabPane) {
                    // 从tabPane的id中提取布局类型（格式：frontend-layout-{layoutType}-pane）
                    const layoutTypeMatch = targetId.match(/frontend-layout-(.+)-pane/);
                    if (layoutTypeMatch) {
                        const layoutType = layoutTypeMatch[1];
                        
                        // 检测该tab内容中默认选中的选项
                        const selectedCard = tabPane.querySelector('.layout-option-card.border-primary');
                        let layoutValue = null;
                        
                        if (selectedCard) {
                            layoutValue = selectedCard.getAttribute('data-layout-value');
                            // 滚动到选中的选项（平滑滚动）
                            selectedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            
                            // 添加高亮动画效果
                            selectedCard.style.transition = 'all 0.3s';
                            selectedCard.style.boxShadow = '0 0 0 3px rgba(13, 110, 253, 0.25)';
                            setTimeout(() => {
                                selectedCard.style.boxShadow = '';
                            }, 1000);
                        } else {
                            // 如果没有选中的选项，使用第一个选项作为默认值
                            const firstCard = tabPane.querySelector('.layout-option-card');
                            if (firstCard) {
                                layoutValue = firstCard.getAttribute('data-layout-value');
                            }
                        }
                        
                        // 如果有布局值，立即更新预览
                        if (layoutValue) {
                            // 获取当前配置，然后使用该tab的布局选项更新预览
                            const currentConfig = getCurrentConfig('frontend');
                            const overrideLayouts = { ...currentConfig.layouts };
                            overrideLayouts[layoutType] = layoutValue;
                            
                            // 更新预览（使用覆盖的布局配置）
                            updatePreview('frontend', overrideLayouts);
                        }
                    }
                }
            });
        });
        
        const backendLayoutTabs = container.querySelectorAll('#backend-layout-tabs button[data-bs-toggle="tab"]');
        backendLayoutTabs.forEach(tab => {
            tab.addEventListener('shown.bs.tab', function(e) {
                const targetId = e.target.getAttribute('data-bs-target');
                const tabPane = container.querySelector(targetId);
                if (tabPane) {
                    // 从tabPane的id中提取布局类型（格式：backend-layout-{layoutType}-pane）
                    const layoutTypeMatch = targetId.match(/backend-layout-(.+)-pane/);
                    if (layoutTypeMatch) {
                        const layoutType = layoutTypeMatch[1];
                        
                        // 检测该tab内容中默认选中的选项
                        const selectedCard = tabPane.querySelector('.layout-option-card.border-primary');
                        let layoutValue = null;
                        
                        if (selectedCard) {
                            layoutValue = selectedCard.getAttribute('data-layout-value');
                            // 滚动到选中的选项（平滑滚动）
                            selectedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            
                            // 添加高亮动画效果
                            selectedCard.style.transition = 'all 0.3s';
                            selectedCard.style.boxShadow = '0 0 0 3px rgba(13, 110, 253, 0.25)';
                            setTimeout(() => {
                                selectedCard.style.boxShadow = '';
                            }, 1000);
                        } else {
                            // 如果没有选中的选项，使用第一个选项作为默认值
                            const firstCard = tabPane.querySelector('.layout-option-card');
                            if (firstCard) {
                                layoutValue = firstCard.getAttribute('data-layout-value');
                            }
                        }
                        
                        // 如果有布局值，立即更新预览
                        if (layoutValue) {
                            // 获取当前配置，然后使用该tab的布局选项更新预览
                            const currentConfig = getCurrentConfig('backend');
                            const overrideLayouts = { ...currentConfig.layouts };
                            overrideLayouts[layoutType] = layoutValue;
                            
                            // 更新预览（使用覆盖的布局配置）
                            updatePreview('backend', overrideLayouts);
                        }
                    }
                }
            });
        });
        
        // 初始化前端预览
        setTimeout(() => {
            updatePreview('frontend');
            updatePreview('backend');
        }, 300);
    }
    
    // 渲染部件配置表单
    function renderPartialsConfig(container, data) {
        let html = '<form id="partialsConfigForm">';
        html += '<input type="hidden" name="theme_id" value="' + data.theme.id + '">';
        html += '<div class="row">';
        
        // 前端配置
        html += '<div class="col-md-6">';
        html += '<div class="card mb-3">';
        html += '<div class="card-header"><h6 class="mb-0"><?= __('前端 Partials') ?></h6></div>';
        html += '<div class="card-body">';
        
        if (!data.frontendPartials || Object.keys(data.frontendPartials).length === 0) {
            html += '<p class="text-muted"><?= __('该主题暂无前端 partials 选项') ?></p>';
        } else {
            Object.keys(data.frontendPartials).forEach(type => {
                html += '<div class="mb-3">';
                html += '<label class="form-label">' + type.charAt(0).toUpperCase() + type.slice(1) + '</label>';
                html += '<select name="frontend_partials[' + type + ']" class="form-select">';
                data.frontendPartials[type].forEach(option => {
                    const selected = (data.frontendConfig[type] || 'default') === option ? 'selected' : '';
                    html += '<option value="' + option + '" ' + selected + '>' + option.charAt(0).toUpperCase() + option.slice(1) + '</option>';
                });
                html += '</select>';
                html += '</div>';
            });
        }
        
        html += '</div></div></div>';
        
        // 后端配置
        html += '<div class="col-md-6">';
        html += '<div class="card mb-3">';
        html += '<div class="card-header"><h6 class="mb-0"><?= __('后端 Partials') ?></h6></div>';
        html += '<div class="card-body">';
        
        if (!data.backendPartials || Object.keys(data.backendPartials).length === 0) {
            html += '<p class="text-muted"><?= __('该主题暂无后端 partials 选项') ?></p>';
        } else {
            Object.keys(data.backendPartials).forEach(type => {
                html += '<div class="mb-3">';
                html += '<label class="form-label">' + type.charAt(0).toUpperCase() + type.slice(1) + '</label>';
                html += '<select name="backend_partials[' + type + ']" class="form-select">';
                data.backendPartials[type].forEach(option => {
                    const selected = (data.backendConfig[type] || 'default') === option ? 'selected' : '';
                    html += '<option value="' + option + '" ' + selected + '>' + option.charAt(0).toUpperCase() + option.slice(1) + '</option>';
                });
                html += '</select>';
                html += '</div>';
            });
        }
        
        html += '</div></div></div>';
        html += '</div>';
        html += '</form>';
        
        container.innerHTML = html;
    }
    
    // 保存布局配置
    document.getElementById('saveLayoutConfigBtn').addEventListener('click', function() {
        const form = document.getElementById('layoutConfigForm');
        if (!form) return;
        
        const formData = new FormData(form);
        if (!formData.get('locale') && currentMetaConfig.locale) {
            formData.append('locale', currentMetaConfig.locale);
        }
        const themeId = formData.get('theme_id');
        
        // 收集前端配置
        const frontendLayouts = {};
        form.querySelectorAll('select[name^="frontend_layouts["]').forEach(select => {
            const name = select.name.match(/\[(.+)\]/)[1];
            frontendLayouts[name] = select.value;
        });
        // 从布局选项卡片收集
        form.querySelectorAll('.layout-option-card[data-area="frontend"].border-primary').forEach(card => {
            const layoutType = card.getAttribute('data-layout-type');
            const layoutValue = card.getAttribute('data-layout-value');
            if (layoutType && layoutValue) {
                frontendLayouts[layoutType] = layoutValue;
            }
        });
        
        // 收集前端色系、部件、变量配置
        const frontendColorCard = form.querySelector('.color-option-card[data-area="frontend"].border-primary');
        const frontendColor = frontendColorCard ? frontendColorCard.getAttribute('data-color-value') : '';
        
        const frontendPartials = {};
        form.querySelectorAll('.partial-option-card[data-area="frontend"].border-primary').forEach(card => {
            const partialType = card.getAttribute('data-partial-type');
            const partialValue = card.getAttribute('data-partial-value');
            if (partialType && partialValue) {
                frontendPartials[partialType] = partialValue;
            }
        });
        
        const frontendVariables = [];
        form.querySelectorAll('.variable-option-card[data-area="frontend"].border-primary').forEach(card => {
            const variableValue = card.getAttribute('data-variable-value');
            if (variableValue) {
                frontendVariables.push(variableValue);
            }
        });
        
        // 收集后端配置
        const backendLayouts = {};
        form.querySelectorAll('select[name^="backend_layouts["]').forEach(select => {
            const name = select.name.match(/\[(.+)\]/)[1];
            backendLayouts[name] = select.value;
        });
        // 从布局选项卡片收集
        form.querySelectorAll('.layout-option-card[data-area="backend"].border-primary').forEach(card => {
            const layoutType = card.getAttribute('data-layout-type');
            const layoutValue = card.getAttribute('data-layout-value');
            if (layoutType && layoutValue) {
                backendLayouts[layoutType] = layoutValue;
            }
        });
        
        // 收集后端色系、部件、变量配置
        const backendColorCard = form.querySelector('.color-option-card[data-area="backend"].border-primary');
        const backendColor = backendColorCard ? backendColorCard.getAttribute('data-color-value') : '';
        
        const backendPartials = {};
        form.querySelectorAll('.partial-option-card[data-area="backend"].border-primary').forEach(card => {
            const partialType = card.getAttribute('data-partial-type');
            const partialValue = card.getAttribute('data-partial-value');
            if (partialType && partialValue) {
                backendPartials[partialType] = partialValue;
            }
        });
        
        const backendVariables = [];
        form.querySelectorAll('.variable-option-card[data-area="backend"].border-primary').forEach(card => {
            const variableValue = card.getAttribute('data-variable-value');
            if (variableValue) {
                backendVariables.push(variableValue);
            }
        });
        
        // 保存前端配置
        const frontendData = new FormData();
        frontendData.append('theme_id', themeId);
        frontendData.append('area', 'frontend');
        frontendData.append('scope', layoutScopes.frontend || 'frontend/' + DEFAULT_SCOPE);
        Object.keys(frontendLayouts).forEach(key => {
            frontendData.append('layouts[' + key + ']', frontendLayouts[key]);
        });
        if (frontendColor) {
            frontendData.append('color', frontendColor);
        }
        Object.keys(frontendPartials).forEach(key => {
            frontendData.append('partials[' + key + ']', frontendPartials[key]);
        });
        frontendVariables.forEach(variable => {
            frontendData.append('variables[]', variable);
        });
        
        // 保存后端配置
        const backendData = new FormData();
        backendData.append('theme_id', themeId);
        backendData.append('area', 'backend');
        backendData.append('scope', layoutScopes.backend || 'backend/' + DEFAULT_SCOPE);
        Object.keys(backendLayouts).forEach(key => {
            backendData.append('layouts[' + key + ']', backendLayouts[key]);
        });
        if (backendColor) {
            backendData.append('color', backendColor);
        }
        Object.keys(backendPartials).forEach(key => {
            backendData.append('partials[' + key + ']', backendPartials[key]);
        });
        backendVariables.forEach(variable => {
            backendData.append('variables[]', variable);
        });
        
        // 禁用保存按钮
        const saveBtn = document.getElementById('saveLayoutConfigBtn');
        saveBtn.disabled = true;
        const originalText = saveBtn.textContent;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __('保存中...') ?>';
        
        // 先保存前端配置
        fetch(layoutSaveUrl, {
            method: 'POST',
            body: frontendData
        })
        .then(response => response.json())
        .then(data => {
            if (data.code === 200) {
                // 再保存后端配置
                return fetch(layoutSaveUrl, {
                    method: 'POST',
                    body: backendData
                });
            } else {
                throw new Error(data.msg || '<?= __('保存失败') ?>');
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.code === 200) {
                // 关闭Modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('layoutConfigModal'));
                modal.hide();
                
                // 显示成功消息
                if (typeof showMessage === 'function') {
                    showMessage('success', data.msg || '<?= __('配置保存成功') ?>');
                } else {
                    alert(data.msg || '<?= __('配置保存成功') ?>');
                }
            } else {
                alert(data.msg || '<?= __('保存失败') ?>');
                saveBtn.disabled = false;
                saveBtn.textContent = originalText;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __('保存失败') ?>: ' + error.message);
            saveBtn.disabled = false;
            saveBtn.textContent = originalText;
        });
    });

    // 参数翻译按钮（在 Meta 参数列表里）
    document.addEventListener('click', function(e) {
        const translateBtn = e.target.closest('.param-translate-btn');
        if (translateBtn) {
            if (!currentThemeId) {
                return;
            }

            currentParamTranslation.identify = translateBtn.getAttribute('data-identify') || '';
            currentParamTranslation.param = translateBtn.getAttribute('data-param') || '';
            currentParamTranslation.area = translateBtn.getAttribute('data-area') || 'frontend';
            currentParamTranslation.scope = translateBtn.getAttribute('data-scope') || DEFAULT_SCOPE;
            currentParamTranslation.locale = null;

            const modal = new bootstrap.Modal(document.getElementById('paramTranslationModal'));
            document.getElementById('paramTranslationModalLabel').textContent = '<?= __('参数翻译') ?> - ' + currentParamTranslation.param;
            modal.show();

            loadParamTranslation();
        }
    });

    // 保存部件配置
    document.getElementById('savePartialsConfigBtn').addEventListener('click', function() {
        const form = document.getElementById('partialsConfigForm');
        if (!form) return;
        
        const formData = new FormData(form);
        const themeId = formData.get('theme_id');
        
        // 收集前端配置
        const frontendPartials = {};
        form.querySelectorAll('select[name^="frontend_partials["]').forEach(select => {
            const name = select.name.match(/\[(.+)\]/)[1];
            frontendPartials[name] = select.value;
        });
        
        // 收集后端配置
        const backendPartials = {};
        form.querySelectorAll('select[name^="backend_partials["]').forEach(select => {
            const name = select.name.match(/\[(.+)\]/)[1];
            backendPartials[name] = select.value;
        });
        
        // 保存前端配置
        const frontendData = new FormData();
        frontendData.append('theme_id', themeId);
        frontendData.append('area', 'frontend');
        Object.keys(frontendPartials).forEach(key => {
            frontendData.append('partials[' + key + ']', frontendPartials[key]);
        });
        
        // 保存后端配置
        const backendData = new FormData();
        backendData.append('theme_id', themeId);
        backendData.append('area', 'backend');
        Object.keys(backendPartials).forEach(key => {
            backendData.append('partials[' + key + ']', backendPartials[key]);
        });
        
        // 禁用保存按钮
        const saveBtn = document.getElementById('savePartialsConfigBtn');
        saveBtn.disabled = true;
        const originalText = saveBtn.textContent;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __('保存中...') ?>';
        
        // 先保存前端配置
        fetch('<?= $this->getUrl('theme/backend/config/partials/save') ?>', {
            method: 'POST',
            body: frontendData
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                // 再保存后端配置
                return fetch('<?= $this->getUrl('theme/backend/config/partials/save') ?>', {
                    method: 'POST',
                    body: backendData
                });
            } else {
                throw new Error(data.message || '<?= __('保存失败') ?>');
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                // 关闭Modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('partialsConfigModal'));
                modal.hide();
                
                // 显示成功消息
                if (typeof showMessage === 'function') {
                    showMessage('success', data.message || '<?= __('配置保存成功') ?>');
                } else {
                    alert(data.message || '<?= __('配置保存成功') ?>');
                }
            } else {
                alert(data.message || '<?= __('保存失败') ?>');
                saveBtn.disabled = false;
                saveBtn.textContent = originalText;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __('保存失败') ?>: ' + error.message);
            saveBtn.disabled = false;
            saveBtn.textContent = originalText;
        });
    });
    
})();
</script>

</body>
</html>
