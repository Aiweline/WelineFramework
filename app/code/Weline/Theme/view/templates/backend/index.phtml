    // 打开 Meta 参数配置 Modal（齿轮按钮）
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.meta-config-btn');
        if (!btn) {
            return;
        }

        if (!currentThemeId) {
            alert('<?= __('请先选择需要配置的主题') ?>');
            return;
        }

        const area = (btn.getAttribute('data-area') || 'frontend').toLowerCase();
        const type = btn.getAttribute('data-type') || '';
        const category = btn.getAttribute('data-category') || '';
        let identify = btn.getAttribute('data-identify') || '';

        if (identify) {
            if (!identify.startsWith('theme.')) {
                identify = 'theme.' + area + '.' + identify.replace(/^theme\./, '');
            }
        }

        const scopeValue = layoutScopes[area] || (area + '/' + DEFAULT_SCOPE);
        const scopeParts = scopeValue.split('/');
        const scope = scopeParts.slice(1).join('/') || DEFAULT_SCOPE;

        const params = new URLSearchParams({
            namespace: 'theme.' + area,
            area: area,
            theme_id: currentThemeId || '',
            scope: scope,
            type: type,
        });

        if (category) {
            params.append('category', category);
        }
        if (identify) {
            params.append('meta_identify', identify);
        }

        if (metaConfigIframeLoading) {
            metaConfigIframeLoading.style.display = 'flex';
        }
        if (metaConfigIframe) {
            metaConfigIframe.classList.add('d-none');
            metaConfigIframe.src = metaManagerUrl + '?' + params.toString();
            metaConfigIframe.onload = function() {
                if (metaConfigIframeLoading) {
                    metaConfigIframeLoading.style.display = 'none';
                }
                metaConfigIframe.classList.remove('d-none');
            };
        }

        if (metaConfigModalElement) {
            const modal = bootstrap.Modal.getOrCreateInstance(metaConfigModalElement);
            const label = document.getElementById('metaConfigModalLabel');
            if (label) {
                label.textContent = '<?= __('Meta配置') ?> - ' + (identify || type || area);
            }
            modal.show();
        }
    });
    
    window.addEventListener('message', function(event) {
        const data = event.data || {};
        if (data.type === 'meta-config:saved') {
            refreshPreviewIframes((data.area || '').toLowerCase());
        }
    });

    function refreshPreviewIframes(targetArea = null) {
        document.querySelectorAll('.config-preview-iframe').forEach(function(iframe) {
            const iframeArea = (iframe.getAttribute('data-area') || '').toLowerCase();
            if (targetArea && iframeArea !== targetArea) {
                return;
            }
            const loadingId = iframe.getAttribute('data-loading-id');
            if (loadingId) {
                const loadingEl = document.getElementById(loadingId);
                if (loadingEl) {
                    loadingEl.style.display = 'flex';
                }
            }
            const src = iframe.getAttribute('src');
            iframe.setAttribute('src', src);
        });
    }
    
