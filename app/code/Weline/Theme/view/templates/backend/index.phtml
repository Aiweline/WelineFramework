<script>
(function() {
    'use strict';
    
    let currentThemeId = null;
    let currentThemeData = null;
    let layoutConfigData = null;
    let partialsConfigData = null;
    const layoutConfigModalBody = document.getElementById('layoutConfigModalBody');
    const layoutConfigUrl = '<?= $this->getUrl('theme/backend/config/layout/config-data') ?>';
    const layoutSaveUrl = '<?= $this->getUrl('theme/backend/config/layout/save') ?>';
    const layoutPreviewUrl = '<?= $this->getUrl('theme/backend/config/layout/preview') ?>';
    const metaConfigModalElement = document.getElementById('metaConfigModal');
    const metaConfigIframe = document.getElementById('metaConfigIframe');
    const metaConfigIframeLoading = document.getElementById('metaConfigIframeLoading');
    const metaManagerUrl = '<?= $this->getUrl('meta/backend/config/file') ?>';
    const DEFAULT_SCOPE = 'default';
    const layoutScopes = {
        frontend: 'frontend/' + DEFAULT_SCOPE,
        backend: 'backend/' + DEFAULT_SCOPE
    };

    const currentParamTranslation = {
        identify: null,
        param: null,
        scope: DEFAULT_SCOPE,
        area: 'frontend',
        locale: null
    };

    function buildPreviewCardHtml(area, context, title, description = '') {
        const capitalize = (value) => value.charAt(0).toUpperCase() + value.slice(1);
        const areaKey = capitalize(area);
        const contextKey = capitalize(context);
        const loadingId = 'iframeLoading' + areaKey + contextKey;
        const iframeId = 'configPreviewIframe' + areaKey + contextKey;
        let html = '';
        html += '<div class="card h-100">';
        html += '<div class="card-header"><h6 class="mb-0">' + title + '</h6></div>';
        html += '<div class="card-body p-0">';
        html += '<div class="config-preview-panel">';
        html += '<div class="iframe-loading small" id="' + loadingId + '">';
        html += '<div class="spinner-border text-primary mb-2" role="status" style="width: 2rem; height: 2rem;"><span class="visually-hidden"><?= __('加载中...') ?></span></div>';
        html += '<p class="text-muted small mb-0"><?= __('正在刷新预览...') ?></p>';
        html += '</div>';
        html += '<iframe id="' + iframeId + '" class="config-preview-iframe" data-area="' + area + '" data-context="' + context + '" data-loading-id="' + loadingId + '" style="width: 100%; min-height: 420px; border: none; background: white; border-radius: 8px;"></iframe>';
        if (description) {
            html += '<div class="preview-note text-muted small text-center py-2">' + description + '</div>';
        }
        html += '</div>';
        html += '</div>';
        html += '</div>';
        return html;
    }

    function normalizeScopeInput(area, value) {
        const normalizedArea = (area || 'frontend').toLowerCase();
        let scope = (value || '').trim();
        if (!scope) {
            return normalizedArea + '/' + DEFAULT_SCOPE;
        }
        if (scope.includes('/')) {
            const parts = scope.split('/');
            const maybeArea = parts.shift() || normalizedArea;
            const rest = parts.join('/').trim() || DEFAULT_SCOPE;
            return maybeArea.toLowerCase() + '/' + rest;
        }
        return normalizedArea + '/' + scope;
    }

    function loadLayoutConfigData(targetBody = null, showLoading = false) {
        if (!currentThemeId) {
            return;
        }
        const container = targetBody || layoutConfigModalBody;
        if (!container) {
            return;
        }

        if (showLoading) {
            container.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div><p class="mt-3 text-muted"><?= __('正在加载配置...') ?></p></div>';
        }

        const params = new URLSearchParams();
        params.append('theme_id', currentThemeId);
        params.append('scope_frontend', layoutScopes.frontend || 'frontend/' + DEFAULT_SCOPE);
        params.append('scope_backend', layoutScopes.backend || 'backend/' + DEFAULT_SCOPE);

        fetch(layoutConfigUrl + '?' + params.toString())
            .then(response => response.json())
            .then(data => {
                if (data.code === 200) {
                    layoutConfigData = data.data;
                    layoutScopes.frontend = normalizeScopeInput('frontend', layoutConfigData.frontendScope || layoutScopes.frontend);
                    layoutScopes.backend = normalizeScopeInput('backend', layoutConfigData.backendScope || layoutScopes.backend);
                    renderLayoutConfig(container, layoutConfigData);
                } else {
                    container.innerHTML = '<div class="alert alert-danger">' + (data.msg || data.message || '<?= __('加载配置失败') ?>') + '</div>';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                container.innerHTML = '<div class="alert alert-danger"><?= __('加载配置失败') ?>: ' + error.message + '</div>';
            });
    }
    
    // 检测外部主题色系（全局函数）
    function detectExternalTheme() {
        const body = document.body;
        // 检查多种可能的主题标识方式
        if (body.getAttribute('data-theme-mode') === 'dark' || 
            body.getAttribute('data-layout-mode') === 'dark' ||
            body.getAttribute('data-sidebar') === 'dark' ||
            body.getAttribute('data-topbar') === 'dark' ||
            body.classList.contains('dark-mode') ||
            body.classList.contains('theme-dark')) {
            return 'dark';
        }
        // 检查html标签
        const html = document.documentElement;
        if (html.getAttribute('data-theme') === 'dark' ||
            html.getAttribute('data-bs-theme') === 'dark') {
            return 'dark';
        }
        // 默认返回亮色
        return 'light';
    }
    
    // 打开主题预览/激活Modal的通用函数
    function openThemeModal(themeId, themeName, isPreview = false) {
        currentThemeId = themeId;
            const modal = new bootstrap.Modal(document.getElementById('themeActivateModal'));
        document.getElementById('themeActivateModalLabel').textContent = (isPreview ? '<?= __('主题预览') ?>' : '<?= __('主题激活') ?>') + ' - ' + themeName;
            
            // 重置Modal内容
            const modalBody = document.getElementById('themeActivateModalBody');
            const confirmBtn = document.getElementById('confirmActivateThemeBtn');
            modalBody.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div><p class="mt-3 text-muted"><?= __('正在加载主题信息...') ?></p></div>';
        
        // 如果是预览模式，隐藏激活按钮；否则显示
