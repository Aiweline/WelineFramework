    // 加载并渲染单个参数的翻译配置
    function loadParamTranslation() {
        if (!currentParamTranslation.identify || !currentParamTranslation.param) {
            return;
        }

        const params = new URLSearchParams();
        params.append('theme_id', currentThemeId);
        params.append('area', currentParamTranslation.area || 'frontend');
        params.append('identify', currentParamTranslation.identify);
        params.append('param', currentParamTranslation.param);
        params.append('scope', currentParamTranslation.scope || DEFAULT_SCOPE);
        if (currentParamTranslation.locale) {
            params.append('locale', currentParamTranslation.locale);
        }

        paramTranslationModalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div><p class="mt-3 text-muted mb-0"><?= __('正在加载翻译...') ?></p></div>';

        fetch(paramTranslationUrl + '?' + params.toString())
            .then(response => response.json())
            .then(data => {
                if (data.code !== 200) {
                    paramTranslationModalBody.innerHTML = '<div class="alert alert-danger mb-0">' + (data.msg || data.message || '<?= __('加载翻译失败') ?>') + '</div>';
                    return;
                }

                const info = data.data || {};
                currentParamTranslation.locale = info.locale || currentParamTranslation.locale || (<?= json_encode(\Weline\Framework\Http\Cookie::getLangLocal() ?? 'zh_Hans_CN') ?>);

                let html = '';
                html += '<form id="paramTranslationForm">';
                html += '<input type="hidden" name="theme_id" value="' + currentThemeId + '">';
                html += '<input type="hidden" name="area" value="' + (info.area || currentParamTranslation.area || 'frontend') + '">';
                html += '<input type="hidden" name="identify" value="' + (info.identify || currentParamTranslation.identify) + '">';
                html += '<input type="hidden" name="param" value="' + (info.param || currentParamTranslation.param) + '">';
                html += '<input type="hidden" name="scope" value="' + (info.scope || currentParamTranslation.scope || DEFAULT_SCOPE) + '">';

                html += '<div class="mb-3">';
                html += '<label class="form-label"><?= __('参数') ?></label>';
                html += '<div><code>' + (info.identify || currentParamTranslation.identify) + '.param.' + (info.param || currentParamTranslation.param) + '.value</code></div>';
                html += '</div>';

                html += '<div class="mb-3">';
                html += '<label class="form-label"><?= __('目标语言代码') ?></label>';
                html += '<input type="text" class="form-control form-control-sm" name="locale" value="' + (info.locale || currentParamTranslation.locale || '') + '" placeholder="zh_Hans_CN">';
                html += '<div class="form-text"><?= __('填写要翻译到的语言代码，例如 zh_Hans_CN / en_US / es_ES 等。') ?></div>';
                html += '</div>';

                const label = info.label || currentParamTranslation.param;
                const desc = info.description || '';
                const val = (typeof info.value !== 'undefined' && info.value !== null) ? info.value : (info.default || '');

                html += '<div class="mb-3">';
                html += '<label class="form-label">' + label + '</label>';
                if (desc) {
                    html += '<div class="text-muted small mb-1">' + desc + '</div>';
                }
                html += '<input type="text" class="form-control" name="value" value="' + String(val).replace(/"/g, '&quot;') + '">';
                html += '</div>';

                paramTranslationModalBody.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                paramTranslationModalBody.innerHTML = '<div class="alert alert-danger mb-0"><?= __('加载翻译失败') ?>: ' + error.message + '</div>';
            });
    }

    /**
     * 加载并渲染 Meta 参数配置（齿轮按钮）
     * @param {Object} options
     * @param {string} options.area frontend/backend
     * @param {string} options.type layouts/colors/variables/components/partials
     * @param {string} options.identify meta_identify（如 layouts.default）
     */
    function loadMetaConfig(options) {
        if (!currentThemeId) {
            return;
        }
        if (!options || !options.identify) {
            return;
        }

        const area = options.area || 'frontend';
        const type = options.type || 'layouts';
        const identify = options.identify;

        if (!metaConfigModalBody) {
            return;
        }

        metaConfigModalBody.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden"><?= __('加载中...') ?></span></div><p class="mt-3 text-muted"><?= __('正在加载配置...') ?></p></div>';

        const params = new URLSearchParams();
        params.append('theme_id', currentThemeId);
        params.append('area', area);
        params.append('identify', identify);
        // scope：复用当前布局配置的 scope 规则
        const scopeValue = area === 'backend' ? (layoutScopes.backend || 'backend/' + DEFAULT_SCOPE) : (layoutScopes.frontend || 'frontend/' + DEFAULT_SCOPE);
        params.append('scope', scopeValue.split('/').slice(1).join('/') || DEFAULT_SCOPE);

        fetch(metaConfigUrl + '?' + params.toString())
            .then(response => response.json())
            .then(data => {
                if (data.code !== 200) {
                    metaConfigModalBody.innerHTML = '<div class="alert alert-danger">' + (data.msg || data.message || '<?= __('加载配置失败') ?>') + '</div>';
                    return;
                }

                const cfg = data.data || {};
                const paramsList = Array.isArray(cfg.params) ? cfg.params : [];

                if (paramsList.length === 0) {
                    metaConfigModalBody.innerHTML = '<div class="alert alert-info mb-0"><?= __('该组件未定义可配置参数。') ?></div>';
                    return;
                }

                let html = '';
                html += '<form id="metaConfigForm">';
                html += '<input type="hidden" name="theme_id" value="' + currentThemeId + '">';
                html += '<input type="hidden" name="area" value="' + (cfg.area || area) + '">';
                html += '<input type="hidden" name="identify" value="' + (cfg.identify || identify) + '">';
                html += '<input type="hidden" name="scope" value="' + (cfg.scope || (scopeValue.split('/').slice(1).join('/') || DEFAULT_SCOPE)) + '">';

                // 语言信息（当前语言）
                const currentLocale = cfg.locale || 'zh_Hans_CN';
                html += '<div class="mb-3 d-flex justify-content-between align-items-center">';
                html += '<div>';
                html += '<span class="badge bg-light text-dark me-2"><?= __('当前语言') ?>:</span>';
                html += '<code style="font-size: 11px;">' + currentLocale + '</code>';
                html += '</div>';
                html += '</div>';

                html += '<div class="list-group list-group-flush">';
                paramsList.forEach(function (item) {
                    const name = item.name || '';
                    const label = item.label || name;
                    const desc = item.description || '';
                    const value = (typeof item.value !== 'undefined' && item.value !== null) ? item.value : (item.default || '');
                    const isTranslatable = !!item.translate;

                    html += '<div class="list-group-item">';
                    html += '<div class="mb-2 d-flex justify-content-between align-items-center">';
                    html += '<div><strong>' + label + '</strong>';
                    html += ' <code class="text-muted ms-1" style="font-size: 11px;">' + name + '</code></div>';
                    if (isTranslatable) {
                        html += '<div class="d-flex align-items-center gap-1">';
                        html += '<span class="badge bg-success-subtle text-success" title="<?= __('该参数支持多语言翻译') ?>"><?= __('多语言') ?></span>';
                        html += '<button type="button" class="btn btn-sm btn-outline-secondary param-translate-btn" ' +
                            'data-area="' + (cfg.area || area) + '" ' +
                            'data-identify="' + (cfg.identify || identify) + '" ' +
                            'data-param="' + name + '" ' +
                            'data-scope="' + (cfg.scope || (scopeValue.split("/").slice(1).join("/") || DEFAULT_SCOPE)) + '">' +
                            '<i class="mdi mdi-translate"></i></button>';
                        html += '</div>';
                    }
                    html += '</div>';
                    if (desc) {
                        html += '<div class="text-muted small mb-2">' + desc + '</div>';
                    }
                    html += '<input type="text" class="form-control form-control-sm" name="params[' + name + ']" value="' + String(value).replace(/"/g, '&quot;') + '">';
                    html += '</div>';
                });
                html += '</div>';

                html += '</form>';

                metaConfigModalBody.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                metaConfigModalBody.innerHTML = '<div class="alert alert-danger"><?= __('加载配置失败') ?>: ' + error.message + '</div>';
            });
    }
    
