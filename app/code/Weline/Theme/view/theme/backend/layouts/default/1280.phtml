@meta.name {default="后端1280px布局",name="后端1280px布局",description="后端1280px布局，用于描述布局的名称"}
@meta.description {default="后端1280px最大宽度布局，内容居中显示",name="后端1280px最大宽度布局，内容居中显示",description="后端1280px最大宽度布局，内容居中显示，用于描述布局的用途"}
