/**
 * 布局：后端 - 1440px 宽度布局
 *
 * 后端1440px最大宽度布局，内容居中显示，适合大屏显示器
 * 字段
 * @info description 描述：后端1440px最大宽度布局，内容居中显示，适合大屏显示器
 * @info name 名称：1440px布局
 * @param title 页面标题
 * @param content 主要内容（HTML字符串）
 * @param sidebar 侧边栏内容（HTML字符串，可选）
 * @param showHeader 是否显示header（默认：true）
 * @param showFooter 是否显示footer（默认：true）
 * @param sidebarCollapsed 侧边栏是否折叠（默认：false）
 * @param class 额外CSS类
 *
 * 参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
 * 模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
 * 页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
 */
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    @template(Weline_Backend::templates/public/head.phtml)
    <style>
        .backend-layout-1440 {
            max-width: 1440px;
            width: 100%;
            margin: 0 auto;
            display: flex;
            flex-direction: row;
            gap: 20px;
            padding: 0 20px;
        }
        .backend-layout-1440 .backend-sidebar {
            flex-shrink: 0;
            width: 250px;
            transition: width 0.3s ease;
        }
        .backend-layout-1440 .backend-sidebar.collapsed {
            width: 60px;
        }
        .backend-layout-1440 .backend-main-content {
            flex: 1;
            min-width: 0;
            overflow: auto;
        }
        @media (max-width: 1440px) {
            .backend-layout-1440 {
                padding: 0 15px;
            }
        }
        @media (max-width: 768px) {
            .backend-layout-1440 {
                flex-direction: column;
            }
            .backend-layout-1440 .backend-sidebar {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <if condition="meta.showHeader">
        @template(Weline_Backend::blocks/header/base.phtml)
    </if>
    
    <div class="backend-layout-1440 <?= htmlspecialchars($meta['class'] ?? '') ?>">
        <if condition="meta.sidebar">
            <aside class="backend-sidebar <if condition="meta.sidebarCollapsed">collapsed</if>">
                {{meta.sidebar}}
            </aside>
        </if>
        
        <main class="backend-main-content">
            {{meta.content}}
        </main>
    </div>
    
    <if condition="meta.showFooter">
        @template(Weline_Backend::blocks/footer/base.phtml)
    </if>
</body>
</html>

