<?php
/**
 * 布局：后端 - 全屏布局
 *
 * 后端全屏布局，内容占满整个屏幕，无侧边栏，适合大屏展示、数据可视化等场景
 * 字段
 * @info description 描述：后端全屏布局，内容占满整个屏幕，无侧边栏，适合大屏展示、数据可视化等场景
 * @info name 名称：全屏布局
 * @param title 页面标题
 * @param content 主要内容（HTML字符串）
 * @param showHeader 是否显示header（默认：true）
 * @param showFooter 是否显示footer（默认：false）
 * @param class 额外CSS类
 *
 * 参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
 * 模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
 * 页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
 */
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}">
<head>
    @template(Weline_Backend::templates/public/head.phtml)
    <style>
        .backend-layout-fullscreen {
            width: 100%;
            height: 100vh;
            overflow: auto;
            display: flex;
            flex-direction: column;
        }
        .backend-layout-fullscreen .backend-main-content {
            flex: 1;
            width: 100%;
            padding: 0;
            margin: 0;
            overflow: auto;
        }
    </style>
</head>
<body>
    <if condition="meta.showHeader">
        @template(Weline_Backend::blocks/header/base.phtml)
    </if>
    
    <div class="backend-layout-fullscreen <?= htmlspecialchars($meta['class'] ?? '') ?>">
        <main class="backend-main-content">
            {{meta.content}}
        </main>
    </div>
    
    <if condition="meta.showFooter">
        @template(Weline_Backend::blocks/footer/base.phtml)
    </if>
</body>
</html>

