<?php
/**
 * 布局：后端 - 全屏布局
 * 
 * 后端全屏布局，内容占满整个屏幕，无侧边栏，适合大屏展示、数据可视化等场景
 * 字段
 * @info description 描述：后端全屏布局，内容占满整个屏幕，无侧边栏，适合大屏展示、数据可视化等场景
 * @info name 名称：全屏布局
 * @param title 页面标题
 * @param content 主要内容（HTML字符串）
 * @param showHeader 是否显示header（默认：true）
 * @param showFooter 是否显示footer（默认：false）
 * @param class 额外CSS类
 */
$title = $this->getData('title') ?? '';
$content = $this->getData('content') ?? '';
$showHeader = $this->getData('showHeader') ?? true;
$showFooter = $this->getData('showFooter') ?? false;
$class = $this->getData('class') ?? '';

// 设置页面标题
if ($title) {
    $this->assign('title', $title);
}
?>
<!DOCTYPE html>
<html lang="<?= str_replace('_', '-', $_SERVER['WELINE_USER_LANG'] ?? 'zh_Hans_CN') ?>">
<head>
    @template(Weline_Backend::templates/public/head.phtml)
    <style>
        .backend-layout-fullscreen {
            width: 100%;
            height: 100vh;
            overflow: auto;
            display: flex;
            flex-direction: column;
        }
        .backend-layout-fullscreen .backend-main-content {
            flex: 1;
            width: 100%;
            padding: 0;
            margin: 0;
            overflow: auto;
        }
    </style>
</head>
<body>
    <?php if ($showHeader): ?>
        @template(Weline_Backend::blocks/header/base.phtml)
    <?php endif; ?>
    
    <div class="backend-layout-fullscreen <?= htmlspecialchars($class) ?>">
        <main class="backend-main-content">
            <?= $content ?>
        </main>
    </div>
    
    <?php if ($showFooter): ?>
        @template(Weline_Backend::blocks/footer/base.phtml)
    <?php endif; ?>
</body>
</html>

