<!--
布局：后端 - 打印布局

后端打印布局，无装饰、纯内容，适合打印输出
字段
@meta.name {default="后端打印布局",name="后端打印布局",description="后端打印布局，用于描述布局的名称"}
@meta.description {default="后端打印布局，无装饰、纯内容",name="后端打印布局，无装饰、纯内容",description="后端打印布局，无装饰、纯内容，用于描述布局的用途"}
@param.title {default="",name="页面标题",description="页面标题，用于设置页面标题"}
@param.content {default="",name="内容（HTML字符串）",description="内容（HTML字符串），用于设置页面内容"}
@param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}

参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
-->
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}" data-theme="backend">
<head>
    <w:hook>Weline_Theme::backend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="backend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::backend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::backend::layouts::print::head-after</w:hook>
</head>
<body class="<?= htmlspecialchars($meta['class'] ?? '') ?>">
    <w:hook>Weline_Theme::backend::layouts::print::body-start</w:hook>
    
    <div class="backend-layout-print">
        <if condition="contentTemplate">
            <?php echo $this->fetch($this->getData("contentTemplate")); ?>
            <else/>
            {{meta.content}}
        </if>
    </div>
    <div class="no-print" style="text-align: center; margin-top: 20px;">
        <button onclick="window.print()" class="backend-print-btn">
            <i class="ri-printer-line"></i>
            <lang>打印</lang>
        </button>
    </div>
    
    <w:hook>Weline_Theme::backend::layouts::print::body-end</w:hook>
</body>
</html>

<style>
/* 打印布局样式 */
body {
    margin: 0;
    padding: 0;
    background-color: var(--backend-color-bg-secondary, #f8f9fa);
    color: var(--backend-color-text-primary, #212529);
}

@media print {
    body {
        background: white;
        color: black;
        font-size: 12pt;
    }
    .no-print {
        display: none !important;
    }
}

@media screen {
    .backend-layout-print {
        max-width: 800px;
        margin: var(--backend-spacing-lg, 20px) auto;
        padding: var(--backend-spacing-lg, 20px);
        background: var(--backend-color-card-bg, #fff);
        border-radius: var(--backend-border-radius-md, 8px);
        box-shadow: var(--backend-card-shadow, 0 0 13px 0 rgba(74, 53, 107, 0.05));
    }
}

.backend-print-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--backend-spacing-xs, 6px);
    padding: var(--backend-spacing-sm, 10px) var(--backend-spacing-lg, 20px);
    border: none;
    border-radius: var(--backend-border-radius, 6px);
    background: var(--backend-color-primary, #556ee6);
    color: var(--backend-color-text-inverse, #fff);
    font-size: 0.9375rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.backend-print-btn:hover {
    background: var(--backend-color-primary-hover, #4857d4);
}
</style>
