<?php
/**
 * 组件：Table
 *
 * @meta.name {default="Table 表格",name="Table 表格",description="用于页面搭建的数据表格"}
 * @meta.description {default="用于页面搭建的数据表格",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.headers {default=["名称","状态","更新时间"],name="表头",description="表头数组"}
 * @param.rows {default=[["示例数据","正常","刚刚"]],name="数据行",description="二维数组"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$headers = $this->getData('headers') ?? $this->getData('meta.headers') ?? ['名称', '状态', '更新时间'];
$rows = $this->getData('rows') ?? $this->getData('meta.rows') ?? [['示例数据', '正常', '刚刚']];
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$headers = is_array($headers) ? $headers : [];
$rows = is_array($rows) ? $rows : [];
$tableClass = trim('table table-sm align-middle w-builder-table ' . $class);
?>
<table class="<?= htmlspecialchars($tableClass, ENT_QUOTES, 'UTF-8') ?>">
    <?php if ($headers !== []): ?>
        <thead>
        <tr>
            <?php foreach ($headers as $header): ?>
                <th><?= htmlspecialchars((string)$header, ENT_QUOTES, 'UTF-8') ?></th>
            <?php endforeach; ?>
        </tr>
        </thead>
    <?php endif; ?>
    <tbody>
    <?php foreach ($rows as $row): ?>
        <tr>
            <?php foreach ((array)$row as $cell): ?>
                <td><?= htmlspecialchars(is_array($cell) ? (string)($cell['content'] ?? '') : (string)$cell, ENT_QUOTES, 'UTF-8') ?></td>
            <?php endforeach; ?>
        </tr>
    <?php endforeach; ?>
    </tbody>
</table>
