<?php
/**
 * 组件：Grid
 *
 * @meta.name {default="Grid 栅格",name="Grid 栅格",description="可嵌套组件的栅格容器"}
 * @meta.description {default="可嵌套组件的栅格容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"content":{"id":"container:{layout_id}","name":"栅格内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true}}
 * @param.columns {default=2,name="列数",description="1-4"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$columns = (int)($this->getData('columns') ?? $this->getData('meta.columns') ?? 2);
$columns = max(1, min(4, $columns));
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'container:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<div class="w-builder-grid" style="display:grid;grid-template-columns:repeat(<?= $columns ?>,minmax(0,1fr));gap:12px;"
     data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-name="<?= htmlspecialchars(__('栅格内容'), ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
     data-wslot-multiple="true">
    <?php if ($editorMode): ?>
        <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入内容组件') ?></div>
    <?php endif; ?>
</div>
