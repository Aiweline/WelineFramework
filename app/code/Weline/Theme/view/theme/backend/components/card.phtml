<?php
/**
 * 组件：Card
 *
 * @meta.name {default="Card 卡片",name="Card 卡片",description="可嵌套内容的卡片容器"}
 * @meta.description {default="可嵌套内容的卡片容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"body":{"id":"card-body:{layout_id}","name":"卡片内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true},"footer":{"id":"card-footer:{layout_id}","name":"卡片底部","accept":["builder-action","builder-component"],"multiple":true}}
 * @param.title {default="数据卡片",name="标题",description="卡片标题"}
 * @param.subtitle {default="",name="副标题",description="卡片副标题"}
 * @param.content {default="",name="兼容内容",description="旧版 HTML 字符串内容"}
 * @param.footer {default="",name="兼容底部",description="旧版 HTML 字符串底部"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? '数据卡片');
$subtitle = (string)($this->getData('subtitle') ?? $this->getData('meta.subtitle') ?? '');
$content = (string)($this->getData('content') ?? $this->getData('meta.content') ?? '');
$footer = (string)($this->getData('footer') ?? $this->getData('meta.footer') ?? '');
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$bodySlotId = 'card-body:' . ($layoutId !== '' ? $layoutId : 'preview');
$footerSlotId = 'card-footer:' . ($layoutId !== '' ? $layoutId : 'preview');
$cardClass = trim('card w-builder-card ' . $class);
?>
<section class="<?= htmlspecialchars($cardClass, ENT_QUOTES, 'UTF-8') ?>">
    <?php if ($title !== '' || $subtitle !== ''): ?>
        <header class="card-header w-builder-card-header">
            <?php if ($title !== ''): ?>
                <h3 class="w-builder-card-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h3>
            <?php endif; ?>
            <?php if ($subtitle !== ''): ?>
                <p class="w-builder-card-subtitle"><?= htmlspecialchars($subtitle, ENT_QUOTES, 'UTF-8') ?></p>
            <?php endif; ?>
        </header>
    <?php endif; ?>
    <div class="card-body w-builder-card-body"
         data-wslot="<?= htmlspecialchars($bodySlotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('卡片内容'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
         data-wslot-multiple="true">
        <?php if ($content !== ''): ?>
            <?= $content ?>
        <?php elseif ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入表单、表格、文本或按钮') ?></div>
        <?php endif; ?>
    </div>
    <div class="card-footer w-builder-card-footer"
         data-wslot="<?= htmlspecialchars($footerSlotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('卡片底部'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-action,builder-component"
         data-wslot-multiple="true">
        <?php if ($footer !== ''): ?>
            <?= $footer ?>
        <?php elseif ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder compact"><?= __('拖入按钮或操作区') ?></div>
        <?php endif; ?>
    </div>
</section>
