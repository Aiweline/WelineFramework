<?php
/**
 * 组件：Badge
 *
 * @meta.name {default="Badge 徽章",name="Badge 徽章",description="用于页面搭建的状态徽章"}
 * @meta.description {default="用于页面搭建的状态徽章",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.text {default="已启用",name="文字",description="徽章文字"}
 * @param.type {default="primary",name="类型",description="primary/success/warning/danger/info/secondary"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$text = (string)($this->getData('text') ?? $this->getData('meta.text') ?? '已启用');
$type = (string)($this->getData('type') ?? $this->getData('meta.type') ?? 'primary');
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$allowedTypes = ['primary', 'success', 'warning', 'danger', 'info', 'secondary'];
if (!in_array($type, $allowedTypes, true)) {
    $type = 'primary';
}
$badgeClass = trim('badge bg-' . $type . ' w-builder-badge ' . $class);
?>
<span class="<?= htmlspecialchars($badgeClass, ENT_QUOTES, 'UTF-8') ?>">
    <?= htmlspecialchars($text, ENT_QUOTES, 'UTF-8') ?>
</span>
