<?php
/**
 * 组件：Button
 *
 * @meta.name {default="Button 按钮",name="Button 按钮",description="用于页面搭建的操作按钮"}
 * @meta.description {default="用于页面搭建的操作按钮",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-action"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.text {default="提交",name="文字",description="按钮文字"}
 * @param.type {default="primary",name="类型",description="primary/secondary/success/warning/danger/info"}
 * @param.html_type {default="button",name="HTML 类型",description="button/submit/reset"}
 * @param.href {default="",name="链接",description="为空时渲染 button"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$text = (string)($this->getData('text') ?? $this->getData('meta.text') ?? '提交');
$type = (string)($this->getData('type') ?? $this->getData('meta.type') ?? 'primary');
$htmlType = (string)($this->getData('html_type') ?? $this->getData('meta.html_type') ?? 'button');
$href = trim((string)($this->getData('href') ?? $this->getData('meta.href') ?? ''));
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$allowedTypes = ['primary', 'secondary', 'success', 'warning', 'danger', 'info'];
if (!in_array($type, $allowedTypes, true)) {
    $type = 'primary';
}
if (!in_array($htmlType, ['button', 'submit', 'reset'], true)) {
    $htmlType = 'button';
}
$buttonClass = trim('btn btn-' . $type . ' w-builder-button ' . $class);
$safeHref = '';
if ($href !== '') {
    $compactHref = strtolower(preg_replace('/[\x00-\x20\x7f]+/', '', html_entity_decode($href, ENT_QUOTES, 'UTF-8')));
    if (!str_starts_with($compactHref, 'javascript:') && !str_starts_with($compactHref, 'vbscript:') && !str_starts_with($compactHref, 'data:')) {
        $safeHref = $href;
    }
}
?>
<?php if ($safeHref !== ''): ?>
    <a class="<?= htmlspecialchars($buttonClass, ENT_QUOTES, 'UTF-8') ?>" href="<?= htmlspecialchars($safeHref, ENT_QUOTES, 'UTF-8') ?>">
        <?= htmlspecialchars($text, ENT_QUOTES, 'UTF-8') ?>
    </a>
<?php else: ?>
    <button class="<?= htmlspecialchars($buttonClass, ENT_QUOTES, 'UTF-8') ?>" type="<?= htmlspecialchars($htmlType, ENT_QUOTES, 'UTF-8') ?>">
        <?= htmlspecialchars($text, ENT_QUOTES, 'UTF-8') ?>
    </button>
<?php endif; ?>
