<?php
/**
 * 组件：Section
 *
 * @meta.name {default="Section 区块",name="Section 区块",description="可嵌套组件的页面区块"}
 * @meta.description {default="可嵌套组件的页面区块",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"content":{"id":"container:{layout_id}","name":"区块内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true}}
 * @param.title {default="区块标题",name="标题",description="区块标题"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? '区块标题');
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'container:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<section class="w-builder-section">
    <?php if ($title !== ''): ?>
        <h2><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h2>
    <?php endif; ?>
    <div data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('区块内容'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
         data-wslot-multiple="true">
        <?php if ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入内容组件') ?></div>
        <?php endif; ?>
    </div>
</section>
