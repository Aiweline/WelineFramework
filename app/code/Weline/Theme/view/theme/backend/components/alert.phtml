<?php
/**
 * 组件：Alert
 *
 * @meta.name {default="Alert 提示",name="Alert 提示",description="用于页面搭建的提示信息块"}
 * @meta.description {default="用于页面搭建的提示信息块",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.type {default="info",name="类型",description="success/warning/danger/info"}
 * @param.title {default="",name="标题",description="提示标题"}
 * @param.message {default="这是一条状态提示信息。",name="内容",description="提示正文"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$type = (string)($this->getData('type') ?? $this->getData('meta.type') ?? 'info');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? '');
$message = (string)($this->getData('message') ?? $this->getData('meta.message') ?? '这是一条状态提示信息。');
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$allowedTypes = ['success', 'warning', 'danger', 'info'];
if (!in_array($type, $allowedTypes, true)) {
    $type = 'info';
}
$alertClass = trim('alert alert-' . $type . ' w-builder-alert ' . $class);
?>
<div class="<?= htmlspecialchars($alertClass, ENT_QUOTES, 'UTF-8') ?>" role="alert">
    <?php if ($title !== ''): ?>
        <strong><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></strong>
    <?php endif; ?>
    <span><?= htmlspecialchars($message, ENT_QUOTES, 'UTF-8') ?></span>
</div>
