<?php
/**
 * 组件：Tabs
 *
 * @meta.name {default="Tabs 标签页",name="Tabs 标签页",description="可嵌套内容的标签页容器"}
 * @meta.description {default="可嵌套内容的标签页容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"panel":{"id":"tabs-panel:{layout_id}:{tab_key}","name":"标签页内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true}}
 * @param.tabs {default=["概览","详情"],name="标签",description="标签数组或 key=>label 数组"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$tabs = $this->getData('tabs') ?? $this->getData('meta.tabs') ?? ['概览', '详情'];
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
if (!is_array($tabs) || $tabs === []) {
    $tabs = ['概览', '详情'];
}
$normalizedTabs = [];
foreach ($tabs as $key => $label) {
    if (is_array($label)) {
        $tabKey = preg_replace('/[^a-zA-Z0-9_-]+/', '-', (string)($label['key'] ?? $key));
        $tabLabel = (string)($label['label'] ?? $label['name'] ?? $tabKey);
    } else {
        $tabKey = is_string($key) ? preg_replace('/[^a-zA-Z0-9_-]+/', '-', $key) : 'tab-' . (count($normalizedTabs) + 1);
        $tabLabel = (string)$label;
    }
    $normalizedTabs[] = ['key' => trim($tabKey, '-') ?: 'tab-' . (count($normalizedTabs) + 1), 'label' => $tabLabel];
}
?>
<section class="w-builder-tabs">
    <nav class="nav nav-tabs" role="tablist">
        <?php foreach ($normalizedTabs as $index => $tab): ?>
            <button class="nav-link<?= $index === 0 ? ' active' : '' ?>" type="button" role="tab">
                <?= htmlspecialchars($tab['label'], ENT_QUOTES, 'UTF-8') ?>
            </button>
        <?php endforeach; ?>
    </nav>
    <div class="tab-content w-builder-tabs-content">
        <?php foreach ($normalizedTabs as $index => $tab): ?>
            <?php $panelSlotId = 'tabs-panel:' . ($layoutId !== '' ? $layoutId : 'preview') . ':' . $tab['key']; ?>
            <section class="tab-pane<?= $index === 0 ? ' active show' : '' ?>"
                     data-wslot="<?= htmlspecialchars($panelSlotId, ENT_QUOTES, 'UTF-8') ?>"
                     data-wslot-name="<?= htmlspecialchars($tab['label'], ENT_QUOTES, 'UTF-8') ?>"
                     data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
                     data-wslot-multiple="true">
                <?php if ($editorMode): ?>
                    <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入标签页内容') ?></div>
                <?php endif; ?>
            </section>
        <?php endforeach; ?>
    </div>
</section>
