<?php
/**
 * 组件：Loading
 * 
 * 后台全局加载指示器组件
 * 字段
 * @info description 描述：后台全局加载指示器组件
 * @info name 名称：Loading加载组件
 * @param id 元素ID（默认：loading）
 * @param class 额外CSS类
 * @param type 加载器类型（默认：1，可扩展其他类型）
 * @param text 加载文字提示
 * @param overlay 是否显示遮罩层（默认：true）
 * @param autoHide 页面加载后是否自动隐藏（默认：true）
 */
$id = $this->getData('id') ?? 'loading';
$class = $this->getData('class') ?? '';
$type = $this->getData('type') ?? 1;
$text = $this->getData('text') ?? '';
$overlay = $this->getData('overlay') ?? true;
$autoHide = $this->getData('autoHide') ?? true;

// 构建CSS类
$sectionClass = 'loading-component';
if ($class) {
    $sectionClass .= ' ' . htmlspecialchars($class);
}
?>
<!--Loading-->
<section id="<?= htmlspecialchars($id) ?>" class="<?= $sectionClass ?>" style="display: none;">
    <?php if ($overlay): ?>
        <div class="loading-overlay"></div>
    <?php endif; ?>
    <div class="loading-content">
        <div class="loader loader-<?= htmlspecialchars($type) ?>">
            <div class="loader-outter"></div>
            <div class="loader-inner"></div>
        </div>
        <?php if ($text): ?>
            <div class="loading-text"><?= htmlspecialchars($text) ?></div>
        <?php endif; ?>
    </div>
</section>
<script>
    // 全局加载函数
    function showLoading(loadingId) {
        loadingId = loadingId || '<?= htmlspecialchars($id) ?>';
        $('#' + loadingId).show();
    }

    function hideLoading(loadingId) {
        loadingId = loadingId || '<?= htmlspecialchars($id) ?>';
        $('#' + loadingId).hide();
    }

    <?php if ($autoHide): ?>
    $(function () {
        $('#<?= htmlspecialchars($id) ?>').hide();
    });
    <?php endif; ?>
</script>

