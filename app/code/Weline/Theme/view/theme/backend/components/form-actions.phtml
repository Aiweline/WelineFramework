<?php
/**
 * 组件：Form Actions
 *
 * @meta.name {default="Form Actions 操作区",name="Form Actions 操作区",description="可接收按钮的操作区"}
 * @meta.description {default="可接收按钮的操作区",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-action"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"actions":{"id":"form-actions-items:{layout_id}","name":"操作按钮","accept":["builder-action"],"multiple":true}}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'form-actions-items:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<div class="w-builder-actions d-flex gap-2 align-items-center"
     data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-name="<?= htmlspecialchars(__('操作按钮'), ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-accept="builder-action"
     data-wslot-multiple="true">
    <?php if ($editorMode): ?>
        <div class="w-builder-slot-placeholder slot-placeholder compact"><?= __('拖入按钮') ?></div>
    <?php endif; ?>
</div>
