<?php
/**
 * 表单部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {data-form}
 * @widget.name {数据表单}
 * @widget.description {后台通用表单部件，支持多种输入类型、验证、分组}
 * @widget.type {data}
 * @widget.area {backend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["default", "dashboard"]}
 * 
 * @param title {default="表单",type="string",label="表单标题"}
 * @param action {default="",type="string",label="提交地址"}
 * @param method {default="POST",type="select",label="提交方法",options={GET:"GET",POST:"POST",PUT:"PUT",DELETE:"DELETE"}}
 * @param fields {default=[],type="array",label="字段配置"}
 * @param groups {default=[],type="array",label="字段分组"}
 * @param submit_text {default="保存",type="string",label="提交按钮文字"}
 * @param cancel_text {default="取消",type="string",label="取消按钮文字"}
 * @param cancel_url {default="",type="string",label="取消跳转地址"}
 * @param show_cancel {default=true,type="bool",label="显示取消按钮"}
 * @param ajax {default=false,type="bool",label="AJAX提交"}
 * @param layout {default="vertical",type="select",label="布局",options={vertical:"垂直",horizontal:"水平",inline:"内联"}}
 */

$title = $this->getData('title') ?? '';
$action = $this->getData('action') ?? '';
$method = strtoupper($this->getData('method') ?? 'POST');
$fields = $this->getData('fields') ?? [];
$groups = $this->getData('groups') ?? [];
$submitText = $this->getData('submit_text') ?? __('保存');
$cancelText = $this->getData('cancel_text') ?? __('取消');
$cancelUrl = $this->getData('cancel_url') ?? '';
$showCancel = (bool)($this->getData('show_cancel') ?? true);
$ajax = (bool)($this->getData('ajax') ?? false);
$layout = $this->getData('layout') ?? 'vertical';
$formData = $this->getData('form_data') ?? [];

$widgetId = 'backend-data-form-' . uniqid();

$renderField = function($field) use ($formData, $layout) {
    $name = $field['name'] ?? '';
    $type = $field['type'] ?? 'text';
    $label = $field['label'] ?? $name;
    $placeholder = $field['placeholder'] ?? '';
    $required = !empty($field['required']);
    $disabled = !empty($field['disabled']);
    $readonly = !empty($field['readonly']);
    $hint = $field['hint'] ?? '';
    $options = $field['options'] ?? [];
    $value = $formData[$name] ?? ($field['default'] ?? '');
    $class = $field['class'] ?? '';
    $attrs = $field['attrs'] ?? [];
    
    $fieldId = 'field-' . $name . '-' . uniqid();
    $isHorizontal = $layout === 'horizontal';
    
    $attrString = '';
    foreach ($attrs as $k => $v) {
        $attrString .= ' ' . htmlspecialchars($k) . '="' . htmlspecialchars($v) . '"';
    }
    
    ob_start();
    ?>
    <div class="backend-form-group <?= $isHorizontal ? 'backend-form-group--horizontal' : '' ?> <?= $required ? 'backend-form-group--required' : '' ?>">
        <?php if ($label): ?>
        <label class="backend-form-label" for="<?= $fieldId ?>">
            <?= htmlspecialchars($label) ?>
            <?php if ($required): ?><span class="backend-form-required">*</span><?php endif; ?>
        </label>
        <?php endif; ?>
        
        <div class="backend-form-control-wrapper">
            <?php 
            switch ($type):
                case 'textarea': ?>
                    <textarea 
                        id="<?= $fieldId ?>"
                        name="<?= htmlspecialchars($name) ?>"
                        class="backend-form-control backend-form-textarea <?= htmlspecialchars($class) ?>"
                        placeholder="<?= htmlspecialchars($placeholder) ?>"
                        <?= $required ? 'required' : '' ?>
                        <?= $disabled ? 'disabled' : '' ?>
                        <?= $readonly ? 'readonly' : '' ?>
                        <?= $attrString ?>
                    ><?= htmlspecialchars((string)$value) ?></textarea>
                <?php break;
                
                case 'select': ?>
                    <select 
                        id="<?= $fieldId ?>"
                        name="<?= htmlspecialchars($name) ?>"
                        class="backend-form-control backend-form-select <?= htmlspecialchars($class) ?>"
                        <?= $required ? 'required' : '' ?>
                        <?= $disabled ? 'disabled' : '' ?>
                        <?= $attrString ?>
                    >
                        <?php if ($placeholder): ?>
                        <option value=""><?= htmlspecialchars($placeholder) ?></option>
                        <?php endif; ?>
                        <?php foreach ($options as $optValue => $optLabel): ?>
                        <option value="<?= htmlspecialchars((string)$optValue) ?>" <?= $value == $optValue ? 'selected' : '' ?>>
                            <?= htmlspecialchars($optLabel) ?>
                        </option>
                        <?php endforeach; ?>
                    </select>
                <?php break;
                
                case 'checkbox': ?>
                    <label class="backend-form-checkbox">
                        <input 
                            type="checkbox"
                            id="<?= $fieldId ?>"
                            name="<?= htmlspecialchars($name) ?>"
                            value="1"
                            <?= $value ? 'checked' : '' ?>
                            <?= $disabled ? 'disabled' : '' ?>
                            <?= $attrString ?>
                        >
                        <span class="backend-form-checkbox-text"><?= htmlspecialchars($placeholder ?: $label) ?></span>
                    </label>
                <?php break;
                
                case 'radio': ?>
                    <div class="backend-form-radio-group">
                        <?php foreach ($options as $optValue => $optLabel): ?>
                        <label class="backend-form-radio">
                            <input 
                                type="radio"
                                name="<?= htmlspecialchars($name) ?>"
                                value="<?= htmlspecialchars((string)$optValue) ?>"
                                <?= $value == $optValue ? 'checked' : '' ?>
                                <?= $disabled ? 'disabled' : '' ?>
                            >
                            <span class="backend-form-radio-text"><?= htmlspecialchars($optLabel) ?></span>
                        </label>
                        <?php endforeach; ?>
                    </div>
                <?php break;
                
                case 'file': ?>
                    <input 
                        type="file"
                        id="<?= $fieldId ?>"
                        name="<?= htmlspecialchars($name) ?>"
                        class="backend-form-control backend-form-file <?= htmlspecialchars($class) ?>"
                        <?= $required ? 'required' : '' ?>
                        <?= $disabled ? 'disabled' : '' ?>
                        <?= $attrString ?>
                    >
                <?php break;
                
                case 'hidden': ?>
                    <input 
                        type="hidden"
                        name="<?= htmlspecialchars($name) ?>"
                        value="<?= htmlspecialchars((string)$value) ?>"
                    >
                <?php break;
                
                case 'number':
                case 'email':
                case 'password':
                case 'url':
                case 'date':
                case 'datetime-local':
                case 'time':
                case 'color':
                default: ?>
                    <input 
                        type="<?= htmlspecialchars($type === 'text' || !in_array($type, ['number', 'email', 'password', 'url', 'date', 'datetime-local', 'time', 'color']) ? 'text' : $type) ?>"
                        id="<?= $fieldId ?>"
                        name="<?= htmlspecialchars($name) ?>"
                        value="<?= htmlspecialchars((string)$value) ?>"
                        class="backend-form-control <?= htmlspecialchars($class) ?>"
                        placeholder="<?= htmlspecialchars($placeholder) ?>"
                        <?= $required ? 'required' : '' ?>
                        <?= $disabled ? 'disabled' : '' ?>
                        <?= $readonly ? 'readonly' : '' ?>
                        <?= $attrString ?>
                    >
                <?php break;
            endswitch;
            ?>
            
            <?php if ($hint): ?>
            <div class="backend-form-hint"><?= htmlspecialchars($hint) ?></div>
            <?php endif; ?>
            
            <div class="backend-form-error" data-error-for="<?= htmlspecialchars($name) ?>"></div>
        </div>
    </div>
    <?php
    return ob_get_clean();
};
?>

<div class="backend-data-form-container" id="<?= $widgetId ?>">
    <?php if ($title): ?>
    <div class="backend-data-form-header">
        <h4 class="backend-data-form-title"><?= htmlspecialchars($title) ?></h4>
    </div>
    <?php endif; ?>
    
    <form class="backend-data-form backend-data-form--<?= htmlspecialchars($layout) ?>" 
          action="<?= htmlspecialchars($action) ?>" 
          method="<?= $method === 'GET' ? 'GET' : 'POST' ?>"
          <?= $ajax ? 'data-ajax-form' : '' ?>>
        
        <csrf/>
        
        <?php if ($method !== 'GET' && $method !== 'POST'): ?>
        <input type="hidden" name="_method" value="<?= htmlspecialchars($method) ?>">
        <?php endif; ?>
        
        <div class="backend-data-form-body">
            <?php if (!empty($groups)): ?>
                <?php foreach ($groups as $group): 
                    $groupLabel = $group['label'] ?? '';
                    $groupFields = $group['fields'] ?? [];
                    $groupCollapsible = !empty($group['collapsible']);
                    $groupCollapsed = !empty($group['collapsed']);
                ?>
                <fieldset class="backend-form-fieldset <?= $groupCollapsible ? 'backend-form-fieldset--collapsible' : '' ?> <?= $groupCollapsed ? 'backend-form-fieldset--collapsed' : '' ?>">
                    <?php if ($groupLabel): ?>
                    <legend class="backend-form-legend" <?= $groupCollapsible ? 'data-toggle-fieldset' : '' ?>>
                        <?= htmlspecialchars($groupLabel) ?>
                        <?php if ($groupCollapsible): ?>
                        <i class="ri-arrow-down-s-line backend-form-fieldset-icon"></i>
                        <?php endif; ?>
                    </legend>
                    <?php endif; ?>
                    
                    <div class="backend-form-fieldset-content">
                        <?php foreach ($groupFields as $fieldName): 
                            foreach ($fields as $field) {
                                if (($field['name'] ?? '') === $fieldName) {
                                    echo $renderField($field);
                                    break;
                                }
                            }
                        endforeach; ?>
                    </div>
                </fieldset>
                <?php endforeach; ?>
            <?php else: ?>
                <?php foreach ($fields as $field): 
                    if (($field['type'] ?? '') !== 'hidden'):
                        echo $renderField($field);
                    endif;
                endforeach; ?>
            <?php endif; ?>
            
            <?php foreach ($fields as $field): 
                if (($field['type'] ?? '') === 'hidden'):
                    echo $renderField($field);
                endif;
            endforeach; ?>
        </div>
        
        <div class="backend-data-form-footer">
            <button type="submit" class="backend-form-btn backend-form-btn--primary">
                <i class="ri-save-line"></i>
                <?= htmlspecialchars($submitText) ?>
            </button>
            
            <?php if ($showCancel): ?>
            <a href="<?= htmlspecialchars($cancelUrl) ?>" class="backend-form-btn backend-form-btn--secondary">
                <?= htmlspecialchars($cancelText) ?>
            </a>
            <?php endif; ?>
        </div>
    </form>
</div>

<style>
