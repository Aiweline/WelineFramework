<?php
/**
 * 数据列表部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {data-list}
 * @widget.name {数据列表}
 * @widget.description {后台通用数据列表部件，支持分页、搜索、批量操作}
 * @widget.type {data}
 * @widget.area {backend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["default", "dashboard"]}
 * 
 * @param title {default="数据列表",type="string",label="列表标题"}
 * @param columns {default=[],type="array",label="列配置"}
 * @param data {default=[],type="array",label="数据源"}
 * @param show_search {default=true,type="bool",label="显示搜索"}
 * @param show_pagination {default=true,type="bool",label="显示分页"}
 * @param show_batch_actions {default=false,type="bool",label="显示批量操作"}
 * @param empty_text {default="暂无数据",type="string",label="空数据提示"}
 * @param striped {default=true,type="bool",label="斑马纹"}
 * @param hover {default=true,type="bool",label="悬停高亮"}
 * @param bordered {default=false,type="bool",label="显示边框"}
 */

$title = $this->getData('title') ?? __('数据列表');
$columns = $this->getData('columns') ?? [];
$data = $this->getData('data') ?? [];
$showSearch = (bool)($this->getData('show_search') ?? true);
$showPagination = (bool)($this->getData('show_pagination') ?? true);
$showBatchActions = (bool)($this->getData('show_batch_actions') ?? false);
$emptyText = $this->getData('empty_text') ?? __('暂无数据');
$striped = (bool)($this->getData('striped') ?? true);
$hover = (bool)($this->getData('hover') ?? true);
$bordered = (bool)($this->getData('bordered') ?? false);

$currentPage = (int)($this->getData('current_page') ?? 1);
$totalPages = (int)($this->getData('total_pages') ?? 1);
$totalCount = (int)($this->getData('total_count') ?? count($data));

$widgetId = 'backend-data-list-' . uniqid();

$tableClasses = ['backend-data-list-table'];
if ($striped) $tableClasses[] = 'backend-data-list-table--striped';
if ($hover) $tableClasses[] = 'backend-data-list-table--hover';
if ($bordered) $tableClasses[] = 'backend-data-list-table--bordered';
?>

<div class="backend-data-list" id="<?= $widgetId ?>">
    <!-- 列表头部：标题、搜索、操作按钮 -->
    <div class="backend-data-list-header">
        <div class="backend-data-list-title">
            <h4><?= htmlspecialchars($title) ?></h4>
            <span class="backend-data-list-count"><?= __('共 %{1} 条', $totalCount) ?></span>
        </div>
        
        <div class="backend-data-list-actions">
            <?php if ($showSearch): ?>
            <div class="backend-data-list-search">
                <input type="text" 
                       class="backend-data-list-search-input" 
                       placeholder="<?= __('搜索...') ?>"
                       data-search-input>
                <i class="ri-search-line backend-data-list-search-icon"></i>
            </div>
            <?php endif; ?>
            
            <!-- 操作按钮插槽 -->
            <div class="backend-data-list-toolbar">
                <?= $this->getData('toolbar_html') ?? '' ?>
            </div>
        </div>
    </div>
    
    <?php if ($showBatchActions): ?>
    <!-- 批量操作栏 -->
    <div class="backend-data-list-batch-bar" style="display: none;" data-batch-bar>
        <span class="backend-data-list-batch-info">
            <lang>已选择</lang> <span data-selected-count>0</span> <lang>项</lang>
        </span>
        <div class="backend-data-list-batch-actions">
            <?= $this->getData('batch_actions_html') ?? '' ?>
        </div>
        <button type="button" class="backend-data-list-batch-cancel" data-clear-selection>
            <lang>取消选择</lang>
        </button>
    </div>
    <?php endif; ?>
    
    <!-- 表格容器 -->
    <div class="backend-data-list-body">
        <?php if (empty($columns)): ?>
        <div class="backend-data-list-empty">
            <i class="ri-table-line"></i>
            <p><lang>请配置列信息</lang></p>
        </div>
        <?php elseif (empty($data)): ?>
        <div class="backend-data-list-empty">
            <i class="ri-inbox-line"></i>
            <p><?= htmlspecialchars($emptyText) ?></p>
        </div>
        <?php else: ?>
        <table class="<?= implode(' ', $tableClasses) ?>">
            <thead>
                <tr>
                    <?php if ($showBatchActions): ?>
                    <th class="backend-data-list-checkbox-col">
                        <input type="checkbox" data-select-all>
                    </th>
                    <?php endif; ?>
                    <?php foreach ($columns as $column): ?>
                    <th class="<?= htmlspecialchars($column['class'] ?? '') ?>" 
                        style="<?= htmlspecialchars($column['style'] ?? '') ?>">
                        <?= htmlspecialchars($column['label'] ?? $column['field'] ?? '') ?>
                        <?php if (!empty($column['sortable'])): ?>
                        <i class="ri-arrow-up-down-line backend-data-list-sort-icon" 
                           data-sort-field="<?= htmlspecialchars($column['field'] ?? '') ?>"></i>
                        <?php endif; ?>
                    </th>
                    <?php endforeach; ?>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($data as $index => $row): ?>
                <tr data-row-id="<?= htmlspecialchars($row['id'] ?? $index) ?>">
                    <?php if ($showBatchActions): ?>
                    <td class="backend-data-list-checkbox-col">
                        <input type="checkbox" 
                               data-row-checkbox 
                               value="<?= htmlspecialchars($row['id'] ?? $index) ?>">
                    </td>
                    <?php endif; ?>
                    <?php foreach ($columns as $column): 
                        $field = $column['field'] ?? '';
                        $value = $row[$field] ?? '';
                        $renderer = $column['renderer'] ?? null;
                    ?>
                    <td class="<?= htmlspecialchars($column['class'] ?? '') ?>">
                        <?php if ($renderer && is_callable($renderer)): ?>
                            <?= $renderer($value, $row, $column) ?>
                        <?php else: ?>
                            <?= htmlspecialchars((string)$value) ?>
                        <?php endif; ?>
                    </td>
                    <?php endforeach; ?>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
        <?php endif; ?>
    </div>
    
    <?php if ($showPagination && $totalPages > 1): ?>
    <!-- 分页 -->
    <div class="backend-data-list-footer">
        <div class="backend-data-list-pagination">
            <button type="button" 
                    class="backend-data-list-page-btn" 
                    <?= $currentPage <= 1 ? 'disabled' : '' ?>
                    data-page="<?= $currentPage - 1 ?>">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            
            <span class="backend-data-list-page-info">
                <?= $currentPage ?> / <?= $totalPages ?>
            </span>
            
            <button type="button" 
                    class="backend-data-list-page-btn" 
                    <?= $currentPage >= $totalPages ? 'disabled' : '' ?>
                    data-page="<?= $currentPage + 1 ?>">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        </div>
    </div>
    <?php endif; ?>
</div>

