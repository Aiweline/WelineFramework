<script>
// Backend Head初始化脚本
(function() {
    'use strict';
    
    // 后端主题配置增强
    if (window.__WelineThemeConfig) {
        // 添加后端主题特定配置
        window.__WelineThemeConfig.backend = {
            primaryColor: '#556ee6',
            secondaryColor: '#6c757d',
            successColor: '#34c38f',
            dangerColor: '#f46a6a',
            warningColor: '#f1b44c',
            infoColor: '#50a5f1'
        };
    }
    
    // 后台不预取站点根路径：根路径为前台首页，后台用户很少从后台跳转到前台首页，预取会徒增每次页面的一个 / 请求

    // 监听来自Visual Editor的postMessage (Live Preview支持)
    window.addEventListener('message', function(event) {
        if (event.data && event.data.type === 'WELINE_THEME_UPDATE') {
            const cssVars = event.data.cssVars || {};
            const root = document.documentElement;
            for (const [varName, value] of Object.entries(cssVars)) {
                root.style.setProperty(varName, value);
            }
            console.log('[Theme] Live preview updated:', Object.keys(cssVars).length, 'variables');
        }
    });
})();
</script>