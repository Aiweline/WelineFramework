<!DOCTYPE html>
<html lang="@hook(Weline_Theme::frontend::layouts::base::html-lang)">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body>
    @template(Weline_Frontend::templates/public/header.phtml)
    
    <main class="cart-empty-main <?= htmlspecialchars($meta['class'] ?? '') ?>" id="cart-empty-main" data-layout="cart_empty">
        <div class="cart-empty-container">
            <div class="cart-empty-content">
                <div class="cart-empty-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <h2 class="cart-empty-title"><?= __('购物车是空的') ?></h2>
                <p class="cart-empty-message"><?= htmlspecialchars($meta['message'] ?? __('您的购物车是空的')) ?></p>
                <a href="<?= htmlspecialchars($meta['continueShopping'] ?? '/') ?>" class="btn btn-primary continue-shopping-btn">
                    <?= __('继续购物') ?>
                </a>
            </div>
        </div>
    </main>
    
    @template(Weline_Frontend::templates/public/footer.phtml)
