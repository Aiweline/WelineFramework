<!--
布局：个人中心 - 订单列表布局

订单列表页面布局，适合表格展示
字段
@meta.name {default="个人中心订单列表布局",name="个人中心订单列表布局",description="个人中心订单列表布局，用于描述布局的名称"}
@meta.description {default="订单列表页面布局，适合表格展示",name="订单列表页面布局，适合表格展示",description="订单列表页面布局，适合表格展示，用于描述布局的用途"}
@preview.login {default=1,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录，0不需要登录，1需要登录，这个不是元素据，是预览系统判断是否需要自动登录的。"}
@login {default=1,option={0:不需要登录,1:需要登录},name="是否需要登录",description="个人中心的订单列表布局，需要登录才能访问。"}
@param title {default="我的订单",name="页面标题",description="页面标题，用于设置页面标题"}
@param content {default="",name="主要内容（HTML字符串）",description="主要内容（HTML字符串），用于设置页面内容"}
@param filters {default="",name="筛选器（订单状态筛选等）",description="筛选器（订单状态筛选等），用于设置订单筛选器"}
@param class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}

参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
-->
<!DOCTYPE html>
<html lang="{{htmlLang}}" dir="{{htmlDir}}" data-local="{{lang_local}}" data-lang="{{lang}}" data-dir="{{htmlDir}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::account::head-after</w:hook>
<style>
.account-orders {
    display: flex;
    min-height: calc(100vh - var(--header-height));
    background: var(--weline-layout-surface-secondary);
}

.account-orders__sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    background: var(--weline-layout-surface-primary);
    border-right: var(--weline-theme-border-width) var(--weline-theme-border-style) var(--weline-theme-border-color-subtle);
    padding: var(--weline-layout-spacing-lg);
    position: sticky;
    top: var(--header-height);
    height: calc(100vh - var(--header-height));
    overflow-y: auto;
}

.account-orders__main {
    flex: 1;
    padding: var(--weline-layout-spacing-lg);
    display: flex;
    justify-content: center;
}

.account-orders__container {
    width: 100%;
    max-width: var(--weline-layout-content-max-width);
}

.account-orders__filters {
    margin-bottom: var(--weline-layout-spacing-lg);
}

.account-orders__list {
    width: 100%;
}

@media (max-width: 768px) {
    .account-orders {
        flex-direction: column;
        min-height: auto;
    }

    .account-orders__sidebar {
        width: 100%;
        height: auto;
        position: static;
        border-right: none;
        border-bottom: var(--weline-theme-border-width) var(--weline-theme-border-style) var(--weline-theme-border-color-subtle);
        padding: var(--weline-layout-spacing-md);
    }

    .account-orders__main {
        padding: var(--weline-layout-spacing-md);
    }
}
</style>
</head>
<body>
    <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
    <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>

    <div class="account-orders {{meta.class}}" id="account-orders" data-layout="account_orders">
        <aside class="account-orders__sidebar">
            <w:slot id="account-orders-sidebar"
                    name="订单页侧边栏"
                    accept="layout-account-orders-sidebar,layout-account-sidebar,account-sidebar,sidebar,account-nav"
                    multiple="true"
                    position="sidebar">
                <w:hook>
                    Weline_Theme::frontend::layouts::account_orders::sidebar
                    <else/>
                <nav class="weline-card">
                    <strong><?= __('账户中心') ?></strong>
                    <p class="weline-muted"><?= __('这里预留账户导航 slot，可由会员模块接入真实菜单。') ?></p>
                </nav>
                </w:hook>
            </w:slot>
        </aside>

        <main class="account-orders__main" id="account-orders-content" data-layout="account_orders_content">
            <div class="account-orders__container">
                <w:slot id="content"
                        name="内容区"
                        accept="layout-account-content,layout-account-orders-content,layout-default-content,content,account-orders,account-content"
                        reject="header,footer"
                        multiple="true"
                        position="content"
                        class="account-orders__content-root-slot">
                    <w:slot id="account-orders-filters"
                        name="订单筛选区"
                        accept="layout-account-orders-filters,account-order-filters,filters"
                        multiple="true"
                        position="content"
                        class="account-orders__filters">
                    <if condition="meta.filters">
                        {{meta.filters}}
                    </if>
                    </w:slot>

                    <w:slot id="account-orders-content"
                        name="订单列表内容"
                        accept="layout-account-orders-content,account-orders,account-content,content"
                        reject="header,footer"
                        multiple="true"
                        position="content"
                        class="account-orders__list">
                    <if condition="meta.content">
                        {{meta.content}}
                    <else/>
                        <section class="weline-layout-surface">
                            <h1><?= __('我的订单') ?></h1>
                            <p class="weline-muted"><?= __('这里是订单列表的默认占位。订单模块接入后，会替换为真实订单表格、状态和操作入口。') ?></p>
                        </section>
                    </if>
                    </w:slot>
                </w:slot>
            </div>
        </main>
    </div>

    <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
    <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
</body>
</html>
