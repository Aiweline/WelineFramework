<?php
/**
 * Default checkout layout.
 *
 * This layout owns only the global page chrome and content hook. Checkout
 * business logic and one-page form rendering must stay in checkout modules.
 */
$meta = $this->getData('meta') ?? [];
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::checkout::head-after</w:hook>
</head>
<body>
<w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
<w:hook>Weline_Theme::frontend::layouts::checkout::body-start</w:hook>

<div class="weline-page-wrapper">
    <if condition="meta.showHeader">
        <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::checkout::header-before</w:hook>
        <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
        <w:hook>Weline_Theme::frontend::layouts::checkout::header-after</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
    </if>

    <div class="weline-main-content">
        <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::checkout::content-before</w:hook>

        <main class="checkout-main <?= htmlspecialchars($meta['class'] ?? '') ?>" id="checkout-main" data-layout="checkout">
            <w:hook>Weline_Theme::frontend::layouts::checkout::main-before</w:hook>
            <w:slot id="content"
                    name="内容区"
                    accept="layout-checkout-content,layout-default-content,content,checkout-content,checkout-form,order-summary,trust-badges"
                    reject="header,footer"
                    multiple="true"
                    position="content"
                    class="checkout-main__content-root-slot">
            <w:slot id="checkout-content"
                    name="结算主内容"
                    accept="layout-checkout-content,checkout-content,content"
                    reject="header,footer"
                    multiple="true"
                    position="content"
                    class="checkout-main__content-slot">
                <w:hook>Weline_Theme::frontend::layouts::checkout::content-before</w:hook>
                <if condition="meta.content">
                    {{meta.content}}
                    <elseif condition="content"/>
                    {{content}}
                    <elseif condition="meta.contentTemplate"/>
                    <?php echo $this->getChildHtml('content'); ?>
                </if>
                <w:hook>Weline_Theme::frontend::layouts::checkout::content-after</w:hook>
            </w:slot>
            <w:slot id="checkout-trust"
                    name="结算保障说明"
                    accept="layout-checkout-trust,trust-badges,content"
                    multiple="true"
                    position="content"
                    wrapper="section"
                    class="checkout-main__trust-slot">
                <w:hook>Weline_Theme::frontend::layouts::checkout::trust</w:hook>
            </w:slot>
            </w:slot>
            <w:hook>Weline_Theme::frontend::layouts::checkout::main-after</w:hook>
        </main>

        <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>
    </div>

    <if condition="meta.showFooter">
        <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::checkout::footer-before</w:hook>
        <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
        <w:hook>Weline_Theme::frontend::layouts::checkout::footer-after</w:hook>
        <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
    </if>
</div>

<w:hook>Weline_Theme::frontend::layouts::checkout::body-end</w:hook>
<w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>

<style>
    .weline-page-wrapper {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .weline-main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .checkout-main {
        width: 100%;
        flex: 1;
    }
</style>
</body>
</html>
