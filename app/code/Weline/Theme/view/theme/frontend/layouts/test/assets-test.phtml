<?php
/**
 * 测试布局：用于验证CSS/JS提取功能
 * 
 * 此布局文件包含内联CSS和JS，用于测试LayoutAssetsExtractor功能
 */
$layoutType = $this->getData('layoutType') ?? 'test';
$layoutOption = $this->getData('layoutOption') ?? 'assets-test';

// 确保布局信息被设置
$this->setData('layoutType', $layoutType);
