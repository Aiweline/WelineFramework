<!--
布局：个人中心 - 仪表盘（dashboard）

与首页一致：Partials 加载前台 Header/Footer，meta.showHeader / meta.showFooter 控制显隐；
中部为侧栏 + 主内容（结构与 account/default 中部相同）。

字段
@meta.name {default="个人中心仪表盘",name="个人中心仪表盘",description="个人中心仪表盘布局"}
@meta.description {default="Partials 顶栏底栏与首页同源 + 账户侧栏主内容",name="描述",description="顶栏底栏与首页一致"}
@preview.login {default=1,option={0:不需要登录,1:需要登录},name="是否需要登录",description="个人中心需登录"}
@login {default=1,option={0:不需要登录,1:需要登录},name="是否需要登录",description="个人中心需登录"}
@param.title {default="个人中心",name="页面标题",description="页面标题"}
@param.content {default="",name="主要内容（HTML字符串）",description="主要内容"}
@param.sidebar {default="",name="侧边栏内容（HTML字符串）",description="侧边栏 HTML"}
@param.sidebarCollapsed {default=false,name="侧边栏是否折叠",description="侧边栏折叠"}
@param.class {default="",name="额外CSS类",description="额外 CSS 类"}
@param.showHeader {default=true,name="是否显示header",description="是否显示顶栏（与首页布局一致）"}
@param.showFooter {default=true,name="是否显示footer",description="是否显示底栏（与首页布局一致）"}
@param.layout.leftsider {default=1,option={0:不显示,1:显示},name="显示左侧栏",description="侧栏"}
@param.layout.rightsider {default=0,option={0:不显示,1:显示},name="显示右侧栏",description="右侧栏"}

参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta
-->
<?php
$meta = $this->getData('meta') ?? [];
/*
 * Observer 会合并 theme.frontend.layouts.account 的全局 meta：后台若关闭「账户页顶栏」，
 * showHeader/showFooter 会为 false，从而压住本文件 @param 默认值，导致与首页不一致。
 * 仪表盘布局固定与首页同源展示 Partials header/footer。
 */
$meta['showHeader'] = true;
$meta['showFooter'] = true;
$this->assign('meta', $meta);
?>
