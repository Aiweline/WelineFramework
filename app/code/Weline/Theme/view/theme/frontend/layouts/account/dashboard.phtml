<body class="account-dashboard-layout">
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::account::body-start</w:hook>

    <div class="weline-page-wrapper">
        <if condition="meta.showHeader">
            <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::account::header-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
            <w:hook>Weline_Theme::frontend::layouts::account::header-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
        </if>

        <div class="weline-main-content">
            <main class="account-main-content <?= htmlspecialchars(($meta['class'] ?? '')) ?>" id="account-main-content" data-layout="account">
                <?php $accountSidebarHtml = (string)($meta['sidebar'] ?? $this->getData('sidebar') ?? ''); ?>
                <?php if (trim($accountSidebarHtml) === '' && function_exists('w_log_warning')) {
                    try {
                        $rootSidebar = $this->getData('sidebar');
                        w_log_warning('[AccountSidebar] dashboard layout sidebar empty at template render', [
                            'uri' => (string)($this->request->getServer('REQUEST_URI') ?? $this->request->getUri() ?? ''),
                            'meta_sidebar_len' => is_string($meta['sidebar'] ?? null) ? strlen(trim($meta['sidebar'])) : 0,
                            'root_sidebar_len' => is_string($rootSidebar) ? strlen(trim($rootSidebar)) : 0,
                            'meta_keys' => array_keys(is_array($meta) ? $meta : []),
                            'template_id' => spl_object_id($this),
                        ], 'account_sidebar');
                    } catch (\Throwable) {
                    }
                } ?>
                <w:slot id="account-dashboard-sidebar"
                        name="账户仪表盘侧边栏"
                        accept="layout-account-dashboard-sidebar,layout-account-sidebar,account-sidebar,sidebar,account-nav"
                        multiple="true"
                        position="sidebar">
                    <?php if (trim($accountSidebarHtml) !== ''): ?>
                        <w:hook>Weline_Theme::frontend::layouts::account::sidebar-before</w:hook>
                        <aside class="account-sidebar <?= !empty($meta['sidebarCollapsed']) ? 'collapsed' : '' ?>">
                            <?= $accountSidebarHtml ?>
                        </aside>
                        <w:hook>Weline_Theme::frontend::layouts::account::sidebar-after</w:hook>
                    <?php endif; ?>
                </w:slot>

                <div class="account-main">
                    <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
                    <w:hook>Weline_Theme::frontend::layouts::account::content-before</w:hook>
                    <w:slot id="content"
                            name="内容区"
                            accept="layout-account-content,layout-account-dashboard-content,layout-default-content,content,account-content"
                            reject="header,footer"
                            multiple="true"
                            position="content"
                            class="account-dashboard__content-root-slot">
                        <w:slot id="account-dashboard-content"
                            name="账户仪表盘主内容"
                            accept="layout-account-dashboard-content,layout-account-content,account-content,content"
                            reject="header,footer"
                            multiple="true"
                            position="content"
                            class="account-dashboard__content-slot">
                        <if condition="meta.content">
                            {{meta.content}}
                            <elseif condition="content"/>
                            {{content}}
                            <elseif condition="meta.contentTemplate"/>
                            <?php echo $this->fetch($this->getData("meta.contentTemplate")); ?>
                            <elseif condition="contentTemplate"/>
                            <?php echo $this->fetch($this->getData("contentTemplate")); ?>
                            <else/>
                            <?= $this->getChildHtml('content') ?>
                        </if>
                        </w:slot>
                    </w:slot>
                    <w:hook>Weline_Theme::frontend::layouts::account::content-after</w:hook>
                    <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>
                </div>
            </main>
        </div>

        <if condition="meta.showFooter">
            <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::account::footer-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
            <w:hook>Weline_Theme::frontend::layouts::account::footer-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
        </if>
    </div>

    <w:hook>Weline_Theme::frontend::layouts::account::body-end</w:hook>
</body>
</html>
