<?php
/**
 * Layout: default.
 *
 * A safe Theme-owned shell for generic frontend pages. Real modules can inject
 * content through hooks, slots, meta.content, content, or contentTemplate.
 *
 * @meta.name {default="Default Layout",name="Default Layout",description="Header, content, optional sidebars, footer"}
 * @param.title {default="Weline",name="Page Title",description="Page title"}
 * @param.content {default="",name="Content HTML",description="Main page content"}
 * @param.showHeader {default=true,name="Show Header",description="Whether to render header"}
 * @param.showFooter {default=true,name="Show Footer",description="Whether to render footer"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class"}
 */

$meta = $this->getData('meta') ?? [];
$class = htmlspecialchars((string)($meta['class'] ?? ''), ENT_QUOTES, 'UTF-8');
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <style data-theme-inline="layout-default">
        .theme-layout-default .default-layout__main {
            padding: clamp(26px, 4vw, 56px) 0;
        }

        .theme-layout-default .default-layout__grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 24px;
            align-items: start;
        }

        .theme-layout-default.has-left-sidebar .default-layout__grid {
            grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
        }

        .theme-layout-default.has-right-sidebar .default-layout__grid {
            grid-template-columns: minmax(0, 1fr) minmax(220px, 280px);
        }

        .theme-layout-default.has-left-sidebar.has-right-sidebar .default-layout__grid {
            grid-template-columns: minmax(180px, 240px) minmax(0, 1fr) minmax(180px, 240px);
        }

        .default-layout__content {
            min-width: 0;
        }

        .default-layout__fallback {
            display: grid;
            gap: 18px;
            padding: clamp(28px, 5vw, 56px);
        }

        .default-layout__fallback h1 {
            margin: 0;
            font-size: clamp(32px, 5vw, 54px);
            line-height: 1.05;
            letter-spacing: 0;
        }

        .default-layout__fallback p {
            max-width: 660px;
            margin: 0;
            color: var(--weline-theme-muted, #657083);
            font-size: 18px;
        }

        .default-layout__fallback-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 6px;
        }

        .default-layout__sidebar {
            min-height: 160px;
        }

        @media (max-width: 920px) {
            .theme-layout-default.has-left-sidebar .default-layout__grid,
            .theme-layout-default.has-right-sidebar .default-layout__grid,
            .theme-layout-default.has-left-sidebar.has-right-sidebar .default-layout__grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body class="theme-layout-default <?= $class ?>">
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::default::body-start</w:hook>

    <div class="weline-page-wrapper">
        <w:slot id="page-top"
                name="Page top"
                accept="layout-page-top,announcement,banner,content"
                multiple="true"
                append="true"
                position="content"
                class="default-layout__page-top">
            <w:hook>Weline_Theme::frontend::layouts::default::page-top</w:hook>
        </w:slot>

        <if condition="meta.showHeader">
            <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
            <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
        </if>

        <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-before</w:hook>
        <w:block class="Weline\Theme\Block\Partials" area="frontend" type="breadcrumb" default-option="default"/>
        <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-after</w:hook>

        <main class="weline-main-content default-layout__main" id="main-content" data-layout="default">
            <div class="weline-container">
                <w:slot id="content-before"
                        name="Content before"
                        accept="layout-content-before,layout-default-before,banner,content,container"
                        multiple="true"
                        append="true"
                        position="content"
                        class="default-layout__content-before">
                    <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
                    <w:hook>Weline_Theme::frontend::layouts::default::content-before</w:hook>
                </w:slot>

                <div class="default-layout__grid">
                    <w:slot id="sidebar-left"
                            name="Left sidebar"
                            accept="layout-sidebar,sidebar,filter,navigation,content"
                            multiple="true"
                            position="sidebar"
                            class="default-layout__sidebar default-layout__sidebar--left">
                        <w:hook>Weline_Theme::frontend::layouts::default::sidebar-left</w:hook>
                    </w:slot>

                    <w:slot id="content"
                            name="Content"
                            accept="layout-default-content,content,container,banner,carousel,product,category,faq,video"
                            reject="header,footer"
                            multiple="true"
                            position="content"
                            class="default-layout__content">
                        <w:slot id="default-content"
                                name="Default content"
                                accept="layout-default-content,content,banner,carousel,product,category,faq,video"
                                reject="header,footer"
                                multiple="true"
                                position="content"
                                class="default-layout__content-slot">
                            <w:hook>Weline_Theme::frontend::layouts::default::content<else/>
                            <if condition="meta.content">
                                {{meta.content}}
                                <elseif condition="content"/>
                                {{content}}
                                <elseif condition="meta.contentTemplate"/>
                                <?php echo $this->fetch($this->getData('meta.contentTemplate')); ?>
                                <else/>
                                <section class="weline-layout-surface default-layout__fallback">
                                    <h1><?= htmlspecialchars((string)($meta['title'] ?? __('Weline default page')), ENT_QUOTES, 'UTF-8') ?></h1>
                                    <p><?= __('This default Theme page is ready for module hooks, visual slots, and direct controller content.') ?></p>
                                    <div class="default-layout__fallback-actions">
                                        <a class="weline-button" href="/"><?= __('Go home') ?></a>
                                        <a class="weline-button weline-button--ghost" href="/contact"><?= __('Contact') ?></a>
                                    </div>
                                </section>
                            </if>
                            </w:hook>
                        </w:slot>
                    </w:slot>

                    <w:slot id="sidebar-right"
                            name="Right sidebar"
                            accept="layout-sidebar,sidebar,filter,navigation,content"
                            multiple="true"
                            position="sidebar"
                            class="default-layout__sidebar default-layout__sidebar--right">
                        <w:hook>Weline_Theme::frontend::layouts::default::sidebar-right</w:hook>
                    </w:slot>
                </div>

                <w:slot id="content-after"
                        name="Content after"
                        accept="layout-content-after,layout-default-after,banner,content,container"
                        multiple="true"
                        append="true"
                        position="content"
                        class="default-layout__content-after">
                    <w:hook>Weline_Theme::frontend::layouts::default::content-after</w:hook>
                    <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>
                </w:slot>
            </div>
        </main>

        <w:slot id="page-bottom"
                name="Page bottom"
                accept="layout-page-bottom,announcement,banner,content"
                multiple="true"
                append="true"
                position="content"
                class="default-layout__page-bottom">
            <w:hook>Weline_Theme::frontend::layouts::default::page-bottom</w:hook>
        </w:slot>

        <if condition="meta.showFooter">
            <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
            <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
        </if>
    </div>

    <w:hook>Weline_Theme::frontend::layouts::default::body-end</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
</body>
</html>
