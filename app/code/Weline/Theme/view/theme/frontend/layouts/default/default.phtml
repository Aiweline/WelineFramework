<?php
/**
 * Layout: default.
 *
 * A safe Theme-owned shell for generic frontend pages. Real modules can inject
 * content through hooks, slots, meta.content, content, or contentTemplate.
 *
 * @meta.name {default="Default Layout",name="Default Layout",description="Header, content, optional sidebars, footer"}
 * @param.title {default="Weline",name="Page Title",description="Page title"}
 * @param.content {default="",name="Content HTML",description="Main page content"}
 * @param.showHeader {default=true,name="Show Header",description="Whether to render header"}
 * @param.showFooter {default=true,name="Show Footer",description="Whether to render footer"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class"}
 */

$meta = $this->getData('meta') ?? [];
$class = htmlspecialchars((string)($meta['class'] ?? ''), ENT_QUOTES, 'UTF-8');
$rawContent = (string)($this->getData('meta.content') ?: $this->getData('content') ?: ($meta['content'] ?? ''));
$contentTemplate = (string)($this->getData('meta.contentTemplate') ?: ($meta['contentTemplate'] ?? ''));
$contentWithoutPreviewPlaceholder = trim((string)preg_replace(
    '/<div\s+class="weline-theme-preview-content"\s+data-theme-preview-content="1"\s*><\/div>/i',
    '',
    $rawContent
));
$hasRealContent = $contentWithoutPreviewPlaceholder !== '';
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" dir="{{htmlDir}}" data-local="{{lang_local}}" data-lang="{{lang}}" data-dir="{{htmlDir}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <style data-theme-inline="layout-default">
        .theme-layout-default .default-layout__main {
            padding: clamp(var(--weline-layout-spacing-lg), 4vw, var(--weline-layout-spacing-3xl)) 0;
        }

        .theme-layout-default .default-layout__grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: var(--weline-layout-spacing-lg);
            align-items: start;
        }

        .theme-layout-default.has-left-sidebar .default-layout__grid {
            grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
        }

        .theme-layout-default.has-right-sidebar .default-layout__grid {
            grid-template-columns: minmax(0, 1fr) minmax(220px, 280px);
        }

        .theme-layout-default.has-left-sidebar.has-right-sidebar .default-layout__grid {
            grid-template-columns: minmax(180px, 240px) minmax(0, 1fr) minmax(180px, 240px);
        }

        .default-layout__content {
            min-width: 0;
        }

        .default-layout__fallback {
            display: grid;
            gap: var(--weline-layout-spacing-lg);
            padding: clamp(var(--weline-layout-spacing-xl), 5vw, var(--weline-layout-spacing-3xl));
        }

        .default-layout__fallback h1 {
            margin: 0;
            font-size: clamp(var(--weline-layout-font-size-4xl), 5vw, calc(var(--weline-layout-font-size-4xl) * 1.7));
            line-height: var(--weline-layout-line-height-tight);
            letter-spacing: 0;
        }

        .default-layout__fallback p {
            max-width: 660px;
            margin: 0;
            color: var(--weline-theme-text-muted);
            font-size: var(--weline-layout-font-size-lg);
        }

        .default-layout__fallback-actions {
            display: flex;
            gap: var(--weline-layout-spacing-sm);
            flex-wrap: wrap;
            margin-top: var(--weline-layout-spacing-sm);
        }

        .default-layout__content-slot > .weline-theme-preview-content:empty {
            display: none;
        }

        .default-layout__content:has(.default-layout__content-slot > :not(.weline-theme-preview-content):not(.slot-toolbar):not(.editor-insert-indicator)) .default-layout__fallback--empty-slot,
        .default-layout__content:has(.default-layout__content-slot > .weline-theme-preview-content:not(:empty)) .default-layout__fallback--empty-slot {
            display: none;
        }

        .default-layout__sidebar {
            min-height: 160px;
        }

        @media (max-width: 920px) {
            .theme-layout-default.has-left-sidebar .default-layout__grid,
            .theme-layout-default.has-right-sidebar .default-layout__grid,
            .theme-layout-default.has-left-sidebar.has-right-sidebar .default-layout__grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body class="theme-layout-default <?= $class ?>">
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
