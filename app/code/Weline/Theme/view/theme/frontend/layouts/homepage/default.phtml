<?php
/**
 * 布局：首页 - 默认布局
 * 
 * 首页默认布局，包含header、banner、main、footer
 * 字段
 * @info description 描述：首页默认布局，包含header、banner、main、footer
 * @info name 名称：首页默认布局
 * @param title 页面标题
 * @param content 主要内容（HTML字符串）
 * @param banner Banner内容（HTML字符串）
 * @param showHeader 是否显示header
 * @param showFooter 是否显示footer
 * @param class 额外CSS类
 */
$title = $this->getData('title') ?? __('首页');
$content = $this->getData('content') ?? '';
$banner = $this->getData('banner') ?? '';
$showHeader = $this->getData('showHeader') ?? true;
$showFooter = $this->getData('showFooter') ?? true;
$class = $this->getData('class') ?? '';

// 设置页面标题
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="<?= str_replace('_', '-', $_SERVER['WELINE_USER_LANG'] ?? 'zh_Hans_CN') ?>">
<head>
    @template(Weline_Frontend::templates/public/head.phtml)
</head>
<body>
    <?php if ($showHeader): ?>
        <?php
        // 使用配置的 header partials
        $partialsBlock = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Block\Partials::class);
        $headerPath = $partialsBlock->getPartialsPath('frontend', 'header', 'default');
        if ($headerPath) {
            echo $this->fetch($headerPath, [
                'logo' => $this->getData('logo') ?? '',
                'logoText' => $this->getData('logoText') ?? __('Weline'),
                'navItems' => $this->getData('navItems') ?? [],
                'showSearch' => $this->getData('showSearch') ?? true,
                'showUserMenu' => $this->getData('showUserMenu') ?? true
            ]);
        }
        ?>
    <?php endif; ?>
    
    <?php if ($banner): ?>
        <section class="homepage-banner">
            <?= $banner ?>
        </section>
    <?php endif; ?>
    
    <main class="homepage-main <?= htmlspecialchars($class) ?>">
        <?= $content ?>
    </main>
    
    <?php if ($showFooter): ?>
        <?php
        // 使用配置的 footer partials
        $footerPath = $partialsBlock->getPartialsPath('frontend', 'footer', 'default');
        if ($footerPath) {
            echo $this->fetch($footerPath, [
                'copyright' => $this->getData('copyright') ?? __('© ' . date('Y') . ' Weline Framework. 保留所有权利'),
                'links' => $this->getData('links') ?? [],
                'showBackToTop' => $this->getData('showBackToTop') ?? true
            ]);
        }
        ?>
    <?php endif; ?>
</body>
</html>

