<!--
布局：个人中心 - 认证页面布局（account_auth 路径）

与 layouts/account/auth.phtml 同源：顶栏底栏走 Theme Partials，避免与 layouts/account_auth 双路径维护漂移。
登录/注册等认证页面的专用布局

字段
@meta.name {default="个人中心认证页面布局",name="个人中心认证页面布局",description="个人中心认证页面布局，用于描述布局的名称"}
@meta.description {default="登录/注册等认证页面的专用布局",name="个人中心认证页面布局",description="登录/注册等认证页面的专用布局"}
@preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录"}
@login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="认证页通常不需要已登录"}
@param.title {default="登录",name="页面标题",description="页面标题"}
@param.content {default="",name="认证表单内容",description="认证表单内容（HTML字符串）"}
@param.class {default="",name="额外CSS类",description="根容器额外 class"}
@param.showHeader {default=true,name="是否显示header",description="是否显示顶栏"}
@param.showFooter {default=true,name="是否显示footer",description="是否显示底栏"}
@param.showSearch {default=true,name="顶栏搜索",description="顶栏是否展示搜索（Partials）"}
@param.showUserMenu {default=true,name="用户菜单",description="顶栏是否展示用户菜单（Partials）"}

参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
-->
<?php
$meta = $this->getData('meta') ?? [];
$meta['showHeader'] = true;
$meta['showFooter'] = true;
$this->assign('meta', $meta);
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::account::head-after</w:hook>
    <theme:css>Weline_Theme::theme/frontend/assets/css/auth-form-wflash.css</theme:css>
</head>
<body class="account-auth-layout">
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::account::body-start</w:hook>

    <div class="account-auth <?= htmlspecialchars(($meta['class'] ?? '')) ?>" id="account-auth" data-layout="account_auth">
        <div class="weline-page-wrapper">
            <if condition="meta.showHeader">
                <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::account::header-before</w:hook>
                <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
                <w:hook>Weline_Theme::frontend::layouts::account::header-after</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
            </if>

            <div class="weline-main-content">
                <main class="account-auth__main" id="account-auth-content" data-layout="account_auth_content">
                    <div class="auth-container">
                        <if condition="meta.content">
                            {{meta.content}}
                            <elseif condition="content"/>
                            {{content}}
                            <elseif condition="meta.contentTemplate"/>
                            <?php echo $this->fetch($this->getData("meta.contentTemplate")); ?>
                        </if>
                    </div>
                </main>
            </div>

            <if condition="meta.showFooter">
                <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::account::footer-before</w:hook>
                <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
                <w:hook>Weline_Theme::frontend::layouts::account::footer-after</w:hook>
                <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
            </if>
        </div>
    </div>

    <w:hook>Weline_Theme::frontend::layouts::account::body-end</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
</body>
</html>
