    <script>
    (function() {
        // 移动端筛选栏展开/收起功能
        const filterToggle = document.querySelector('.category-filter-toggle');
        const filterSidebar = document.getElementById('category-filter-sidebar');
        const filterOverlay = document.getElementById('category-filter-overlay');
        const filterClose = document.querySelector('.category-filter-close');
        const filterBadge = document.getElementById('filter-count-badge');

        if (filterToggle && filterSidebar && filterOverlay) {
            // 更新筛选数量徽章
            function updateFilterBadge() {
                if (!filterBadge) return;
                const activeFilters = document.querySelectorAll('.filter-chip.is-active');
                const count = activeFilters.length;
                if (count > 0) {
                    filterBadge.textContent = count;
                    filterBadge.style.display = 'flex';
                } else {
                    filterBadge.style.display = 'none';
                }
            }

            // 打开筛选栏
            function openFilterSidebar() {
                filterSidebar.classList.add('active');
                filterOverlay.classList.add('active');
                filterToggle.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden'; // 防止背景滚动
            }

            // 关闭筛选栏
            function closeFilterSidebar() {
                filterSidebar.classList.remove('active');
                filterOverlay.classList.remove('active');
                filterToggle.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = ''; // 恢复滚动
            }

            // 点击筛选按钮
            filterToggle.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                if (filterSidebar.classList.contains('active')) {
                    closeFilterSidebar();
                } else {
                    openFilterSidebar();
                }
            });

            // 点击关闭按钮
            if (filterClose) {
                filterClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    closeFilterSidebar();
                });
            }

            // 点击遮罩层关闭
            filterOverlay.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                closeFilterSidebar();
            });

            // 点击筛选栏内部不关闭（阻止事件冒泡）
            filterSidebar.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // ESC 键关闭
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && filterSidebar.classList.contains('active')) {
                    closeFilterSidebar();
                }
            });

            // 监听筛选变化，更新徽章
            document.addEventListener('DOMContentLoaded', function() {
                updateFilterBadge();
                // 使用 MutationObserver 监听筛选状态变化
                const observer = new MutationObserver(function(mutations) {
                    updateFilterBadge();
                });
                const filterContainer = document.querySelector('.category-filter-applied');
                if (filterContainer) {
                    observer.observe(filterContainer, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ['class']
                    });
                }
            });

            // 延迟执行，确保 DOM 已加载
            setTimeout(updateFilterBadge, 100);
        }
    })();
    </script>
