<?php
/**
 * 布局：个人中心 - 登出页面布局
 * 
 * 用户登出页面的专用布局
 * 字段
 * @meta.name {default="个人中心登出页面布局",name="个人中心登出页面布局",description="个人中心登出页面布局，用于描述布局的名称"}
 * @meta.description {default="用户登出页面的专用布局",name="用户登出页面的专用布局",description="用户登出页面的专用布局，用于描述布局的用途"}
 * @preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录，0不需要登录，1需要登录，这个不是元素据，是预览系统判断是否需要自动登录的。"}
 * @login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="登出页面不需要登录，因为用户已经登出了。"}
 * @param.title {default="退出登录",name="页面标题",description="页面标题，用于设置页面标题"}
 * @param.content {default="",name="登出页面内容（HTML字符串）",description="登出页面内容（HTML字符串），用于设置页面内容"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 */
$title = $this->getData('title') ?? __('退出登录');
$content = $this->getData('content') ?? '';
$class = $this->getData('class') ?? '';

// 设置页面标题
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="<?= str_replace('_', '-', $_SERVER['WELINE_USER_LANG'] ?? 'zh_Hans_CN') ?>">
<head>
    @template(Weline_Frontend::templates/public/head.phtml)
</head>
<body>
    @template(Weline_Frontend::templates/public/header.phtml)
    
    <main class="account-logout-content <?= htmlspecialchars($class) ?>">
        <div class="logout-container">
            <?php
            // 如果指定了 contentTemplate，优先渲染原模板
            $contentTemplate = $this->getData('contentTemplate');
            if ($contentTemplate) {
                echo $this->fetch($contentTemplate);
            } else {
                // 否则使用 content 变量（HTML字符串）
                echo $content;
            }
            ?>
        </div>
    </main>
    
    @template(Weline_Frontend::templates/public/footer.phtml)
</body>
</html>

