    <script data-auth-theme-toggle-script>
    (function () {
        'use strict';

        function initAuthThemeToggle() {
            var root = document.documentElement;
            var themeToggleBtn = document.querySelector('[data-auth-theme-toggle]');
            if (!themeToggleBtn) {
                return;
            }

            function ensureAvailableThemes() {
                if (!window.Weline || !window.Weline.Theme) {
                    return;
                }

                var themes = Array.isArray(window.Weline.Theme.themes) ? window.Weline.Theme.themes.slice() : [];
                ['light', 'dark'].forEach(function (themeName) {
                    if (themes.indexOf(themeName) === -1) {
                        themes.push(themeName);
                    }
                });
                window.Weline.Theme.themes = themes;
            }

            function resolveTheme() {
                if (window.Weline && window.Weline.Theme && typeof window.Weline.Theme.getCurrent === 'function') {
                    var currentTheme = window.Weline.Theme.getCurrent();
                    if (currentTheme === 'dark' || currentTheme === 'light') {
                        return currentTheme;
                    }
                }

                return root.classList.contains('dark') || root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
            }

            function syncThemeState(theme) {
                var normalizedTheme = String(theme || '').toLowerCase() === 'dark' ? 'dark' : 'light';
                var nextTitle = normalizedTheme === 'dark'
                    ? (themeToggleBtn.dataset.titleLight || '')
                    : (themeToggleBtn.dataset.titleDark || '');
                var darkIcon = themeToggleBtn.querySelector('[data-auth-theme-icon-dark]');
                var lightIcon = themeToggleBtn.querySelector('[data-auth-theme-icon-light]');

                root.classList.toggle('dark', normalizedTheme === 'dark');
                root.classList.toggle('light', normalizedTheme !== 'dark');
                root.setAttribute('data-theme-mode', normalizedTheme);

                if (darkIcon && lightIcon) {
                    darkIcon.hidden = normalizedTheme === 'dark';
                    lightIcon.hidden = normalizedTheme !== 'dark';
                }

                if (nextTitle) {
                    themeToggleBtn.setAttribute('title', nextTitle);
                    themeToggleBtn.setAttribute('aria-label', nextTitle);
                }
            }

            function switchTheme(nextTheme) {
                ensureAvailableThemes();

                if (window.Weline && window.Weline.Theme && typeof window.Weline.Theme.switch === 'function') {
                    window.Weline.Theme.switch(nextTheme);
                    syncThemeState(nextTheme);
                    return;
                }

                root.setAttribute('data-theme', nextTheme);
                try {
                    localStorage.setItem('weline-theme', nextTheme);
                } catch (error) {
                }
                document.dispatchEvent(new CustomEvent('themechange', {
                    detail: { theme: nextTheme }
                }));
                syncThemeState(nextTheme);
            }

            if (themeToggleBtn.dataset.bound === '1') {
                syncThemeState(resolveTheme());
                return;
            }
            themeToggleBtn.dataset.bound = '1';

            themeToggleBtn.addEventListener('click', function () {
                var currentTheme = resolveTheme();
                switchTheme(currentTheme === 'dark' ? 'light' : 'dark');
            });

            document.addEventListener('themechange', function (event) {
                syncThemeState(event && event.detail ? event.detail.theme : resolveTheme());
            });

            ensureAvailableThemes();
            syncThemeState(resolveTheme());
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initAuthThemeToggle, { once: true });
        } else {
            initAuthThemeToggle();
        }
    })();
    </script>
