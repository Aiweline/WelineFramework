            min-height: 60vh;
        }

        /* 响应式调整 */
        @media (min-width: 768px) and (max-width: 1024px) {
            .account-dashboard__body {
                gap: 1rem;
                padding: 1.25rem 1rem;
            }

            .account-main-content {
                padding: 1.25rem;
            }
        }

        @media (max-width: 767px) {
            .account-dashboard__body {
                flex-direction: column;
                padding: var(--weline-layout-spacing-md) var(--weline-layout-content-padding-inline);
                gap: var(--weline-layout-spacing-md);
            }

            .account-sidebar {
                width: 100%;
                position: static;
                border-radius: var(--weline-layout-radius-md);
