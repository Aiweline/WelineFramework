            width: var(--sidebar-collapsed-width);
            padding: var(--weline-layout-spacing-md);
        }

        .account-sidebar.collapsed .account-sidebar__nav-text,
        .account-sidebar.collapsed .account-sidebar__user-info {
            display: none;
        }

        /* 主内容区样式 */
        .account-main {
            flex: 1;
            min-width: 0;
        }

        .account-main-content {
            background: var(--weline-layout-surface-primary);
