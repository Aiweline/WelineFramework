<?php
$meta = $this->getData('meta') ?? [];
$title = $meta['title'] ?? $this->getData('title') ?? __('Product');
$meta['showHeader'] = $meta['showHeader'] ?? true;
$meta['showFooter'] = $meta['showFooter'] ?? true;
$this->assign('meta', $meta);
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" dir="{{htmlDir}}" data-local="{{lang_local}}" data-lang="{{lang}}" data-dir="{{htmlDir}}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, shrink-to-fit=no">
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>seo::head</w:hook>
</head>
<body>
    <w:hook>seo::body</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <div class="weline-page-wrapper weshop-product-layout weshop-product-layout--festival" data-weshop-layout-option="festival">
        <if condition="meta.showHeader">
            <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default"/>
            <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
        </if>

        <main class="weshop-product-layout__main" id="product-detail-main" data-layout="product" data-weshop-layout-option="festival">
            <section class="weshop-product-layout__banner">
                <span class="weshop-product-layout__eyebrow"><?= __('Scheduled product layout') ?></span>
                <h1 class="weshop-product-layout__title"><?= htmlspecialchars((string)$title, ENT_QUOTES, 'UTF-8') ?></h1>
            </section>

            <w:slot id="product-main"
                    name="Product main"
                    accept="layout-product-main,product-gallery,product-info,product-options,add-to-cart"
                    multiple="true"
                    position="content"
                    class="weshop-product-layout__content">
                <w:hook>
                    WeShop_Product::frontend::layouts::product::main-content
                    <else/>
                    <if condition="meta.content">{{meta.content}}</if>
                </w:hook>
            </w:slot>

            <section class="weshop-product-layout__sections">
                <w:hook>WeShop_Product::frontend::layouts::product::tabs-content</w:hook>
            </section>
        </main>

        <if condition="meta.showFooter">
            <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
            <footer class="weline-footer">
                <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default"/>
            </footer>
            <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
        </if>
    </div>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
    <style>
        .weshop-product-layout__main {
            width: 100%;
            padding: 24px 0 56px;
            background: #fff7ed;
        }
        .weshop-product-layout__banner {
            width: min(1180px, calc(100% - 32px));
            margin: 0 auto 24px;
            padding: 18px 22px;
            border: 1px solid #fed7aa;
            border-radius: 8px;
            background: #ffffff;
        }
        .weshop-product-layout__eyebrow {
            display: inline-flex;
            margin-bottom: 8px;
            color: #c2410c;
            font-size: 0.875rem;
            font-weight: 700;
        }
        .weshop-product-layout__title {
            margin: 0;
            color: #111827;
            font-size: clamp(1.5rem, 2vw, 2.25rem);
            line-height: 1.15;
        }
        .weshop-product-layout__content,
        .weshop-product-layout__sections {
            width: min(1180px, calc(100% - 32px));
            margin: 0 auto 24px;
        }
    </style>
    <w:hook>seo::footer</w:hook>
</body>
</html>
