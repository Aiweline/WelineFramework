                                        position="content"
                                        class="weline-layout-surface homepage-minimal__hero-card">
                                    <w:hook>Weline_Theme::frontend::layouts::homepage::hero<else/>
                                    <div>
                                        <span class="homepage-minimal__eyebrow"><?= __('Default Theme') ?></span>
                                        <h1 class="homepage-minimal__title"><?= htmlspecialchars((string)($meta['title'] ?? __('A clean Weline homepage')), ENT_QUOTES, 'UTF-8') ?></h1>
                                        <p class="homepage-minimal__lead"><?= __('Use slots for visual composition, hooks for real module data, and this fallback for a complete default page.') ?></p>
                                        <div class="homepage-minimal__actions">
                                            <a class="weline-button" href="/products"><?= __('Explore') ?></a>
                                            <a class="weline-button weline-button--ghost" href="/contact"><?= __('Contact') ?></a>
                                        </div>
                                    </div>
                                    <div class="homepage-minimal__visual">
                                        <div class="weline-card homepage-minimal__visual-card">
                                            <strong><?= __('Header') ?></strong>
                                            <span class="weline-muted"><?= __('Logo, navigation, search, account, and cart slots.') ?></span>
                                        </div>
                                        <div class="weline-card homepage-minimal__visual-card">
                                            <strong><?= __('Content') ?></strong>
                                            <span class="weline-muted"><?= __('Hero, products, categories, banners, and module content.') ?></span>
                                        </div>
                                        <div class="weline-card homepage-minimal__visual-card">
                                            <strong><?= __('Footer') ?></strong>
                                            <span class="weline-muted"><?= __('Links, social, newsletter, payment, and copyright slots.') ?></span>
                                        </div>
                                    </div>
                                    </w:hook>
                                </w:slot>
                            </div>
                        </section>

                        <section class="homepage-minimal__content">
                            <div class="weline-container">
                                <w:slot id="homepage-minimal-features"
                                        name="Homepage minimal features"
                                        accept="layout-homepage-features,feature-list,content,cards,container"
                                        multiple="true"
                                        position="content"
                                        class="homepage-minimal__fallback-grid">
                                    <w:hook>Weline_Theme::frontend::layouts::homepage::features<else/>
                                    <article class="weline-card homepage-minimal__fallback-card">
                                        <h2><?= __('Real data first') ?></h2>
                                        <p><?= __('Modules can replace this card through hooks without changing Theme code.') ?></p>
                                    </article>
                                    <article class="weline-card homepage-minimal__fallback-card">
                                        <h2><?= __('Visual slots') ?></h2>
                                        <p><?= __('The editor can place widgets into clearly named homepage regions.') ?></p>
                                    </article>
                                    <article class="weline-card homepage-minimal__fallback-card">
                                        <h2><?= __('Safe defaults') ?></h2>
                                        <p><?= __('The page remains readable when optional modules are not installed.') ?></p>
                                    </article>
                                    </w:hook>
                                </w:slot>
                            </div>
                        </section>
                    </if>
                    </w:hook>
                </w:slot>
            </w:slot>

            <w:slot id="homepage-minimal-after"
                    name="Homepage minimal after"
                    accept="layout-homepage-after,banner,announcement,content"
                    multiple="true"
                    append="true"
                    position="content"
                    class="homepage-minimal__after">
                <w:hook>Weline_Theme::frontend::layouts::homepage::content-after</w:hook>
            </w:slot>
        </main>

        <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
        <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
        <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
    </div>

    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
