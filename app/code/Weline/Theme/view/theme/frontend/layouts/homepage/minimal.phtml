/**
 * Layout: homepage minimal.
 *
 * Keeps the existing content/homepage-minimal-content slot ids while providing
 * a complete default page when no module or editor content is available.
 *
 * @meta.name {default="Homepage Minimal",name="Homepage Minimal",description="Minimal homepage layout"}
 * @param.title {default="Home",name="Page Title",description="Page title"}
 * @param.content {default="",name="Content HTML",description="Main content"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class"}
 */

$meta = $this->getData('meta') ?? [];
$class = htmlspecialchars((string)($meta['class'] ?? ''), ENT_QUOTES, 'UTF-8');
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
