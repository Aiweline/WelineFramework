<?php
/**
 * 布局：CMS页面 - 默认布局
 *
 * CMS内容页面默认布局，简化为 header、content、footer 三大区域
 * content 区域是一个大的 slot 容器，可以放入任意部件或容器（行列布局等）
 * 
 * 字段
 * @meta.name {default="CMS页面默认布局",name="CMS页面默认布局",description="CMS页面默认布局，用于描述布局的名称"}
 * @meta.description {default="CMS页面默认布局，包含 header、content、footer 三大区域",name="CMS页面默认布局描述",description="简化的CMS页面布局，content区域支持自由拖放部件和容器"}
 * @preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录，0不需要登录，1需要登录"}
 * @param title {default="CMS页面",name="页面标题",description="页面标题，用于设置页面标题"}
 * @param content {default="",name="主要内容（HTML字符串）",description="主要内容（HTML字符串），用于设置页面内容"}
 * @param showHeader {default=true,name="是否显示header",description="是否显示header，用于控制header的显示"}
 * @param showFooter {default=true,name="是否显示footer",description="是否显示footer，用于控制footer的显示"}
 * @param showBreadcrumb {default=true,name="是否显示面包屑",description="是否显示面包屑导航"}
 * @param class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 *
 * 参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
 * 模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
 * 页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
 */
$meta = $this->getData('meta') ?? [];
$colors = $this->getData('colors') ?? [];
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::base::head-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::cms_page::head-after</w:hook>
</head>
<body>
    <w:hook>Weline_Theme::frontend::layouts::base::body-start</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::cms_page::body-start</w:hook>
    
    <div class="weline-page-wrapper">
        <!-- ========== HEADER 区域 ========== -->
        <if condition="meta.showHeader">
            <w:hook>Weline_Theme::frontend::layouts::base::header-before</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::cms_page::header-before</w:hook>
            
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="header" default-option="default" vars="logo,logoText,navItems,showSearch,showUserMenu"/>
            
            <w:hook>Weline_Theme::frontend::layouts::cms_page::header-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::header-after</w:hook>
        </if>

        <!-- ========== CONTENT 主内容区域 ========== -->
        <div class="weline-main-content">
            <w:hook>Weline_Theme::frontend::layouts::base::content-before</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::cms_page::content-before</w:hook>
            
            <main class="cms-page-main <?= htmlspecialchars($meta['class'] ?? '') ?>" id="cms-page-main" data-layout="cms_page">
                <!-- 面包屑导航 -->
                <if condition="meta.showBreadcrumb">
                    <div class="container">
                        <w:hook>Weline_Theme::frontend::layouts::cms_page::breadcrumb</w:hook>
                    </div>
                </if>
                
                <w:hook>Weline_Theme::frontend::layouts::cms_page::main-before</w:hook>
                
                <!-- ========== CONTENT SLOT 主内容插槽 ========== -->
                <w:slot id="content" 
                        name="内容区域"
                        multiple="true"
                        reject="header,footer"
                        position="content"
                        class="cms-page-content-slot">
                    <w:hook name="Weline_Theme::frontend::layouts::cms_page::content">
                        <if condition="meta.content">
                            <div class="container">
                                <div class="cms-content">
                                    {{meta.content}}
                                </div>
                            </div>
                        <else/>
                            <div class="cms-page-default-content">
                                <div class="container">
                                    <div class="slot-placeholder" data-placeholder="content">
                                        <span class="placeholder-icon">📄</span>
                                        <span class="placeholder-text">CMS内容区域 - 拖拽部件或容器到此处</span>
                                        <span class="placeholder-hint">支持：富文本内容、Banner、图片、视频等任意部件</span>
                                    </div>
                                </div>
                            </div>
                        </if>
                    </w:hook>
                </w:slot>
                
                <w:hook>Weline_Theme::frontend::layouts::cms_page::main-after</w:hook>
            </main>
            
            <w:hook>Weline_Theme::frontend::layouts::cms_page::content-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::content-after</w:hook>
        </div>
        
        <!-- ========== FOOTER 区域 ========== -->
        <if condition="meta.showFooter">
            <w:hook>Weline_Theme::frontend::layouts::base::footer-before</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::cms_page::footer-before</w:hook>
            
            <w:block class="Weline\Theme\Block\Partials" area="frontend" type="footer" default-option="default" vars="copyright,links,showBackToTop,socialMedia,showSocialMedia"/>
            
            <w:hook>Weline_Theme::frontend::layouts::cms_page::footer-after</w:hook>
            <w:hook>Weline_Theme::frontend::layouts::base::footer-after</w:hook>
        </if>
    </div>
    
    <w:hook>Weline_Theme::frontend::layouts::cms_page::body-end</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::body-end</w:hook>
    
