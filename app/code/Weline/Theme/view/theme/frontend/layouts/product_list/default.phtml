<?php
$title = $this->getData('title') ?? __('产品列表');
$content = $this->getData('content') ?? '';
$filters = $this->getData('filters') ?? '';
$toolbar = $this->getData('toolbar') ?? '';
$class = $this->getData('class') ?? '';

// 设置页面标题
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body>
    @template(Weline_Frontend::templates/public/header.phtml)

    <!-- 产品列表页布局的面包屑导航区域 -->
    <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-before</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::product_list::breadcrumb-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="breadcrumb" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::product_list::breadcrumb-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-after</w:hook>
    
    <main class="product-list-main <?= htmlspecialchars($class ?? '') ?>" id="product-list-main" data-layout="product_list">
        <div class="product-list-container">
            <?php if ($filters): ?>
                <aside class="product-list-filters">
                    {{filters}}
                </aside>
            <?php endif; ?>
            
            <div class="product-list-content">
                <?php if ($toolbar): ?>
                    <div class="product-list-toolbar">
                        {{toolbar}}
                    </div>
                <?php endif; ?>
                
                <div class="product-list-grid">
                    {{content}}
                </div>
            </div>
        </div>
    </main>
    
    @template(Weline_Frontend::templates/public/footer.phtml)
</body>
</html>

