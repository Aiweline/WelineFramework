    }

    .product-list-layout__recommendations-container {
        max-width: var(--weline-layout-content-max-width, var(--layout-max-width, 1440px));
        margin: 0 auto;
        padding: 0 var(--weline-layout-content-padding-inline, var(--spacing-4, 1.5rem));
        box-sizing: border-box;
    }

    /* ---- 遮罩层 ---- */
    .product-list-layout__overlay {
        position: fixed;
        inset: 0;
        background-color: color-mix(in srgb, var(--weline-theme-text) 50%, transparent);
        z-index: var(--z-index-overlay, 998);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .product-list-layout__overlay.is-visible {
        opacity: 1;
        visibility: visible;
    }

    /* ---- 占位符 ---- */
    .product-list-layout__placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-4, 1rem);
        padding: var(--spacing-8, 4rem) var(--spacing-4, 1.5rem);
        text-align: center;
        color: var(--color-text-tertiary);
    }

    .product-list-layout__placeholder-icon {
        color: var(--color-text-disabled);
    }

    .product-list-layout__placeholder-text {
        font-size: var(--font-size-sm, 0.875rem);
    }

    /* ---- 编辑模式样式由 editor-mode.css 统一管理 ---- */

    /* ---- 响应式设计 ---- */
    @media (max-width: 992px) {
        .product-list-layout__container {
            grid-template-columns: 1fr;
            padding: 0 var(--spacing-4, 1rem);
        }

        .product-list-layout__filter-toggle {
            display: inline-flex;
        }

        .product-list-layout__sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: min(85%, 360px);
            height: 100vh;
            max-height: 100vh;
            border-radius: var(--border-radius-none);
            border: none;
            border-right: var(--weline-theme-border-width) var(--weline-theme-border-style) var(--color-border-light);
            z-index: var(--z-index-drawer, 999);
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .product-list-layout__sidebar.is-open {
            transform: translateX(0);
        }

        .product-list-layout__sidebar-header {
            display: flex;
        }

        .product-list-layout__sidebar-content {
            flex: 1;
            overflow-y: auto;
            overscroll-behavior: contain;
        }

        .product-list-layout__overlay {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .product-list-layout__main {
            padding: var(--spacing-3, 1rem) 0;
        }

        .product-list-layout__container {
            padding: 0 var(--spacing-3, 0.75rem);
        }

        .product-list-layout__toolbar {
            padding: var(--spacing-3, 0.75rem);
        }

        .product-list-layout__recommendations {
            padding: var(--spacing-5, 1.5rem) 0;
        }

        .product-list-layout__recommendations-container {
            padding: 0 var(--spacing-3, 0.75rem);
        }
    }
    </style>

    <!-- 编辑模式脚本由 ThemeEditor 控制器注入 -->
    <w:hook>seo::footer</w:hook>
</body>
</html>
