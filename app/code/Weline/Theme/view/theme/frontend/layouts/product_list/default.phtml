/**
 * 布局：商品列表页
 *
 * 电商商品列表/搜索结果页布局，包含筛选侧边栏、工具栏、产品网格和分页
 * 支持移动端筛选抽屉、视图切换、排序等功能
 *
 * @meta.name {default="商品列表页布局",name="商品列表页布局",description="电商商品列表页主布局，包含筛选器、产品网格、排序分页等功能"}
 * @meta.description {default="商品列表页布局，包含筛选侧边栏、工具栏（排序/视图切换）、产品网格和分页，支持移动端筛选抽屉和响应式设计",name="商品列表页布局",description="商品列表页布局，包含筛选侧边栏、工具栏（排序/视图切换）、产品网格和分页，支持移动端筛选抽屉和响应式设计"}
 * @meta.category {default="catalog",name="商品列表",description="布局所属分类"}
 * @preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录，0不需要登录，1需要登录"}
 * @param title {default="商品列表",name="页面标题",description="页面标题，用于设置页面标题"}
 * @param content {default="",name="主要内容（HTML字符串）",description="主要内容（HTML字符串），用于设置页面内容"}
 * @param showHeader {default=true,name="是否显示header",description="是否显示header，用于控制header的显示"}
 * @param showFooter {default=true,name="是否显示footer",description="是否显示footer，用于控制footer的显示"}
 * @param showBreadcrumb {default=true,name="是否显示面包屑",description="是否显示面包屑导航"}
 * @param showFilters {default=true,name="是否显示筛选器",description="是否显示左侧筛选器"}
 * @param showToolbar {default=true,name="是否显示工具栏",description="是否显示排序/视图切换工具栏"}
 * @param filterDrawerTitle {default="筛选条件",name="筛选抽屉标题",description="移动端筛选抽屉的标题文字"}
 * @param gridColumns {default=4,type=number,name="网格列数",description="桌面端每行显示的产品卡片数量"}
 * @param class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 * @param layout.leftsider {default=1,option={0:不显示,1:显示},name="显示左侧栏",description="是否显示左侧栏（筛选器）"}
 * @param layout.rightsider {default=0,option={0:不显示,1:显示},name="显示右侧栏",description="是否显示右侧栏"}
 *
 * 参数配置由 ControllerFetchFileBefore Observer 自动加载到 meta 数组中
 * 模板中使用 meta.参数 输出内容，使用 meta.参数 在条件判断中
 * 页面标题由 Observer 自动设置（如果控制器未设置，则使用 meta.title 的默认值）
 */
$meta = $this->getData('meta') ?? [];
$colors = $this->getData('colors') ?? [];

$showFilters = $meta['showFilters'] ?? $this->getData('showFilters') ?? true;
$showToolbar = $meta['showToolbar'] ?? $this->getData('showToolbar') ?? true;
$filterDrawerTitle = \Weline\Theme\Helper\WidgetI18n::label(
    (string)($meta['filterDrawerTitle'] ?? $this->getData('filterDrawerTitle') ?? '筛选条件')
);
$gridColumns = $meta['gridColumns'] ?? $this->getData('gridColumns') ?? 4;
$isSearchLayout = (bool) $this->getData('is_search_layout');

if ($isSearchLayout) {
    $showFilters = false;
    $showToolbar = false;
}

$meta['showFilters'] = $showFilters;
$meta['showToolbar'] = $showToolbar;
$meta['filterDrawerTitle'] = $filterDrawerTitle;
$meta['gridColumns'] = $gridColumns;
$this->assign('meta', $meta);
?>
