    /* ---- 页面主体 ---- */
    .product-detail-layout__main {
        padding: var(--spacing-4, 2rem) 0;
    }

    .product-detail-layout__container {
        width: 100%;
        max-width: var(--layout-max-width, 1600px);
        margin: 0 auto;
        padding: 0 var(--spacing-4, 1.5rem);
    }

    .product-detail-layout__wrapper {
        display: flex;
        gap: var(--spacing-6, 2rem);
        flex-wrap: wrap;
    }

    /* ---- 主内容区域 ---- */
    .product-detail-layout__main-content {
        flex: 1;
        min-width: 0;
    }

    /* ---- 侧边栏 ---- */
    .product-detail-layout__sidebar {
        width: var(--sidebar-width, 320px);
        flex-shrink: 0;
        position: sticky;
        top: calc(var(--header-height, 70px) + var(--spacing-4, 1rem));
        max-height: calc(100vh - var(--header-height, 70px) - var(--spacing-8, 4rem));
        overflow-y: auto;
        overscroll-behavior: contain;
    }

    /* ---- 详情标签区域 ---- */
    .product-detail-layout__tabs {
        padding: var(--spacing-6, 2rem) 0;
        background-color: var(--color-bg-secondary);
    }

    .product-detail-layout__tabs-container {
        width: 100%;
        max-width: var(--layout-max-width, 1600px);
        margin: 0 auto;
        padding: 0 var(--spacing-4, 1.5rem);
    }

    /* ---- 相关产品区域 ---- */
    .product-detail-layout__related {
        padding: var(--spacing-6, 2rem) 0;
    }

    .product-detail-layout__related-container {
        width: 100%;
        max-width: var(--layout-max-width, 1600px);
        margin: 0 auto;
        padding: 0 var(--spacing-4, 1.5rem);
    }

    /* ---- 占位符 ---- */
    .product-detail-layout__placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-4, 1rem);
        padding: var(--spacing-8, 4rem) var(--spacing-4, 1.5rem);
        text-align: center;
        color: var(--color-text-tertiary);
    }

    .product-detail-layout__placeholder-icon {
        color: var(--color-text-disabled);
    }

    .product-detail-layout__placeholder-text {
        font-size: var(--font-size-sm, 0.875rem);
    }

