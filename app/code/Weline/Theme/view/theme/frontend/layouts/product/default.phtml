    /* ---- 响应式设计 ---- */
    @media (max-width: 992px) {
        .product-detail-layout__wrapper {
            flex-direction: column;
        }

        .product-detail-layout__sidebar {
            width: 100%;
            position: static;
            max-height: none;
        }
    }

    @media (max-width: 768px) {
        .product-detail-layout__main {
            padding: var(--spacing-3, 1rem) 0;
        }

        .product-detail-layout__container {
            padding: 0 var(--spacing-3, 0.75rem);
