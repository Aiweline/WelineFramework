    <?php if ($this->getData('editor_mode')): ?>
    <script>
    (function() {
        document.body.classList.add('editor-mode');
        
        document.querySelectorAll('[data-wslot]').forEach(slot => {
            slot.addEventListener('click', function(e) {
                e.stopPropagation();
                
                const slotData = {
                    id: this.dataset.wslot,
                    name: this.dataset.wslotName || this.dataset.wslot,
                    accept: this.dataset.wslotAccept ? this.dataset.wslotAccept.split(',').map(s => s.trim()) : [],
                    multiple: this.dataset.wslotMultiple === 'true',
                    exclusive: this.dataset.wslotExclusive === 'true'
                };
                
                if (window.parent !== window) {
                    window.parent.postMessage({ type: 'slot-selected', slot: slotData }, '*');
                }
                
                document.querySelectorAll('[data-wslot]').forEach(s => s.classList.remove('slot-active'));
                this.classList.add('slot-active');
            });
            
            slot.addEventListener('dragover', function(e) {
                e.preventDefault();
                this.classList.add('drag-over');
            });
            
            slot.addEventListener('dragleave', function(e) {
                if (!this.contains(e.relatedTarget)) {
                    this.classList.remove('drag-over');
                }
            });
            
            slot.addEventListener('drop', function(e) {
                e.preventDefault();
                this.classList.remove('drag-over');
                
                let widgetData;
                try {
                    const jsonData = e.dataTransfer.getData('application/json') || e.dataTransfer.getData('text/plain');
                    if (jsonData) widgetData = JSON.parse(jsonData);
                } catch (err) { return; }
                
                if (!widgetData) return;
                
                const slotData = {
                    id: this.dataset.wslot,
                    name: this.dataset.wslotName || this.dataset.wslot,
                    accept: this.dataset.wslotAccept ? this.dataset.wslotAccept.split(',').map(s => s.trim()) : []
                };
                
                if (window.parent !== window) {
                    window.parent.postMessage({ type: 'widget-dropped', widget: widgetData, slot: slotData }, '*');
                }
            });
        });
    })();
    </script>
