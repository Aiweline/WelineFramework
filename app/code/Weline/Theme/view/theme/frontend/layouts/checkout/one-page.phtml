?>
<?php
$title = $this->getData('title') ?? __('结账');
$content = $this->getData('content') ?? '';
$orderSummary = $this->getData('orderSummary') ?? '';
$breadcrumb = $this->getData('breadcrumb') ?? '';
$class = $this->getData('class') ?? '';

// 设置页面标题
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body>
    @template(Weline_Frontend::templates/public/header.phtml)
    
    <?php if ($breadcrumb): ?>
        <nav class="breadcrumb-nav">
            {{breadcrumb}}
        </nav>
    <?php endif; ?>
    
    <main class="checkout-main one-page <?= htmlspecialchars($class ?? '') ?>" id="checkout-main" data-layout="checkout_one_page">
        <w:slot id="content"
                name="内容区"
                accept="layout-checkout-one-page-content,layout-checkout-content,layout-default-content,content,checkout-content,checkout-form,order-summary,trust-badges"
                reject="header,footer"
                multiple="true"
                position="content"
                class="checkout-main__content-root-slot">
        <div class="checkout-container">
            <div class="checkout-content-wrapper">
                <w:slot id="checkout-one-page-content"
                        name="单页结算表单"
                        accept="layout-checkout-one-page-content,layout-checkout-content,checkout-content,content"
                        reject="header,footer"
                        multiple="true"
                        position="content"
                        class="checkout-form">
                    {{content}}
                </w:slot>
                
                <?php if ($orderSummary): ?>
                    <w:slot id="checkout-one-page-summary"
                            name="单页结算摘要"
                            accept="layout-checkout-one-page-summary,order-summary,checkout-summary"
                            exclusive="true"
                            multiple="false"
                            position="sidebar"
                            wrapper="aside"
                            class="checkout-summary sticky">
                        {{orderSummary}}
                    </w:slot>
                <?php endif; ?>
            </div>
        </div>
        </w:slot>
    </main>
    
    @template(Weline_Frontend::templates/public/footer.phtml)
