<?php
$title = $this->getData('title') ?? __('分类');
$content = $this->getData('content') ?? '';
$categoryNav = $this->getData('categoryNav') ?? '';
$filters = $this->getData('filters') ?? '';
$class = $this->getData('class') ?? '';

// 设置页面标题
$this->assign('title', $title);
?>
<!DOCTYPE html>
<html lang="{{htmlLang}}" data-local="{{lang_local}}" data-lang="{{lang}}">
<head>
    <w:hook>Weline_Theme::frontend::layouts::base::head-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="head" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::default::head-after</w:hook>
</head>
<body>
    @template(Weline_Frontend::templates/public/header.phtml)

    <!-- 分类列表页布局的面包屑导航区域 -->
    <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-before</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::category::breadcrumb-before</w:hook>
    <w:block class="Weline\Theme\Block\Partials" area="frontend" type="breadcrumb" default-option="default"/>
    <w:hook>Weline_Theme::frontend::layouts::category::breadcrumb-after</w:hook>
    <w:hook>Weline_Theme::frontend::layouts::base::breadcrumb-after</w:hook>
    
    <main class="category-list-main <?= htmlspecialchars($class ?? '') ?>" id="category-list-main" data-layout="category_list">
        <w:slot id="content"
                name="内容区"
                accept="layout-category-list-content,layout-category-content,layout-default-content,content,category-list,category-filter,category-grid,category-nav"
                reject="header,footer"
                multiple="true"
                position="content"
                class="category-list-main__content-root-slot">
        <div class="category-list-container">
            <?php if ($categoryNav): ?>
                <nav class="category-nav">
                    <w:slot id="category-list-nav"
                            name="分类列表导航"
                            accept="layout-category-list-nav,category-list,category-menu,navigation"
                            multiple="true"
                            position="content">
                        {{categoryNav}}
                    </w:slot>
                </nav>
            <?php endif; ?>
            
            <div class="category-content-wrapper">
                <?php if ($filters): ?>
                    <aside class="category-filters">
                        <w:slot id="category-list-filters"
                                name="分类列表筛选"
                                accept="layout-category-filters,layout-category-list-filters,category-filters,attribute-filter,price-filter"
                                multiple="true"
                                position="sidebar">
                            {{filters}}
                        </w:slot>
                    </aside>
                <?php endif; ?>
                
                <w:slot id="category-list-content"
                        name="分类列表内容"
                        accept="layout-category-list-content,layout-category-products,product-grid,product-list-view,category-children"
                        reject="header,footer"
                        multiple="true"
                        position="content"
                        class="category-content">
                    {{content}}
                </w:slot>
            </div>
        </div>
        </w:slot>
    </main>
    
    @template(Weline_Frontend::templates/public/footer.phtml)
</body>
</html>

