 * @meta.description {default="分类列表页布局，包含分类筛选、产品展示等",name="分类列表页布局，包含分类筛选、产品展示等",description="分类列表页布局，包含分类筛选、产品展示等，用于描述布局的用途"}
 * @preview.login {default=0,option={0:不需要登录,1:需要登录},name="是否需要登录",description="是否需要登录，0不需要登录，1需要登录，这个不是元素据，是预览系统判断是否需要自动登录的。"}
 * @param title {default="分类",name="页面标题",description="页面标题，用于设置页面标题"}
 * @param content {default="",name="主要内容（HTML字符串）",description="主要内容（HTML字符串），用于设置页面内容"}
 * @param categoryNav {default="",name="分类导航",description="分类导航，用于设置分类导航"}
 * @param filters {default="",name="筛选器内容",description="筛选器内容，用于设置筛选器"}
