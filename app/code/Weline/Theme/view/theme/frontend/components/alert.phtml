<?php
/**
 * 组件：Alert
 * 
 * 提示信息组件，支持多种类型和样式
 * 字段
 * @meta.name {default="Alert提示组件",name="Alert提示组件",description="Alert提示组件，用于描述组件的名称"}
 * @meta.description {default="提示信息组件，支持多种类型和样式",name="提示信息组件，支持多种类型和样式",description="提示信息组件，支持多种类型和样式，用于描述组件的用途"}
 * @param type {default="info",name="类型",description="类型，可选值：success/error/warning/info"}
 * @param message {default="",name="提示信息",description="提示信息，必填参数"}
 * @param title {default="",name="标题",description="标题，用于设置提示标题"}
 * @param dismissible {default=false,name="是否可关闭",description="是否可关闭，用于控制提示是否可关闭"}
 * @param icon {default="",name="自定义图标",description="自定义图标，用于设置自定义图标"}
 * @param class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
 * @param html {default=false,name="是否解析HTML",description="是否解析HTML，设为true时message中的HTML标签会被渲染"}
 */
$type = $this->getData('type') ?? 'info';
$message = $this->getData('message') ?? '';
$title = $this->getData('title') ?? '';
$dismissible = $this->getData('dismissible') ?? false;
$icon = $this->getData('icon') ?? '';
$class = $this->getData('class') ?? '';
$allowHtml = $this->getData('html') ?? false;
$alertId = trim((string) ($this->getData('id') ?? ''));

// Theme uses danger for error-state alerts.
$themeAlertModifier = ($type === 'error') ? 'danger' : $type;

// 构建CSS类
$alertClass = 'w-alert w-alert-' . htmlspecialchars((string) $themeAlertModifier);
if ($dismissible) {
    $alertClass .= ' w-alert-dismissible fade show';
}
if ($class) {
    $alertClass .= ' ' . htmlspecialchars($class);
}

// 默认图标
if (!$icon) {
    switch ($type) {
        case 'success':
            $icon = 'ri-checkbox-circle-line';
            break;
        case 'error':
        case 'danger':
            $icon = 'ri-error-warning-line';
            break;
        case 'warning':
            $icon = 'ri-alert-line';
            break;
        case 'info':
        default:
            $icon = 'ri-information-line';
            break;
    }
}
?>
<div class="<?= $alertClass ?>" role="alert"<?= $alertId !== '' ? ' id="' . htmlspecialchars($alertId, ENT_QUOTES, 'UTF-8') . '"' : '' ?>>
    <?php if ($icon): ?>
        <i class="<?= htmlspecialchars($icon) ?> me-2"></i>
    <?php endif; ?>
    
    <?php if ($title): ?>
        <strong><?= htmlspecialchars($title) ?></strong>
    <?php endif; ?>
    
    <?php if ($allowHtml): ?>
        <?= $message ?>
    <?php else: ?>
        <?= htmlspecialchars((string) $message, ENT_QUOTES, 'UTF-8') ?>
    <?php endif; ?>
    
    <?php if ($dismissible): ?>
        <button type="button" 
                class="w-btn-close"
                data-bs-dismiss="alert" 
                aria-label="<?= htmlspecialchars(__('关闭'), ENT_QUOTES, 'UTF-8') ?>">
        </button>
    <?php endif; ?>
</div>

