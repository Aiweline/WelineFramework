<?php
/**
 * 组件：Text
 *
 * @meta.name {default="Text 文本内容",name="Text 文本内容",description="用于页面搭建的标题、段落和说明文本"}
 * @meta.description {default="用于页面搭建的标题、段落和说明文本",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.eyebrow {default="",name="眉标题",description="用于展示标签或上方小标题"}
 * @param.title {default="清晰表达你的页面主张",name="标题",description="主标题"}
 * @param.body {default="在这里添加一段说明文字，介绍产品、服务、活动或页面内容。",name="正文",description="正文内容，支持换行"}
 * @param.align {default="start",name="对齐方式",description="start/center/end"}
 * @param.size {default="md",name="尺寸",description="sm/md/lg"}
 * @param.maxWidth {default="",name="最大宽度",description="例如 720px、80%"}
 * @param.textColor {default="",name="文字颜色",description="支持 #111、rgba()、var(--token)"}
 * @param.titleWeight {default="700",name="标题字重",description="400/500/600/700/800"}
 * @param.lineHeight {default="",name="正文行高",description="例如 1.6、28px"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
if (!function_exists('weline_builder_component_css_length')) {
    function weline_builder_component_css_length(mixed $value, string $fallback = ''): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return $fallback;
        }
        if (preg_match('/^(0|[0-9]+(?:\.[0-9]+)?(?:px|rem|em|%|vh|vw|svh|lvh|dvh))$/', $value)) {
            return $value;
        }
        if (preg_match('/^clamp\([0-9a-zA-Z%.,\s+\-]+\)$/', $value)) {
            return $value;
        }
        return $fallback;
    }
}
if (!function_exists('weline_builder_component_css_color')) {
    function weline_builder_component_css_color(mixed $value): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return '';
        }
        if (preg_match('/^#[0-9a-fA-F]{3,8}$/', $value)
            || preg_match('/^(rgba?|hsla?)\([0-9.,%\s]+\)$/i', $value)
            || preg_match('/^var\(--[a-zA-Z0-9_-]+\)$/', $value)
            || in_array(strtolower($value), ['transparent', 'currentcolor', 'inherit'], true)) {
            return $value;
        }
        return '';
    }
}
$eyebrow = (string)($this->getData('eyebrow') ?? $this->getData('meta.eyebrow') ?? '');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? __('清晰表达你的页面主张'));
$body = (string)($this->getData('body') ?? $this->getData('meta.body') ?? __('在这里添加一段说明文字，介绍产品、服务、活动或页面内容。'));
$align = strtolower(trim((string)($this->getData('align') ?? $this->getData('meta.align') ?? 'start')));
$size = strtolower(trim((string)($this->getData('size') ?? $this->getData('meta.size') ?? 'md')));
$maxWidth = weline_builder_component_css_length($this->getData('maxWidth') ?? $this->getData('meta.maxWidth') ?? '');
$textColor = weline_builder_component_css_color($this->getData('textColor') ?? $this->getData('meta.textColor') ?? '');
$titleWeight = trim((string)($this->getData('titleWeight') ?? $this->getData('meta.titleWeight') ?? '700'));
$lineHeight = trim((string)($this->getData('lineHeight') ?? $this->getData('meta.lineHeight') ?? ''));
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$allowedAlign = ['start', 'center', 'end'];
$allowedSize = ['sm', 'md', 'lg'];
if (!in_array($align, $allowedAlign, true)) {
    $align = 'start';
}
if (!in_array($size, $allowedSize, true)) {
    $size = 'md';
}
if (!in_array($titleWeight, ['400', '500', '600', '700', '800'], true)) {
    $titleWeight = '700';
}
if ($lineHeight !== '' && !preg_match('/^([0-9]+(?:\.[0-9]+)?|[0-9]+(?:\.[0-9]+)?px)$/', $lineHeight)) {
    $lineHeight = '';
}
$styles = [];
if ($maxWidth !== '') $styles[] = '--w-builder-text-max:' . $maxWidth;
if ($textColor !== '') $styles[] = '--w-builder-color:' . $textColor;
if ($titleWeight !== '') $styles[] = '--w-builder-title-weight:' . $titleWeight;
if ($lineHeight !== '') $styles[] = '--w-builder-line-height:' . $lineHeight;
$textClass = trim('w-builder-text w-builder-text--' . $size . ' w-builder-align-' . $align . ' ' . $class);
?>
<div class="<?= htmlspecialchars($textClass, ENT_QUOTES, 'UTF-8') ?>"
     style="<?= htmlspecialchars(implode(';', $styles), ENT_QUOTES, 'UTF-8') ?>">
    <?php if ($eyebrow !== ''): ?>
        <p class="w-builder-text__eyebrow"><?= htmlspecialchars($eyebrow, ENT_QUOTES, 'UTF-8') ?></p>
    <?php endif; ?>
    <?php if ($title !== ''): ?>
        <h2 class="w-builder-text__title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h2>
    <?php endif; ?>
    <?php if ($body !== ''): ?>
        <p class="w-builder-text__body"><?= nl2br(htmlspecialchars($body, ENT_QUOTES, 'UTF-8')) ?></p>
    <?php endif; ?>
</div>
