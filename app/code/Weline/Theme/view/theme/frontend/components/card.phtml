<?php
/**
 * 组件：Card
 * 
 * 卡片组件，用于展示结构化内容
 * 字段
 * @meta.name {default="Card卡片组件",name="Card卡片组件",description="Card卡片组件，用于描述组件的名称"}
 * @meta.description {default="卡片组件，用于展示结构化内容",name="卡片组件，用于展示结构化内容",description="卡片组件，用于展示结构化内容，用于描述组件的用途"}
 * @param.title {default="",name="卡片标题",description="卡片标题，用于设置卡片标题"}
 * @param.subtitle {default="",name="副标题",description="副标题，用于设置卡片副标题"}
 * @param.content {default="",name="卡片内容（HTML字符串）",description="卡片内容（HTML字符串），必填参数，用于设置卡片内容"}
 * @param.footer {default="",name="卡片底部内容",description="卡片底部内容，用于设置卡片底部内容"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
 * @param.id {default="",name="元素ID",description="元素ID，用于设置卡片ID"}
 * @param.headerActions {default=[],name="标题栏操作按钮",description="标题栏操作按钮，用于设置标题栏操作按钮"}
 * @param.image {default="",name="卡片图片URL",description="卡片图片URL，用于设置卡片图片"}
 * @param.imageAlt {default="",name="图片alt文本",description="图片alt文本，用于设置图片alt属性"}
 */
$title = $this->getData('title') ?? '';
$subtitle = $this->getData('subtitle') ?? '';
$content = $this->getData('content') ?? '';
$footer = $this->getData('footer') ?? '';
$class = $this->getData('class') ?? '';
$id = $this->getData('id') ?? '';
$headerActions = $this->getData('headerActions') ?? [];
$image = $this->getData('image') ?? '';
$imageAlt = $this->getData('imageAlt') ?? '';

// 构建CSS类
$cardClass = 'card';
if ($class) {
    $cardClass .= ' ' . htmlspecialchars($class);
}
?>
<div class="<?= $cardClass ?>" <?= $id ? 'id="' . htmlspecialchars($id) . '"' : '' ?>>
    <?php if ($image): ?>
        <img src="<?= htmlspecialchars($image) ?>" 
             alt="<?= htmlspecialchars($imageAlt) ?>" 
             class="card-image">
    <?php endif; ?>
    
    <?php if ($title || $subtitle || !empty($headerActions)): ?>
        <div class="card-header">
            <?php if ($title): ?>
                <h3 class="card-title"><?= htmlspecialchars($title) ?></h3>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="card-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
            <?php if (!empty($headerActions)): ?>
                <div class="card-actions">
                    <?php foreach ($headerActions as $action): ?>
                        <?= $action ?>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="card-body">
        <?= $content ?>
    </div>
    
    <?php if ($footer): ?>
        <div class="card-footer">
            <?= $footer ?>
        </div>
    <?php endif; ?>
</div>

