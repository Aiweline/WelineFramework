<?php
/**
 * 组件：Image
 *
 * @meta.name {default="Image 图片媒体",name="Image 图片媒体",description="用于展示图片、说明和链接的媒体组件"}
 * @meta.description {default="用于展示图片、说明和链接的媒体组件",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @param.src {default="",name="图片地址",description="图片 URL"}
 * @param.alt {default="图片",name="替代文本",description="图片 alt 文本"}
 * @param.caption {default="",name="图片说明",description="图片下方说明"}
 * @param.href {default="",name="链接地址",description="点击图片跳转地址"}
 * @param.ratio {default="16x9",name="宽高比",description="auto/1x1/4x3/16x9/21x9"}
 * @param.objectFit {default="cover",name="填充方式",description="cover/contain"}
 * @param.objectPosition {default="center",name="图片焦点",description="center/top/bottom/left/right"}
 * @param.align {default="start",name="对齐方式",description="start/center/end"}
 * @param.maxWidth {default="",name="最大宽度",description="例如 640px、100%"}
 * @param.radius {default="",name="圆角",description="例如 24px"}
 * @param.shadow {default="none",name="阴影",description="none/sm/md/lg"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
if (!function_exists('weline_builder_component_safe_url')) {
    function weline_builder_component_safe_url(mixed $url): string
    {
        $url = trim((string)$url);
        if ($url === '') {
            return '';
        }
        $compact = strtolower(preg_replace('/[\x00-\x20\x7f]+/', '', html_entity_decode($url, ENT_QUOTES, 'UTF-8')));
        if (str_starts_with($compact, 'javascript:') || str_starts_with($compact, 'vbscript:') || str_starts_with($compact, 'data:')) {
            return '';
        }
        return $url;
    }
}
if (!function_exists('weline_builder_component_css_length')) {
    function weline_builder_component_css_length(mixed $value, string $fallback = ''): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return $fallback;
        }
        if (preg_match('/^(0|[0-9]+(?:\.[0-9]+)?(?:px|rem|em|%|vh|vw|svh|lvh|dvh))$/', $value)) {
            return $value;
        }
        if (preg_match('/^clamp\([0-9a-zA-Z%.,\s+\-]+\)$/', $value)) {
            return $value;
        }
        return $fallback;
    }
}

$src = weline_builder_component_safe_url($this->getData('src') ?? $this->getData('meta.src') ?? '');
$alt = (string)($this->getData('alt') ?? $this->getData('meta.alt') ?? __('图片'));
$caption = (string)($this->getData('caption') ?? $this->getData('meta.caption') ?? '');
$href = weline_builder_component_safe_url($this->getData('href') ?? $this->getData('meta.href') ?? '');
$ratio = strtolower(trim((string)($this->getData('ratio') ?? $this->getData('meta.ratio') ?? '16x9')));
$objectFit = strtolower(trim((string)($this->getData('objectFit') ?? $this->getData('meta.objectFit') ?? 'cover')));
$objectPosition = strtolower(trim((string)($this->getData('objectPosition') ?? $this->getData('meta.objectPosition') ?? 'center')));
$align = strtolower(trim((string)($this->getData('align') ?? $this->getData('meta.align') ?? 'start')));
$maxWidth = weline_builder_component_css_length($this->getData('maxWidth') ?? $this->getData('meta.maxWidth') ?? '');
$radius = weline_builder_component_css_length($this->getData('radius') ?? $this->getData('meta.radius') ?? '');
$shadow = strtolower(trim((string)($this->getData('shadow') ?? $this->getData('meta.shadow') ?? 'none')));
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$allowedRatios = ['auto', '1x1', '4x3', '16x9', '21x9'];
$allowedObjectFit = ['cover', 'contain'];
$allowedPosition = ['center', 'top', 'bottom', 'left', 'right'];
$allowedAlign = ['start', 'center', 'end'];
$allowedShadow = ['none', 'sm', 'md', 'lg'];
if (!in_array($ratio, $allowedRatios, true)) {
    $ratio = '16x9';
}
if (!in_array($objectFit, $allowedObjectFit, true)) {
    $objectFit = 'cover';
}
if (!in_array($objectPosition, $allowedPosition, true)) {
    $objectPosition = 'center';
}
if (!in_array($align, $allowedAlign, true)) {
    $align = 'start';
}
if (!in_array($shadow, $allowedShadow, true)) {
    $shadow = 'none';
}
$styles = [];
if ($maxWidth !== '') $styles[] = '--w-builder-image-max:' . $maxWidth;
if ($radius !== '') $styles[] = '--w-builder-radius:' . $radius;
$styles[] = '--w-builder-object-position:' . $objectPosition;
$imageClass = trim('w-builder-image w-builder-image--' . $ratio . ' w-builder-image--' . $objectFit . ' w-builder-align-' . $align . ' w-builder-shadow-' . $shadow . ' ' . $class);
$mediaHtml = $src !== ''
    ? '<img src="' . htmlspecialchars($src, ENT_QUOTES, 'UTF-8') . '" alt="' . htmlspecialchars($alt, ENT_QUOTES, 'UTF-8') . '" loading="lazy">'
    : '<div class="w-builder-image__placeholder">' . htmlspecialchars(__('添加图片地址'), ENT_QUOTES, 'UTF-8') . '</div>';
?>
<figure class="<?= htmlspecialchars($imageClass, ENT_QUOTES, 'UTF-8') ?>"
        style="<?= htmlspecialchars(implode(';', $styles), ENT_QUOTES, 'UTF-8') ?>">
    <?php if ($href !== '' && $src !== ''): ?>
        <a class="w-builder-image__link" href="<?= htmlspecialchars($href, ENT_QUOTES, 'UTF-8') ?>">
            <?= $mediaHtml ?>
        </a>
    <?php else: ?>
        <?= $mediaHtml ?>
    <?php endif; ?>
    <?php if ($caption !== ''): ?>
        <figcaption class="w-builder-image__caption"><?= htmlspecialchars($caption, ENT_QUOTES, 'UTF-8') ?></figcaption>
    <?php endif; ?>
</figure>
