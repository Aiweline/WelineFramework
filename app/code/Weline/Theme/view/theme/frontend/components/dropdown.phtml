<!--
组件：Dropdown

下拉菜单组件，用于显示选项列表
字段
@meta.name {default="Dropdown下拉菜单组件",name="Dropdown下拉菜单组件",description="Dropdown下拉菜单组件，用于描述组件的名称"}
@meta.description {default="下拉菜单组件，用于显示选项列表",name="下拉菜单组件，用于显示选项列表",description="下拉菜单组件，用于显示选项列表，用于描述组件的用途"}
@param.id {default="",name="下拉菜单ID",description="下拉菜单ID，必填参数"}
@param.trigger {default="",name="触发器内容",description="触发器内容（HTML字符串），必填参数"}
@param.items {default=[],name="菜单项数组",description="菜单项数组，必填参数"}
@param.position {default="left",name="位置",description="位置，可选值：left/right"}
@param.class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
-->
<?php
$id = $this->getData('id') ?? '';
$trigger = $this->getData('trigger') ?? '';
$items = $this->getData('items') ?? [];
$position = $this->getData('position') ?? 'left';
$class = $this->getData('class') ?? '';

// 构建CSS类
$dropdownClass = 'dropdown';
if ($position === 'right') {
    $dropdownClass .= ' dropdown-right';
}
if ($class) {
    $dropdownClass .= ' ' . htmlspecialchars($class);
}
?>
<div class="<?= $dropdownClass ?>">
    <button class="btn dropdown-toggle" 
            type="button" 
            id="<?= htmlspecialchars($id) ?>" 
            data-toggle="dropdown" 
            aria-haspopup="true" 
            aria-expanded="false">
        {{trigger}}
    </button>
    <div class="dropdown-menu" aria-labelledby="<?= htmlspecialchars($id) ?>">
        <?php foreach ($items as $item): ?>
            <?php if (isset($item['divider']) && $item['divider']): ?>
                <div class="dropdown-divider"></div>
            <?php elseif (isset($item['header'])): ?>
                <h6 class="dropdown-header"><?= htmlspecialchars($item['header']) ?></h6>
            <?php else: ?>
                <a class="dropdown-item" 
                   href="<?= htmlspecialchars($item['url'] ?? '#') ?>"
                   <?= isset($item['onclick']) ? 'onclick="' . htmlspecialchars($item['onclick']) . '"' : '' ?>>
                    <?php if (isset($item['icon'])): ?>
                        <i class="<?= htmlspecialchars($item['icon']) ?> me-2"></i>
                    <?php endif; ?>
                    <?= htmlspecialchars($item['text'] ?? '') ?>
                </a>
            <?php endif; ?>
        <?php endforeach; ?>
    </div>
</div>

