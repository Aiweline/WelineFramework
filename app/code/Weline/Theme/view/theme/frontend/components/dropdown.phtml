<!--
组件：Dropdown

下拉菜单组件，用于显示选项列表
字段
@meta.name {default="Dropdown下拉菜单组件",name="Dropdown下拉菜单组件",description="Dropdown下拉菜单组件，用于描述组件的名称"}
@meta.description {default="下拉菜单组件，用于显示选项列表",name="下拉菜单组件，用于显示选项列表",description="下拉菜单组件，用于显示选项列表，用于描述组件的用途"}
@param.id {default="",name="下拉菜单ID",description="下拉菜单ID，必填参数"}
@param.trigger {default="",name="触发器内容",description="触发器内容（HTML字符串），必填参数"}
@param.items {default=[],name="菜单项数组",description="菜单项数组，必填参数"}
@param.position {default="left",name="位置",description="位置，可选值：left/right"}
@param.class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
-->
<?php
$id = $this->getData('id') ?? '';
$trigger = $this->getData('trigger') ?? '';
$items = $this->getData('items') ?? [];
$position = $this->getData('position') ?? 'left';
$class = $this->getData('class') ?? '';

if (!function_exists('weline_dropdown_escape')) {
    function weline_dropdown_escape(mixed $value): string
    {
        return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
    }
}

if (!function_exists('weline_dropdown_safe_url')) {
    function weline_dropdown_safe_url(mixed $url): string
    {
        $url = trim((string)$url);
        if ($url === '') {
            return '#';
        }

        $compact = strtolower(preg_replace('/[\x00-\x20\x7f]+/', '', html_entity_decode($url, ENT_QUOTES, 'UTF-8')));
        if (str_starts_with($compact, 'javascript:') || str_starts_with($compact, 'vbscript:') || str_starts_with($compact, 'data:')) {
            return '#';
        }

        return $url;
    }
}

// 构建CSS类
$dropdownClass = 'w-dropdown dropdown';
if ($position === 'right') {
    $dropdownClass .= ' w-dropdown-right dropdown-right';
}
if ($class) {
    $dropdownClass .= ' ' . weline_dropdown_escape($class);
}
?>
<div class="<?= $dropdownClass ?>">
    <button class="w-btn w-btn-secondary w-dropdown-toggle dropdown-toggle"
            type="button"
            id="<?= weline_dropdown_escape($id) ?>"
            data-toggle="dropdown"
            aria-haspopup="true"
            aria-expanded="false">
        {{trigger}}
    </button>
    <div class="w-dropdown-menu dropdown-menu" aria-labelledby="<?= weline_dropdown_escape($id) ?>">
        <?php foreach ($items as $item): ?>
            <?php if (isset($item['divider']) && $item['divider']): ?>
                <div class="w-dropdown-divider dropdown-divider"></div>
            <?php elseif (isset($item['header'])): ?>
                <h6 class="w-dropdown-header dropdown-header"><?= weline_dropdown_escape($item['header']) ?></h6>
            <?php else: ?>
                <a class="w-dropdown-item dropdown-item"
                   href="<?= weline_dropdown_escape(weline_dropdown_safe_url($item['url'] ?? '#')) ?>"
                   <?= isset($item['onclick']) ? 'data-weline-click="' . weline_dropdown_escape($item['onclick']) . '"' : '' ?>>
                    <?php if (isset($item['icon'])): ?>
                        <i class="<?= weline_dropdown_escape($item['icon']) ?> me-2"></i>
                    <?php endif; ?>
                    <?= weline_dropdown_escape($item['text'] ?? '') ?>
                </a>
            <?php endif; ?>
        <?php endforeach; ?>
    </div>
</div>

