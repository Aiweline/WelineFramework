<?php
/**
 * 组件：Field Group
 *
 * @meta.name {default="Field Group 字段分组",name="Field Group 字段分组",description="可嵌套字段的字段集"}
 * @meta.description {default="可嵌套字段的字段集",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-field"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"fields":{"id":"field-group:{layout_id}","name":"字段分组","accept":["builder-field"],"multiple":true}}
 * @param.legend {default="字段分组",name="标题",description="分组标题"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$legend = (string)($this->getData('legend') ?? $this->getData('meta.legend') ?? '字段分组');
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'field-group:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<fieldset class="w-builder-field-group">
    <?php if ($legend !== ''): ?>
        <legend><?= htmlspecialchars($legend, ENT_QUOTES, 'UTF-8') ?></legend>
    <?php endif; ?>
    <div data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('字段分组'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-field"
         data-wslot-multiple="true">
        <?php if ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入字段') ?></div>
        <?php endif; ?>
    </div>
</fieldset>
