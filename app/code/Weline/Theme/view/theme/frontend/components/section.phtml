<?php
/**
 * 组件：Section
 *
 * @meta.name {default="Section 区块容器",name="Section 区块容器",description="带标题、说明和内嵌插槽的页面区块"}
 * @meta.description {default="带标题、说明和内嵌插槽的页面区块",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"content":{"id":"section-content:{layout_id}","name":"区块内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true}}
 * @param.title {default="区块标题",name="标题",description="区块标题"}
 * @param.subtitle {default="",name="副标题",description="区块副标题"}
 * @param.content {default="",name="说明内容",description="区块默认说明内容"}
 * @param.variant {default="default",name="区块样式",description="default/hero/cta/subtle"}
 * @param.align {default="start",name="对齐方式",description="start/center/end"}
 * @param.verticalAlign {default="top",name="垂直对齐",description="top/center/bottom"}
 * @param.padding {default="",name="内边距",description="例如 32px、4rem、clamp(32px,6vw,96px)"}
 * @param.minHeight {default="",name="最小高度",description="例如 420px、60vh"}
 * @param.maxWidth {default="",name="最大宽度",description="例如 1180px、90%"}
 * @param.radius {default="",name="圆角",description="例如 24px"}
 * @param.backgroundColor {default="",name="背景色",description="支持 #fff、rgba()、var(--token)"}
 * @param.backgroundImage {default="",name="背景图",description="背景图片 URL"}
 * @param.backgroundPosition {default="center",name="背景位置",description="center/top/bottom/left/right"}
 * @param.textColor {default="",name="文字颜色",description="支持 #111、rgba()、var(--token)"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
if (!function_exists('weline_builder_component_safe_url')) {
    function weline_builder_component_safe_url(mixed $url): string
    {
        $url = trim((string)$url);
        if ($url === '') {
            return '';
        }
        $compact = strtolower(preg_replace('/[\x00-\x20\x7f]+/', '', html_entity_decode($url, ENT_QUOTES, 'UTF-8')));
        if (str_starts_with($compact, 'javascript:') || str_starts_with($compact, 'vbscript:') || str_starts_with($compact, 'data:')) {
            return '';
        }
        return preg_match('/["\'()\\\\\r\n]/', $url) ? '' : $url;
    }
}
if (!function_exists('weline_builder_component_css_length')) {
    function weline_builder_component_css_length(mixed $value, string $fallback = ''): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return $fallback;
        }
        if (preg_match('/^(0|[0-9]+(?:\.[0-9]+)?(?:px|rem|em|%|vh|vw|svh|lvh|dvh))$/', $value)) {
            return $value;
        }
        if (preg_match('/^clamp\([0-9a-zA-Z%.,\s+\-]+\)$/', $value)) {
            return $value;
        }
        return $fallback;
    }
}
if (!function_exists('weline_builder_component_css_color')) {
    function weline_builder_component_css_color(mixed $value): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return '';
        }
        if (preg_match('/^#[0-9a-fA-F]{3,8}$/', $value)
            || preg_match('/^(rgba?|hsla?)\([0-9.,%\s]+\)$/i', $value)
            || preg_match('/^var\(--[a-zA-Z0-9_-]+\)$/', $value)
            || in_array(strtolower($value), ['transparent', 'currentcolor', 'inherit'], true)) {
            return $value;
        }
        return '';
    }
}
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? __('区块标题'));
$subtitle = (string)($this->getData('subtitle') ?? $this->getData('meta.subtitle') ?? '');
$content = (string)($this->getData('content') ?? $this->getData('meta.content') ?? '');
$variant = strtolower(trim((string)($this->getData('variant') ?? $this->getData('meta.variant') ?? 'default')));
$align = strtolower(trim((string)($this->getData('align') ?? $this->getData('meta.align') ?? 'start')));
$verticalAlign = strtolower(trim((string)($this->getData('verticalAlign') ?? $this->getData('meta.verticalAlign') ?? 'top')));
$padding = weline_builder_component_css_length($this->getData('padding') ?? $this->getData('meta.padding') ?? '');
$minHeight = weline_builder_component_css_length($this->getData('minHeight') ?? $this->getData('meta.minHeight') ?? '');
$maxWidth = weline_builder_component_css_length($this->getData('maxWidth') ?? $this->getData('meta.maxWidth') ?? '');
$radius = weline_builder_component_css_length($this->getData('radius') ?? $this->getData('meta.radius') ?? '');
$backgroundColor = weline_builder_component_css_color($this->getData('backgroundColor') ?? $this->getData('meta.backgroundColor') ?? '');
$backgroundImage = weline_builder_component_safe_url($this->getData('backgroundImage') ?? $this->getData('meta.backgroundImage') ?? '');
$backgroundPosition = strtolower(trim((string)($this->getData('backgroundPosition') ?? $this->getData('meta.backgroundPosition') ?? 'center')));
$textColor = weline_builder_component_css_color($this->getData('textColor') ?? $this->getData('meta.textColor') ?? '');
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'section-content:' . ($layoutId !== '' ? $layoutId : 'preview');
$allowedVariants = ['default', 'hero', 'cta', 'subtle'];
$allowedAlign = ['start', 'center', 'end'];
$allowedVerticalAlign = ['top', 'center', 'bottom'];
$allowedBackgroundPosition = ['center', 'top', 'bottom', 'left', 'right'];
if (!in_array($variant, $allowedVariants, true)) {
    $variant = 'default';
}
if (!in_array($align, $allowedAlign, true)) {
    $align = 'start';
}
if (!in_array($verticalAlign, $allowedVerticalAlign, true)) {
    $verticalAlign = 'top';
}
if (!in_array($backgroundPosition, $allowedBackgroundPosition, true)) {
    $backgroundPosition = 'center';
}
$styles = [];
if ($padding !== '') $styles[] = '--w-builder-padding:' . $padding;
if ($minHeight !== '') $styles[] = '--w-builder-min-height:' . $minHeight;
if ($maxWidth !== '') $styles[] = '--w-builder-max-width:' . $maxWidth;
if ($radius !== '') $styles[] = '--w-builder-radius:' . $radius;
if ($backgroundColor !== '') $styles[] = '--w-builder-bg:' . $backgroundColor;
if ($backgroundImage !== '') $styles[] = '--w-builder-bg-image:url("' . $backgroundImage . '")';
if ($backgroundPosition !== '') $styles[] = '--w-builder-bg-position:' . $backgroundPosition;
if ($textColor !== '') $styles[] = '--w-builder-color:' . $textColor;
$sectionClass = trim('w-builder-section w-builder-section--' . $variant . ' w-builder-align-' . $align . ' ' . $class);
?>
<section class="<?= htmlspecialchars($sectionClass, ENT_QUOTES, 'UTF-8') ?>"
         data-vertical-align="<?= htmlspecialchars($verticalAlign, ENT_QUOTES, 'UTF-8') ?>"
         style="<?= htmlspecialchars(implode(';', $styles), ENT_QUOTES, 'UTF-8') ?>">
    <?php if ($title !== '' || $subtitle !== '' || $content !== ''): ?>
        <header class="w-builder-section__header">
            <?php if ($subtitle !== ''): ?>
                <p class="w-builder-section__eyebrow"><?= htmlspecialchars($subtitle, ENT_QUOTES, 'UTF-8') ?></p>
            <?php endif; ?>
            <?php if ($title !== ''): ?>
                <h2 class="w-builder-section__title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h2>
            <?php endif; ?>
            <?php if ($content !== ''): ?>
                <p class="w-builder-section__description"><?= nl2br(htmlspecialchars($content, ENT_QUOTES, 'UTF-8')) ?></p>
            <?php endif; ?>
        </header>
    <?php endif; ?>
    <div class="w-builder-section__body"
         data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('区块内容'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
         data-wslot-position="content"
         data-wslot-multiple="true">
        <?php if ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入内容组件') ?></div>
        <?php endif; ?>
    </div>
</section>
