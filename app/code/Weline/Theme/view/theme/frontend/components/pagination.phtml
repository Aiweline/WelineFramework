<?php
/**
 * 组件：Pagination
 * 
 * 分页组件，用于数据分页导航
 * 字段
 * @meta.name {default="Pagination分页组件",name="Pagination分页组件",description="Pagination分页组件，用于描述组件的名称"}
 * @meta.description {default="分页组件，用于数据分页导航",name="分页组件，用于数据分页导航",description="分页组件，用于数据分页导航，用于描述组件的用途"}
 * @param currentPage {default=1,name="当前页码",description="当前页码，必填参数"}
 * @param totalPages {default=1,name="总页数",description="总页数，必填参数"}
 * @param baseUrl {default="",name="基础URL",description="基础URL，必填参数"}
 * @param pageParam {default="page",name="页码参数名",description="页码参数名，用于URL参数"}
 * @param showFirstLast {default=true,name="是否显示首页/末页",description="是否显示首页/末页，用于控制首页末页按钮的显示"}
 * @param showPrevNext {default=true,name="是否显示上一页/下一页",description="是否显示上一页/下一页，用于控制上一页下一页按钮的显示"}
 * @param maxVisible {default=5,name="最大可见页码数",description="最大可见页码数，用于控制显示的页码数量"}
 * @param class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
 */
$currentPage = (int)($this->getData('currentPage') ?? 1);
$totalPages = (int)($this->getData('totalPages') ?? 1);
$baseUrl = $this->getData('baseUrl') ?? '';
$pageParam = $this->getData('pageParam') ?? 'page';
$showFirstLast = $this->getData('showFirstLast') ?? true;
$showPrevNext = $this->getData('showPrevNext') ?? true;
$maxVisible = (int)($this->getData('maxVisible') ?? 5);
$class = $this->getData('class') ?? '';

// 构建CSS类
$paginationClass = 'pagination';
if ($class) {
    $paginationClass .= ' ' . htmlspecialchars($class);
}

// 构建URL函数
$buildUrl = function($page) use ($baseUrl, $pageParam) {
    $url = $baseUrl;
    $separator = strpos($url, '?') !== false ? '&' : '?';
    return $url . $separator . $pageParam . '=' . $page;
};

// 计算显示的页码范围
$startPage = max(1, $currentPage - floor($maxVisible / 2));
$endPage = min($totalPages, $startPage + $maxVisible - 1);
if ($endPage - $startPage < $maxVisible - 1) {
    $startPage = max(1, $endPage - $maxVisible + 1);
}
?>
<nav class="<?= $paginationClass ?>">
    <ul class="pagination-list">
        <?php if ($showFirstLast && $currentPage > 1): ?>
            <li class="page-item">
                <a class="page-link" href="<?= $buildUrl(1) ?>"><?= __('首页') ?></a>
            </li>
        <?php endif; ?>
        
        <?php if ($showPrevNext && $currentPage > 1): ?>
            <li class="page-item">
                <a class="page-link" href="<?= $buildUrl($currentPage - 1) ?>"><?= __('上一页') ?></a>
            </li>
        <?php endif; ?>
        
        <?php for ($i = $startPage; $i <= $endPage; $i++): ?>
            <li class="page-item <?= $i === $currentPage ? 'active' : '' ?>">
                <a class="page-link" href="<?= $buildUrl($i) ?>"><?= $i ?></a>
            </li>
        <?php endfor; ?>
        
        <?php if ($showPrevNext && $currentPage < $totalPages): ?>
            <li class="page-item">
                <a class="page-link" href="<?= $buildUrl($currentPage + 1) ?>"><?= __('下一页') ?></a>
            </li>
        <?php endif; ?>
        
        <?php if ($showFirstLast && $currentPage < $totalPages): ?>
            <li class="page-item">
                <a class="page-link" href="<?= $buildUrl($totalPages) ?>"><?= __('末页') ?></a>
            </li>
        <?php endif; ?>
    </ul>
</nav>

