<?php
/**
 * 组件：Grid
 *
 * @meta.name {default="Grid 栅格容器",name="Grid 栅格容器",description="可嵌套组件的响应式栅格容器"}
 * @meta.description {default="可嵌套组件的响应式栅格容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"content":{"id":"grid-items:{layout_id}","name":"栅格内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true}}
 * @param.columns {default=2,name="列数",description="1-4"}
 * @param.gap {default="16px",name="间距",description="栅格项间距"}
 * @param.minColumnWidth {default="220px",name="最小列宽",description="响应式最小列宽"}
 * @param.alignItems {default="stretch",name="纵向对齐",description="start/center/end/stretch"}
 * @param.justifyItems {default="stretch",name="横向对齐",description="start/center/end/stretch"}
 * @param.padding {default="",name="内边距",description="例如 24px、2rem"}
 * @param.backgroundColor {default="",name="背景色",description="支持 #fff、rgba()、var(--token)"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
if (!function_exists('weline_builder_component_css_length')) {
    function weline_builder_component_css_length(mixed $value, string $fallback = ''): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return $fallback;
        }
        if (preg_match('/^(0|[0-9]+(?:\.[0-9]+)?(?:px|rem|em|%|vh|vw|svh|lvh|dvh))$/', $value)) {
            return $value;
        }
        if (preg_match('/^clamp\([0-9a-zA-Z%.,\s+\-]+\)$/', $value)) {
            return $value;
        }
        return $fallback;
    }
}
if (!function_exists('weline_builder_component_css_color')) {
    function weline_builder_component_css_color(mixed $value): string
    {
        $value = trim((string)$value);
        if ($value === '') {
            return '';
        }
        if (preg_match('/^#[0-9a-fA-F]{3,8}$/', $value)
            || preg_match('/^(rgba?|hsla?)\([0-9.,%\s]+\)$/i', $value)
            || preg_match('/^var\(--[a-zA-Z0-9_-]+\)$/', $value)
            || in_array(strtolower($value), ['transparent', 'currentcolor', 'inherit'], true)) {
            return $value;
        }
        return '';
    }
}
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$columns = (int)($this->getData('columns') ?? $this->getData('meta.columns') ?? 2);
$columns = max(1, min(4, $columns));
$gap = trim((string)($this->getData('gap') ?? $this->getData('meta.gap') ?? '16px'));
$minColumnWidth = trim((string)($this->getData('minColumnWidth') ?? $this->getData('meta.minColumnWidth') ?? '220px'));
$alignItems = strtolower(trim((string)($this->getData('alignItems') ?? $this->getData('meta.alignItems') ?? 'stretch')));
$justifyItems = strtolower(trim((string)($this->getData('justifyItems') ?? $this->getData('meta.justifyItems') ?? 'stretch')));
$padding = weline_builder_component_css_length($this->getData('padding') ?? $this->getData('meta.padding') ?? '');
$backgroundColor = weline_builder_component_css_color($this->getData('backgroundColor') ?? $this->getData('meta.backgroundColor') ?? '');
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$slotId = 'grid-items:' . ($layoutId !== '' ? $layoutId : 'preview');
$gap = preg_match('/^[0-9.]+(px|rem|em|%)$/', $gap) ? $gap : '16px';
$minColumnWidth = preg_match('/^[0-9.]+(px|rem|em|%)$/', $minColumnWidth) ? $minColumnWidth : '220px';
$allowedItemAlign = ['start', 'center', 'end', 'stretch'];
if (!in_array($alignItems, $allowedItemAlign, true)) {
    $alignItems = 'stretch';
}
if (!in_array($justifyItems, $allowedItemAlign, true)) {
    $justifyItems = 'stretch';
}
$styles = [
    '--w-builder-grid-columns:' . $columns,
    '--w-builder-grid-gap:' . $gap,
    '--w-builder-grid-min:' . $minColumnWidth,
    '--w-builder-grid-align:' . $alignItems,
    '--w-builder-grid-justify:' . $justifyItems,
];
if ($padding !== '') $styles[] = '--w-builder-padding:' . $padding;
if ($backgroundColor !== '') $styles[] = '--w-builder-bg:' . $backgroundColor;
$gridClass = trim('w-builder-grid ' . $class);
?>
<div class="<?= htmlspecialchars($gridClass, ENT_QUOTES, 'UTF-8') ?>"
     style="<?= htmlspecialchars(implode(';', $styles), ENT_QUOTES, 'UTF-8') ?>"
     data-wslot="<?= htmlspecialchars($slotId, ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-name="<?= htmlspecialchars(__('栅格内容'), ENT_QUOTES, 'UTF-8') ?>"
     data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
     data-wslot-position="content"
     data-wslot-multiple="true">
    <?php if ($editorMode): ?>
        <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入内容组件') ?></div>
    <?php endif; ?>
</div>
