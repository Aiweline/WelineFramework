<?php
/**
 * 组件：Form
 *
 * @meta.name {default="Form 表单",name="Form 表单",description="可嵌套字段的表单容器"}
 * @meta.description {default="可嵌套字段的表单容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-form"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"fields":{"id":"form-fields:{layout_id}","name":"表单字段","accept":["builder-field","builder-container"],"multiple":true},"actions":{"id":"form-actions:{layout_id}","name":"表单操作","accept":["builder-action"],"multiple":true}}
 * @param.method {default="post",name="提交方式",description="get/post"}
 * @param.action {default="",name="提交地址",description="表单提交地址"}
 * @param.class {default="",name="额外 CSS 类",description="追加样式类"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$method = strtolower((string)($this->getData('method') ?? $this->getData('meta.method') ?? 'post'));
$action = trim((string)($this->getData('action') ?? $this->getData('meta.action') ?? ''));
$class = trim((string)($this->getData('class') ?? $this->getData('meta.class') ?? ''));
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
if (!in_array($method, ['get', 'post'], true)) {
    $method = 'post';
}
$safeAction = '';
if ($action !== '') {
    $compactAction = strtolower(preg_replace('/[\x00-\x20\x7f]+/', '', html_entity_decode($action, ENT_QUOTES, 'UTF-8')));
    if (!str_starts_with($compactAction, 'javascript:') && !str_starts_with($compactAction, 'vbscript:') && !str_starts_with($compactAction, 'data:')) {
        $safeAction = $action;
    }
}
$fieldsSlotId = 'form-fields:' . ($layoutId !== '' ? $layoutId : 'preview');
$actionsSlotId = 'form-actions:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<form class="<?= htmlspecialchars(trim('w-builder-form ' . $class), ENT_QUOTES, 'UTF-8') ?>"
      method="<?= htmlspecialchars($method, ENT_QUOTES, 'UTF-8') ?>"
      <?= $safeAction !== '' ? 'action="' . htmlspecialchars($safeAction, ENT_QUOTES, 'UTF-8') . '"' : '' ?>>
    <div class="w-builder-form-fields"
         data-wslot="<?= htmlspecialchars($fieldsSlotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('表单字段'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-field,builder-container"
         data-wslot-multiple="true">
        <?php if ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入字段或字段分组') ?></div>
        <?php endif; ?>
    </div>
    <div class="w-builder-form-actions"
         data-wslot="<?= htmlspecialchars($actionsSlotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('表单操作'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-action"
         data-wslot-multiple="true">
        <?php if ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder compact"><?= __('拖入按钮') ?></div>
        <?php endif; ?>
    </div>
</form>
