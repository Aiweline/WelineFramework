<!--
组件：FormGroup

表单组组件，用于包装表单字段
字段
@meta.name {default="FormGroup表单组组件",name="FormGroup表单组组件",description="FormGroup表单组组件，用于描述组件的名称"}
@meta.description {default="表单组组件，用于包装表单字段",name="表单组组件，用于包装表单字段",description="表单组组件，用于包装表单字段，用于描述组件的用途"}
@widget.supports {["builder-component","builder-field","builder-container"]}
@widget.position {["content"]}
@widget.page_layouts {["*","dashboard"]}
@widget.compatible {true}
@param.label {default="",name="字段标签",description="字段标签，用于设置字段标签"}
@param.input {default="",name="输入框HTML",description="输入框HTML，必填参数"}
@param.help {default="",name="帮助文字",description="帮助文字，用于设置帮助文字"}
@param.error {default="",name="错误信息",description="错误信息，用于设置错误信息"}
@param.required {default=false,name="是否必填",description="是否必填，用于控制字段的必填状态"}
@param.class {default="",name="额外CSS类",description="额外CSS类，用于设置组件额外CSS类"}
-->
<?php
$label = $this->getData('label') ?? '';
$input = $this->getData('input') ?? '';
$help = $this->getData('help') ?? '';
$error = $this->getData('error') ?? '';
$required = $this->getData('required') ?? false;
$class = $this->getData('class') ?? '';

// 构建CSS类
$formGroupClass = 'w-form-group';
if ($class) {
    $formGroupClass .= ' ' . htmlspecialchars($class);
}
?>
<div class="<?= $formGroupClass ?>">
    <?php if ($label): ?>
        <label class="w-form-label">
            <?= htmlspecialchars($label) ?>
            <?php if ($required): ?>
                <span class="w-text-danger">*</span>
            <?php endif; ?>
        </label>
    <?php endif; ?>
    
    {{input}}
    
    <?php if ($help && !$error): ?>
        <small class="w-form-text"><?= htmlspecialchars($help) ?></small>
    <?php endif; ?>
    
    <?php if ($error): ?>
        <div class="w-invalid-feedback"><?= htmlspecialchars($error) ?></div>
    <?php endif; ?>
</div>
