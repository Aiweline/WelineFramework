<?php
/**
 * 组件：FormGroup
 * 
 * 表单组组件，用于包装表单字段
 * 字段
 * @info description 描述：表单组组件，用于包装表单字段
 * @info name 名称：FormGroup表单组组件
 * @param label 字段标签
 * @param input 输入框HTML（必填）
 * @param help 帮助文字
 * @param error 错误信息
 * @param required 是否必填
 * @param class 额外CSS类
 */
$label = $this->getData('label') ?? '';
$input = $this->getData('input') ?? '';
$help = $this->getData('help') ?? '';
$error = $this->getData('error') ?? '';
$required = $this->getData('required') ?? false;
$class = $this->getData('class') ?? '';

// 构建CSS类
$formGroupClass = 'form-group';
if ($class) {
    $formGroupClass .= ' ' . htmlspecialchars($class);
}
?>
<div class="<?= $formGroupClass ?>">
    <?php if ($label): ?>
        <label class="form-label">
            <?= htmlspecialchars($label) ?>
            <?php if ($required): ?>
                <span class="text-danger">*</span>
            <?php endif; ?>
        </label>
    <?php endif; ?>
    
    <?= $input ?>
    
    <?php if ($help && !$error): ?>
        <small class="form-text"><?= htmlspecialchars($help) ?></small>
    <?php endif; ?>
    
    <?php if ($error): ?>
        <div class="invalid-feedback"><?= htmlspecialchars($error) ?></div>
    <?php endif; ?>
</div>

