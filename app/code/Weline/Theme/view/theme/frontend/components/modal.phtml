<?php
/**
 * 组件：Modal
 *
 * @meta.name {default="Modal 弹窗",name="Modal 弹窗",description="可嵌套内容的弹窗容器"}
 * @meta.description {default="可嵌套内容的弹窗容器",name="描述",description="组件用途"}
 * @widget.supports {["builder-component","builder-container","builder-display"]}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*","dashboard"]}
 * @widget.compatible {true}
 * @widget.is_container {true}
 * @widget.slots {"body":{"id":"modal-body:{layout_id}","name":"弹窗内容","accept":["builder-component","builder-form","builder-display","builder-container"],"multiple":true},"footer":{"id":"modal-footer:{layout_id}","name":"弹窗底部","accept":["builder-action","builder-component"],"multiple":true}}
 * @param.title {default="弹窗标题",name="标题",description="弹窗标题"}
 * @param.content {default="",name="兼容内容",description="旧版 HTML 字符串内容"}
 * @param.footer {default="",name="兼容底部",description="旧版 HTML 字符串底部"}
 */
$layoutId = (string)($this->getData('layout_id') ?? $this->getData('_layout_id') ?? 'preview');
$title = (string)($this->getData('title') ?? $this->getData('meta.title') ?? '弹窗标题');
$content = (string)($this->getData('content') ?? $this->getData('meta.content') ?? '');
$footer = (string)($this->getData('footer') ?? $this->getData('meta.footer') ?? '');
$editorMode = (bool)($this->getData('editor_mode') ?? $this->getData('preview_mode') ?? false);
$bodySlotId = 'modal-body:' . ($layoutId !== '' ? $layoutId : 'preview');
$footerSlotId = 'modal-footer:' . ($layoutId !== '' ? $layoutId : 'preview');
?>
<section class="w-modal modal-content w-builder-modal">
    <header class="w-modal-header modal-header">
        <h3 class="w-modal-title modal-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h3>
    </header>
    <div class="w-modal-body modal-body"
         data-wslot="<?= htmlspecialchars($bodySlotId, ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-name="<?= htmlspecialchars(__('弹窗内容'), ENT_QUOTES, 'UTF-8') ?>"
         data-wslot-accept="builder-component,builder-form,builder-display,builder-container"
         data-wslot-multiple="true">
        <?php if ($content !== ''): ?>
            <?= $content ?>
        <?php elseif ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder"><?= __('拖入弹窗内容') ?></div>
        <?php endif; ?>
    </div>
    <footer class="w-modal-footer modal-footer"
            data-wslot="<?= htmlspecialchars($footerSlotId, ENT_QUOTES, 'UTF-8') ?>"
            data-wslot-name="<?= htmlspecialchars(__('弹窗底部'), ENT_QUOTES, 'UTF-8') ?>"
            data-wslot-accept="builder-action,builder-component"
            data-wslot-multiple="true">
        <?php if ($footer !== ''): ?>
            <?= $footer ?>
        <?php elseif ($editorMode): ?>
            <div class="w-builder-slot-placeholder slot-placeholder compact"><?= __('拖入按钮') ?></div>
        <?php endif; ?>
    </footer>
</section>
