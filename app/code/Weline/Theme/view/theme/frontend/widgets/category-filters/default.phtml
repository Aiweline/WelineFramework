/**
 * 部件模板：分类页左侧筛选（Category Filters）
 *
 * @widget.code {category-filters}
 * @widget.name {分类筛选}
 * @widget.description {分类页左侧筛选器，支持价格、品牌、属性筛选}
 * @widget.type {sidebar}
 * @widget.area {frontend}
 * @widget.position {["sidebar"]}
 * @widget.page_layouts {["category", "search"]}
 * 
 * - 通过 Widget 引擎渲染：
 *   使用 w:widget type="sidebar" name="category-filters" 标签
 *   支持 params='{"html":"..."}' 参数传入业务渲染的筛选结构
 * - 支持通过参数 html 传入业务渲染的筛选结构；
 *   未传入 html 时：
 *   1. 尝试使用 WeShop_Filters 模块的 Hook 渲染真实筛选数据
 *   2. 如果 Hook 不可用，使用内置的亚马逊风格 Mock 内容，方便可视化编辑与设计预览。
 *
 * 样式类说明（由主题 layouts 提供样式）：
 * - .category-filter-mock
 * - .category-filter-header / .category-filter-title / .category-filter-clear
 * - .category-filter-applied / .filter-chip / .chip-remove
 * - .category-filter-group / .category-filter-group-title
 * - .category-filter-list / .category-filter-item / .label / .count / .stars
 */

/** @var array $meta */
$meta = $this->getData('meta') ?? [];

// 优先使用 Widget 参数 html，其次 meta.filters
$filtersHtml = $this->getData('html') ?? ($meta['filters'] ?? '');

if (!empty($filtersHtml) && is_string($filtersHtml)) {
    // 如果传入了 html，直接输出
    echo $filtersHtml;
} else {
    // 尝试使用 WeShop_Filters Hook 渲染真实筛选
    $hookContent = $this->getHook('Weline_Theme::frontend::layouts::category::filters-sidebar');
    
    if (!empty($hookContent)) {
        // 使用 Hook 渲染的筛选内容
        echo $hookContent;
    } else {
        // 否则输出默认 Mock 模板内容
?>
