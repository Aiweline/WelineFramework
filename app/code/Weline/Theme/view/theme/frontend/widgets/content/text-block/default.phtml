<?php
/**
 * 文本块部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {text-block}
 * @widget.name {文本块}
 * @widget.description {富文本内容区块，支持标题和样式设置}
 * @widget.type {content}
 * @widget.area {frontend}
 * @widget.position {["content", "sidebar"]}
 * @widget.page_layouts {["*"]}
 * @widget.compatible {true}
 * 
 * @param title {default="",type="string",label="标题"}
 * @param content {default="",type="textarea",label="内容"}
 * @param alignment {default="left",type="select",label="对齐方式",options={left:"左对齐",center:"居中",right:"右对齐"}}
 * @param background_color {default="transparent",type="color",label="背景颜色"}
 * @param padding {default="20px",type="string",label="内边距"}
 */

$title = $this->getData('title') ?? '';
$content = $this->getData('content') ?? '';
$alignment = $this->getData('alignment') ?? 'left';
$backgroundColor = $this->getData('background_color') ?? 'transparent';
$padding = $this->getData('padding') ?? '20px';

$widgetId = 'text-block-' . uniqid();
?>

<div class="widget-text-block text-<?= htmlspecialchars($alignment) ?>" 
     id="<?= $widgetId ?>"
     style="background-color: <?= htmlspecialchars($backgroundColor) ?>; padding: <?= htmlspecialchars($padding) ?>;">
    
    <?php if ($title): ?>
        <h2 class="block-title"><?= htmlspecialchars($title) ?></h2>
    <?php endif; ?>
    
    <?php if ($content): ?>
        <div class="block-content">
            <?= $content // 允许HTML ?>
        </div>
    <?php endif; ?>
</div>

<style>
.widget-text-block {
    border-radius: 8px;
}

.widget-text-block.text-left { text-align: left; }
.widget-text-block.text-center { text-align: center; }
.widget-text-block.text-right { text-align: right; }

.widget-text-block .block-title {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 15px;
    color: var(--heading-color, #222);
}

.widget-text-block .block-content {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-color, #444);
}

.widget-text-block .block-content p {
    margin: 0 0 15px;
}

.widget-text-block .block-content p:last-child {
    margin-bottom: 0;
}

.widget-text-block .block-content a {
    color: var(--primary-color, #007bff);
}

.widget-text-block .block-content ul,
.widget-text-block .block-content ol {
    margin: 15px 0;
    padding-left: 25px;
}

.widget-text-block .block-content li {
    margin-bottom: 8px;
}
</style>
