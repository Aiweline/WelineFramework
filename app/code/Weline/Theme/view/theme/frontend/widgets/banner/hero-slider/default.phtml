<?php
/**
 * Hero 轮播图部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {hero-slider}
 * @widget.name {Hero 轮播图}
 * @widget.description {首页大图轮播Banner，支持多张图片轮播展示}
 * @widget.type {banner}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["homepage", "cms_page"]}
 * 
 * @param slides {default=[],type="array",label="轮播图片",description="图片数组，每项包含image、title、subtitle、link、button_text"}
 * @param autoplay {default=true,type="bool",label="自动播放"}
 * @param autoplay_speed {default=5000,type="number",label="播放间隔",description="自动播放间隔（毫秒）"}
 * @param show_dots {default=true,type="bool",label="显示指示点"}
 * @param show_arrows {default=true,type="bool",label="显示箭头"}
 * @param effect {default="slide",type="select",label="切换效果",options={slide:"滑动",fade:"淡入淡出"}}
 * @param height {default="500px",type="string",label="轮播高度"}
 */

$slides = $this->getData('slides') ?? [];
$autoplay = (bool)($this->getData('autoplay') ?? true);
$autoplaySpeed = (int)($this->getData('autoplay_speed') ?? 5000);
$showDots = (bool)($this->getData('show_dots') ?? true);
$showArrows = (bool)($this->getData('show_arrows') ?? true);
$effect = $this->getData('effect') ?? 'slide';
$height = $this->getData('height') ?? '500px';
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png') ?? '';

// 示例数据
if (empty($slides)) {
    $slides = [
        [
            'image' => $placeholder,
            'title' => __('2026春季新品上市'),
            'subtitle' => __('探索最新时尚潮流'),
            'button_text' => __('立即选购'),
            'link' => '/products/new',
            'text_position' => 'left', // left/center/right
        ],
        [
            'image' => $placeholder,
            'title' => __('限时特惠'),
            'subtitle' => __('全场满300减50'),
            'button_text' => __('查看详情'),
            'link' => '/promotions',
            'text_position' => 'center',
        ],
        [
            'image' => $placeholder,
            'title' => __('品质生活'),
            'subtitle' => __('精选优质好物'),
            'button_text' => __('开始探索'),
            'link' => '/featured',
            'text_position' => 'right',
        ],
    ];
}

$sliderId = 'hero-slider-' . uniqid();
?>

<div class="widget-hero-slider" id="<?= $sliderId ?>" style="height: <?= htmlspecialchars($height ?? '') ?>;">
    <div class="slider-container effect-<?= htmlspecialchars($effect ?? '') ?>">
        <div class="slider-wrapper">
            <?php foreach ($slides as $index => $slide): ?>
                <div class="slide <?= $index === 0 ? 'active' : '' ?>" 
                     data-index="<?= $index ?>"
                     style="background-image: url('<?= htmlspecialchars($slide['image'] ?? '') ?>');">
                    <div class="slide-overlay"></div>
                    <div class="slide-content text-<?= htmlspecialchars($slide['text_position'] ?? 'left') ?>">
                        <div class="slide-text">
                            <?php if (!empty($slide['title'])): ?>
                                <h2 class="slide-title"><?= htmlspecialchars($slide['title'] ?? '') ?></h2>
                            <?php endif; ?>
                            <?php if (!empty($slide['subtitle'])): ?>
                                <p class="slide-subtitle"><?= htmlspecialchars($slide['subtitle'] ?? '') ?></p>
                            <?php endif; ?>
                            <?php if (!empty($slide['button_text'])): ?>
                                <a href="<?= htmlspecialchars($slide['link'] ?? '#') ?>" class="slide-button">
                                    <?= htmlspecialchars($slide['button_text'] ?? '') ?>
                                </a>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
        
        <?php if ($showArrows && count($slides) > 1): ?>
            <button class="slider-arrow slider-prev" type="button" aria-label="<?= __('上一张') ?>">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <button class="slider-arrow slider-next" type="button" aria-label="<?= __('下一张') ?>">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
        
        <?php if ($showDots && count($slides) > 1): ?>
            <div class="slider-dots">
                <?php foreach ($slides as $index => $slide): ?>
                    <button class="dot <?= $index === 0 ? 'active' : '' ?>" 
                            data-index="<?= $index ?>"
                            type="button"
                            aria-label="<?= __('第%d张', $index + 1) ?>"></button>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </div>
</div>

