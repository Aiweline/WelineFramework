<?php
/**
 * Header Logo 部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {logo}
 * @widget.name {Header Logo}
 * @widget.description {网站 Logo，支持图片或文字显示}
 * @widget.type {header}
 * @widget.area {frontend}
 * @widget.position {["header"]}
 * @widget.page_layouts {["*"]}
 * @widget.slot {logo}
 * @widget.exclusive {true}
 * 
 * @param logo_image {default="",type="image",label="Logo图片",description="Logo图片URL，留空使用文字"}
 * @param logo_text {default="WeShop",type="string",label="Logo文字"}
 * @param logo_link {default="/",type="string",label="Logo链接"}
 * @param logo_height {default=40,type="number",label="Logo高度(px)"}
 */

$logoImage = $this->getData('logo_image') ?? '';
$logoText = $this->getData('logo_text') ?? 'WeShop';
$logoLink = $this->getData('logo_link') ?? '/';
$logoHeight = (int)($this->getData('logo_height') ?? 40);
?>
<div class="widget-header-logo">
    <a href="<?= htmlspecialchars($logoLink) ?>" class="logo-link" title="<?= htmlspecialchars($logoText) ?>">
        <?php if ($logoImage): ?>
            <img src="<?= htmlspecialchars($logoImage) ?>" 
                 alt="<?= htmlspecialchars($logoText) ?>" 
                 class="logo-image"
                 style="height: <?= $logoHeight ?>px; width: auto;">
        <?php else: ?>
            <span class="logo-text"><?= htmlspecialchars($logoText) ?></span>
        <?php endif; ?>
    </a>
</div>

<style>
.widget-header-logo {
    display: flex;
    align-items: center;
}
.widget-header-logo .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
}
.widget-header-logo .logo-image {
    max-width: 200px;
    object-fit: contain;
}
.widget-header-logo .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary-color, #333);
}
</style>
