<?php
/**
 * 最近浏览部件
 *
 * @var \Weline\Framework\View\Template $this
 *
 * @widget.code {recently-viewed}
 * @widget.name {最近浏览}
 * @widget.description {展示当前用户或游客浏览器真实浏览过的产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content", "sidebar"]}
 * @widget.page_layouts {["*"]}
 * @widget.supports {["layout-product-recently-viewed","layout-product-sidebar","layout-product-list-recommendations","layout-search-recommendations"]}
 * @widget.compatible {true}
 *
 * @param title {default="最近浏览",type="string",label="标题"}
 * @param limit {default=6,type="number",label="显示数量"}
 * @param columns {default="6",type="select",label="每行列数",options={3:"3列",4:"4列",5:"5列",6:"6列"}}
 * @param layout {default="carousel",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 * @param show_price {default=true,type="bool",label="显示价格"}
 */

use Weline\Theme\Helper\WidgetI18n;

$titleSource = trim((string)($this->getData('title') ?? '')) ?: '最近浏览';
$widgetTitle = WidgetI18n::label($titleSource, '最近浏览');
$limit = max(1, (int)($this->getData('limit') ?? 6));
$columns = (string)($this->getData('columns') ?? '6');
$layout = (string)($this->getData('layout') ?? 'carousel');
$showPrice = (bool)($this->getData('show_price') ?? true);
$placeholder = 'data:image/svg+xml;charset=UTF-8,' . rawurlencode(
    '<svg xmlns="http://www.w3.org/2000/svg" width="640" height="640" viewBox="0 0 640 640"><defs><linearGradient id="g" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#f8fafc"/><stop offset="1" stop-color="#dbeafe"/></linearGradient></defs><rect width="640" height="640" fill="url(#g)"/><circle cx="320" cy="320" r="150" fill="none" stroke="#93c5fd" stroke-width="34"/><path d="M320 220v112l86 52" fill="none" stroke="#60a5fa" stroke-width="34" stroke-linecap="round" stroke-linejoin="round"/></svg>'
);

$products = [];
try {
    $objectManager = \Weline\Framework\Manager\ObjectManager::class;
    $recentlyViewedService = $objectManager::getInstance(\WeShop\RecentlyViewed\Service\RecentlyViewedService::class);
    $customerContext = $objectManager::getInstance(\WeShop\Customer\Api\CustomerContextInterface::class);
    $customerId = (int)($customerContext->getUserId() ?? 0);
    $viewedItems = [];

    if ($customerId > 0) {
        $viewedItems = $recentlyViewedService->getRecentlyViewed($customerId, $limit);
    }

    if ($viewedItems === []) {
        $productModelClass = \WeShop\Product\Model\Product::class;
        foreach (\WeShop\RecentlyViewed\Service\StorefrontRecentlyViewedRecorder::getGuestProductIds() as $productId) {
            if (count($viewedItems) >= $limit) {
                break;
            }
            $product = $objectManager::getInstance($productModelClass);
            $product->load($productId);
            if ($product->getId()) {
                $viewedItems[] = [
                    'product_id' => $productId,
                    'product' => $product->getData(),
                ];
            }
        }
    }

    foreach ($viewedItems as $item) {
        $product = is_array($item['product'] ?? null) ? $item['product'] : [];
        $productId = (int)($product['product_id'] ?? $product['id'] ?? $item['product_id'] ?? 0);
        if ($productId <= 0 || $product === []) {
            continue;
        }

        $handle = trim((string)($product['handle'] ?? ''));
        $products[] = [
            'id' => $productId,
            'name' => (string)($product['name'] ?? ''),
            'url' => $handle !== ''
                ? $this->getUrl('product/' . $handle)
                : $this->getUrl('weshop/product/view', ['id' => $productId]),
            'image' => (string)($product['image'] ?? $product['thumbnail'] ?? $placeholder),
            'price' => (float)($product['price'] ?? 0),
        ];
    }
} catch (\Throwable) {
    $products = [];
}

$widgetInstanceKey = (string)($this->getData('_widget_instance_key') ?: sha1(json_encode([$titleSource, $limit, $columns, $layout, $showPrice]) ?: 'recently-viewed'));
$widgetId = 'recently-viewed-' . substr(preg_replace('/[^a-zA-Z0-9_-]/', '', $widgetInstanceKey) ?: sha1($widgetInstanceKey), 0, 12);

if (empty($products)) {
    return;
}
?>

<div class="widget-recently-viewed widget-products" id="<?= $widgetId ?>" style="width:100%;max-width:var(--layout-max-width,1600px);margin:0 auto;padding:var(--spacing-6,2rem) var(--spacing-4,1.5rem);box-sizing:border-box;">
    <div class="widget-header">
        <h2 class="widget-title">
            <i class="ri-history-line" aria-hidden="true"></i>
            <?= htmlspecialchars($widgetTitle, ENT_QUOTES, 'UTF-8') ?>
        </h2>
    </div>

    <div class="products-container layout-<?= htmlspecialchars($layout, ENT_QUOTES, 'UTF-8') ?>">
        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns, ENT_QUOTES, 'UTF-8') ?>" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:var(--spacing-4,1rem);width:100%;box-sizing:border-box;">
                <?php foreach ($products as $product): ?>
                    <article class="product-card compact-card" style="display:flex;min-width:0;flex-direction:column;overflow:hidden;border:1px solid var(--color-border-light,#e5e7eb);border-radius:var(--radius-lg,12px);background:var(--color-bg-primary,#fff);box-shadow:var(--shadow-sm,0 1px 2px rgba(15,23,42,.04));">
                        <a href="<?= htmlspecialchars((string)$product['url'], ENT_QUOTES, 'UTF-8') ?>" class="card-link">
                            <div class="product-image-wrapper">
                                <img src="<?= htmlspecialchars((string)$product['image'], ENT_QUOTES, 'UTF-8') ?>"
                                     alt="<?= htmlspecialchars((string)$product['name'], ENT_QUOTES, 'UTF-8') ?>"
                                     class="product-image"
                                     loading="lazy">
                            </div>
                            <div class="product-info" style="display:flex;width:auto;min-width:0;flex:1;flex-direction:column;gap:.45rem;padding:var(--spacing-3,0.875rem);box-sizing:border-box;">
                                <h3 class="product-name"><?= htmlspecialchars((string)$product['name'], ENT_QUOTES, 'UTF-8') ?></h3>
                                <?php if ($showPrice): ?>
                                    <span class="price-current">¥<?= number_format((float)$product['price'], 2) ?></span>
                                <?php endif; ?>
                            </div>
                        </a>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</div>

<style>
.widget-recently-viewed { background: var(--color-bg-secondary, #f8fafc); }
.widget-recently-viewed .widget-header { margin-bottom: var(--spacing-5, 1.5rem); }
.widget-recently-viewed .widget-title { display: flex; align-items: center; gap: .5rem; margin: 0; color: var(--color-text-primary, #111827); font-size: clamp(1.25rem, 1.6vw, 1.6rem); font-weight: var(--font-weight-bold, 700); line-height: 1.2; }
.widget-recently-viewed .widget-title i { color: var(--color-text-secondary, #64748b); }
.widget-recently-viewed .products-wrapper { width: 100%; overflow: hidden; }
.widget-recently-viewed .card-link { display: flex; height: 100%; flex-direction: column; color: inherit; text-decoration: none; }
.widget-recently-viewed .product-card { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
.widget-recently-viewed .product-card:hover { transform: translateY(-2px); border-color: var(--color-primary, #2563eb); box-shadow: var(--shadow-md, 0 12px 30px rgba(15,23,42,.10)); }
.widget-recently-viewed .product-image-wrapper { position: relative; overflow: hidden; background: var(--color-bg-primary, #fff); aspect-ratio: 1 / 1; }
.widget-recently-viewed .product-image { display: block; width: 100%; height: 100%; object-fit: cover; }
.widget-recently-viewed .product-name { margin: 0; color: var(--color-text-primary, #111827); font-size: .875rem; font-weight: 600; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.widget-recently-viewed .card-link:hover .product-name { color: var(--color-primary, #2563eb); }
.widget-recently-viewed .price-current { color: var(--color-primary, #2563eb); font-weight: 800; }
</style>
