<?php
/**
 * 猜你喜欢部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {you-may-like}
 * @widget.name {猜你喜欢}
 * @widget.description {基于用户行为智能推荐产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*"]}
 * @widget.compatible {true}
 * 
 * @param title {default="猜你喜欢",type="string",label="标题"}
 * @param subtitle {default="根据您的浏览记录推荐",type="string",label="副标题"}
 * @param limit {default=8,type="number",label="显示数量"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列",5:"5列"}}
 * @param layout {default="grid",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 */

$title = (string)($this->getData('title') ?? __('猜你喜欢'));
$subtitle = (string)($this->getData('subtitle') ?? __('根据您的浏览记录推荐'));
$limit = (int)($this->getData('limit') ?? 8);
$columns = (string)($this->getData('columns') ?? '4');
$layout = (string)($this->getData('layout') ?? 'grid');
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

// 示例产品数据（实际应从推荐引擎获取）
$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $products[] = [
        'id' => $i,
        'name' => __('推荐产品 %d', $i),
        'url' => '/product/recommend-' . $i,
        'image' => $placeholder,
        'price' => rand(50, 500),
        'original_price' => rand(50, 500) * 1.2,
        'rating' => rand(35, 50) / 10,
        'review_count' => rand(10, 500),
        'match_score' => rand(80, 99), // 匹配度
    ];
}

$widgetId = 'you-may-like-' . uniqid();
?>

<div class="widget-you-may-like widget-products" id="<?= $widgetId ?>">
    <div class="widget-header">
        <?php if ($title): ?>
            <h2 class="widget-title">
                <i class="ri-magic-line" style="color: #9b59b6;"></i>
                <?= htmlspecialchars($title) ?>
            </h2>
        <?php endif; ?>
        <?php if ($subtitle): ?>
            <p class="widget-subtitle"><?= htmlspecialchars($subtitle) ?></p>
        <?php endif; ?>
    </div>
    
    <div class="products-container layout-<?= htmlspecialchars($layout) ?>">
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-prev" type="button">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        <?php endif; ?>
        
        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns) ?>">
                <?php foreach ($products as $product): ?>
                    <?php
                    // 确保所有产品字段都是字符串，避免null值
                    $productUrl = (string)($product['url'] ?? '');
                    $productImage = (string)($product['image'] ?? '');
                    $productName = (string)($product['name'] ?? '');
                    ?>
                    <div class="product-card">
                        <div class="product-image-wrapper">
                            <a href="<?= htmlspecialchars($productUrl) ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars($productImage) ?>" 
                                     alt="<?= htmlspecialchars($productName) ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>
                            
                            <div class="match-badge">
                                <i class="ri-thumb-up-fill"></i>
                                <?= $product['match_score'] ?>% <?= __('匹配') ?>
                            </div>
                            
                            <div class="product-actions">
                                <button class="action-btn btn-wishlist" title="<?= __('加入收藏') ?>">
                                    <i class="ri-heart-line"></i>
                                </button>
                                <button class="action-btn btn-quickview" title="<?= __('快速查看') ?>">
                                    <i class="ri-eye-line"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="product-info">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars($productUrl) ?>">
                                    <?= htmlspecialchars($productName) ?>
                                </a>
                            </h3>
                            
                            <div class="product-rating">
                                <div class="stars">
                                    <?php for ($s = 1; $s <= 5; $s++): ?>
                                        <i class="ri-star-<?= $s <= floor($product['rating']) ? 'fill' : 'line' ?>"></i>
                                    <?php endfor; ?>
                                </div>
                                <span class="review-count">(<?= $product['review_count'] ?>)</span>
                            </div>
                            
                            <div class="product-price">
                                <?php if ($product['original_price'] > $product['price']): ?>
                                    <span class="price-original">¥<?= number_format($product['original_price'], 2) ?></span>
                                <?php endif; ?>
                                <span class="price-current">¥<?= number_format($product['price'], 2) ?></span>
                            </div>
                            
                            <button class="btn-add-to-cart" data-product-id="<?= $product['id'] ?>">
                                <i class="ri-shopping-cart-line"></i>
                                <span><?= __('加入购物车') ?></span>
                            </button>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        </div>
        
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-next" type="button">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
    </div>
</div>

