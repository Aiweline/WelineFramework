    width: 40px;
    height: 40px;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s;
}

.widget-brand-logos .carousel-arrow:hover {
    background: var(--primary-color, #007bff);
    color: #fff;
    border-color: var(--primary-color, #007bff);
}

.widget-brand-logos .carousel-prev { left: -20px; }
.widget-brand-logos .carousel-next { right: -20px; }

@media (max-width: 992px) {
    .widget-brand-logos .brands-grid.columns-6,
    .widget-brand-logos .brands-grid.columns-8 {
        grid-template-columns: repeat(4, 1fr);
    }
}

@media (max-width: 768px) {
    .widget-brand-logos .brands-grid {
        grid-template-columns: repeat(3, 1fr) !important;
    }
    
    .widget-brand-logos .brand-logo {
        max-height: 40px;
    }
}

@media (max-width: 480px) {
    .widget-brand-logos .brands-grid {
        grid-template-columns: repeat(2, 1fr) !important;
    }
}
</style>
