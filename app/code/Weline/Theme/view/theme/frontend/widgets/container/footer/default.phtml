<?php
/**
 * Footer 容器部件模板
 * 
 * 定义底部布局和内部插槽位置
 * 
 * @var array $config 部件配置
 * @var array $children 子部件（按插槽分组）
 * 
 * @widget.code {footer-container}
 * @widget.name {Footer 容器}
 * @widget.description {页面底部容器，包含链接、社交、订阅、版权等插槽。独占底部区域。}
 * @widget.type {container}
 * @widget.area {frontend}
 * @widget.position {["footer"]}
 * @widget.page_layouts {["*"]}
 * @widget.is_container {true}
 * @widget.exclusive {true}
 * @widget.slots {"links":{"name":"链接区插槽","position":"top","accept":["footer-links"],"max":4},"newsletter":{"name":"订阅区插槽","position":"top-right","accept":["footer-newsletter"],"max":1},"social":{"name":"社交媒体插槽","position":"bottom-left","accept":["footer-social"],"max":1},"payment":{"name":"支付方式插槽","position":"bottom-center","accept":["footer-payment"],"max":1},"copyright":{"name":"版权信息插槽","position":"bottom-right","accept":["footer-copyright"],"max":1}}
 * 
 * @param bg_color {default="#1a1a2e",type="color",label="背景颜色"}
 * @param text_color {default="#ffffff",type="color",label="文字颜色"}
 */

$bgColor = $config['bg_color'] ?? '#1a1a2e';
$textColor = $config['text_color'] ?? '#ffffff';

// 子部件数据（由渲染器注入）
$children = $children ?? [];
?>
<footer class="widget-footer-container" style="background-color: <?= htmlspecialchars($bgColor) ?>; color: <?= htmlspecialchars($textColor) ?>;">
    
    <!-- 顶部区域：链接和订阅 -->
    <div class="footer-top">
        <div class="footer-container">
            
            <!-- 链接区插槽 -->
            <div class="footer-links-area">
                <div class="footer-slot slot-links" data-slot="links" data-accept="footer-links">
                    <?php if (!empty($children['links'])): ?>
                        <?php foreach ($children['links'] as $child): ?>
                            <div class="slot-widget footer-link-group" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                                <?= $child['html'] ?? '' ?>
                            </div>
                        <?php endforeach; ?>
                    <?php else: ?>
                        <div class="slot-placeholder">
                            <i class="ri-links-line"></i>
                            <span>页脚链接</span>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
            
            <!-- 订阅区插槽 -->
            <div class="footer-slot slot-newsletter" data-slot="newsletter" data-accept="footer-newsletter">
                <?php if (!empty($children['newsletter'])): ?>
                    <?php foreach ($children['newsletter'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder">
                        <i class="ri-mail-line"></i>
                        <span>邮件订阅</span>
                    </div>
                <?php endif; ?>
            </div>
            
        </div>
    </div>
    
    <!-- 底部区域：社交、支付、版权 -->
    <div class="footer-bottom">
        <div class="footer-container">
            
            <!-- 社交媒体插槽 -->
            <div class="footer-slot slot-social" data-slot="social" data-accept="footer-social">
                <?php if (!empty($children['social'])): ?>
                    <?php foreach ($children['social'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder">
                        <i class="ri-share-line"></i>
                        <span>社交媒体</span>
                    </div>
                <?php endif; ?>
            </div>
            
            <!-- 支付方式插槽 -->
            <div class="footer-slot slot-payment" data-slot="payment" data-accept="footer-payment">
                <?php if (!empty($children['payment'])): ?>
                    <?php foreach ($children['payment'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder">
                        <i class="ri-bank-card-line"></i>
                        <span>支付方式</span>
                    </div>
                <?php endif; ?>
            </div>
            
            <!-- 版权信息插槽 -->
            <div class="footer-slot slot-copyright" data-slot="copyright" data-accept="footer-copyright">
                <?php if (!empty($children['copyright'])): ?>
                    <?php foreach ($children['copyright'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder">
                        <i class="ri-copyright-line"></i>
                        <span>版权信息</span>
                    </div>
                <?php endif; ?>
            </div>
            
        </div>
    </div>
    
</footer>

<style>
.widget-footer-container {
    width: 100%;
}

.footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
}

.footer-top {
    padding: 50px 0 40px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

.footer-top .footer-container {
    display: flex;
    justify-content: space-between;
    gap: 40px;
}

.footer-links-area {
    flex: 1;
}

.slot-links {
    display: flex;
    gap: 60px;
}

.footer-link-group {
    min-width: 150px;
}

.slot-newsletter {
    width: 300px;
    flex-shrink: 0;
}

.footer-bottom {
    padding: 30px 0;
}

.footer-bottom .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
}

/* 插槽样式 */
.footer-slot {
    position: relative;
    min-height: 40px;
}

/* 编辑模式样式由 editor-mode.css 统一管理 */
</style>
