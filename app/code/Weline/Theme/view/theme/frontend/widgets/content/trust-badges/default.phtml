    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.widget-trust-badges.style-icon-text .badge-icon i {
    font-size: 24px;
    color: #fff;
}

