<?php
/**
 * 信任徽章部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {trust-badges}
 * @widget.name {信任徽章}
 * @widget.description {展示安全支付、退款保障等信任标识}
 * @widget.type {content}
 * @widget.area {frontend}
 * @widget.position {["content", "sidebar"]}
 * @widget.page_layouts {["*"]}
 * @widget.supports {["layout-homepage-trust","layout-cart-trust","layout-checkout-trust","layout-contact-help","layout-contact-methods","layout-contact-content","layout-default-content"]}
 * @widget.compatible {true}
 * 
 * @param title {default="",type="string",label="标题"}
 * @param badges {default=[],type="array",label="自定义徽章"}
 * @param preset_badges {default=["secure-payment","money-back","free-shipping","24-7-support"],type="array",label="预设徽章"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列"}}
 * @param style {default="icon-text",type="select",label="样式",options={icon-text:"图标+文字",icon-only:"仅图标",card:"卡片"}}
 */

$title = $this->getData('title') ?? '';
$badges = $this->getData('badges') ?? [];
$presetBadges = $this->getData('preset_badges') ?? ['secure-payment', 'money-back', 'free-shipping', '24-7-support'];
$columns = $this->getData('columns') ?? '4';
$style = $this->getData('style') ?? 'icon-text';

// 预设徽章配置
$presetConfig = [
    'secure-payment' => ['icon' => 'ri-shield-check-line', 'title' => __('安全支付'), 'description' => __('SSL加密保护')],
    'money-back'     => ['icon' => 'ri-refund-2-line', 'title' => __('无忧退款'), 'description' => __('30天无理由退货')],
    'free-shipping'  => ['icon' => 'ri-truck-line', 'title' => __('免费配送'), 'description' => __('满额包邮')],
    '24-7-support'   => ['icon' => 'ri-customer-service-2-line', 'title' => __('全天候客服'), 'description' => __('7×24小时在线')],
    'ssl-secure'     => ['icon' => 'ri-lock-line', 'title' => __('SSL安全'), 'description' => __('数据加密传输')],
    'verified-seller'=> ['icon' => 'ri-verified-badge-line', 'title' => __('认证商家'), 'description' => __('正品保证')],
];

// 合并预设和自定义徽章
$allBadges = [];
foreach ($presetBadges as $preset) {
    if (isset($presetConfig[$preset])) {
        $allBadges[] = $presetConfig[$preset];
    }
}
$allBadges = array_merge($allBadges, $badges);

$widgetId = 'trust-badges-' . uniqid();
?>

<div class="widget-trust-badges style-<?= htmlspecialchars($style) ?>" id="<?= $widgetId ?>">
    <?php if ($title): ?>
        <h3 class="widget-title"><?= htmlspecialchars($title) ?></h3>
    <?php endif; ?>
    
    <div class="badges-grid columns-<?= htmlspecialchars($columns) ?>">
        <?php foreach ($allBadges as $badge): ?>
            <div class="badge-item">
                <div class="badge-icon">
                    <i class="<?= htmlspecialchars($badge['icon'] ?? 'ri-checkbox-circle-line') ?>"></i>
                </div>
                
                <?php if ($style !== 'icon-only'): ?>
                    <div class="badge-content">
                        <h4 class="badge-title"><?= htmlspecialchars($badge['title'] ?? '') ?></h4>
                        <?php if ($style === 'card' && !empty($badge['description'])): ?>
                            <p class="badge-description"><?= htmlspecialchars($badge['description']) ?></p>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>
    </div>
</div>

<style>
.widget-trust-badges {
    padding: 30px 0;
}

.widget-trust-badges .widget-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 20px;
    text-align: center;
}

