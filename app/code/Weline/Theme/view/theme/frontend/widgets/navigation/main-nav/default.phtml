<?php
/**
 * Header 导航菜单部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {main-nav}
 * @widget.name {主导航菜单}
 * @widget.description {Header 主导航菜单，支持多级下拉和Mega菜单}
 * @widget.type {navigation}
 * @widget.area {frontend}
 * @widget.position {["header"]}
 * @widget.page_layouts {["*"]}
 * @widget.slot {navigation}
 * @widget.supports {["layout-header-navigation","layout-global-header-navigation"]}
 * @widget.exclusive {true}
 * 
 * @param menu_style {default="horizontal",type="select",label="菜单样式",options={horizontal:"水平",vertical:"垂直",mega:"Mega菜单"}}
 * @param show_icons {default=false,type="bool",label="显示图标"}
 * @param max_depth {default=3,type="number",label="最大层级"}
 * @param menu_items {default=[],type="array",label="菜单项",description="菜单项数组，每项包含label、url、icon、children"}
 */

$menuStyle = $this->getData('menu_style') ?? 'horizontal';
$showIcons = (bool)($this->getData('show_icons') ?? false);
$maxDepth = (int)($this->getData('max_depth') ?? 3);
$menuItems = $this->getData('menu_items') ?? [];

// 示例菜单数据（实际使用时应从系统获取）
if (empty($menuItems)) {
    $menuItems = [
        ['label' => __('首页'), 'url' => '/', 'icon' => 'ri-home-line'],
        ['label' => __('商品'), 'url' => '/products', 'icon' => 'ri-shopping-bag-line', 'children' => [
            ['label' => __('新品上架'), 'url' => '/products/new'],
            ['label' => __('热销商品'), 'url' => '/products/bestsellers'],
            ['label' => __('特价促销'), 'url' => '/products/sale'],
        ]],
        ['label' => __('分类'), 'url' => '/categories', 'icon' => 'ri-apps-line', 'children' => [
            ['label' => __('电子产品'), 'url' => '/category/electronics'],
            ['label' => __('服装鞋帽'), 'url' => '/category/fashion'],
            ['label' => __('家居生活'), 'url' => '/category/home'],
        ]],
        ['label' => __('关于我们'), 'url' => '/about', 'icon' => 'ri-information-line'],
        ['label' => __('联系我们'), 'url' => '/contact', 'icon' => 'ri-mail-line'],
    ];
}

// 递归渲染菜单项（闭包，避免模板多次包含时重复声明）
$renderMenuItem = function ($item, $depth = 0, $maxDepth = 3, $showIcons = false) use (&$renderMenuItem) {
    $hasChildren = !empty($item['children']) && $depth < $maxDepth;
    $icon = $item['icon'] ?? '';
    ?>
    <li class="nav-item<?= $hasChildren ? ' has-children' : '' ?>">
        <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>" class="nav-link">
            <?php if ($showIcons && $icon): ?>
                <i class="<?= htmlspecialchars($icon) ?>"></i>
            <?php endif; ?>
            <span><?= htmlspecialchars($item['label'] ?? '') ?></span>
            <?php if ($hasChildren): ?>
                <i class="ri-arrow-down-s-line dropdown-icon"></i>
            <?php endif; ?>
        </a>
        <?php if ($hasChildren): ?>
            <ul class="dropdown-menu">
                <?php foreach ($item['children'] as $child): ?>
                    <?php $renderMenuItem($child, $depth + 1, $maxDepth, $showIcons); ?>
                <?php endforeach; ?>
            </ul>
        <?php endif; ?>
    </li>
    <?php
};
?>

<nav class="widget-main-nav nav-style-<?= htmlspecialchars($menuStyle) ?>">
    <ul class="nav-menu">
        <?php foreach ($menuItems as $item): ?>
            <?php $renderMenuItem($item, 0, $maxDepth, $showIcons); ?>
        <?php endforeach; ?>
    </ul>
</nav>

<style>
.widget-main-nav {
    position: relative;
}

/* 水平菜单样式 */
.nav-style-horizontal .nav-menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 5px;
}

.nav-style-horizontal .nav-item {
    position: relative;
}

.nav-style-horizontal .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 15px;
    color: var(--nav-color, #333);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s, background-color 0.3s;
    border-radius: 4px;
}

.nav-style-horizontal .nav-link:hover {
    color: var(--primary-color, #007bff);
    background-color: var(--nav-hover-bg, rgba(0,123,255,0.1));
}

.nav-style-horizontal .dropdown-icon {
    font-size: 0.8em;
    transition: transform 0.3s;
}

.nav-style-horizontal .has-children:hover .dropdown-icon {
    transform: rotate(180deg);
}

/* 下拉菜单 */
.nav-style-horizontal .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    list-style: none;
    padding: 8px 0;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s;
    z-index: 1000;
}

.nav-style-horizontal .has-children:hover > .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.nav-style-horizontal .dropdown-menu .nav-link {
    padding: 10px 20px;
    border-radius: 0;
}

.nav-style-horizontal .dropdown-menu .dropdown-menu {
    top: 0;
    left: 100%;
}

/* 垂直菜单样式 */
.nav-style-vertical .nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
}

.nav-style-vertical .nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 15px;
    color: var(--nav-color, #333);
    text-decoration: none;
    border-bottom: 1px solid #eee;
    transition: all 0.3s;
}

.nav-style-vertical .nav-link:hover {
    background-color: var(--nav-hover-bg, #f5f5f5);
    color: var(--primary-color, #007bff);
}

.nav-style-vertical .dropdown-menu {
    list-style: none;
    padding-left: 20px;
    margin: 0;
}

/* Mega菜单样式 */
.nav-style-mega .dropdown-menu {
    min-width: 600px;
    padding: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.nav-style-mega .dropdown-menu .nav-item {
    flex: 1;
    min-width: 150px;
}
</style>
