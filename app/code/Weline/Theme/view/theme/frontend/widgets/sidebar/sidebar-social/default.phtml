    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--social-gap, 10px);
}

#<?= $widgetId ?> .social-link {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
}

