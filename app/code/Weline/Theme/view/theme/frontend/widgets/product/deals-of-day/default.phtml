 */

$title = $this->getData('title') ?? __('今日特价');
$subtitle = $this->getData('subtitle') ?? __('限时抢购，错过不再');
$limit = (int)($this->getData('limit') ?? 4);
$showCountdown = (bool)($this->getData('show_countdown') ?? true);
$countdownEnd = $this->getData('countdown_end') ?? date('Y-m-d 23:59:59');
