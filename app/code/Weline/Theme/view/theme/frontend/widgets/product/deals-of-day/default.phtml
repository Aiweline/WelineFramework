        'id' => $i,
        'name' => __('特价产品 %d', $i),
        'url' => '/product/deal-' . $i,
        'image' => '/images/products/deal-' . $i . '.jpg',
        'price' => $originalPrice * (100 - $discount) / 100,
        'original_price' => $originalPrice,
        'discount_percent' => $discount,
        'rating' => rand(40, 50) / 10,
        'review_count' => rand(20, 300),
        'stock_total' => 100,
        'stock_sold' => rand(50, 95),
    ];
}

$widgetId = 'deals-of-day-' . uniqid();
?>

<div class="widget-deals-of-day widget-products" id="<?= $widgetId ?>">
