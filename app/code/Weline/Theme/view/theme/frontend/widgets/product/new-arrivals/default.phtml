<?php
/**
 * 新品到达部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {new-arrivals}
 * @widget.name {新品上架}
 * @widget.description {展示最新上架的产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["homepage", "cms_page", "category"]}
 * 
 * @param title {default="新品上架",type="string",label="标题"}
 * @param subtitle {default="发现最新商品",type="string",label="副标题"}
 * @param limit {default=8,type="number",label="显示数量"}
 * @param days {default=30,type="number",label="天数范围",description="多少天内上架的算新品"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列",5:"5列",6:"6列"}}
 * @param show_new_badge {default=true,type="bool",label="显示新品标签"}
 * @param layout {default="grid",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 */

$title = $this->getData('title') ?? __('新品上架');
$subtitle = $this->getData('subtitle') ?? __('发现最新商品');
$limit = (int)($this->getData('limit') ?? 8);
$days = (int)($this->getData('days') ?? 30);
$columns = $this->getData('columns') ?? '4';
$showNewBadge = (bool)($this->getData('show_new_badge') ?? true);
$layout = $this->getData('layout') ?? 'grid';
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

// 示例产品数据
$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $products[] = [
        'id' => $i,
        'name' => __('新品产品 %d', $i),
        'url' => '/product/new-' . $i,
        'image' => $placeholder,
        'price' => rand(80, 600),
        'original_price' => rand(80, 600) * 1.1,
        'rating' => rand(40, 50) / 10,
        'review_count' => rand(5, 100),
        'created_at' => date('Y-m-d', strtotime('-' . rand(1, $days) . ' days')),
    ];
}

$widgetId = 'new-arrivals-' . uniqid();
?>

<div class="widget-new-arrivals widget-products" id="<?= $widgetId ?>">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="products-container layout-<?= htmlspecialchars($layout) ?>">
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-prev" type="button">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        <?php endif; ?>
        
        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns) ?>">
                <?php foreach ($products as $product): ?>
                    <?php
                    // 确保所有产品字段都是字符串，避免null值
                    $productUrl = (string)($product['url'] ?? '');
                    $productImage = (string)($product['image'] ?? '');
                    $productName = (string)($product['name'] ?? '');
                    ?>
                    <div class="product-card">
                        <div class="product-image-wrapper">
                            <a href="<?= htmlspecialchars($productUrl) ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars($productImage) ?>" 
                                     alt="<?= htmlspecialchars($productName) ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>
                            
                            <?php if ($showNewBadge): ?>
                                <div class="product-badges">
                                    <span class="badge badge-new"><?= __('NEW') ?></span>
                                </div>
                            <?php endif; ?>
                            
                            <div class="product-actions">
                                <button class="action-btn btn-wishlist weline-pixel::add_to_wishlist" title="<?= __('加入收藏') ?>">
                                    <i class="ri-heart-line weline-pixel::add_to_wishlist"></i>
                                </button>
                                <button class="action-btn btn-quickview" title="<?= __('快速查看') ?>">
                                    <i class="ri-eye-line"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="product-info">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars($productUrl) ?>">
                                    <?= htmlspecialchars($productName) ?>
                                </a>
                            </h3>
                            
                            <div class="product-meta">
                                <span class="new-date">
                                    <i class="ri-time-line"></i>
                                    <?= date('m/d', strtotime($product['created_at'])) ?> <?= __('上架') ?>
                                </span>
                            </div>
                            
                            <div class="product-rating">
                                <div class="stars" style="--rating: <?= $product['rating'] ?>;">
                                    <?php for ($s = 1; $s <= 5; $s++): ?>
                                        <i class="ri-star-<?= $s <= floor($product['rating']) ? 'fill' : 'line' ?>"></i>
                                    <?php endfor; ?>
                                </div>
                                <span class="review-count">(<?= $product['review_count'] ?>)</span>
                            </div>
                            
                            <div class="product-price">
                                <?php if ($product['original_price'] > $product['price']): ?>
                                    <span class="price-original">¥<?= number_format($product['original_price'], 2) ?></span>
                                <?php endif; ?>
                                <span class="price-current weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)(float)$product['price'], ENT_QUOTES, 'UTF-8') ?>">¥<?= number_format($product['price'], 2) ?></span>
                            </div>
                            
                            <button class="btn-add-to-cart weline-pixel::add_to_cart" data-product-id="<?= $product['id'] ?>">
                                <i class="ri-shopping-cart-line weline-pixel::add_to_cart"></i>
                                <span class="weline-pixel::add_to_cart"><?= __('加入购物车') ?></span>
                            </button>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        </div>
        
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-next" type="button">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
    </div>
    
    <div class="widget-footer">
        <a href="/products/new" class="btn-view-all">
            <?= __('查看全部新品') ?>
            <i class="ri-arrow-right-line"></i>
        </a>
    </div>
</div>

<style>
.widget-new-arrivals .product-meta {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 8px;
    font-size: 12px;
    color: var(--success-color, #28a745);
}

.widget-new-arrivals .product-meta i {
    font-size: 14px;
}

.widget-new-arrivals .widget-footer {
    text-align: center;
    margin-top: 30px;
}

.widget-new-arrivals .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 30px;
    border: 2px solid var(--primary-color, #007bff);
    color: var(--primary-color, #007bff);
    text-decoration: none;
    border-radius: 30px;
    font-weight: 600;
    transition: all 0.3s;
}

.widget-new-arrivals .btn-view-all:hover {
    background: var(--primary-color, #007bff);
    color: #fff;
}

/* 继承基础产品样式 */
.widget-new-arrivals .product-rating .stars i {
    color: #ffc107;
}

.widget-new-arrivals .product-rating .stars i.ri-star-line {
    color: #ddd;
}
</style>
