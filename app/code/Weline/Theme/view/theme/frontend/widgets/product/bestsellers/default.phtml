.widget-bestsellers .rank-2 { background: linear-gradient(135deg, #e5e7eb, #cbd5e1); color: #475569; }
.widget-bestsellers .rank-3 { background: linear-gradient(135deg, #d97706, #92400e); color: #fff; }
.widget-bestsellers .product-badges { position: absolute; left: 10px; bottom: 10px; }
.widget-bestsellers .badge-hot { display: inline-flex; align-items: center; border-radius: 999px; background: linear-gradient(135deg, #ff6b6b, #ee5253); color: #fff; padding: .25rem .55rem; font-size: .75rem; font-weight: 700; }
.widget-bestsellers .product-actions { position: absolute; top: .75rem; right: .75rem; display: flex; gap: .5rem; }
.widget-bestsellers .action-btn { display: inline-flex; width: 2.25rem; height: 2.25rem; align-items: center; justify-content: center; border: 0; border-radius: 999px; background: rgba(255,255,255,.92); color: var(--color-text-primary, #111827); cursor: pointer; box-shadow: 0 8px 20px rgba(15,23,42,.12); }
.widget-bestsellers .product-card { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
.widget-bestsellers .product-card:hover { transform: translateY(-2px); border-color: var(--color-primary, #2563eb); box-shadow: var(--shadow-md, 0 12px 30px rgba(15,23,42,.10)); }
.widget-bestsellers .product-name { margin: 0; font-size: var(--font-size-base, 1rem); line-height: 1.35; }
.widget-bestsellers .product-name a { color: var(--color-text-primary, #111827); text-decoration: none; }
.widget-bestsellers .product-name a:hover { color: var(--color-primary, #2563eb); }
.widget-bestsellers .product-rating, .widget-bestsellers .product-sales { display: flex; align-items: center; gap: .45rem; color: var(--color-text-secondary, #64748b); font-size: .875rem; }
.widget-bestsellers .stars i { color: #ffc107; }
.widget-bestsellers .product-price { display: flex; align-items: baseline; gap: .5rem; margin-top: auto; }
.widget-bestsellers .price-original { color: var(--color-text-tertiary, #94a3b8); text-decoration: line-through; }
