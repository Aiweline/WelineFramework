<?php
/**
 * Bestsellers product widget.
 *
 * @var \Weline\Framework\View\Template $this
 *
 * @widget.code {bestsellers}
 * @widget.name {热销产品}
 * @widget.description {展示最受欢迎的热销产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content", "sidebar"]}
 * @widget.page_layouts {["homepage", "cms_page", "category", "product"]}
 * @widget.compatible {true}
 */

$title = $this->getData('title') ?? __('热销产品');
$subtitle = $this->getData('subtitle') ?? __('最受欢迎的商品');
$limit = max(1, (int)($this->getData('limit') ?? 8));
$period = (string)($this->getData('period') ?? 'month');
$showSalesCount = (bool)($this->getData('show_sales_count') ?? false);
$columns = (string)($this->getData('columns') ?? '4');
$layout = (string)($this->getData('layout') ?? 'grid');
$placeholder = 'data:image/svg+xml;charset=UTF-8,' . rawurlencode(
    '<svg xmlns="http://www.w3.org/2000/svg" width="640" height="640" viewBox="0 0 640 640"><defs><linearGradient id="g" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#fff7ed"/><stop offset="1" stop-color="#fed7aa"/></linearGradient></defs><rect width="640" height="640" fill="url(#g)"/><path d="M334 120c36 74-18 100-18 150 0 35 28 58 62 45 38-15 42-62 16-108 92 54 122 139 86 219-31 69-94 101-160 101s-129-32-160-101c-34-76-6-158 74-211-8 52 14 82 48 82 39 0 62-40 52-177z" fill="#fb923c"/></svg>'
);

$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $price = 49 + ($i * 37);
    $originalPrice = round($price * (1.1 + (($i % 3) * 0.05)), 2);
    $products[] = [
        'id' => $i,
        'name' => '热销产品 ' . $i,
        'url' => '/product/best-' . $i,
        'image' => $placeholder,
        'price' => $price,
        'original_price' => $originalPrice,
        'rating' => min(5.0, 4.1 + (($i % 5) * 0.1)),
        'review_count' => 80 + ($i * 37),
        'sales_count' => 240 + ($i * 173),
        'rank' => $i,
    ];
}

$realProducts = [];
try {
    $recommendationService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Service\ProductRecommendationService::class);
    $realProducts = $recommendationService->getRecommendations([], $limit);
} catch (\Throwable) {
    $realProducts = [];
}
if ($realProducts !== []) {
    $products = $realProducts;
    foreach ($products as $index => &$product) {
        $productId = (int)($product['product_id'] ?? $product['id'] ?? 0);
        $handle = trim((string)($product['handle'] ?? ''));
        $product['id'] = $productId;
        $product['rank'] = $index + 1;
        $product['url'] = $handle !== '' ? '/product/' . rawurlencode($handle) : '/product/view?id=' . $productId;
        $product['sales_count'] = (int)($product['sales_count'] ?? max(20, (int)($product['review_count'] ?? 0)) * 8 + (($index + 1) * 37));
    }
    unset($product);
}

$widgetKey = (string)($this->getData('_widget_instance_key') ?? ($title . '|' . $limit . '|' . $period . '|' . $columns . '|' . $layout));
$widgetId = 'bestsellers-' . substr(sha1($widgetKey), 0, 12);
?>

<div class="widget-bestsellers widget-products" id="<?= $widgetId ?>" style="width:100%;max-width:var(--layout-max-width,1600px);margin:0 auto;padding:var(--spacing-6,2rem) var(--spacing-4,1.5rem);box-sizing:border-box;">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title">
                    <i class="ri-fire-fill" aria-hidden="true"></i>
                    <?= htmlspecialchars((string)$title, ENT_QUOTES, 'UTF-8') ?>
                </h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= htmlspecialchars((string)$subtitle, ENT_QUOTES, 'UTF-8') ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>

    <div class="products-container layout-<?= htmlspecialchars($layout, ENT_QUOTES, 'UTF-8') ?>">
        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns, ENT_QUOTES, 'UTF-8') ?>" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--spacing-4,1rem);width:100%;box-sizing:border-box;">
                <?php foreach ($products as $product): ?>
                    <article class="product-card" style="display:flex;min-width:0;flex-direction:column;overflow:hidden;border:1px solid var(--color-border-light,#e5e7eb);border-radius:var(--radius-lg,12px);background:var(--color-bg-primary,#fff);box-shadow:var(--shadow-sm,0 1px 2px rgba(15,23,42,.04));">
                        <div class="product-image-wrapper">
                            <?php if ((int)$product['rank'] <= 3): ?>
                                <span class="rank-badge rank-<?= (int)$product['rank'] ?>"><?= (int)$product['rank'] ?></span>
                            <?php endif; ?>
                            <a href="<?= htmlspecialchars((string)$product['url'], ENT_QUOTES, 'UTF-8') ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars((string)$product['image'], ENT_QUOTES, 'UTF-8') ?>"
                                     alt="<?= htmlspecialchars((string)$product['name'], ENT_QUOTES, 'UTF-8') ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>
                            <div class="product-badges">
                                <span class="badge badge-hot">HOT</span>
                            </div>
                            <div class="product-actions">
                                <button class="action-btn btn-wishlist weline-pixel::add_to_wishlist" type="button" title="<?= __('加入收藏') ?>">
                                    <i class="ri-heart-line weline-pixel::add_to_wishlist"></i>
                                </button>
                                <button class="action-btn btn-quickview" type="button" title="<?= __('快速查看') ?>">
                                    <i class="ri-eye-line"></i>
                                </button>
                            </div>
                        </div>

                        <div class="product-info" style="display:flex;width:auto;min-width:0;flex:1;flex-direction:column;gap:.6rem;padding:var(--spacing-4,1rem);box-sizing:border-box;">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars((string)$product['url'], ENT_QUOTES, 'UTF-8') ?>">
                                    <?= htmlspecialchars((string)$product['name'], ENT_QUOTES, 'UTF-8') ?>
                                </a>
                            </h3>
                            <?php if ($showSalesCount): ?>
                                <div class="product-sales">
                                    <i class="ri-shopping-bag-line" aria-hidden="true"></i>
                                    <?= number_format((int)$product['sales_count']) ?> <?= __('已售') ?>
                                </div>
                            <?php endif; ?>
                            <div class="product-rating">
                                <div class="stars" aria-label="<?= number_format((float)$product['rating'], 1) ?>">
                                    <?php for ($s = 1; $s <= 5; $s++): ?>
                                        <i class="ri-star-<?= $s <= floor((float)$product['rating']) ? 'fill' : 'line' ?>"></i>
                                    <?php endfor; ?>
                                </div>
                                <span class="review-count">(<?= (int)$product['review_count'] ?>)</span>
                            </div>
                            <div class="product-price">
                                <?php if ((float)$product['original_price'] > (float)$product['price']): ?>
                                    <span class="price-original">¥<?= number_format((float)$product['original_price'], 2) ?></span>
                                <?php endif; ?>
                                <span class="price-current weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)(float)$product['price'], ENT_QUOTES, 'UTF-8') ?>">¥<?= number_format((float)$product['price'], 2) ?></span>
                            </div>
                            <button class="btn-add-to-cart weline-pixel::add_to_cart" type="button" data-product-id="<?= (int)$product['id'] ?>">
                                <i class="ri-shopping-cart-line weline-pixel::add_to_cart"></i>
                                <span class="weline-pixel::add_to_cart"><?= __('加入购物车') ?></span>
                            </button>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>
    </div>
</div>

<style>
.widget-bestsellers .widget-header { margin-bottom: var(--spacing-5, 1.5rem); }
.widget-bestsellers .widget-title { display: flex; align-items: center; gap: .5rem; margin: 0; color: var(--color-text-primary, #111827); font-size: clamp(1.5rem, 2vw, 2rem); font-weight: var(--font-weight-bold, 700); line-height: 1.2; }
.widget-bestsellers .widget-title i { color: var(--color-primary, #ff6b35); }
.widget-bestsellers .widget-subtitle { margin: .5rem 0 0; color: var(--color-text-secondary, #64748b); }
.widget-bestsellers .products-wrapper { width: 100%; overflow: hidden; }
.widget-bestsellers .product-image-wrapper { position: relative; overflow: hidden; background: var(--color-bg-secondary, #f8fafc); }
.widget-bestsellers .product-image-link { display: block; aspect-ratio: 1 / 1; }
.widget-bestsellers .product-image { display: block; width: 100%; height: 100%; object-fit: cover; }
