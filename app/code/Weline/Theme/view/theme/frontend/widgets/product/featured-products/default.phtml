<script>
(function() {
    const widget = document.getElementById('<?= $widgetId ?>');
    if (!widget) return;
    
    const layout = '<?= $layout ?>';
    
    if (layout === 'carousel') {
        const wrapper = widget.querySelector('.products-grid');
        const prevBtn = widget.querySelector('.carousel-prev');
        const nextBtn = widget.querySelector('.carousel-next');
        
        if (!wrapper || !prevBtn || !nextBtn) return;
        
        const cards = wrapper.querySelectorAll('.product-card');
        const cardWidth = cards[0]?.offsetWidth || 0;
        const gap = 20;
        let currentPosition = 0;
        const maxPosition = Math.max(0, (cards.length - 4) * (cardWidth + gap));
        
        function updatePosition() {
            wrapper.style.transform = 'translateX(-' + currentPosition + 'px)';
        }
        
        prevBtn.addEventListener('click', function() {
            currentPosition = Math.max(0, currentPosition - (cardWidth + gap));
            updatePosition();
        });
        
        nextBtn.addEventListener('click', function() {
            currentPosition = Math.min(maxPosition, currentPosition + (cardWidth + gap));
            updatePosition();
        });
    }
    
    // 加入购物车功能
    widget.querySelectorAll('.btn-add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const productId = this.dataset.productId;
            // 这里应该调用实际的加购API
            console.log('Add to cart:', productId);
            
            // 显示添加动画
            this.innerHTML = '<i class="ri-check-line"></i> <span><?= __('已添加') ?></span>';
            this.style.background = 'var(--success-color, #28a745)';
            
            setTimeout(() => {
                this.innerHTML = '<i class="ri-shopping-cart-line"></i> <span><?= __('加入购物车') ?></span>';
                this.style.background = '';
            }, 2000);
        });
    });
})();
</script>
