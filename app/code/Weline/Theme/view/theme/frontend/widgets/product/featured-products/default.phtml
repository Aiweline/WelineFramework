<?php
/**
 * 推荐产品部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {featured-products}
 * @widget.name {推荐产品}
 * @widget.description {展示精选推荐产品，支持网格和轮播布局}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["homepage", "cms_page", "category"]}
 * 
 * @param title {default="推荐产品",type="string",label="标题"}
 * @param subtitle {default="为您精选的优质商品",type="string",label="副标题"}
 * @param product_ids {default="",type="string",label="产品ID",description="指定产品ID，逗号分隔"}
 * @param limit {default=8,type="number",label="显示数量"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列",5:"5列",6:"6列"}}
 * @param show_price {default=true,type="bool",label="显示价格"}
 * @param show_rating {default=true,type="bool",label="显示评分"}
 * @param show_add_to_cart {default=true,type="bool",label="显示加购按钮"}
 * @param layout {default="grid",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 */

$normalize = static function ($value, string $default = ''): string {
    if (is_string($value) || is_numeric($value)) {
        return (string)$value;
    }
    return $default;
};

$title = $normalize($this->getData('title'), __('推荐产品'));
$subtitle = $normalize($this->getData('subtitle'), __('为您精选的优质商品'));
$productIds = $normalize($this->getData('product_ids'), '');
$limit = (int)($this->getData('limit') ?? 8);
$columns = $normalize($this->getData('columns'), '4');
$showPrice = (bool)($this->getData('show_price') ?? true);
$showRating = (bool)($this->getData('show_rating') ?? true);
$showAddToCart = (bool)($this->getData('show_add_to_cart') ?? true);
$layout = $normalize($this->getData('layout'), 'grid');
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

// 示例产品数据（实际应从产品服务获取）
$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $products[] = [
        'id' => $i,
        'name' => __('示例产品 %d', $i),
        'url' => '/product/' . $i,
        'image' => $placeholder,
        'price' => rand(50, 500),
        'original_price' => rand(50, 500) * 1.2,
        'rating' => rand(35, 50) / 10,
        'review_count' => rand(10, 500),
        'is_new' => rand(0, 1),
        'is_sale' => rand(0, 1),
        'stock' => rand(0, 100),
    ];
}

$widgetId = 'featured-products-' . uniqid();
?>

<div class="widget-featured-products widget-products" id="<?= $widgetId ?>">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="products-container layout-<?= htmlspecialchars($layout) ?>" 
         data-columns="<?= htmlspecialchars($columns) ?>">
        
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-prev" type="button">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        <?php endif; ?>
        
        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns) ?>">
                <?php foreach ($products as $product): ?>
                    <div class="product-card">
                        <div class="product-image-wrapper">
                            <a href="<?= htmlspecialchars($product['url'] ?? '') ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars($product['image'] ?? '') ?>" 
                                     alt="<?= htmlspecialchars($product['name'] ?? '') ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>
                            
                            <!-- 标签 -->
                            <div class="product-badges">
                                <?php if ($product['is_new']): ?>
                                    <span class="badge badge-new"><?= __('NEW') ?></span>
                                <?php endif; ?>
                                <?php if ($product['is_sale']): ?>
                                    <span class="badge badge-sale"><?= __('SALE') ?></span>
                                <?php endif; ?>
                            </div>
                            
                            <!-- 快捷操作 -->
                            <div class="product-actions">
                                <button class="action-btn btn-wishlist" title="<?= __('加入收藏') ?>">
                                    <i class="ri-heart-line"></i>
                                </button>
                                <button class="action-btn btn-quickview" title="<?= __('快速查看') ?>">
                                    <i class="ri-eye-line"></i>
                                </button>
                                <button class="action-btn btn-compare" title="<?= __('加入对比') ?>">
                                    <i class="ri-arrow-left-right-line"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="product-info">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars($product['url'] ?? '') ?>">
                                    <?= htmlspecialchars($product['name'] ?? '') ?>
                                </a>
                            </h3>
                            
                            <?php if ($showRating): ?>
                                <div class="product-rating">
                                    <div class="stars" style="--rating: <?= $product['rating'] ?>;">
                                        <i class="ri-star-fill"></i>
                                        <i class="ri-star-fill"></i>
                                        <i class="ri-star-fill"></i>
                                        <i class="ri-star-fill"></i>
                                        <i class="ri-star-fill"></i>
                                    </div>
                                    <span class="review-count">(<?= $product['review_count'] ?>)</span>
                                </div>
                            <?php endif; ?>
                            
                            <?php if ($showPrice): ?>
                                <div class="product-price">
                                    <?php if ($product['original_price'] > $product['price']): ?>
                                        <span class="price-original">¥<?= number_format($product['original_price'], 2) ?></span>
                                    <?php endif; ?>
                                    <span class="price-current">¥<?= number_format($product['price'], 2) ?></span>
                                </div>
                            <?php endif; ?>
                            
                            <?php if ($showAddToCart): ?>
                                <div class="product-cart">
                                    <?php if ($product['stock'] > 0): ?>
                                        <button class="btn-add-to-cart" data-product-id="<?= $product['id'] ?>">
                                            <i class="ri-shopping-cart-line"></i>
                                            <span><?= __('加入购物车') ?></span>
                                        </button>
                                    <?php else: ?>
                                        <button class="btn-out-of-stock" disabled>
                                            <span><?= __('暂时缺货') ?></span>
                                        </button>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        </div>
        
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-next" type="button">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
    </div>
</div>

