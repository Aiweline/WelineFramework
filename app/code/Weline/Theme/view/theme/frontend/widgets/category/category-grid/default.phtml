<?php
/**
 * 分类网格部件
 * 
 * @var \Weline\Framework\View\Template $this
 */

$title = $this->getData('title') ?? __('热门分类');
$subtitle = $this->getData('subtitle') ?? __('浏览我们的商品分类');
$categoryIds = $this->getData('category_ids') ?? '';
$limit = (int)($this->getData('limit') ?? 8);
$columns = $this->getData('columns') ?? '4';
$showCount = (bool)($this->getData('show_count') ?? true);
$imageRatio = $this->getData('image_ratio') ?? 'square';

// 图片比例映射
$ratioMap = [
    'square'    => '100%',
    'landscape' => '56.25%',
    'portrait'  => '133.33%',
];
$paddingTop = $ratioMap[$imageRatio] ?? '100%';

// 示例分类数据
$categories = [
    ['id' => 1, 'name' => __('电子产品'), 'url' => '/category/electronics', 'image' => '/images/categories/electronics.jpg', 'count' => 156],
    ['id' => 2, 'name' => __('服装鞋帽'), 'url' => '/category/fashion', 'image' => '/images/categories/fashion.jpg', 'count' => 243],
    ['id' => 3, 'name' => __('家居生活'), 'url' => '/category/home', 'image' => '/images/categories/home.jpg', 'count' => 178],
    ['id' => 4, 'name' => __('美妆个护'), 'url' => '/category/beauty', 'image' => '/images/categories/beauty.jpg', 'count' => 134],
    ['id' => 5, 'name' => __('食品生鲜'), 'url' => '/category/food', 'image' => '/images/categories/food.jpg', 'count' => 89],
    ['id' => 6, 'name' => __('母婴用品'), 'url' => '/category/baby', 'image' => '/images/categories/baby.jpg', 'count' => 67],
    ['id' => 7, 'name' => __('运动户外'), 'url' => '/category/sports', 'image' => '/images/categories/sports.jpg', 'count' => 112],
    ['id' => 8, 'name' => __('图书文具'), 'url' => '/category/books', 'image' => '/images/categories/books.jpg', 'count' => 78],
];

$categories = array_slice($categories, 0, $limit);
$widgetId = 'category-grid-' . uniqid();
?>

<div class="widget-category-grid" id="<?= $widgetId ?>">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="category-grid columns-<?= htmlspecialchars($columns) ?>">
        <?php foreach ($categories as $category): ?>
            <a href="<?= htmlspecialchars($category['url']) ?>" class="category-card">
                <div class="category-image-wrapper" style="padding-top: <?= $paddingTop ?>;">
                    <img src="<?= htmlspecialchars($category['image']) ?>" 
                         alt="<?= htmlspecialchars($category['name']) ?>"
                         class="category-image"
                         loading="lazy">
                    <div class="category-overlay"></div>
                </div>
                
                <div class="category-info">
                    <h3 class="category-name"><?= htmlspecialchars($category['name']) ?></h3>
                    <?php if ($showCount): ?>
                        <span class="category-count"><?= $category['count'] ?> <?= __('件商品') ?></span>
                    <?php endif; ?>
                </div>
            </a>
        <?php endforeach; ?>
    </div>
</div>

