<?php
/**
 * 迷你购物车部件
 * 
 * @var \Weline\Framework\View\Template $this
 */

$title = $this->getData('title') ?? __('购物车');
$maxItems = (int)($this->getData('max_items') ?? 5);
$showSubtotal = (bool)($this->getData('show_subtotal') ?? true);
$showCheckoutButton = (bool)($this->getData('show_checkout_button') ?? true);
$showViewCartButton = (bool)($this->getData('show_view_cart_button') ?? true);

// 示例购物车数据
$cartItems = [
    ['id' => 1, 'name' => __('示例商品 1'), 'image' => '/images/products/1.jpg', 'price' => 99.00, 'qty' => 2],
    ['id' => 2, 'name' => __('示例商品 2'), 'image' => '/images/products/2.jpg', 'price' => 149.00, 'qty' => 1],
    ['id' => 3, 'name' => __('示例商品 3'), 'image' => '/images/products/3.jpg', 'price' => 79.00, 'qty' => 1],
];

$cartItems = array_slice($cartItems, 0, $maxItems);
$subtotal = array_sum(array_map(fn($item) => $item['price'] * $item['qty'], $cartItems));
$itemCount = count($cartItems);

$widgetId = 'mini-cart-' . uniqid();
?>

<div class="widget-mini-cart" id="<?= $widgetId ?>">
    <div class="widget-header">
        <h3 class="widget-title">
            <i class="ri-shopping-cart-2-line"></i>
            <?= htmlspecialchars($title) ?>
            <span class="item-count">(<?= $itemCount ?>)</span>
        </h3>
    </div>
    
    <?php if (empty($cartItems)): ?>
        <div class="cart-empty">
            <i class="ri-shopping-cart-line"></i>
            <p><?= __('购物车是空的') ?></p>
            <a href="/products" class="btn-shop"><?= __('去购物') ?></a>
        </div>
    <?php else: ?>
        <div class="cart-items">
            <?php foreach ($cartItems as $item): ?>
                <div class="cart-item" data-item-id="<?= $item['id'] ?>">
                    <img src="<?= htmlspecialchars($item['image']) ?>" 
                         alt="<?= htmlspecialchars($item['name']) ?>"
                         class="item-image">
                    
                    <div class="item-details">
                        <h4 class="item-name"><?= htmlspecialchars($item['name']) ?></h4>
                        <div class="item-meta">
                            <span class="item-price">¥<?= number_format($item['price'], 2) ?></span>
                            <span class="item-qty">× <?= $item['qty'] ?></span>
                        </div>
                    </div>
                    
                    <button class="item-remove" type="button" title="<?= __('删除') ?>">
                        <i class="ri-close-line"></i>
                    </button>
                </div>
            <?php endforeach; ?>
        </div>
        
        <?php if ($showSubtotal): ?>
            <div class="cart-subtotal">
                <span class="label"><?= __('小计') ?>:</span>
                <span class="value">¥<?= number_format($subtotal, 2) ?></span>
            </div>
        <?php endif; ?>
        
        <div class="cart-actions">
            <?php if ($showViewCartButton): ?>
                <a href="/cart" class="btn btn-outline"><?= __('查看购物车') ?></a>
            <?php endif; ?>
            <?php if ($showCheckoutButton): ?>
                <a href="/checkout" class="btn btn-primary"><?= __('去结算') ?></a>
            <?php endif; ?>
        </div>
    <?php endif; ?>
</div>

