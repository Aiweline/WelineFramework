<?php
/**
 * Header 购物车图标部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {mini-cart-icon}
 * @widget.name {Header 购物车}
 * @widget.description {购物车图标，显示购物车商品数量和小计}
 * @widget.type {header}
 * @widget.area {frontend}
 * @widget.position {["header"]}
 * @widget.page_layouts {["*"]}
 * @widget.slot {user-area}
 * 
 * @param show_quantity {default=true,type="bool",label="显示数量"}
 * @param show_subtotal {default=true,type="bool",label="显示小计"}
 * @param icon_style {default="cart",type="select",label="图标样式",options={cart:"购物车",bag:"购物袋",basket:"购物篮"}}
 */

$showQuantity = (bool)($this->getData('show_quantity') ?? true);
$showSubtotal = (bool)($this->getData('show_subtotal') ?? true);
$iconStyle = $this->getData('icon_style') ?? 'cart';
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png') ?? '';

// 图标映射
$icons = [
    'cart'   => 'ri-shopping-cart-line',
    'bag'    => 'ri-shopping-bag-line',
    'basket' => 'ri-shopping-basket-line',
];
$icon = $icons[$iconStyle] ?? $icons['cart'];

// 示例数据（实际应从购物车服务获取）
$cartQuantity = 3;
$cartSubtotal = '¥299.00';
?>

<div class="widget-mini-cart-icon">
    <a href="/cart" class="cart-link" title="<?= __('购物车') ?>">
        <span class="cart-icon-wrapper">
            <i class="<?= $icon ?>"></i>
            <?php if ($showQuantity && $cartQuantity > 0): ?>
                <span class="cart-count"><?= $cartQuantity > 99 ? '99+' : $cartQuantity ?></span>
            <?php endif; ?>
        </span>
        
        <?php if ($showSubtotal): ?>
            <span class="cart-info">
                <span class="cart-label"><?= __('购物车') ?></span>
                <span class="cart-subtotal"><?= htmlspecialchars($cartSubtotal) ?></span>
            </span>
        <?php endif; ?>
    </a>
    
    <!-- 迷你购物车下拉 -->
    <div class="mini-cart-dropdown">
        <div class="mini-cart-header">
            <span class="mini-cart-title"><?= __('购物车') ?> (<span class="item-count"><?= $cartQuantity ?></span>)</span>
        </div>
        
        <div class="mini-cart-items">
            <!-- 示例商品 -->
            <div class="mini-cart-item">
                <img src="<?= htmlspecialchars($placeholder ?? '') ?>" alt="Product" class="item-image">
                <div class="item-info">
                    <h4 class="item-name"><?= __('示例商品名称') ?></h4>
                    <span class="item-price">¥99.00 × 1</span>
                </div>
                <button class="item-remove" title="<?= __('删除') ?>">
                    <i class="ri-close-line"></i>
                </button>
            </div>
            <!-- 更多商品... -->
        </div>
        
        <div class="mini-cart-footer">
            <div class="mini-cart-total">
                <span><?= __('小计') ?>:</span>
                <span class="total-amount"><?= htmlspecialchars($cartSubtotal) ?></span>
            </div>
            <div class="mini-cart-actions">
                <a href="/cart" class="btn btn-outline"><?= __('查看购物车') ?></a>
                <a href="/checkout" class="btn btn-primary"><?= __('去结算') ?></a>
            </div>
        </div>
    </div>
</div>

