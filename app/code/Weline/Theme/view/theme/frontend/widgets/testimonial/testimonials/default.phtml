    margin-bottom: 15px;
}

.widget-testimonials .testimonial-rating i {
    color: #ffc107;
    font-size: 16px;
}

.widget-testimonials .testimonial-rating i.ri-star-line {
    color: #ddd;
}

.widget-testimonials .testimonial-content {
    font-size: 15px;
    line-height: 1.7;
    color: #555;
    margin: 0 0 20px;
    font-style: italic;
}

.widget-testimonials .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
}

.widget-testimonials .author-avatar {
    width: 50px;
