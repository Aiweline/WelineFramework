<?php
/**
 * 客户评价部件
 * 
 * @var \Weline\Framework\View\Template $this
 */

$title = $this->getData('title') ?? __('客户评价');
$subtitle = $this->getData('subtitle') ?? __('看看客户怎么说');
$testimonials = $this->getData('testimonials') ?? [];
$columns = $this->getData('columns') ?? '3';
$layout = $this->getData('layout') ?? 'grid';
$showRating = (bool)($this->getData('show_rating') ?? true);
$showAvatar = (bool)($this->getData('show_avatar') ?? true);
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

// 示例数据
if (empty($testimonials)) {
    $testimonials = [
        [
            'content' => __('产品质量非常好，物流速度也很快，下次还会继续购买！'),
            'author' => '张先生',
            'position' => __('企业客户'),
            'avatar' => $placeholder,
            'rating' => 5,
        ],
        [
            'content' => __('客服态度很好，有问题都能及时解决，购物体验非常满意。'),
            'author' => '李女士',
            'position' => __('普通用户'),
            'avatar' => $placeholder,
            'rating' => 5,
        ],
        [
            'content' => __('价格实惠，性价比很高，已经推荐给身边的朋友了。'),
            'author' => '王先生',
            'position' => __('VIP会员'),
            'avatar' => $placeholder,
            'rating' => 4,
        ],
    ];
}

$widgetId = 'testimonials-' . uniqid();
?>

<div class="widget-testimonials" id="<?= $widgetId ?>">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title"><?= htmlspecialchars($title) ?></h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= htmlspecialchars($subtitle) ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="testimonials-container layout-<?= htmlspecialchars($layout) ?>">
        <div class="testimonials-grid columns-<?= htmlspecialchars($columns) ?>">
            <?php foreach ($testimonials as $testimonial): ?>
                <div class="testimonial-card">
                    <div class="testimonial-quote">
                        <i class="ri-double-quotes-l"></i>
                    </div>
                    
                    <?php if ($showRating && isset($testimonial['rating'])): ?>
                        <div class="testimonial-rating">
                            <?php for ($i = 1; $i <= 5; $i++): ?>
                                <i class="ri-star-<?= $i <= $testimonial['rating'] ? 'fill' : 'line' ?>"></i>
                            <?php endfor; ?>
                        </div>
                    <?php endif; ?>
                    
                    <p class="testimonial-content"><?= htmlspecialchars($testimonial['content'] ?? '') ?></p>
                    
                    <div class="testimonial-author">
                        <?php if ($showAvatar && !empty($testimonial['avatar'])): ?>
                            <img src="<?= htmlspecialchars($testimonial['avatar'] ?? '') ?>" 
                                 alt="<?= htmlspecialchars($testimonial['author'] ?? '') ?>"
                                 class="author-avatar">
                        <?php endif; ?>
                        
                        <div class="author-info">
                            <h4 class="author-name"><?= htmlspecialchars($testimonial['author'] ?? '') ?></h4>
                            <?php if (!empty($testimonial['position'])): ?>
                                <span class="author-position"><?= htmlspecialchars($testimonial['position'] ?? '') ?></span>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</div>

