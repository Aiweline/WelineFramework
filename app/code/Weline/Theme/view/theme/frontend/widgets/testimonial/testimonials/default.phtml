<?php
/**
 * 客户评价部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {testimonials}
 * @widget.name {客户评价}
 * @widget.description {展示客户评价和推荐语}
 * @widget.type {testimonial}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["homepage", "cms_page"]}
 * 
 * @param title {default="客户评价",type="string",label="标题"}
 * @param subtitle {default="看看客户怎么说",type="string",label="副标题"}
 * @param testimonials {default=[],type="array",label="评价列表",description="每项包含name、avatar、content、rating、company"}
 * @param columns {default="3",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列"}}
 * @param layout {default="grid",type="select",label="布局",options={grid:"网格",carousel:"轮播"}}
 */

$title = $this->getData('title') ?? __('客户评价');
$subtitle = $this->getData('subtitle') ?? __('看看客户怎么说');
$testimonials = $this->getData('testimonials') ?? [];
$columns = $this->getData('columns') ?? '3';
$layout = $this->getData('layout') ?? 'grid';
$showRating = (bool)($this->getData('show_rating') ?? true);
$showAvatar = (bool)($this->getData('show_avatar') ?? true);
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');

// 示例数据
if (empty($testimonials)) {
    $testimonials = [
        [
            'content' => __('产品质量非常好，物流速度也很快，下次还会继续购买！'),
            'author' => '张先生',
            'position' => __('企业客户'),
            'avatar' => $placeholder,
            'rating' => 5,
        ],
        [
            'content' => __('客服态度很好，有问题都能及时解决，购物体验非常满意。'),
            'author' => '李女士',
            'position' => __('普通用户'),
            'avatar' => $placeholder,
            'rating' => 5,
        ],
        [
            'content' => __('价格实惠，性价比很高，已经推荐给身边的朋友了。'),
            'author' => '王先生',
            'position' => __('VIP会员'),
            'avatar' => $placeholder,
            'rating' => 4,
        ],
    ];
}

$widgetId = 'testimonials-' . uniqid();

// 确保传给 htmlspecialchars 的为字符串（部件参数有时为数组）
$esc = function ($v) {
    if (is_string($v)) {
        return htmlspecialchars($v, ENT_QUOTES, 'UTF-8');
    }
    if (is_array($v)) {
        return htmlspecialchars(implode(', ', array_map('strval', $v)), ENT_QUOTES, 'UTF-8');
    }
    return htmlspecialchars((string) $v, ENT_QUOTES, 'UTF-8');
};
?>

<div class="widget-testimonials" id="<?= $widgetId ?>">
    <?php if ($title || $subtitle): ?>
        <div class="widget-header">
            <?php if ($title): ?>
                <h2 class="widget-title"><?= $esc($title) ?></h2>
            <?php endif; ?>
            <?php if ($subtitle): ?>
                <p class="widget-subtitle"><?= $esc($subtitle) ?></p>
            <?php endif; ?>
        </div>
    <?php endif; ?>
    
    <div class="testimonials-container layout-<?= $esc($layout) ?>">
        <div class="testimonials-grid columns-<?= $esc($columns) ?>">
            <?php foreach ($testimonials as $testimonial): ?>
                <div class="testimonial-card">
                    <div class="testimonial-quote">
                        <i class="ri-double-quotes-l"></i>
                    </div>
                    
                    <?php if ($showRating && isset($testimonial['rating'])): ?>
                        <div class="testimonial-rating">
                            <?php for ($i = 1; $i <= 5; $i++): ?>
                                <i class="ri-star-<?= $i <= $testimonial['rating'] ? 'fill' : 'line' ?>"></i>
                            <?php endfor; ?>
                        </div>
                    <?php endif; ?>
                    
                    <p class="testimonial-content"><?= $esc($testimonial['content'] ?? '') ?></p>
                    
                    <div class="testimonial-author">
                        <?php if ($showAvatar && !empty($testimonial['avatar'])): ?>
                            <img src="<?= $esc($testimonial['avatar'] ?? '') ?>" 
                                 alt="<?= $esc($testimonial['author'] ?? '') ?>"
                                 class="author-avatar">
                        <?php endif; ?>
                        
                        <div class="author-info">
                            <h4 class="author-name"><?= $esc($testimonial['author'] ?? '') ?></h4>
                            <?php if (!empty($testimonial['position'])): ?>
                                <span class="author-position"><?= $esc($testimonial['position'] ?? '') ?></span>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</div>

<style>
.widget-testimonials {
    padding: 60px 0;
    background: #f9f9f9;
}

.widget-testimonials .widget-header {
    text-align: center;
    margin-bottom: 40px;
}

.widget-testimonials .widget-title {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 10px;
}

.widget-testimonials .widget-subtitle {
    font-size: 16px;
    color: #666;
    margin: 0;
}

.widget-testimonials .testimonials-grid {
    display: grid;
    gap: 30px;
}

.widget-testimonials .testimonials-grid.columns-1 { grid-template-columns: 1fr; max-width: 700px; margin: 0 auto; }
.widget-testimonials .testimonials-grid.columns-2 { grid-template-columns: repeat(2, 1fr); }
.widget-testimonials .testimonials-grid.columns-3 { grid-template-columns: repeat(3, 1fr); }

.widget-testimonials .testimonial-card {
    background: #fff;
    border-radius: 16px;
    padding: 30px;
    position: relative;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: all 0.3s;
}

.widget-testimonials .testimonial-card:hover {
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    transform: translateY(-5px);
}

