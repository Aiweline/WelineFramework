<?php
/**
 * Header 用户账户部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * 参数说明：
 * - show_avatar: 显示头像
 * - show_name: 显示用户名
 * - dropdown_items: 下拉菜单项
 */

$showAvatar = (bool)($this->getData('show_avatar') ?? true);
$showName = (bool)($this->getData('show_name') ?? false);
$dropdownItems = $this->getData('dropdown_items') ?? [];

// 示例：检查登录状态（实际应从Session获取）
$isLoggedIn = false;
$userName = '用户名';
$userAvatar = '';

// 默认下拉菜单
if (empty($dropdownItems)) {
    $dropdownItems = [
        ['label' => __('我的账户'), 'url' => '/account', 'icon' => 'ri-user-line'],
        ['label' => __('我的订单'), 'url' => '/account/orders', 'icon' => 'ri-file-list-line'],
        ['label' => __('我的收藏'), 'url' => '/account/wishlist', 'icon' => 'ri-heart-line'],
        ['label' => __('地址管理'), 'url' => '/account/addresses', 'icon' => 'ri-map-pin-line'],
        ['type' => 'divider'],
        ['label' => __('退出登录'), 'url' => '/account/logout', 'icon' => 'ri-logout-box-line'],
    ];
}
?>

<div class="widget-header-account">
    <?php if ($isLoggedIn): ?>
        <!-- 已登录状态 -->
        <div class="account-logged-in">
            <a href="/account" class="account-link">
                <?php if ($showAvatar): ?>
                    <span class="account-avatar">
                        <?php if ($userAvatar): ?>
                            <img src="<?= htmlspecialchars($userAvatar) ?>" alt="<?= htmlspecialchars($userName) ?>">
                        <?php else: ?>
                            <i class="ri-user-line"></i>
                        <?php endif; ?>
                    </span>
                <?php endif; ?>
                
                <?php if ($showName): ?>
                    <span class="account-name"><?= htmlspecialchars($userName) ?></span>
                <?php endif; ?>
                
                <i class="ri-arrow-down-s-line dropdown-arrow"></i>
            </a>
            
            <!-- 下拉菜单 -->
            <div class="account-dropdown">
                <div class="dropdown-header">
                    <span class="welcome-text"><?= __('欢迎回来') ?></span>
                    <span class="user-name"><?= htmlspecialchars($userName) ?></span>
                </div>
                <ul class="dropdown-menu">
                    <?php foreach ($dropdownItems as $item): ?>
                        <?php if (($item['type'] ?? '') === 'divider'): ?>
                            <li class="divider"></li>
                        <?php else: ?>
                            <li>
                                <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>">
                                    <?php if (!empty($item['icon'])): ?>
                                        <i class="<?= htmlspecialchars($item['icon']) ?>"></i>
                                    <?php endif; ?>
                                    <?= htmlspecialchars($item['label'] ?? '') ?>
                                </a>
                            </li>
                        <?php endif; ?>
                    <?php endforeach; ?>
                </ul>
            </div>
        </div>
    <?php else: ?>
        <!-- 未登录状态 -->
        <div class="account-guest">
            <a href="/account/login" class="account-link">
                <span class="account-avatar">
                    <i class="ri-user-line"></i>
                </span>
                <span class="account-text">
                    <span class="login-text"><?= __('登录') ?></span>
                    <span class="register-text"><?= __('注册') ?></span>
                </span>
            </a>
        </div>
    <?php endif; ?>
</div>

