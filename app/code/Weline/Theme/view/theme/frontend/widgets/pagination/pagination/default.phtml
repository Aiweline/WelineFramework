<?php
/**
 * 分页部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {pagination}
 * @widget.name {分页}
 * @widget.description {列表分页导航}
 * @widget.type {pagination}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["category", "search", "cms_page"]}
 * @widget.supports {["layout-category-pagination","layout-product-list-pagination"]}
 * 
 * @param style {default="default",type="select",label="样式",options={default:"默认",simple:"简洁",minimal:"极简"}}
 * @param show_first_last {default=true,type="bool",label="显示首尾按钮"}
 * @param show_prev_next {default=true,type="bool",label="显示上下页按钮"}
 * @param page_range {default=5,type="number",label="显示页码数量"}
 * @param prev_text {default="上一页",type="string",label="上一页文字"}
 * @param next_text {default="下一页",type="string",label="下一页文字"}
 */

$style = $this->getData('style') ?? 'default';
$showFirstLast = (bool)($this->getData('show_first_last') ?? true);
$showPrevNext = (bool)($this->getData('show_prev_next') ?? true);
$pageRange = (int)($this->getData('page_range') ?? 5);
$prevText = $this->getData('prev_text') ?? __('上一页');
$nextText = $this->getData('next_text') ?? __('下一页');

// 分页数据（应从系统获取）
$currentPage = (int)($this->getData('current_page') ?? 1);
$totalPages = (int)($this->getData('total_pages') ?? 10);
$baseUrl = $this->getData('base_url') ?? '?page=';

// 计算显示的页码范围
$startPage = max(1, $currentPage - floor($pageRange / 2));
$endPage = min($totalPages, $startPage + $pageRange - 1);
if ($endPage - $startPage + 1 < $pageRange) {
    $startPage = max(1, $endPage - $pageRange + 1);
}

$widgetId = 'pagination-' . uniqid();

if ($totalPages <= 1) return; // 只有一页时不显示
?>

<nav class="widget-pagination style-<?= htmlspecialchars($style) ?>" id="<?= $widgetId ?>" aria-label="<?= __('分页导航') ?>">
    <ul class="w-pagination-list">
        <?php if ($showFirstLast && $currentPage > 1): ?>
            <li class="w-page-item">
                <a href="<?= htmlspecialchars($baseUrl . '1') ?>" class="w-page-link page-first" title="<?= __('第一页') ?>">
                    <i class="ri-skip-back-line"></i>
                </a>
            </li>
        <?php endif; ?>
        
        <?php if ($showPrevNext): ?>
            <li class="w-page-item <?= $currentPage <= 1 ? 'w-disabled' : '' ?>">
                <?php if ($currentPage > 1): ?>
                    <a href="<?= htmlspecialchars($baseUrl . ($currentPage - 1)) ?>" class="w-page-link page-prev">
                        <i class="ri-arrow-left-s-line"></i>
                        <span><?= htmlspecialchars($prevText) ?></span>
                    </a>
                <?php else: ?>
                    <span class="w-page-link page-prev">
                        <i class="ri-arrow-left-s-line"></i>
                        <span><?= htmlspecialchars($prevText) ?></span>
                    </span>
                <?php endif; ?>
            </li>
        <?php endif; ?>
        
        <?php if ($startPage > 1): ?>
            <li class="w-page-item">
                <a href="<?= htmlspecialchars($baseUrl . '1') ?>" class="w-page-link">1</a>
            </li>
            <?php if ($startPage > 2): ?>
                <li class="w-page-item w-ellipsis"><span class="w-page-link">...</span></li>
            <?php endif; ?>
        <?php endif; ?>
        
        <?php for ($i = $startPage; $i <= $endPage; $i++): ?>
            <li class="w-page-item <?= $i === $currentPage ? 'w-active' : '' ?>">
                <?php if ($i === $currentPage): ?>
                    <span class="w-page-link" aria-current="page"><?= $i ?></span>
                <?php else: ?>
                    <a href="<?= htmlspecialchars($baseUrl . $i) ?>" class="w-page-link"><?= $i ?></a>
                <?php endif; ?>
            </li>
        <?php endfor; ?>
        
        <?php if ($endPage < $totalPages): ?>
            <?php if ($endPage < $totalPages - 1): ?>
                <li class="w-page-item w-ellipsis"><span class="w-page-link">...</span></li>
            <?php endif; ?>
            <li class="w-page-item">
                <a href="<?= htmlspecialchars($baseUrl . $totalPages) ?>" class="w-page-link"><?= $totalPages ?></a>
            </li>
        <?php endif; ?>
        
        <?php if ($showPrevNext): ?>
            <li class="w-page-item <?= $currentPage >= $totalPages ? 'w-disabled' : '' ?>">
                <?php if ($currentPage < $totalPages): ?>
                    <a href="<?= htmlspecialchars($baseUrl . ($currentPage + 1)) ?>" class="w-page-link page-next">
                        <span><?= htmlspecialchars($nextText) ?></span>
                        <i class="ri-arrow-right-s-line"></i>
                    </a>
                <?php else: ?>
                    <span class="w-page-link page-next">
                        <span><?= htmlspecialchars($nextText) ?></span>
                        <i class="ri-arrow-right-s-line"></i>
                    </span>
                <?php endif; ?>
            </li>
        <?php endif; ?>
        
        <?php if ($showFirstLast && $currentPage < $totalPages): ?>
            <li class="w-page-item">
                <a href="<?= htmlspecialchars($baseUrl . $totalPages) ?>" class="w-page-link page-last" title="<?= __('最后一页') ?>">
                    <i class="ri-skip-forward-line"></i>
                </a>
            </li>
        <?php endif; ?>
    </ul>
</nav>

<style>
