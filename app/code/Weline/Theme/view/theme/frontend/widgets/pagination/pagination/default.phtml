    background: var(--weline-theme-surface);
    transition: all var(--weline-theme-transition-base);
}

.widget-pagination .w-page-link:hover {
    border-color: var(--weline-theme-primary);
    color: var(--weline-theme-primary);
}

.widget-pagination .w-page-item.w-active .w-page-link {
    background: var(--weline-theme-primary);
