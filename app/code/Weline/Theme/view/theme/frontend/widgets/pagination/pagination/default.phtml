}

/* 默认样式 */
.widget-pagination.style-default .w-page-link {
    border-radius: 6px;
}

/* 简洁样式 */
.widget-pagination.style-simple .w-page-link {
    border: none;
    background: none;
}

.widget-pagination.style-simple .w-page-item.w-active .w-page-link {
    background: var(--weline-theme-primary);
