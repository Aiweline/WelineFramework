}

/* 圆角样式 */
.widget-pagination.style-rounded .w-page-link {
    border-radius: 50%;
}

.widget-pagination.style-rounded .page-prev,
.widget-pagination.style-rounded .page-next {
    border-radius: 20px;
}

@media (max-width: 576px) {
    .widget-pagination .page-prev span,
    .widget-pagination .page-next span {
        display: none;
    }
    
    .widget-pagination .w-page-link {
