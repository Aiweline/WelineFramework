<?php
/**
 * 页脚社交图标部件
 * 
 * 显示社交媒体链接图标，支持多种样式和布局
 * 
 * @widget.code {footer-social}
 * @widget.name {页脚社交图标}
 * @widget.description {Footer 区域的社交媒体图标链接}
 * @widget.type {social}
 * @widget.area {frontend}
 * @widget.position {["footer"]}
 * @widget.page_layouts {["*"]}
 * @widget.slot {social}
 * @widget.exclusive {true}
 * 
 * @param title {default="",name="标题",description="部件标题，可选",type=string}
 * @param custom_links {default="",name="自定义社交链接",description="JSON格式的自定义社交链接配置，格式：[{\"platform\":\"facebook\",\"url\":\"https://...\"}]",type=string}
 * @param alignment {default="left",name="对齐方式",description="图标对齐方式",type=select,options={left:"左对齐",center:"居中",right:"右对齐"}}
 * @param icon_size {default="medium",name="图标尺寸",description="图标大小",type=select,options={small:"小号",medium:"中号",large:"大号"}}
 * @param icon_style {default="colored",name="图标样式",description="图标显示样式",type=select,options={colored:"彩色",mono:"单色",outline:"线框"}}
 * @param gap {default="10px",name="图标间距",description="图标之间的间距，支持CSS单位（如10px、1rem）",type=string}
 * @param facebook {default="",name="Facebook链接",description="Facebook主页链接",type=string}
 * @param twitter {default="",name="Twitter/X链接",description="Twitter/X主页链接",type=string}
 * @param instagram {default="",name="Instagram链接",description="Instagram主页链接",type=string}
 * @param youtube {default="",name="YouTube链接",description="YouTube频道链接",type=string}
 * @param linkedin {default="",name="LinkedIn链接",description="LinkedIn主页链接",type=string}
 * @param pinterest {default="",name="Pinterest链接",description="Pinterest主页链接",type=string}
 * @param tiktok {default="",name="TikTok链接",description="TikTok主页链接",type=string}
 * @param weibo {default="",name="微博链接",description="微博主页链接",type=string}
 * @param wechat {default="",name="微信链接",description="微信公众号链接",type=string}
 * @param github {default="",name="GitHub链接",description="GitHub主页链接",type=string}
 * @param telegram {default="",name="Telegram链接",description="Telegram频道链接",type=string}
 * @param whatsapp {default="",name="WhatsApp链接",description="WhatsApp联系链接",type=string}
 * @param discord {default="",name="Discord链接",description="Discord服务器链接",type=string}
 * @param reddit {default="",name="Reddit链接",description="Reddit社区链接",type=string}
 * @param snapchat {default="",name="Snapchat链接",description="Snapchat主页链接",type=string}
 * 
 * @var \Weline\Framework\View\Template $this
 */

use Weline\Theme\Helper\SocialIconHelper;

$title = $this->getData('title') ?? '';
$alignment = $this->getData('alignment') ?? 'left'; // left, center, right
$iconSize = $this->getData('icon_size') ?? 'medium'; // small, medium, large
$iconStyle = $this->getData('icon_style') ?? 'colored'; // colored, mono, outline
$gap = $this->getData('gap') ?? '10px'; // 图标间距

// 获取自定义社交链接配置（JSON 格式）
$customLinks = $this->getData('custom_links') ?? '';
$socials = [];

// 如果有自定义配置，解析 JSON
if ($customLinks) {
    $customLinksArray = json_decode($customLinks, true);
    if (is_array($customLinksArray)) {
        foreach ($customLinksArray as $link) {
            if (!empty($link['platform']) && !empty($link['url'])) {
                $platform = $link['platform'];
                $socials[] = [
                    'platform' => $platform,
                    'name' => SocialIconHelper::getName($platform) ?? $link['name'] ?? $platform,
                    'url' => $link['url'],
                    'color' => SocialIconHelper::getColor($platform) ?? '#666'
                ];
            }
        }
    }
}

// 如果没有自定义配置，使用传统的单独字段配置
if (empty($socials)) {
    $platforms = ['facebook', 'twitter', 'instagram', 'youtube', 'linkedin', 'pinterest', 'tiktok', 'weibo', 'wechat', 'github', 'telegram', 'whatsapp', 'discord', 'reddit', 'snapchat'];
    
    foreach ($platforms as $platform) {
        $url = $this->getData($platform) ?? '';
        if ($url) {
            $socials[] = [
                'platform' => $platform,
                'name' => SocialIconHelper::getName($platform) ?? ucfirst($platform),
                'url' => $url,
                'color' => SocialIconHelper::getColor($platform) ?? '#666'
            ];
        }
    }
}

// 示例数据（如果没有任何配置）
if (empty($socials)) {
    $socials = [
        ['platform' => 'facebook', 'name' => 'Facebook', 'url' => '#', 'color' => '#1877f2'],
        ['platform' => 'twitter', 'name' => 'Twitter/X', 'url' => '#', 'color' => '#000000'],
        ['platform' => 'instagram', 'name' => 'Instagram', 'url' => '#', 'color' => '#e4405f'],
        ['platform' => 'youtube', 'name' => 'YouTube', 'url' => '#', 'color' => '#ff0000'],
    ];
}

$widgetId = 'footer-social-' . uniqid();
?>

<div class="widget-footer-social" id="<?= $widgetId ?>" data-size="<?= htmlspecialchars($iconSize) ?>" data-style="<?= htmlspecialchars($iconStyle) ?>" data-align="<?= htmlspecialchars($alignment) ?>">
    <?php if ($title): ?>
        <h4 class="social-title"><?= htmlspecialchars($title) ?></h4>
    <?php endif; ?>
    
    <div class="social-links" style="--social-gap: <?= htmlspecialchars($gap) ?>;">
        <?php foreach ($socials as $social): ?>
            <a href="<?= htmlspecialchars($social['url']) ?>" 
               class="social-link social-link-<?= htmlspecialchars($social['platform']) ?>"
               title="<?= htmlspecialchars($social['name']) ?>"
               target="_blank"
               rel="noopener noreferrer"
               style="--brand-color: <?= htmlspecialchars($social['color']) ?>;">
                <?= SocialIconHelper::renderIcon($social['platform'], ['class' => 'social-icon', 'width' => '20', 'height' => '20']) ?>
            </a>
        <?php endforeach; ?>
    </div>
</div>

<style>
