    /* 重置外部样式影响 */
    all: initial;
    display: block;
    box-sizing: border-box;
}

#<?= $widgetId ?> * {
    box-sizing: border-box;
}

#<?= $widgetId ?> .social-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 15px;
    color: #fff;
    font-family: inherit;
}

#<?= $widgetId ?> .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--social-gap, 10px);
}

/* 对齐方式 */
#<?= $widgetId ?>[data-align="left"] .social-links {
    justify-content: flex-start;
}

#<?= $widgetId ?>[data-align="center"] .social-links {
    justify-content: center;
}

#<?= $widgetId ?>[data-align="right"] .social-links {
    justify-content: flex-end;
}

#<?= $widgetId ?> .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.3s ease;
    text-decoration: none;
    cursor: pointer;
}

#<?= $widgetId ?> .social-link .social-icon {
    display: block;
}

