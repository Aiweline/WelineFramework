<?php
/**
 * 广告横幅部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {ad-banner}
 * @widget.name {广告横幅}
 * @widget.description {通用广告横幅，支持图片链接}
 * @widget.type {banner}
 * @widget.area {frontend}
 * @widget.position {["content", "sidebar"]}
 * @widget.page_layouts {["*"]}
 * 
 * @param image {default="",type="image",label="广告图片"}
 * @param link {default="",type="string",label="链接地址"}
 * @param alt_text {default="广告",type="string",label="替代文字"}
 * @param open_new_tab {default=false,type="bool",label="新窗口打开"}
 * @param border_radius {default="8px",type="string",label="圆角大小"}
 */

$image = $this->getData('image') ?? '';
$link = $this->getData('link') ?? '';
$altText = $this->getData('alt_text') ?? __('广告');
$openNewTab = (bool)($this->getData('open_new_tab') ?? false);
$borderRadius = $this->getData('border_radius') ?? '8px';
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png') ?? '';

// 示例图片
if (empty($image)) {
    $image = $placeholder;
}
?>

<div class="widget-ad-banner" style="border-radius: <?= htmlspecialchars($borderRadius ?? '') ?>;">
    <?php if ($link): ?>
        <a href="<?= htmlspecialchars($link ?? '') ?>" 
           class="ad-link"
           <?= $openNewTab ? 'target="_blank" rel="noopener noreferrer"' : '' ?>>
    <?php endif; ?>
    
    <img src="<?= htmlspecialchars($image ?? '') ?>" 
         alt="<?= htmlspecialchars($altText ?? '') ?>" 
         class="ad-image"
         loading="lazy">
    
    <span class="ad-label"><?= __('广告') ?></span>
    
    <?php if ($link): ?>
        </a>
    <?php endif; ?>
</div>

<style>
.widget-ad-banner {
    position: relative;
    overflow: hidden;
    display: block;
    width: 100%;
}

.widget-ad-banner .ad-link {
    display: block;
    text-decoration: none;
}

.widget-ad-banner .ad-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
}

.widget-ad-banner:hover .ad-image {
    transform: scale(1.02);
}

.widget-ad-banner .ad-label {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 2px 8px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    font-size: 10px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
</style>
