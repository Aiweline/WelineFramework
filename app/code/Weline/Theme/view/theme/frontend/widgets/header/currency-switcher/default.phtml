    padding: 10px 15px;
    color: var(--text-color, #333);
    text-decoration: none;
    transition: background-color 0.2s;
}

.widget-currency-switcher .currency-list li a:hover {
    background-color: #f5f5f5;
}

.widget-currency-switcher .currency-list li.active a {
    color: var(--primary-color, #007bff);
}

.widget-currency-switcher .currency-list .currency-symbol {
    width: 20px;
    text-align: center;
    font-size: 16px;
}

