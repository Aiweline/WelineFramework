<?php
/**
 * Related products widget.
 *
 * @var \Weline\Framework\View\Template $this
 *
 * @widget.code {related-products}
 * @widget.name {相关产品}
 * @widget.description {展示与当前产品相关的其他产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["product"]}
 * @widget.supports {["layout-product-related-products","layout-product-sidebar"]}
 *
 * @param title {default="相关产品",type="string",label="标题"}
 * @param limit {default=4,type="number",label="显示数量"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列",5:"5列"}}
 * @param layout {default="carousel",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 */

use Weline\Theme\Helper\WidgetI18n;

$titleSource = trim((string)($this->getData('title') ?? '')) ?: '相关产品';
$widgetTitle = WidgetI18n::label($titleSource, '相关产品');
$limit = max(1, (int)($this->getData('limit') ?? 4));
$columns = (string)($this->getData('columns') ?? '4');
$layout = (string)($this->getData('layout') ?? 'carousel');
$placeholder = 'data:image/svg+xml;charset=UTF-8,' . rawurlencode(
    '<svg xmlns="http://www.w3.org/2000/svg" width="640" height="640" viewBox="0 0 640 640"><defs><linearGradient id="g" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#f8fafc"/><stop offset="1" stop-color="#e2e8f0"/></linearGradient></defs><rect width="640" height="640" fill="url(#g)"/><circle cx="320" cy="270" r="72" fill="#cbd5e1"/><path d="M160 488c42-94 94-141 156-141s116 47 164 141" fill="#cbd5e1"/></svg>'
);

$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $price = 50 + ($i * 39);
    $originalPrice = round($price * (1.1 + (($i % 3) * 0.05)), 2);
    $products[] = [
        'id' => $i,
        'name' => '相关产品 ' . $i,
        'url' => '/product/related-' . $i,
        'image' => $placeholder,
        'price' => $price,
        'original_price' => $originalPrice,
        'rating' => min(5, 3.6 + (($i % 4) * 0.3)),
        'review_count' => 18 + ($i * 23),
    ];
}

$realProducts = [];
try {
    $currentProduct = $this->getData('product');
    $seedProductId = (int)($this->getData('product_id') ?? 0);
    if ($seedProductId <= 0 && is_object($currentProduct)) {
        if (method_exists($currentProduct, 'getId')) {
            $seedProductId = (int)$currentProduct->getId();
        }
        if ($seedProductId <= 0 && method_exists($currentProduct, 'getData')) {
            $seedProductId = (int)($currentProduct->getData('product_id') ?? $currentProduct->getData('entity_id') ?? 0);
        }
    } elseif ($seedProductId <= 0 && is_array($currentProduct)) {
        $seedProductId = (int)($currentProduct['product_id'] ?? $currentProduct['entity_id'] ?? 0);
    }
    if ($seedProductId <= 0) {
        $requestUri = (string)(\Weline\Framework\Env\WelineEnv::server('REQUEST_URI', '') ?: ($_SERVER['REQUEST_URI'] ?? ''));
        $requestPath = parse_url($requestUri, PHP_URL_PATH) ?: '';
        $pathParts = array_values(array_filter(explode('/', trim($requestPath, '/')), static fn(string $part): bool => $part !== ''));
        $productPartIndex = array_search('product', $pathParts, true);
        if ($productPartIndex !== false && isset($pathParts[$productPartIndex + 1])) {
            $handle = rawurldecode((string)$pathParts[$productPartIndex + 1]);
            /** @var \WeShop\Product\Service\ProductService $productService */
            $productService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Service\ProductService::class);
            $currentProductModel = $productService->getProductByHandle($handle);
            $seedProductId = (int)($currentProductModel?->getId() ?? 0);
        }
    }
    $recommendationService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Service\ProductRecommendationService::class);
    $realProducts = $recommendationService->getRecommendations($seedProductId > 0 ? [$seedProductId] : [], $limit);
} catch (\Throwable) {
    $realProducts = [];
}
if ($realProducts !== []) {
    $products = $realProducts;
    foreach ($products as &$product) {
        $productId = (int)($product['product_id'] ?? $product['id'] ?? 0);
        $handle = trim((string)($product['handle'] ?? ''));
        $product['id'] = $productId;
        $product['url'] = $handle !== ''
            ? $this->getUrl('product/' . $handle)
            : $this->getUrl('weshop/product/view', ['id' => $productId]);
    }
    unset($product);
}

$widgetKey = (string)($this->getData('_widget_instance_key') ?? ($titleSource . '|' . $limit . '|' . $columns . '|' . $layout));
$widgetId = 'related-products-' . substr(sha1($widgetKey), 0, 12);
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT
    | JSON_INVALID_UTF8_SUBSTITUTE;
?>

<div class="widget-related-products widget-products" id="<?= $widgetId ?>" style="width:100%;max-width:var(--layout-max-width,1600px);margin:0 auto;padding:0 var(--spacing-4,1.5rem);box-sizing:border-box;">
    <div class="widget-header">
        <h2 class="widget-title"><?= htmlspecialchars($widgetTitle, ENT_QUOTES, 'UTF-8') ?></h2>
    </div>

    <div class="products-container layout-<?= htmlspecialchars($layout, ENT_QUOTES, 'UTF-8') ?>">
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-prev" type="button" aria-label="<?= __('上一组') ?>">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        <?php endif; ?>

        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns, ENT_QUOTES, 'UTF-8') ?>" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--spacing-4,1rem);width:100%;box-sizing:border-box;">
                <?php foreach ($products as $product): ?>
                    <?php
                    $actionProductId = (int)($product['id'] ?? $product['product_id'] ?? 0);
                    $actionProductUrl = (string)($product['url'] ?? '');
                    ?>
                    <article class="product-card" style="display:flex;min-width:0;flex-direction:column;overflow:hidden;border:1px solid var(--color-border-light,#e5e7eb);border-radius:var(--radius-lg,12px);background:var(--color-bg-primary,#fff);box-shadow:var(--shadow-sm,0 1px 2px rgba(15,23,42,.04));">
                        <div class="product-image-wrapper">
                            <a href="<?= htmlspecialchars((string)($product['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars((string)($product['image'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                                     alt="<?= htmlspecialchars((string)($product['name'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>

                            <div class="product-actions">
                                <button class="action-btn btn-wishlist weline-pixel::add_to_wishlist" type="button" title="<?= __('加入收藏') ?>" aria-label="<?= __('加入收藏') ?>" aria-pressed="false" data-product-id="<?= $actionProductId ?>">
                                    <svg class="action-icon weline-pixel::add_to_wishlist" aria-hidden="true" focusable="false" viewBox="0 0 24 24">
                                        <path d="M12 20.35l-1.45-1.32C5.4 14.36 2 11.27 2 7.5 2 4.42 4.42 2 7.5 2c1.74 0 3.41.81 4.5 2.08C13.09 2.81 14.76 2 16.5 2 19.58 2 22 4.42 22 7.5c0 3.77-3.4 6.86-8.55 11.53L12 20.35z"/>
                                    </svg>
                                </button>
                                <a class="action-btn btn-quickview" href="<?= htmlspecialchars($actionProductUrl, ENT_QUOTES, 'UTF-8') ?>" title="<?= __('快速查看') ?>" aria-label="<?= __('快速查看') ?>" data-product-id="<?= $actionProductId ?>">
                                    <svg class="action-icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24">
                                        <path d="M12 4.5c5.05 0 9.27 3.11 11 7.5-1.73 4.39-5.95 7.5-11 7.5S2.73 16.39 1 12c1.73-4.39 5.95-7.5 11-7.5zm0 2C8.24 6.5 4.93 8.57 3.18 12 4.93 15.43 8.24 17.5 12 17.5s7.07-2.07 8.82-5.5C19.07 8.57 15.76 6.5 12 6.5zm0 2.5a3 3 0 110 6 3 3 0 010-6z"/>
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <div class="product-info" style="display:flex;width:auto;min-width:0;flex:1;flex-direction:column;gap:.6rem;padding:var(--spacing-4,1rem);box-sizing:border-box;">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars((string)($product['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>">
                                    <?= htmlspecialchars((string)($product['name'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
                                </a>
                            </h3>

                            <div class="product-rating">
                                <div class="stars" aria-label="<?= number_format((float)$product['rating'], 1) ?>">
                                    <?php for ($s = 1; $s <= 5; $s++): ?>
                                        <i class="ri-star-<?= $s <= floor((float)$product['rating']) ? 'fill' : 'line' ?>"></i>
                                    <?php endfor; ?>
                                </div>
                                <span class="review-count">(<?= (int)$product['review_count'] ?>)</span>
                            </div>

                            <div class="product-price">
                                <?php if ((float)$product['original_price'] > (float)$product['price']): ?>
                                    <span class="price-original">¥<?= number_format((float)$product['original_price'], 2) ?></span>
                                <?php endif; ?>
                                <span class="price-current weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)(float)$product['price'], ENT_QUOTES, 'UTF-8') ?>">¥<?= number_format((float)$product['price'], 2) ?></span>
                            </div>

                            <button class="btn-add-to-cart weline-pixel::add_to_cart" type="button" data-product-id="<?= (int)$product['id'] ?>">
                                <i class="ri-shopping-cart-line weline-pixel::add_to_cart"></i>
                                <span class="weline-pixel::add_to_cart"><?= __('加入购物车') ?></span>
                            </button>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>

        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-next" type="button" aria-label="<?= __('下一组') ?>">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
    </div>
</div>

<script>
(function () {
    var widget = document.getElementById(<?= json_encode($widgetId, $jsonForScriptFlags) ?>);
    if (!widget || widget.dataset.wishlistActionsBound === '1') {
        return;
    }
    widget.dataset.wishlistActionsBound = '1';

    var texts = {
        added: <?= json_encode((string)__('已加入收藏'), $jsonForScriptFlags) ?>,
        failed: <?= json_encode((string)__('加入收藏失败，请稍后重试'), $jsonForScriptFlags) ?>,
        login: <?= json_encode((string)__('请先登录'), $jsonForScriptFlags) ?>
    };

    function showNotice(message, type) {
        if (window.Weline && window.Weline.Toast && typeof window.Weline.Toast.show === 'function') {
            window.Weline.Toast.show({ message: message, type: type || 'info' });
        }
    }

    async function getWishlistApi() {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
            return window.Weline.Api.resource('wishlist');
        }
        if (window.Weline && typeof window.Weline.use === 'function') {
            await window.Weline.use('api');
        }
        if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
            throw new Error('Weline.Api.resource is not available');
        }
        return window.Weline.Api.resource('wishlist');
    }

    function normalizeWishlistPayload(payload) {
        if (payload && typeof payload === 'object' && payload.data && typeof payload.data === 'object') {
            if ('success' in payload.data || 'message' in payload.data || 'redirect_url' in payload.data) {
                return payload.data;
            }
        }
        return payload && typeof payload === 'object' ? payload : {};
    }

    function updateWishlistCount(count) {
        if (count === undefined || count === null) {
            return;
        }
        document.querySelectorAll('.wishlist-count').forEach(function (node) {
            node.textContent = String(count);
            node.setAttribute('data-count', String(count));
            node.style.display = Number(count) > 0 ? '' : 'none';
        });
    }

    widget.addEventListener('click', function (event) {
        var button = event.target && event.target.closest ? event.target.closest('.btn-wishlist') : null;
        if (!button || !widget.contains(button)) {
            return;
        }
        event.preventDefault();
        event.stopPropagation();

        var productId = Number(button.getAttribute('data-product-id') || 0);
        if (productId <= 0 || button.disabled) {
            return;
        }

        button.disabled = true;
        button.setAttribute('aria-busy', 'true');

        getWishlistApi()
            .then(function (WishlistApi) {
                return WishlistApi.add({ product_id: productId });
            })
            .then(function (payload) {
                var data = normalizeWishlistPayload(payload);
                var redirectUrl = data.redirect_url || (data.data && data.data.redirect_url) || '';
                if (redirectUrl) {
                    window.location.href = redirectUrl;
                    return;
                }
                if (data.success === false) {
                    showNotice(data.message || texts.login, 'warning');
                    return;
                }
                button.classList.add('is-active');
                button.setAttribute('aria-pressed', 'true');
                updateWishlistCount(
                    Object.prototype.hasOwnProperty.call(data, 'wishlist_count')
                        ? data.wishlist_count
                        : (data.data && data.data.wishlist_count)
                );
                showNotice(data.message || texts.added, 'success');
            })
            .catch(function (error) {
                console.error('[related-products] wishlist add failed', error);
                showNotice(texts.failed, 'error');
            })
            .finally(function () {
                button.disabled = false;
                button.removeAttribute('aria-busy');
            });
    });
})();
</script>

