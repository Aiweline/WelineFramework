<?php
/**
 * Related products widget.
 *
 * @var \Weline\Framework\View\Template $this
 *
 * @widget.code {related-products}
 * @widget.name {相关产品}
 * @widget.description {展示与当前产品相关的其他产品}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["product"]}
 *
 * @param title {default="相关产品",type="string",label="标题"}
 * @param limit {default=4,type="number",label="显示数量"}
 * @param columns {default="4",type="select",label="每行列数",options={2:"2列",3:"3列",4:"4列",5:"5列"}}
 * @param layout {default="carousel",type="select",label="布局方式",options={grid:"网格",carousel:"轮播"}}
 */

$title = $this->getData('title') ?? __('相关产品');
$limit = max(1, (int)($this->getData('limit') ?? 4));
$columns = (string)($this->getData('columns') ?? '4');
$layout = (string)($this->getData('layout') ?? 'carousel');
$placeholder = 'data:image/svg+xml;charset=UTF-8,' . rawurlencode(
    '<svg xmlns="http://www.w3.org/2000/svg" width="640" height="640" viewBox="0 0 640 640"><defs><linearGradient id="g" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#f8fafc"/><stop offset="1" stop-color="#e2e8f0"/></linearGradient></defs><rect width="640" height="640" fill="url(#g)"/><circle cx="320" cy="270" r="72" fill="#cbd5e1"/><path d="M160 488c42-94 94-141 156-141s116 47 164 141" fill="#cbd5e1"/></svg>'
);

$products = [];
for ($i = 1; $i <= $limit; $i++) {
    $price = 50 + ($i * 39);
    $originalPrice = round($price * (1.1 + (($i % 3) * 0.05)), 2);
    $products[] = [
        'id' => $i,
        'name' => '相关产品 ' . $i,
        'url' => '/product/related-' . $i,
        'image' => $placeholder,
        'price' => $price,
        'original_price' => $originalPrice,
        'rating' => min(5, 3.6 + (($i % 4) * 0.3)),
        'review_count' => 18 + ($i * 23),
    ];
}

$realProducts = [];
try {
    $currentProduct = (array)($this->getData('product') ?? []);
    $seedProductId = (int)($currentProduct['product_id'] ?? $this->getData('product_id') ?? 0);
    if ($seedProductId <= 0) {
        $requestUri = (string)(\Weline\Framework\Env\WelineEnv::server('REQUEST_URI', '') ?: ($_SERVER['REQUEST_URI'] ?? ''));
        $requestPath = parse_url($requestUri, PHP_URL_PATH) ?: '';
        $productPathPrefix = '/product/';
        if (strncmp($requestPath, $productPathPrefix, strlen($productPathPrefix)) === 0) {
            $handle = rawurldecode(trim(substr($requestPath, strlen($productPathPrefix)), '/'));
            /** @var \WeShop\Product\Service\ProductService $productService */
            $productService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Service\ProductService::class);
            $currentProductModel = $productService->getProductByHandle($handle);
            $seedProductId = (int)($currentProductModel?->getId() ?? 0);
        }
    }
    $recommendationService = \Weline\Framework\Manager\ObjectManager::getInstance(\WeShop\Product\Service\ProductRecommendationService::class);
    $realProducts = $recommendationService->getRecommendations($seedProductId > 0 ? [$seedProductId] : [], $limit);
} catch (\Throwable) {
    $realProducts = [];
}
if ($realProducts !== []) {
    $products = $realProducts;
    foreach ($products as &$product) {
        $productId = (int)($product['product_id'] ?? $product['id'] ?? 0);
        $handle = trim((string)($product['handle'] ?? ''));
        $product['id'] = $productId;
        $product['url'] = $handle !== '' ? '/product/' . rawurlencode($handle) : '/product/view?id=' . $productId;
    }
    unset($product);
}

$widgetKey = (string)($this->getData('_widget_instance_key') ?? ($title . '|' . $limit . '|' . $columns . '|' . $layout));
$widgetId = 'related-products-' . substr(sha1($widgetKey), 0, 12);
?>

<div class="widget-related-products widget-products" id="<?= $widgetId ?>" style="width:100%;max-width:var(--layout-max-width,1600px);margin:0 auto;padding:0 var(--spacing-4,1.5rem);box-sizing:border-box;">
    <div class="widget-header">
        <h2 class="widget-title"><?= htmlspecialchars((string)$title, ENT_QUOTES, 'UTF-8') ?></h2>
    </div>

    <div class="products-container layout-<?= htmlspecialchars($layout, ENT_QUOTES, 'UTF-8') ?>">
        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-prev" type="button" aria-label="<?= __('上一组') ?>">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        <?php endif; ?>

        <div class="products-wrapper">
            <div class="products-grid columns-<?= htmlspecialchars($columns, ENT_QUOTES, 'UTF-8') ?>" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--spacing-4,1rem);width:100%;box-sizing:border-box;">
                <?php foreach ($products as $product): ?>
                    <article class="product-card" style="display:flex;min-width:0;flex-direction:column;overflow:hidden;border:1px solid var(--color-border-light,#e5e7eb);border-radius:var(--radius-lg,12px);background:var(--color-bg-primary,#fff);box-shadow:var(--shadow-sm,0 1px 2px rgba(15,23,42,.04));">
                        <div class="product-image-wrapper">
                            <a href="<?= htmlspecialchars((string)($product['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" class="product-image-link">
                                <img src="<?= htmlspecialchars((string)($product['image'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                                     alt="<?= htmlspecialchars((string)($product['name'] ?? ''), ENT_QUOTES, 'UTF-8') ?>"
                                     class="product-image"
                                     loading="lazy">
                            </a>

                            <div class="product-actions">
                                <button class="action-btn btn-wishlist weline-pixel::add_to_wishlist" type="button" title="<?= __('加入收藏') ?>">
                                    <i class="ri-heart-line weline-pixel::add_to_wishlist"></i>
                                </button>
                                <button class="action-btn btn-quickview" type="button" title="<?= __('快速查看') ?>">
                                    <i class="ri-eye-line"></i>
                                </button>
                            </div>
                        </div>

                        <div class="product-info" style="display:flex;width:auto;min-width:0;flex:1;flex-direction:column;gap:.6rem;padding:var(--spacing-4,1rem);box-sizing:border-box;">
                            <h3 class="product-name">
                                <a href="<?= htmlspecialchars((string)($product['url'] ?? ''), ENT_QUOTES, 'UTF-8') ?>">
                                    <?= htmlspecialchars((string)($product['name'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
                                </a>
                            </h3>

                            <div class="product-rating">
                                <div class="stars" aria-label="<?= number_format((float)$product['rating'], 1) ?>">
                                    <?php for ($s = 1; $s <= 5; $s++): ?>
                                        <i class="ri-star-<?= $s <= floor((float)$product['rating']) ? 'fill' : 'line' ?>"></i>
                                    <?php endfor; ?>
                                </div>
                                <span class="review-count">(<?= (int)$product['review_count'] ?>)</span>
                            </div>

                            <div class="product-price">
                                <?php if ((float)$product['original_price'] > (float)$product['price']): ?>
                                    <span class="price-original">¥<?= number_format((float)$product['original_price'], 2) ?></span>
                                <?php endif; ?>
                                <span class="price-current weline-pixel::add_to_cart:value" data-pixel-value="<?= htmlspecialchars((string)(float)$product['price'], ENT_QUOTES, 'UTF-8') ?>">¥<?= number_format((float)$product['price'], 2) ?></span>
                            </div>

                            <button class="btn-add-to-cart weline-pixel::add_to_cart" type="button" data-product-id="<?= (int)$product['id'] ?>">
                                <i class="ri-shopping-cart-line weline-pixel::add_to_cart"></i>
                                <span class="weline-pixel::add_to_cart"><?= __('加入购物车') ?></span>
                            </button>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>
        </div>

        <?php if ($layout === 'carousel'): ?>
            <button class="carousel-arrow carousel-next" type="button" aria-label="<?= __('下一组') ?>">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        <?php endif; ?>
    </div>
</div>

