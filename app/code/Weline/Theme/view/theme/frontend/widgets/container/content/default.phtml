<?php
/**
 * Content 容器部件模板
 * 
 * 定义主内容区域布局和内部插槽位置
 * 子部件会自动渲染到对应的插槽中
 * 支持多种布局：全宽、带左侧栏、带右侧栏、双侧栏
 * 
 * @var array $config 部件配置
 * @var array $children 子部件（按插槽分组）
 * 
 * @widget.code {content-container}
 * @widget.name {Content 容器}
 * @widget.description {主内容区域容器，包含 Hero、推荐、主内容、侧栏等插槽。支持多种布局。}
 * @widget.type {container}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["*"]}
 * @widget.is_container {true}
 * @widget.exclusive {true}
 * 
 * @param layout {default="full-width",type="select",label="布局类型",options={full-width:"全宽",with-left:"带左侧栏",with-right:"带右侧栏",with-both:"双侧栏"}}
 * @param sidebar_width {default="25",type="select",label="侧栏宽度",options={20:"20%",25:"25%",30:"30%",33:"33%"}}
 * @param container_width {default="container",type="select",label="容器宽度",options={container:"标准宽度",container-fluid:"全宽",container-lg:"大屏宽度"}}
 */

$layout = $config['layout'] ?? 'full-width';
$sidebarWidth = $config['sidebar_width'] ?? '25';
$containerWidth = $config['container_width'] ?? 'container';

// 子部件数据（由渲染器注入）
$children = $children ?? [];

// 计算主内容区宽度
$contentWidth = 100;
if ($layout === 'with-left' || $layout === 'with-right') {
    $contentWidth = 100 - (int)$sidebarWidth;
} elseif ($layout === 'with-both') {
    $contentWidth = 100 - ((int)$sidebarWidth * 2);
}
?>
<main class="widget-content-container layout-<?= htmlspecialchars($layout) ?>" 
      data-layout="<?= htmlspecialchars($layout) ?>">
    
    <div class="<?= htmlspecialchars($containerWidth) ?>">
        
        <!-- Hero 区域（全宽顶部） -->
        <w:slot id="widget-hero" 
                name="Hero轮播区域"
                accept="hero-slider,promo-banner,deals-of-day,featured-products,image-text,video-player,countdown,text-block,product-carousel,category-grid,new-arrivals,bestsellers,breadcrumb,search-bar,product-grid,product-list-view"
                exclusive="true"
                position="content"
                wrapper="section"
                class="content-slot slot-hero">
            <?php if (!empty($children['hero'])): ?>
                <?php foreach ($children['hero'] as $child): ?>
                    <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                        <?= $child['html'] ?? '' ?>
                    </div>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="slot-placeholder slot-placeholder-large">
                    <i class="ri-slideshow-3-line"></i>
                    <span>Hero 轮播区域</span>
                    <small>拖放轮播图或促销横幅到此处</small>
                </div>
            <?php endif; ?>
        </w:slot>
        
        <!-- 推荐区域（全宽） -->
        <w:slot id="widget-featured"
                name="推荐区域"
                accept="featured-products,category-grid,deals-of-day,bestsellers,new-arrivals,product-carousel,you-may-like"
                multiple="true"
                position="content"
                wrapper="section"
                class="content-slot slot-featured">
            <?php if (!empty($children['featured'])): ?>
                <?php foreach ($children['featured'] as $child): ?>
                    <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                        <?= $child['html'] ?? '' ?>
                    </div>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="slot-placeholder">
                    <i class="ri-star-line"></i>
                    <span>推荐区域</span>
                    <small>推荐产品、分类网格或特价商品</small>
                </div>
            <?php endif; ?>
        </w:slot>
        
        <!-- 主内容区域 (带侧栏布局) -->
        <div class="content-body">
            
            <?php if ($layout === 'with-left' || $layout === 'with-both'): ?>
            <!-- 左侧栏 -->
            <w:slot id="widget-sidebar-left"
                    name="左侧栏"
                    accept="category-filters,category-list,sidebar-menu,sidebar-ads,mini-cart,tags-cloud,sidebar-social,sidebar-newsletter"
                    multiple="true"
                    position="sidebar"
                    wrapper="aside"
                    class="content-slot slot-sidebar-left"
                    style="flex: 0 0 <?= $sidebarWidth ?>%;">
                <?php if (!empty($children['sidebar-left'])): ?>
                    <?php foreach ($children['sidebar-left'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder slot-placeholder-vertical">
                        <i class="ri-layout-left-line"></i>
                        <span>左侧栏</span>
                        <small>筛选、菜单、广告</small>
                    </div>
                <?php endif; ?>
            </w:slot>
            <?php endif; ?>
            
            <!-- 主内容区 -->
            <w:slot id="widget-main"
                    name="主内容区"
                    accept="*"
                    multiple="true"
                    position="content"
                    wrapper="section"
                    class="content-slot slot-main"
                    style="flex: 1;">
                <?php if (!empty($children['main'])): ?>
                    <?php foreach ($children['main'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder slot-placeholder-large">
                        <i class="ri-layout-masonry-line"></i>
                        <span>主内容区</span>
                        <small>产品列表、文章、自定义内容</small>
                    </div>
                <?php endif; ?>
            </w:slot>
            
            <?php if ($layout === 'with-right' || $layout === 'with-both'): ?>
            <!-- 右侧栏 -->
            <w:slot id="widget-sidebar-right"
                    name="右侧栏"
                    accept="mini-cart,recently-viewed,sidebar-newsletter,sidebar-social,tags-cloud,sidebar-ads,sidebar-menu"
                    multiple="true"
                    position="sidebar"
                    wrapper="aside"
                    class="content-slot slot-sidebar-right"
                    style="flex: 0 0 <?= $sidebarWidth ?>%;">
                <?php if (!empty($children['sidebar-right'])): ?>
                    <?php foreach ($children['sidebar-right'] as $child): ?>
                        <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                            <?= $child['html'] ?? '' ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="slot-placeholder slot-placeholder-vertical">
                        <i class="ri-layout-right-line"></i>
                        <span>右侧栏</span>
                        <small>购物车、最近浏览、订阅</small>
                    </div>
                <?php endif; ?>
            </w:slot>
            <?php endif; ?>
            
        </div>
        
        <!-- 底部区域（全宽） -->
        <w:slot id="widget-bottom"
                name="底部区域"
                accept="testimonials,brand-logos,faq-accordion,trust-badges,deals-of-day,newsletter-popup,social-share"
                multiple="true"
                position="content"
                wrapper="section"
                class="content-slot slot-bottom">
            <?php if (!empty($children['bottom'])): ?>
                <?php foreach ($children['bottom'] as $child): ?>
                    <div class="slot-widget" data-widget-code="<?= htmlspecialchars($child['code']) ?>">
                        <?= $child['html'] ?? '' ?>
                    </div>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="slot-placeholder">
                    <i class="ri-layout-bottom-line"></i>
                    <span>底部区域</span>
                    <small>客户评价、品牌Logo、FAQ等</small>
                </div>
            <?php endif; ?>
        </w:slot>
        
    </div>
    
</main>

<style>
.widget-content-container {
    width: 100%;
    padding: 20px 0;
}

.widget-content-container > .container,
.widget-content-container > .container-fluid,
.widget-content-container > .container-lg {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
}

.widget-content-container > .container-fluid {
    max-width: 100%;
}

/* Hero 区域 */
.slot-hero {
    margin-bottom: 30px;
}

/* 推荐区域 */
.slot-featured {
    margin-bottom: 30px;
}

/* 主内容区域布局 */
.content-body {
    display: flex;
    gap: 30px;
    margin-bottom: 30px;
}

/* 侧栏样式 */
.slot-sidebar-left,
.slot-sidebar-right {
    flex-shrink: 0;
}

/* 主内容区 */
.slot-main {
    min-height: 400px;
}

/* 底部区域 */
.slot-bottom {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid #e0e0e0;
}

/* 插槽通用样式 */
.content-slot {
    position: relative;
    min-height: 50px;
}

/* 编辑模式样式由 editor-mode.css 统一管理 */

/* slot 选中状态（点击后） */
.content-slot.slot-selected,
[data-slot].slot-selected,
[data-wslot].slot-selected {
    outline: 3px solid #6366f1 !important;
    outline-offset: 2px;
    background: rgba(99, 102, 241, 0.05) !important;
}

.slot-widget {
    position: relative;
    margin-bottom: 20px;
}

.slot-widget:last-child {
    margin-bottom: 0;
}

/* 响应式布局 */
@media (max-width: 992px) {
    .content-body {
        flex-wrap: wrap;
    }
    
    .slot-sidebar-left,
    .slot-sidebar-right {
        flex: 0 0 100% !important;
        order: 2;
    }
    
    .slot-main {
        order: 1;
        flex: 0 0 100%;
    }
}
</style>
