<?php
/**
 * 交叉销售部件
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @widget.code {cross-sell}
 * @widget.name {交叉销售}
 * @widget.description {展示经常一起购买的产品组合}
 * @widget.type {product}
 * @widget.area {frontend}
 * @widget.position {["content"]}
 * @widget.page_layouts {["product", "cart"]}
 * @widget.supports {["layout-cart-recommendations","layout-product-cross-sell","layout-product-sidebar"]}
 * 
 * @param title {default="经常一起购买",type="string",label="标题"}
 * @param limit {default=4,type="number",label="显示数量"}
 * @param show_add_all_button {default=true,type="bool",label="显示一键添加按钮"}
 * @param show_total_price {default=true,type="bool",label="显示组合总价"}
 */

$title = (string)($this->getData('title') ?? __('经常一起购买'));
$limit = (int)($this->getData('limit') ?? 4);
$showAddAllButton = (bool)($this->getData('show_add_all_button') ?? true);
$showTotalPrice = (bool)($this->getData('show_total_price') ?? true);
$placeholder = $this->getStaticUrl('Weline_Theme::theme/frontend/assets/images/theme/placeholder.png');
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_APOS
    | JSON_HEX_AMP
    | JSON_HEX_QUOT;

// 示例产品数据
$products = [];
$totalPrice = 0;
for ($i = 1; $i <= $limit; $i++) {
    $price = rand(50, 300);
    $totalPrice += $price;
    $products[] = [
        'id' => $i,
        'name' => __('搭配产品 %d', $i),
        'url' => '/product/cross-' . $i,
        'image' => $placeholder,
        'price' => $price,
        'selected' => true,
    ];
}

$widgetId = 'cross-sell-' . uniqid();
?>

<div class="widget-cross-sell" id="<?= $widgetId ?>">
    <h3 class="widget-title">
        <i class="ri-links-line"></i>
        <?= htmlspecialchars($title) ?>
    </h3>
    
    <div class="cross-sell-container">
        <div class="cross-sell-products">
            <?php foreach ($products as $index => $product): ?>
                <?php
                // 确保所有产品字段都是字符串，避免null值
                $productUrl = (string)($product['url'] ?? '');
                $productImage = (string)($product['image'] ?? '');
                $productName = (string)($product['name'] ?? '');
                ?>
                <?php if ($index > 0): ?>
                    <span class="plus-sign">+</span>
                <?php endif; ?>
                
                <div class="cross-product" data-product-id="<?= $product['id'] ?>">
                    <div class="product-checkbox">
                        <input type="checkbox" 
                               id="cross-product-<?= $product['id'] ?>" 
                               class="cross-checkbox"
                               data-price="<?= $product['price'] ?>"
                               <?= $product['selected'] ? 'checked' : '' ?>>
                        <label for="cross-product-<?= $product['id'] ?>"></label>
                    </div>
                    
                    <a href="<?= htmlspecialchars($productUrl) ?>" class="product-link">
                        <img src="<?= htmlspecialchars($productImage) ?>" 
                             alt="<?= htmlspecialchars($productName) ?>"
                             class="product-image">
                    </a>
                    
                    <div class="product-info">
                        <h4 class="product-name">
                            <a href="<?= htmlspecialchars($productUrl) ?>">
                                <?= htmlspecialchars($productName) ?>
                            </a>
                        </h4>
                        <span class="product-price">¥<?= number_format($product['price'], 2) ?></span>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
        
        <div class="cross-sell-summary">
            <?php if ($showTotalPrice): ?>
                <div class="total-price">
                    <span class="label"><?= __('总价') ?>:</span>
                    <span class="value" data-original-total="<?= $totalPrice ?>">¥<?= number_format($totalPrice, 2) ?></span>
                </div>
            <?php endif; ?>
            
            <?php if ($showAddAllButton): ?>
                <button class="btn-add-all" type="button">
                    <i class="ri-shopping-cart-2-line"></i>
                    <?= __('全部加入购物车') ?>
                </button>
            <?php endif; ?>
            <div class="cross-sell-status" role="status" aria-live="polite"></div>
        </div>
    </div>
</div>

