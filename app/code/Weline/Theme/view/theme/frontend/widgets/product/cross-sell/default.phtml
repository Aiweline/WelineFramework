<script>
(function() {
    const widget = document.getElementById(<?= json_encode($widgetId, $jsonForScriptFlags) ?>);
    if (!widget) return;

    const crossSellMessages = {
        selectOne: <?= json_encode((string)__('请至少选择一个商品'), $jsonForScriptFlags) ?>,
        added: <?= json_encode((string)__('已添加'), $jsonForScriptFlags) ?>,
        addAll: <?= json_encode((string)__('全部加入购物车'), $jsonForScriptFlags) ?>
    };
    
    const checkboxes = widget.querySelectorAll('.cross-checkbox');
    const totalEl = widget.querySelector('.total-price .value');

    function showCrossSellNotice(message, type) {
        if (window.Weline && window.Weline.Toast && typeof window.Weline.Toast.show === 'function') {
            window.Weline.Toast.show({ message: message, type: type || 'info' });
            return;
        }
        const status = widget.querySelector('.cross-sell-status');
        if (status) {
            status.textContent = message;
            status.className = 'cross-sell-status is-' + (type || 'info');
            return;
        }
        console.info(message);
    }

    function setAddAllButtonState(button, iconClass, label) {
        button.textContent = '';
        const icon = document.createElement('i');
        icon.className = iconClass;
        button.appendChild(icon);
        button.appendChild(document.createTextNode(' ' + label));
    }
    
    function updateTotal() {
        if (!totalEl) return;
        
        let total = 0;
        checkboxes.forEach(function(cb) {
            if (cb.checked) {
                total += parseFloat(cb.dataset.price);
            }
        });
        
        totalEl.textContent = '¥' + total.toFixed(2);
    }
    
    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateTotal);
    });
    
    // 全部加入购物车
    const addAllBtn = widget.querySelector('.btn-add-all');
    if (addAllBtn) {
        addAllBtn.addEventListener('click', function() {
            const selectedIds = [];
            checkboxes.forEach(function(cb) {
                if (cb.checked) {
                    const product = cb.closest('.cross-product');
                    selectedIds.push(product.dataset.productId);
                }
            });
            
            if (selectedIds.length === 0) {
                showCrossSellNotice(crossSellMessages.selectOne, 'warning');
                return;
            }
            
            console.log('Add to cart:', selectedIds);
            
            // 显示成功状态
            showCrossSellNotice(crossSellMessages.added, 'success');
            setAddAllButtonState(this, 'ri-check-line', crossSellMessages.added);
            this.style.background = 'var(--success-color, #28a745)';
            
            setTimeout(() => {
                setAddAllButtonState(this, 'ri-shopping-cart-2-line', crossSellMessages.addAll);
                this.style.background = '';
            }, 2000);
        });
    }
})();
</script>
