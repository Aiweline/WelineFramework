    position: relative;
    width: 100%;
    padding-top: 100%;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
}

.product-card-partial--horizontal .product-card-partial__image-wrapper {
    width: 160px;
    padding-top: 0;
    height: 160px;
}

.product-card-partial__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.product-card-partial:hover .product-card-partial__image {
    transform: scale(1.05);
}

.product-card-partial__image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-secondary);
    color: var(--color-text-disabled);
}

.product-card-partial__badges {
    position: absolute;
    top: var(--spacing-2, 0.5rem);
    left: var(--spacing-2, 0.5rem);
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 1;
}

.product-card-partial__badge {
    padding: 2px var(--spacing-1, 0.25rem);
    font-size: 0.65rem;
    font-weight: var(--font-weight-semibold, 600);
    text-transform: uppercase;
    border-radius: var(--radius-sm, 4px);
    letter-spacing: 0.5px;
}

.product-card-partial__badge--new {
    background-color: var(--color-success);
    color: var(--color-text-light);
}

.product-card-partial__badge--sale {
    background-color: var(--color-error);
    color: var(--color-text-light);
}

.product-card-partial__out-of-stock {
    position: absolute;
    top: var(--spacing-2, 0.5rem);
    right: var(--spacing-2, 0.5rem);
    padding: 2px var(--spacing-1, 0.25rem);
    background-color: var(--color-text-secondary);
    color: var(--color-text-light);
    font-size: 0.65rem;
    font-weight: var(--font-weight-semibold, 600);
    border-radius: var(--radius-sm, 4px);
    z-index: 1;
}

.product-card-partial__wishlist {
    position: absolute;
    top: var(--spacing-2, 0.5rem);
    right: var(--spacing-2, 0.5rem);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-primary);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: var(--color-text-secondary);
    box-shadow: var(--shadow-md, 0 4px 6px -1px rgba(0, 0, 0, 0.1));
    opacity: 0;
    transform: translateX(8px);
    transition: all 0.3s ease;
    z-index: 2;
}

.product-card-partial:hover .product-card-partial__wishlist {
    opacity: 1;
    transform: translateX(0);
}

.product-card-partial__wishlist:hover {
    background-color: var(--color-error);
    color: var(--color-text-light);
}

.product-card-partial__content {
    padding: var(--spacing-3, 0.75rem);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1, 0.25rem);
    flex: 1;
}

.product-card-partial__title {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.product-card-partial__title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
}

.product-card-partial__title a:hover {
    color: var(--color-link);
}

.product-card-partial__rating {
    display: flex;
    align-items: center;
    gap: var(--spacing-1, 0.25rem);
}

.product-card-partial__stars {
    display: inline-flex;
    position: relative;
    color: var(--color-text-disabled);
}

.product-card-partial__stars::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: calc(var(--rating, 0) / 5 * 100%);
    background: linear-gradient(90deg, var(--color-warning), var(--color-warning));
    -webkit-background-clip: text;
    background-clip: text;
}

.product-card-partial__star {
    width: 12px;
    height: 12px;
}

.product-card-partial__review-count {
    font-size: var(--font-size-xs, 0.7rem);
    color: var(--color-text-tertiary);
}

.product-card-partial__price {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-1, 0.25rem);
    margin-top: auto;
}

.product-card-partial__price-original {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-text-tertiary);
    text-decoration: line-through;
}

.product-card-partial__price-current {
    font-size: var(--font-size-base, 1rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-error);
}

.product-card-partial__actions {
    margin-top: var(--spacing-2, 0.5rem);
}

.product-card-partial__add-to-cart {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-1, 0.25rem);
    padding: var(--spacing-2, 0.5rem);
    background-color: var(--color-accent);
    color: var(--color-text-light);
    border: none;
    border-radius: var(--radius-md, 8px);
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: var(--font-weight-medium, 500);
    cursor: pointer;
    transition: background-color 0.2s ease;
}

.product-card-partial__add-to-cart:hover {
    background-color: var(--color-accent-hover);
}

.product-card-partial__out-of-stock-btn {
    width: 100%;
    padding: var(--spacing-2, 0.5rem);
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: none;
    border-radius: var(--radius-md, 8px);
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: var(--font-weight-medium, 500);
    cursor: not-allowed;
}

@media (max-width: 480px) {
    .product-card-partial__wishlist {
        opacity: 1;
        transform: translateX(0);
    }
}
</style>

<script>
(function() {
    'use strict';
    var card = document.getElementById('<?= $uniqueId ?>');
    if (!card) return;

    var addToCartBtn = card.querySelector('.product-card-partial__add-to-cart');
    if (addToCartBtn) {
        addToCartBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var originalHtml = addToCartBtn.innerHTML;
            addToCartBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> <span>@lang{已添加}</span>';
            addToCartBtn.style.backgroundColor = 'var(--color-success)';
            setTimeout(function() {
                addToCartBtn.innerHTML = originalHtml;
                addToCartBtn.style.backgroundColor = '';
            }, 2000);
        });
    }

    var wishlistBtn = card.querySelector('.product-card-partial__wishlist');
    if (wishlistBtn) {
        wishlistBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var svg = wishlistBtn.querySelector('svg');
            if (svg.getAttribute('fill') === 'none') {
                svg.setAttribute('fill', 'currentColor');
                wishlistBtn.style.color = 'var(--color-error)';
            } else {
                svg.setAttribute('fill', 'none');
                wishlistBtn.style.color = '';
            }
        });
    }
})();
</script>
<?php endif; ?>
