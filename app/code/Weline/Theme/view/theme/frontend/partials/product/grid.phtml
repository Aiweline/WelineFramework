    border: none;
    border-radius: var(--radius-md, 8px);
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    cursor: not-allowed;
}

/* ---- 响应式 ---- */
@media (max-width: 1200px) {
    .product-grid-partial__grid {
        grid-template-columns: repeat(<?= min($columns, 4) ?>, 1fr);
    }
}

@media (max-width: 992px) {
    .product-grid-partial__grid {
        grid-template-columns: repeat(<?= $columnsTablet ?>, 1fr);
    }
}

@media (max-width: 768px) {
    .product-grid-partial__grid {
        grid-template-columns: repeat(<?= $columnsMobile ?>, 1fr);
        gap: var(--spacing-3, 0.75rem);
    }

    .product-grid-partial__content {
        padding: var(--spacing-3, 0.75rem);
    }

    .product-grid-partial__wishlist {
        opacity: 1;
        transform: translateX(0);
    }
}

@media (max-width: 480px) {
    .product-grid-partial__grid {
        grid-template-columns: repeat(<?= min($columnsMobile, 2) ?>, 1fr);
        gap: var(--spacing-2, 0.5rem);
    }
}
</style>

<script>
(function() {
    'use strict';
    var grid = document.getElementById('<?= $uniqueId ?>');
    if (!grid) return;

    grid.querySelectorAll('.product-grid-partial__add-to-cart').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.dataset.productId;
            var originalHtml = this.innerHTML;
            this.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> <span>@lang{已添加}</span>';
            this.style.backgroundColor = 'var(--color-success)';
            setTimeout(function() {
                btn.innerHTML = originalHtml;
                btn.style.backgroundColor = '';
            }, 2000);
        });
    });

    grid.querySelectorAll('.product-grid-partial__wishlist').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var svg = btn.querySelector('svg');
            if (svg.getAttribute('fill') === 'none') {
                svg.setAttribute('fill', 'currentColor');
                btn.style.color = 'var(--color-error)';
            } else {
                svg.setAttribute('fill', 'none');
                btn.style.color = '';
            }
        });
    });
})();
</script>
<?php endif; ?>
