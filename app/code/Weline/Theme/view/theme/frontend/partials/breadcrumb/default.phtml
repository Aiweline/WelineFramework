<?php
/**
 * 片段：Breadcrumb
 * 
 * 面包屑导航
 * 字段
 * @meta.name {default="Breadcrumb面包屑片段",name="Breadcrumb面包屑片段",description="Breadcrumb面包屑片段，用于描述片段的名称"}
 * @meta.description {default="面包屑导航",name="面包屑导航",description="面包屑导航，用于描述片段的用途"}
 * @param.items {default=[],name="面包屑项数组",description="面包屑项数组，用于设置面包屑导航项，格式：[{\"text\":\"文字\",\"url\":\"链接\"}]"}
 * @param.separator {default="/",name="分隔符",description="分隔符，用于设置面包屑项之间的分隔符"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 */

// 读取ThemeData的该模板文件的元数据配置信息并填充到模板数据中
$metaParams = \Weline\Theme\Helper\ThemeData::getFileParams('partials.breadcrumb.default');
foreach ($metaParams as $key => $value) {
    $this->setData("meta.{$key}", $value);
}

$items = $this->getData("meta.items") ?? [];
$separator = $this->getData("meta.separator") ?? '/';
$class = $this->getData("meta.class") ?? '';

// 构建CSS类
$breadcrumbClass = 'breadcrumb';
if ($class) {
    $breadcrumbClass .= ' ' . htmlspecialchars($class);
}
?>
<nav class="<?= $breadcrumbClass ?>" aria-label="breadcrumb">
    <ol class="breadcrumb-list">
        <?php foreach ($items as $index => $item): ?>
            <li class="breadcrumb-item <?= empty($item['url']) ? 'active' : '' ?>">
                <?php if (!empty($item['url'])): ?>
                    <a href="<?= htmlspecialchars($item['url']) ?>">
                        <?= htmlspecialchars($item['text'] ?? '') ?>
                    </a>
                <?php else: ?>
                    <span><?= htmlspecialchars($item['text'] ?? '') ?></span>
                <?php endif; ?>
            </li>
            <?php if ($index < count($items) - 1): ?>
                <span class="breadcrumb-separator"><?= htmlspecialchars($separator) ?></span>
            <?php endif; ?>
        <?php endforeach; ?>
    </ol>
</nav>

