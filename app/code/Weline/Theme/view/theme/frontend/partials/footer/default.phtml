// 加载布局特定的JS文件（在footer中加载）
// 规则：所有主题相关数据（包括主题对象）由 ControllerFetchFileBefore Observer 设置
$themeData = $this->getData('theme') ?? [];
$area = $themeData['area'] ?? 'frontend';
$layoutType = $themeData['layoutType'] ?? null;
$layoutOption = $themeData['layoutOption'] ?? null;
$theme = $themeData['theme'] ?? null; // 主题对象（由 Observer 设置）

// 加载生成的布局JS文件（包含所有partials的JS）
if (!empty($layoutType) && !empty($layoutOption) && $theme && $theme->getId()) {
    $assetsManager = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Helper\LayoutAssetsManager::class);
    try {
        $jsUrl = $assetsManager->getJsUrl($area, $layoutType, $layoutOption, $theme, $this);
        ?>
<!-- 布局JS（包含所有partials的JavaScript）：<?= htmlspecialchars($layoutType) ?>/<?= htmlspecialchars($layoutOption) ?> -->
<script src="<?= htmlspecialchars($jsUrl) ?>"></script>
<?php
    } catch (\Exception $e) {
        // 如果获取URL失败，记录错误
        if (defined('DEV') && DEV) {
            try {
                $logger = \Weline\Framework\App\Env::getInstance()->getLogger();
                if ($logger) {
                    $logger->error('Footer Partial: 无法获取布局JS URL', [
                        'layoutType' => $layoutType,
                        'layoutOption' => $layoutOption,
                        'error' => $e->getMessage()
                    ]);
                }
            } catch (\Exception $logError) {
                // 忽略日志错误
            }
        }
    }
}
