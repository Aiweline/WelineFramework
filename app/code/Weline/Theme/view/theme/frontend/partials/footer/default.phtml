<?php
/**
 * 片段：Footer
 * 
 * 页面底部区域（链接、版权信息等）
 * 字段
 * @meta.name {default="Footer底部片段",name="Footer底部片段",description="Footer底部片段，用于描述片段的名称"}
 * @meta.description {default="页面底部区域（链接、版权信息等）",name="页面底部区域（链接、版权信息等）",description="页面底部区域（链接、版权信息等），用于描述片段的用途"}
 * @param.copyright {default="© {year} Weline Framework. 保留所有权利",name="版权信息",description="版权信息，用于设置页面底部的版权文字"}
 * @param.links {default=[{"title":"关于我们","items":[{"text":"公司简介","url":"/about"},{"text":"联系我们","url":"/contact"},{"text":"加入我们","url":"/careers"}]},{"title":"帮助中心","items":[{"text":"使用指南","url":"/help"},{"text":"常见问题","url":"/faq"},{"text":"服务条款","url":"/terms"}]},{"title":"客户服务","items":[{"text":"在线客服","url":"/support"},{"text":"意见反馈","url":"/feedback"},{"text":"隐私政策","url":"/privacy"}]}],name="链接数组",description="链接数组，用于设置页面底部的链接列表，格式：[{\"title\":\"标题\",\"items\":[{\"text\":\"链接文字\",\"url\":\"链接地址\"}]}]"}
 * @param.showBackToTop {default=true,name="是否显示返回顶部",description="是否显示返回顶部按钮，用于控制返回顶部按钮的显示"}
 * @param.socialMedia {default=[{"name":"微信公众号","icon":"fab fa-weixin","url":"#","color":"#07c160"},{"name":"微博","icon":"fab fa-weibo","url":"#","color":"#e6162d"},{"name":"抖音","icon":"fab fa-tiktok","url":"#","color":"#000000"},{"name":"B站","icon":"fab fa-bilibili","url":"#","color":"#fb7299"},{"name":"小红书","icon":"fab fa-instagram","url":"#","color":"#ff2442"}],name="官媒配置",description="官媒配置，用于设置官方社交媒体链接，格式：[{\"name\":\"名称\",\"icon\":\"图标类名\",\"url\":\"链接地址\",\"color\":\"主题色\"}]"}
 * @param.showSocialMedia {default=true,name="是否显示官媒",description="是否显示官媒链接，用于控制官媒区域的显示"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 *
 * 参数配置说明：
 * - Partials 自己的 meta 数据：通过 $meta 或 $this->getData('meta') 访问
 * - Layout 的 meta 数据：通过 $layout 或 $this->getData('layout') 访问
 * - 参数配置由 Block\Partials 在渲染时自动加载
 * - 模板中使用 {{meta.参数}} 输出 partials 的参数，使用 {{layout.参数}} 输出 layout 的参数
 */
$meta = $this->getData('meta') ?? [];
$layout = $this->getData('layout') ?? [];
$copyright = $meta['copyright'] ?? __('© ' . date('Y') . ' Weline Framework. 保留所有权利');
// 确保$links是数组
$links = $meta['links'] ?? [];
if (!is_array($links)) {
    if (is_string($links)) {
        $decoded = json_decode($links, true);
        $links = is_array($decoded) ? $decoded : [];
    } else {
        $links = [];
    }
}
$showBackToTop = $meta['showBackToTop'] ?? true;
// 确保$socialMedia是数组
$socialMedia = $meta['socialMedia'] ?? [];
if (!is_array($socialMedia)) {
    if (is_string($socialMedia)) {
        $decoded = json_decode($socialMedia, true);
        $socialMedia = is_array($decoded) ? $decoded : [];
    } else {
        $socialMedia = [];
    }
}
$showSocialMedia = $meta['showSocialMedia'] ?? true;
$class = $meta['class'] ?? '';
?>
<footer id="footer" class="weline-footer <?= htmlspecialchars($class) ?>" data-layout="default" data-layout-type="default" data-layout-option="default">
    <w:hook>Weline_Theme::frontend::partials::footer::before</w:hook>
    
    <w:block>Weline\Frontend\Block\Footer\Base</w:block>
    <?php
    /**@var \Weline\Framework\View\Template $this */
    echo $this->getFooter()->getHtml();
    ?>
    <!-- Footer Hooks -->
    <w:hook>footer</w:hook>
    
    <div class="footer-container">
        <w:hook>Weline_Theme::frontend::partials::footer::content-before</w:hook>
        <?php if (!empty($links) && is_array($links)): ?>
            <div class="footer-content">
                <w:hook>Weline_Theme::frontend::partials::footer::section-before</w:hook>
                
                <?php foreach ($links as $section): ?>
                    <?php if (!is_array($section)) continue; ?>
                    <div class="footer-section">
                        <?php if (isset($section['title'])): ?>
                            <h3><?= htmlspecialchars($section['title']) ?></h3>
                        <?php endif; ?>
                        <?php if (isset($section['items']) && is_array($section['items'])): ?>
                            <ul>
                                <?php foreach ($section['items'] as $item): ?>
                                    <?php if (!is_array($item)) continue; ?>
                                    <li>
                                        <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>">
                                            <?= htmlspecialchars($item['text'] ?? '') ?>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        <?php endif; ?>
                    </div>
                <?php endforeach; ?>
                
                <w:hook>Weline_Theme::frontend::partials::footer::section-after</w:hook>
            </div>
        <?php endif; ?>
        
        <w:hook>Weline_Theme::frontend::partials::footer::content-after</w:hook>
        
        <?php if ($showSocialMedia && !empty($socialMedia) && is_array($socialMedia)): ?>
            <w:hook>Weline_Theme::frontend::partials::footer::social-media-before</w:hook>
            <div class="footer-social-media">
                <div class="social-media-title"><?= __('关注我们') ?></div>
                <div class="social-media-links">
                    <w:hook>Weline_Theme::frontend::partials::footer::social-media-links-before</w:hook>
                    
                    <?php foreach ($socialMedia as $media): ?>
                        <?php if (!is_array($media)) continue; ?>
                        <a href="<?= htmlspecialchars($media['url'] ?? '#') ?>" 
                           class="social-media-link" 
                           title="<?= htmlspecialchars($media['name'] ?? '') ?>"
                           target="_blank"
                           rel="noopener noreferrer"
                           style="--social-color: <?= htmlspecialchars($media['color'] ?? '#3b82f6') ?>">
                            <i class="<?= htmlspecialchars($media['icon'] ?? 'fas fa-link') ?>"></i>
                            <span class="social-media-name"><?= htmlspecialchars($media['name'] ?? '') ?></span>
                        </a>
                    <?php endforeach; ?>
                    
                    <w:hook>Weline_Theme::frontend::partials::footer::social-media-links-after</w:hook>
                </div>
            </div>
            
            <w:hook>Weline_Theme::frontend::partials::footer::social-media-after</w:hook>
        <?php endif; ?>
        
        <div class="footer-bottom">
            <w:hook>Weline_Theme::frontend::partials::footer::copyright-before</w:hook>
            <p><?= htmlspecialchars($copyright) ?></p>
            <w:hook>Weline_Theme::frontend::partials::footer::copyright-after</w:hook>
        </div>
    </div>
    
    <?php if ($showBackToTop): ?>
        <button class="back-to-top" id="backToTop" title="<?= __('返回顶部') ?>">
            <i class="fas fa-arrow-up"></i>
        </button>
    <?php endif; ?>
    
    <w:hook>Weline_Theme::frontend::partials::footer::after</w:hook>
</footer>

<?php
// 加载布局特定的JS文件（在footer中加载）
// 从 theme 对象中读取所有主题相关数据
$theme = $this->getData('theme') ?? [];
$area = $theme['area'] ?? 'frontend';
$layoutType = $theme['layoutType'] ?? $this->getData('layoutType') ?? '';
$layoutOption = $theme['layoutOption'] ?? $this->getData('layoutOption') ?? 'default';
$requestPath = $this->request->getPathInfo() ?? '';
if (strpos($requestPath, '/admin') === 0 || strpos($requestPath, '/backend') === 0) {
    $area = 'backend';
}

if ($layoutType && $layoutOption) {
    $this->setData('area', $area);
    ?>
<theme:js>Weline_Theme::theme/{{area}}/assets/js/layouts/{{layoutType}}/{{layoutOption}}.js</theme:js>
<?php
}
?>

