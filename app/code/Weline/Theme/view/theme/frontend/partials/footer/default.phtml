<?php
/**
 * Theme partial: default frontend footer.
 *
 * @meta.name {default="Default Footer",name="Default Footer",description="Theme-owned frontend footer"}
 * @param.copyright {default="",name="Copyright",description="Footer copyright text"}
 * @param.links {default=[],name="Footer Links",description="Footer link sections"}
 * @param.socialMedia {default=[],name="Social Links",description="Social media links"}
 * @param.showBackToTop {default=true,name="Show Back To Top",description="Whether to show the back-to-top control"}
 * @param.showSocialMedia {default=true,name="Show Social Media",description="Whether to show social links"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class"}
 */

$meta = $this->getData('meta') ?? [];
$class = (string)($meta['class'] ?? '');
$copyright = (string)($meta['copyright'] ?? '');
if ($copyright === '' && class_exists(\Weline\Theme\Helper\FooterCopyrightHelper::class)) {
    $copyright = \Weline\Theme\Helper\FooterCopyrightHelper::resolve(null);
}
if ($copyright === '') {
    $copyright = '© ' . date('Y') . ' Weline Framework. All rights reserved.';
}

$links = $meta['links'] ?? [];
if (is_string($links)) {
    $decodedLinks = json_decode($links, true);
    $links = is_array($decodedLinks) ? $decodedLinks : [];
}
if (!is_array($links) || $links === []) {
    $links = [
        [
            'title' => __('Theme'),
            'items' => [
                ['text' => __('Home'), 'url' => '/'],
                ['text' => __('Products'), 'url' => '/products'],
                ['text' => __('Solutions'), 'url' => '/solutions'],
                ['text' => __('Contact'), 'url' => '/contact'],
            ],
        ],
        [
            'title' => __('Support'),
            'items' => [
                ['text' => __('Help Center'), 'url' => '/help'],
                ['text' => __('Orders'), 'url' => '/account/orders'],
                ['text' => __('Returns'), 'url' => '/policy/refund'],
                ['text' => __('FAQ'), 'url' => '/faq'],
            ],
        ],
        [
            'title' => __('Policies'),
            'items' => [
                ['text' => __('Privacy'), 'url' => '/policy/privacy'],
                ['text' => __('Terms'), 'url' => '/policy/term-condition'],
                ['text' => __('Cookie'), 'url' => '/policy/cookie'],
                ['text' => __('Disclaimer'), 'url' => '/policy/disclaimer'],
            ],
        ],
    ];
}

$socialMedia = $meta['socialMedia'] ?? [];
if (is_string($socialMedia)) {
    $decodedSocial = json_decode($socialMedia, true);
    $socialMedia = is_array($decodedSocial) ? $decodedSocial : [];
}
if (!is_array($socialMedia) || $socialMedia === []) {
    $socialMedia = [
        ['name' => __('WeChat'), 'icon' => 'ri-wechat-line', 'url' => '#'],
        ['name' => __('Douyin'), 'icon' => 'ri-music-2-line', 'url' => '#'],
        ['name' => __('YouTube'), 'icon' => 'ri-youtube-line', 'url' => '#'],
        ['name' => __('Instagram'), 'icon' => 'ri-instagram-line', 'url' => '#'],
    ];
}

$boolValue = static function ($value, bool $default): bool {
    if ($value === null || $value === '') {
        return $default;
    }
    $parsed = filter_var($value, FILTER_VALIDATE_BOOL, FILTER_NULL_ON_FAILURE);
    return $parsed ?? $default;
};
$showBackToTop = $boolValue($meta['showBackToTop'] ?? true, true);
$showSocialMedia = $boolValue($meta['showSocialMedia'] ?? true, true);
$esc = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
