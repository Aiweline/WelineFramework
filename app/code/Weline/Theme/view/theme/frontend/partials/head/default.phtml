/**@var \Weline\Framework\View\Template $this */
/**@var \Weline\Frontend\Block\ThemeConfig $themeConfig */
$themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Frontend\Block\ThemeConfig::class);

// 获取基础URL和当前语言
$baseUrl = $this->request->getBaseUrl();
$currentLang = $_SERVER['WELINE_USER_LANG'] ?? 'zh_Hans_CN';
$currentCurrency = $_SERVER['WELINE_USER_CURRENCY'] ?? 'CNY';
$siteName = $this->getData('site_name') ?? __('Weline Framework');
$pageTitle = $this->getData('title') ?? __('欢迎使用WelineFramework框架！');
$pageDescription = $this->getData('description') ?? __('Weline Framework - 现代化的PHP框架');
$pageKeywords = $this->getData('keywords') ?? __('Weline, Framework, PHP');

// API 和 Account 模块的配置（如 tokenRefreshPeriod 等）会由模块内部自动从全局配置读取
// i18n 模块的翻译词会由模块内部自动读取，无需在此处配置
// 注意：翻译词字典由 PHP 在模板编译时收集，会传递给 i18n 模块

// 获取开发模式状态
$isDev = defined('DEV') && DEV;

// 扫描可用的主题（从 colors 目录动态获取）
$availableThemes = ['light']; // 默认主题
try {
    /**@var \Weline\Framework\App\Env $env */
    $env = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\App\Env::class);
    $modules = $env->getModuleList();
    if (isset($modules['Weline_Theme'])) {
        $themeModule = $modules['Weline_Theme'];
        $themeBasePath = $themeModule['base_path'];
        
        // 检测当前区域（frontend 或 backend）
        $area = 'frontend'; // 默认前端
        $requestPath = $this->request->getPathInfo() ?? '';
        if (strpos($requestPath, '/admin') === 0 || strpos($requestPath, '/backend') === 0) {
            $area = 'backend';
        }
        
        // 扫描 colors 目录
        $colorsDir = $themeBasePath . DS . 'view' . DS . 'theme' . DS . $area . DS . 'colors';
        if (is_dir($colorsDir)) {
            $colorFiles = glob($colorsDir . DS . '_*.css');
            $themes = [];
            foreach ($colorFiles as $file) {
                $basename = basename($file, '.css');
                // 去掉下划线前缀，获取主题名称
                if (strpos($basename, '_') === 0) {
                    $themeName = substr($basename, 1);
                    if (!empty($themeName)) {
                        $themes[] = $themeName;
                    }
                }
            }
            if (!empty($themes)) {
                $availableThemes = $themes;
            }
        }
    }
} catch (\Throwable $e) {
    // 扫描失败时使用默认主题列表
    if ($isDev) {
        error_log('扫描主题失败: ' . $e->getMessage());
    }
}
?>
