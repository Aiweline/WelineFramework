    'WELINE_ENV' => $isDev ? 'DEV' : 'PROD',
    'DEV' => $isDev,
    'PROD' => !$isDev,
];
// API 模块的 workerUrl 由 API 模块内部自动处理，无需在此处配置
$themeConfigPayload = [
    'env' => $envConfig,
    'baseUrl' => $baseUrl,
    'currentLang' => $currentLang,
    'currentCurrency' => $currentCurrency,
    'debug' => $isDev,
    'site' => [
        'name' => $siteName,
        'title' => $pageTitle,
        'description' => $pageDescription,
        'keywords' => $pageKeywords,
    ],
    // i18n 模块配置由 i18n 模块内部自动处理，无需在此处配置
    // i18n 模块会自动从全局配置读取所需配置，并处理 URL 解析
    // 模块加载器配置由模块加载器内部自动处理，无需在此处配置
    // 模块加载器会自动检测环境并生成合适的 URL
    // API 模块配置由 API 模块内部自动处理，无需在此处配置
    // API 模块会自动从全局配置读取所需配置，并处理 URL 解析
    // 如需自定义，可在 api 配置中提供 workerUrl 等配置项
    // Account 模块配置由 Account 模块内部自动处理，无需在此处配置
    // Account 模块会自动从全局配置读取所需配置，并处理 URL 解析
    'theme' => [
        'current' => $themeMode,
        'available' => $availableThemes, // 动态扫描的主题列表
    ],
];
?>
<script>
    (function() {
        window.WELINE_ENV = window.WELINE_ENV || '<?= $envConfig['WELINE_ENV'] ?>';
        window.DEV = window.WELINE_ENV === 'DEV';
        window.PROD = window.WELINE_ENV === 'PROD';
        
        // URL解析辅助函数（参考API文档界面的实现）
        const getThemeUrlHelper = () => {
            return (window.Weline && window.Weline.Url) || null;
        };
        
        const resolveAbsoluteUrl = (path, options = {}) => {
            if (!path) return '';
            if (/^https?:\/\//i.test(path)) {
                return path;
            }
            
            const helper = getThemeUrlHelper();
            if (helper && typeof helper.resolve === 'function') {
                const opts = typeof options === 'string' ? { type: options } : (options || {});
                return helper.resolve(path, opts);
            }
            
            // Fallback: 直接返回绝对路径
            const normalizedOrigin = window.location.origin.replace(/\/+$/, '');
            const cleanPath = path.startsWith('/') ? path.slice(1) : path;
            return normalizedOrigin + '/' + cleanPath;
        };
        
        // 设置配置
        const themeConfigPayload = <?= json_encode($themeConfigPayload, JSON_UNESCAPED_UNICODE) ?>;
        
        // Account 模块配置由 Account 模块内部自动处理，无需在此处解析 URL
        // Account 模块会自动处理 URL 解析和配置管理
        
        window.__WelineThemeConfig = themeConfigPayload;
    })();
</script>
