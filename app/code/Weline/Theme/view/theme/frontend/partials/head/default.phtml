<?php
/**
 * Theme partial: frontend head.
 *
 * Owns the default theme assets, runtime theme config, and a small critical CSS
 * baseline that keeps every Theme layout readable even when no module hooks are
 * registered yet.
 *
 * @meta.name {default="Head",name="Head",description="Frontend theme head partial"}
 * @meta.cache.mode {default="chrome",name="缓存模式"}
 * @meta.cache.auth {default="guest",name="鉴权维度"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class for theme head consumers"}
 */

$themeData = $this->getData('theme') ?? [];
$area = $themeData['area'] ?? 'frontend';
$layoutType = $themeData['layoutType'] ?? null;
$layoutOption = $themeData['layoutOption'] ?? null;
$theme = $themeData['theme'] ?? null;
$colorMode = $themeData['colorMode'] ?? 'default';

$frontendBaseUrl = $this->request->getUrlBuilder()->getFrontendUrl('/');
$isDev = defined('DEV') && DEV;
$baseUrl = $this->request->getBaseUrl();
$currentLang = \w_env('user.lang', 'zh_Hans_CN');
$htmlDir = (string)($this->getData('htmlDir') ?: 'ltr');
$htmlDir = $htmlDir === 'rtl' ? 'rtl' : 'ltr';
$jsonEncodeFlags = JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE;
$currentCurrency = \w_env('user.currency', 'CNY');
$defaultLang = \w_env('website.language', '') ?: \Weline\Framework\App\Env::get('locale', \Weline\Framework\App\Env::get('lang', 'zh_Hans_CN')) ?: 'zh_Hans_CN';
$defaultCurrency = \w_env('website.currency', '') ?: \Weline\Framework\App\Env::get('currency', 'CNY') ?: 'CNY';
$availableCurrencies = [];
try {
    if (class_exists(\Weline\Websites\Data\WebsiteData::class)) {
        foreach (\Weline\Websites\Data\WebsiteData::getCurrencyCodes() as $currencyCode) {
            $currencyCode = strtoupper(trim((string)$currencyCode));
            if ($currencyCode !== '') {
                $availableCurrencies[] = $currencyCode;
            }
        }
    }
} catch (\Throwable) {
    $availableCurrencies = [];
}
$defaultCurrency = strtoupper(trim((string)$defaultCurrency)) ?: 'CNY';
$availableCurrencies[] = $defaultCurrency;
$availableCurrencies = array_values(array_unique($availableCurrencies));
$currentCurrency = strtoupper(trim((string)$currentCurrency));
if (!\Weline\Framework\App\State::isAllowedCurrencyCode($currentCurrency)) {
    $currentCurrency = $defaultCurrency;
}
$siteName = $this->getData('site_name') ?? __('Weline Framework');

$modulesConfigUrl = $isDev
    ? '/Weline/Frontend/view/statics/base/weline.modules.js'
    : '/static/Weline/Frontend/base/weline.modules.js';
$modulesBaseUrl = $isDev
    ? '/Weline/Frontend/view/statics/js/weline-api'
    : '/static/Weline/Frontend/js/weline-api';
$frontendQueryBinUrl = \Weline\Framework\App\Env::getFrontendQueryBinPath();

$themeConfigPayload = [
    'env' => [
        'WELINE_ENV' => DEV ? 'DEV' : 'PROD',
        'DEV' => DEV,
        'PROD' => !DEV,
    ],
    'baseUrl' => $baseUrl,
    'modulesConfigUrl' => $modulesConfigUrl,
    'modulesBaseUrl' => $modulesBaseUrl,
    'assetVersion' => '20260606-language-flag',
    'deployVersion' => ($__dv = @json_decode((string)@file_get_contents(BP . 'var/deploy/current.json'), true)) ? ($__dv['deploy_version'] ?? 'dev') : 'dev',
    'workerBuildId' => ($__dv !== null && is_array($__dv)) ? ($__dv['worker_build_id'] ?? 'dev') : 'dev',
    'api' => [
        'workerUrl' => $isDev
            ? '/Weline/Frontend/view/statics/js/weline-api-worker.js'
            : '/static/Weline/Frontend/js/weline-api-worker.js',
        'endpoint' => $frontendQueryBinUrl,
        'queryBinUrl' => $frontendQueryBinUrl,
        'locale' => $currentLang,
        'currency' => $currentCurrency,
    ],
    'currentLang' => $currentLang,
    'currentCurrency' => $currentCurrency,
    'defaultLang' => $defaultLang,
    'defaultCurrency' => $defaultCurrency,
    'availableCurrencies' => $availableCurrencies,
    'htmlDir' => $htmlDir,
    'textDirection' => $htmlDir,
    'isRtl' => $htmlDir === 'rtl',
    'debug' => DEV,
    'i18n' => [
        'currentLang' => $currentLang,
        'defaultLang' => $defaultLang,
        'direction' => $htmlDir,
    ],
    'site' => [
        'name' => $siteName,
    ],
    'theme' => [
        'area' => $area,
        'colorMode' => $colorMode,
        'layoutType' => $layoutType,
        'layoutOption' => $layoutOption,
    ],
];

$this->setData('themeConfigPayload', json_encode($themeConfigPayload, $jsonEncodeFlags));
?>
<base href="<?= htmlspecialchars($frontendBaseUrl, ENT_QUOTES, 'UTF-8') ?>">

<w:hook>Weline_Theme::frontend::partials::head::favicon<else/>
