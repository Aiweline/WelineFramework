<?php
// 根据主题模式加载颜色主题（优先使用预览配置）
$session = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\Session\Session::class);
$previewThemeId = $session->getData('preview_theme_id');
$area = 'frontend';
$requestPath = $this->request->getPathInfo() ?? '';
if (strpos($requestPath, '/admin') === 0 || strpos($requestPath, '/backend') === 0) {
    $area = 'backend';
}

if ($previewThemeId) {
    // 预览模式：使用预览配置
    $theme = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Theme\Model\WelineTheme::class);
    $theme->load($previewThemeId);
    if ($theme->getId()) {
        $themeMode = \Weline\Theme\Helper\LayoutScanner::getColorConfig($theme, $area);
    } else {
        $themeMode = $themeConfig->getThemeModel() ?: 'light';
    }
} else {
    // 正常模式：使用用户配置
    $themeMode = $themeConfig->getThemeModel() ?: 'light';
}

// 加载色系CSS文件
if ($themeMode && $themeMode !== 'light'): ?>
<theme:css>Weline_Theme::theme/<?= $area ?>/colors/_<?= $themeMode ?>.css</theme:css>
<?php endif; 

// 加载变量CSS文件（预览配置）
if ($previewThemeId && isset($theme) && $theme->getId()) {
    $variables = \Weline\Theme\Helper\LayoutScanner::getVariablesConfig($theme, $area);
    foreach ($variables as $variable) {
        if ($variable): ?>
<theme:css>Weline_Theme::theme/<?= $area ?>/variables/_<?= $variable ?>.css</theme:css>
<?php 
        endif;
    }
}
