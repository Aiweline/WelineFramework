<?php
/**
 * 片段：Head
 *
 * 页面头部区域（meta标签、CSS、JS初始化等）
 * 字段
 * @meta.name {default="Head头部片段",name="Head头部片段",description="Head头部片段，用于描述片段的名称"}
 * @meta.description {default="页面头部区域（meta标签、CSS、JS初始化等）",name="页面头部区域（meta标签、CSS、JS初始化等）",description="页面头部区域（meta标签、CSS、JS初始化等），用于描述片段的用途"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 *
 * 参数配置说明：
 * - 参数配置由 Block\Partials 在渲染时自动加载
 */
// 主题相关数据由 ControllerFetchFileBefore Observer 设置
$themeData = $this->getData('theme') ?? [];

// 获取 frontend 基础 URL 用于 base 标签
$frontendBaseUrl = $this->request->getUrlBuilder()->getFrontendUrl('/');
?>
<!-- Base URL 设置：所有相对链接将基于此路径 -->
<base href="<?= htmlspecialchars($frontendBaseUrl) ?>">
<!-- Favicon Hook: 允许其他模块通过 hook 提供自定义 favicon -->
