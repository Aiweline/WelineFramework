        height: 24px;
    }
    
    .search-category-facade {
        min-width: 80px;
        font-size: 0.625rem;
    }
    
    .search-input {
        font-size: 0.75rem;
    }
    
    .header-actions {
        gap: 0.125rem;
    }
    
    .action-link {
        min-width: 40px;
        padding: 0.25rem;
    }
    
    .action-line-1 {
        font-size: 0.625rem;
    }
}
</style>

<script>
(function() {
    // 检测分类菜单 Hook 是否有内容，如果没有则显示 fallback
    document.addEventListener('DOMContentLoaded', function() {
        const hookWrapper = document.querySelector('.categories-hook-wrapper');
        if (hookWrapper) {
            const hookContent = hookWrapper.querySelector('.categories-hook-content');
            const fallbackNav = hookWrapper.querySelector('.categories-nav-fallback');
            
            if (hookContent && fallbackNav) {
                // 检查 hook 内容是否为空（去除空白字符）
                const hookText = hookContent.textContent.trim();
                const hookHasContent = hookContent.children.length > 0 || hookText.length > 0;
                
                if (!hookHasContent) {
                    // Hook 没有内容，显示 fallback
                    fallbackNav.style.display = 'block';
                    hookContent.style.display = 'none';
                } else {
                    // Hook 有内容，隐藏 fallback
                    fallbackNav.style.display = 'none';
                    hookContent.style.display = 'block';
                }
            }
        }

        // 移动端多级菜单点击展开/收起
        const isMobile = window.innerWidth <= 768;
        if (isMobile) {
            const categoryItems = document.querySelectorAll('.category-item.has-children');
            // 删除点击展开逻辑，改为纯hover展开
        }

        // 搜索分类下拉菜单同步
        const searchCategorySelect = document.querySelector('.search-category-select');
        const searchCategoryLabel = document.querySelector('.search-category-label');
        const searchCategoryFacade = document.querySelector('.search-category-facade');
        
        if (searchCategorySelect && searchCategoryLabel && searchCategoryFacade) {
            // 点击分类下拉区域，触发 select
            searchCategoryFacade.addEventListener('click', function() {
                searchCategorySelect.focus();
                searchCategorySelect.click();
            });
            
            // 同步 select 值到 label
            searchCategorySelect.addEventListener('change', function() {
                const selectedOption = this.options[this.selectedIndex];
                searchCategoryLabel.textContent = selectedOption.textContent;
            });
        }
        
        // 搜索建议功能
        const searchInput = document.querySelector('.search-input');
        const searchSuggestions = document.getElementById('search-suggestions');
        const searchSuggestionsList = document.getElementById('search-suggestions-list');
        let searchTimeout;
        
        if (searchInput && searchSuggestions && searchSuggestionsList) {
            // 输入时显示建议
            searchInput.addEventListener('input', function() {
                const query = this.value.trim();
                clearTimeout(searchTimeout);
                
                if (query.length >= 2) {
                    searchTimeout = setTimeout(function() {
                        showSearchSuggestions(query);
                    }, 300);
                } else {
                    hideSearchSuggestions();
                }
            });
            
            // 聚焦时显示建议（如果有内容）
            searchInput.addEventListener('focus', function() {
                if (this.value.trim().length >= 2) {
                    showSearchSuggestions(this.value.trim());
                }
            });
            
            // 点击外部关闭建议
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !searchSuggestions.contains(e.target)) {
                    hideSearchSuggestions();
                }
            });
            
            // 键盘导航
            searchInput.addEventListener('keydown', function(e) {
                const items = searchSuggestionsList.querySelectorAll('li');
                const activeItem = searchSuggestionsList.querySelector('li.active');
                let currentIndex = -1;
                
                if (activeItem) {
                    currentIndex = Array.from(items).indexOf(activeItem);
                }
                
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (currentIndex < items.length - 1) {
                        if (activeItem) activeItem.classList.remove('active');
                        items[currentIndex + 1].classList.add('active');
                        items[currentIndex + 1].scrollIntoView({ block: 'nearest' });
                    }
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (currentIndex > 0) {
                        if (activeItem) activeItem.classList.remove('active');
                        items[currentIndex - 1].classList.add('active');
                        items[currentIndex - 1].scrollIntoView({ block: 'nearest' });
                    }
                } else if (e.key === 'Enter' && activeItem) {
                    e.preventDefault();
                    activeItem.click();
                } else if (e.key === 'Escape') {
                    hideSearchSuggestions();
                }
            });
        }
        
        function showSearchSuggestions(query) {
            // 这里可以调用API获取搜索建议
            // 目前使用模拟数据
            const suggestions = generateMockSuggestions(query);
            
            searchSuggestionsList.innerHTML = '';
            
            if (suggestions.length > 0) {
                suggestions.forEach(function(suggestion) {
                    const li = document.createElement('li');
                    li.textContent = suggestion;
                    li.addEventListener('click', function() {
                        searchInput.value = suggestion;
                        hideSearchSuggestions();
                        // 可以在这里触发搜索
                        const form = searchInput.closest('form');
                        if (form) {
                            form.submit();
                        }
                    });
                    searchSuggestionsList.appendChild(li);
                });
                searchSuggestions.setAttribute('aria-hidden', 'false');
            } else {
                hideSearchSuggestions();
            }
        }
        
        function hideSearchSuggestions() {
            searchSuggestions.setAttribute('aria-hidden', 'true');
            searchSuggestionsList.querySelectorAll('li').forEach(function(li) {
                li.classList.remove('active');
            });
        }
        
        function generateMockSuggestions(query) {
            // 模拟搜索建议数据
            const allSuggestions = [
                '智能手机',
                '笔记本电脑',
                '耳机',
                '运动鞋',
                'T恤',
                '背包',
                '手表',
                '相机',
                '平板电脑',
                '键盘鼠标'
            ];
            
            return allSuggestions.filter(function(item) {
                return item.toLowerCase().includes(query.toLowerCase());
            }).slice(0, 8);
        }
        
        // 汉堡菜单切换 - 侧边栏菜单
        const hamburgerMenu = document.getElementById('hamburger-menu');
        const categoriesSidebar = document.getElementById('categories-sidebar');
        const categoriesSidebarOverlay = document.getElementById('categories-sidebar-overlay');
        const categoriesSidebarClose = document.getElementById('categories-sidebar-close');
        
        if (hamburgerMenu && categoriesSidebar && categoriesSidebarOverlay) {
            hamburgerMenu.addEventListener('click', function(e) {
                e.preventDefault();
                const isExpanded = this.getAttribute('aria-expanded') === 'true';
                if (!isExpanded) {
                    showSidebar();
                } else {
                    hideSidebar();
                }
            });
            
            if (categoriesSidebarClose) {
                categoriesSidebarClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    hideSidebar();
                });
            }
            
            categoriesSidebarOverlay.addEventListener('click', function(e) {
                if (categoriesSidebar.contains(e.target)) {
                    return;
                }
                hideSidebar();
            });
            
            // 侧边栏菜单项点击展开/收起
            const sidebarItems = categoriesSidebar.querySelectorAll('.sidebar-category-item.has-children');
            sidebarItems.forEach(function(item) {
                const link = item.querySelector('.sidebar-category-link');
                if (link) {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        item.classList.toggle('active');
                    });
                }
            });
        }
        
        function showSidebar() {
            if (hamburgerMenu) {
                hamburgerMenu.setAttribute('aria-expanded', 'true');
            }
            if (categoriesSidebar) {
                categoriesSidebar.setAttribute('aria-hidden', 'false');
            }
            if (categoriesSidebarOverlay) {
                categoriesSidebarOverlay.setAttribute('aria-hidden', 'false');
            }
            document.body.style.overflow = 'hidden';
        }
        
        function hideSidebar() {
            if (hamburgerMenu) {
                hamburgerMenu.setAttribute('aria-expanded', 'false');
            }
            if (categoriesSidebar) {
                categoriesSidebar.setAttribute('aria-hidden', 'true');
            }
            if (categoriesSidebarOverlay) {
                categoriesSidebarOverlay.setAttribute('aria-hidden', 'true');
            }
            document.body.style.overflow = '';
        }

        // 自适应分类菜单：检测空间并动态调整
        function adjustCategoriesMenu() {
            // 只在桌面端执行（移动端不需要）
            if (window.innerWidth <= 768) {
                // 移动端：显示所有分类，隐藏"更多"按钮
                document.querySelectorAll('.category-more-item').forEach(function(item) {
                    item.style.display = 'none';
                });
                document.querySelectorAll('.category-item.category-hidden').forEach(function(item) {
                    item.classList.remove('category-hidden');
                    item.style.display = '';
                });
                return;
            }

            // 处理两个可能的列表（正常列表和 fallback 列表）
            const lists = [
                { list: document.getElementById('categories-list'), suffix: '' },
                { list: document.getElementById('categories-list-fallback'), suffix: '-fallback' }
            ].filter(function(obj) { return obj.list !== null; });

            lists.forEach(function(obj) {
                const list = obj.list;
                const suffix = obj.suffix;

                const moreItem = document.getElementById('category-more-item' + suffix);
                const moreLink = document.getElementById('category-more-link' + suffix);
                const moreSubmenu = document.getElementById('category-more-submenu' + suffix);

                if (!moreItem || !moreLink || !moreSubmenu) return;

                // 重置：显示所有分类项，隐藏"更多"按钮
                const allItems = Array.from(list.querySelectorAll('.category-item:not(.category-more-item)'));
                allItems.forEach(function(item) {
                    item.classList.remove('category-hidden');
                    item.style.display = '';
                    item.style.visibility = '';
                    item.style.position = '';
                });
                moreItem.style.display = 'none';
                moreSubmenu.innerHTML = '';

                // 获取容器可用宽度
                const categoriesNav = list.closest('.categories-nav');
                if (!categoriesNav) return;

                const containerWidth = categoriesNav.offsetWidth;
                if (containerWidth === 0) return; // 容器未渲染

                // 估算"更多"按钮宽度（包括 gap）
                const moreItemWidth = 80; // 估算值
                const gap = 8; // var(--spacing-sm) 的估算值

                // 计算每个分类项的宽度
                let totalWidth = 0;
                let visibleItems = [];
                let hiddenItems = [];

                allItems.forEach(function(item) {
                    // 确保项目可见以测量宽度
                    const originalDisplay = item.style.display;
                    const originalVisibility = item.style.visibility;
                    const originalPosition = item.style.position;
                    
                    item.style.display = 'block';
                    item.style.visibility = 'visible';
                    item.style.position = 'static';
                    
                    const itemWidth = item.offsetWidth + gap;
                    
                    // 恢复原始样式
                    item.style.display = originalDisplay;
                    item.style.visibility = originalVisibility;
                    item.style.position = originalPosition;
                    
                    // 检查是否放得下（包括"更多"按钮的空间）
                    const needMoreButton = hiddenItems.length > 0;
                    const requiredWidth = totalWidth + itemWidth + (needMoreButton ? 0 : moreItemWidth);
                    
                    if (requiredWidth <= containerWidth) {
                        totalWidth += itemWidth;
                        visibleItems.push(item);
                    } else {
                        hiddenItems.push(item);
                    }
                });

                // 如果有隐藏的分类，显示"更多"按钮
                if (hiddenItems.length > 0) {
                    moreItem.style.display = '';
                    
                    // 将隐藏的分类移到"更多"下拉菜单
                    hiddenItems.forEach(function(item) {
                        item.classList.add('category-hidden');
                        item.style.display = 'none';
                        
                        // 克隆到"更多"菜单（保持原有结构，包括子菜单）
                        const clonedItem = item.cloneNode(true);
                        clonedItem.classList.remove('category-hidden');
                        clonedItem.style.display = '';
                        clonedItem.style.visibility = '';
                        clonedItem.style.position = '';
                        moreSubmenu.appendChild(clonedItem);
                    });
                }
            });
        }

        // 初始化自适应菜单
        adjustCategoriesMenu();

        // 窗口大小改变时重新调整
        let resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(adjustCategoriesMenu, 100);
        });

        // 删除点击展开逻辑，"更多"按钮改为纯hover展开

        // 迷你购物车：点击展开/关闭
        const miniCartOverlay = document.getElementById('mini-cart-overlay');
        const miniCart = document.getElementById('mini-cart');
        const headerCart = document.querySelector('.header-cart');
        const cartLink = document.querySelector('.cart-link');

        if (miniCartOverlay && miniCart && headerCart && cartLink) {
            // 点击购物车按钮切换显示/隐藏
            cartLink.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                toggleMiniCart();
            });
            
            // 点击 header-cart 容器也切换（如果点击的不是按钮）
            headerCart.addEventListener('click', function(e) {
                // 如果点击的是按钮，不处理（已在上面处理）
                if (cartLink.contains(e.target)) {
                    return;
                }
                // 如果点击的是 mini-cart 或 overlay，不处理
                if (miniCart.contains(e.target) || miniCartOverlay.contains(e.target)) {
                    return;
                }
                // 其他情况切换显示
                toggleMiniCart();
            });

            // 点击 overlay 时关闭（关键：确保点击蒙版能关闭，但点击 mini-cart 本身不关闭）
            miniCartOverlay.addEventListener('click', function(e) {
                // 如果点击的是 mini-cart 本身，不关闭
                if (miniCart.contains(e.target)) {
                    return;
                }
                // 点击的是 overlay（蒙版），立即关闭
                e.preventDefault();
                e.stopPropagation();
                hideMiniCart();
            });
            
            // 确保 overlay 可以接收点击事件
            miniCartOverlay.style.pointerEvents = 'auto';
            
            // 阻止 mini-cart 的点击事件冒泡到 overlay
            miniCart.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // 点击关闭按钮时关闭
            const miniCartClose = document.getElementById('mini-cart-close');
            if (miniCartClose) {
                miniCartClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    hideMiniCart();
                });
            }

            // 点击页面其他地方时关闭（排除购物车按钮和迷你购物车本身）
            // 注意：overlay 的点击事件在上面单独处理，这里排除 overlay 避免重复
            document.addEventListener('click', function(e) {
                // 如果点击的是 overlay 或 mini-cart，不在这里处理（已在上面单独处理）
                if (miniCartOverlay.contains(e.target) || miniCart.contains(e.target)) {
                    return;
                }
                // 如果点击的是购物车按钮或容器，不关闭（会触发切换）
                if (headerCart.contains(e.target)) {
                    return;
                }
                // 点击页面其他地方，立即关闭
                hideMiniCart();
            });

            // 切换迷你购物车显示/隐藏的函数
            function toggleMiniCart() {
                if (headerCart.classList.contains('mini-cart-open')) {
                    hideMiniCart();
                } else {
                    showMiniCart();
                }
            }

            // 显示迷你购物车的函数（添加 class）
            function showMiniCart() {
                headerCart.classList.add('mini-cart-open');
                // 更新 aria-expanded 属性
                headerCart.setAttribute('aria-expanded', 'true');
            }

            // 隐藏迷你购物车的函数（移除 class）
            function hideMiniCart() {
                headerCart.classList.remove('mini-cart-open');
                // 更新 aria-expanded 属性
                headerCart.setAttribute('aria-expanded', 'false');
            }
        }
    });
})();
</script>

