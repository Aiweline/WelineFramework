<script data-no-extract="true">
    (function() {
        var header = document.getElementById('header');
        if (!header) {
            return;
        }
        var toggle = header.querySelector('[data-theme-header-toggle]');
        if (!toggle) {
            return;
        }
        toggle.addEventListener('click', function() {
            header.classList.toggle('is-open');
        });
    })();
</script>
