<?php
/**
 * Theme partial: default frontend header.
 *
 * @meta.name {default="Default Header",name="Default Header",description="Theme-owned frontend header"}
 * @param.logo {default="",name="Logo URL",description="Logo image URL"}
 * @param.logoText {default="Weline",name="Logo Text",description="Text shown when no logo image is configured"}
 * @param.navItems {default=[],name="Navigation Items",description="Navigation items, format: [{\"text\":\"Home\",\"url\":\"/\"}]"}
 * @param.showSearch {default=true,name="Show Search",description="Whether the default search area is shown"}
 * @param.showUserMenu {default=true,name="Show User Menu",description="Whether account/cart actions are shown"}
 * @param.class {default="",name="Extra CSS class",description="Extra CSS class"}
 */

$meta = $this->getData('meta') ?? [];
$logo = (string)($meta['logo'] ?? '');
$logoText = (string)($meta['logoText'] ?? __('Weline'));
$logoHeight = max(28, (int)($meta['logoHeight'] ?? 38));
$class = (string)($meta['class'] ?? '');
$navItems = $this->getData('navItems') ?? $meta['navItems'] ?? [];

if (is_string($navItems)) {
    $decodedNavItems = json_decode($navItems, true);
    $navItems = is_array($decodedNavItems) ? $decodedNavItems : [];
}

if (!is_array($navItems) || $navItems === []) {
    $navItems = [
        ['text' => __('Home'), 'url' => '/'],
        ['text' => __('Products'), 'url' => '/products'],
        ['text' => __('Solutions'), 'url' => '/solutions'],
        ['text' => __('Docs'), 'url' => '/docs'],
        ['text' => __('Support'), 'url' => '/support'],
    ];
}

$boolValue = static function ($value, bool $default): bool {
    if ($value === null || $value === '') {
        return $default;
    }
    $parsed = filter_var($value, FILTER_VALIDATE_BOOL, FILTER_NULL_ON_FAILURE);
    return $parsed ?? $default;
};

$showSearch = $boolValue($meta['showSearch'] ?? true, true);
$showUserMenu = $boolValue($meta['showUserMenu'] ?? true, true);
$esc = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
