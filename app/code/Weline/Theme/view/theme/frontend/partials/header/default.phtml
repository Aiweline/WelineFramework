/* 分类子菜单 - Megamenu 样式（第一层，直接子菜单） */
.category-item.has-children > .category-submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background-color: transparent;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
    min-width: 1100px;
    max-width: 1400px;
    width: auto;
    margin-top: 0.5rem;
    display: none;
    opacity: 0;
    transform: translateY(10px) scale(0.98);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 1001;
    list-style: none;
    margin: 0;
    padding: 2rem;
    grid-template-columns: repeat(4, minmax(220px, 1fr)); /* 固定4列，确保所有列都显示 */
    gap: 2rem;
    column-gap: 3rem;
    grid-auto-flow: row; /* 确保按行排列 */
}

/* 当菜单项靠近右边缘时，megamenu 从右侧对齐 */
