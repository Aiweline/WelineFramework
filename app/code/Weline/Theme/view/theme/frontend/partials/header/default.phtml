<?php
/**
 * 片段：Header
 * 
 * 页面头部区域（导航栏、Logo、搜索等）
 * 字段
 * @meta.name {default="Header头部片段",name="Header头部片段",description="Header头部片段，用于描述片段的名称"}
 * @meta.description {default="页面头部区域（导航栏、Logo、搜索等）",name="页面头部区域（导航栏、Logo、搜索等）",description="页面头部区域（导航栏、Logo、搜索等），用于描述片段的用途"}
 * @param.logo {default="",name="Logo URL",description="Logo图片URL，用于设置头部Logo图片地址"}
 * @param.logoText {default="Weline",name="Logo文字",description="Logo文字，用于设置当Logo图片不存在时显示的文字"}
 * @param.navItems {default=[],name="导航项数组",description="导航项数组，用于设置头部导航菜单，格式：[{\"text\":\"菜单文字\",\"url\":\"菜单链接\"}]"}
 * @param.showSearch {default=true,name="是否显示搜索框",description="是否显示搜索框，用于控制搜索框的显示"}
 * @param.showUserMenu {default=true,name="是否显示用户菜单",description="是否显示用户菜单，用于控制用户菜单的显示"}
 * @param.class {default="",name="额外CSS类",description="额外CSS类，用于设置页面额外CSS类"}
 */
$logo = $this->getData('logo') ?? '';
$logoText = $this->getData('logoText') ?? __('Weline');
$navItems = $this->getData('navItems') ?? [];
$showSearch = $this->getData('showSearch') ?? true;
$showUserMenu = $this->getData('showUserMenu') ?? true;
$class = $this->getData('class') ?? '';

$baseUrl = $this->request->getBaseUrl();
$frontendUrl = $this->request->getUrlBuilder()->getFrontendUrl('/');
?>
<header class="weline-header <?= htmlspecialchars($class) ?>" data-layout="default" data-layout-type="default">
    <div class="header-container">
        <!-- Logo -->
        <div class="header-logo">
            <a href="<?= $frontendUrl ?>" title="<?= __('首页') ?>">
                <?php if ($logo): ?>
                    <img src="<?= htmlspecialchars($logo) ?>" alt="<?= __('网站Logo') ?>" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';">
                <?php else: ?>
                    <img src="@static(Weline_Frontend::img/logo.png)" alt="<?= __('网站Logo') ?>" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';">
                <?php endif; ?>
                <span class="logo-text" style="display: none;"><?= htmlspecialchars($logoText) ?></span>
            </a>
        </div>

        <!-- 导航菜单 -->
        <?php if (!empty($navItems)): ?>
            <nav class="header-nav">
                <ul class="nav-list">
                    <?php foreach ($navItems as $item): ?>
                        <li class="nav-item">
                            <a href="<?= htmlspecialchars($item['url'] ?? '#') ?>" class="nav-link">
                                <?= htmlspecialchars($item['text'] ?? '') ?>
                            </a>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </nav>
        <?php endif; ?>

        <!-- 搜索框 -->
        <?php if ($showSearch): ?>
            <div class="header-search">
                <form action="<?= $frontendUrl ?>search" method="get" class="search-form">
                    <input type="text" name="q" class="search-input" placeholder="<?= __('搜索商品...') ?>" autocomplete="off">
                    <button type="submit" class="search-button" title="<?= __('搜索') ?>">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>
        <?php endif; ?>

        <!-- 右侧功能区 -->
        <div class="header-actions">
            <!-- 语言切换 Hook -->
            <div class="header-action-item" data-hook="header-language-switcher">
                <hook>header-language-switcher</hook>
            </div>

            <!-- 货币切换 Hook -->
            <div class="header-action-item" data-hook="header-currency-switcher">
                <hook>header-currency-switcher</hook>
            </div>

            <!-- 购物车 Hook -->
            <div class="header-action-item" data-hook="header-cart">
                <hook>header-cart</hook>
            </div>

            <!-- 个人中心 -->
            <?php if ($showUserMenu): ?>
                <div class="header-action-item header-account">
                    <a href="<?= $frontendUrl ?>account" class="account-link" title="<?= __('我的账户') ?>">
                        <i class="fas fa-user"></i>
                        <span class="account-text"><?= __('账户') ?></span>
                    </a>
                    <div class="account-dropdown">
                        <ul>
                            <li><a href="<?= $frontendUrl ?>account/dashboard"><?= __('仪表盘') ?></a></li>
                            <li><a href="<?= $frontendUrl ?>account/orders"><?= __('我的订单') ?></a></li>
                            <li><a href="<?= $frontendUrl ?>account/settings"><?= __('账户设置') ?></a></li>
                            <li><a href="<?= $frontendUrl ?>account/logout"><?= __('退出登录') ?></a></li>
                        </ul>
                    </div>
                </div>
            <?php endif; ?>
        </div>
    </div>
</header>

