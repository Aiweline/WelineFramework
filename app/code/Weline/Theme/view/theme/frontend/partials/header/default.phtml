</style>

<script>
(function() {


        // 移动端多级菜单点击展开/收起
        const isMobile = window.innerWidth <= 768;
        if (isMobile) {
            const categoryItems = document.querySelectorAll('.category-item.has-children');
            // 删除点击展开逻辑，改为纯hover展开
        }

        // 搜索相关功能已移至 search.js 模块
        // 搜索分类下拉菜单同步和搜索建议功能由 Weline.Search 模块处理

        // 导航链接"更多"按钮功能
        const navLinksList = document.getElementById('nav-links-list');
        const navMoreWrapper = document.getElementById('nav-more-wrapper');
        const navMoreBtn = document.getElementById('nav-more-btn');
        const navMoreDropdown = document.getElementById('nav-more-dropdown');
        const headerNavFill = document.getElementById('header-nav-fill');
        
        if (navLinksList && navMoreWrapper && navMoreBtn && navMoreDropdown && headerNavFill) {
            let resizeTimeout;
            
            // 检查并调整菜单项
            function adjustNavLinks() {
                // 重置所有菜单项
                const allItems = navLinksList.querySelectorAll('li');
                allItems.forEach(function(item) {
                    item.classList.remove('hidden');
                });
                navMoreDropdown.innerHTML = '';
                navMoreWrapper.style.display = 'none';
                
                // 等待DOM更新
                requestAnimationFrame(function() {
                    // 获取nav-links-list的实际宽度和可用宽度
                    const navLinksListRect = navLinksList.getBoundingClientRect();
                    const headerNavFillRect = headerNavFill.getBoundingClientRect();
                    
                    // 计算可用宽度（从nav-links-list左边缘到header-nav-fill右边缘）
                    const availableWidth = headerNavFillRect.right - navLinksListRect.left;
                    
                    // 临时显示"更多"按钮以获取其宽度
                    navMoreWrapper.style.display = 'flex';
                    const moreBtnWidth = navMoreWrapper.getBoundingClientRect().width + 10; // 加一些边距
                    navMoreWrapper.style.display = 'none';
                    
                    // 计算每个菜单项的宽度
                    const items = Array.from(navLinksList.querySelectorAll('li'));
                    let totalWidth = 0;
                    let itemsToHide = [];
                    
                    // 获取gap值（从CSS中，gap: 1.25rem）
                    const computedStyle = window.getComputedStyle(navLinksList);
                    const gap = parseFloat(computedStyle.gap) || 20; // 默认20px
                    
                    // 计算可见项的总宽度
                    for (let i = 0; i < items.length; i++) {
                        const item = items[i];
                        const itemRect = item.getBoundingClientRect();
                        const itemWidth = itemRect.width;
                        const itemGap = i > 0 ? gap : 0;
                        
                        // 检查是否需要显示"更多"按钮
                        if (totalWidth + itemWidth + itemGap + moreBtnWidth > availableWidth) {
                            // 需要隐藏这个及之后的项
                            itemsToHide = items.slice(i);
                            break;
                        }
                        totalWidth += itemWidth + itemGap;
                    }
                    
                    // 如果有需要隐藏的项，显示"更多"按钮并移动项
                    if (itemsToHide.length > 0) {
                        navMoreWrapper.style.display = 'flex';
                        itemsToHide.forEach(function(item) {
                            item.classList.add('hidden');
                            // 创建下拉菜单项
                            const dropdownItem = document.createElement('li');
                            const link = item.querySelector('a');
                            if (link) {
                                dropdownItem.innerHTML = link.outerHTML;
                                navMoreDropdown.appendChild(dropdownItem);
                            }
                        });
                    } else {
                        navMoreWrapper.style.display = 'none';
                    }
                });
            }
            
            // 初始调整
            adjustNavLinks();
            
            // 窗口大小变化时重新调整
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(adjustNavLinks, 100);
            });
            
            let isClickActivated = false; // 标记是否通过点击激活
            
            // "更多"按钮点击事件
            navMoreBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const isActive = navMoreWrapper.classList.contains('active');
                
                isClickActivated = !isActive; // 如果激活则为true，如果关闭则为false
                
                if (isActive) {
                    navMoreWrapper.classList.remove('active');
                    navMoreBtn.setAttribute('aria-expanded', 'false');
                    navMoreDropdown.setAttribute('aria-hidden', 'true');
                } else {
                    navMoreWrapper.classList.add('active');
                    navMoreBtn.setAttribute('aria-expanded', 'true');
                    navMoreDropdown.setAttribute('aria-hidden', 'false');
                }
            });
            
            // hover事件：鼠标进入时展开（CSS会自动处理，这里更新aria属性）
            navMoreWrapper.addEventListener('mouseenter', function() {
                navMoreBtn.setAttribute('aria-expanded', 'true');
                navMoreDropdown.setAttribute('aria-hidden', 'false');
            });
            
            // 鼠标离开时：如果是通过点击激活的，保持展开；如果是hover，延迟关闭
            let hoverTimeout;
            navMoreWrapper.addEventListener('mouseleave', function() {
                if (!isClickActivated) {
                    // 如果不是点击激活的，延迟关闭（给用户时间移动到下拉菜单）
                    hoverTimeout = setTimeout(function() {
                        if (!navMoreWrapper.matches(':hover')) {
                            navMoreWrapper.classList.remove('active');
                            navMoreBtn.setAttribute('aria-expanded', 'false');
                            navMoreDropdown.setAttribute('aria-hidden', 'true');
                        }
                    }, 200);
                }
            });
            
            // 点击外部关闭下拉菜单（仅在点击激活时）
            document.addEventListener('click', function(e) {
                if (!navMoreWrapper.contains(e.target) && isClickActivated) {
                    navMoreWrapper.classList.remove('active');
                    navMoreBtn.setAttribute('aria-expanded', 'false');
                    navMoreDropdown.setAttribute('aria-hidden', 'true');
                    isClickActivated = false;
                }
            });
        }
        
        // 汉堡菜单切换 - 侧边栏菜单
        const hamburgerMenu = document.getElementById('hamburger-menu');
        const categoriesSidebar = document.getElementById('categories-sidebar');
        const categoriesSidebarOverlay = document.getElementById('categories-sidebar-overlay');
        const categoriesSidebarClose = document.getElementById('categories-sidebar-close');
        
        // 检查是否已经有其他处理器（避免与 theme.js 冲突）
        if (hamburgerMenu && categoriesSidebar && categoriesSidebarOverlay && !hamburgerMenu.dataset.hamburgerHandler) {
            // 标记已处理
            hamburgerMenu.dataset.hamburgerHandler = 'true';
            // 使用一个标志来防止重复触发
            let isProcessing = false;
            let lastClickTime = 0;
            let mouseDownPos = null;
            let mouseDownTime = 0;
            
            // 处理汉堡菜单点击的函数
            function handleHamburgerClick(e) {
                // 防止重复触发
                const now = Date.now();
                if (isProcessing || (now - lastClickTime < 300)) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    return;
                }
                
                // 检测是否为误触：如果鼠标移动距离过大，可能是滑动操作
                if (mouseDownPos) {
                    const moveDistance = Math.sqrt(
                        Math.pow(e.clientX - mouseDownPos.x, 2) + 
                        Math.pow(e.clientY - mouseDownPos.y, 2)
                    );
                    // 如果移动距离超过 5px，认为是滑动操作，不触发
                    if (moveDistance > 5) {
                        mouseDownPos = null;
                        e.preventDefault();
                        e.stopPropagation();
                        e.stopImmediatePropagation();
                        return;
                    }
                }
                
                // 检测点击持续时间：如果按下时间过短（< 50ms），可能是误触
                if (mouseDownTime && (now - mouseDownTime < 50)) {
                    mouseDownPos = null;
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    return;
                }
                
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                
                isProcessing = true;
                lastClickTime = now;
                mouseDownPos = null;
                mouseDownTime = 0;
                
                const isExpanded = hamburgerMenu.getAttribute('aria-expanded') === 'true';
                if (!isExpanded) {
                    showSidebar();
                } else {
                    hideSidebar();
                }
                
                // 延迟后重置标志，防止快速连续点击
                setTimeout(function() {
                    isProcessing = false;
                }, 300);
            }
            
            // 记录鼠标按下位置和时间
            hamburgerMenu.addEventListener('mousedown', function(e) {
                mouseDownPos = { x: e.clientX, y: e.clientY };
                mouseDownTime = Date.now();
            }, true);
            
            // 触摸设备支持
            hamburgerMenu.addEventListener('touchstart', function(e) {
                const touch = e.touches[0];
                mouseDownPos = { x: touch.clientX, y: touch.clientY };
                mouseDownTime = Date.now();
            }, true);
            
            hamburgerMenu.addEventListener('touchend', function(e) {
                if (!mouseDownPos) return;
                
                const touch = e.changedTouches[0];
                const moveDistance = Math.sqrt(
                    Math.pow(touch.clientX - mouseDownPos.x, 2) + 
                    Math.pow(touch.clientY - mouseDownPos.y, 2)
                );
                
                // 触摸移动距离超过 10px，认为是滑动
                if (moveDistance > 10) {
                    mouseDownPos = null;
                    mouseDownTime = 0;
                    return;
                }
                
                // 模拟点击事件
                const clickEvent = new MouseEvent('click', {
                    bubbles: true,
                    cancelable: true,
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                hamburgerMenu.dispatchEvent(clickEvent);
            }, true);
            
            // 只使用 click 事件，避免重复触发
            hamburgerMenu.addEventListener('click', handleHamburgerClick, true);
            
            if (categoriesSidebarClose) {
                categoriesSidebarClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    hideSidebar();
                });
            }
            
            categoriesSidebarOverlay.addEventListener('click', function(e) {
                if (categoriesSidebar.contains(e.target)) {
                    return;
                }
                hideSidebar();
            });
            
            // 侧边栏菜单项点击展开/收起
            const sidebarItems = categoriesSidebar.querySelectorAll('.sidebar-category-item.has-children');
            sidebarItems.forEach(function(item) {
                const linkWrapper = item.querySelector('.sidebar-category-link-wrapper');
                const link = item.querySelector('.sidebar-category-link');
                const arrow = item.querySelector('.sidebar-category-arrow');
                
                if (linkWrapper) {
                    // 点击容器（除了链接文字部分）时展开/收起
                    linkWrapper.addEventListener('click', function(e) {
                        // 如果点击的是链接文字，允许默认跳转
                        if (link && (e.target === link || link.contains(e.target))) {
                            return; // 允许链接正常跳转
                        }
                        
                        // 如果点击的是箭头或其他区域，阻止默认行为并切换展开状态
                        if (arrow && (e.target === arrow || arrow.contains(e.target))) {
                            e.preventDefault();
                            e.stopPropagation();
                            item.classList.toggle('active');
                        } else if (window.innerWidth <= 768) {
                            // 移动端：点击容器其他区域也展开/收起
                            e.preventDefault();
                            e.stopPropagation();
                            item.classList.toggle('active');
                        }
                    });
                }
            });
        }
        
        function showSidebar() {
            if (hamburgerMenu) {
                hamburgerMenu.setAttribute('aria-expanded', 'true');
            }
            if (categoriesSidebar) {
                categoriesSidebar.setAttribute('aria-hidden', 'false');
            }
            if (categoriesSidebarOverlay) {
                categoriesSidebarOverlay.setAttribute('aria-hidden', 'false');
            }
            document.body.style.overflow = 'hidden';
        }
        
        function hideSidebar() {
            if (hamburgerMenu) {
                hamburgerMenu.setAttribute('aria-expanded', 'false');
            }
            if (categoriesSidebar) {
                categoriesSidebar.setAttribute('aria-hidden', 'true');
            }
            if (categoriesSidebarOverlay) {
                categoriesSidebarOverlay.setAttribute('aria-hidden', 'true');
            }
            document.body.style.overflow = '';
        }



        // 迷你购物车：点击展开/关闭
        const miniCartOverlay = document.getElementById('mini-cart-overlay');
        const miniCart = document.getElementById('mini-cart');
        const headerCart = document.querySelector('.header-cart');
        const cartLink = document.querySelector('.cart-link');

        // 迷你购物车控制函数（需要在 if 之前定义，以便在 if 内部调用）
        function toggleMiniCart() {
            if (headerCart && headerCart.classList.contains('mini-cart-open')) {
                hideMiniCart();
            } else {
                showMiniCart();
            }
        }

        function showMiniCart() {
            if (headerCart) {
                headerCart.classList.add('mini-cart-open');
                headerCart.setAttribute('aria-expanded', 'true');
            }
        }

        function hideMiniCart() {
            if (headerCart) {
                headerCart.classList.remove('mini-cart-open');
                headerCart.setAttribute('aria-expanded', 'false');
            }
        }

        if (miniCartOverlay && miniCart && headerCart && cartLink) {
            // 点击购物车按钮切换显示/隐藏
            cartLink.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                toggleMiniCart();
            });
            
            // 点击 header-cart 容器也切换（如果点击的不是按钮）
            headerCart.addEventListener('click', function(e) {
                // 如果点击的是按钮，不处理（已在上面处理）
                if (cartLink.contains(e.target)) {
                    return;
                }
                // 如果点击的是 mini-cart 或 overlay，不处理
                if (miniCart.contains(e.target) || miniCartOverlay.contains(e.target)) {
                    return;
                }
                // 其他情况切换显示
                toggleMiniCart();
            });

            // 点击 overlay 时关闭（关键：确保点击蒙版能关闭，但点击 mini-cart 本身不关闭）
            miniCartOverlay.addEventListener('click', function(e) {
                // 如果点击的是 mini-cart 本身，不关闭
                if (miniCart.contains(e.target)) {
                    return;
                }
                // 点击的是 overlay（蒙版），立即关闭
                e.preventDefault();
                e.stopPropagation();
                hideMiniCart();
            });
            
            // 确保 overlay 可以接收点击事件
            miniCartOverlay.style.pointerEvents = 'auto';
            
            // 阻止 mini-cart 的点击事件冒泡到 overlay
            miniCart.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // 点击关闭按钮时关闭
            const miniCartClose = document.getElementById('mini-cart-close');
            if (miniCartClose) {
                miniCartClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    hideMiniCart();
                });
            }

            // 点击页面其他地方时关闭（排除购物车按钮和迷你购物车本身）
            // 注意：overlay 的点击事件在上面单独处理，这里排除 overlay 避免重复
            document.addEventListener('click', function(e) {
                // 如果点击的是 overlay 或 mini-cart，不在这里处理（已在上面单独处理）
                if (miniCartOverlay.contains(e.target) || miniCart.contains(e.target)) {
                    return;
                }
                // 如果点击的是购物车按钮或容器，不关闭（会触发切换）
                if (headerCart.contains(e.target)) {
                    return;
                }
                // 点击页面其他地方，立即关闭
                hideMiniCart();
            });
        }

        // --- 修复：导航条溢出检测与处理 ---
        const mainNav = document.querySelector('.header-main-nav');
        const navLeft = document.querySelector('.header-nav-left');
        const navRight = document.querySelector('.header-nav-right');
        // 复用上面已声明的变量：headerNavFill, navLinksList, navMoreWrapper, navMoreDropdown
        const navList = navLinksList; // navLinksList 已在上面声明

        if (mainNav && navList && navMoreWrapper) {
            function checkNavFillOverflow() {
                // 1. 获取最原始的、不可变的外层物理宽度
                // 不要直接测量 mainNav，因为它可能被内部项撑开，要测量它的父容器
                const headerContainer = mainNav.parentElement;
                const totalPhysicalWidth = headerContainer.getBoundingClientRect().width;
                
                // 2. 先重置所有项显示，以便后续循环计算它们的真实宽度
                const items = Array.from(navList.children);
                items.forEach(item => {
                    item.style.display = 'block';
                    item.classList.remove('hidden');
                });
                navMoreWrapper.style.display = 'none';

                // 3. 测量左右两侧已占用的空间
                const leftWidth = navLeft ? navLeft.getBoundingClientRect().width : 0;
                const rightWidth = navRight ? navRight.getBoundingClientRect().width : 0;
                
                // 4. 计算中间链接区域能拿到的真正“净空”
                const baseGap = 30; // 区域间固定安全间隙
                let availableForLinks = totalPhysicalWidth - leftWidth - rightWidth - baseGap;

                // 5. 遍历计算
                const moreBtnWidth = 90; // “更多”按钮预估宽
                let currentAccumulatedWidth = 0;
                let overflowIndices = [];
                const itemGap = 20; // 链接项之间的间隙

                items.forEach((item, index) => {
                    // 在这一步，由于我们之前设为了 display: block，getBoundingClientRect 拿到的就是它们的自然宽度
                    const itemWidth = item.getBoundingClientRect().width;
                    currentAccumulatedWidth += itemWidth + itemGap; 
                    
                    if (currentAccumulatedWidth > availableForLinks) {
                        overflowIndices.push(index);
                    } else if (currentAccumulatedWidth > (availableForLinks - moreBtnWidth) && index < items.length - 1) {
                        // 灵敏预测：如果剩下的空间不够放“更多”按钮，就开始折叠
                        overflowIndices.push(index);
                    }
                });

                // 6. 应用折叠结果
                if (overflowIndices.length > 0) {
                    // 只有这里显式设置为 flex
                    navMoreWrapper.style.display = 'flex';
                    navMoreDropdown.innerHTML = '';
                    
                    overflowIndices.forEach(index => {
                        const item = items[index];
                        item.style.display = 'none';
                        item.classList.add('hidden');
                        
                        const link = item.querySelector('a');
                        if (link) {
                            const li = document.createElement('li');
                            const newLink = link.cloneNode(true);
                            li.appendChild(newLink);
                            navMoreDropdown.appendChild(li);
                        }
                    });
                }
            }

            // 使用 ResizeObserver 监听关键容器变化
            const navResizeObserver = new ResizeObserver(() => {
                requestAnimationFrame(checkNavFillOverflow);
            });
            navResizeObserver.observe(mainNav);
            if (navLeft) navResizeObserver.observe(navLeft);

            // 同时绑定窗口缩放事件作为备用
            window.addEventListener('resize', checkNavFillOverflow);

            // 初始执行
            setTimeout(checkNavFillOverflow, 100); // 稍微延迟以等待布局完全稳定
        }
})();
</script>

