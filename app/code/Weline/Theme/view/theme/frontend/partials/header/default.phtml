.category-item.has-children > .category-link-wrapper:hover ~ .category-submenu,
.category-item.has-children .category-link:hover ~ .category-submenu {
    display: grid !important; /* 显示子菜单，使用grid布局 */
    opacity: 1;
    transform: translateY(0) scale(1);
}

/* 当鼠标在父菜单项（category-item）上时，也显示子菜单
