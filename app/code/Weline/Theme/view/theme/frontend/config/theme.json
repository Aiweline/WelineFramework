{
    "name": "weline_frontend",
    "title": "Weline Default Theme",
    "version": "1.0.0",
    "description": "Weline Frontend 默认主题，参考Amazon简约风格",
    "author": "Weline Team",
    "license": "MIT",
    "homepage": "https://aiweline.com",
    "module": "Weline_Theme",
    "area": "frontend",
    
    "variables": {
        "primary-color": "#f0c14b",
        "font-family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
        "container-max-width": "1200px"
    },
    
    "themes": [
        {
            "name": "light",
            "label": "亮色主题",
            "default": true
        },
        {
            "name": "dark",
            "label": "暗色主题",
            "default": false
        },
        {
            "name": "amazon",
            "label": "Amazon风格",
            "default": false
        }
    ],
    
    "components": [
        {
            "name": "button",
            "file": "components/button.phtml",
            "description": "按钮组件"
        },
        {
            "name": "input",
            "file": "components/input.phtml",
            "description": "输入框组件"
        },
        {
            "name": "card",
            "file": "components/card.phtml",
            "description": "卡片组件"
        },
        {
            "name": "modal",
            "file": "components/modal.phtml",
            "description": "模态框组件"
        },
        {
            "name": "alert",
            "file": "components/alert.phtml",
            "description": "提示框组件"
        },
        {
            "name": "form-group",
            "file": "components/form-group.phtml",
            "description": "表单组组件"
        },
        {
            "name": "badge",
            "file": "components/badge.phtml",
            "description": "徽章组件"
        },
        {
            "name": "dropdown",
            "file": "components/dropdown.phtml",
            "description": "下拉菜单组件"
        },
        {
            "name": "table",
            "file": "components/table.phtml",
            "description": "表格组件"
        },
        {
            "name": "pagination",
            "file": "components/pagination.phtml",
            "description": "分页组件"
        }
    ],
    
    "layouts": [
        {
            "name": "default",
            "file": "layouts/default.phtml",
            "description": "默认布局"
        },
        {
            "name": "auth",
            "file": "layouts/auth.phtml",
            "description": "认证页面布局"
        },
        {
            "name": "dashboard",
            "file": "layouts/dashboard.phtml",
            "description": "仪表盘布局"
        },
        {
            "name": "minimal",
            "file": "layouts/minimal.phtml",
            "description": "极简布局"
        }
    ],
    
    "features": {
        "rtl": false,
        "responsive": true,
        "dark-mode": true,
        "custom-colors": true
    }
}

