        "partials": {
          "name": "部件",
          "description": "部件命名空间",
          "options": {},
          "values": [],
          "default": "default",
          "type": "select",
          "required": true,
          "placeholder": "请选择部件",
          "show": true
        }
      },
      "backend": {
        "default": "后端",
        "name": "后端",
        "description": "后端主题",
        "layout": {
          "name": "布局",
          "description": "布局命名空间",
          "options": {},
          "values": [],
          "default": "default",
          "type": "select",
          "required": true,
          "placeholder": "请选择布局",
          "show": true
        }
      }
    }
