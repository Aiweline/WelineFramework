<js:part name="debounce"/>
<script>
(function() {
    'use strict';
    
    window.QueuePage = new Vue({
        el: '#QueuePage',
        data: {
            tip: '',
            dir: '{{dir}}',
            module: '{{module}}',
            queueName: '{{queueData.name}}',
            params: {
                id: '{{queueData.queue_id}}',
                type_id: '{{queueData.type_id}}',
                attributes: [],
                name: '{{queueData.name}}',
            },
            activeName: '{{queueData.progress|"progress-select-queueData"}}',
            QueueTypesSearchVal: '',
            queue_types: <?= isset($queue_types) ? json_encode($queue_types) : '[]' ?>,
            typeAttributeParams: [],
            types: <?= isset($types) ? json_encode($types) : '[]' ?>,
            clickedParamsProcess: false,
        },
        mounted: function() {
            this.activeName = '{{queueData.progress|"progress-select-queueData"}}';
            if (this.params.type_id) {
                this.renderSearchQueueTypeAttributes();
            }
            if (this.params.type_id) {
                for (var i = 0; i < this.queue_types.length; i++) {
                    if (this.queue_types[i].type_id == this.params.type_id) {
                        this.changeTypeTip(this.queue_types[i]);
                        break;
                    }
                }
            }
        },
        methods: {
            changeTypeTip: function(t) {
                this.tip = t.tip;
                this.queueName = t.name;
                this.clickedParamsProcess = false;
            },
            submitQueue: function() {
                var self = this;
                if (!this.params.type_id) {
                    Swal.fire({
                        title: '@lang{请先选择队列类型再操作！}',
                        text: '@lang{当前队列类型为空！无法创建属性！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    });
                    return false;
                }
                $.ajax({
                    type: 'POST',
                    url: "@backend-url('*/backend/queue/form')?module=" + this.module + "&dir=" + this.dir,
                    data: this.params,
                    success: function(res) {
                        if (res.code === 200) {
                            Swal.fire({
                                title: res.msg,
                                icon: 'success',
                                confirmButtonText: '@lang{好的}'
                            }).then(function(result) {
                                if (result.isConfirmed) {
                                    if (window.showLoading) showLoading();
                                    window.parent.location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                title: '@lang{队列创建失败!}',
                                text: JSON.stringify(res.msg),
                                icon: 'error',
                                confirmButtonText: '@lang{好的}'
                            });
                        }
                    }
                });
            },
            debounceChange: debounce(function(code, type_id, set_id, group_id) {
                var self = this;
                if (!type_id) {
                    Swal.fire({
                        title: '@lang{请先选择队列类型再操作！}',
                        text: '@lang{当前队列类型为空！无法创建属性！}',
                        icon: 'warning',
                        confirmButtonText: '@lang{好的}'
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            self.activeName = 'progress-select-queueData';
                        }
                    });
                    return false;
                }
                $.ajax({
                    type: "get",
                    url: '@backend-url("*/backend/queue/search")?field=code&limit=1&search=' + code + '&type_id=' + type_id + '&set_id=' + set_id + '&group_id=' + group_id,
                    dataType: "json",
                    success: function(res) {
                        if (res.items.length > 0) {
                            Swal.fire({
                                title: '@lang{属性已存在！}',
                                text: '@lang{该属性已存在！}',
                                icon: 'warning',
                                confirmButtonText: '@lang{好的}'
                            }).then(function(result) {
                                if (result.isConfirmed) {
                                    $('#progress-queueData-code').css({border: 'red 1px solid'});
                                }
                            });
                        } else {
                            $('#progress-queueData-code').css({border: 'green 1px solid'});
                        }
                    }
                });
            }, 500),
            checkCode: function(e) {
                this.debounceChange(this.params.code, this.params.type_id, this.params.set_id, this.params.group_id);
            },
            renderSearchQueueTypes: debounce(function(e) {
                var self = this;
                $.ajax({
                    url: '@backend-url("*/backend/queue/searchType")?q=' + this.QueueTypesSearchVal + '&module={{module}}&dir={{dir}}',
                    success: function(res) {
                        self.queue_types = res['data'];
                    }
                });
            }, 500),
            renderSearchQueueTypeAttributes: function(e) {
                var self = this;
                if (window.showLoading) showLoading();
                var queue_id = '';
                if (this.params.id) {
                    queue_id = '&queue_id=' + this.params.id;
                }
                $.ajax({
                    url: '@backend-url("*/backend/queue/typeAttributes")?id=' + this.params.id + '&type_id=' + this.params.type_id,
                    success: function(res) {
                        if (res['msg']) {
                            Swal.fire({
                                title: '警告！',
                                text: res['msg'],
                                icon: 'error',
                                dangerMode: true,
                                confirmButtonText: '@lang{好的}'
                            });
                            return false;
                        }
                        var html = '';
                        var queueParamsForm = $('#queueParamsForm');
                        queueParamsForm.html(html);
                        for (var i = 0; i < res['data'].length; i++) {
                            html += '<div class="gap-2 col-lg-4 col-md-6 col-sm-12">' + res['data'][i].html + '</div>';
                        }
                        if ('' === html) {
                            html = '<lang>队列无属性，可以直接进行下一步提交。</lang>';
                        }
                        queueParamsForm.html(html);
                        self.typeAttributeParams = res['data'];
                        if (window.hideLoading) hideLoading();
                    }
                });
            },
            findLabel: function(arr, id, key, name) {
                var label = '';
                arr.forEach(function(item) {
                    if (item[key] == id) {
                        label = item[name];
                    }
                });
                return label;
            },
            changeType: function(arr, id) {
                var find_item = {};
                var self = this;
                arr.forEach(function(item) {
                    if (item.type_id == Number(id)) {
                        self.params.has_option = item.is_swatch;
                        self.stopable = item.is_swatch;
                        find_item = item;
                    }
                });
                this.debounceSaveType(find_item);
                this.activeAttrItem = find_item;
            },
            changeNav: function(name, reload) {
                if (reload === undefined) reload = true;
                if (this.clickedParamsProcess) {
                    reload = false;
                }
                this.activeName = name;
                if (name === 'progress-params' && this.params.type_id !== '' && reload) {
                    this.clickedParamsProcess = true;
                    this.renderSearchQueueTypeAttributes();
                }
                if (name === 'progress-confirm') {
                    var self = this;
                    var queueParamsForm = $('#queueParamsForm');
                    if (!this.params.name) {
                        var queueName = $('#queueName');
                        this.changeNav('progress-params');
                        $('html, body').animate({
                            scrollTop: queueName.offset().top - 10
                        }, 500);
                        queueName.focus().css({border: 'red 1px solid'});
                        return false;
                    }
                    var inputs = queueParamsForm.find('*[scope="queue"]');
                    this.params.attributes = [];
                    var hasError = false;
                    inputs.each(function(index, item) {
                        item = $(item);
                        if (item.attr('required')) {
                            if (!item.val() || (typeof item.val() === 'object' && item.val().length === 0)) {
                                item.focus();
                                self.changeNav('progress-params', false);
                                $('html, body').animate({
                                    scrollTop: item.offset().top - 10
                                }, 500);
                                item.css({border: 'red 1px solid'});
                                Swal.fire({
                                    title: '警告！',
                                    text: '@lang(请填写必填项: )' + item.attr('title'),
                                    icon: 'error',
                                    dangerMode: true,
                                    confirmButtonText: '@lang{好的}'
                                });
                                hasError = true;
                                return false;
                            }
                        }
                        var model_class_data = item.attr('model_class_data');
                        if (model_class_data) {
                            model_class_data = JSON.parse(model_class_data);
                        }
                        var options = item.find('option');
                        model_class_data = {};
                        options.each(function(index, itemOption) {
                            itemOption = $(itemOption);
                            model_class_data[itemOption.val()] = itemOption.text();
                        });
                        var alias = item.val();
                        if (model_class_data) {
                            if (typeof item.val() === 'object') {
                                alias = '';
                                item.val().forEach(function(i) {
                                    if (model_class_data[i]) {
                                        alias += model_class_data[i] + ',';
                                    }
                                });
                            } else {
                                if (model_class_data[alias]) {
                                    alias = model_class_data[alias];
                                }
                            }
                        }
                        self.params.attributes.push({
                            name: item.attr('title'),
                            code: item.attr('name'),
                            value: item.val(),
                            value_alias: alias
                        });
                    });
                }
            },
        },
    });
})();
</script>
