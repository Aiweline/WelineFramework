<!-- start page message -->
<div class='row'>
    <template>Weline_Component::message.phtml</template>
</div>
<!-- end message -->

<div class='row'>
    <div class='col-12'>
        <div class='card weline-queue-content'>
            <div class='card-body'>
                <notempty name="data">
                    <div class="weline-queue-content-body" id="queueContentBody">{{data}}</div>
                    <div class="weline-queue-content-actions">
                        <button type="button" class="weline-queue-content-btn weline-queue-content-btn--copy" data-queue-content-copy="1">
                            <i class="mdi mdi-content-copy"></i>
                            <lang>复制内容</lang>
                        </button>
                    </div>
                <else/>
                    <div class="weline-queue-content-empty">
                        <i class="mdi mdi-text-box-remove-outline"></i>
                        <p><lang>暂无内容数据</lang></p>
                    </div>
                </notempty>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    window.WelineQueueContent = {
        copyContent: function() {
            var contentEl = document.getElementById('queueContentBody');
            if (!contentEl) return;
            
            var text = contentEl.innerText || contentEl.textContent;
            
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success('@lang(内容已复制到剪贴板)');
                    }
                }).catch(function() {
                    WelineQueueContent.fallbackCopy(text);
                });
            } else {
                WelineQueueContent.fallbackCopy(text);
            }
        },
        
        fallbackCopy: function(text) {
            var textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.success('@lang(内容已复制到剪贴板)');
                }
            } catch (err) {
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('@lang(复制失败，请手动复制)');
                }
            }
            document.body.removeChild(textarea);
        }
    };

    document.addEventListener('click', function(event) {
        var target = event.target;
        if (!(target instanceof Element)) {
            return;
        }

        if (target.closest('[data-queue-content-copy]')) {
            event.preventDefault();
            window.WelineQueueContent.copyContent();
        }
    });
})();
</script>
