<!-- 统计卡片 -->
<div class="row weline-queue-stats">
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')" class="weline-queue-stat-card weline-queue-stat-all">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-format-list-bulleted"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.all}}</div>
                <div class="weline-queue-stat-label"><lang>全部</lang></div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')?status=pending" class="weline-queue-stat-card weline-queue-stat-pending">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-clock-outline"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.pending}}</div>
                <div class="weline-queue-stat-label"><lang>等待中</lang></div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')?status=running" class="weline-queue-stat-card weline-queue-stat-running">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-play-circle-outline"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.running}}</div>
                <div class="weline-queue-stat-label"><lang>运行中</lang></div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')?status=done" class="weline-queue-stat-card weline-queue-stat-done">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-check-circle-outline"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.done}}</div>
                <div class="weline-queue-stat-label"><lang>已完成</lang></div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')?status=error" class="weline-queue-stat-card weline-queue-stat-error">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-alert-circle-outline"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.error}}</div>
                <div class="weline-queue-stat-label"><lang>出错</lang></div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <a href="@backend-url('*/backend/queue')?status=stop" class="weline-queue-stat-card weline-queue-stat-stop">
            <div class="weline-queue-stat-icon">
                <i class="mdi mdi-pause-circle-outline"></i>
            </div>
            <div class="weline-queue-stat-content">
                <div class="weline-queue-stat-number">{{stats.stop}}</div>
                <div class="weline-queue-stat-label"><lang>已暂停</lang></div>
            </div>
        </a>
    </div>
</div>
