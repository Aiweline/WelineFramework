                    $statusClass = match ($queue['status'] ?? 'error') {
                        'running' => 'weline-queue-status-running',
                        'done' => 'weline-queue-status-done',
                        'error' => 'weline-queue-status-error',
                        'stop' => 'weline-queue-status-stop',
                        default => 'weline-queue-status-pending',
                    };
                    $statusText = match ($queue['status'] ?? 'pending') {
                        'running' => __('运行中'),
                        'done' => __('已完成'),
                        'error' => __('出错'),
                        'stop' => __('已暂停'),
                        default => __('等待中'),
                    };
                    $statusIcon = match ($queue['status'] ?? 'pending') {
                        'running' => 'mdi-play-circle',
                        'done' => 'mdi-check-circle',
                        'error' => 'mdi-alert-circle',
                        'stop' => 'mdi-pause-circle',
                        default => 'mdi-clock',
                    };
                    ?>
                    <span class="weline-queue-status <?= $statusClass ?>">
                        <i class="mdi <?= $statusIcon ?>"></i>
                        <?= $statusText ?>
                    </span>
                    <if condition="queue.finished">
                        <span class="weline-queue-finished-badge" title="@lang{已结束}">
                            <i class="mdi mdi-flag-checkered"></i>
                        </span>
                    </if>
