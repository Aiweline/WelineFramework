                                        aria-haspopup="dialog"
                                        title="<?= htmlspecialchars((string)__('队列结果详情'), ENT_QUOTES, 'UTF-8') ?>">
                                    <i class="mdi mdi-open-in-new"></i>
                                    <lang>查看全部</lang>
                                </button>
                            <else/>
