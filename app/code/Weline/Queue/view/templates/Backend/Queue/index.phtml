<!-- 组件脚本 -->
<script>
(function() {
    'use strict';

    var config = {
        apiAction: '<?= $this->getBackendUrl("*/backend/queue/api-action") ?>',
        apiBatch: '<?= $this->getBackendUrl("*/backend/queue/api-batch") ?>',
        baseUrl: '<?= $this->getBackendUrl("*/backend/queue") ?>',
        text: {
            deleteConfirm: '<?= addslashes(__("确定要删除队列「%{1}」吗？此操作不可恢复。")) ?>',
            stopConfirm: '<?= addslashes(__("确定要暂停此队列吗？")) ?>',
            continueConfirm: '<?= addslashes(__("确定要继续执行此队列吗？")) ?>',
            retryConfirm: '<?= addslashes(__("确定要重试此队列吗？")) ?>',
            resetConfirm: '<?= addslashes(__("确定要重新执行此队列吗？")) ?>',
            batchDeleteConfirm: '<?= addslashes(__("确定要删除选中的 %{1} 个队列吗？此操作不可恢复。")) ?>',
            batchStopConfirm: '<?= addslashes(__("确定要暂停选中的 %{1} 个队列吗？")) ?>',
            batchContinueConfirm: '<?= addslashes(__("确定要继续执行选中的 %{1} 个队列吗？")) ?>',
            selectRequired: '<?= addslashes(__("请至少选择一个队列")) ?>',
            networkError: '<?= addslashes(__("网络错误，请检查网络后重试")) ?>'
        }
    };

    function getSelectedIds() {
        var ids = [];
        document.querySelectorAll('.weline-queue-checkbox:checked').forEach(function(cb) {
            ids.push(cb.value);
        });
        return ids;
    }

    function updateBatchActionsVisibility() {
        var ids = getSelectedIds();
        var batchActions = document.querySelector('.weline-queue-batch-actions');
        if (batchActions) {
            if (ids.length > 0) {
                batchActions.classList.remove('d-none');
            } else {
                batchActions.classList.add('d-none');
            }
        }
    }

    function performAction(queueId, action, confirmMsg) {
        BackendConfirm.show(confirmMsg, {
            type: action === 'delete' ? 'danger' : 'warning'
        }).then(function(confirmed) {
            if (!confirmed) return;
            window.Weline.Api.request(config.apiAction, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ id: queueId, action: action })
            })
            .then(function(response) {
                var result = response.data;
                if (response.ok && result && result.success) {
                    BackendToast.success(result.msg);
                    if (action === 'delete') {
                        var row = document.querySelector('tr[data-queue-id="' + queueId + '"]');
                        if (row) {
                            row.style.transition = 'opacity 0.3s';
                            row.style.opacity = '0';
                            setTimeout(function() { row.remove(); }, 300);
                        }
                    } else {
                        setTimeout(function() { location.reload(); }, 800);
                    }
                } else {
                    BackendToast.error((result && result.msg) || config.text.networkError);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error && error.message ? ': ' + error.message : ''));
            });
        });
    }

    function performBatchAction(action, confirmMsg) {
        var ids = getSelectedIds();
        if (ids.length === 0) {
            BackendToast.warning(config.text.selectRequired);
            return;
        }
        
        var msg = confirmMsg.replace('%{1}', ids.length);
        
        BackendConfirm.show(msg, {
            type: action === 'delete' ? 'danger' : 'warning'
        }).then(function(confirmed) {
            if (!confirmed) return;
            BackendToast.info('<?= addslashes(__("正在执行批量操作...")) ?>');
            window.Weline.Api.request(config.apiBatch, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ ids: ids, action: action })
            })
            .then(function(response) {
                var result = response.data;
                if (response.ok && result && result.success) {
                    BackendToast.success(result.msg);
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    BackendToast.error((result && result.msg) || config.text.networkError);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error && error.message ? ': ' + error.message : ''));
            });
        });
    }

    function init() {
        var selectAll = document.getElementById('weline-queue-select-all');
        if (selectAll) {
            selectAll.addEventListener('change', function() {
                var checked = this.checked;
                document.querySelectorAll('.weline-queue-checkbox').forEach(function(cb) {
                    cb.checked = checked;
                });
                updateBatchActionsVisibility();
            });
        }

        document.querySelectorAll('.weline-queue-checkbox').forEach(function(cb) {
            cb.addEventListener('change', updateBatchActionsVisibility);
        });

        var statusFilter = document.getElementById('weline-queue-status-filter');
        if (statusFilter) {
            statusFilter.addEventListener('change', function() {
                var status = this.value;
                var url = new URL(config.baseUrl, window.location.origin);
                if (status) {
                    url.searchParams.set('status', status);
                }
                window.location.href = url.toString();
            });
        }

        document.querySelectorAll('.weline-queue-delete-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var queueId = this.dataset.queueId;
                var queueName = this.dataset.queueName || queueId;
                var msg = config.text.deleteConfirm.replace('%{1}', queueName);
                performAction(queueId, 'delete', msg);
            });
        });

        document.querySelectorAll('.weline-queue-stop-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                performAction(this.dataset.queueId, 'stop', config.text.stopConfirm);
            });
        });

        document.querySelectorAll('.weline-queue-continue-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                performAction(this.dataset.queueId, 'continue', config.text.continueConfirm);
            });
        });

        document.querySelectorAll('.weline-queue-retry-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                performAction(this.dataset.queueId, 'retry', config.text.retryConfirm);
            });
        });

        document.querySelectorAll('.weline-queue-reset-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                performAction(this.dataset.queueId, 'reset', config.text.resetConfirm);
            });
        });

        var batchDelete = document.getElementById('weline-queue-batch-delete');
        if (batchDelete) {
            batchDelete.addEventListener('click', function() {
                performBatchAction('delete', config.text.batchDeleteConfirm);
            });
        }

        var batchStop = document.getElementById('weline-queue-batch-stop');
        if (batchStop) {
            batchStop.addEventListener('click', function() {
                performBatchAction('stop', config.text.batchStopConfirm);
            });
        }

        var batchContinue = document.getElementById('weline-queue-batch-continue');
        if (batchContinue) {
            batchContinue.addEventListener('click', function() {
                performBatchAction('continue', config.text.batchContinueConfirm);
            });
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
