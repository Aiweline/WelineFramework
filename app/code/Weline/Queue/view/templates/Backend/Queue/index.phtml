<!-- 组件脚本 -->
<script>
(function() {
    'use strict';

    var config = {
        apiAction: '<?= $this->getBackendUrl("*/backend/queue/api-action") ?>',
        apiBatch: '<?= $this->getBackendUrl("*/backend/queue/api-batch") ?>',
        snapshotUrl: '<?= $this->getBackendUrl("*/backend/queue/snapshot") ?>',
        baseUrl: '<?= $this->getBackendUrl("*/backend/queue") ?>',
        pollIntervalMs: 3000,
        actionRefreshDelayMs: 600,
        text: {
            deleteConfirm: '<?= addslashes(__("确定要删除队列「%{1}」吗？此操作不可恢复。")) ?>',
            stopConfirm: '<?= addslashes(__("确定要暂停此队列吗？")) ?>',
            continueConfirm: '<?= addslashes(__("确定要继续执行此队列吗？")) ?>',
            retryConfirm: '<?= addslashes(__("确定要重试此队列吗？")) ?>',
            resetConfirm: '<?= addslashes(__("确定要重新执行此队列吗？")) ?>',
            batchDeleteConfirm: '<?= addslashes(__("确定要删除选中的 %{1} 个队列吗？此操作不可恢复。")) ?>',
            batchStopConfirm: '<?= addslashes(__("确定要暂停选中的 %{1} 个队列吗？")) ?>',
            batchContinueConfirm: '<?= addslashes(__("确定要继续执行选中的 %{1} 个队列吗？")) ?>',
            selectRequired: '<?= addslashes(__("请至少选择一个队列")) ?>',
            networkError: '<?= addslashes(__("网络错误，请检查网络后重试")) ?>',
            resultCopied: '<?= addslashes(__("队列结果已复制到剪贴板")) ?>',
            resultCopyFailed: '<?= addslashes(__("复制失败，请手动复制")) ?>'
        }
    };
    var snapshotTimer = 0;
    var snapshotInFlight = false;
    var lastSnapshotStatsHtml = '';
    var lastSnapshotListingHtml = '';

    function getSelectedIds() {
        var ids = [];
        document.querySelectorAll('.weline-queue-checkbox:checked').forEach(function(cb) {
            ids.push(cb.value);
        });
        return ids;
    }

    function restoreSelectedIds(ids) {
        if (!Array.isArray(ids) || ids.length === 0) {
            return;
        }
        document.querySelectorAll('.weline-queue-checkbox').forEach(function(cb) {
            cb.checked = ids.indexOf(String(cb.value || '')) !== -1;
        });
    }

    function updateBatchActionsVisibility() {
        var ids = getSelectedIds();
        var batchActions = document.querySelector('.weline-queue-batch-actions');
        var allCheckboxes = document.querySelectorAll('.weline-queue-checkbox');
        var selectAll = document.getElementById('weline-queue-select-all');
        if (batchActions) {
            if (ids.length > 0) {
                batchActions.classList.remove('d-none');
            } else {
                batchActions.classList.add('d-none');
            }
        }
        if (selectAll) {
            selectAll.checked = allCheckboxes.length > 0 && ids.length === allCheckboxes.length;
            selectAll.indeterminate = ids.length > 0 && ids.length < allCheckboxes.length;
        }
    }

    function shouldPauseSnapshotRefresh() {
        if (document.hidden) {
            return true;
        }
        return !!document.querySelector('.modal.show, .offcanvas.show');
    }

    function buildSnapshotUrl() {
        var url = new URL(config.snapshotUrl, window.location.origin);
        var currentUrl = new URL(window.location.href);
        currentUrl.searchParams.forEach(function(value, key) {
            url.searchParams.set(key, value);
        });
        return url.toString();
    }

    function cleanupManagedQueueResultModals() {
        document.querySelectorAll('.weline-queue-result-modal[data-live-managed="1"]').forEach(function(modal) {
            if (modal.parentElement) {
                modal.parentElement.removeChild(modal);
            }
        });
    }

    function cleanupManagedQueueOffcanvases() {
        document.querySelectorAll('.weline-component-offcanvas[id^="queueshow"], .weline-component-offcanvas[id^="off_canvas_queue_edit"]').forEach(function(panel) {
            if (panel.parentElement) {
                panel.parentElement.removeChild(panel);
            }
        });
    }

    function activateInlineScripts(root) {
        if (!(root instanceof Element)) {
            return;
        }
        root.querySelectorAll('script').forEach(function(oldScript) {
            var newScript = document.createElement('script');
            Array.prototype.slice.call(oldScript.attributes || []).forEach(function(attr) {
                newScript.setAttribute(attr.name, attr.value);
            });
            newScript.text = oldScript.text || oldScript.textContent || '';
            oldScript.parentNode.replaceChild(newScript, oldScript);
        });
    }

    function applySnapshot(payload) {
        var statsRegion = document.getElementById('weline-queue-stats-region');
        var listingRegion = document.getElementById('weline-queue-listing-region');
        var selectedIds = getSelectedIds();

        if (statsRegion && typeof payload.stats_html === 'string' && payload.stats_html !== lastSnapshotStatsHtml) {
            statsRegion.innerHTML = payload.stats_html;
            lastSnapshotStatsHtml = payload.stats_html;
        }
        if (listingRegion && typeof payload.listing_html === 'string' && payload.listing_html !== lastSnapshotListingHtml) {
            cleanupManagedQueueResultModals();
            cleanupManagedQueueOffcanvases();
            listingRegion.innerHTML = payload.listing_html;
            activateInlineScripts(listingRegion);
            lastSnapshotListingHtml = payload.listing_html;
        }

        restoreSelectedIds(selectedIds);
        updateBatchActionsVisibility();
        portalQueueResultModals();
    }

    function refreshQueueSnapshot(options) {
        options = options || {};
        if (snapshotInFlight && !options.force) {
            return Promise.resolve(false);
        }
        if (!options.force && shouldPauseSnapshotRefresh()) {
            return Promise.resolve(false);
        }

        snapshotInFlight = true;
        return fetch(buildSnapshotUrl(), {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        }).then(function(response) {
            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }
            return response.json();
        }).then(function(result) {
            if (result && result.success) {
                applySnapshot(result);
                return true;
            }
            return false;
        }).catch(function(error) {
            if (options.showError && typeof BackendToast !== 'undefined') {
                BackendToast.error(config.text.networkError + (error && error.message ? ': ' + error.message : ''));
            }
            return false;
        }).finally(function() {
            snapshotInFlight = false;
        });
    }

    function queueSnapshotRefresh(delayMs) {
        if (snapshotTimer) {
            window.clearTimeout(snapshotTimer);
        }
        snapshotTimer = window.setTimeout(function() {
            refreshQueueSnapshot().finally(function() {
                queueSnapshotRefresh(config.pollIntervalMs);
            });
        }, typeof delayMs === 'number' ? delayMs : config.pollIntervalMs);
    }

    function performAction(queueId, action, confirmMsg) {
        BackendConfirm.show(confirmMsg, {
            type: action === 'delete' ? 'danger' : 'warning'
        }).then(function(confirmed) {
            if (!confirmed) return;
            window.Weline.Api.request(config.apiAction, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ id: queueId, action: action })
            })
            .then(function(response) {
                var result = response.data;
                if (response.ok && result && result.success) {
                    BackendToast.success(result.msg);
                    if (action === 'delete') {
                        var row = document.querySelector('tr[data-queue-id="' + queueId + '"]');
                        if (row) {
                            row.style.transition = 'opacity 0.3s';
                            row.style.opacity = '0';
                            setTimeout(function() { row.remove(); }, 300);
                        }
                    }
                    queueSnapshotRefresh(action === 'delete' ? 350 : config.actionRefreshDelayMs);
                } else {
                    BackendToast.error((result && result.msg) || config.text.networkError);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error && error.message ? ': ' + error.message : ''));
            });
        });
    }

    function performBatchAction(action, confirmMsg) {
        var ids = getSelectedIds();
        if (ids.length === 0) {
            BackendToast.warning(config.text.selectRequired);
            return;
        }
        
        var msg = confirmMsg.replace('%{1}', ids.length);
        
        BackendConfirm.show(msg, {
            type: action === 'delete' ? 'danger' : 'warning'
        }).then(function(confirmed) {
            if (!confirmed) return;
            BackendToast.info('<?= addslashes(__("正在执行批量操作...")) ?>');
            window.Weline.Api.request(config.apiBatch, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ ids: ids, action: action })
            })
            .then(function(response) {
                var result = response.data;
                if (response.ok && result && result.success) {
                    BackendToast.success(result.msg);
                    queueSnapshotRefresh(config.actionRefreshDelayMs);
                } else {
                    BackendToast.error((result && result.msg) || config.text.networkError);
                }
            })
            .catch(function(error) {
                BackendToast.error(config.text.networkError + (error && error.message ? ': ' + error.message : ''));
            });
        });
    }

    function copyQueueResult(modalId) {
        var modal = document.getElementById(modalId);
        var content = modal ? modal.querySelector('.weline-queue-result-modal-body') : null;
        if (!content) {
            return;
        }

        var text = content.innerText || content.textContent || '';
        var notifySuccess = function() {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.success(config.text.resultCopied);
            }
        };
        var notifyError = function() {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.error(config.text.resultCopyFailed);
            }
        };

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(notifySuccess).catch(function() {
                fallbackCopyQueueResult(text, notifySuccess, notifyError);
            });
            return;
        }

        fallbackCopyQueueResult(text, notifySuccess, notifyError);
    }

    function fallbackCopyQueueResult(text, notifySuccess, notifyError) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        try {
            document.execCommand('copy') ? notifySuccess() : notifyError();
        } catch (e) {
            notifyError();
        }
        document.body.removeChild(textarea);
    }

    window.WelineQueueResultModal = {
        copy: copyQueueResult
    };

    function markQueueResultBackdrop() {
        document.querySelectorAll('.modal-backdrop').forEach(function(backdrop) {
            backdrop.classList.add('weline-queue-result-backdrop');
        });
    }

    function portalQueueResultModals() {
        document.querySelectorAll('.weline-queue-result-modal').forEach(function(modal) {
            modal.dataset.liveManaged = modal.dataset.liveManaged || '1';
            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            if (modal.dataset.portalBound === '1') {
                return;
            }
            modal.dataset.portalBound = '1';
            modal.addEventListener('show.bs.modal', function() {
                setTimeout(markQueueResultBackdrop, 0);
            });
            modal.addEventListener('shown.bs.modal', markQueueResultBackdrop);
            modal.addEventListener('hidden.bs.modal', function() {
                document.querySelectorAll('.modal-backdrop.weline-queue-result-backdrop').forEach(function(backdrop) {
                    if (!document.querySelector('.weline-queue-result-modal.show')) {
                        backdrop.classList.remove('weline-queue-result-backdrop');
                    }
                });
            });
        });
    }

    function initStaticActions() {
        document.addEventListener('change', function(event) {
            var target = event.target;
            if (!(target instanceof Element)) {
                return;
            }
            if (target.id === 'weline-queue-select-all') {
                var checked = !!target.checked;
                document.querySelectorAll('.weline-queue-checkbox').forEach(function(cb) {
                    cb.checked = checked;
                });
                updateBatchActionsVisibility();
                return;
            }
            if (target.classList.contains('weline-queue-checkbox')) {
                updateBatchActionsVisibility();
                return;
            }
            if (target.id === 'weline-queue-status-filter') {
                var status = String(target.value || '');
                var url = new URL(window.location.href);
                if (status) {
                    url.searchParams.set('status', status);
                } else {
                    url.searchParams.delete('status');
                }
                window.location.href = url.toString();
            }
        });

        document.addEventListener('click', function(event) {
            var target = event.target;
            if (!(target instanceof Element)) {
                return;
            }

            var deleteBtn = target.closest('.weline-queue-delete-btn');
            if (deleteBtn) {
                var queueId = deleteBtn.dataset.queueId;
                var queueName = deleteBtn.dataset.queueName || queueId;
                var deleteMsg = config.text.deleteConfirm.replace('%{1}', queueName);
                performAction(queueId, 'delete', deleteMsg);
                return;
            }

            var stopBtn = target.closest('.weline-queue-stop-btn');
            if (stopBtn) {
                performAction(stopBtn.dataset.queueId, 'stop', config.text.stopConfirm);
                return;
            }

            var continueBtn = target.closest('.weline-queue-continue-btn');
            if (continueBtn) {
                performAction(continueBtn.dataset.queueId, 'continue', config.text.continueConfirm);
                return;
            }

            var retryBtn = target.closest('.weline-queue-retry-btn');
            if (retryBtn) {
                performAction(retryBtn.dataset.queueId, 'retry', config.text.retryConfirm);
                return;
            }

            var resetBtn = target.closest('.weline-queue-reset-btn');
            if (resetBtn) {
                performAction(resetBtn.dataset.queueId, 'reset', config.text.resetConfirm);
                return;
            }

            var batchDelete = target.closest('#weline-queue-batch-delete');
            if (batchDelete) {
                performBatchAction('delete', config.text.batchDeleteConfirm);
                return;
            }

            var batchStop = target.closest('#weline-queue-batch-stop');
            if (batchStop) {
                performBatchAction('stop', config.text.batchStopConfirm);
                return;
            }

            var batchContinue = target.closest('#weline-queue-batch-continue');
            if (batchContinue) {
                performBatchAction('continue', config.text.batchContinueConfirm);
            }
        });
    }

    function init() {
        portalQueueResultModals();
        initStaticActions();
        updateBatchActionsVisibility();
        var statsRegion = document.getElementById('weline-queue-stats-region');
        var listingRegion = document.getElementById('weline-queue-listing-region');
        lastSnapshotStatsHtml = statsRegion ? statsRegion.innerHTML : '';
        lastSnapshotListingHtml = listingRegion ? listingRegion.innerHTML : '';
        queueSnapshotRefresh(config.pollIntervalMs);
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) {
                queueSnapshotRefresh(200);
            }
        });
        window.addEventListener('beforeunload', function() {
            if (snapshotTimer) {
                window.clearTimeout(snapshotTimer);
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
