<script>
(function() {
    'use strict';
    
    var enableUrl = "@backend-url('*/backend/type/enable')";
    var disableUrl = "@backend-url('*/backend/type/disable')";
    
    function handleTypeAction(button) {
        var action = button.getAttribute('data-action');
        var typeId = button.getAttribute('data-id');
        var typeName = button.getAttribute('data-name');
        
        var actionText = action === 'enable' ? '@lang(启用)' : '@lang(禁用)';
        var confirmMsg = '@lang(确定要)' + actionText + '@lang(队列类型)' + ' "' + typeName + '" @lang(吗？)';
        
        BackendConfirm.show(confirmMsg, {
            title: actionText + '@lang(确认)',
            confirmText: actionText,
            cancelText: '@lang(取消)',
            type: action === 'enable' ? 'success' : 'warning'
        }).then(function(confirmed) {
            if (!confirmed) return;
            
            var url = action === 'enable' ? enableUrl : disableUrl;
            url += '?id=' + typeId;
            
            if (window.showLoading) showLoading();
            
            fetch(url, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(function(response) {
                return response.text();
            })
            .then(function() {
                BackendToast.success(actionText + '@lang(成功，页面即将刷新...)');
                setTimeout(function() {
                    window.location.reload();
                }, 1000);
            })
            .catch(function(error) {
                if (window.hideLoading) hideLoading();
                BackendToast.error('@lang(操作失败：)' + error.message);
            });
        });
    }
    
    function init() {
        document.querySelectorAll('[data-action="enable"], [data-action="disable"]').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                handleTypeAction(this);
            });
        });
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
