{
    "name": "weline/two-factor-auth",
    "description": "完全自主开发的双因素身份验证模块 - 标准TOTP实现，兼容所有主流2FA应用",
    "type": "weline-module",
    "license": "MIT",
    "keywords": [
        "2fa",
        "totp",
        "authentication",
        "security",
        "weline"
    ],
    "authors": [
        {
            "name": "Aiweline",
            "email": "aiweline@qq.com",
            "homepage": "https://aiweline.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "weline/framework": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Weline\\TwoFactorAuth\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Weline\\TwoFactorAuth\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}