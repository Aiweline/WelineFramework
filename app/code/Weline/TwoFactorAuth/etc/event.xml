<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 前端控制器初始化之前检查登录状态 -->
    <event name="Framework_FrontendController::init_before">
        <observer name="Weline_TwoFactorAuth_CheckUserLogin" instance="Weline\TwoFactorAuth\Observer\CheckUserLogin" disabled="false" shared="true"/>
    </event>
    
    <!-- 前端REST控制器初始化之前检查登录状态 -->
    <event name="Framework_FrontendRestController::init_before">
        <observer name="Weline_TwoFactorAuth_CheckUserLogin_Rest" instance="Weline\TwoFactorAuth\Observer\CheckUserLogin" disabled="false" shared="true"/>
    </event>
</config>

