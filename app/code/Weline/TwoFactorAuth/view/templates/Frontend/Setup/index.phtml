    <script>
        // 复制密钥
        function copySecret() {
            const text = '<?= str_replace(' ', '', $formatted_secret) ?>';
            navigator.clipboard.writeText(text).then(() => {
                alert('密钥已复制到剪贴板');
            });
        }

        // 复制备份码
        function copyBackupCodes() {
            const codes = <?= json_encode($backup_codes) ?>;
            const text = codes.join('\n');
            navigator.clipboard.writeText(text).then(() => {
                alert('备份码已复制到剪贴板\n请妥善保存！');
            });
        }

        // 自动格式化验证码输入
        document.getElementById('verifyCode').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        // 启用2FA
        async function enableTwoFactor() {
            const code = document.getElementById('verifyCode').value;
            const secret = document.getElementById('secret').value;
            const backupCodes = document.getElementById('backupCodesJson').value;

            if (!code || code.length !== 6) {
                alert('请输入6位验证码');
                return;
            }

            try {
                const response = await fetch('/two-factor-auth/frontend/setup/enable', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `secret=${encodeURIComponent(secret)}&code=${code}&backup_codes=${encodeURIComponent(backupCodes)}`
                });

                const result = await response.json();
                
                if (result.success) {
                    alert('✅ 双因素身份验证已成功启用！\n\n请确保已保存备份码，然后点击确定返回管理页面。');
                    window.location.href = '/two-factor-auth/frontend';
                } else {
                    alert('❌ ' + result.message + '\n\n请检查验证码是否正确，注意验证码每30秒会更新。');
                }
            } catch (error) {
                alert('操作失败，请重试');
                console.error(error);
            }
        }

        // Enter键提交
        document.getElementById('verifyCode').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                enableTwoFactor();
            }
        });
    </script>
