                <input type="text" id="regenerateCode" placeholder="输入6位验证码" maxlength="6">
            </div>
            <div class="action-buttons">
                <button class="btn btn-secondary" onclick="closeRegenerateModal()">取消</button>
                <button class="btn btn-primary" onclick="regenerateBackupCodes()">确认生成</button>
            </div>
        </div>
