    <!-- SweetAlert2 CSS -->
    <link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
    <!-- SweetAlert2 JS -->
    <script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
    <script>
        function showDisableModal() {
            document.getElementById('disableModal').classList.add('active');
        }

        function closeDisableModal() {
            document.getElementById('disableModal').classList.remove('active');
            document.getElementById('disableCode').value = '';
        }

        function showRegenerateModal() {
            document.getElementById('regenerateModal').classList.add('active');
        }

        function closeRegenerateModal() {
            document.getElementById('regenerateModal').classList.remove('active');
            document.getElementById('regenerateCode').value = '';
        }

        async function disableTwoFactor() {
            const code = document.getElementById('disableCode').value;
            if (!code || code.length !== 6) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请输入6位验证码') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('请输入6位验证码');
                }
                return;
            }

            try {
                const TwoFactorApi = await Weline.Api.resource('twoFactor');
                const result = await TwoFactorApi.disable({code: code}, {silent: true});
                
                if (result.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: result.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    } else {
                        console.log(result.message);
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('失败') ?>',
                            text: result.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(result.message);
                    }
                }
            } catch (error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: '<?= __('请重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('操作失败，请重试');
                }
            }
        }

        async function regenerateBackupCodes() {
            const code = document.getElementById('regenerateCode').value;
            if (!code || code.length !== 6) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请输入6位验证码') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('请输入6位验证码');
                }
                return;
            }

            try {
                const TwoFactorApi = await Weline.Api.resource('twoFactor');
                const result = await TwoFactorApi.regenerateBackupCodes({code: code}, {silent: true});
                
                if (result.success) {
                    // 显示新的备份码
                    let codesHtml = '<h3>新的备份码</h3><ul>';
                    result.backup_codes.forEach(code => {
                        codesHtml += `<li style="font-family: monospace; padding: 5px;">${code}</li>`;
                    });
                    codesHtml += '</ul><p style="color: red;">请妥善保存这些备份码！</p>';
                    
                    const modal = document.getElementById('regenerateModal');
                    modal.querySelector('.modal-content').innerHTML = codesHtml + 
                        '<button class="btn btn-primary" onclick="location.reload()">完成</button>';
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: result.message,
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        console.log(result.message);
                    }
                }
            } catch (error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: '<?= __('请重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('操作失败，请重试');
                }
            }
        }

        // 显示验证器APP提示模态框
        function showAuthenticatorAppModal() {
            const modal = document.createElement('div');
            modal.id = 'authenticatorAppModal';
            modal.style.cssText = 'position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 10000; display: flex; align-items: center; justify-content: center;';
            
            const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
            const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
            const isAndroid = /Android/.test(navigator.userAgent);
            
            let installInstructions = '';
            if (isIOS) {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>📱 <?= __('iOS设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在Safari浏览器中，点击底部"分享"按钮') ?></li>
                            <li><?= __('选择"添加到主屏幕"') ?></li>
                            <li><?= __('点击"添加"完成安装') ?></li>
                        </ol>
                    </div>
                `;
            } else if (isAndroid) {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>📱 <?= __('Android设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在Chrome浏览器中，点击右上角"菜单"（三个点）') ?></li>
                            <li><?= __('选择"添加到主屏幕"或"安装应用"') ?></li>
                            <li><?= __('点击"添加"或"安装"完成') ?></li>
                        </ol>
                    </div>
                `;
            } else {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>💻 <?= __('桌面设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在浏览器地址栏右侧，点击"安装"图标') ?></li>
                            <li><?= __('或使用浏览器的"添加到主屏幕"功能') ?></li>
                            <li><?= __('安装后即可像应用一样使用') ?></li>
                        </ol>
                    </div>
                `;
            }
            
            modal.innerHTML = `
                <div style="background: white; padding: 2rem; border-radius: 12px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                    <h2 style="margin-bottom: 1rem; color: #333; display: flex; align-items: center; gap: 0.5rem;">
                        📱 打开验证器APP
                    </h2>
                    <p style="color: #666; margin-bottom: 1rem; line-height: 1.6;">
                        我们的验证器是一个PWA（渐进式Web应用），可以像原生应用一样安装到您的设备上。
                    </p>
                    <div style="margin-top: 1rem; padding: 1rem; background: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px;">
                        <strong>💡 提示：</strong>
                        <p style="margin: 0.5rem 0 0 0; color: #856404;">
                            建议将验证器保存到桌面，方便随时使用。安装后可以离线使用，无需每次打开浏览器。
                        </p>
                    </div>
                    ${installInstructions}
                    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
                        <button onclick="closeAuthenticatorAppModal()" style="padding: 0.75rem 1.5rem; border: 1px solid #ddd; border-radius: 8px; background: white; color: #333; cursor: pointer; font-weight: 500;">
                            取消
                        </button>
                        <a href="/twofa-app/" target="_blank" onclick="closeAuthenticatorAppModal()" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #007bff; color: white; text-decoration: none; font-weight: 500; display: inline-block;">
                            打开验证器
                        </a>
                    </div>
                </div>
            `;
            
            document.body.appendChild(modal);
            
            // 点击外部关闭
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    closeAuthenticatorAppModal();
                }
            });
        }

        // 关闭验证器APP提示模态框
        function closeAuthenticatorAppModal() {
            const modal = document.getElementById('authenticatorAppModal');
            if (modal) {
                modal.remove();
            }
        }
    </script>
</body>
