    <script>
        // TOTP算法实现
        function base32Decode(str) {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';
            let bits = '';
            
            for (let i = 0; i < str.length; i++) {
                const val = chars.indexOf(str[i]);
                if (val === -1) continue;
                bits += val.toString(2).padStart(5, '0');
            }
            
            const bytes = [];
            for (let i = 0; i < bits.length; i += 8) {
                const byte = bits.substr(i, 8);
                if (byte.length === 8) {
                    bytes.push(parseInt(byte, 2));
                }
            }
            
            return new Uint8Array(bytes);
        }
        
        function generateTOTP(secret, algorithm = 'SHA1', digits = 6, period = 30) {
            let timeStep = Math.floor(Date.now() / 1000 / period);
            
            // 将时间步数转换为8字节大端序
            const timeBytes = new Uint8Array(8);
            let currentStep = timeStep;
            for (let i = 7; i >= 0; i--) {
                timeBytes[i] = currentStep & 0xff;
                currentStep >>= 8;
            }
            
            // HMAC计算
            const secretBytes = base32Decode(secret);
            
            // 使用Web Crypto API计算HMAC
            return crypto.subtle.importKey(
                'raw',
                secretBytes,
                { name: 'HMAC', hash: { name: algorithm === 'SHA256' ? 'SHA-256' : 'SHA-1' } },
                false,
                ['sign']
            ).then(key => {
                return crypto.subtle.sign('HMAC', key, timeBytes);
            }).then(signature => {
                // 动态截断（RFC 4226）
                const hash = new Uint8Array(signature);
                const offset = hash[hash.length - 1] & 0x0F;
                const truncated = ((hash[offset] & 0x7F) << 24) |
                                 ((hash[offset + 1] & 0xFF) << 16) |
                                 ((hash[offset + 2] & 0xFF) << 8) |
                                 (hash[offset + 3] & 0xFF);
                
                const code = truncated % Math.pow(10, digits);
                return code.toString().padStart(digits, '0');
            });
        }

        // 自动刷新验证码
        function refreshCodes() {
            const codeElements = document.querySelectorAll('[id^="code-"]');
            codeElements.forEach(element => {
                const secret = element.dataset.secret;
                const algorithm = element.dataset.algorithm || 'SHA1';
                const digits = parseInt(element.dataset.digits || '6');
                const period = parseInt(element.dataset.period || '30');
                
                if (!secret) return;
                
                generateTOTP(secret, algorithm, digits, period).then(code => {
                    element.textContent = code;
                    
                    // 显示剩余时间进度条
                    updateProgressBar(element, period);
                });
            });
        }
        
        // 更新倒计时圆圈和数字
        function updateCountdownCircle(accountId, period) {
            const remaining = period - (Math.floor(Date.now() / 1000) % period);
            const progressBar = document.getElementById(`progress-${accountId}`);
            const countdownNumber = document.getElementById(`countdown-${accountId}`);
            const circumference = 94.24; // 2 * π * 15
            
            if (progressBar && countdownNumber) {
                // 更新数字
                countdownNumber.textContent = remaining;
                
                // 更新圆圈进度
                const offset = circumference - (remaining / period) * circumference;
                progressBar.style.strokeDashoffset = offset;
            }
            
            // 返回下次刷新时间（毫秒）
            return remaining * 1000;
        }
        
        // 刷新单个账户并安排下次刷新
        function refreshCodeWithSchedule(element) {
            const secret = element.dataset.secret;
            const algorithm = element.dataset.algorithm || 'SHA1';
            const digits = parseInt(element.dataset.digits || '6');
            const period = parseInt(element.dataset.period || '30');
            const accountId = element.id.replace('code-', '');
            
            if (!secret) return;
            
            generateTOTP(secret, algorithm, digits, period).then(code => {
                element.textContent = code;
                
                // 更新倒计时圆圈
                const nextRefresh = updateCountdownCircle(accountId, period);
                
                // 安排下次倒计时更新（每秒）
                let countdownTimer;
                function startCountdown() {
                    clearInterval(countdownTimer);
                    countdownTimer = setInterval(() => {
                        const newRemaining = period - (Math.floor(Date.now() / 1000) % period);
                        const progressBar = document.getElementById(`progress-${accountId}`);
                        const countdownNumber = document.getElementById(`countdown-${accountId}`);
                        const circumference = 94.24;
                        
                        if (progressBar && countdownNumber) {
                            countdownNumber.textContent = newRemaining;
                            const offset = circumference - (newRemaining / period) * circumference;
                            progressBar.style.strokeDashoffset = offset;
                            
                            // 倒计时结束，刷新验证码
                            if (newRemaining <= 1) {
                                clearInterval(countdownTimer);
                                refreshCodeWithSchedule(element);
                            }
                        }
                    }, 100);
                }
                
                startCountdown();
                
                // 安排在验证码到期时刷新
                setTimeout(() => {
                    clearInterval(countdownTimer);
                    refreshCodeWithSchedule(element);
                }, nextRefresh + 100);
            });
        }

        // 立即刷新所有验证码
        const codeElements = document.querySelectorAll('[id^="code-"]');
        codeElements.forEach(element => {
            refreshCodeWithSchedule(element);
        });

        // 显示添加模态框
        function showAddModal() {
            document.getElementById('addModal').classList.add('active');
        }

        // 关闭模态框
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.getElementById('addForm').reset();
            document.getElementById('importForm').reset();
            stopCamera();
            switchTab('qr');
        }

        // 切换标签页
        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            
            if (tab === 'qr') {
                document.querySelectorAll('.tab')[0].classList.add('active');
                document.getElementById('qrTab').classList.add('active');
            } else if (tab === 'manual') {
                document.querySelectorAll('.tab')[1].classList.add('active');
                document.getElementById('manualTab').classList.add('active');
            } else {
                document.querySelectorAll('.tab')[2].classList.add('active');
                document.getElementById('uriTab').classList.add('active');
            }
        }
        
        // 切换标签页（事件处理）
        function switchTabWithEvent(tab) {
            switchTab(tab);
        }
        
        // 处理文件上传
        function handleFileUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    document.getElementById('previewImage').src = e.target.result;
                    document.getElementById('previewSection').style.display = 'block';
                    parseQRCode(img);
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }
        
        // 解析二维码
        function parseQRCode(img) {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = img.width;
            canvas.height = img.height;
            ctx.drawImage(img, 0, 0);
            
            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const code = jsQR(imageData.data, imageData.width, imageData.height);
            
            if (code) {
                document.getElementById('previewText').innerHTML = '<span style="color:green;">✓ 二维码解析成功！</span>';
                setTimeout(() => {
                    handleQRCodeURI(code.data);
                }, 500);
            } else {
                document.getElementById('previewText').innerHTML = '<span style="color:red;">✗ 无法识别二维码，请重试</span>';
            }
        }
        
        // 启动摄像头
        let cameraStream = null;
        let scanningInterval = null;
        
        function startCamera() {
            navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
                .then(stream => {
                    cameraStream = stream;
                    const video = document.getElementById('cameraVideo');
                    video.srcObject = stream;
                    video.style.display = 'block';
                    document.getElementById('startCameraBtn').style.display = 'none';
                    
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    scanningInterval = setInterval(() => {
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        ctx.drawImage(video, 0, 0);
                        
                        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                        const code = jsQR(imageData.data, imageData.width, imageData.height);
                        
                        if (code) {
                            stopCamera();
                            handleQRCodeURI(code.data);
                        }
                    }, 100);
                })
                .catch(err => {
                    alert('无法访问摄像头：' + err.message);
                });
        }
        
        // 停止摄像头
        function stopCamera() {
            if (cameraStream) {
                cameraStream.getTracks().forEach(track => track.stop());
                cameraStream = null;
            }
            if (scanningInterval) {
                clearInterval(scanningInterval);
                scanningInterval = null;
            }
            document.getElementById('cameraVideo').style.display = 'none';
            document.getElementById('startCameraBtn').style.display = 'block';
        }
        
        // 处理解析的URI
        function handleQRCodeURI(uri) {
            if (!uri.startsWith('otpauth://')) {
                alert('无效的二维码格式');
                return;
            }
            
            // 解析URI
            const url = new URL(uri);
            const params = new URLSearchParams(url.search);
            
            const data = {
                name: url.pathname.split(':').pop() || '',
                issuer: params.get('issuer') || '',
                secret: params.get('secret') || '',
                algorithm: params.get('algorithm') || 'SHA1',
                digits: params.get('digits') || '6',
                period: params.get('period') || '30'
            };
            
            // 通过导入接口添加账户
            fetch('/two-factor-auth/frontend/accounts/import', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `uri=${encodeURIComponent(uri)}`
            })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    alert('账户添加成功！');
                    closeModal('addModal');
                    location.reload();
                } else {
                    alert(result.message || '添加失败，请重试');
                }
            })
            .catch(error => {
                alert('添加失败，请重试');
            });
        }

        // 添加账户
        async function addAccount(event) {
            event.preventDefault();
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData);
            
            try {
                const response = await fetch('/two-factor-auth/frontend/accounts/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: new URLSearchParams(data)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('账户添加成功！');
                    closeModal('addModal');
                    location.reload();
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('添加失败，请重试');
            }
        }

        // 导入账户
        async function importAccount(event) {
            event.preventDefault();
            const formData = new FormData(event.target);
            
            try {
                const response = await fetch('/two-factor-auth/frontend/accounts/import', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('账户导入成功！');
                    closeModal('addModal');
                    location.reload();
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('导入失败，请重试');
            }
        }

        // 切换下拉菜单
        function toggleDropdown(accountId) {
            // 关闭所有下拉菜单
            document.querySelectorAll('.dropdown-menu').forEach(menu => {
                menu.classList.remove('show');
            });
            
            // 切换当前菜单
            const dropdown = document.getElementById(`dropdown-${accountId}`);
            if (dropdown) {
                dropdown.classList.toggle('show');
            }
        }
        
        // 点击页面其他地方时关闭下拉菜单
        document.addEventListener('click', function(event) {
            if (!event.target.closest('.account-actions')) {
                document.querySelectorAll('.dropdown-menu').forEach(menu => {
                    menu.classList.remove('show');
                });
            }
        });
        
        // 确认删除账户（二次确认）
        function confirmDelete(accountId) {
            const confirmed = confirm('⚠️ 警告：此操作不可撤销！\n\n确定要删除这个验证器账户吗？');
            
            if (confirmed) {
                deleteAccount(accountId);
            }
        }
        
        // 删除账户（实际执行）
        async function deleteAccount(accountId) {
            try {
                const response = await fetch('/two-factor-auth/frontend/accounts/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `account_id=${accountId}`
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('账户已删除');
                    location.reload();
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('删除失败，请重试');
            }
        }

        // 显示导入模态框
        function showImportModal() {
            showAddModal();
            switchTab('uri');
            // 默认显示文件导入
            switchImportTab('file');
        }
        
        // 触发文件上传
        function triggerFileUpload() {
            const input = document.getElementById('importFileInput');
            if (input) {
                input.click();
            }
        }
        
        // 切换导入方式标签页
        function switchImportTab(mode) {
            document.querySelectorAll('#uriTab .tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('#uriTab .import-tab-content').forEach(c => c.classList.remove('active'));
            
            if (mode === 'file') {
                document.querySelectorAll('#uriTab .tab')[0].classList.add('active');
                document.getElementById('fileImportTab').classList.add('active');
            } else {
                document.querySelectorAll('#uriTab .tab')[1].classList.add('active');
                document.getElementById('uriImportTab').classList.add('active');
            }
        }
        
        // 处理文件导入
        function handleImportFile(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                const fileName = file.name.toLowerCase();
                
                try {
                    let accounts = [];
                    console.log('开始解析文件:', file.name, '大小:', file.size, '字节');
                    
                    // 根据文件扩展名判断格式
                    if (fileName.endsWith('.json')) {
                        accounts = parseJsonImport(text);
                    } else if (fileName.endsWith('.csv')) {
                        accounts = parseCsvImport(text);
                    } else if (fileName.endsWith('.txt')) {
                        accounts = parseTxtImport(text);
                    } else {
                        throw new Error('不支持的文件格式');
                    }
                    
                    console.log('解析结果:', accounts);
                    
                    if (accounts.length === 0) {
                        document.getElementById('importFileText').innerHTML = 
                            `<span style="color:orange;">⚠ 未找到有效的账户数据。请检查文件格式是否正确。</span><br>
                            <small style="color:#999;">支持格式：JSON(Google/Microsoft/Authy/2FAS/双因素身份验证)、CSV、TXT</small>`;
                        document.getElementById('importFilePreview').style.display = 'block';
                        return;
                    }
                    
                    document.getElementById('importFileText').innerHTML = 
                        `<span style="color:green;">✓ 解析成功，找到 ${accounts.length} 个账户</span>`;
                    document.getElementById('importFilePreview').style.display = 'block';
                    
                    // 批量导入账户
                    importAccounts(accounts);
                    
                } catch (error) {
                    console.error('解析错误:', error);
                    document.getElementById('importFileText').innerHTML = 
                        `<span style="color:red;">✗ 解析失败：${error.message}</span><br>
                        <small style="asilkan:#999;">请检查文件格式是否正确</small>`;
                    document.getElementById('importFilePreview').style.display = 'block';
                }
            };
            reader.readAsText(file);
        }
        
        // 解析JSON格式（Google Authenticator、Microsoft Authenticator导出）
        function parseJsonImport(text) {
            const data = JSON.parse(text);
            const accounts = [];
            
            console.log('JSON数据:', data);
            
            // 如果是数组，直接处理
            if (Array.isArray(data)) {
                data.forEach(item => {
                    if (item.uri && item.uri.startsWith('otpauth://')) {
                        accounts.push({ uri: item.uri });
                    } else if (item.url && item.url.startsWith('otpauth://')) {
                        accounts.push({ uri: item.url });
                    }
                });
            }
            // Google Authenticator 格式
            else if (data.exportFormat === 'uri' && data.uris) {
                data.uris.forEach(uriObj => {
                    if (uriObj.uri && uriObj.uri.startsWith('otpauth://')) {
                        accounts.push({ uri: uriObj.uri });
                    }
                });
            }
            // Microsoft Authenticator 格式
            else if (data.rows && Array.isArray(data.rows)) {
                data.rows.forEach(row => {
                    if (row.url && row.url.startsWith('otpauth://')) {
                        accounts.push({ uri: row.url });
                    }
                });
            }
            // 2FAS (2-Factor Authenticator Secrets) 格式
            else if (data.schema_version && data.services) {
                data.services.forEach(service => {
                    if (service.secret && service.name) {
                        const issuer = service.otp || service.issuer || '';
                        const uri = `otpauth://totp/${encodeURIComponent(issuer)}:${encodeURIComponent(service.name)}?secret=${service.secret}${issuer ? '&issuer=' + encodeURIComponent(issuer) : ''}`;
                        accounts.push({ uri: uri });
                    }
                });
            }
            // Authy 格式
            else if (data.authy && Array.isArray(data.authy)) {
                data.authy.forEach(item => {
                    if (item.uri && item.uri.startsWith('otpauth://')) {
                        accounts.push({ uri: item.uri });
                    }
                });
            }
            // 双因素身份验证 格式
            else if (data.db && data.db.entries && Array.isArray(data.db.entries)) {
                data.db.entries.forEach(entry => {
                    if (entry.type === 'totp' && entry.info && entry.info.secret) {
                        const name = entry.name || '';
                        const issuer = entry.issuer || '';
                        const algo = entry.info.algo || 'SHA1';
                        const digits = entry.info.digits || 6;
                        const period = entry.info.period || 30;
                        const secret = entry.info.secret;
                        
                        const uri = `otpauth://totp/${encodeURIComponent(issuer || name)}:${encodeURIComponent(name)}?secret=${secret}&algorithm=${algo}&digits=${digits}&period=${period}${issuer ? '&issuer=' + encodeURIComponent(issuer) : ''}`;
                        accounts.push({ uri: uri });
                    }
                });
            }
            // 其他格式，尝试直接使用
            else {
                Object.entries(data).forEach(([key, value]) => {
                    if (typeof value === 'object' && value.secret) {
                        const uri = buildOtpAuthUri(value);
                        if (uri) {
                            accounts.push({ uri: uri });
                        }
                    } else if (typeof value === 'string' && value.startsWith('otpauth://')) {
                        accounts.push({ uri: value });
                    }
                });
            }
            
            console.log('解析后的账户:', accounts);
            return accounts;
        }
        
        // 解析CSV格式
        function parseCsvImport(text) {
            const lines = text.split('\n');
            const accounts = [];
            
            // 跳过标题行
            for (let i = 1; i < lines.length; i++) {
                const line = lines[i].trim();
                if (!line) continue;
                
                const parts = line.split(',');
                if (parts.length >= 2) {
                    const name = parts[0].trim();
                    const secret = parts[1].trim();
                    const issuer = parts[2] ? parts[2].trim() : '';
                    
                    if (secret) {
                        const uri = `otpauth://totp/${encodeURIComponent(issuer || name)}:${encodeURIComponent(name)}?secret=${secret}${issuer ? '&issuer=' + encodeURIComponent(issuer) : ''}`;
                        accounts.push({ uri: uri });
                    }
                }
            }
            
            return accounts;
        }
        
        // 解析TXT格式（每行一个URI）
        function parseTxtImport(text) {
            const lines = text.split('\n');
            const accounts = [];
            
            lines.forEach(line => {
                line = line.trim();
                if (line && line.startsWith('otpauth://')) {
                    accounts.push({ uri: line });
                }
            });
            
            return accounts;
        }
        
        // 构建otpauth URI
        function buildOtpAuthUri(data) {
            if (!data.secret) return null;
            
            const name = data.name || data.label || 'Account';
            const issuer = data.issuer || '';
            const algorithm = data.algorithm || 'SHA1';
            const digits = data.digits || 6;
            const period = data.period || 30;
            
            return `otpauth://totp/${encodeURIComponent(issuer || name)}:${encodeURIComponent(name)}?secret=${data.secret}&algorithm=${algorithm}&digits=${digits}&period=${period}${issuer ? '&issuer=' + encodeURIComponent(issuer) : ''}`;
        }
        
        // 导出账户
        function exportAccounts() {
            const format = confirm('选择导出格式：\n\n确定 = JSON格式\n取消 = CSV格式') ? 'json' : 'csv';
            window.location.href = `/two-factor-auth/frontend/accounts/export?format=${format}`;
        }
        
        // 批量导入账户
        async function importAccounts(accounts) {
            let successCount = 0;
            let failCount = 0;
            
            for (const account of accounts) {
                try {
                    const response = await fetch('/two-factor-auth/frontend/accounts/import', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: `uri=${encodeURIComponent(account.uri)}`
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        successCount++;
                    } else {
                        failCount++;
                    }
                } catch (error) {
                    failCount++;
                }
            }
            
            let message = `导入完成！成功：${successCount} 个`;
            if (failCount > 0) {
                message += `，失败：${failCount} 个`;
            }
            
            alert(message);
            
            if (successCount > 0) {
                closeModal('addModal');
                location.reload();
            }
        }
    </script>
</body>
</html>

