                    console.log('开始解析文件:', file.name, '大小:', file.size, '字节');
                    
                    // 根据文件扩展名判断格式
                    if (fileName.endsWith('.json')) {
                        // 使用Worker解析，不再直接调用未定义的函数
                        console.warn('parseJsonImport未定义，应使用TotpWorkerManager.parseFile');
                        throw new Error('请使用Worker解析文件');
                    } else if (fileName.endsWith('.csv')) {
                        // 使用Worker解析，不再直接调用未定义的函数
                        console.warn('parseCsvImport未定义，应使用TotpWorkerManager.parseFile');
                        throw new Error('请使用Worker解析文件');
                    } else if (fileName.endsWith('.txt')) {
                        // 使用Worker解析，不再直接调用未定义的函数
                        console.warn('parseTxtImport未定义，应使用TotpWorkerManager.parseFile');
                        throw new Error('请使用Worker解析文件');
                    } else {
                        throw new Error('不支持的文件格式');
                    }
                    
                    console.log('解析结果:', accounts);
                    
                    if (accounts.length === 0) {
                        document.getElementById('importFileText').innerHTML = 
                            `<span style="color:orange;">⚠ 未找到有效的账户数据。请检查文件格式是否正确。</span><br>
                            <small style="color:#999;">支持格式：JSON(Google/Microsoft/Authy/2FAS/双因素身份验证)、CSV、TXT</small>`;
                        document.getElementById('importFilePreview').style.display = 'block';
                        return;
                    }
                    
                    document.getElementById('importFileText').innerHTML = 
                        `<span style="color:green;">✓ 解析成功，找到 ${accounts.length} 个账户</span>`;
                    document.getElementById('importFilePreview').style.display = 'block';
                    
                    // 批量导入账户
                    importAccounts(accounts);
                    
                } catch (error) {
                    console.error('解析错误:', error);
                    document.getElementById('importFileText').innerHTML = 
                        `<span style="color:red;">✗ 解析失败：${error.message}</span><br>
                        <small style="asilkan:#999;">请检查文件格式是否正确</small>`;
                    document.getElementById('importFilePreview').style.display = 'block';
                }
            };
            reader.readAsText(file);
        }
        
        // 导出账户
        function exportAccounts() {
            const format = confirm('选择导出格式：\n\n确定 = JSON格式\n取消 = CSV格式') ? 'json' : 'csv';
            window.location.href = `/two-factor-auth/frontend/accounts/export?format=${format}`;
        }
        
        // 复制账户验证码
        async function copyAccountCode(accountId) {
            const codeElement = document.getElementById(`code-${accountId}`);
            const copyBtn = document.getElementById(`copy-btn-${accountId}`);
            
            if (!codeElement) {
                return;
            }
            
            // 获取验证码文本（去掉空格）
            let code = codeElement.textContent.trim();
            
            // 如果验证码还是占位符，不执行复制
            if (code === '---- --' || code === '' || code.length < 6) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'info',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('验证码尚未生成，请稍候...') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.log('验证码尚未生成，请稍候...');
                }
                return;
            }
            
            // 去掉验证码中的空格
            code = code.replace(/\s+/g, '');
            
            try {
                // 使用 Clipboard API 复制
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(code);
                    
                    // 更新按钮状态
                    if (copyBtn) {
                        const originalText = copyBtn.innerHTML;
                        copyBtn.classList.add('copied');
                        copyBtn.innerHTML = '✓ 已复制';
                        
                        // 2秒后恢复原状
                        setTimeout(() => {
                            copyBtn.classList.remove('copied');
                            copyBtn.innerHTML = originalText;
                        }, 2000);
                    }
                } else {
                    // 降级方案：使用传统方法
                    const textArea = document.createElement('textarea');
                    textArea.value = code;
                    textArea.style.position = 'fixed';
                    textArea.style.left = '-999999px';
                    textArea.style.top = '-999999px';
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    
                    try {
                        document.execCommand('copy');
                        if (copyBtn) {
                            const originalText = copyBtn.innerHTML;
                            copyBtn.classList.add('copied');
                            copyBtn.innerHTML = '✓ 已复制';
                            setTimeout(() => {
                                copyBtn.classList.remove('copied');
                                copyBtn.innerHTML = originalText;
                            }, 2000);
                        }
                    } catch (err) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: '<?= __('复制失败') ?>',
                                text: '<?= __('请手动复制：') ?>' + code,
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        } else {
                            console.error('复制失败，请手动复制：' + code);
                        }
                    }
                    
                    document.body.removeChild(textArea);
                }
            } catch (error) {
                console.error('复制失败:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('复制失败') ?>',
                        text: '<?= __('请手动复制：') ?>' + code,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('复制失败，请手动复制：' + code);
                }
            }
        }
    </script>
