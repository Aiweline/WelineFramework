        // 解析二维码
        function parseQRCode(img) {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = img.width;
            canvas.height = img.height;
            ctx.drawImage(img, 0, 0);
            
            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const code = jsQR(imageData.data, imageData.width, imageData.height);
            
            if (code) {
                document.getElementById('previewText').innerHTML = '<span style="color:green;">✓ 二维码解析成功！</span>';
                setTimeout(() => {
                    handleQRCodeURI(code.data);
                }, 500);
            } else {
                document.getElementById('previewText').innerHTML = '<span style="color:red;">✗ 无法识别二维码，请重试</span>';
            }
        }
        
        // 启动摄像头
        let cameraStream = null;
        let scanningInterval = null;
        
        function startCamera() {
            navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
                .then(stream => {
                    cameraStream = stream;
                    const video = document.getElementById('cameraVideo');
                    video.srcObject = stream;
                    video.style.display = 'block';
                    document.getElementById('startCameraBtn').style.display = 'none';
                    
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    scanningInterval = setInterval(() => {
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        ctx.drawImage(video, 0, 0);
                        
                        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                        const code = jsQR(imageData.data, imageData.width, imageData.height);
                        
                        if (code) {
                            stopCamera();
                            handleQRCodeURI(code.data);
                        }
                    }, 100);
                })
                .catch(err => {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('无法访问摄像头') ?>',
                            text: err.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('无法访问摄像头：' + err.message);
                    }
                });
        }
        
        // 停止摄像头
        function stopCamera() {
            if (cameraStream) {
                cameraStream.getTracks().forEach(track => track.stop());
                cameraStream = null;
            }
            if (scanningInterval) {
                clearInterval(scanningInterval);
                scanningInterval = null;
            }
            document.getElementById('cameraVideo').style.display = 'none';
            document.getElementById('startCameraBtn').style.display = 'block';
        }
        
        // 处理解析的URI
        async function handleQRCodeURI(uri) {
            if (!uri.startsWith('otpauth://')) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('错误') ?>',
                        text: '<?= __('无效的二维码格式') ?>',
