    <script>
        document.addEventListener('click', function(e) {
            const trigger = e.target.closest('[data-twofa-action]');
            if (!trigger) {
                return;
            }

            const action = trigger.getAttribute('data-twofa-action');
            if (action === 'copy-secret') {
                copySecret();
            } else if (action === 'copy-backup-codes') {
                copyBackupCodes();
            } else if (action === 'download-backup-codes') {
                downloadBackupCodes();
            } else if (action === 'enable-two-factor') {
                enableTwoFactor();
            } else if (action === 'show-authenticator-app-modal') {
                showAuthenticatorAppModal();
            } else if (action === 'close-authenticator-app-modal') {
                closeAuthenticatorAppModal();
            }
        });

        document.addEventListener('keydown', function(e) {
            const trigger = e.target.closest('[data-twofa-action]');
            if (!trigger || (e.key !== 'Enter' && e.key !== ' ')) {
                return;
            }
            e.preventDefault();
            trigger.click();
        });

        // 复制密钥
        function copySecret() {
            const text = '<?= str_replace(' ', '', $formatted_secret) ?>';
            navigator.clipboard.writeText(text).then(() => {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('复制成功') ?>',
                        text: '<?= __('密钥已复制到剪贴板') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    console.log('<?= __('密钥已复制到剪贴板') ?>');
                }
            });
        }

        // 复制备份码
        function copyBackupCodes() {
            const codes = <?= json_encode($backup_codes) ?>;
            const text = codes.join('\n');
            navigator.clipboard.writeText(text).then(() => {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('复制成功') ?>',
                        html: '<?= __('备份码已复制到剪贴板') ?><br><?= __('请妥善保存') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    console.log('<?= __('备份码已复制到剪贴板\n请妥善保存！') ?>');
                }
            });
        }

        // 下载备份码
        function downloadBackupCodes() {
            const codes = <?= json_encode($backup_codes) ?>;
            const userEmail = <?= json_encode($user_email ?? 'user') ?>;
            const timestamp = new Date().toISOString().split('T')[0];
            
            // 构建文件内容
            let content = '<?= __('双因素身份验证备份码') ?>\n';
            content += '='.repeat(30) + '\n\n';
            content += '<?= __('账户：') ?>' + userEmail + '\n';
            content += '<?= __('生成时间：') ?>' + timestamp + '\n';
            content += '\n⚠️ <?= __('重要提示：') ?>\n';
            content += '<?= __('这些备份码用于在无法获取验证器时登录账户。') ?>\n';
            content += '<?= __('每个备份码只能使用一次，请妥善保存！') ?>\n\n';
            content += '<?= __('备份码列表：') ?>\n';
            content += '-'.repeat(30) + '\n';
            codes.forEach((code, index) => {
                content += (index + 1) + '. ' + code + '\n';
            });
            content += '-'.repeat(30) + '\n\n';
            content += '<?= __('请将本文件保存在安全的地方！') ?>\n';
            
            // 创建Blob并下载
            const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = '2FA备份码_' + userEmail + '_' + timestamp + '.txt';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
            
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('下载成功') ?>',
                    html: '<?= __('备份码已下载') ?><br><?= __('文件名：') ?>' + link.download,
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log('<?= __('备份码已下载！\n文件名：') ?>' + link.download);
            }
        }

        // 自动格式化验证码输入
        document.getElementById('verifyCode').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        // 启用2FA
        async function enableTwoFactor() {
            const code = document.getElementById('verifyCode').value;
            const secret = document.getElementById('secret').value;
            const backupCodes = document.getElementById('backupCodesJson').value;

            if (!code || code.length !== 6) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请输入6位验证码') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('请输入6位验证码') ?>');
                }
                return;
            }

            try {
                const response = await fetch('/two-factor-auth/frontend/setup/enable', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `secret=${encodeURIComponent(secret)}&code=${code}&backup_codes=${encodeURIComponent(backupCodes)}`
                });

                const result = await response.json();
                
                if (result.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            html: '<?= __('双因素身份验证已成功启用') ?><br><br><?= __('请确保已保存备份码，然后点击确定返回管理页面。') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        }).then(() => {
                            window.location.href = '/two-factor-auth/frontend';
                        });
                    } else {
                        console.log('✅ <?= __('双因素身份验证已成功启用！\n\n请确保已保存备份码，然后点击确定返回管理页面。') ?>');
                        window.location.href = '/two-factor-auth/frontend';
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('失败') ?>',
                            html: result.message + '<br><br><?= __('请检查验证码是否正确，注意验证码每30秒会更新。') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('❌ ' + result.message + '\n\n<?= __('请检查验证码是否正确，注意验证码每30秒会更新。') ?>');
                    }
                }
            } catch (error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: '<?= __('请重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败，请重试') ?>');
                }
                console.error(error);
            }
        }

        // Enter键提交
        document.getElementById('verifyCode').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                enableTwoFactor();
            }
        });

        // 显示验证器APP提示模态框
        function showAuthenticatorAppModal() {
            const modal = document.createElement('div');
            modal.id = 'authenticatorAppModal';
            modal.style.cssText = 'position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 10000; display: flex; align-items: center; justify-content: center;';
            
            const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
            const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
            const isAndroid = /Android/.test(navigator.userAgent);
            
            let installInstructions = '';
            if (isIOS) {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>📱 <?= __('iOS设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在Safari浏览器中，点击底部"分享"按钮') ?></li>
                            <li><?= __('选择"添加到主屏幕"') ?></li>
                            <li><?= __('点击"添加"完成安装') ?></li>
                        </ol>
                    </div>
                `;
            } else if (isAndroid) {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>📱 <?= __('Android设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在Chrome浏览器中，点击右上角"菜单"（三个点）') ?></li>
                            <li><?= __('选择"添加到主屏幕"或"安装应用"') ?></li>
                            <li><?= __('点击"添加"或"安装"完成') ?></li>
                        </ol>
                    </div>
                `;
            } else {
                installInstructions = `
                    <div style="margin-top: 1rem; padding: 1rem; background: #e7f3ff; border-radius: 8px;">
                        <strong>💻 <?= __('桌面设备安装步骤：') ?></strong>
                        <ol style="margin: 0.5rem 0; padding-left: 1.5rem;">
                            <li><?= __('点击下方"打开验证器"按钮') ?></li>
                            <li><?= __('在浏览器地址栏右侧，点击"安装"图标') ?></li>
                            <li><?= __('或使用浏览器的"添加到主屏幕"功能') ?></li>
                            <li><?= __('安装后即可像应用一样使用') ?></li>
                        </ol>
                    </div>
                `;
            }
            
            modal.innerHTML = `
                <div style="background: white; padding: 2rem; border-radius: 12px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                    <h2 style="margin-bottom: 1rem; color: #333; display: flex; align-items: center; gap: 0.5rem;">
                        📱 <?= __('打开验证器APP') ?>
                    </h2>
                    <p style="color: #666; margin-bottom: 1rem; line-height: 1.6;">
                        <?= __('我们的验证器是一个PWA（渐进式Web应用），可以像原生应用一样安装到您的设备上。') ?>
                    </p>
                    <div style="margin-top: 1rem; padding: 1rem; background: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px;">
                        <strong>💡 <?= __('提示：') ?></strong>
                        <p style="margin: 0.5rem 0 0 0; color: #856404;">
                            <?= __('建议将验证器保存到桌面，方便随时使用。安装后可以离线使用，无需每次打开浏览器。') ?>
                        </p>
                    </div>
                    ${installInstructions}
                    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
                        <button type="button" data-twofa-action="close-authenticator-app-modal" style="padding: 0.75rem 1.5rem; border: 1px solid #ddd; border-radius: 8px; background: white; color: #333; cursor: pointer; font-weight: 500;">
                            <?= __('取消') ?>
                        </button>
                        <a href="/twofa-app/" target="_blank" data-twofa-action="close-authenticator-app-modal" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #007bff; color: white; text-decoration: none; font-weight: 500; display: inline-block;">
                            <?= __('打开验证器') ?>
                        </a>
                    </div>
                </div>
            `;
            
            document.body.appendChild(modal);
            
            // 点击外部关闭
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    closeAuthenticatorAppModal();
                }
            });
        }

        // 关闭验证器APP提示模态框
        function closeAuthenticatorAppModal() {
            const modal = document.getElementById('authenticatorAppModal');
            if (modal) {
                modal.remove();
            }
        }
    </script>
</body>
</html>

