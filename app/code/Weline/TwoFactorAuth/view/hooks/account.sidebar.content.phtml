/**@var \Weline\Framework\View\Template $this */

// 获取当前用户（从模板数据中获取）
$user = $this->getData('user');
if (!$user) {
    return;
}

$userId = $user->getId();

// 获取两步验证服务
try {
    /** @var \Weline\TwoFactorAuth\Service\TwoFactorAuthService $twoFactorService */
    $twoFactorService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\TwoFactorAuth\Service\TwoFactorAuthService::class);
    $isEnabled = $twoFactorService->isEnabled($userId);
    $config = $twoFactorService->getUserConfig($userId);
    $remainingSeconds = $twoFactorService->getRemainingSeconds();
} catch (\Exception $e) {
    // 如果服务不可用，不显示面板
    return;
}

// 准备内容HTML
$statusBadge = $isEnabled 
    ? '<div style="display: inline-block; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; background: #d4edda; color: #155724; margin-bottom: 1.5rem;">✓ ' . __('已启用') . '</div>'
    : '<div style="display: inline-block; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; background: #f8d7da; color: #721c24; margin-bottom: 1.5rem;">✗ ' . __('未启用') . '</div>';

$infoGrid = '';
