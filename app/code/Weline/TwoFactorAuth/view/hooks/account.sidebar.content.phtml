    }
    
    modal.innerHTML = `
        <div style="background: white; padding: 2rem; border-radius: 12px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
            <h2 style="margin-bottom: 1rem; color: #333; display: flex; align-items: center; gap: 0.5rem;">
                📱 <?= __('打开验证器APP') ?>
            </h2>
            <p style="color: #666; margin-bottom: 1rem; line-height: 1.6;">
                <?= __('我们的验证器是一个PWA（渐进式Web应用），可以像原生应用一样安装到您的设备上。') ?>
            </p>
            <div style="margin-top: 1rem; padding: 1rem; background: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px;">
                <strong>💡 <?= __('提示：') ?></strong>
                <p style="margin: 0.5rem 0 0 0; color: #856404;">
                    <?= __('建议将验证器保存到桌面，方便随时使用。安装后可以离线使用，无需每次打开浏览器。') ?>
                </p>
            </div>
            ${installInstructions}
            <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
                <button onclick="closeAuthenticatorAppModal()" style="padding: 0.75rem 1.5rem; border: 1px solid #ddd; border-radius: 8px; background: white; color: #333; cursor: pointer; font-weight: 500;">
                    <?= __('取消') ?>
                </button>
                <a href="/twofa-app/" target="_blank" onclick="closeAuthenticatorAppModal()" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #007bff; color: white; text-decoration: none; font-weight: 500; display: inline-block;">
                    <?= __('打开验证器') ?>
                </a>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
    
    // 点击外部关闭
    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            closeAuthenticatorAppModal();
        }
    });
}

// 关闭验证器APP提示模态框
function closeAuthenticatorAppModal() {
    const modal = document.getElementById('authenticatorAppModal');
    if (modal) {
        modal.remove();
    }
}
</script>
