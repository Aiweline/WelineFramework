<script>
// 显示禁用2FA模态框
function showDisableTwoFactorModal() {
    document.getElementById('disableTwoFactorModal').classList.remove('d-none');
    document.getElementById('disableTwoFactorModal').style.display = 'flex';
}

// 关闭禁用2FA模态框
function closeDisableTwoFactorModal() {
    document.getElementById('disableTwoFactorModal').classList.add('d-none');
    document.getElementById('disableTwoFactorModal').style.display = 'none';
    document.getElementById('disableTwoFactorCode').value = '';
}

// 显示重新生成备份码模态框
function showRegenerateBackupCodesModal() {
    document.getElementById('regenerateBackupCodesModal').classList.remove('d-none');
    document.getElementById('regenerateBackupCodesModal').style.display = 'flex';
}

// 关闭重新生成备份码模态框
function closeRegenerateBackupCodesModal() {
    document.getElementById('regenerateBackupCodesModal').classList.add('d-none');
    document.getElementById('regenerateBackupCodesModal').style.display = 'none';
    document.getElementById('regenerateBackupCodesCode').value = '';
}

// 禁用2FA
async function disableTwoFactor() {
    const code = document.getElementById('disableTwoFactorCode').value;
    if (!code || code.length !== 6) {
        alert('<?= __('请输入6位验证码') ?>');
        return;
    }

    try {
        const response = await fetch('/two-factor-auth/frontend/setup/disable', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `code=${code}`
        });

        const result = await response.json();
        
        if (result.success) {
            alert(result.message);
            location.reload();
        } else {
            alert(result.message);
        }
    } catch (error) {
        alert('<?= __('操作失败，请重试') ?>');
    }
}

// 重新生成备份码
async function regenerateBackupCodes() {
    const code = document.getElementById('regenerateBackupCodesCode').value;
    if (!code || code.length !== 6) {
        alert('<?= __('请输入6位验证码') ?>');
        return;
    }

    try {
        const response = await fetch('/two-factor-auth/frontend/setup/regenerate-backup-codes', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `code=${code}`
        });

        const result = await response.json();
        
        if (result.success) {
            // 显示新的备份码
            let codesHtml = '<h3 style="margin-bottom: 1rem;"><?= __('新的备份码') ?></h3><ul style="list-style: none; padding: 0;">';
            result.backup_codes.forEach(code => {
                codesHtml += `<li style="font-family: monospace; padding: 0.5rem; background: #f8f9fa; margin-bottom: 0.5rem; border-radius: 4px;">${code}</li>`;
            });
            codesHtml += '</ul><p style="color: red; margin-top: 1rem;"><?= __('请妥善保存这些备份码！') ?></p>';
            
            const modal = document.getElementById('regenerateBackupCodesModal');
            modal.querySelector('.modal-content').innerHTML = codesHtml + 
                '<button class="btn btn-primary" onclick="location.reload()" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #007bff; color: white; cursor: pointer; margin-top: 1rem;"><?= __('完成') ?></button>';
        } else {
            alert(result.message);
        }
    } catch (error) {
        alert('<?= __('操作失败，请重试') ?>');
    }
}

// 点击模态框外部关闭
document.addEventListener('click', function(event) {
    if (event.target.id === 'disableTwoFactorModal') {
        closeDisableTwoFactorModal();
    }
    if (event.target.id === 'regenerateBackupCodesModal') {
        closeRegenerateBackupCodesModal();
    }
    if (event.target.id === 'authenticatorAppModal') {
        closeAuthenticatorAppModal();
    }
});

// 显示验证器APP提示模态框
