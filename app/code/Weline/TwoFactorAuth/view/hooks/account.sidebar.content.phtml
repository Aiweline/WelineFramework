            </button>
            <button type="button" onclick="regenerateBackupCodes()" class="btn btn-primary" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #007bff; color: white; cursor: pointer;">
                <?= __('确认生成') ?>
            </button>
        </div>
