<?php
/**
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

use Weline\Customer\Service\AccountSidebarContentGate;

if (!AccountSidebarContentGate::accepts('twofa')) {
    return;
}

$user = $this->getData('user');
if (!$user) {
    return;
}

$userId = (int)$user->getId();

try {
    /** @var \Weline\TwoFactorAuth\Service\TwoFactorAuthService $twoFactorService */
    $twoFactorService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\TwoFactorAuth\Service\TwoFactorAuthService::class);
    $isEnabled = $twoFactorService->isEnabled($userId);
    $config = $twoFactorService->getUserConfig($userId);
    $setupData = null;

    if (!$isEnabled) {
        $accountLabel = $user->getUsername() . ':' . $user->getEmail();
        $setupData = $twoFactorService->initialize($userId);
        $setupData['formatted_secret'] = $twoFactorService->formatSecret($setupData['secret']);
        $setupData['qr_code_url'] = $twoFactorService->getQRCodeUrl($setupData['secret'], $accountLabel);
    }
} catch (\Exception $e) {
    return;
}
?>
