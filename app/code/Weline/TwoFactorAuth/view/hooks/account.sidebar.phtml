<?php
/**
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$user = $this->getData('user');
if (!$user) {
    return;
}

try {
    $accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
    if (!is_string($accountIndexPath) || $accountIndexPath === '') {
        $accountIndexPath = '/customer/account/index';
    }
    $accountIndexPath = rtrim($accountIndexPath, '/');
} catch (\Exception $e) {
    return;
}
?>
<a class="account-hook-nav-link" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#twofa" data-section="twofa" data-account-nav-link="true" data-account-nav-parent="security">
    <span class="account-hook-nav-link__label">
        <i class="ri-shield-keyhole-line" aria-hidden="true"></i>
        <span class="account-hook-nav-link__text">
            <strong><?= __('两步验证') ?></strong>
            <span><?= __('账户登录安全验证') ?></span>
        </span>
    </span>
    <span class="account-hook-nav-link__arrow" aria-hidden="true">
        <i class="fa fa-angle-right"></i>
    </span>
</a>
