<?php
/**
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$user = $this->getData('user');
if (!$user) {
    return;
}

$userId = $user->getId();

try {
    /** @var \Weline\TwoFactorAuth\Service\TwoFactorAuthService $twoFactorService */
    $twoFactorService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\TwoFactorAuth\Service\TwoFactorAuthService::class);
    $isEnabled = $twoFactorService->isEnabled($userId);
    $accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
    if (!is_string($accountIndexPath) || $accountIndexPath === '') {
        $accountIndexPath = '/customer/account/index';
    }
    $accountIndexPath = rtrim($accountIndexPath, '/');
} catch (\Exception $e) {
    return;
}
?>
<a class="account-hook-nav-link" href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#twofa" data-section="twofa" data-account-nav-link="true" data-account-nav-parent="security">
    <span class="account-hook-nav-link__label">
        <i class="ri-shield-keyhole-line" aria-hidden="true"></i>
        <span class="account-hook-nav-link__text">
            <strong><?= __('Two-Factor Verification') ?></strong>
            <span><?= __('Account Login Security Verification') ?></span>
        </span>
    </span>
    <span class="account-hook-nav-link__arrow" aria-hidden="true">
        <?php if ($isEnabled): ?>
            <span class="badge badge-success" style="background: #28a745; color: white; padding: 2px 6px; border-radius: 10px; font-size: 10px;"><?= __('Enabled') ?></span>
        <?php else: ?>
            <span class="badge badge-secondary" style="background: #6c757d; color: white; padding: 2px 6px; border-radius: 10px; font-size: 10px;"><?= __('Disabled') ?></span>
        <?php endif; ?>
    </span>
</a>
