<?php
/**
 * Header delivery location selector hook.
 *
 * @hook-priority 100
 * @hook-sort-order 1
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$currentLocation = null;
$locationFromCookie = \w_env_cookie('weline_delivery_location');
if ($locationFromCookie) {
    $currentLocation = json_decode($locationFromCookie, true);
}

$locationFromUrl = $this->request->getParam('delivery_location');
if ($locationFromUrl) {
    $decodedLocation = json_decode(base64_decode((string)$locationFromUrl), true);
    if (is_array($decodedLocation)) {
        $currentLocation = $decodedLocation;
    }
}

$locationData = [
    'country' => $currentLocation['country'] ?? __('China'),
    'province' => $currentLocation['province'] ?? '',
    'city' => $currentLocation['city'] ?? '',
    'district' => $currentLocation['district'] ?? '',
    'full_address' => $currentLocation['full_address'] ?? __('Deliver to'),
];

$displayText = $locationData['full_address'];
if (empty($displayText) || $displayText === __('Deliver to')) {
    $displayText = $locationData['city']
        ?: ($locationData['province'] ?: ($locationData['country'] ?: __('Deliver to')));
}
?>
<div class="geo-location-selector" data-geo-location-selector>
    <a href="#" class="location-link" title="<?= __('Select delivery address') ?>" data-action="select-location">
        <i class="fas fa-map-marker-alt"></i>
        <div class="location-text">
            <span class="location-line-1"><?= __('Deliver to') ?></span>
            <span class="location-line-2" data-location-display><?= htmlspecialchars((string)$displayText, ENT_QUOTES, 'UTF-8') ?></span>
        </div>
        <i class="fas fa-chevron-down"></i>
    </a>
    <div class="location-selector-dropdown" hidden>
        <div class="location-selector-header">
            <h3><?= __('Select delivery address') ?></h3>
        </div>
        <div class="location-selector-content">
            <button type="button" class="location-option" data-action="auto-detect">
                <i class="fas fa-crosshairs"></i>
                <span><?= __('Auto detect') ?></span>
            </button>
            <button type="button" class="location-option" data-action="manual-select">
                <i class="fas fa-map-marked-alt"></i>
                <span><?= __('Manual select') ?></span>
            </button>
        </div>
        <div class="location-selector-footer">
            <button type="button" class="btn-close" data-action="close-selector"><?= __('Close') ?></button>
        </div>
    </div>
</div>

<script>
(function () {
    'use strict';

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLocationSelector);
    } else {
        initLocationSelector();
    }

    function getApi(provider) {
        if (!window.Weline || !window.Weline.Api) {
            return Promise.reject(new Error('Weline API is not available.'));
        }

        return Promise.resolve(window.Weline.Api.resource(provider));
    }

    function initLocationSelector() {
        var selector = document.querySelector('[data-geo-location-selector]');
        if (!selector) {
            return;
        }

        var link = selector.querySelector('[data-action="select-location"]');
        var dropdown = selector.querySelector('.location-selector-dropdown');
        var display = selector.querySelector('[data-location-display]');
        var autoDetect = selector.querySelector('[data-action="auto-detect"]');
        var manualSelect = selector.querySelector('[data-action="manual-select"]');
        var closeBtn = selector.querySelector('[data-action="close-selector"]');

        if (!link || !dropdown || !display) {
            return;
        }

        link.addEventListener('click', function (event) {
            event.preventDefault();
            dropdown.hidden = !dropdown.hidden;
        });

        if (closeBtn) {
            closeBtn.addEventListener('click', function () {
                dropdown.hidden = true;
            });
        }

        document.addEventListener('click', function (event) {
            if (!selector.contains(event.target)) {
                dropdown.hidden = true;
            }
        });

        if (autoDetect) {
            autoDetect.addEventListener('click', async function () {
                var originalHtml = autoDetect.innerHTML;
                try {
                    autoDetect.classList.add('loading');
                    autoDetect.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span><?= __('Locating...') ?></span>';

                    if (typeof WelineLocation === 'undefined') {
                        if (typeof Weline !== 'undefined' && Weline.load) {
                            await Weline.load('geo');
                        } else {
                            throw new Error('Geo module is not available.');
                        }
                    }

                    var position = await WelineLocation.getLocation();
                    var LocationApi = await getApi('location');
                    var geoResult = await LocationApi.address({
                        latitude: Number(position.latitude),
                        longitude: Number(position.longitude)
                    }, {silent: true});

                    if (!geoResult || geoResult.code !== 200 || !geoResult.data) {
                        throw new Error((geoResult && (geoResult.msg || geoResult.message)) || 'Address lookup failed.');
                    }

                    saveLocationToStorage(geoResult.data);
                    updateLocationDisplay(geoResult.data);
                    await updateShippingInfo(geoResult.data);
                    dropdown.hidden = true;
                } catch (error) {
                    alert(error.message || 'Location detection failed.');
                } finally {
                    autoDetect.classList.remove('loading');
                    autoDetect.innerHTML = originalHtml;
                }
            });
        }

        if (manualSelect) {
            manualSelect.addEventListener('click', async function () {
                var selectedAddress = prompt('<?= __('Enter delivery address, format: Province/City/District') ?>', '');
                if (!selectedAddress) {
                    return;
                }

                var addressParts = selectedAddress.split('/');
                var addressData = {
                    country: '<?= __('China') ?>',
                    countryCode: 'CN',
                    province: addressParts[0] || '',
                    city: addressParts[1] || '',
                    district: addressParts[2] || '',
                    street: '',
                    full_address: selectedAddress
                };

                saveLocationToStorage(addressData);
                updateLocationDisplay(addressData);
                await updateShippingInfo(addressData);
                dropdown.hidden = true;
            });
        }

        function saveLocationToStorage(addressData) {
            if (window.WelineShipping && window.WelineShipping.Location) {
                window.WelineShipping.Location.save(addressData);
                return;
            }

            try {
                var cookieValue = JSON.stringify(addressData);
                var expires = new Date();
                expires.setTime(expires.getTime() + 30 * 24 * 60 * 60 * 1000);
                document.cookie = 'weline_delivery_location=' + encodeURIComponent(cookieValue) + ';expires=' + expires.toUTCString() + ';path=/';
                localStorage.setItem('weline_delivery_location', cookieValue);
            } catch (error) {
                console.error('Failed to save location:', error);
            }
        }

        async function updateShippingInfo(addressData) {
            try {
                if (window.WelineShipping && window.WelineShipping.Location) {
                    await window.WelineShipping.Location.fetchShippingInfo(addressData);
                    return;
                }

                var ShippingInfoApi = await getApi('shippingInfo');
                var shippingResult = await ShippingInfoApi.getByLocation({
                    country_code: addressData.countryCode || 'CN',
                    province: addressData.province || '',
                    city: addressData.city || '',
                    district: addressData.district || ''
                }, {silent: true});

                if (
                    shippingResult
                    && shippingResult.code === 200
                    && window.WelineShipping
                    && window.WelineShipping.IndexedDB
                ) {
                    await window.WelineShipping.IndexedDB.saveShippingInfo(addressData, shippingResult.data);
                }
            } catch (error) {
                console.error('Failed to update shipping info:', error);
            }
        }

        function updateLocationDisplay(addressData) {
            display.textContent = addressData.city
                || addressData.province
                || addressData.country
                || '<?= __('Deliver to') ?>';
        }
    }
})();
</script>

<style>
