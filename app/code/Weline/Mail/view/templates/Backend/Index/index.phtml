                                        <td><?= (int)$message->getData('account_id') ?></td>
                                        <td><?= $escape($message->getData('folder')) ?></td>
                                        <td><?= $escape($message->getData('from_email')) ?></td>
                                        <td><?= $escape($message->getData('to_email')) ?></td>
                                        <td><?= $escape($message->getData('subject')) ?></td>
                                        <td><?= $escape($message->getData('delivery_status')) ?></td>
                                        <td><?= $escape($message->getData('created_at')) ?></td>
                                    </tr>
                                <?php endforeach; ?>
                            <?php endif; ?>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var domainOptions = <?= $domainOptionsJson ?>;
    var searchInput = document.getElementById('mail-domain-search');
    var hiddenInput = document.getElementById('mail-domain-hidden');
    var resultBox = document.getElementById('mail-domain-results');
    var selectedName = document.getElementById('mail-selected-domain-name');
    var selectedMeta = document.getElementById('mail-selected-domain-meta');
    var hostInput = document.getElementById('mail-domain-hostname');
    var engineSelect = document.getElementById('mail-domain-engine');
    var domainSubmit = document.getElementById('mail-domain-submit');
    var accountDomainSelect = document.getElementById('mail-account-domain-select');
    var accountDomainSuffix = document.getElementById('mail-account-domain-suffix');
    var accountQuota = document.getElementById('mail-account-quota');
    var accountStatus = document.getElementById('mail-account-status');
    var accountFilter = document.getElementById('mail-account-domain-filter');

    function normalize(value) {
        return String(value || '').trim().toLowerCase();
    }

    function isFakeDomain(domain) {
        return domain.endsWith('.test') || domain.endsWith('.invalid');
    }

    function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, function (char) {
            return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'}[char];
        });
    }

    function renderDomainOptions() {
        var query = normalize(searchInput.value);
        var filtered = domainOptions.filter(function (item) {
            if (!query) {
                return true;
            }
            return normalize(item.domain).indexOf(query) !== -1
                || normalize(item.source_domain).indexOf(query) !== -1
                || normalize(item.source).indexOf(query) !== -1;
        }).slice(0, 14);

        if (!filtered.length) {
            resultBox.innerHTML = '<div class="p-3 text-muted"><?= $escape(__('暂无匹配域名，可输入 .test / .invalid 域名做 Fake 冒烟')) ?></div>';
            return;
        }

        resultBox.innerHTML = filtered.map(function (item) {
            var created = item.is_created ? '<span class="badge bg-success ms-2"><?= $escape(__('已开通')) ?></span>' : '';
            var sourceDomain = item.source_domain && item.source_domain !== item.domain
                ? '<span class="text-muted ms-2">' + escapeHtml(item.source_domain) + '</span>'
                : '';
            var accountText = item.is_created
                ? '<?= $escape(__('账号数')) ?> ' + Number(item.account_count || 0)
                : '<?= $escape(__('未开通')) ?>';
            return '<button type="button" class="mail-domain-option" data-domain="' + escapeHtml(item.domain) + '">'
                + '<div><span class="mail-domain-name">' + escapeHtml(item.domain) + '</span>' + created + sourceDomain + '</div>'
                + '<div class="mail-muted-line">' + escapeHtml(item.source || '') + ' · ' + escapeHtml(item.website_status || '') + ' · ' + accountText + '</div>'
                + '</button>';
        }).join('');
    }

    function findDomainOption(domain) {
        domain = normalize(domain);
        for (var i = 0; i < domainOptions.length; i++) {
            if (normalize(domainOptions[i].domain) === domain) {
                return domainOptions[i];
            }
        }
        return null;
    }

    function selectDomain(domain) {
        domain = normalize(domain);
        var option = findDomainOption(domain);
        hiddenInput.value = domain;
        searchInput.value = domain;
        if (!hostInput.value || hostInput.dataset.auto === '1') {
            hostInput.value = domain ? 'mail.' + domain : '';
            hostInput.dataset.auto = '1';
        }
        if (domain) {
            engineSelect.value = isFakeDomain(domain) ? 'fake' : 'stalwart';
        }
        if (option) {
            selectedName.textContent = option.domain;
            selectedMeta.textContent = (option.source || '') + (option.is_created ? ' · <?= $escape(__('已开通')) ?>' : ' · <?= $escape(__('可开通')) ?>');
            domainSubmit.disabled = !!option.is_created;
        } else {
            selectedName.textContent = domain || '<?= $escape(__('尚未选择域名')) ?>';
            selectedMeta.textContent = domain ? '<?= $escape(__('手动测试域名')) ?>' : '<?= $escape(__('请搜索并选择一个域名')) ?>';
            domainSubmit.disabled = false;
        }
        Array.prototype.forEach.call(resultBox.querySelectorAll('.mail-domain-option'), function (button) {
            button.classList.toggle('is-selected', normalize(button.getAttribute('data-domain')) === domain);
        });
    }

    if (searchInput && resultBox) {
        renderDomainOptions();
        searchInput.addEventListener('input', function () {
            var value = normalize(searchInput.value);
            hiddenInput.value = value;
            if (!hostInput.value || hostInput.dataset.auto === '1') {
                hostInput.value = value ? 'mail.' + value : '';
                hostInput.dataset.auto = '1';
            }
            if (value) {
                var exact = findDomainOption(value);
                if (exact) {
                    selectDomain(value);
                } else {
                    selectedName.textContent = value;
                    selectedMeta.textContent = '<?= $escape(__('手动测试域名')) ?>';
                    domainSubmit.disabled = false;
                }
            }
            renderDomainOptions();
        });
        resultBox.addEventListener('click', function (event) {
            var button = event.target.closest('.mail-domain-option');
            if (!button) {
                return;
            }
            selectDomain(button.getAttribute('data-domain'));
        });
        hostInput.addEventListener('input', function () {
            hostInput.dataset.auto = '0';
        });
        document.getElementById('mail-domain-create-form').addEventListener('submit', function () {
            hiddenInput.value = normalize(hiddenInput.value || searchInput.value);
        });
    }

    function syncAccountDomainDefaults() {
        if (!accountDomainSelect) {
            return;
        }
        var option = accountDomainSelect.options[accountDomainSelect.selectedIndex];
        var domain = option ? option.getAttribute('data-domain') : '';
        var engine = option ? option.getAttribute('data-engine') : '';
        accountDomainSuffix.textContent = domain ? '@' + domain : '@';
        if (option && option.getAttribute('data-quota')) {
            accountQuota.value = option.getAttribute('data-quota');
        }
        if (accountStatus) {
            accountStatus.value = engine === 'fake' ? 'active' : 'pending';
        }
    }

    if (accountDomainSelect) {
        accountDomainSelect.addEventListener('change', syncAccountDomainDefaults);
        syncAccountDomainDefaults();
    }

    function filterAccountRows() {
        if (!accountFilter) {
            return;
        }
        var domainId = accountFilter.value;
        Array.prototype.forEach.call(document.querySelectorAll('#mail-account-table-body tr[data-domain-id]'), function (row) {
            row.classList.toggle('mail-row-hidden', domainId && row.getAttribute('data-domain-id') !== domainId);
        });
    }

    if (accountFilter) {
        accountFilter.addEventListener('change', filterAccountRows);
        filterAccountRows();
    }
})();
</script>
