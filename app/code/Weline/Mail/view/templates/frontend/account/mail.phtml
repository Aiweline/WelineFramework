<?php
/**
 * Hook: Weline_Mail::frontend::account::index::mail
 *
 * @hook-priority 165
 * @hook-sort-order 11
 * @hook-solo false
 *
 * @var \Weline\Framework\View\Template $this
 */
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Session\SessionFactory;
use Weline\Mail\Model\MailAccount;
use Weline\Mail\Model\MailDomain;
use Weline\Mail\Model\MailMessage;
use Weline\Mail\Service\MailCustomerAccountService;
use Weline\Mail\Service\MailFakeMailboxService;

$escape = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$user = $user ?? $this->getData('user');
if (!is_object($user) || !method_exists($user, 'getId')) {
    try {
        $user = SessionFactory::getInstance()->createFrontendSession()->getUser();
    } catch (\Throwable) {
        $user = null;
    }
}
$customerId = is_object($user) && method_exists($user, 'getId') ? (int)$user->getId() : 0;
/** @var MailCustomerAccountService $mailService */
$mailService = ObjectManager::getInstance(MailCustomerAccountService::class);
/** @var MailFakeMailboxService $mailboxService */
$mailboxService = ObjectManager::getInstance(MailFakeMailboxService::class);
$fakeFlag = (string)($this->request->getGet('mail_fake', '') ?? ($_GET['mail_fake'] ?? ''));
$fakeMode = $fakeFlag === '1';
$enabled = $mailService->isServiceEnabled($fakeMode);
$domains = $mailService->getActiveDomains();
$accounts = $mailService->getAccountsForCustomer($customerId);
$fakeAccounts = $mailboxService->getUsableAccounts($accounts);
$selectedAccount = $fakeAccounts[0] ?? null;
$selectedAccountId = $selectedAccount ? (int)$selectedAccount->getId() : 0;
$inboxMessages = $selectedAccountId > 0 ? $mailboxService->getMessagesForCustomer($customerId, $selectedAccountId, 'inbox') : [];
$sentMessages = $selectedAccountId > 0 ? $mailboxService->getMessagesForCustomer($customerId, $selectedAccountId, 'sent') : [];
$applyUrl = $this->getFrontendUrl('weline_mail/frontend/account/mail/apply');
$suspendUrl = $this->getFrontendUrl('weline_mail/frontend/account/mail/suspend');
$resumeUrl = $this->getFrontendUrl('weline_mail/frontend/account/mail/resume');
$sendUrl = $this->getFrontendUrl('weline_mail/frontend/account/mail/send');
$receiveTestUrl = $this->getFrontendUrl('weline_mail/frontend/account/mail/receive-test');
$statusLabels = [
    'pending' => __('待同步'),
    'active' => __('已启用'),
    'suspended' => __('已暂停'),
];
?>
<div class="weline-mail-account">
    <div class="account-card">
        <header class="account-card__header">
            <h2 class="account-card__title"><?= __('我的邮箱') ?></h2>
        </header>
        <div class="account-card__body">
            <?php if (!$enabled): ?>
                <div class="weline-mail-account__notice">
                    <strong><?= __('邮箱服务尚未开启') ?></strong>
                    <p><?= __('站点管理员需要先完成原生邮件服务安装、端口检测，并开启至少一个邮箱域名后，用户才能申请企业邮箱账号。') ?></p>
                </div>
            <?php elseif ($domains === []): ?>
                <div class="weline-mail-account__notice">
                    <strong><?= __('暂无可申请域名') ?></strong>
                    <p><?= __('当前没有已开启的邮箱域名，请稍后再试。') ?></p>
                </div>
            <?php else: ?>
                <form class="weline-mail-account__form" method="post" action="<?= $escape($applyUrl) ?>">
                    <?php if ($fakeMode): ?>
                        <input type="hidden" name="mail_fake" value="1">
                    <?php endif; ?>
                    <div class="weline-mail-account__form-grid">
                        <div class="account-form__group">
                            <label class="account-form__label" for="mail_local_part"><?= __('邮箱账号') ?></label>
                            <input id="mail_local_part" class="account-form__input" name="local_part" placeholder="name" required pattern="[a-z0-9][a-z0-9._-]{1,62}">
                            <span class="account-form__hint"><?= __('仅支持小写字母、数字、点、下划线和短横线。') ?></span>
                        </div>
                        <div class="account-form__group">
                            <label class="account-form__label" for="mail_domain_id"><?= __('邮箱域名') ?></label>
                            <select id="mail_domain_id" class="account-form__input" name="domain_id" required>
                                <?php foreach ($domains as $domain): ?>
                                    <option value="<?= (int)$domain->getId() ?>">@<?= $escape($domain->getData(MailDomain::schema_fields_DOMAIN_NAME)) ?></option>
                                <?php endforeach; ?>
                            </select>
                        </div>
                        <div class="account-form__group">
                            <label class="account-form__label" for="mail_display_name"><?= __('显示名称') ?></label>
                            <input id="mail_display_name" class="account-form__input" name="display_name" placeholder="<?= $escape(__('例如：业务邮箱')) ?>">
                        </div>
                    </div>
                    <div class="account-form__actions">
                        <button class="account-form__btn account-form__btn--primary" type="submit">
                            <i class="ri-mail-add-line" aria-hidden="true"></i> <?= __('申请邮箱账号') ?>
                        </button>
                    </div>
                </form>
            <?php endif; ?>
        </div>
    </div>

    <div class="account-card">
        <header class="account-card__header">
            <h2 class="account-card__title"><?= __('邮箱账号') ?></h2>
        </header>
        <div class="account-card__body">
            <?php if ($accounts === []): ?>
                <p class="weline-mail-account__empty"><?= __('您还没有申请邮箱账号。') ?></p>
            <?php else: ?>
                <div class="weline-mail-account__list">
                    <?php foreach ($accounts as $account): ?>
                        <?php
                        $accountId = (int)$account->getId();
                        $status = (string)$account->getData(MailAccount::schema_fields_STATUS);
                        ?>
                        <article class="weline-mail-account__item">
                            <div>
                                <strong><?= $escape($account->getData(MailAccount::schema_fields_EMAIL)) ?></strong>
                                <span><?= $escape($account->getData(MailAccount::schema_fields_DISPLAY_NAME)) ?></span>
                            </div>
                            <span class="weline-mail-account__badge"><?= $statusLabels[$status] ?? $escape($status) ?></span>
                            <div class="weline-mail-account__actions">
                                <?php if ($status !== 'suspended'): ?>
                                    <form method="post" action="<?= $escape($suspendUrl) ?>">
                                        <input type="hidden" name="account_id" value="<?= $accountId ?>">
                                        <button type="submit" class="account-form__btn account-form__btn--secondary"><?= __('暂停') ?></button>
                                    </form>
                                <?php else: ?>
                                    <form method="post" action="<?= $escape($resumeUrl) ?>">
                                        <input type="hidden" name="account_id" value="<?= $accountId ?>">
                                        <button type="submit" class="account-form__btn account-form__btn--secondary"><?= __('恢复') ?></button>
                                    </form>
                                <?php endif; ?>
                            </div>
                        </article>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </div>
    </div>

    <?php if ($selectedAccount): ?>
        <?php $selectedEmail = (string)$selectedAccount->getData(MailAccount::schema_fields_EMAIL); ?>
        <div class="account-card">
            <header class="account-card__header">
                <h2 class="account-card__title"><?= __('测试邮箱') ?></h2>
            </header>
            <div class="account-card__body">
                <div class="weline-mail-client">
                    <section class="weline-mail-client__compose">
                        <div class="weline-mail-client__bar">
                            <div>
                                <strong><?= $escape($selectedEmail) ?></strong>
                                <span><?= __('Fake 模式已启用，可进行本地收发信冒烟。') ?></span>
                            </div>
                            <form method="post" action="<?= $escape($receiveTestUrl) ?>">
                                <input type="hidden" name="account_id" value="<?= $selectedAccountId ?>">
                                <button type="submit" class="account-form__btn account-form__btn--secondary"><?= __('收取测试邮件') ?></button>
                            </form>
                        </div>
                        <form class="weline-mail-client__form" method="post" action="<?= $escape($sendUrl) ?>">
                            <input type="hidden" name="account_id" value="<?= $selectedAccountId ?>">
                            <div class="account-form__group">
                                <label class="account-form__label" for="mail_to_email"><?= __('收件人') ?></label>
                                <input id="mail_to_email" class="account-form__input" name="to_email" type="email" value="<?= $escape($selectedEmail) ?>" required>
                            </div>
                            <div class="account-form__group">
                                <label class="account-form__label" for="mail_subject"><?= __('主题') ?></label>
                                <input id="mail_subject" class="account-form__input" name="subject" maxlength="180" required>
                            </div>
                            <div class="account-form__group">
                                <label class="account-form__label" for="mail_body"><?= __('正文') ?></label>
                                <textarea id="mail_body" class="account-form__input weline-mail-client__textarea" name="body" rows="4" required></textarea>
                            </div>
                            <div class="account-form__actions">
                                <button class="account-form__btn account-form__btn--primary" type="submit">
                                    <i class="ri-send-plane-line" aria-hidden="true"></i> <?= __('发送测试邮件') ?>
                                </button>
                            </div>
                        </form>
                    </section>

                    <section class="weline-mail-client__folders">
                        <div class="weline-mail-client__folder">
                            <h3><?= __('收件箱') ?></h3>
                            <?php if ($inboxMessages === []): ?>
                                <p class="weline-mail-account__empty"><?= __('收件箱暂无邮件。') ?></p>
                            <?php else: ?>
                                <div class="weline-mail-message-list">
                                    <?php foreach ($inboxMessages as $message): ?>
                                        <article class="weline-mail-message">
                                            <div class="weline-mail-message__meta">
                                                <strong><?= $escape($message->getData(MailMessage::schema_fields_SUBJECT)) ?></strong>
                                                <span><?= $escape($message->getData(MailMessage::schema_fields_FROM_EMAIL)) ?></span>
                                            </div>
                                            <p><?= nl2br($escape($message->getData(MailMessage::schema_fields_BODY))) ?></p>
                                            <time><?= $escape($message->getData(MailMessage::schema_fields_CREATED_AT)) ?></time>
                                        </article>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                        <div class="weline-mail-client__folder">
                            <h3><?= __('已发送') ?></h3>
                            <?php if ($sentMessages === []): ?>
                                <p class="weline-mail-account__empty"><?= __('暂无已发送邮件。') ?></p>
                            <?php else: ?>
                                <div class="weline-mail-message-list">
                                    <?php foreach ($sentMessages as $message): ?>
                                        <article class="weline-mail-message">
                                            <div class="weline-mail-message__meta">
                                                <strong><?= $escape($message->getData(MailMessage::schema_fields_SUBJECT)) ?></strong>
                                                <span><?= $escape($message->getData(MailMessage::schema_fields_TO_EMAIL)) ?></span>
                                            </div>
                                            <p><?= nl2br($escape($message->getData(MailMessage::schema_fields_BODY))) ?></p>
                                            <time><?= $escape($message->getData(MailMessage::schema_fields_CREATED_AT)) ?></time>
                                        </article>
                                    <?php endforeach; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    <?php endif; ?>
</div>

