<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <event name="Weline_Framework_Url::detect_language">
        <observer name="Weline_I18n::detect_language" instance="Weline\I18n\Observer\DetectLanguage" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Cookie::lang_local">
        <observer name="Weline_I18n::i18n_lang_local" instance="Weline\I18n\Observer\LangLocal" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework::get_words_file">
        <observer name="Weline_I18n::get_words_file" instance="Weline\I18n\Observer\GetWordsFile" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Register::register_installer">
        <observer name="Weline_I18n::register_installer" instance="Weline\I18n\Observer\Register" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::module_upgrade">
        <observer name="Weline_I18n::i18n_locals_upgrade" instance="Weline\I18n\Observer\I18nLocalsUpgrade" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_System::system_update_after">
        <observer name="Weline_I18n::system_update_observer" instance="Weline\I18n\Observer\SystemUpdateObserver" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::module_install_after">
        <observer name="Weline_I18n::module_install_observer" instance="Weline\I18n\Observer\SystemUpdateObserver" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_View::fetch_file">
        <observer name="Weline_I18n::template_fetch_js_words" instance="Weline\I18n\Observer\TemplateFetchFile" disabled="false" shared="true" sort="50"/>
    </event>
    <event name="Weline_Framework_Template::after_compile">
        <observer name="Weline_I18n::template_compile_extract_js_modules" instance="Weline\I18n\Observer\TemplateCompile" disabled="false" shared="true" sort="100"/>
    </event>
    <event name="Weline_I18n::collect_translations">
        <observer name="Weline_I18n::collect_translations" instance="Weline\I18n\Observer\CollectTranslations" disabled="false" shared="true" sort="10"/>
    </event>
    <event name="Weline_Framework_MarketplaceMeta::collect_translations">
        <observer name="Weline_I18n::marketplace_meta_collect_translations" instance="Weline\I18n\Observer\CollectTranslations" disabled="false" shared="true" sort="10"/>
    </event>
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_I18n::setup_upgrade_collect_translations" instance="Weline\I18n\Observer\SetupUpgradeCollectTranslations" disabled="false" shared="true" sort="100"/>
    </event>
</config>
