<?php
/** @var \Weline\Framework\View\Template $this */

$locals = (array)($this->getData('locals') ?? []);
$pagination = $this->getData('pagination') ?: '';
$targetLocal = $this->getData('target_local');

$readValue = static function ($item, string $key, mixed $default = null): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value === null ? $default : $value;
        }
        return $item->{$key} ?? $default;
    }

    return $default;
};

$installedCount = 0;
$activeCount = 0;
foreach ($locals as $local) {
    $installedCount += (int)$readValue($local, 'is_install', 0) === 1 ? 1 : 0;
    $activeCount += (int)$readValue($local, 'is_active', 0) === 1 ? 1 : 0;
}
