<script>
function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.country-checkbox');
    
    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAll.checked;
    });
}

function batchAction(action) {
    const checkboxes = document.querySelectorAll('.country-checkbox:checked');
    const countryCodes = Array.from(checkboxes).map(cb => cb.value);
    
    if (countryCodes.length === 0) {
        alert('请选择要操作的区域');
        return;
    }
    
    if (!confirm(`确定要${action === 'activate' ? '激活' : '停用'} ${countryCodes.length} 个区域吗？`)) {
        return;
    }
    
    // 创建表单并提交
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/i18n/backend/localization/batchAction';
    
    const actionInput = document.createElement('input');
    actionInput.type = 'hidden';
    actionInput.name = 'action';
    actionInput.value = action;
    form.appendChild(actionInput);
    
    countryCodes.forEach(code => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'country_codes[]';
        input.value = code;
        form.appendChild(input);
    });
    
    document.body.appendChild(form);
    form.submit();
}

$(document).ready(function() {
    // 初始化工具提示
    $('[data-toggle="tooltip"]').tooltip();
    
    // 初始化世界地图
    initWorldMap();
    
    // 初始化未启用提醒列表
    initWarningsList();
});

function initWorldMap() {
    // 获取国家地图数据（只包含已安装和已激活的区域）
    const countryMapData = <?= json_encode($countryMapData ?? []) ?>;
    
    // 创建颜色映射对象（按国家码分组）
    const colorMapping = {};
    const countryLocales = {};
    
    countryMapData.forEach(locale => {
        const countryCode = locale.code ? locale.code.toUpperCase() : '';
        
        if (countryCode) {
            // 记录每个国家的区域
            if (!countryLocales[countryCode]) {
                countryLocales[countryCode] = [];
            }
            countryLocales[countryCode].push(locale);
            
            // 确定国家的整体状态（优先级：已激活 > 已安装 > 未安装）
            let currentColor = colorMapping[countryCode];
            let newColor = '#6c757d'; // 默认灰色 - 未安装
            
            if (locale.is_install && locale.is_active) {
                newColor = '#198754'; // 绿色 - 已激活
            } else if (locale.is_install) {
                newColor = '#fd7e14'; // 橙色 - 已安装
            }
            
            // 设置颜色优先级：绿色 > 橙色 > 灰色
            if (!currentColor || 
                (newColor === '#198754') || 
                (newColor === '#fd7e14' && currentColor === '#6c757d')) {
                colorMapping[countryCode] = newColor;
            }
        }
    });
    
    // 初始化 jVectorMap
    $('#world-map-markers').vectorMap({
        map: 'world_mill_en',
        normalizeFunction: 'polynomial',
        hoverOpacity: 0.7,
        hoverColor: false,
        // 禁用缩放和平移
        zoomButtons: false,
        zoomOnScroll: false,
        panOnDrag: false,
        backgroundColor: 'transparent',
        regionStyle: {
            initial: {
                fill: '#d4dadd', // 默认颜色
                stroke: '#ffffff',
                'stroke-width': 0.5
            },
            hover: {
                'fill-opacity': 0.8,
                stroke: '#ffffff',
                'stroke-width': 1
            }
        },
        onRegionClick: function(event, code) {
            // 显示国家的区域信息
            const countryLocalesList = countryLocales[code.toUpperCase()] || [];
            if (countryLocalesList.length > 0) {
                let message = `国家: ${code}\n区域列表:\n`;
                countryLocalesList.forEach(locale => {
                    let status = '未安装';
                    if (locale.is_install && locale.is_active) {
                        status = '已激活';
                    } else if (locale.is_install) {
                        status = '已安装';
                    }
                    message += `- ${locale.code} (${locale.display_name || locale.code}): ${status}\n`;
                });
                // 可以在这里添加更优雅的提示方式，比如模态框
            }
        },
        onRegionTipShow: function(event, tip, code) {
            const countryLocalesList = countryLocales[code.toUpperCase()] || [];
            if (countryLocalesList.length > 0) {
                let activeCount = 0;
                let installedCount = 0;
                let totalCount = countryLocalesList.length;
                
                countryLocalesList.forEach(locale => {
                    if (locale.is_install && locale.is_active) {
                        activeCount++;
                    } else if (locale.is_install) {
                        installedCount++;
                    }
                });
                
                let statusText = '未安装';
                let statusColor = '#6c757d';
                
                if (activeCount > 0) {
                    statusText = `已激活 ${activeCount} 个区域`;
                    statusColor = '#198754';
                } else if (installedCount > 0) {
                    statusText = `已安装 ${installedCount} 个区域`;
                    statusColor = '#fd7e14';
                }
                
                tip.html(`
                    <div style="text-align: left;">
                        <strong>${code}</strong><br>
                        总区域数: ${totalCount}<br>
                        状态: <span style="color: ${statusColor}; font-weight: bold;">${statusText}</span>
                    </div>
                `);
            } else {
                tip.html(`
                    <div style="text-align: left;">
                        <strong>${code}</strong><br>
                        状态: <span style="color: #6c757d; font-weight: bold;">无区域数据</span>
                    </div>
                `);
            }
        }
    });
    
    // 地图初始化完成后设置颜色
    setTimeout(function() {
        const mapObject = $('#world-map-markers').vectorMap('get', 'mapObject');
        if (mapObject) {
            // 设置每个区域的颜色
            Object.keys(colorMapping).forEach(function(code) {
                const color = colorMapping[code];
                try {
                    mapObject.regions[code].element.setStyle('fill', color);
                } catch(e) {
                    // 静默处理颜色设置失败的情况
                }
            });
        }
    }, 100);
}

// 初始化未启用提醒列表
function initWarningsList() {
    const locales = <?= json_encode($locales ?? []) ?>;
    const unactivatedRegions = <?= json_encode($unactivatedRegions ?? []) ?>;
    const warningList = document.getElementById('warning-list');
    const warningCount = document.getElementById('warning-count');
    const regionsCount = document.getElementById('regions-count');
    const noWarnings = document.getElementById('no-warnings');
    
    // 更新区域列表数量
    regionsCount.textContent = locales.length;
    
    // 更新警告数量（使用专门的未启用区域数据）
    warningCount.textContent = unactivatedRegions.length;
    
    if (unactivatedRegions.length === 0) {
        // 没有警告，显示成功消息
        warningList.style.display = 'none';
        noWarnings.style.display = 'block';
    } else {
        // 有警告，显示列表
        warningList.style.display = 'table-row-group';
        noWarnings.style.display = 'none';
        
        // 清空现有内容
        warningList.innerHTML = '';
        
        // 添加警告行（显示未启用区域的国家）
        unactivatedRegions.forEach(country => {
            const row = document.createElement('tr');
            row.className = 'table-warning';
            row.innerHTML = `
                <td class="text-center">
                    <i class="ri-error-warning-line text-warning fs-5"></i>
                </td>
                <td class="text-center">
                    <div style="width: 24px; height: 18px; display: inline-block;">
                        ${country.flag || ''}
                    </div>
                </td>
                <td>
                    <span class="badge bg-danger bg-opacity-10 text-danger fw-medium px-2 py-1 rounded-pill">
                        ${country.code}
                    </span>
                </td>
                <td>
                    <span class="badge bg-info bg-opacity-10 fw-medium px-2 py-1 rounded-pill">
                        ${country.code}
                    </span>
                </td>
                 <td>
                     <div class="fw-medium" style="color: var(--text-color, #212529);">
                         ${country.display_name || country.code}
                     </div>
                 </td>
                <td>
                    <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1 rounded-pill">
                        <i class="ri-alert-line me-1"></i>已安装未启用任何区域
                    </span>
                </td>
                <td class="text-center">
                    <a href="@backend-url('*/backend/countries')?filter=installed&country_code=${country.code}" 
                       class="btn btn-primary btn-sm rounded-pill px-3"
                       title="管理该国家的区域">
                        <i class="ri-settings-3-line me-1"></i>管理区域
                    </a>
                </td>
            `;
            warningList.appendChild(row);
        });
    }
}

</script>

