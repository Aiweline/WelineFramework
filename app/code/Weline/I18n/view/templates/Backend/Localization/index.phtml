<script>
(function () {
    function showConfirm(message, type) {
        if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
            return BackendConfirm.show(message, {type: type || 'info'});
        }
        if (typeof Swal !== 'undefined' && Swal.fire) {
            return Swal.fire({
                text: message,
                icon: type === 'danger' ? 'warning' : (type || 'info'),
                showCancelButton: true,
                confirmButtonText: '<?= addslashes(__('确定')) ?>',
                cancelButtonText: '<?= addslashes(__('取消')) ?>'
            }).then(function (result) {
                return !!result.isConfirmed;
            });
        }
        return Promise.resolve(true);
    }

    function showWarning(message) {
        if (typeof BackendToast !== 'undefined' && BackendToast.warning) {
            BackendToast.warning(message);
            return;
        }
        if (typeof Swal !== 'undefined' && Swal.fire) {
            Swal.fire({text: message, icon: 'warning'});
            return;
        }
        console.warn(message);
    }

    function fillBatchForm(form, action, codes) {
        form.querySelectorAll('input[name="locale_codes[]"]').forEach(function (input) {
            input.remove();
        });

        var actionInput = form.querySelector('input[name="action"]');
        if (!actionInput) {
            actionInput = document.createElement('input');
            actionInput.type = 'hidden';
            actionInput.name = 'action';
            form.appendChild(actionInput);
        }
        actionInput.value = action;

        codes.forEach(function (code) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'locale_codes[]';
            input.value = code;
            form.appendChild(input);
        });
    }

    function collectSelectedLocales() {
        return Array.from(document.querySelectorAll('.locale-checkbox:checked'))
            .map(function (checkbox) {
                return checkbox.value;
            })
            .filter(Boolean);
    }

    window.submitUtilityForm = function (formId, message, type) {
        var form = document.getElementById(formId);
        if (!form) {
            return;
        }
        showConfirm(message, type).then(function (confirmed) {
            if (!confirmed) {
                return;
            }
            form.submit();
        });
    };

    window.submitLocaleBatch = function (formId, action, message, type) {
        var codes = collectSelectedLocales();
        if (!codes.length) {
            showWarning('<?= addslashes(__('请选择操作和区域')) ?>');
            return;
        }

        var form = document.getElementById(formId);
        if (!form) {
            return;
        }

        showConfirm(message, type).then(function (confirmed) {
            if (!confirmed) {
                return;
            }
            fillBatchForm(form, action, codes);
            form.submit();
        });
    };

    var selectAll = document.getElementById('locale-select-all');
    if (selectAll) {
        selectAll.addEventListener('change', function () {
            document.querySelectorAll('.locale-checkbox').forEach(function (checkbox) {
                checkbox.checked = selectAll.checked;
            });
        });
    }

    document.addEventListener('submit', function (event) {
        var form = event.target;
        if (!(form instanceof HTMLFormElement)) {
            return;
        }
        if (form.dataset.confirmed === '1') {
            form.dataset.confirmed = '0';
            return;
        }

        var message = form.getAttribute('data-confirm-message');
        if (!message) {
            return;
        }

        event.preventDefault();
        showConfirm(message, form.getAttribute('data-confirm-type')).then(function (confirmed) {
            if (!confirmed) {
                return;
            }
            form.dataset.confirmed = '1';
            form.submit();
        });
    }, true);
})();
</script>
