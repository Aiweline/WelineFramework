/** @var \Weline\Framework\View\Template $this */

$translations = (array)($this->getData('translations') ?? []);
$availableLocales = (array)($this->getData('available_locales') ?? []);
$progress = (array)($this->getData('progress_stats') ?? []);
$pagination = $this->getData('pagination') ?: '';
$localeCode = (string)($this->getData('locale_code') ?? '');
$search = (string)($this->getData('search') ?? '');
$targetLocale = (array)($this->getData('target_locale') ?? []);

$currentLocale = $availableLocales[$localeCode] ?? [
    'code' => $localeCode,
    'name' => $targetLocale['name'] ?? $localeCode,
    'display' => ($targetLocale['name'] ?? $localeCode) . ($localeCode !== '' ? ' (' . $localeCode . ')' : ''),
];

$translatedCount = (int)($progress['translated'] ?? 0);
$totalCount = (int)($progress['total'] ?? 0);
$untranslatedCount = (int)($progress['untranslated'] ?? max(0, $totalCount - $translatedCount));
$progressPercent = (float)($progress['progress_percent'] ?? 0);

$readValue = static function ($item, string $key, mixed $default = null): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value === null ? $default : $value;
        }
        return $item->{$key} ?? $default;
    }

    return $default;
};
