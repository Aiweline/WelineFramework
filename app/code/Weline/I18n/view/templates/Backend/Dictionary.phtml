// 保存当前翻译
function saveCurrentTranslation() {
    if (quickTranslationData.length === 0 || currentRecordIndex < 0) return;
    
    const record = quickTranslationData[currentRecordIndex];
    const newTranslation = document.getElementById('quick-translate-input').value.trim();
    
    // 如果翻译没有变化，不需要保存
    if (newTranslation === (record.translate || '')) return;
    
    const saveStatus = document.getElementById('save-status');
    const saveError = document.getElementById('save-error');
    
    // 隐藏状态
    saveStatus.style.display = 'none';
    saveError.style.display = 'none';
    
    fetch('@backend-url("*/backend/dictionary/postQuickSave")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `md5=${record.md5 || ''}&translate=${encodeURIComponent(newTranslation)}&word=${encodeURIComponent(record.word)}&locale_code=${encodeURIComponent(record.locale_code)}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 更新本地数据
            record.translate = newTranslation;
            
            // 显示保存成功
            saveStatus.style.display = 'inline';
            setTimeout(() => {
                saveStatus.style.display = 'none';
            }, 2000);
            
            // 更新进度
            if (data.progress) {
                updateQuickProgress(data.progress);
                updateMainPageProgress(data.progress);
            }
            
            // 更新主页面对应行的显示
            updateMainTableRow(record.md5, newTranslation);
            
            // 重要：更新上下文记录列表以显示打勾标记
            updateContextRecordsList();
            
            // 可选：添加保存成功的视觉反馈动画
            showSaveSuccessAnimation(currentRecordIndex);
            
            // 检查是否完成当前页面的翻译
            checkAndAutoNextPage();
            
        } else {
            saveError.style.display = 'inline';
            setTimeout(() => {
                saveError.style.display = 'none';
            }, 3000);
        }
    })
    .catch(error => {
        console.error('保存失败:', error);
        saveError.style.display = 'inline';
        setTimeout(() => {
            saveError.style.display = 'none';
        }, 3000);
    });
}

// 更新快速翻译弹窗的进度
function updateQuickProgress(progress) {
    const progressBar = document.getElementById('quick-progress-bar');
    const progressText = document.getElementById('quick-progress-text');
    
    progressBar.style.width = progress.progress_percent + '%';
    progressText.textContent = `翻译进度: ${progress.translated}/${progress.total} (${progress.progress_percent}%)`;
}

// 更新主页面的进度
function updateMainPageProgress(progress) {
    const mainProgressBar = document.getElementById('progress-bar');
    const mainProgressPercent = document.getElementById('progress-percent');
    const translatedCount = document.getElementById('translated-count');
    const untranslatedCount = document.getElementById('untranslated-count');
    const totalCount = document.getElementById('total-count');
    
    if (mainProgressBar) {
        mainProgressBar.style.width = progress.progress_percent + '%';
    }
    if (mainProgressPercent) {
        mainProgressPercent.textContent = progress.progress_percent + '%';
    }
    if (translatedCount) {
        translatedCount.textContent = progress.translated;
    }
    if (untranslatedCount) {
        untranslatedCount.textContent = progress.untranslated;
    }
    if (totalCount) {
        totalCount.textContent = progress.total;
    }
}

