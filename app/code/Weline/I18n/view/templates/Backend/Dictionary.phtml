// 显示保存成功的动画效果
function showSaveSuccessAnimation(recordIndex) {
    const listContainer = document.getElementById('context-records-list');
    const recordElements = listContainer.querySelectorAll('.list-group-item');
    
    if (recordElements[recordIndex]) {
        const element = recordElements[recordIndex];
        
        // 添加成功动画效果
        element.style.transition = 'all 0.3s ease';
        element.style.transform = 'scale(1.02)';
        element.style.boxShadow = '0 4px 12px rgba(40, 167, 69, 0.3)';
        element.style.borderLeft = '4px solid #28a745';
        
        // 500ms后恢复原状
        setTimeout(() => {
            element.style.transform = 'scale(1)';
            element.style.boxShadow = '';
            element.style.borderLeft = '';
        }, 500);
        
        // 让打勾图标闪烁一下
        const checkIcon = element.querySelector('.ri-check-line');
        if (checkIcon) {
