<script>
(function () {
    var localeCode = <?= json_encode($localeCode, JSON_UNESCAPED_UNICODE) ?>;
    var endpoints = {
        collectWords: "@backend-url('*/backend/dictionary/collectWords')",
        currentTranslationMode: "@backend-url('*/backend/dictionary/currentTranslationMode')",
        checkAutoRegister: "@backend-url('*/backend/dictionary/checkAutoRegister')",
        enableAutoRegister: "@backend-url('*/backend/dictionary/enableAutoRegister')",
        disableAutoRegister: "@backend-url('*/backend/dictionary/disableAutoRegister')",
        setTranslationMode: "@backend-url('*/backend/dictionary/setTranslationMode')"
    };

    function updateProgress(progress) {
        if (!progress) {
            return;
        }

        var translated = Number(progress.translated || 0);
        var total = Number(progress.total || 0);
        var untranslated = Number(progress.untranslated || Math.max(0, total - translated));
        var percent = Number(progress.progress_percent || 0);

        document.getElementById('dictionary-total-count').textContent = String(total);
        document.getElementById('dictionary-translated-count').textContent = String(translated);
        document.getElementById('dictionary-untranslated-count').textContent = String(untranslated);
        document.getElementById('dictionary-progress-translated').textContent = String(translated);
        document.getElementById('dictionary-progress-percent').textContent = String(percent).replace(/\.0$/, '') + '%';
        document.getElementById('dictionary-progress-bar').style.width = Math.max(0, Math.min(100, percent)) + '%';
    }

    function updateModeState(data) {
        if (!data) {
            return;
        }

        var modeName = data.mode_name || data.mode || '<?= addslashes(__('未知')) ?>';
        document.getElementById('dictionary-mode-label').textContent = modeName;
        document.getElementById('dictionary-mode-chip').textContent = modeName;
        document.getElementById('dictionary-auto-register-label').textContent = data.auto_register ? '<?= addslashes(__('激活')) ?>' : '<?= addslashes(__('停用')) ?>';
        document.getElementById('dictionary-auto-register-toggle').textContent = data.auto_register ? '<?= addslashes(__('停用')) ?>' : '<?= addslashes(__('自动词汇注册')) ?>';
        document.getElementById('dictionary-auto-register-toggle').dataset.enabled = data.auto_register ? '1' : '0';
    }

    function postJson(url, payload) {
        return fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: new URLSearchParams(payload)
        }).then(function (response) {
            return response.json();
        });
    }

    function loadModeState() {
        fetch(endpoints.currentTranslationMode, {
            headers: {'X-Requested-With': 'XMLHttpRequest'},
            credentials: 'same-origin'
        }).then(function (response) {
            return response.json();
        }).then(function (data) {
            updateModeState(data);
        }).catch(function () {
            I18nAdminUI.toast('warning', '<?= addslashes(__('加载失败')) ?>');
        });
    }

    document.querySelectorAll('.dictionary-edit-trigger').forEach(function (button) {
        button.addEventListener('click', function () {
            document.getElementById('dictionary-edit-md5').value = button.dataset.md5 || '';
            document.getElementById('dictionary-edit-word').value = button.dataset.word || '';
            document.getElementById('dictionary-edit-translate').value = button.dataset.translate === button.dataset.word ? '' : (button.dataset.translate || '');
            document.getElementById('dictionary-edit-locale-label').value = button.dataset.localeCode || '';
        });
    });

    var collectButton = document.getElementById('dictionary-collect-btn');
    if (collectButton) {
        collectButton.addEventListener('click', function () {
            I18nAdminUI.confirm('<?= addslashes(__('收集词典')) ?>', 'info').then(function (confirmed) {
                if (!confirmed) {
                    return;
                }

                collectButton.disabled = true;
                postJson(endpoints.collectWords, {}).then(function (result) {
                    if (result.success) {
                        I18nAdminUI.toast('success', result.message || '<?= addslashes(__('收集完成')) ?>');
                        window.setTimeout(function () {
                            window.location.reload();
                        }, 600);
                        return;
                    }

                    I18nAdminUI.toast('error', result.message || '<?= addslashes(__('保存失败')) ?>');
                }).catch(function (error) {
                    I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
                }).finally(function () {
                    collectButton.disabled = false;
                });
            });
        });
    }

    document.querySelectorAll('[data-mode-switch]').forEach(function (button) {
        button.addEventListener('click', function () {
            var mode = button.getAttribute('data-mode-switch');
            I18nAdminUI.confirm('<?= addslashes(__('翻译模式')) ?>: ' + mode, 'info').then(function (confirmed) {
                if (!confirmed) {
                    return;
                }

                postJson(endpoints.setTranslationMode, {mode: mode}).then(function (result) {
                    if (!result.success) {
                        I18nAdminUI.toast('error', result.message || '<?= addslashes(__('保存失败')) ?>');
                        return;
                    }

                    I18nAdminUI.toast('success', result.message || '<?= addslashes(__('保存成功')) ?>');
                    loadModeState();
                }).catch(function (error) {
                    I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
                });
            });
        });
    });

    var autoRegisterButton = document.getElementById('dictionary-auto-register-toggle');
    if (autoRegisterButton) {
        autoRegisterButton.addEventListener('click', function () {
            var enabled = autoRegisterButton.dataset.enabled === '1';
            var url = enabled ? endpoints.disableAutoRegister : endpoints.enableAutoRegister;

            I18nAdminUI.confirm(enabled ? '<?= addslashes(__('停用')) ?>' : '<?= addslashes(__('自动词汇注册')) ?>', enabled ? 'warning' : 'success').then(function (confirmed) {
                if (!confirmed) {
                    return;
                }

                postJson(url, {}).then(function (result) {
                    if (!result.success) {
                        I18nAdminUI.toast('error', result.message || '<?= addslashes(__('保存失败')) ?>');
                        return;
                    }

                    I18nAdminUI.toast('success', result.message || '<?= addslashes(__('保存成功')) ?>');
                    return fetch(endpoints.checkAutoRegister, {
                        headers: {'X-Requested-With': 'XMLHttpRequest'},
                        credentials: 'same-origin'
                    }).then(function (response) {
                        return response.json();
                    }).then(function (statusResult) {
                        updateModeState({
                            mode: document.getElementById('dictionary-mode-chip').textContent,
                            mode_name: document.getElementById('dictionary-mode-chip').textContent,
                            auto_register: !!statusResult.enabled
                        });
                    });
                }).catch(function (error) {
                    I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
                });
            });
        });
    }

    document.querySelectorAll('#dictionary-import-modal form').forEach(function (form) {
        form.addEventListener('submit', function (event) {
            event.preventDefault();

            var formData = new FormData(form);
            fetch(form.action, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: {'X-Requested-With': 'XMLHttpRequest'}
            }).then(function (response) {
                return response.json();
            }).then(function (result) {
                if (!result.success) {
                    I18nAdminUI.toast('error', result.message || '<?= addslashes(__('导入失败!')) ?>');
                    return;
                }

                I18nAdminUI.toast('success', result.message || '<?= addslashes(__('导入完成!')) ?>');
                window.setTimeout(function () {
                    window.location.href = "@backend-url('*/backend/dictionary')?locale_code=" + encodeURIComponent(localeCode);
                }, 600);
            }).catch(function (error) {
                I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
            });
        });
    });

    loadModeState();
    updateProgress(<?= json_encode($progress, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>);
})();
</script>
