<!-- 导入CSV模态框 -->
<div class="modal fade" id="importCsvModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="ri-file-upload-line me-2"></i>
                    <lang>导入CSV文件</lang>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="ri-information-line me-2"></i>
                    <strong><lang>导入要求：</lang></strong>
                    <ul class="mb-0 mt-2">
                        <li><lang>文件名必须是有效的locale_code（如：zh_Hans_CN.csv、en_US.csv）</lang></li>
                        <li><lang>CSV格式：word,translate,locale_code,update_time</lang></li>
                        <li><lang>支持UTF-8编码，建议使用Excel或记事本保存为CSV格式</lang></li>
                    </ul>
                </div>
                
                <form id="importCsvForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="csvFile" class="form-label">
                            <i class="ri-file-line me-2"></i>
                            <lang>选择CSV文件</lang>
                        </label>
                        <input type="file" class="form-control" id="csvFile" name="csv_file" accept=".csv" required>
                        <div class="form-text">
                            <lang>支持.csv格式，文件名必须是locale_code</lang>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="overwriteExisting" name="overwrite_existing">
                            <label class="form-check-label" for="overwriteExisting">
                                <lang>覆盖已存在的翻译</lang>
                            </label>
                        </div>
                    </div>
                </form>
                
                <div id="importProgress" class="mt-3" style="display: none;">
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                    </div>
                    <div class="text-center mt-2">
                        <small class="text-muted" id="importProgressText">正在导入...</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <lang>取消</lang>
                </button>
                <button type="button" class="btn btn-primary" onclick="importCsv()" id="importBtn">
                    <i class="ri-upload-line me-2"></i>
                    <lang>开始导入</lang>
                </button>
            </div>
        </div>
    </div>
</div>

@template(Weline_Admin::common/footer.phtml)
