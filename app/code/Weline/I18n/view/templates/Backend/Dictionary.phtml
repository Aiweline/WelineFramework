// 格式化下拉选项显示
function formatLocaleOption(option) {
    if (!option.id) {
        return option.text;
    }
    
    var $option = $(
        '<span><strong>' + option.text.split(' (')[0] + '</strong> <small class="text-muted">(' + option.id + ')</small></span>'
    );
    return $option;
}

// 格式化选中选项显示
function formatLocaleSelection(option) {
    if (!option.id) {
        return option.text;
    }
    
    return option.text.split(' (')[0] + ' (' + option.id + ')';
}

// 翻译模式相关函数
let currentTranslationMode = 'cache';

// 设置翻译模式
function setTranslationMode(mode) {
    // 阻止默认行为
    event.preventDefault();
    event.stopPropagation();
    
    const modal = new bootstrap.Modal(document.getElementById('translationModeModal'));
    modal.show();
    
    // 更新当前模式显示
    updateCurrentModeDisplay();
}

// 确认设置翻译模式
async function confirmSetTranslationMode(mode) {
    try {
        // 调用后端API设置翻译模式
        const response = await fetch('@backend-url("*/backend/dictionary/setTranslationMode")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                mode: mode
            })
        });
        
        if (!response.ok) {
            throw new Error('请求失败');
        }
        
        const result = await response.json();
        
        if (result.success) {
            currentTranslationMode = mode;
            updateCurrentModeDisplay();
            
            const modal = bootstrap.Modal.getInstance(document.getElementById('translationModeModal'));
            modal.hide();
            
            showCustomAlert(result.message, 'success');
        } else {
            throw new Error(result.message || '设置失败');
        }
        
    } catch (error) {
        console.error('设置翻译模式失败:', error);
        showCustomAlert('设置翻译模式失败: ' + error.message, 'error');
    }
}

// 更新当前模式显示
function updateCurrentModeDisplay() {
    // 更新模态框中的显示
    const displayElement = document.getElementById('currentModeDisplay');
    if (displayElement) {
        displayElement.textContent = currentTranslationMode === 'online' ? '在线翻译模式' : '缓存模式';
    }
    
    // 更新按钮上的徽章
    const badgeElement = document.getElementById('currentModeBadge');
    if (badgeElement) {
        badgeElement.textContent = currentTranslationMode === 'online' ? '在线模式' : '缓存模式';
        badgeElement.className = currentTranslationMode === 'online' ? 'badge bg-success ms-2' : 'badge bg-primary ms-2';
    }
    
    // 更新页面顶部的翻译模式状态
    const statusElement = document.getElementById('translationModeStatus');
    if (statusElement) {
        if (currentTranslationMode === 'online') {
            statusElement.innerHTML = '<i class="ri-wifi-line me-1"></i>在线翻译模式';
            statusElement.className = 'badge bg-success px-2 py-1 rounded-pill';
        } else {
            statusElement.innerHTML = '<i class="ri-database-2-line me-1"></i>缓存模式';
            statusElement.className = 'badge bg-primary px-2 py-1 rounded-pill';
        }
    }
    
    // 更新下拉菜单中的当前模式指示器
    const onlineIndicator = document.getElementById('onlineModeIndicator');
    const cacheIndicator = document.getElementById('cacheModeIndicator');
    
    if (onlineIndicator && cacheIndicator) {
        if (currentTranslationMode === 'online') {
            onlineIndicator.style.display = 'inline';
            cacheIndicator.style.display = 'none';
        } else {
            onlineIndicator.style.display = 'none';
            cacheIndicator.style.display = 'inline';
        }
    }
}

// 获取当前翻译模式
async function getCurrentTranslationMode() {
    try {
        const response = await fetch('@backend-url("*/backend/dictionary/currentTranslationMode")', {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (response.ok) {
            const result = await response.json();
            currentTranslationMode = result.mode || 'cache';
            updateCurrentModeDisplay();
        }
    } catch (error) {
        console.error('获取翻译模式失败:', error);
        currentTranslationMode = 'cache';
        updateCurrentModeDisplay();
    }
}

// 收集真实翻译词汇
function collectRealWords() {
    const modal = new bootstrap.Modal(document.getElementById('collectProgressModal'));
    modal.show();
    
    // 重置进度
    updateCollectProgress(0, '正在收集真实翻译词汇...', '正在扫描框架文件...');
    
    // 开始收集
    startWordCollection();
}

// 开始词汇收集
async function startWordCollection() {
    try {
        // 第一步：调用收集命令
        updateCollectProgress(20, '正在收集真实翻译词汇...', '正在扫描框架文件...');
        
        const response = await fetch('@backend-url("*/backend/dictionary/collectWords")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                locale_code: currentLocaleCode || 'zh_CN'
            })
        });
        
        if (!response.ok) {
            throw new Error('收集请求失败');
        }
        
        const result = await response.json();
        
        if (result.success) {
            updateCollectProgress(100, '收集完成！', `成功收集了 ${result.count || 0} 个翻译词汇`);
            
            // 2秒后关闭模态框并刷新页面
            setTimeout(() => {
                const modal = bootstrap.Modal.getInstance(document.getElementById('collectProgressModal'));
                modal.hide();
                location.reload();
            }, 2000);
        } else {
            throw new Error(result.message || '收集失败');
        }
        
    } catch (error) {
        console.error('收集翻译词汇失败:', error);
        updateCollectProgress(0, '收集失败', error.message);
        
        // 3秒后关闭模态框
        setTimeout(() => {
            const modal = bootstrap.Modal.getInstance(document.getElementById('collectProgressModal'));
            modal.hide();
        }, 3000);
    }
}

// 更新收集进度
function updateCollectProgress(percent, text, detail) {
    const progressBar = document.getElementById('collectProgressBar');
    const progressText = document.getElementById('collectProgressText');
    const progressDetail = document.getElementById('collectProgressDetail');
    
    if (progressBar) {
        progressBar.style.width = percent + '%';
        progressBar.textContent = Math.round(percent) + '%';
        
        if (percent === 100) {
            progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
            progressBar.classList.add('bg-success');
        }
    }
    
    if (progressText) {
        progressText.textContent = text;
    }
    
    if (progressDetail) {
        progressDetail.textContent = detail;
    }
}

// 自动词汇注册相关函数
let autoRegisterEnabled = false;

// 切换自动词汇注册
async function toggleAutoRegister() {
    // 阻止默认行为
    event.preventDefault();
    event.stopPropagation();
    
    try {
        const action = autoRegisterEnabled ? 'disableAutoRegister' : 'enableAutoRegister';
        const response = await fetch(`@backend-url("*/backend/dictionary/")`+action, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (!response.ok) {
            throw new Error('请求失败');
        }
        
        const result = await response.json();
        
        if (result.success) {
            autoRegisterEnabled = !autoRegisterEnabled;
            updateAutoRegisterStatus();
            showCustomAlert(result.message, 'success');
        } else {
            throw new Error(result.message || '操作失败');
        }
        
    } catch (error) {
        console.error('切换自动词汇注册失败:', error);
        showCustomAlert('切换自动词汇注册失败: ' + error.message, 'error');
    }
}

// 更新自动注册状态显示
function updateAutoRegisterStatus() {
    const statusElement = document.getElementById('autoRegisterStatus');
    if (statusElement) {
        if (autoRegisterEnabled) {
            statusElement.textContent = '已启用';
            statusElement.className = 'badge bg-success ms-2';
            statusElement.style.display = 'inline-block';
        } else {
            statusElement.textContent = '已禁用';
            statusElement.className = 'badge bg-secondary ms-2';
            statusElement.style.display = 'inline-block';
        }
    }
    
    // 同时更新按钮的显示状态
    const toggleButton = document.querySelector('[onclick="toggleAutoRegister()"]');
    if (toggleButton) {
        const icon = toggleButton.querySelector('i');
        if (icon) {
            if (autoRegisterEnabled) {
                icon.className = 'ri-magic-line me-2 text-success';
            } else {
                icon.className = 'ri-magic-line me-2 text-warning';
            }
        }
    }
}

// 检查自动注册状态
async function checkAutoRegisterStatus() {
    try {
        const response = await fetch('@backend-url("*/backend/dictionary/checkAutoRegister")', {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (response.ok) {
            const result = await response.json();
            autoRegisterEnabled = result.enabled || false;
            updateAutoRegisterStatus();
        }
    } catch (error) {
        console.error('检查自动注册状态失败:', error);
    }
}

// 页面加载时初始化翻译模式显示
document.addEventListener('DOMContentLoaded', function() {
    getCurrentTranslationMode();
    checkAutoRegisterStatus();
});
</script>

