<script src='@static(Weline_Admin::/libs/jquery.mCustomScrollbar/jquery.mCustomScrollbar.concat.min.js)'></script>
<!-- Responsive Table js -->
<script src='@static(Weline_Admin::assets/libs/admin-resources/rwd-table/rwd-table.min.js)'></script>

<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<!-- Init js -->
<script src='@static(Weline_Admin::assets/js/pages/table-responsive.init.js)'></script>

<script>
// 快速翻译相关变量
let quickTranslationData = [];
let currentRecordIndex = 0;
let currentPage = 1;
let totalPages = 1;
let currentLocaleCode = '{{locale_code}}';
let currentSearch = '{{search}}'; // 当前搜索条件
let isLoading = false;

// 编辑翻译功能
function editTranslation(md5, currentTranslate) {
    document.getElementById('edit_md5').value = md5;
    document.getElementById('edit_translate').value = currentTranslate;
    var editModal = new bootstrap.Modal(document.getElementById('editTranslationModal'));
    editModal.show();
}

// 打开快速翻译弹窗
function openQuickTranslation() {
    const modal = new bootstrap.Modal(document.getElementById('quickTranslationModal'));
    modal.show();
    updateTranslationDirection();
    loadQuickTranslationData();
}

// 双击表格行打开快速翻译
function openQuickTranslationWithRecord(row) {
    const md5 = row.getAttribute('data-md5');
    const modal = new bootstrap.Modal(document.getElementById('quickTranslationModal'));
    modal.show();
    updateTranslationDirection();
    
    // 加载数据时传递目标MD5，后端会自动定位并返回上下文
    loadQuickTranslationDataWithTarget(md5);
}

// 加载快速翻译数据
function loadQuickTranslationData(page = 1) {
    if (isLoading) return;
    
    isLoading = true;
    const url = '@backend-url("*/backend/dictionary/getQuickTranslationData")';
    
    // 构建请求参数，包含搜索条件
    const params = new URLSearchParams({
        locale_code: currentLocaleCode,
        search: currentSearch,
        page: page,
        page_size: 50
    });
    
    console.log('请求URL:', `${url}?${params.toString()}`);
    
    fetch(`${url}?${params.toString()}`)
        .then(response => {
            console.log('响应状态:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('响应数据:', data);
            if (data.success) {
                quickTranslationData = data.data;
                currentPage = data.pagination.current_page;
                totalPages = data.pagination.total_pages;
                
                // 更新进度信息
                updateQuickProgress(data.progress);
                
                // 显示第一条记录
                currentRecordIndex = 0;
                displayCurrentRecord();
                
                // 更新翻页按钮状态
                updatePageNavigationButtons();
            } else {
                console.error('加载数据失败:', data.message);
                alert('加载数据失败: ' + data.message);
            }
        })
        .catch(error => {
            console.error('请求失败:', error);
            alert('请求失败，请检查网络连接: ' + error.message);
        })
        .finally(() => {
            isLoading = false;
        });
}

// 加载快速翻译数据并定位到目标记录
function loadQuickTranslationDataWithTarget(targetMd5) {
    if (isLoading) return;
    
    isLoading = true;
    const url = '@backend-url("*/backend/dictionary/getQuickTranslationData")';
    
    // 构建请求参数，包含搜索条件和目标MD5
    const params = new URLSearchParams({
        locale_code: currentLocaleCode,
        search: currentSearch,
        target_md5: targetMd5,
        page_size: 5 // 显示5条记录的上下文
    });
    
    console.log('目标定位请求URL:', `${url}?${params.toString()}`);
    
    fetch(`${url}?${params.toString()}`)
        .then(response => {
            console.log('目标定位响应状态:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('目标定位响应数据:', data);
            if (data.success) {
                quickTranslationData = data.data;
                currentPage = data.pagination.current_page;
                totalPages = data.pagination.total_pages;
                
                // 更新进度信息
                updateQuickProgress(data.progress);
                
                // 如果返回了目标索引，直接定位到目标记录
                if (data.target_index >= 0) {
                    currentRecordIndex = data.target_index;
                } else {
                    // 如果没有找到目标记录，选择第一条
                    currentRecordIndex = 0;
                }
                
                displayCurrentRecord();
                
                // 更新翻页按钮状态
                updatePageNavigationButtons();
            } else {
                console.error('加载数据失败:', data.message);
                alert('加载数据失败: ' + data.message);
            }
        })
        .catch(error => {
            console.error('请求失败:', error);
            alert('请求失败，请检查网络连接: ' + error.message);
        })
        .finally(() => {
            isLoading = false;
        });
}

// 显示当前记录
function displayCurrentRecord() {
    if (quickTranslationData.length === 0) {
        document.getElementById('quick-source-text').textContent = '暂无数据';
        document.getElementById('quick-translate-input').value = '';
        document.getElementById('current-record-info').textContent = '0/0';
        document.getElementById('context-records-list').innerHTML = '<div class="text-muted p-3">暂无数据</div>';
        return;
    }
    
    const record = quickTranslationData[currentRecordIndex];
    document.getElementById('quick-source-text').textContent = record.word;
    document.getElementById('quick-translate-input').value = record.translate || '';
    
    // 更新记录信息
    document.getElementById('current-record-info').textContent = 
        `${currentRecordIndex + 1}/${quickTranslationData.length}`;
    
    // 更新上下文记录列表
    updateContextRecordsList();
    
    // 更新导航按钮状态
    document.getElementById('prev-record-btn').disabled = (currentRecordIndex === 0 && currentPage === 1);
    document.getElementById('next-record-btn').disabled = (currentRecordIndex === quickTranslationData.length - 1 && currentPage === totalPages);
    
    // 聚焦到翻译输入框
    setTimeout(() => {
        document.getElementById('quick-translate-input').focus();
    }, 100);
}

// 更新上下文记录列表
function updateContextRecordsList() {
    const listContainer = document.getElementById('context-records-list');
    let html = '';
    
    quickTranslationData.forEach((record, index) => {
        const isActive = index === currentRecordIndex;
        const isTranslated = record.is_translated || (record.translate && record.translate !== record.word);
        
        const statusClass = isTranslated ? 'translated' : 'untranslated';
        
        html += `
            <a href="javascript:void(0)" 
               class="list-group-item list-group-item-action ${statusClass} ${isActive ? 'active' : ''}"
               onclick="switchToRecord(${index})"
               style="cursor: pointer;">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="flex-grow-1">
                        <div class="fw-medium ${isActive ? 'text-white' : 'text-dark'}" style="font-size: 14px;">
                            ${record.word}
                        </div>
                        <div class="small ${isActive ? 'text-white-50' : 'text-muted'}" style="font-size: 12px;">
                            ${record.translate || '未翻译'}
                        </div>
                    </div>
                    <div class="flex-shrink-0">
                        ${isTranslated ? 
                            '<i class="ri-check-line text-success fs-5"></i>' : 
                            '<i class="ri-error-warning-line text-warning fs-5"></i>'
                        }
                    </div>
                </div>
            </a>
        `;
    });
    
    listContainer.innerHTML = html;
}

// 切换到指定记录
function switchToRecord(index) {
    if (index >= 0 && index < quickTranslationData.length) {
        // 保存当前翻译
        saveCurrentTranslation();
        
        // 切换到新记录
        currentRecordIndex = index;
        displayCurrentRecord();
    }
}

// 导航到上一条/下一条记录
function navigateRecord(direction) {
    // 先保存当前翻译
    saveCurrentTranslation();
    
    if (direction === 1) { // 下一条
        if (currentRecordIndex < quickTranslationData.length - 1) {
            currentRecordIndex++;
            displayCurrentRecord();
        } else if (currentPage < totalPages) {
            // 加载下一页
            loadQuickTranslationData(currentPage + 1);
        }
    } else if (direction === -1) { // 上一条
        if (currentRecordIndex > 0) {
            currentRecordIndex--;
            displayCurrentRecord();
        } else if (currentPage > 1) {
            // 加载上一页
            currentPage--;
            loadQuickTranslationData(currentPage);
            // 加载完成后定位到最后一条记录
            setTimeout(() => {
                currentRecordIndex = quickTranslationData.length - 1;
                displayCurrentRecord();
            }, 500);
        }
    }
}

// 翻页导航
function navigatePage(direction) {
    // 先保存当前翻译
    saveCurrentTranslation();
    
    if (direction === 1 && currentPage < totalPages) {
        // 下一页
        loadQuickTranslationData(currentPage + 1);
    } else if (direction === -1 && currentPage > 1) {
        // 上一页
        loadQuickTranslationData(currentPage - 1);
    }
}

// 更新翻页按钮状态
function updatePageNavigationButtons() {
    const prevPageBtn = document.getElementById('prev-page-btn');
    const nextPageBtn = document.getElementById('next-page-btn');
    const currentPageDisplay = document.getElementById('current-page-display');
    const totalPagesDisplay = document.getElementById('total-pages-display');
    
    if (prevPageBtn) {
        prevPageBtn.disabled = currentPage <= 1;
        prevPageBtn.classList.toggle('disabled', currentPage <= 1);
    }
    
    if (nextPageBtn) {
        nextPageBtn.disabled = currentPage >= totalPages;
        nextPageBtn.classList.toggle('disabled', currentPage >= totalPages);
    }
    
    if (currentPageDisplay) {
        currentPageDisplay.textContent = currentPage;
    }
    
    if (totalPagesDisplay) {
        totalPagesDisplay.textContent = totalPages;
    }
}

// 检查并自动翻页
function checkAndAutoNextPage() {
    // 检查当前页面是否全部翻译完成
    const allTranslated = quickTranslationData.every(record => 
        record.translate && record.translate.trim() !== '' && record.translate !== record.word
    );
    
    if (allTranslated && quickTranslationData.length > 0) {
        // 当前页面全部翻译完成，检查是否有下一页
        if (currentPage < totalPages) {
            // 有下一页，自动翻页
            setTimeout(() => {
                loadQuickTranslationData(currentPage + 1);
                showPageCompleteMessage();
            }, 1500); // 延迟1.5秒让用户看到完成状态
        } else {
            // 没有下一页，显示完成消息并刷新主页面
            showAllCompleteMessage();
            setTimeout(() => {
                // 刷新主页面以显示最新数据
                window.location.reload();
            }, 2000);
        }
    }
}

// 显示页面完成消息
function showPageCompleteMessage() {
    const modal = bootstrap.Modal.getInstance(document.getElementById('quickTranslationModal'));
    if (modal) {
        // 显示页面完成提示
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-success alert-dismissible fade show position-fixed';
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        alertDiv.innerHTML = `
            <i class="ri-check-line me-2"></i>
            <strong>当前页面翻译完成！</strong> 正在加载下一页...
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        
        // 3秒后自动移除
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 3000);
    }
}

// 导出CSV文件
function exportCsv() {
    const localeCode = document.getElementById('locale-select').value;
    
    if (!localeCode) {
        alert('请先选择要导出的语言');
        return;
    }
    
    // 创建下载链接
    const url = `@backend-url("*/backend/dictionary/exportCsv")?locale_code=${encodeURIComponent(localeCode)}`;
    
    // 创建临时链接并点击
    const link = document.createElement('a');
    link.href = url;
    link.download = `${localeCode}.csv`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

// 显示导入模态框
function showImportModal() {
    const modal = new bootstrap.Modal(document.getElementById('importCsvModal'));
    modal.show();
}

// 导入CSV文件
function importCsv() {
    const fileInput = document.getElementById('csvFile');
    const file = fileInput.files[0];
    
    if (!file) {
        alert('请选择要导入的CSV文件');
        return;
    }
    
    // 验证文件扩展名
    if (!file.name.toLowerCase().endsWith('.csv')) {
        alert('请选择CSV格式的文件');
        return;
    }
    
    // 验证文件名是否为locale_code
    const fileName = file.name.replace('.csv', '');
    if (!isValidLocaleCode(fileName)) {
        alert('文件名必须是有效的locale_code，如：zh_Hans_CN、en_US等');
        return;
    }
    
    // 显示进度条
    const progressDiv = document.getElementById('importProgress');
    const progressBar = progressDiv.querySelector('.progress-bar');
    const progressText = document.getElementById('importProgressText');
    const importBtn = document.getElementById('importBtn');
    
    progressDiv.style.display = 'block';
    importBtn.disabled = true;
    progressBar.style.width = '0%';
    progressText.textContent = '正在上传文件...';
    
    // 创建FormData
    const formData = new FormData();
    formData.append('csv_file', file);
    
    // 发送请求
    fetch('@backend-url("*/backend/dictionary/importCsv")', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        progressBar.style.width = '100%';
        
        if (data.success) {
            progressText.textContent = `导入成功！新增 ${data.data.new_count} 条，更新 ${data.data.update_count} 条`;
            progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
            progressBar.classList.add('bg-success');
            
            // 3秒后关闭模态框并刷新页面
            setTimeout(() => {
                bootstrap.Modal.getInstance(document.getElementById('importCsvModal')).hide();
                window.location.reload();
            }, 3000);
        } else {
            progressText.textContent = `导入失败：${data.message}`;
            progressBar.classList.add('bg-danger');
            importBtn.disabled = false;
        }
    })
    .catch(error => {
        console.error('导入失败:', error);
        progressText.textContent = `导入失败：${error.message}`;
        progressBar.classList.add('bg-danger');
        importBtn.disabled = false;
    });
}

// 验证locale_code是否有效（前端验证）
function isValidLocaleCode(localeCode) {
    // 基本的locale_code格式验证
    const localePattern = /^[a-z]{2}(_[A-Z]{2})?(_[A-Z]{2})?$/;
    return localePattern.test(localeCode);
}

