<script>
(function () {
    var endpoints = {
        translate: "@backend-url('*/backend/countries/locale/words/translate')",
        restore: "@backend-url('*/backend/countries/locale/words/restore')",
        push: "@backend-url('*/backend/countries/locale/words/push')?country_code=<?= urlencode($countryCode) ?>&code=<?= urlencode($localeCode) ?>",
        enable: "@backend-url('*/backend/countries/locale/words/enable')?country_code=<?= urlencode($countryCode) ?>&code=<?= urlencode($localeCode) ?>",
        disable: "@backend-url('*/backend/countries/locale/words/disable')?country_code=<?= urlencode($countryCode) ?>&code=<?= urlencode($localeCode) ?>"
    };

    var modalElement = document.getElementById('locale-word-edit-modal');
    var modal = typeof bootstrap !== 'undefined' && bootstrap.Modal ? new bootstrap.Modal(modalElement) : null;
    var currentRow = null;

    function postForm(url, payload) {
        return fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: new URLSearchParams(payload)
        }).then(function (response) {
            return response.json();
        });
    }

    function updateRowTranslation(row, translation) {
        if (!row) {
            return;
        }

        row.dataset.translate = translation;
        var cell = row.querySelector('.locale-word-translation-cell');
        if (!cell) {
            return;
        }

        var source = row.dataset.word || '';
        if (translation && translation !== source) {
            cell.innerHTML = '<span class="text-success fw-medium"></span>';
            cell.querySelector('span').textContent = translation;
        } else {
            cell.innerHTML = '<span class="text-muted fst-italic"><?= addslashes(__('暂无翻译数据')) ?></span>';
        }
    }

    document.querySelectorAll('.locale-word-row').forEach(function (row) {
        row.addEventListener('dblclick', function () {
            row.querySelector('.locale-word-edit-btn').click();
        });
    });

    document.querySelectorAll('.locale-word-edit-btn').forEach(function (button) {
        button.addEventListener('click', function () {
            currentRow = button.closest('.locale-word-row');
            if (!currentRow) {
                return;
            }

            document.getElementById('locale-word-md5').value = currentRow.dataset.md5 || '';
            document.getElementById('locale-word-source').value = currentRow.dataset.word || '';
            document.getElementById('locale-word-source').readOnly = true;
            document.getElementById('locale-word-translate').value = (currentRow.dataset.translate || '') === (currentRow.dataset.word || '') ? '' : (currentRow.dataset.translate || '');

            if (modal) {
                modal.show();
            }
        });
    });

    document.querySelectorAll('.locale-word-restore-btn').forEach(function (button) {
        button.addEventListener('click', function () {
            var row = button.closest('.locale-word-row');
            if (!row) {
                return;
            }

            I18nAdminUI.confirm('<?= addslashes(__('确定恢复该词典么？')) ?>', 'warning').then(function (confirmed) {
                if (!confirmed) {
                    return;
                }

                postForm(endpoints.restore, {
                    md5: row.dataset.md5 || '',
                    code: "<?= addslashes($localeCode) ?>",
                    country_code: "<?= addslashes($countryCode) ?>"
                }).then(function (result) {
                    if (!result.success) {
                        I18nAdminUI.toast('error', result.msg || result.message || '<?= addslashes(__('保存失败')) ?>');
                        return;
                    }

                    updateRowTranslation(row, row.dataset.word || '');
                    I18nAdminUI.toast('success', result.msg || result.message || '<?= addslashes(__('恢复成功！')) ?>');
                }).catch(function (error) {
                    I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
                });
            });
        });
    });

    document.getElementById('locale-word-edit-form').addEventListener('submit', function (event) {
        event.preventDefault();

        var payload = {
            md5: document.getElementById('locale-word-md5').value,
            word: document.getElementById('locale-word-source').value,
            translate: document.getElementById('locale-word-translate').value,
            code: "<?= addslashes($localeCode) ?>",
            country_code: "<?= addslashes($countryCode) ?>"
        };

        postForm(endpoints.translate, payload).then(function (result) {
            if (!result.success) {
                I18nAdminUI.toast('error', result.msg || result.message || '<?= addslashes(__('保存失败')) ?>');
                return;
            }

            if (currentRow) {
                updateRowTranslation(currentRow, payload.translate);
            } else {
                window.location.reload();
                return;
            }
            I18nAdminUI.toast('success', result.msg || result.message || '<?= addslashes(__('成功保存！')) ?>');
            if (modal) {
                modal.hide();
            }
        }).catch(function (error) {
            I18nAdminUI.toast('error', '<?= addslashes(__('请求错误！')) ?>' + ': ' + error.message);
        });
    });

    document.getElementById('locale-word-add-btn').addEventListener('click', function () {
        currentRow = null;
        document.getElementById('locale-word-md5').value = '';
        document.getElementById('locale-word-source').value = '';
        document.getElementById('locale-word-source').readOnly = false;
        document.getElementById('locale-word-translate').value = '';
        if (modal) {
            modal.show();
        }
    });

    document.getElementById('locale-word-publish-btn').addEventListener('click', function () {
        I18nAdminUI.confirm('<?= addslashes(__('发布')) ?>', 'success').then(function (confirmed) {
            if (!confirmed) {
                return;
            }

            window.location.href = endpoints.push;
        });
    });

    document.querySelectorAll('[data-mode-switch]').forEach(function (button) {
        button.addEventListener('click', function () {
            var mode = button.getAttribute('data-mode-switch');
            I18nAdminUI.confirm(mode === 'online' ? '<?= addslashes(__('实时')) ?>' : '<?= addslashes(__('缓存')) ?>', mode === 'online' ? 'success' : 'info').then(function (confirmed) {
                if (!confirmed) {
                    return;
                }

                window.location.href = mode === 'online' ? endpoints.enable : endpoints.disable;
            });
        });
    });
})();
</script>
