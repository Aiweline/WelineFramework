$readValue = static function ($item, string $key, mixed $default = null): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value === null ? $default : $value;
        }
        return $item->{$key} ?? $default;
    }

    return $default;
};

$preserve = ['filter' => $currentFilter];
if ($search !== '') {
    $preserve['search'] = $search;
}

$renderHiddenFields = static function (array $fields): string {
    $html = '';
    foreach ($fields as $name => $value) {
        if ($value === '' || $value === null) {
            continue;
        }
        $html .= '<input type="hidden" name="' . htmlspecialchars((string)$name, ENT_QUOTES, 'UTF-8') . '" value="' .
            htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8') . '">' . PHP_EOL;
    }

    return $html;
};

