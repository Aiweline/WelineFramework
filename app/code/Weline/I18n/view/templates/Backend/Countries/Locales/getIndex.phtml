<script>
(function () {
    function showConfirm(message, type) {
        if (typeof BackendConfirm !== 'undefined' && BackendConfirm.show) {
            return BackendConfirm.show(message, {type: type || 'info'});
        }
        if (typeof Swal !== 'undefined' && Swal.fire) {
            return Swal.fire({
                text: message,
                icon: type === 'danger' ? 'warning' : (type || 'info'),
                showCancelButton: true,
                confirmButtonText: '<?= addslashes(__('确定')) ?>',
                cancelButtonText: '<?= addslashes(__('取消')) ?>'
            }).then(function (result) {
                return !!result.isConfirmed;
            });
        }
        return Promise.resolve(true);
    }

    document.addEventListener('submit', function (event) {
        var form = event.target;
        if (!(form instanceof HTMLFormElement)) {
            return;
        }
        if (form.dataset.confirmed === '1') {
            form.dataset.confirmed = '0';
            return;
        }

        var message = form.getAttribute('data-confirm-message');
        if (!message) {
            return;
        }

        event.preventDefault();
        showConfirm(message, form.getAttribute('data-confirm-type')).then(function (confirmed) {
            if (!confirmed) {
                return;
            }
            form.dataset.confirmed = '1';
            form.submit();
        });
    }, true);
})();
