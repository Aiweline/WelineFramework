<style>
.weline-choice-switcher {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 40px;
    max-width: 100%;
    min-width: 0;
    padding: 0.45rem 0.55rem;
    border: 1px solid transparent;
    border-radius: 2px;
    color: inherit;
    cursor: pointer;
}
.weline-choice-switcher:hover {
    border-color: currentColor;
}
.weline-choice-switcher .action-line-1 {
    font-size: 0.72rem;
    line-height: 1;
    opacity: 0.86;
}
.weline-choice-switcher .action-line-2 {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
    max-width: 100%;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.25;
    overflow: hidden;
}
.weline-choice-switcher .current-language {
    max-width: 7rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.weline-choice-switcher .current-currency {
    max-width: 4.5rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.weline-choice-switcher .current-currency-symbol {
    font-weight: 600;
    opacity: 0.86;
}
.weline-choice-switcher .weline-choice-panel {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 1000;
    min-width: 320px;
    max-width: min(420px, calc(100vw - 16px));
    margin-top: 0.25rem;
    padding: 0.5rem;
    border: 1px solid #d5d9d9;
    border-radius: 4px;
    background: #fff;
    color: #111;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.16);
    cursor: default;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
}
.weline-choice-switcher.weline-choice-open .weline-choice-panel,
.weline-choice-switcher:hover .weline-choice-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}
.weline-choice-search {
    padding: 0.25rem 0.25rem 0.5rem;
}
.weline-choice-search input {
    width: 100%;
    min-height: 36px;
    padding: 0.45rem 0.65rem;
    border: 1px solid #d5d9d9;
    border-radius: 4px;
    color: #111;
    background: #fff;
    font-size: 0.875rem;
    outline: none;
}
.weline-choice-search input:focus {
    border-color: #ff9900;
    box-shadow: 0 0 0 2px rgba(255, 153, 0, 0.2);
}
.weline-choice-items {
    max-height: min(360px, 58vh);
    overflow-y: auto;
}
.language-option.weline-choice-option,
.currency-option.weline-choice-option {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.65rem;
    padding: 0.65rem 0.75rem;
}
.language-option.weline-choice-option .fa-check,
.currency-option.weline-choice-option .fa-check {
    flex: 0 0 auto;
    display: none;
    color: #ff9900;
}
.language-option.weline-choice-option.active .fa-check,
.currency-option.weline-choice-option.active .fa-check {
    display: inline-block;
}
.weline-choice-flag,
.weline-choice-current-flag,
.weline-choice-symbol {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.weline-choice-current-flag svg,
.weline-choice-flag svg {
    display: block;
    width: 24px;
    height: 18px;
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
}
.weline-choice-current-flag svg {
    width: 18px;
    height: 14px;
}
.weline-choice-flag-fallback,
.weline-choice-symbol {
    min-width: 30px;
    height: 22px;
    padding: 0 0.35rem;
    border-radius: 3px;
    background: #f3f3f3;
    color: #111;
    font-size: 0.72rem;
    font-weight: 700;
}
.weline-choice-text {
    min-width: 0;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
}
.weline-choice-name {
    color: #111;
    font-size: 0.9rem;
    line-height: 1.2;
}
.weline-choice-meta {
    color: #565959;
    font-size: 0.75rem;
    line-height: 1.2;
}
.weline-choice-native {
    flex: 0 0 auto;
    margin-left: auto;
    padding: 0.2rem 0.55rem;
    border: 1px solid #d5d9d9;
    border-radius: 4px;
    color: #111;
    font-size: 0.78rem;
    line-height: 1.2;
    white-space: nowrap;
}
.weline-choice-empty {
    padding: 0.7rem 0.75rem;
    color: #565959;
    font-size: 0.85rem;
}
.weline-choice-more {
    width: 100%;
    margin-top: 0.35rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid #d5d9d9;
    border-radius: 4px;
    background: #fff;
    color: #111;
    font-size: 0.85rem;
    cursor: pointer;
}
.weline-choice-more:hover {
    background: #f7fafa;
}
.weline-choice-option[hidden],
.weline-choice-empty[hidden],
.weline-choice-more[hidden] {
    display: none !important;
}
</style>
<script>
(function () {
    if (!window.WelineHeaderChoiceSelector) {
        window.WelineHeaderChoiceSelector = (function () {
            function normalize(value) {
                return String(value || '').trim().toLocaleLowerCase();
            }

            function init(root) {
                if (!root || root.dataset.welineChoiceReady === '1') {
                    return;
                }
                root.dataset.welineChoiceReady = '1';

                var panel = root.querySelector('[data-weline-choice-panel]');
                var input = root.querySelector('[data-choice-search]');
                var more = root.querySelector('[data-choice-more]');
                var empty = root.querySelector('[data-choice-empty]');
                var pageSize = parseInt(root.getAttribute('data-choice-page-size') || '50', 10);
                if (!pageSize || pageSize < 1) {
                    pageSize = 50;
                }

                var visibleLimit = pageSize;

                function getOptions() {
                    return Array.prototype.slice.call(root.querySelectorAll('[data-choice-option]'));
                }

                function render(resetLimit) {
                    if (resetLimit) {
                        visibleLimit = pageSize;
                    }

                    var query = normalize(input ? input.value : '');
                    var options = getOptions();
                    var matched = 0;
                    var shown = 0;

                    options.forEach(function (option) {
                        var searchText = normalize((option.getAttribute('data-search') || '') + ' ' + option.textContent);
                        var matches = query === '' || searchText.indexOf(query) !== -1;
                        if (!matches) {
                            option.hidden = true;
                            return;
                        }

                        matched++;
                        if (shown < visibleLimit) {
                            option.hidden = false;
                            shown++;
                            return;
                        }

                        option.hidden = true;
                    });

                    if (empty) {
                        empty.hidden = matched !== 0;
                    }
                    if (more) {
                        more.hidden = matched <= shown;
                    }
                }

                function openPanel() {
                    root.classList.add('weline-choice-open');
                    root.setAttribute('aria-expanded', 'true');
                }

                function closePanel() {
                    root.classList.remove('weline-choice-open');
                    root.setAttribute('aria-expanded', 'false');
                }

                root.addEventListener('click', function (event) {
                    if (panel && panel.contains(event.target)) {
                        return;
                    }
                    openPanel();
                    if (input) {
                        setTimeout(function () {
                            input.focus();
                        }, 0);
                    }
                });

                if (panel) {
                    panel.addEventListener('click', function (event) {
                        if (!event.target.closest('[data-choice-option]')) {
                            event.stopPropagation();
                        }
                    });
                }
                if (input) {
                    input.addEventListener('input', function () {
                        render(true);
                    });
                    input.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            closePanel();
                            root.focus();
                        }
                    });
                }
                if (more) {
                    more.addEventListener('click', function (event) {
                        event.preventDefault();
                        event.stopPropagation();
                        visibleLimit += pageSize;
                        render(false);
                    });
                }
                root.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openPanel();
                        if (input) {
                            setTimeout(function () {
                                input.focus();
                            }, 0);
                        }
                    }
                    if (event.key === 'Escape') {
                        closePanel();
                    }
                });
                document.addEventListener('click', function (event) {
                    if (!root.contains(event.target)) {
                        closePanel();
                    }
                });

                render(true);
            }

            function initAll() {
                document.querySelectorAll('[data-weline-choice-switcher]').forEach(init);
            }

            return {
                initAll: initAll
            };
        })();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', window.WelineHeaderChoiceSelector.initAll, { once: true });
    } else {
        window.WelineHeaderChoiceSelector.initAll();
    }
})();
</script>
