<!--实时翻译收集 START-->
<if condition="(env.translate_mode ?? '') === 'online'">
    <script>
        let success_word = __('成功推送收集词汇！推送消息：%{msg}')
        let error_word = __('推送收集词汇失败！推送消息：%{1}')
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.resource === 'function') {
            Promise.resolve(window.Weline.Api.resource('i18n')).then(function (I18nApi) {
                return I18nApi.collect({
                    words: window.site && window.site.i18n ? window.site.i18n : {},
                    module: window.site && window.site.module ? window.site.module : 'Weline_I18n'
                }, {
                    silent: true
                }).then(function (res) {
                    console.log(__(success_word, res || {}))
                });
            }).catch(function (err) {
                console.log(__(error_word, err && err.message ? err.message : JSON.stringify(err || {})))
            });
        } else {
            console.warn('[WelineI18n] Weline.Api is not ready; skip online translation collect.');
        }
    </script>
</if>
<!--实时翻译收集 END-->
