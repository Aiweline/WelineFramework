<?php
/**
 * 
 * @hook-priority 50   Hook优先级：50（默认值）
 * @hook-sort-order 0  Hook排序顺序：0（默认值）
 * @hook-solo false    Hook独享：false（不独占）
 */

use Weline\Framework\App\State;
use Weline\Framework\Event\EventsManager;
use Weline\Framework\Manager\ObjectManager;
use Weline\I18n\Model\I18n;
use Weline\I18n\Service\ActiveLocaleCodeProvider;

/** @var \Weline\Framework\View\Template $this */

// 获取当前语言
$currentLang = State::getLang();
$currentLangLocal = State::getLangLocal();

// 获取 I18n 模型
/** @var I18n $i18n */
$i18n = ObjectManager::getInstance(I18n::class);
$selectorPageSize = 50;
$activeLocaleCodes = [];
$escape = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$normalizeSearchText = static function (array $tokens): string {
    $normalized = [];
    foreach ($tokens as $token) {
        $token = trim(strip_tags((string)$token));
        if ($token === '') {
            continue;
        }
        $key = function_exists('mb_strtolower') ? mb_strtolower($token, 'UTF-8') : strtolower($token);
        $normalized[$key] = $token;
    }

    return implode(' ', array_values($normalized));
};
$shortLocaleCode = static function (string $localeCode): string {
    $parts = explode('_', $localeCode);
    $langDisplay = strtoupper(substr((string)($parts[0] ?? 'ZH'), 0, 2));
    if ($langDisplay === 'ZH' && isset($parts[1]) && strtoupper((string)$parts[1]) === 'HANT') {
        return 'TW';
    }

    return $langDisplay !== '' ? $langDisplay : 'ZH';
};
$sanitizeInlineFlagMarkup = static function (string $markup): string {
    if ($markup === '') {
        return '';
    }

    return (string)preg_replace('/<\\?xml[^?]*\\?>/i', '', $markup);
};
$getLanguageFlag = static function (string $localeCode) use ($i18n, $sanitizeInlineFlagMarkup): string {
    try {
        $flag = (string)($i18n->getCountryFlagWithLocal($localeCode, 24, 18)['flag'] ?? '');
        return $sanitizeInlineFlagMarkup($flag);
    } catch (\Throwable) {
        return '';
    }
};

// 获取可用语言列表
// 使用 try-catch 避免数据库错误影响页面渲染
try {
    // 后台语言来源：Locals 表里「已安装+已激活」的语言集合（与网站 id 无关）
    /** @var ActiveLocaleCodeProvider $activeLocaleCodeProvider */
    $activeLocaleCodeProvider = ObjectManager::getInstance(ActiveLocaleCodeProvider::class);
    $activeLocaleCodes = $activeLocaleCodeProvider->getInstalledActiveCodes();
    $allowedLocaleMap = $activeLocaleCodeProvider->getInstalledActiveCodeMap();
    
    // 获取语言本地化名称
    $langLocals = $i18n->getLocals($currentLangLocal);
    
    // 构建语言数据（仅已安装且已激活）
    $i18nLanguages = [];
    foreach ($langLocals as $localeCode => $localeName) {
        if (!empty($allowedLocaleMap) && !isset($allowedLocaleMap[(string)$localeCode]) && !isset($allowedLocaleMap[strtolower((string)$localeCode)])) {
            continue;
        }
        
        try {
            $selfName = (string)$i18n->getLocaleLanguageSelfName((string)$localeCode);
        } catch (\Throwable) {
            $selfName = '';
        }

        $i18nLanguages[] = [
            'code' => $localeCode,
            'name' => $localeName,
            'native' => $selfName !== '' ? $selfName : $localeName,
            'flag' => $getLanguageFlag((string)$localeCode),
        ];
    }
} catch (\Throwable $e) {
    // 如果获取失败，使用默认列表
    $i18nLanguages = [];
}

// 如果没有可用语言，使用默认列表
if (empty($i18nLanguages)) {
    $i18nLanguages = [
        ['code' => 'zh_Hans_CN', 'name' => '简体中文', 'native' => '简体中文', 'flag' => $getLanguageFlag('zh_Hans_CN')],
        ['code' => 'en_US', 'name' => 'English', 'native' => 'English', 'flag' => $getLanguageFlag('en_US')],
        ['code' => 'zh_Hant_TW', 'name' => '繁體中文', 'native' => '繁體中文', 'flag' => $getLanguageFlag('zh_Hant_TW')],
    ];
}

// 准备 event 数据
$eventData = [
    'currentLang' => $currentLang,
    'currentLangLocal' => $currentLangLocal,
    'languages' => $i18nLanguages, // I18n 模块的数据
    'template' => $this,
    'request' => $this->request,
];

// 触发 event: Weline_I18n::header-language-switcher-data
/** @var EventsManager $eventsManager */
$eventsManager = ObjectManager::getInstance(EventsManager::class);
$eventsManager->dispatch('Weline_I18n::header-language-switcher-data', $eventData);

// 获取 event 对象（如果 event 被监听，数据可能已被修改）
$event = $eventsManager->getEventData('Weline_I18n::header-language-switcher-data');

// 检查 event 是否被监听并修改了数据
// Event 对象通过 getData() 方法获取数据，如果 event 被监听并修改，数据会更新
if ($event) {
    $eventDataResult = $event->getData('data');
    if (is_array($eventDataResult)) {
        $eventLanguages = $eventDataResult['languages'] ?? null;
        $eventCurrentLang = $eventDataResult['currentLang'] ?? null;
    } else {
        $eventLanguages = null;
        $eventCurrentLang = null;
    }
} else {
    $eventLanguages = null;
    $eventCurrentLang = null;
}

// 如果 event 返回了数据，使用 event 的数据，否则使用 I18n 的数据
$languages = $eventLanguages ?? $i18nLanguages;
$displayCurrentLang = $eventCurrentLang ?? $currentLang;
$websiteDisplayLocale = $currentLangLocal !== '' ? $currentLangLocal : $displayCurrentLang;

$aliasDisplayLocales = [];
$addAliasDisplayLocale = static function (string $localeCode) use (&$aliasDisplayLocales): void {
    $localeCode = trim($localeCode);
    if ($localeCode === '') {
        return;
    }
    $aliasDisplayLocales[strtolower($localeCode)] = $localeCode;
};

foreach ([$currentLangLocal, $displayCurrentLang, 'zh_Hans_CN', 'en_US', 'es_ES', 'fr_FR', 'de_DE', 'ja_JP', 'ko_KR', 'pt_BR'] as $displayLocale) {
    $addAliasDisplayLocale((string)$displayLocale);
}

foreach ($activeLocaleCodes as $displayLocale) {
    if (count($aliasDisplayLocales) >= 20) {
        break;
    }
    $addAliasDisplayLocale((string)$displayLocale);
}

$localeNameMaps = [];
foreach ($aliasDisplayLocales as $displayLocale) {
    try {
        $localeNameMaps[$displayLocale] = $i18n->getLocals($displayLocale);
    } catch (\Throwable) {
        $localeNameMaps[$displayLocale] = [];
    }
}

$normalizedLanguages = [];
$seenLanguageCodes = [];
foreach ($languages as $lang) {
    if (!is_array($lang)) {
        continue;
    }

    $langCode = trim((string)($lang['code'] ?? ''));
    if ($langCode === '') {
        continue;
    }

    $langKey = strtolower($langCode);
    if (isset($seenLanguageCodes[$langKey])) {
        continue;
    }
    $seenLanguageCodes[$langKey] = true;

    $aliases = [];
    foreach ($localeNameMaps as $localeNames) {
        if (isset($localeNames[$langCode])) {
            $aliases[] = (string)$localeNames[$langCode];
        }
    }

    try {
        $aliases[] = $i18n->getLocaleLanguageSelfName($langCode);
    } catch (\Throwable) {
    }

    $firstAlias = reset($aliases);
    $langName = '';
    try {
        $langName = trim((string)$i18n->getLocaleName($langCode, $websiteDisplayLocale));
    } catch (\Throwable) {
        $langName = '';
    }
    if ($langName === '') {
        $langName = trim((string)($lang['name'] ?? ''));
    }
    if ($langName === '') {
        $langName = trim((string)($firstAlias ?: $langCode));
    }

    $langNative = '';
    try {
        $langNative = trim((string)$i18n->getLocaleLanguageSelfName($langCode));
    } catch (\Throwable) {
    }
    if ($langNative === '') {
        $langNative = trim((string)($lang['native'] ?? ''));
    }
    if ($langNative === '') {
        $langNative = $langName;
    }
    $flag = $sanitizeInlineFlagMarkup((string)($lang['flag'] ?? ''));
    if ($flag === '') {
        $flag = $getLanguageFlag($langCode);
    }

    $normalizedLanguages[] = [
        'code' => $langCode,
        'name' => $langName,
        'native' => $langNative,
        'flag' => $flag,
        'short' => $shortLocaleCode($langCode),
        'search' => $normalizeSearchText(array_merge([$langCode, $langName, $langNative], $aliases)),
    ];
}

$currentLanguages = [];
$otherLanguages = [];
foreach ($normalizedLanguages as $language) {
    if ((string)$language['code'] === (string)$displayCurrentLang) {
        $currentLanguages[] = $language;
        continue;
    }
    $otherLanguages[] = $language;
}

$languages = array_merge($currentLanguages, $otherLanguages);
$currentLanguageFlag = '';
$currentLanguageShort = $shortLocaleCode((string)$displayCurrentLang);
$currentLanguageName = '';
$currentLanguageNative = '';
foreach ($languages as $lang) {
    if ((string)$lang['code'] === (string)$displayCurrentLang) {
        $currentLanguageFlag = (string)($lang['flag'] ?? '');
        $currentLanguageShort = (string)($lang['short'] ?? $currentLanguageShort);
        $currentLanguageName = trim((string)($lang['name'] ?? ''));
        $currentLanguageNative = trim((string)($lang['native'] ?? $currentLanguageName));
        break;
    }
}
$currentLanguageLabel = $currentLanguageName !== ''
    ? $currentLanguageName
    : ($currentLanguageNative !== '' ? $currentLanguageNative : $currentLanguageShort);

// 渲染语言切换器
// 注意：URL 链接由前端 i18n.js 模块动态生成（通过 updateLanguageSwitcherLinks()）
// 使用 data-i18n-switcher 属性标记，供 JavaScript 识别和初始化
?>
<div class="language-switcher weline-choice-switcher" data-i18n-switcher="true" data-weline-choice-switcher="language" data-choice-page-size="<?= $selectorPageSize ?>" role="button" tabindex="0" aria-haspopup="menu" aria-label="<?= __('切换语言') ?>">
    <span class="action-line-1"><?= __('语言') ?></span>
    <span class="action-line-2">
        <span class="weline-choice-current-flag" aria-hidden="true">
            <?php if ($currentLanguageFlag !== ''): ?>
                <?= $currentLanguageFlag ?>
            <?php else: ?>
                <i class="fas fa-globe" aria-hidden="true"></i>
            <?php endif; ?>
        </span>
        <span class="current-language" title="<?= $escape($currentLanguageShort) ?>"><?= $escape($currentLanguageLabel) ?></span>
        <i class="fas fa-chevron-down" aria-hidden="true"></i>
    </span>
    <div class="language-options weline-choice-panel" data-weline-choice-panel role="menu" aria-label="<?= __('语言选项') ?>">
        <div class="weline-choice-search">
            <input type="search" data-choice-search placeholder="<?= $escape(__('搜索语言、语言码或翻译')) ?>" autocomplete="off" aria-label="<?= $escape(__('搜索语言')) ?>">
        </div>
        <div class="weline-choice-items" data-choice-items>
        <?php foreach ($languages as $index => $lang): ?>
            <?php
            $langCode = $lang['code'] ?? '';
            $langName = $lang['name'] ?? $langCode;
            $langNative = $lang['native'] ?? '';
            $langFlag = (string)($lang['flag'] ?? '');
            $isCurrent = ($langCode === $displayCurrentLang);
            
            // URL 由前端 i18n.js 模块动态生成（使用框架推荐的路径格式）
            // 这里只生成基本的链接结构，href 会在前端通过 updateLanguageSwitcherLinks() 更新
            ?>
            <a href="#"
               class="language-option weline-choice-option <?= $isCurrent ? 'active' : '' ?>"
               data-language-option="true"
               data-choice-option="true"
               data-lang="<?= $escape($langCode) ?>"
               data-native="<?= $escape($langNative) ?>"
               data-search="<?= $escape($lang['search'] ?? $langCode) ?>"
               role="menuitem"
               <?= $index >= $selectorPageSize ? 'hidden' : '' ?>>
                <span class="weline-choice-flag" aria-hidden="true">
                    <?php if ($langFlag !== ''): ?>
                        <?= $langFlag ?>
                    <?php else: ?>
                        <span class="weline-choice-flag-fallback"><?= $escape($lang['short'] ?? '') ?></span>
                    <?php endif; ?>
                </span>
                <span class="weline-choice-text">
                    <span class="weline-choice-name"><?= $escape($langName) ?></span>
                    <span class="weline-choice-meta"><?= $escape($langCode) ?></span>
                </span>
                <?php if ($langNative !== '' && $langNative !== $langName): ?>
                    <span class="weline-choice-native" aria-hidden="true"><?= $escape($langNative) ?></span>
                <?php endif; ?>
                <i class="fas fa-check" aria-hidden="true"></i>
            </a>
        <?php endforeach; ?>
        </div>
        <div class="weline-choice-empty" data-choice-empty hidden><?= $escape(\Weline\Theme\Helper\WidgetI18n::label('无匹配语言')) ?></div>
        <button type="button" class="weline-choice-more" data-choice-more <?= count($languages) <= $selectorPageSize ? 'hidden' : '' ?>><?= $escape(__('加载更多')) ?></button>
    </div>
</div>
<?php
$assetsFlagKey = '__weline_i18n_header_choice_assets_rendered';
if (!$this->getData($assetsFlagKey)) {
    $this->setData($assetsFlagKey, true);
    echo $this->fetch('Weline_I18n::templates/Frontend/header-choice-selector-assets.phtml');
}
?>
