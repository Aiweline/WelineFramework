<?php
/**
 *
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */

use Weline\Framework\App\State;
use Weline\Framework\Event\EventsManager;
use Weline\Framework\Manager\ObjectManager;

/** @var \Weline\Framework\View\Template $this */

$currentCurrency = State::getCurrency();
$i18nCurrencies = [];

$normalizeCurrencyName = static function (string $currencyCode, string $currencyName): string {
    $currencyCode = strtoupper(trim($currencyCode));
    $currencyName = trim($currencyName);

    if ($currencyCode !== '' && ($currencyName === '' || strtoupper($currencyName) === $currencyCode)) {
        return match ($currencyCode) {
            'CNY' => '人民币',
            'USD' => '美元',
            'EUR' => '欧元',
            'GBP' => '英镑',
            default => $currencyName !== '' ? $currencyName : $currencyCode,
        };
    }

    return $currencyName;
};

if (class_exists(\Weline\Currency\Data\CurrencyData::class)) {
    try {
        $currencies = \Weline\Currency\Data\CurrencyData::getCurrencies();
        if (is_array($currencies) && !empty($currencies)) {
            foreach ($currencies as $currency) {
                if (is_array($currency)) {
                    $currencyCode = strtoupper((string)($currency['code'] ?? ''));
                    $i18nCurrencies[] = [
                        'code' => $currencyCode,
                        'name' => $normalizeCurrencyName($currencyCode, (string)($currency['name'] ?? $currencyCode)),
                        'symbol' => $currency['symbol'] ?? '',
                        'format' => $currency['format'] ?? '',
                    ];
                } elseif (is_object($currency)) {
                    $currencyCode = strtoupper((string)($currency->getCode() ?? $currency->getData('code') ?? ''));
                    $i18nCurrencies[] = [
                        'code' => $currencyCode,
                        'name' => $normalizeCurrencyName($currencyCode, (string)($currency->getName() ?? $currency->getData('name') ?? $currencyCode)),
                        'symbol' => $currency->getSymbol() ?? $currency->getData('symbol') ?? '',
                        'format' => $currency->getFormat() ?? $currency->getData('format') ?? '',
                    ];
                }
            }
        }
    } catch (\Throwable $e) {
    }
}

if (empty($i18nCurrencies)) {
    $i18nCurrencies = [
        ['code' => 'CNY', 'name' => '人民币', 'symbol' => '¥', 'format' => ''],
        ['code' => 'USD', 'name' => '美元', 'symbol' => '$', 'format' => ''],
        ['code' => 'EUR', 'name' => '欧元', 'symbol' => '€', 'format' => ''],
        ['code' => 'GBP', 'name' => '英镑', 'symbol' => '£', 'format' => ''],
    ];
}

$eventData = [
    'currentCurrency' => $currentCurrency,
    'currencies' => $i18nCurrencies,
    'template' => $this,
    'request' => $this->request,
];

/** @var EventsManager $eventsManager */
$eventsManager = ObjectManager::getInstance(EventsManager::class);
$eventsManager->dispatch('Weline_I18n::header-currency-switcher-data', $eventData);
$event = $eventsManager->getEventData('Weline_I18n::header-currency-switcher-data');

if ($event) {
    $eventDataResult = $event->getData('data');
    if (is_array($eventDataResult)) {
        $eventCurrencies = $eventDataResult['currencies'] ?? null;
        $eventCurrentCurrency = $eventDataResult['currentCurrency'] ?? null;
    } else {
        $eventCurrencies = null;
        $eventCurrentCurrency = null;
    }
} else {
    $eventCurrencies = null;
    $eventCurrentCurrency = null;
}

$currencies = $eventCurrencies ?? $i18nCurrencies;
$displayCurrentCurrency = $eventCurrentCurrency ?? $currentCurrency;
?>
<div class="currency-switcher" data-currency-switcher="true" role="button" tabindex="0" aria-label="<?= __('切换货币') ?>">
    <span class="action-line-1"><?= __('货币') ?></span>
    <span class="action-line-2">
        <i class="fas fa-dollar-sign" aria-hidden="true"></i>
        <span class="current-currency"><?= htmlspecialchars($displayCurrentCurrency) ?></span>
        <i class="fas fa-chevron-down" aria-hidden="true"></i>
    </span>
    <div class="currency-options" role="menu" aria-label="<?= __('货币选项') ?>">
        <?php foreach ($currencies as $currency): ?>
            <?php
            $currencyCode = strtoupper($currency['code'] ?? '');
            $currencyName = \__((string)($currency['name'] ?? $currencyCode));
            $isCurrent = ($currencyCode === strtoupper($displayCurrentCurrency));
            ?>
            <a href="#"
               class="currency-option <?= $isCurrent ? 'active' : '' ?>"
               data-currency-option="true"
               data-currency="<?= htmlspecialchars($currencyCode) ?>"
               role="menuitem">
                <span><?= htmlspecialchars($currencyName) ?></span>
                <i class="fas fa-check" aria-hidden="true"></i>
            </a>
        <?php endforeach; ?>
    </div>
</div>
