<script>
(function () {
    'use strict';

    var root = document.querySelector('.weline-database-admin');
    if (!root) {
        return;
    }

    var endpoints = <?= json_encode($endpoints, $jsonFlags) ?>;
    var text = <?= json_encode($texts, $jsonFlags) ?>;
    var currentSqlImportToken = '';
    var currentSqlImportConfirmPhrase = 'I_UNDERSTAND_SQL_IMPORT';

    var dbSelect = document.getElementById('db-select');
    var tableSelect = document.getElementById('table-select');
    var rowsPanel = document.getElementById('rows-panel');
    var rowsSummary = document.getElementById('rows-summary');
    var metaPanel = document.getElementById('meta-panel');
    var sqlPanel = document.getElementById('sql-panel');
    var sqlInput = document.getElementById('sql-input');
    var sqlImportForm = document.getElementById('sql-import-form');
    var sqlImportFile = document.getElementById('sql-import-file');
    var sqlImportPanel = document.getElementById('sql-import-panel');
    var sqlImportPrepare = document.getElementById('sql-import-prepare');
    var sqlImportBackupLink = document.getElementById('sql-import-backup-link');
    var sqlImportBackupConfirmed = document.getElementById('sql-import-backup-confirmed');
    var sqlImportConfirmPhrase = document.getElementById('sql-import-confirm-phrase');
    var sqlImportExecute = document.getElementById('sql-import-execute');
    var sqlImportDownloadFrame = document.getElementById('sql-import-download-frame');

    function notify(type, message) {
        var toast = window.BackendToast;
        if (toast && typeof toast[type] === 'function') {
            toast[type](message);
        }
    }

    function unwrapResponse(response) {
        var hasTransportEnvelope = response
            && typeof response === 'object'
            && !Array.isArray(response)
            && Object.prototype.hasOwnProperty.call(response, 'data')
            && (Object.prototype.hasOwnProperty.call(response, 'status')
                || Object.prototype.hasOwnProperty.call(response, 'ok')
                || Object.prototype.hasOwnProperty.call(response, 'headers'));
        var data = hasTransportEnvelope ? response.data : response;
        if (typeof data === 'string') {
            try {
                return JSON.parse(data);
            } catch (e) {
                return {success: false, message: data};
            }
        }
        return data || {};
    }

    function requestJson(url, options) {
        var requestOptions = Object.assign({silent: true}, options || {});
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function') {
            return window.Weline.Api.request(url, requestOptions).then(unwrapResponse);
        }

        return Promise.reject(new Error(text.apiUnavailable));
    }

    function withQuery(url, params) {
        var query = new URLSearchParams();
        Object.keys(params || {}).forEach(function (key) {
            if (params[key] !== undefined && params[key] !== null) {
                query.append(key, params[key]);
            }
        });
        var glue = url.indexOf('?') === -1 ? '?' : '&';
        return url + glue + query.toString();
    }

    function setJsonPanel(panel, data) {
        if (!panel) {
            return;
        }
        panel.textContent = typeof data === 'string' ? data : JSON.stringify(data, null, 2);
    }

    function setSummary(id, value) {
        var node = document.getElementById(id);
        if (node) {
            node.textContent = value;
        }
    }

    function createEmptyState(message, icon) {
        var empty = document.createElement('div');
        empty.className = 'w-db-empty-state';
        var i = document.createElement('i');
        i.className = 'mdi ' + (icon || 'mdi-database-search');
        var span = document.createElement('span');
        span.textContent = message;
        empty.appendChild(i);
        empty.appendChild(span);
        return empty;
    }

    function formatCellValue(value) {
        if (value === null) {
            return text.nullValue;
        }
        if (typeof value === 'object') {
            return JSON.stringify(value);
        }
        return String(value);
    }

    function renderRows(payload) {
        var rows = Array.isArray(payload.items) ? payload.items : [];
        rowsPanel.innerHTML = '';
        rowsSummary.textContent = text.totalRows + ': ' + (payload.total || 0) + ' / ' + text.currentRows + ': ' + rows.length;

        if (!rows.length) {
            rowsPanel.appendChild(createEmptyState(text.emptyRows, 'mdi-table-off'));
            return;
        }

        var columns = [];
        rows.forEach(function (row) {
            Object.keys(row || {}).forEach(function (key) {
                if (columns.indexOf(key) === -1) {
                    columns.push(key);
                }
            });
        });

        var wrapper = document.createElement('div');
        wrapper.className = 'table-responsive';
        var table = document.createElement('table');
        table.className = 'table table-bordered table-hover align-middle mb-0';
        var thead = document.createElement('thead');
        var headRow = document.createElement('tr');
        columns.forEach(function (column) {
            var th = document.createElement('th');
            th.textContent = column;
            headRow.appendChild(th);
        });
        thead.appendChild(headRow);
        table.appendChild(thead);

        var tbody = document.createElement('tbody');
        rows.forEach(function (row) {
            var tr = document.createElement('tr');
            columns.forEach(function (column) {
                var td = document.createElement('td');
                td.className = 'w-db-cell';
                td.textContent = formatCellValue(row ? row[column] : '');
                td.title = td.textContent;
                tr.appendChild(td);
            });
            tbody.appendChild(tr);
        });
        table.appendChild(tbody);
        wrapper.appendChild(table);
        rowsPanel.appendChild(wrapper);
    }

    function updateSqlImportExecuteState() {
        sqlImportExecute.disabled = !currentSqlImportToken
            || !sqlImportBackupConfirmed.checked
            || sqlImportConfirmPhrase.value.trim() !== currentSqlImportConfirmPhrase;
    }

    function loadTables(database) {
        if (!database) {
            tableSelect.innerHTML = '';
            setSummary('table-count', '-');
            setSummary('active-database', '-');
            return Promise.resolve();
        }
        setSummary('active-database', database);
        tableSelect.disabled = true;
        return requestJson(withQuery(endpoints.tables, {database: database}))
            .then(function (data) {
                var tables = Array.isArray(data.data) ? data.data : [];
                tableSelect.innerHTML = '';
                tables.forEach(function (table) {
                    var option = document.createElement('option');
                    option.value = table;
                    option.textContent = table;
                    tableSelect.appendChild(option);
                });
                setSummary('table-count', tables.length);
                if (!tables.length) {
                    rowsPanel.innerHTML = '';
                    rowsPanel.appendChild(createEmptyState(text.emptyTables, 'mdi-table-off'));
                }
            })
            .catch(function (error) {
                notify('error', text.loadFailed + ': ' + error.message);
            })
            .finally(function () {
                tableSelect.disabled = false;
            });
    }

    function loadDatabases() {
        dbSelect.disabled = true;
        return requestJson(endpoints.databases)
            .then(function (data) {
                var databases = Array.isArray(data.data) ? data.data : [];
                var defaultDatabase = root.getAttribute('data-default-database') || '';
                if (defaultDatabase && databases.indexOf(defaultDatabase) === -1) {
                    databases.unshift(defaultDatabase);
                }
                dbSelect.innerHTML = '';
                databases.forEach(function (database) {
                    var option = document.createElement('option');
                    option.value = database;
                    option.textContent = database;
                    dbSelect.appendChild(option);
                });
                setSummary('db-count', databases.length);
                if (defaultDatabase && databases.indexOf(defaultDatabase) !== -1) {
                    dbSelect.value = defaultDatabase;
                }
                if (dbSelect.value) {
                    return loadTables(dbSelect.value);
                }
                return null;
            })
            .catch(function (error) {
                notify('error', text.loadFailed + ': ' + error.message);
            })
            .finally(function () {
                dbSelect.disabled = false;
            });
    }

    dbSelect.addEventListener('change', function () {
        loadTables(dbSelect.value);
    });

    document.getElementById('load-table').addEventListener('click', function () {
        if (!dbSelect.value || !tableSelect.value) {
            rowsPanel.innerHTML = '';
            rowsPanel.appendChild(createEmptyState(text.chooseDatabaseTable, 'mdi-alert-circle-outline'));
            return;
        }
        rowsPanel.innerHTML = '';
        rowsPanel.appendChild(createEmptyState(text.loading, 'mdi-loading mdi-spin'));
        requestJson(withQuery(endpoints.rows, {
            database: dbSelect.value,
            table: tableSelect.value
        })).then(function (data) {
            if (!data.success) {
                throw new Error(data.message || text.loadFailed);
            }
            renderRows(data.data || {});
            notify('success', text.loadRowsSuccess);
        }).catch(function (error) {
            rowsPanel.innerHTML = '';
            rowsPanel.appendChild(createEmptyState(text.loadFailed + ': ' + error.message, 'mdi-alert-circle-outline'));
            notify('error', text.loadFailed + ': ' + error.message);
        });
    });

    document.getElementById('load-meta').addEventListener('click', function () {
        if (!dbSelect.value || !tableSelect.value) {
            setJsonPanel(metaPanel, text.chooseDatabaseTable);
            return;
        }
        setJsonPanel(metaPanel, text.loading);
        requestJson(withQuery(endpoints.tableMeta, {
            database: dbSelect.value,
            table: tableSelect.value
        })).then(function (data) {
            if (!data.success) {
                throw new Error(data.message || text.loadFailed);
            }
            setJsonPanel(metaPanel, data.data || {});
            notify('success', text.loadMetaSuccess);
        }).catch(function (error) {
            setJsonPanel(metaPanel, {success: false, message: error.message});
            notify('error', text.loadFailed + ': ' + error.message);
        });
    });

    document.getElementById('sql-run').addEventListener('click', function () {
        var payload = new URLSearchParams({
            database: dbSelect.value || '',
            table: tableSelect.value || '',
            sql: sqlInput.value,
            confirmed: document.getElementById('sql-confirmed').checked ? '1' : '0',
            confirm_phrase: document.getElementById('sql-confirm-phrase').value
        });
        setJsonPanel(sqlPanel, text.sqlExecuting);
        requestJson(endpoints.executeSql, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest'},
            body: payload.toString()
        }).then(function (data) {
            setJsonPanel(sqlPanel, data);
            notify(data.success ? 'success' : 'error', data.message || (data.success ? text.success : text.failed));
        }).catch(function (error) {
            setJsonPanel(sqlPanel, {success: false, message: error.message});
            notify('error', text.failed + ': ' + error.message);
        });
    });

    sqlImportForm.addEventListener('submit', function (event) {
        event.preventDefault();
        var file = sqlImportFile.files && sqlImportFile.files[0] ? sqlImportFile.files[0] : null;
        currentSqlImportToken = '';
        sqlImportBackupConfirmed.checked = false;
        sqlImportConfirmPhrase.value = '';
        sqlImportBackupLink.classList.add('is-hidden');
        updateSqlImportExecuteState();

        if (!file) {
            setJsonPanel(sqlImportPanel, text.chooseSqlFile);
            notify('warning', text.chooseSqlFile);
            return;
        }

        var payload = new FormData();
        payload.append('sql_file', file);
        sqlImportPrepare.disabled = true;
        setJsonPanel(sqlImportPanel, text.prepareImporting);
        requestJson(endpoints.prepareSqlImport, {
            method: 'POST',
            body: payload
        }).then(function (data) {
            setJsonPanel(sqlImportPanel, data);
            if (data.success && data.data && data.data.token) {
                currentSqlImportToken = data.data.token;
                currentSqlImportConfirmPhrase = data.data.confirm_phrase || currentSqlImportConfirmPhrase;
                var backupUrl = withQuery(endpoints.downloadSqlBackup, {token: currentSqlImportToken});
                sqlImportBackupLink.href = backupUrl;
                sqlImportBackupLink.textContent = text.downloadBackupPrefix + (data.data.backup_filename || 'weline_sql_import_backup.sql');
                sqlImportBackupLink.classList.remove('is-hidden');
                sqlImportDownloadFrame.src = backupUrl + '&_=' + Date.now();
                notify('success', text.success);
            } else {
                notify('error', data.message || text.failed);
            }
        }).catch(function (error) {
            setJsonPanel(sqlImportPanel, {success: false, message: error.message});
            notify('error', text.failed + ': ' + error.message);
        }).finally(function () {
            sqlImportPrepare.disabled = false;
            updateSqlImportExecuteState();
        });
    });

    sqlImportBackupConfirmed.addEventListener('change', updateSqlImportExecuteState);
    sqlImportConfirmPhrase.addEventListener('input', updateSqlImportExecuteState);

    sqlImportExecute.addEventListener('click', function () {
        if (!currentSqlImportToken) {
            setJsonPanel(sqlImportPanel, text.uploadSqlFirst);
            notify('warning', text.uploadSqlFirst);
            return;
        }
        var payload = new URLSearchParams({
            token: currentSqlImportToken,
            backup_confirmed: sqlImportBackupConfirmed.checked ? '1' : '0',
            confirm_phrase: sqlImportConfirmPhrase.value.trim()
        });
        sqlImportExecute.disabled = true;
        setJsonPanel(sqlImportPanel, text.executeImporting);
        requestJson(endpoints.executeSqlImport, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest'},
            body: payload.toString()
        }).then(function (data) {
            setJsonPanel(sqlImportPanel, data);
            if (data.success) {
                currentSqlImportToken = '';
                sqlImportBackupConfirmed.checked = false;
                sqlImportConfirmPhrase.value = '';
                notify('success', text.success);
            } else {
                notify('error', data.message || text.failed);
            }
        }).catch(function (error) {
            setJsonPanel(sqlImportPanel, {success: false, message: error.message});
            notify('error', text.failed + ': ' + error.message);
        }).finally(updateSqlImportExecuteState);
    });

    loadDatabases();
})();
</script>

