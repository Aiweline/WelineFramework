$initialDatabases = is_array($initialDatabases) ? array_values(array_filter(
    array_map(static fn(mixed $value): string => (string)$value, $initialDatabases),
    static fn(string $value): bool => $value !== ''
)) : [];
if ($defaultDatabase === '' && $initialDatabases !== []) {
    $defaultDatabase = $initialDatabases[0];
}
if ($defaultDatabase !== '' && !in_array($defaultDatabase, $initialDatabases, true)) {
    array_unshift($initialDatabases, $defaultDatabase);
}
$initialTables = $tables ?? $this->getData('tables') ?? [];
$initialTables = is_array($initialTables) ? array_values(array_filter(
    array_map(static fn(mixed $value): string => (string)$value, $initialTables),
    static fn(string $value): bool => $value !== ''
)) : [];
$auditLogs = $audit_logs ?? $this->getData('audit_logs') ?? [];
$auditLogs = is_array($auditLogs) ? $auditLogs : [];
$auditJson = json_encode($auditLogs, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT);
$auditJson = $auditJson === false ? '[]' : $auditJson;

$h = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$navClass = static fn(string $tab): string => 'nav-link' . ($activeTab === $tab ? ' active' : '');
$paneClass = static fn(string $tab): string => 'tab-pane fade' . ($activeTab === $tab ? ' show active' : '');
$jsonFlags = JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT;

$endpoints = [
    'databases' => $this->getBackendUrl('database/backend/admin/databases'),
    'tables' => $this->getBackendUrl('database/backend/admin/tables'),
    'rows' => $this->getBackendUrl('database/backend/admin/rows'),
    'tableMeta' => $this->getBackendUrl('database/backend/admin/table-meta'),
