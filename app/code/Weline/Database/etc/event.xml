<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 模块升级事件监听 -->
    <event name="Framework_Module::module_upgrade">
        <observer name="Weline_Database::module_upgrade" instance="Weline\Database\Observer\ModuleUpgradeObserver" disabled="false" shared="true" sort="0"/>
    </event>
    
    <!-- 系统升级事件监听 -->
    <event name="Framework_Setup::upgrade_after">
        <observer name="Weline_Database::setup_upgrade" instance="Weline\Database\Observer\SetupUpgradeObserver" disabled="false" shared="true" sort="0"/>
    </event>
    
    <!-- 模块安装事件监听 -->
    <event name="Framework_Module::module_install_after">
        <observer name="Weline_Database::module_install" instance="Weline\Database\Observer\ModuleUpgradeObserver" disabled="false" shared="true" sort="0"/>
    </event>
    
    <!-- 模块卸载事件监听 -->
    <event name="Framework_Module::module_uninstall_after">
        <observer name="Weline_Database::module_uninstall" instance="Weline\Database\Observer\ModuleUpgradeObserver" disabled="false" shared="true" sort="0"/>
    </event>
</config>

