<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 翻译事件 - 其他模块可以监听此事件来使用翻译服务 -->
    <event name="Weline_TranslationService::translate">
        <observer name="Weline_TranslationService::translate" 
                  instance="Weline\TranslationService\Observer\TranslationObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- 批量翻译事件 -->
    <event name="Weline_TranslationService::batch_translate">
        <observer name="Weline_TranslationService::batch_translate" 
                  instance="Weline\TranslationService\Observer\BatchTranslationObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- 语言检测事件 -->
    <event name="Weline_TranslationService::detect_language">
        <observer name="Weline_TranslationService::detect_language" 
                  instance="Weline\TranslationService\Observer\DetectLanguageObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
</config>

