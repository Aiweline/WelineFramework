<script>
function selectAllLanguages() {
    document.querySelectorAll('#supported-languages-container input[type="checkbox"]').forEach(function(checkbox) {
        checkbox.checked = true;
    });
}

function deselectAllLanguages() {
    document.querySelectorAll('#supported-languages-container input[type="checkbox"]').forEach(function(checkbox) {
        checkbox.checked = false;
    });
}

document.querySelectorAll('[data-language-selection]').forEach(function(button) {
    button.addEventListener('click', function() {
        if (button.getAttribute('data-language-selection') === 'all') {
            selectAllLanguages();
            return;
        }

        deselectAllLanguages();
    });
});
</script>
