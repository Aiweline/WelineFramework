                            <tr>
                                <th><?= __('渠道名称') ?></th>
                                <th><?= __('渠道代码') ?></th>
                                <th><?= __('状态') ?></th>
                                <th><?= __('默认') ?></th>
                                <th><?= __('优先级') ?></th>
                                <th><?= __('操作') ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($providers as $provider): ?>
                                <tr>
                                    <td><?= htmlspecialchars($provider->getData('provider_name')) ?></td>
                                    <td><code><?= htmlspecialchars($provider->getData('provider_code')) ?></code></td>
                                    <td>
                                        <?php if ($provider->isEnabled()): ?>
                                            <span class="badge bg-success"><?= __('启用') ?></span>
                                        <?php else: ?>
                                            <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                        <?php endif; ?>
                                    </td>
                                    <td>
                                        <?php if ($provider->isDefault()): ?>
                                            <span class="badge bg-primary"><?= __('是') ?></span>
                                        <?php else: ?>
                                            <span class="text-muted"><?= __('否') ?></span>
                                        <?php endif; ?>
                                    </td>
                                    <td><?= htmlspecialchars($provider->getData('priority')) ?></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="<?= $this->getBackendUrl('*/backend/config/edit', ['id' => $provider->getId()]) ?>" 
                                               class="btn btn-outline-primary">
                                                <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                                            </a>
                                            <button type="button" 
                                                    class="btn btn-outline-info test-connection-btn" 
                                                    data-id="<?= $provider->getId() ?>">
                                                <i class="mdi mdi-network"></i> <?= __('测试') ?>
                                            </button>
                                            <a href="<?= $this->getBackendUrl('*/backend/config/delete', ['id' => $provider->getId()]) ?>" 
                                               class="btn btn-outline-danger"
                                               data-translation-config-confirm="deleteProvider">
                                                <i class="mdi mdi-delete"></i> <?= __('删除') ?>
