<?php
/**
 * 翻译服务配置页面
 * 
 * @var \Weline\Framework\View\Template $this
 * @var array $providers 渠道配置列表
 */
$providers = $this->getData('providers') ?? [];
?>
<div class="translation-service-config-page">
    <div class="page-header mb-4">
        <h1><?= __('翻译服务配置') ?></h1>
        <p class="text-muted"><?= __('配置和管理翻译服务渠道，支持Google、百度、DeepL、Microsoft等主流翻译服务') ?></p>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3><?= __('渠道列表') ?></h3>
            <a href="<?= $this->getBackendUrl('*/backend/config/edit') ?>" class="btn btn-primary">
                <i class="mdi mdi-plus"></i> <?= __('添加渠道') ?>
            </a>
        </div>
        <div class="card-body">
            <?php if (empty($providers)): ?>
                <div class="alert alert-info">
                    <?= __('暂无渠道配置') ?>
                </div>
            <?php else: ?>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th><?= __('渠道名称') ?></th>
                                <th><?= __('渠道代码') ?></th>
                                <th><?= __('状态') ?></th>
                                <th><?= __('默认') ?></th>
                                <th><?= __('优先级') ?></th>
                                <th><?= __('操作') ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($providers as $provider): ?>
                                <tr>
                                    <td><?= htmlspecialchars($provider->getData('provider_name')) ?></td>
                                    <td><code><?= htmlspecialchars($provider->getData('provider_code')) ?></code></td>
                                    <td>
                                        <?php if ($provider->isEnabled()): ?>
                                            <span class="badge bg-success"><?= __('启用') ?></span>
                                        <?php else: ?>
                                            <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                        <?php endif; ?>
                                    </td>
                                    <td>
                                        <?php if ($provider->isDefault()): ?>
                                            <span class="badge bg-primary"><?= __('是') ?></span>
                                        <?php else: ?>
                                            <span class="text-muted"><?= __('否') ?></span>
                                        <?php endif; ?>
                                    </td>
                                    <td><?= htmlspecialchars($provider->getData('priority')) ?></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="<?= $this->getBackendUrl('*/backend/config/edit', ['id' => $provider->getId()]) ?>" 
                                               class="btn btn-outline-primary">
                                                <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                                            </a>
                                            <button type="button" 
                                                    class="btn btn-outline-info test-connection-btn" 
                                                    data-id="<?= $provider->getId() ?>">
                                                <i class="mdi mdi-network"></i> <?= __('测试') ?>
                                            </button>
                                            <a href="<?= $this->getBackendUrl('*/backend/config/delete', ['id' => $provider->getId()]) ?>" 
                                               class="btn btn-outline-danger"
                                               onclick="return confirm('<?= __('确定要删除此渠道配置吗？') ?>')">
                                                <i class="mdi mdi-delete"></i> <?= __('删除') ?>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php endif; ?>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 测试连接
    document.querySelectorAll('.test-connection-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const providerId = this.getAttribute('data-id');
            const btn = this;
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('测试中...') ?>';
            
            fetch('<?= $this->getBackendUrl('*/backend/config/test') ?>?id=' + providerId)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('<?= __('连接测试成功') ?>');
                    } else {
                        alert('<?= __('连接测试失败') ?>: ' + (data.message || ''));
                    }
                })
                .catch(error => {
                    alert('<?= __('测试失败') ?>: ' + error.message);
                })
                .finally(() => {
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });
        });
    });
});
</script>

