$providers = $this->getData('providers') ?? [];
$dialogJsonFlags = JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP | JSON_THROW_ON_ERROR;
$confirmMessages = [
    'confirmTitle' => (string)__('确认操作'),
    'confirmButton' => (string)__('确定'),
    'cancelButton' => (string)__('取消'),
    'deleteProvider' => (string)__('确定要删除此渠道配置吗？'),
];
?>
<div class="translation-service-config-page">
    <div class="page-header mb-4">
        <h1><?= __('翻译服务配置') ?></h1>
        <p class="text-muted"><?= __('配置和管理翻译服务渠道，支持Google、百度、DeepL、Microsoft等主流翻译服务') ?></p>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
