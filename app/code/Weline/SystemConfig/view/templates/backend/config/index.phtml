<?php
/**
 * @var \Weline\Framework\View\Template $this
 * @var array $modules
 * @var array $tree
 * @var string $selected_module
 * @var string $selected_area
 * @var string $search
 * @var string $scope
 * @var string $locale
 * @var array $fallback_scopes
 * @var string $post_url
 */
$modules = $modules ?? [];
$tree = $tree ?? ['modules' => []];
$selectedModule = (string)($selected_module ?? '');
$selectedArea = (string)($selected_area ?? 'backend');
$search = (string)($search ?? '');
$scope = (string)($scope ?? 'default.default.default');
$locale = (string)($locale ?? 'default');
$fallbackScopes = $fallback_scopes ?? [];
$postUrl = (string)($post_url ?? '');
if ($postUrl === '') {
    $postUrl = (string)$this->getBackendUrl('weline_systemconfig/backend/config');
}
$guideData = is_array($this->getData('guide')) ? $this->getData('guide') : [];
$assignedGuideParams = is_array($guide_params ?? null) ? $guide_params : [];
$decodeGuideDisplay = static function (string $value): string {
    $value = trim($value);
    if ($value === '') {
        return '';
    }
    for ($i = 0; $i < 5; $i++) {
        if (!preg_match('/%[0-9A-Fa-f]{2}/', $value)) {
            break;
        }
        $decoded = rawurldecode($value);
        if ($decoded === $value) {
            $decoded = urldecode($value);
        }
        if ($decoded === $value) {
            break;
        }
        $value = $decoded;
    }
    return trim($value);
};
$guideKey = $decodeGuideDisplay((string)($guideData['key'] ?? $assignedGuideParams['guide_key'] ?? ($guide_key ?? '')));
$guideKeys = is_array($guideData['keys'] ?? null)
    ? array_values(array_filter(array_map('strval', $guideData['keys'])))
    : (is_array($guide_keys ?? null) ? array_values(array_filter(array_map('strval', $guide_keys))) : []);
$guideKeys = array_values(array_filter(array_map(static function ($key) use ($decodeGuideDisplay): string {
    return $decodeGuideDisplay((string)$key);
}, $guideKeys), static fn(string $key): bool => $key !== ''));
if ($guideKeys === [] && $guideKey !== '') {
    foreach (preg_split('/[\s,|;]+/', $guideKey) ?: [] as $part) {
        $part = $decodeGuideDisplay((string)$part);
        if ($part !== '' && !in_array($part, $guideKeys, true)) {
            $guideKeys[] = $part;
        }
    }
}
$guideLocate = $decodeGuideDisplay((string)($guideData['locate'] ?? $assignedGuideParams['guide_locate'] ?? ($guide_locate ?? '')));
if ($guideLocate === '' || ($guideKeys !== [] && !in_array($guideLocate, $guideKeys, true))) {
    $guideLocate = $guideKeys[0] ?? '';
}
$guideTargets = is_array($guideData['targets'] ?? null)
    ? $guideData['targets']
    : (is_array($guide_targets ?? null) ? $guide_targets : []);
$guideTitle = $decodeGuideDisplay((string)($guideData['title'] ?? $assignedGuideParams['guide_title'] ?? ($guide_title ?? '')));
$guideSummary = $decodeGuideDisplay((string)($guideData['summary'] ?? $assignedGuideParams['guide_summary'] ?? ($guide_summary ?? '')));
$guideStep = $decodeGuideDisplay((string)($guideData['step'] ?? $assignedGuideParams['guide_step'] ?? ($guide_step ?? '')));
$guideReturn = trim((string)($guideData['return'] ?? $assignedGuideParams['guide_return'] ?? ($guide_return ?? '')));
$guideActive = $guideKeys !== [] || $guideTitle !== '' || $guideSummary !== '';
$guideKeySet = $guideKeys !== [] ? array_fill_keys($guideKeys, true) : [];
$guideKeyIndex = $guideKeys !== [] ? array_flip($guideKeys) : [];
$moduleRows = $tree['modules'] ?? [];
$totalTemplates = 0;
$totalFields = 0;
$totalAdapters = 0;
foreach ($moduleRows as $moduleRow) {
    $totalTemplates += (int)($moduleRow['template_count'] ?? 0);
    $totalFields += (int)($moduleRow['field_count'] ?? 0);
    $totalAdapters += (int)($moduleRow['adapter_count'] ?? 0);
}
$parseOptions = static function (string $options): array {
    $options = trim($options);
    if ($options === '' || str_starts_with($options, '$')) {
        return [];
    }
    $result = [];
    foreach (array_filter(array_map('trim', preg_split('/[,;]/', $options) ?: [])) as $option) {
        if (str_contains($option, ':')) {
            [$value, $label] = explode(':', $option, 2);
            $result[trim($value)] = trim($label);
        } else {
            $result[$option] = $option;
        }
    }
    return $result;
};
$guideParams = [];
if ($guideActive) {
    foreach ([
        'guide_key' => $guideKeys !== [] ? implode(',', $guideKeys) : $guideKey,
        'guide_locate' => $guideLocate,
        'guide_title' => $guideTitle,
        'guide_summary' => $guideSummary,
        'guide_step' => $guideStep,
        'guide_return' => $guideReturn,
    ] as $guideParamKey => $guideParamValue) {
        if ($guideParamValue !== '') {
            $guideParams[$guideParamKey] = $guideParamValue;
        }
    }
}
$configUrl = static function (array $params = []) use ($postUrl, $guideParams): string {
    $params = array_merge($guideParams, $params);
    $query = http_build_query($params, '', '&', PHP_QUERY_RFC3986);
    $url = $postUrl . ($query !== '' ? '?' . $query : '');
    return htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
};
$guideTargetNav = [];
foreach ($guideTargets as $guideTarget) {
    if (!is_array($guideTarget)) {
        continue;
    }
    $targetKey = trim((string)($guideTarget['key'] ?? ''));
    if ($targetKey === '') {
        continue;
    }
    $targetModule = trim((string)($guideTarget['module'] ?? ''));
    $targetArea = trim((string)($guideTarget['area'] ?? $selectedArea));
    $navParams = [
        'area' => $targetArea !== '' ? $targetArea : $selectedArea,
        'scope' => $scope,
        'locale' => $locale,
        'guide_locate' => $targetKey,
    ];
    if ($targetModule !== '') {
        $navParams['module'] = $targetModule;
    }
    $guideTargetNav[$targetKey] = [
        'index' => (int)($guideTarget['index'] ?? count($guideTargetNav)),
        'key' => $targetKey,
        'label' => trim((string)($guideTarget['label'] ?? $targetKey)),
        'module' => $targetModule,
        'area' => $targetArea,
        'code' => trim((string)($guideTarget['code'] ?? '')),
        'found' => !empty($guideTarget['found']),
        'href' => html_entity_decode($configUrl($navParams), ENT_QUOTES, 'UTF-8'),
    ];
}
foreach ($guideKeys as $index => $targetKey) {
    if (isset($guideTargetNav[$targetKey])) {
        continue;
    }
    $guideTargetNav[$targetKey] = [
        'index' => (int)$index,
        'key' => $targetKey,
        'label' => $targetKey,
        'module' => '',
        'area' => $selectedArea,
        'code' => '',
        'found' => false,
        'href' => html_entity_decode($configUrl([
            'area' => $selectedArea,
            'scope' => $scope,
            'locale' => $locale,
            'guide_locate' => $targetKey,
        ]), ENT_QUOTES, 'UTF-8'),
    ];
}
uksort($guideTargetNav, static function (string $a, string $b) use ($guideKeyIndex): int {
    return ((int)($guideKeyIndex[$a] ?? 9999)) <=> ((int)($guideKeyIndex[$b] ?? 9999));
});
$guideTargetNav = array_values($guideTargetNav);
$templateInstance = $this;
$adapterQueryParams = static function (array $adapter): array {
    $query = trim((string)($adapter['query'] ?? ''));
    if ($query === '') {
        return [];
    }

    $params = [];
    parse_str($query, $params);
    return is_array($params) ? $params : [];
};
$adapterAction = static function (array $adapter) use ($templateInstance, $adapterQueryParams): array {
    $url = '';
    $target = trim((string)($adapter['target'] ?? ''));
    $queryParams = $adapterQueryParams($adapter);

    if (!empty($adapter['external-url'])) {
        $url = trim((string)$adapter['external-url']);
        $target = $target !== '' ? $target : '_blank';
    } elseif (!empty($adapter['backend-url']) || !empty($adapter['manage-url'])) {
        $route = trim((string)($adapter['backend-url'] ?? $adapter['manage-url'] ?? ''));
        if ($route !== '') {
            if (str_contains($route, '://') || str_starts_with($route, '/')) {
                $url = $route;
                if ($queryParams !== []) {
                    $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
                }
            } else {
                $url = (string)$templateInstance->getBackendUrl($route, $queryParams);
            }
        }
    } elseif (!empty($adapter['frontend-url'])) {
        $route = trim((string)$adapter['frontend-url']);
        if ($route !== '') {
            if (str_contains($route, '://') || str_starts_with($route, '/')) {
                $url = $route;
                if ($queryParams !== []) {
                    $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
                }
            } elseif (method_exists($templateInstance, 'getFrontendUrl')) {
                $url = (string)$templateInstance->getFrontendUrl($route, $queryParams);
            } else {
                $url = (string)$templateInstance->getUrl($route, $queryParams);
            }
        }
    } elseif (!empty($adapter['url'])) {
        $url = trim((string)$adapter['url']);
        if ($queryParams !== []) {
            $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
        }
    }

    return [
        'url' => $url,
        'target' => $target,
        'label' => trim((string)($adapter['action-label'] ?? __('打开'))),
    ];
};
