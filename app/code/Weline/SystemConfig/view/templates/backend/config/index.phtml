/**
 * @var \Weline\Framework\View\Template $this
 * @var array $modules
 * @var array $tree
 * @var string $selected_module
 * @var string $selected_area
 * @var string $search
 * @var string $scope
 * @var string $locale
 * @var array $fallback_scopes
 * @var string $post_url
 */
$modules = $modules ?? [];
$tree = $tree ?? ['modules' => []];
$selectedModule = (string)($selected_module ?? '');
$selectedArea = (string)($selected_area ?? 'backend');
$search = (string)($search ?? '');
$scope = (string)($scope ?? 'default.default.default');
$locale = (string)($locale ?? 'default');
$fallbackScopes = $fallback_scopes ?? [];
$postUrl = (string)($post_url ?? '');
if ($postUrl === '') {
    $postUrl = (string)$this->getBackendUrl('weline_systemconfig/backend/config');
}
$guideData = is_array($this->getData('guide')) ? $this->getData('guide') : [];
$assignedGuideParams = is_array($guide_params ?? null) ? $guide_params : [];
$guideKey = trim((string)($guideData['key'] ?? $assignedGuideParams['guide_key'] ?? ($guide_key ?? '')));
$guideTitle = trim((string)($guideData['title'] ?? $assignedGuideParams['guide_title'] ?? ($guide_title ?? '')));
$guideSummary = trim((string)($guideData['summary'] ?? $assignedGuideParams['guide_summary'] ?? ($guide_summary ?? '')));
$guideStep = trim((string)($guideData['step'] ?? $assignedGuideParams['guide_step'] ?? ($guide_step ?? '')));
$guideReturn = trim((string)($guideData['return'] ?? $assignedGuideParams['guide_return'] ?? ($guide_return ?? '')));
$guideActive = $guideKey !== '' || $guideTitle !== '' || $guideSummary !== '';
$moduleRows = $tree['modules'] ?? [];
$totalTemplates = 0;
$totalFields = 0;
$totalAdapters = 0;
foreach ($moduleRows as $moduleRow) {
    $totalTemplates += (int)($moduleRow['template_count'] ?? 0);
    $totalFields += (int)($moduleRow['field_count'] ?? 0);
    $totalAdapters += (int)($moduleRow['adapter_count'] ?? 0);
}
$parseOptions = static function (string $options): array {
    $options = trim($options);
    if ($options === '' || str_starts_with($options, '$')) {
        return [];
    }
    $result = [];
    foreach (array_filter(array_map('trim', preg_split('/[,;]/', $options) ?: [])) as $option) {
        if (str_contains($option, ':')) {
            [$value, $label] = explode(':', $option, 2);
            $result[trim($value)] = trim($label);
        } else {
            $result[$option] = $option;
        }
    }
    return $result;
};
$guideParams = [];
if ($guideActive) {
    foreach ([
        'guide_key' => $guideKey,
        'guide_title' => $guideTitle,
        'guide_summary' => $guideSummary,
        'guide_step' => $guideStep,
        'guide_return' => $guideReturn,
    ] as $guideParamKey => $guideParamValue) {
        if ($guideParamValue !== '') {
            $guideParams[$guideParamKey] = $guideParamValue;
        }
    }
}
$configUrl = static function (array $params = []) use ($postUrl, $guideParams): string {
    $params = array_merge($guideParams, $params);
    $query = http_build_query($params);
    $url = $postUrl . ($query !== '' ? '?' . $query : '');
    return htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
};
$templateInstance = $this;
$adapterQueryParams = static function (array $adapter): array {
    $query = trim((string)($adapter['query'] ?? ''));
    if ($query === '') {
        return [];
    }

    $params = [];
    parse_str($query, $params);
    return is_array($params) ? $params : [];
};
$adapterAction = static function (array $adapter) use ($templateInstance, $adapterQueryParams): array {
    $url = '';
    $target = trim((string)($adapter['target'] ?? ''));
    $queryParams = $adapterQueryParams($adapter);

    if (!empty($adapter['external-url'])) {
        $url = trim((string)$adapter['external-url']);
        $target = $target !== '' ? $target : '_blank';
    } elseif (!empty($adapter['backend-url']) || !empty($adapter['manage-url'])) {
        $route = trim((string)($adapter['backend-url'] ?? $adapter['manage-url'] ?? ''));
        if ($route !== '') {
            if (str_contains($route, '://') || str_starts_with($route, '/')) {
                $url = $route;
                if ($queryParams !== []) {
                    $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
                }
            } else {
                $url = (string)$templateInstance->getBackendUrl($route, $queryParams);
            }
        }
    } elseif (!empty($adapter['frontend-url'])) {
        $route = trim((string)$adapter['frontend-url']);
        if ($route !== '') {
            if (str_contains($route, '://') || str_starts_with($route, '/')) {
                $url = $route;
                if ($queryParams !== []) {
                    $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
                }
            } elseif (method_exists($templateInstance, 'getFrontendUrl')) {
                $url = (string)$templateInstance->getFrontendUrl($route, $queryParams);
            } else {
                $url = (string)$templateInstance->getUrl($route, $queryParams);
            }
        }
    } elseif (!empty($adapter['url'])) {
        $url = trim((string)$adapter['url']);
        if ($queryParams !== []) {
            $url .= (str_contains($url, '?') ? '&' : '?') . http_build_query($queryParams);
        }
    }

    return [
        'url' => $url,
        'target' => $target,
        'label' => trim((string)($adapter['action-label'] ?? __('打开'))),
    ];
};
