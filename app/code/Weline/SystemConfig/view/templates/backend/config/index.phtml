<?php if ($guideKeys !== []): ?>
<script>
    (function () {
        var initialLocate = <?= json_encode($guideLocate, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var notFoundMsg = <?= json_encode((string)__('未找到引导配置项，请确认已选中对应模块。'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var currentPrefix = <?= json_encode((string)__('当前：%{1}', ['__LABEL__']), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var modeSamePage = <?= json_encode((string)__('同页'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var modeJump = <?= json_encode((string)__('跳转'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var modeMissing = <?= json_encode((string)__('未找到'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var badgeCurrent = <?= json_encode((string)__('当前定位'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var badgeTarget = <?= json_encode((string)__('引导目标'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var guideParamNames = ['guide_key', 'guide_keys', 'guide_title', 'guide_summary', 'guide_locate', 'guide_step', 'guide_return'];
        var currentKey = '';

        var decodeGuideValue = function (value) {
            var cur = String(value || '').trim();
            if (!cur) {
                return '';
            }
            for (var i = 0; i < 5; i++) {
                if (!/%[0-9A-Fa-f]{2}/.test(cur)) {
                    break;
                }
                try {
                    var next = decodeURIComponent(cur.replace(/\+/g, '%20'));
                    if (next === cur) {
                        break;
                    }
                    cur = next;
                } catch (e) {
                    break;
                }
            }
            return cur.trim();
        };

        initialLocate = decodeGuideValue(initialLocate);
        currentKey = initialLocate || '';

        var findTarget = function (key) {
            key = decodeGuideValue(key);
            if (!key) {
                return null;
            }
            var rows = document.querySelectorAll('[data-guide-key]');
            for (var i = 0; i < rows.length; i++) {
                if (decodeGuideValue(rows[i].getAttribute('data-guide-key') || '') === key) {
                    return rows[i];
                }
            }
            return null;
        };

        var findTriggerByKey = function (key) {
            key = decodeGuideValue(key);
            var preferred = document.querySelectorAll('.wsc-guide-float-item[data-wsc-guide-locate-key]');
            for (var i = 0; i < preferred.length; i++) {
                if (decodeGuideValue(preferred[i].getAttribute('data-wsc-guide-locate-key') || '') === key) {
                    return preferred[i];
                }
            }
            var buttons = document.querySelectorAll('[data-wsc-guide-locate-key]');
            for (var j = 0; j < buttons.length; j++) {
                if (decodeGuideValue(buttons[j].getAttribute('data-wsc-guide-locate-key') || '') === key) {
                    return buttons[j];
                }
            }
            return null;
        };

        var syncModeLabels = function () {
            document.querySelectorAll('[data-wsc-guide-locate-key]').forEach(function (btn) {
                var key = decodeGuideValue(btn.getAttribute('data-wsc-guide-locate-key') || '');
                var mode = btn.querySelector('[data-wsc-guide-mode]');
                if (!mode) {
                    return;
                }
                if (findTarget(key)) {
                    mode.textContent = modeSamePage;
                    btn.classList.remove('is-missing');
                } else if (btn.getAttribute('data-wsc-guide-href')) {
                    mode.textContent = modeJump;
                } else {
                    mode.textContent = modeMissing;
                    btn.classList.add('is-missing');
                }
            });
        };

        var setCurrentUi = function (key, label) {
            currentKey = decodeGuideValue(key || '');
            document.querySelectorAll('.wsc-guide-float-item, .wsc-guide-key-chip').forEach(function (el) {
                var itemKey = decodeGuideValue(el.getAttribute('data-wsc-guide-locate-key') || '');
                el.classList.toggle('is-current', itemKey !== '' && itemKey === currentKey);
            });
            document.querySelectorAll('tr.wsc-guide-target').forEach(function (row) {
                var rowKey = decodeGuideValue(row.getAttribute('data-guide-key') || '');
                var isCurrent = rowKey !== '' && rowKey === currentKey;
                row.classList.toggle('wsc-guide-target--focused', isCurrent);
                var badge = row.querySelector('.wsc-guide-target-badge');
                if (badge) {
                    badge.classList.toggle('is-current', isCurrent);
                    badge.textContent = isCurrent ? badgeCurrent : badgeTarget;
                }
            });
            var currentLabelEl = document.querySelector('[data-wsc-guide-current-label]');
            if (currentLabelEl) {
                var text = label || key || '';
                currentLabelEl.textContent = String(currentPrefix).replace('__LABEL__', text);
                currentLabelEl.setAttribute('title', text);
            }
        };

        var sanitizeGuideSearchParams = function (url) {
            guideParamNames.forEach(function (name) {
                if (!url.searchParams.has(name)) {
                    return;
                }
                var decoded = decodeGuideValue(url.searchParams.get(name) || '');
                if (decoded === '') {
                    url.searchParams.delete(name);
                } else {
                    url.searchParams.set(name, decoded);
                }
            });
            return url;
        };

        var replaceLocateInUrl = function (key) {
            try {
                var url = sanitizeGuideSearchParams(new URL(window.location.href));
                key = decodeGuideValue(key);
                if (key) {
                    url.searchParams.set('guide_locate', key);
                } else {
                    url.searchParams.delete('guide_locate');
                }
                window.history.replaceState({}, '', url.toString());
            } catch (e) {
                // ignore
            }
        };

        var locateOnPage = function (key) {
            key = decodeGuideValue(key);
            var target = findTarget(key);
            if (!target) {
                return false;
            }
            var templateCard = target.closest('.wsc-template-card');
            if (templateCard) {
                templateCard.classList.add('wsc-guide-template');
            }
            var label = '';
            var floatBtn = findTriggerByKey(key);
            if (floatBtn) {
                label = floatBtn.getAttribute('data-wsc-guide-label') || '';
            }
            setCurrentUi(key, label);
            replaceLocateInUrl(key);
            target.scrollIntoView({behavior: 'smooth', block: 'center'});
            var control = target.querySelector('input:not([type="hidden"]), select, textarea, button');
            if (control && typeof control.focus === 'function') {
                try {
                    control.focus({preventScroll: true});
                } catch (e) {
                    control.focus();
                }
            }
            return true;
        };

        var navigateToTarget = function (trigger, key) {
            key = decodeGuideValue(key);
            var href = (trigger && trigger.getAttribute)
                ? (trigger.getAttribute('data-wsc-guide-href') || '')
                : '';
            if (!href) {
                var fallback = findTriggerByKey(key);
                href = fallback ? (fallback.getAttribute('data-wsc-guide-href') || '') : '';
            }
            if (!href) {
                if (typeof BackendToast !== 'undefined' && BackendToast.warning) {
                    BackendToast.warning(notFoundMsg);
                }
                return false;
            }
            try {
                var url = sanitizeGuideSearchParams(new URL(href, window.location.href));
                if (key) {
                    url.searchParams.set('guide_locate', key);
                }
                window.location.assign(url.toString());
            } catch (e) {
                window.location.href = href;
            }
            return true;
        };

        var locateKey = function (key, trigger) {
            key = decodeGuideValue(key);
            if (!key) {
                return false;
            }
            if (locateOnPage(key)) {
                return true;
            }
            return navigateToTarget(trigger || findTriggerByKey(key), key);
        };

        var autoLocateWithRetry = function (attempt) {
            if (!initialLocate) {
                return;
            }
            if (locateOnPage(initialLocate)) {
                return;
            }
            if (attempt < 8) {
                window.setTimeout(function () {
                    autoLocateWithRetry(attempt + 1);
                }, 120 + attempt * 80);
            }
        };

        var collapseLabel = <?= json_encode((string)__('收起'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var expandLabel = <?= json_encode((string)__('展开'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
        var floatPanel = document.getElementById('wsc-guide-float');
        var floatToggle = floatPanel
            ? floatPanel.querySelector('[data-wsc-guide-float-toggle]')
            : null;
        var floatStorageKey = 'wsc-guide-float-collapsed';

        var setFloatCollapsed = function (collapsed) {
            if (!floatPanel || !floatToggle) {
                return;
            }
            floatPanel.classList.toggle('is-collapsed', !!collapsed);
            floatToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            floatToggle.setAttribute('title', collapsed ? expandLabel : collapseLabel);
            var icon = floatToggle.querySelector('i');
            if (icon) {
                icon.className = collapsed ? 'mdi mdi-chevron-left' : 'mdi mdi-chevron-right';
            }
            try {
                window.sessionStorage.setItem(floatStorageKey, collapsed ? '1' : '0');
            } catch (e) {
                // ignore
            }
        };

        var readFloatCollapsed = function () {
            try {
                return window.sessionStorage.getItem(floatStorageKey) === '1';
            } catch (e) {
                return false;
            }
        };

        setFloatCollapsed(readFloatCollapsed());

        syncModeLabels();
        try {
            var cleanUrl = sanitizeGuideSearchParams(new URL(window.location.href));
            if (cleanUrl.toString() !== window.location.href) {
                window.history.replaceState({}, '', cleanUrl.toString());
            }
        } catch (e) {
            // ignore
        }
        window.setTimeout(function () {
            autoLocateWithRetry(0);
        }, 120);

        document.addEventListener('click', function (event) {
            if (!event.target || !event.target.closest) {
                return;
            }

            var toggle = event.target.closest('[data-wsc-guide-float-toggle]');
            if (toggle) {
                event.preventDefault();
                event.stopPropagation();
                setFloatCollapsed(!(floatPanel && floatPanel.classList.contains('is-collapsed')));
                return;
            }

            if (floatPanel && floatPanel.classList.contains('is-collapsed') && floatPanel.contains(event.target)) {
                event.preventDefault();
                setFloatCollapsed(false);
                return;
            }

            var trigger = event.target.closest('[data-wsc-guide-locate-key], [data-wsc-guide-locate]');
            if (!trigger) {
                return;
            }
            event.preventDefault();
            var key = decodeGuideValue(
                trigger.getAttribute('data-wsc-guide-locate-key') || currentKey || initialLocate || ''
            );
            if (!locateKey(key, trigger)) {
                if (typeof BackendToast !== 'undefined' && BackendToast.warning) {
                    BackendToast.warning(notFoundMsg);
                }
            }
        });
    })();
</script>
<?php endif; ?>
