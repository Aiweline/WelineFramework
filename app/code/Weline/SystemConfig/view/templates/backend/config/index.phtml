<?php if ($guideKey !== ''): ?>
<script>
    (function () {
        var target = document.getElementById('wsc-guide-target');
        if (!target) {
            return;
        }
        window.setTimeout(function () {
            target.scrollIntoView({behavior: 'smooth', block: 'center'});
            target.classList.add('wsc-guide-target--focused');
            var control = target.querySelector('input:not([type="hidden"]), select, textarea, button');
            if (control && typeof control.focus === 'function') {
                control.focus({preventScroll: true});
            }
        }, 180);
    })();
</script>
