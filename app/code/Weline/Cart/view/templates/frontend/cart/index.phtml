<?php
/**
 * Cart page content.
 *
 * The global shell is owned by Weline_Theme cart layouts. This template only
 * renders the cart body that the default cart layout places into its content slot.
 */
$cart = $this->getData('cart') ?? [];
$items = $this->getData('items') ?? [];
$items = \is_array($items) ? $items : [];
$currency = (string)($cart['currency'] ?? '');
$subtotal = (float)($cart['subtotal'] ?? 0);
$grandTotal = (float)($cart['grand_total'] ?? $subtotal);

$formatMoney = static function (float $amount) use ($currency): string {
    $prefix = $currency !== '' ? $currency . ' ' : '';
    return $prefix . \number_format($amount, 2);
};
?>
<section class="weline-cart-shell" data-cart-content="1">
    <div class="weline-cart-shell__header">
        <div>
            <h1><?= __('购物车') ?></h1>
            <p><?= __('检查商品数量，确认无误后进入结账。') ?></p>
        </div>
        <a class="weline-cart-shell__continue" href="/"><?= __('继续购物') ?></a>
    </div>

    <div class="weline-cart-shell__grid">
        <div class="weline-cart-shell__items">
            <table>
                <thead>
                <tr>
                    <th><?= __('商品') ?></th>
                    <th><?= __('单价') ?></th>
                    <th><?= __('数量') ?></th>
                    <th><?= __('小计') ?></th>
                </tr>
                </thead>
                <tbody>
                <?php foreach ($items as $item): ?>
                    <?php if (!\is_array($item)) { continue; } ?>
                    <tr>
                        <td data-label="<?= \htmlspecialchars((string)__('商品'), ENT_QUOTES, 'UTF-8') ?>">
                            <strong><?= \htmlspecialchars((string)($item['name'] ?? ''), ENT_QUOTES, 'UTF-8') ?></strong>
                            <?php if (\trim((string)($item['sku'] ?? '')) !== ''): ?>
                                <small>SKU: <?= \htmlspecialchars((string)$item['sku'], ENT_QUOTES, 'UTF-8') ?></small>
                            <?php endif; ?>
                        </td>
                        <td data-label="<?= \htmlspecialchars((string)__('单价'), ENT_QUOTES, 'UTF-8') ?>"><?= \htmlspecialchars($formatMoney((float)($item['price'] ?? 0)), ENT_QUOTES, 'UTF-8') ?></td>
                        <td data-label="<?= \htmlspecialchars((string)__('数量'), ENT_QUOTES, 'UTF-8') ?>"><?= (int)($item['qty'] ?? 1) ?></td>
                        <td data-label="<?= \htmlspecialchars((string)__('小计'), ENT_QUOTES, 'UTF-8') ?>"><?= \htmlspecialchars($formatMoney((float)($item['row_total'] ?? 0)), ENT_QUOTES, 'UTF-8') ?></td>
                    </tr>
                <?php endforeach; ?>
                </tbody>
            </table>
        </div>

        <aside class="weline-cart-shell__summary" aria-label="<?= \htmlspecialchars((string)__('订单摘要'), ENT_QUOTES, 'UTF-8') ?>">
            <h2><?= __('订单摘要') ?></h2>
            <div class="weline-cart-shell__summary-list">
                <div class="weline-cart-shell__summary-row">
                    <span><?= __('商品数量') ?></span>
                    <strong><?= (int)($cart['cart_count'] ?? 0) ?></strong>
                </div>
                <div class="weline-cart-shell__summary-row">
                    <span><?= __('小计') ?></span>
                    <strong><?= \htmlspecialchars($formatMoney($subtotal), ENT_QUOTES, 'UTF-8') ?></strong>
                </div>
                <div class="weline-cart-shell__summary-row total">
                    <span><?= __('合计') ?></span>
                    <strong><?= \htmlspecialchars($formatMoney($grandTotal), ENT_QUOTES, 'UTF-8') ?></strong>
                </div>
            </div>
            <a class="weline-cart-shell__checkout" href="/checkout"><?= __('去结算') ?></a>
        </aside>
    </div>
</section>

