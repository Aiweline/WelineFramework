<?php
/**
 * 支付方式只读详情页。
 *
 * 普通 key/value 配置由 Weline_SystemConfig 统一保存；本页只展示 Provider 元数据和跳转入口。
 */
$scope = $this->getData('scope') ?? ['scope' => 'default.default.default', 'environment' => 'sandbox'];
$metadata = is_array($this->getData('metadata')) ? $this->getData('metadata') : [];
$runtimeConfig = is_array($this->getData('runtimeConfig')) ? $this->getData('runtimeConfig') : [];
$configFields = is_array($this->getData('configFields')) ? $this->getData('configFields') : [];
$methodCode = (string)$method->getData('code');
$providerModule = (string)$method->getData('provider_module');
$configModule = $providerModule !== '' ? $providerModule : 'Weline_Payment';
$configUrl = $this->getUrl('system_config/backend/index') . '?' . http_build_query([
    'area' => 'backend',
    'scope' => (string)($scope['scope'] ?? 'default.default.default'),
    'module' => $configModule,
    'q' => 'payment/method/' . $methodCode,
]);
$h = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$json = static fn(mixed $value): string => json_encode($value, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT) ?: '{}';
?>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">
                <i class="mdi mdi-pencil me-2"></i><?= __('编辑支付方式') ?>
            </h4>
        </div>
    </div>
</div>

<div class="row">
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center gap-2">
                <h4 class="card-title mb-0">
                    <i class="mdi mdi-credit-card-settings-outline me-2"></i><?= __('支付方式配置入口') ?>
                </h4>
                <a href="<?= $h($configUrl) ?>" class="btn btn-primary">
                    <i class="mdi mdi-cog-outline me-2"></i><?= __('打开系统配置中心') ?>
                </a>
            </div>
            <div class="card-body">
                <div class="alert alert-info mb-4">
                    <?= __('支付方式普通配置、scope 选择、继承来源、保存、校验和缓存失效由系统配置中心统一处理。') ?>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-2 p-3 h-100">
                            <div class="text-muted small mb-1"><?= __('支付方式代码') ?></div>
                            <div class="fw-semibold"><?= $h($methodCode) ?></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-2 p-3 h-100">
                            <div class="text-muted small mb-1"><?= __('支付方式名称') ?></div>
                            <div class="fw-semibold"><?= $h($method->getData('name')) ?></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-2 p-3 h-100">
                            <div class="text-muted small mb-1"><?= __('配置 scope') ?></div>
                            <div class="fw-semibold"><?= $h($scope['scope'] ?? 'default.default.default') ?></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-2 p-3 h-100">
                            <div class="text-muted small mb-1"><?= __('环境') ?></div>
                            <div class="fw-semibold"><?= $h(strtoupper((string)($scope['environment'] ?? 'sandbox'))) ?></div>
                        </div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3"><?= __('Provider 元数据') ?></h5>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <tbody>
                        <tr>
                            <th><?= __('支付提供商') ?></th>
                            <td><?= $h($method->getData('provider_class')) ?></td>
                        </tr>
                        <tr>
                            <th><?= __('模块') ?></th>
                            <td><?= $h($configModule) ?></td>
                        </tr>
                        <tr>
                            <th><?= __('结账模板代码') ?></th>
                            <td><?= $h($metadata['checkout_template_code'] ?? $methodCode) ?></td>
                        </tr>
                        <tr>
                            <th><?= __('配置模板代码') ?></th>
                            <td><?= $h($metadata['config_template_code'] ?? $methodCode) ?></td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <?php if ($configFields !== []): ?>
                    <h5 class="mt-4 mb-3"><?= __('Provider 动态字段') ?></h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead>
                            <tr>
                                <th><?= __('代码') ?></th>
                                <th><?= __('类型') ?></th>
                                <th><?= __('是否必填') ?></th>
                                <th><?= __('说明') ?></th>
                            </tr>
                            </thead>
                            <tbody>
                            <?php foreach ($configFields as $fieldName => $fieldConfig): ?>
                                <?php $fieldConfig = is_array($fieldConfig) ? $fieldConfig : []; ?>
                                <tr>
                                    <td><code><?= $h($fieldConfig['key'] ?? $fieldName) ?></code></td>
                                    <td><?= $h($fieldConfig['type'] ?? 'text') ?></td>
                                    <td><?= !empty($fieldConfig['required']) ? __('是') : __('否') ?></td>
                                    <td><?= $h($fieldConfig['description'] ?? $fieldConfig['label'] ?? '') ?></td>
                                </tr>
                            <?php endforeach; ?>
                            </tbody>
                        </table>
                    </div>
                <?php endif; ?>

                <h5 class="mt-4 mb-3"><?= __('当前运行时配置摘要') ?></h5>
                <pre class="bg-light border rounded-2 p-3 mb-0"><code><?= $h($json($runtimeConfig)) ?></code></pre>

                <div class="mt-3">
                    <a href="<?= $this->getUrl('*/backend/method/index') ?>" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left me-2"></i><?= __('返回') ?>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
