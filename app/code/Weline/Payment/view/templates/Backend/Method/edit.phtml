<script>
(function() {
    'use strict';
    
    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('weline-payment-method-form');
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            var formData = new FormData(form);
            var Toast = window.BackendToast || window.AdminToast;
            window.Weline.Api.request(form.action, { method: 'POST', body: formData })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    if (Toast) Toast.success(data.message || '<?= __('保存成功') ?>');
                    setTimeout(function() {
                        location.href = '<?= $this->getUrl("*/backend/method/index") ?>';
                    }, 1500);
                } else {
                    if (Toast) Toast.error((data && data.message) || '<?= __('保存失败') ?>');
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                if (Toast) Toast.error((error && error.message) || '<?= __('保存失败，请重试') ?>');
            });
        });
    });
})();
</script>
