<script>
(function() {
    'use strict';
    
    function performToggle(code) {
        fetch('<?= $this->getUrl("*/backend/method/toggle") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'code=' + encodeURIComponent(code)
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __('状态已切换') ?>');
                }
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('操作失败') ?>');
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __('操作失败，请重试') ?>');
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.weline-payment-toggle-status').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var code = this.getAttribute('data-code');
                
                if (typeof AdminConfirm !== 'undefined') {
                    AdminConfirm.show({
                        title: '<?= __('确认切换状态') ?>',
                        message: '<?= __('确定要切换支付方式状态吗？') ?>',
                        confirmText: '<?= __('确定切换') ?>',
                        cancelText: '<?= __('取消') ?>',
                        onConfirm: function() {
                            performToggle(code);
                        }
                    });
                } else {
                    performToggle(code);
                }
            });
        });
    });
})();
</script>
