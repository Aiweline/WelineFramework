<script>
document.addEventListener('DOMContentLoaded', function() {
    // 查询支付状态
    document.querySelectorAll('.query-status').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            
            fetch('<?= $this->getUrl("*/backend/transaction/query") ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message || '<?= __('查询成功') ?>');
                    location.reload();
                } else {
                    alert(data.message || '<?= __('查询失败') ?>');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('<?= __('查询失败') ?>');
            });
        });
    });
});
</script>

