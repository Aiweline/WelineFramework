<?php
/**
 * 支付方式选择组件
 *
 * 用于在结账界面展示可用的支付方式。
 */
$esc = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$json = static fn(mixed $value): string => json_encode(
    $value,
    JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
) ?: '{}';

/** @var \Weline\Payment\Block\PaymentMethod $block */
$block = $this->getBlock(\Weline\Payment\Block\PaymentMethod::class);
$methodManager = $block->getMethodManager();
$isFakeMode = (bool)$this->getData('payment_fake_mode');
$methods = $isFakeMode ? $block->getAvailableMethods(['fake_mode' => true]) : $block->getAvailableMethods();
$fakeScenarioPayload = [];
$fakeUnavailableItems = [];

if ($isFakeMode) {
    $fakeUnavailableItems = [
        [
            'code' => 'credit_asset',
            'title' => (string)__('Credit Asset'),
            'description' => (string)__('Requires exchange ratio and payable permission before checkout.'),
            'reason' => (string)__('This asset is not enabled for payment.'),
            'mode' => (string)__('Payment method'),
        ],
        [
            'code' => 'reward_points',
            'title' => (string)__('Reward Points'),
            'description' => (string)__('Can be configured as discount, payment, or both.'),
            'reason' => (string)__('Current currency is not supported.'),
            'mode' => (string)__('Discount or payment'),
        ],
        [
            'code' => 'w_coin',
            'title' => (string)__('W Coin'),
            'description' => (string)__('Can partially deduct payable amount when enabled.'),
            'reason' => (string)__('Current customer country is not supported.'),
            'mode' => (string)__('Payment method'),
        ],
    ];

    foreach ($methods as $method) {
        if (!$method instanceof \Weline\Payment\Model\PaymentMethod) {
            continue;
        }

        $methodCode = (string)$method->getData('code');
        $provider = $methodManager->getProviderInstance($method, ['fake_mode' => true]);
        if (!$provider instanceof \Weline\Payment\Interface\ProviderInterface) {
            $fakeScenarioPayload[$methodCode] = [
                'available' => false,
                'requires_terms' => true,
                'disabled_reason' => (string)__('Payment provider is not ready.'),
                'results' => [],
            ];
            continue;
        }

        $metadata = $methodManager->getProviderMetadata($method, $provider);
        $runtimeConfig = $methodManager->getRuntimeConfig($method, [
            'fake_mode' => true,
            'scope' => 'default.default.default',
            'environment' => 'sandbox',
        ]);
        $amountMinor = 128800;
        $currencyCode = 'CNY';
        $intentCode = 'FAKE-INTENT-' . strtoupper($methodCode);
        $attemptCode = 'FAKE-ATTEMPT-' . strtoupper($methodCode);
        $context = [
            'fake_mode' => true,
            'runtime_config' => $runtimeConfig,
        ];
        $availability = $provider->checkAvailability(\Weline\Payment\Api\Data\AvailabilityRequest::fromArray([
            'payable_type' => 'fake_checkout',
            'payable_id' => 'browser-verification',
            'method_code' => $methodCode,
            'scope' => 'default.default.default',
            'amount_minor' => $amountMinor,
            'currency_code' => $currencyCode,
            'country_code' => 'CN',
            'language_code' => 'zh_Hans_CN',
            'context' => $context,
        ]));
        $baseRequest = [
            'intent_code' => $intentCode,
            'attempt_code' => $attemptCode,
            'payable_type' => 'fake_checkout',
            'payable_id' => 'browser-verification',
            'method_code' => $methodCode,
            'provider_code' => (string)($metadata['provider_code'] ?? ''),
            'scope' => 'default.default.default',
            'amount_minor' => $amountMinor,
            'currency_code' => $currencyCode,
            'idempotency_key' => 'fake-checkout-' . $methodCode,
            'return_url' => '#fake-paid',
            'cancel_url' => '#fake-cancelled',
            'failure_url' => '#fake-failed',
            'context' => $context,
        ];

        $paidResult = $provider->createPayment(\Weline\Payment\Api\Data\PaymentRequest::fromArray($baseRequest + [
            'dynamic_form_values' => ['fake_result' => 'paid'],
        ]));
        $failedResult = $provider->createPayment(\Weline\Payment\Api\Data\PaymentRequest::fromArray($baseRequest + [
            'dynamic_form_values' => ['fake_result' => 'failed'],
        ]));
        $cancelledResult = $provider->createPayment(\Weline\Payment\Api\Data\PaymentRequest::fromArray($baseRequest + [
            'dynamic_form_values' => ['fake_result' => 'cancelled'],
        ]));
        $refundResult = $provider->refund(\Weline\Payment\Api\Data\RefundRequest::fromArray($baseRequest + [
            'refund_code' => 'FAKE-REFUND-' . strtoupper($methodCode),
            'transaction_code' => $paidResult->getProviderReference(),
            'provider_reference' => $paidResult->getProviderReference(),
            'reason_code' => 'browser_verification',
        ]));

        $fakeScenarioPayload[$methodCode] = [
            'available' => $availability->isAvailable(),
            'requires_terms' => $availability->requiresTerms(),
            'disabled_reason' => $availability->getDisabledReasonText() ?: '',
            'amount' => '1,288.00 ' . $currencyCode,
            'method_label' => (string)$method->getData('name'),
            'results' => [
                'paid' => [
                    'title' => (string)__('支付成功'),
                    'status' => $paidResult->getStatus(),
                    'reference' => $paidResult->getProviderReference(),
                    'message' => (string)__('支付订单创建成功'),
                ],
                'failed' => [
                    'title' => (string)__('支付失败'),
                    'status' => $failedResult->getStatus(),
                    'reference' => $failedResult->getProviderReference(),
                    'message' => (string)__('支付未完成，请重试'),
                ],
                'cancelled' => [
                    'title' => (string)__('取消'),
                    'status' => $cancelledResult->getData('action_type') ?: $cancelledResult->getStatus(),
                    'reference' => $cancelledResult->getProviderReference(),
                    'message' => (string)__('取消'),
                ],
                'refunded' => [
                    'title' => (string)__('已退款'),
                    'status' => $refundResult->getStatus(),
                    'reference' => $refundResult->getProviderReference(),
                    'message' => (string)__('已退款'),
                ],
            ],
        ];
    }
}
?>
<div class="payment-methods<?= $isFakeMode ? ' payment-methods--fake' : '' ?>"
     data-fake-mode="<?= $isFakeMode ? '1' : '0' ?>"
     data-fake-scenarios='<?= $esc($json($fakeScenarioPayload)) ?>'
     data-message-select="<?= $esc(__('Select a payment method to continue.')) ?>"
     data-message-terms="<?= $esc(__('Please agree to the payment terms before continuing.')) ?>"
     data-label-selected="<?= $esc(__('Selected payment method:')) ?>"
     data-label-status="<?= $esc(__('状态')) ?>"
     data-label-reference="<?= $esc(__('交易号')) ?>"
     data-label-amount="<?= $esc(__('支付金额')) ?>">
    <div class="payment-methods__head">
        <h3><?= __('支付方式') ?></h3>
        <?php if ($isFakeMode): ?>
            <p><?= __('Used by browser verification only.') ?></p>
        <?php endif; ?>
    </div>

    <w:hook>Weline_Payment::frontend::checkout::payment-methods-before</w:hook>

    <div class="payment-methods-list">
        <?php if (empty($methods)): ?>
            <div class="payment-methods__notice" role="status">
                <?= __('No payment method is available for the current payable object.') ?>
            </div>
        <?php else: ?>
            <div class="payment-methods__grid">
                <?php foreach ($methods as $method): ?>
                    <?php
                    $metadata = $method instanceof \Weline\Payment\Model\PaymentMethod
                        ? $methodManager->getProviderMetadata($method)
                        : [];
                    $display = is_array($metadata['display_metadata'] ?? null) ? $metadata['display_metadata'] : [];
                    $methodCode = (string)($method instanceof \Weline\Payment\Model\PaymentMethod ? $method->getData('code') : '');
                    $methodName = (string)($method instanceof \Weline\Payment\Model\PaymentMethod ? $method->getData('name') : '');
                    $safeMethodId = preg_replace('/[^a-zA-Z0-9_-]+/', '-', $methodCode) ?: 'payment-method';
                    $iconUrl = (string)($display['icon_url'] ?? $display['icon'] ?? '');
                    $description = (string)($display['description'] ?? '');
                    $fakeAvailability = is_array($fakeScenarioPayload[$methodCode] ?? null) ? $fakeScenarioPayload[$methodCode] : [];
                    $isAvailable = !$isFakeMode || !empty($fakeAvailability['available']);
                    ?>
                    <label class="payment-method-card<?= $isAvailable ? '' : ' payment-method-card--disabled' ?>"
                           for="payment_method_<?= $esc($safeMethodId) ?>"
                           data-method-card="<?= $esc($methodCode) ?>">
                        <span class="payment-method-card__choice">
                            <input class="payment-method-card__input"
                                   type="radio"
                                   name="payment_method"
                                   id="payment_method_<?= $esc($safeMethodId) ?>"
                                   value="<?= $esc($methodCode) ?>"
                                   <?= $isAvailable ? '' : 'disabled' ?>>
                            <span class="payment-method-card__body">
                                <span class="payment-method-card__title-row">
                                    <?php if ($iconUrl !== ''): ?>
                                        <img src="<?= $esc($iconUrl) ?>"
                                             alt="<?= $esc($methodName) ?>"
                                             class="payment-method-icon">
                                    <?php endif; ?>
                                    <span class="payment-method-name"><?= $esc($methodName) ?></span>
                                    <?php if ($isFakeMode): ?>
                                        <span class="payment-method-card__badge"><?= __('支付待处理') ?></span>
                                    <?php endif; ?>
                                </span>
                                <?php if ($description !== ''): ?>
                                    <span class="payment-method-description"><?= $esc(__($description)) ?></span>
                                <?php endif; ?>
                                <?php if (!$isAvailable): ?>
                                    <span class="payment-method-card__reason">
                                        <?= $esc($fakeAvailability['disabled_reason'] ?? __('支付方式当前不可用')) ?>
                                    </span>
                                <?php endif; ?>
                            </span>
                        </span>
                    </label>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </div>

    <?php if ($isFakeMode): ?>
        <div class="payment-methods__terms">
            <label class="payment-methods__terms-label">
                <input type="checkbox" class="payment-methods__terms-input" data-payment-terms>
                <span><?= __('I agree to the payment terms.') ?></span>
            </label>
            <div class="payment-methods__feedback" data-payment-feedback aria-live="polite"></div>
        </div>

        <div class="payment-methods__actions" aria-label="<?= $esc(__('支付状态')) ?>">
            <button type="button" class="payment-methods__action payment-methods__action--primary" data-fake-action="paid">
                <?= __('支付成功') ?>
            </button>
            <button type="button" class="payment-methods__action" data-fake-action="failed">
                <?= __('支付失败') ?>
            </button>
            <button type="button" class="payment-methods__action" data-fake-action="cancelled">
                <?= __('取消') ?>
            </button>
            <button type="button" class="payment-methods__action" data-fake-action="refunded">
                <?= __('已退款') ?>
            </button>
        </div>

        <section class="payment-methods__result" data-payment-result hidden>
            <div class="payment-methods__result-status" data-payment-result-title></div>
            <dl class="payment-methods__result-list">
                <div>
                    <dt><?= __('支付方式') ?></dt>
                    <dd data-payment-result-method></dd>
                </div>
                <div>
                    <dt><?= __('支付状态') ?></dt>
                    <dd data-payment-result-status></dd>
                </div>
                <div>
                    <dt><?= __('交易号') ?></dt>
                    <dd data-payment-result-reference></dd>
                </div>
                <div>
                    <dt><?= __('支付金额') ?></dt>
                    <dd data-payment-result-amount></dd>
                </div>
            </dl>
            <p data-payment-result-message></p>
        </section>

        <section class="payment-methods__more">
            <h4><?= __('More') ?></h4>
            <div class="payment-methods__asset-grid">
                <?php foreach ($fakeUnavailableItems as $item): ?>
                    <article class="payment-methods__asset" aria-disabled="true">
                        <div>
                            <strong><?= $esc($item['title']) ?></strong>
                            <span><?= $esc($item['mode']) ?></span>
                        </div>
                        <p><?= $esc($item['description']) ?></p>
                        <em><?= $esc($item['reason']) ?></em>
                    </article>
                <?php endforeach; ?>
            </div>
        </section>
    <?php endif; ?>

    <w:hook>Weline_Payment::frontend::checkout::payment-methods-after</w:hook>

    <w:hook>Weline_Payment::frontend::checkout::payment-form-before</w:hook>

    <div class="payment-form" id="payment-form" hidden></div>

    <w:hook>Weline_Payment::frontend::checkout::payment-form-after</w:hook>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const root = document.querySelector('.payment-methods');
    if (!root) {
        return;
    }

    const paymentMethods = root.querySelectorAll('input[name="payment_method"]');
    const paymentForm = root.querySelector('#payment-form');
    const isFakeMode = root.dataset.fakeMode === '1';

    paymentMethods.forEach(function(radio) {
        radio.addEventListener('change', function() {
            if (paymentForm) {
                paymentForm.hidden = !this.checked;
            }
        });
    });

    if (!isFakeMode) {
        return;
    }

    let scenarios = {};
    try {
        scenarios = JSON.parse(root.dataset.fakeScenarios || '{}');
    } catch (error) {
        scenarios = {};
    }

    const terms = root.querySelector('[data-payment-terms]');
    const feedback = root.querySelector('[data-payment-feedback]');
    const result = root.querySelector('[data-payment-result]');
    const resultTitle = root.querySelector('[data-payment-result-title]');
    const resultMethod = root.querySelector('[data-payment-result-method]');
    const resultStatus = root.querySelector('[data-payment-result-status]');
    const resultReference = root.querySelector('[data-payment-result-reference]');
    const resultAmount = root.querySelector('[data-payment-result-amount]');
    const resultMessage = root.querySelector('[data-payment-result-message]');

    const setFeedback = function(message) {
        if (feedback) {
            feedback.textContent = message || '';
        }
    };

    root.querySelectorAll('[data-fake-action]').forEach(function(button) {
        button.addEventListener('click', function() {
            const selected = root.querySelector('input[name="payment_method"]:checked');
            if (!selected) {
                setFeedback(root.dataset.messageSelect || '');
                return;
            }
            if (terms && !terms.checked) {
                setFeedback(root.dataset.messageTerms || '');
                return;
            }

            const scenario = scenarios[selected.value] || {};
            const action = button.dataset.fakeAction || 'paid';
            const entry = (scenario.results || {})[action];
            if (!entry) {
                setFeedback(scenario.disabled_reason || '');
                return;
            }

            setFeedback('');
            if (result) {
                result.hidden = false;
                result.dataset.status = action;
            }
            if (resultTitle) {
                resultTitle.textContent = entry.title || '';
            }
            if (resultMethod) {
                resultMethod.textContent = scenario.method_label || selected.value;
            }
            if (resultStatus) {
                resultStatus.textContent = entry.status || '';
            }
            if (resultReference) {
                resultReference.textContent = entry.reference || '';
            }
            if (resultAmount) {
                resultAmount.textContent = scenario.amount || '';
            }
            if (resultMessage) {
                resultMessage.textContent = entry.message || '';
            }
        });
    });
});
</script>

