<!-- 页面标题 -->
<div class="page-title">
    <h1><?= $title ?? '循环依赖检测' ?></h1>
    <div class="page-actions">
        <a href="*/backend/extends/index" class="btn btn-secondary">
            <i class="mdi mdi-arrow-left"></i> 返回列表
        </a>
        <a href="*/backend/extends/refresh" class="btn btn-warning">
            <i class="mdi mdi-refresh"></i> 刷新注册表
        </a>
    </div>
</div>

<!-- 检测结果 -->
<?php
$cycles = $this->getData('cycles') ?? [];
?>
<div class="detection-result">
    <?php if (empty($cycles)): ?>
        <div class="success-message">
            <div class="icon">
                <i class="mdi mdi-check-circle"></i>
            </div>
            <h2>未检测到循环依赖</h2>
            <p>所有模块的扩展关系都是正常的，没有发现循环依赖问题。</p>
        </div>
    <?php else: ?>
        <div class="error-message">
            <div class="icon">
                <i class="mdi mdi-alert-circle"></i>
            </div>
            <h2>检测到 <?= count($cycles) ?> 个循环依赖</h2>
            <p>以下模块之间存在循环依赖关系，请检查并修复：</p>
        </div>
        
        <div class="cycles-list">
            <?php foreach ($cycles as $index => $cycle): ?>
                <div class="cycle-item">
                    <div class="cycle-header">
                        <h3>循环依赖 #<?= $index + 1 ?></h3>
                        <span class="cycle-length"><?= count($cycle) ?> 个模块</span>
                    </div>
                    <div class="cycle-path">
                        <?php
                        $cyclePath = [];
                        foreach ($cycle as $module) {
                            $cyclePath[] = '<strong>' . htmlspecialchars($module) . '</strong>';
                        }
                        // 形成循环路径
                        $cyclePath[] = '<strong>' . htmlspecialchars($cycle[0]) . '</strong>';
                        ?>
                        <div class="path">
                            <?= implode(' <i class="mdi mdi-arrow-right"></i> ', $cyclePath) ?>
                        </div>
                    </div>
                    <div class="cycle-details">
                        <h4>详细说明：</h4>
                        <ul>
                            <?php for ($i = 0; $i < count($cycle); $i++): ?>
                                <?php
                                $current = $cycle[$i];
                                $next = $cycle[($i + 1) % count($cycle)];
                                ?>
                                <li>
                                    <strong><?= htmlspecialchars($current) ?></strong> 
                                    扩展了 
                                    <strong><?= htmlspecialchars($next) ?></strong>
                                    <a href="*/backend/extends/moduleDetail/module/<?= urlencode($next) ?>" 
                                       class="btn btn-sm btn-outline-primary">查看详情</a>
                                </li>
                            <?php endfor; ?>
                        </ul>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
        
        <div class="warning-box">
            <h4><i class="mdi mdi-information"></i> 如何解决循环依赖？</h4>
            <ol>
                <li>检查循环依赖链中的每个模块，找出不必要的扩展关系</li>
                <li>考虑将共同的功能提取到一个独立的模块中</li>
                <li>重新设计模块间的依赖关系，避免相互依赖</li>
                <li>如果确实需要相互扩展，考虑使用事件机制或观察者模式</li>
            </ol>
        </div>
    <?php endif; ?>
</div>

