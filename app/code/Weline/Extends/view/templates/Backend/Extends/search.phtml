<!-- 页面标题 -->
<div class="page-title">
    <h1><?= $title ?? '扩展搜索' ?></h1>
    <div class="page-actions">
        <a href="*/backend/extends/index" class="btn btn-secondary">
            <i class="mdi mdi-arrow-left"></i> 返回列表
        </a>
    </div>
</div>

<!-- 搜索表单 -->
<div class="search-form">
    <form method="get" action="*/backend/extends/search">
        <div class="form-group">
            <input type="text" name="q" value="<?= htmlspecialchars($search_term ?? '') ?>" 
                   placeholder="搜索模块名、扩展点、文件路径..." class="form-control">
        </div>
        <div class="form-group">
            <select name="type" class="form-control">
                <option value="all" <?= ($search_type ?? 'all') === 'all' ? 'selected' : '' ?>>全部类型</option>
                <option value="sticker" <?= ($search_type ?? '') === 'sticker' ? 'selected' : '' ?>>Sticker 扩展</option>
                <option value="module" <?= ($search_type ?? '') === 'module' ? 'selected' : '' ?>>模块扩展</option>
                <option value="theme" <?= ($search_type ?? '') === 'theme' ? 'selected' : '' ?>>主题扩展</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">
            <i class="mdi mdi-magnify"></i> 搜索
        </button>
    </form>
</div>

<!-- 搜索结果 -->
<?php
$results = $this->getData('results') ?? [];
?>
<div class="search-results">
    <?php if (empty($search_term ?? '')): ?>
        <div class="empty-state">
            <i class="mdi mdi-magnify"></i>
            <h3>请输入搜索关键词</h3>
            <p>在搜索框中输入模块名、扩展点名称或文件路径进行搜索。</p>
        </div>
    <?php elseif (empty($results)): ?>
        <div class="empty-state">
            <i class="mdi mdi-magnify"></i>
            <h3>未找到匹配结果</h3>
            <p>没有找到与 "<?= htmlspecialchars($search_term ?? '') ?>" 相关的扩展信息。</p>
        </div>
    <?php else: ?>
        <div class="results-summary">
            <p>找到 <strong><?= count($results) ?></strong> 个模块的匹配结果</p>
        </div>
        
        <?php foreach ($results as $moduleName => $moduleResults): ?>
            <div class="result-module">
                <h3>
                    <i class="mdi mdi-cube"></i>
                    <?= htmlspecialchars($moduleName) ?>
                    <span class="count"><?= count($moduleResults) ?> 个匹配项</span>
                </h3>
                
                <div class="result-items">
                    <?php foreach ($moduleResults as $result): ?>
                        <div class="result-item">
                            <div class="result-type">
                                <?php
                                $type = $result['type'] ?? 'unknown';
                                $typeLabels = [
                                    'module_name' => '模块名',
                                    'extends_definition' => '扩展定义',
                                    'extended_by' => '被扩展',
                                    'extension_file' => '扩展文件'
                                ];
                                ?>
                                <span class="badge badge-info"><?= $typeLabels[$type] ?? $type ?></span>
                            </div>
                            
                            <div class="result-content">
                                <?php if ($type === 'module_name'): ?>
                                    <p>模块：<strong><?= htmlspecialchars($moduleName) ?></strong></p>
                                    <a href="*/backend/extends/moduleDetail/module/<?= urlencode($moduleName) ?>" 
                                       class="btn btn-sm btn-outline-primary">查看详情</a>
                                    
                                <?php elseif ($type === 'extends_definition'): ?>
                                    <p><strong>扩展点：</strong><?= htmlspecialchars($result['extend_name'] ?? '') ?></p>
                                    <p><strong>描述：</strong><?= htmlspecialchars($result['data']['description'] ?? '') ?></p>
                                    <p><strong>路径：</strong><code><?= htmlspecialchars($result['data']['path'] ?? '') ?></code></p>
                                    
                                <?php elseif ($type === 'extended_by'): ?>
                                    <p><strong>源模块：</strong><?= htmlspecialchars($result['source_module'] ?? '') ?></p>
                                    <p><strong>扩展数量：</strong><?= count($result['data'] ?? []) ?></p>
                                    
                                <?php elseif ($type === 'extension_file'): ?>
                                    <p><strong>源模块：</strong><?= htmlspecialchars($result['source_module'] ?? '') ?></p>
                                    <p><strong>文件路径：</strong><code><?= htmlspecialchars($result['extension']['file_path'] ?? '') ?></code></p>
                                    <p><strong>源文件：</strong><code class="small"><?= htmlspecialchars($result['extension']['source_file'] ?? '') ?></code></p>
                                <?php endif; ?>
                            </div>
                        </div>
                    <?php endforeach; ?>
                </div>
            </div>
        <?php endforeach; ?>
    <?php endif; ?>
</div>

