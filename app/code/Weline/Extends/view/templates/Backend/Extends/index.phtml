                                                        $completeness = $data['completeness'] ?? [];
                                                        
                                                        // 统计被扩展数量
                                                        $totalExtendedBy = 0;
                                                        $stickerExtensions = 0;
                                                        $moduleExtensions = 0;
                                                        $themeExtensions = 0;
                                                        
