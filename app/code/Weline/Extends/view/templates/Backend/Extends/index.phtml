<?php
$stats = $this->getData('stats') ?? [];
$extends = $this->getData('extends') ?? [];
$searchKeyword = (string) $this->request->getGet('search', '');
$hasSearch = trim($searchKeyword) !== '';

$extendsFilterMatch = static function (string $moduleName, array $data, string $keyword): bool {
    $searchLower = strtolower($keyword);
    $moduleNameLower = strtolower($moduleName);
    $extendsDef = $data['extends'] ?? [];
    if (str_contains($moduleNameLower, $searchLower)) {
        return true;
    }
    if (!empty($extendsDef['extends'])) {
        foreach ($extendsDef['extends'] as $extendName => $extendConfig) {
            if (stripos((string) $extendName, $keyword) !== false
                || stripos((string) ($extendConfig['description'] ?? ''), $keyword) !== false) {
                return true;
            }
        }
    }
    return false;
};

$filteredExtends = [];
if (!empty($extends)) {
    foreach ($extends as $moduleName => $data) {
        if ($hasSearch && !$extendsFilterMatch($moduleName, $data, $searchKeyword)) {
            continue;
        }
        $filteredExtends[$moduleName] = $data;
    }
}
