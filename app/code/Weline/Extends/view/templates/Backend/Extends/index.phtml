            <div class="card-value"><?= $stats['modules_with_extends'] ?? 0 ?></div>
        </div>
    </div>
    <div class="card">
        <div class="card-content">
            <div class="card-title">被扩展的模块</div>
            <div class="card-value"><?= $stats['modules_extended_by_others'] ?? 0 ?></div>
        </div>
    </div>
    <div class="card">
        <div class="card-content">
            <div class="card-title">Sticker 扩展数</div>
