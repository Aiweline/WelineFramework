<!-- 扩展列表 -->
<?php
$extends = $this->getData('extends') ?? [];
$searchKeyword = $this->request->getGet('search', '');
?>
<div class='row'>
    <div class='col-12'>
        <div class='card'>
            <div class='card-body'>
                <!-- 搜索过滤 -->
                <div class='row align-items-center mb-3'>
                    <div class='col-md-4'>
                        <block class='Weline\Component\Block\Form\Search'
                               id='extends-search' 
                               action='*/backend/extends/index' 
                               method='get'
                               keyword='search' 
                               value='<?= htmlspecialchars($searchKeyword) ?>'
                               placeholder='<lang>请输入模块名或扩展点关键词回车搜索</lang>'></block>
                    </div>
                    <div class='col-md-8 text-end'>
                        <?php if (!empty($searchKeyword)): ?>
                            <a href="@backend-url('*/backend/extends/index')" class="btn btn-sm btn-outline-secondary">
                                <i class="mdi mdi-close"></i> <lang>清除搜索</lang>
                            </a>
                        <?php endif; ?>
                    </div>
                </div>
                
                <?php if (empty($extends)): ?>
                    <div class="weline-extends-empty-state">
                        <i class="mdi mdi-puzzle-outline"></i>
                        <h3><lang>暂无扩展信息</lang></h3>
                        <p><lang>系统中还没有定义任何扩展点或扩展关系。</lang></p>
                    </div>
                <?php else: ?>
                    <div class="weline-extends-table-container">
                        <div class='table-responsive mb-0' data-pattern='priority-columns'>
                            <table class='table table-striped table-bordered'>
                                <thead>
                                    <tr>
                                        <th><lang>模块名</lang></th>
                                        <th><lang>扩展定义</lang></th>
                                        <th><lang>被扩展统计</lang></th>
                                        <th><lang>Sticker 扩展</lang></th>
                                        <th><lang>操作</lang></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <?php 
                                    $displayCount = 0;
                                    foreach ($extends as $moduleName => $data): 
                                        // 搜索过滤
                                        if (!empty($searchKeyword)) {
                                            $searchLower = strtolower($searchKeyword);
                                            $moduleNameLower = strtolower($moduleName);
                                            $extendsDef = $data['extends'] ?? [];
                                            $extendedBy = $data['extended_by'] ?? [];
                                            
                                            // 检查模块名是否匹配
                                            $matchModuleName = strpos($moduleNameLower, $searchLower) !== false;
                                            
                                            // 检查扩展点是否匹配
                                            $matchExtendPoints = false;
                                            if (!empty($extendsDef['extends'])) {
                                                foreach ($extendsDef['extends'] as $extendName => $extendConfig) {
                                                    if (stripos($extendName, $searchKeyword) !== false || 
                                                        stripos($extendConfig['description'] ?? '', $searchKeyword) !== false) {
                                                        $matchExtendPoints = true;
                                                        break;
                                                    }
                                                }
                                            }
                                            
                                            // 如果都不匹配，跳过
                                            if (!$matchModuleName && !$matchExtendPoints) {
                                                continue;
                                            }
                                        }
                                        $displayCount++;
                                        
                                        $extendsDef = $data['extends'] ?? [];
                                        $extendedBy = $data['extended_by'] ?? [];
                                        $completeness = $data['completeness'] ?? [];
                                        
                                        // 统计被扩展数量
                                        $totalExtendedBy = 0;
                                        $stickerExtensions = 0;
                                        $moduleExtensions = 0;
                                        $themeExtensions = 0;
                                        
                                        foreach ($extendedBy as $sourceModule => $extensions) {
                                            $totalExtendedBy += count($extensions);
                                            foreach ($extensions as $extension) {
                                                if (($extension['is_sticker_extension'] ?? false) === true) {
                                                    $stickerExtensions++;
                                                } elseif (($extension['type'] ?? '') === 'module') {
                                                    $moduleExtensions++;
                                                } elseif (($extension['type'] ?? '') === 'theme') {
                                                    $themeExtensions++;
                                                }
                                            }
                                        }
                                        ?>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <strong class="text-dark"><?= htmlspecialchars($moduleName) ?></strong>
                                                    <?php if (!empty($completeness['errors'])): ?>
                                                        <span class="badge bg-danger" title="<lang>有错误</lang>"><lang>错误</lang></span>
                                                    <?php endif; ?>
                                                    <?php if (!empty($completeness['warnings'])): ?>
                                                        <span class="badge bg-warning text-dark" title="<lang>有警告</lang>"><lang>警告</lang></span>
                                                    <?php endif; ?>
                                                </div>
                                            </td>
                                            <td>
                                                <?php if (!empty($extendsDef)): ?>
                                                    <div class="weline-extends-def">
                                                        <div class="weline-extends-type">
                                                            <span class="badge badge-info"><?= $extendsDef['type'] ?? 'unknown' ?></span>
                                                        </div>
                                                        <div class="weline-extends-points">
                                                            <?php
                                                            $extendPoints = $extendsDef['extends'] ?? [];
                                                            $pointCount = count($extendPoints);
                                                            ?>
                                                            <small><?= $pointCount ?> <lang>个扩展点</lang></small>
                                                        </div>
                                                    </div>
                                                <?php else: ?>
                                                    <span class="text-muted"><lang>无扩展定义</lang></span>
                                                <?php endif; ?>
                                            </td>
                                            <td>
                                                <div class="weline-extends-extension-stats">
                                                    <span class="weline-extends-stat-item">
                                                        <i class="mdi mdi-puzzle"></i> <lang>总计</lang>: <?= $totalExtendedBy ?>
                                                    </span>
                                                    <?php if ($moduleExtensions > 0): ?>
                                                        <span class="weline-extends-stat-item">
                                                            <i class="mdi mdi-cube"></i> <lang>模块</lang>: <?= $moduleExtensions ?>
                                                        </span>
                                                    <?php endif; ?>
                                                    <?php if ($themeExtensions > 0): ?>
                                                        <span class="weline-extends-stat-item">
                                                            <i class="mdi mdi-theme-light-dark"></i> <lang>主题</lang>: <?= $themeExtensions ?>
                                                        </span>
                                                    <?php endif; ?>
                                                </div>
                                            </td>
                                            <td>
                                                <?php if ($stickerExtensions > 0): ?>
                                                    <span class="badge badge-primary">
                                                        <i class="mdi mdi-sticker"></i> <?= $stickerExtensions ?> <lang>个 Sticker</lang>
                                                    </span>
                                                <?php else: ?>
                                                    <span class="text-muted"><lang>无 Sticker 扩展</lang></span>
                                                <?php endif; ?>
                                            </td>
                                            <td>
                                                <div class="actions d-flex gap-2">
                                                    <block class='Weline\Component\Block\OffCanvas'
                                                           template='Weline_Component::off-canvas.phtml'
                                                           cache='0'
                                                           id='off_canvas_extends_detail_<?= md5($moduleName) ?>'
                                                           action='*/backend/extends/moduleDetail'
                                                           action-params='{module: "<?= htmlspecialchars($moduleName, ENT_QUOTES) ?>"}'
                                                           title='<lang>模块扩展详情</lang>: <?= htmlspecialchars($moduleName) ?>'
                                                           close-button-show='1'
                                                           close-button-text='<lang>关闭</lang>'
                                                           direction='right'
                                                           class-names='w-75'
                                                           off-canvas-body-style=''
                                                           target-button-text='<lang>详情</lang>'
                                                           target-button-class='btn btn-sm btn-outline-primary'
                                                           target-tag='button'
                                                           save='0'
                                                    />
                                                    <?php if ($stickerExtensions > 0): ?>
                                                        <block class='Weline\Component\Block\OffCanvas'
                                                               template='Weline_Component::off-canvas.phtml'
                                                               cache='0'
                                                               id='off_canvas_extends_sticker_<?= md5($moduleName) ?>'
                                                               action='*/backend/extends/moduleDetail'
                                                               action-params='{module: "<?= htmlspecialchars($moduleName, ENT_QUOTES) ?>", anchor: "sticker"}'
                                                               title='<lang>Sticker 扩展详情</lang>: <?= htmlspecialchars($moduleName) ?>'
                                                               close-button-show='1'
                                                               close-button-text='<lang>关闭</lang>'
                                                               direction='right'
                                                               class-names='w-75'
                                                               off-canvas-body-style=''
                                                               target-button-text='Sticker'
                                                               target-button-class='btn btn-sm btn-outline-info'
                                                               target-tag='button'
                                                               save='0'
                                                        />
                                                    <?php endif; ?>
                                                </div>
                                            </td>
                                        </tr>
                                        
                                        <!-- 展开的详细信息 -->
                                        <?php if (!empty($completeness['warnings']) || !empty($completeness['errors'])): ?>
                                            <tr class="weline-extends-completeness-row">
                                                <td colspan="5">
                                                    <div class="weline-extends-completeness-info">
                                                        <?php if (!empty($completeness['errors'])): ?>
                                                            <div class="alert alert-danger">
                                                                <strong><lang>错误</lang>：</strong>
                                                                <ul>
                                                                    <?php foreach ($completeness['errors'] as $error): ?>
                                                                        <li><?= htmlspecialchars($error) ?></li>
                                                                    <?php endforeach; ?>
                                                                </ul>
                                                            </div>
                                                        <?php endif; ?>
                                                        
                                                        <?php if (!empty($completeness['warnings'])): ?>
                                                            <div class="alert alert-warning">
                                                                <strong><lang>警告</lang>：</strong>
                                                                <ul>
                                                                    <?php foreach ($completeness['warnings'] as $warning): ?>
                                                                        <li><?= htmlspecialchars($warning) ?></li>
                                                                    <?php endforeach; ?>
                                                                </ul>
                                                            </div>
                                                        <?php endif; ?>
                                                    </div>
                                                </td>
                                            </tr>
                                        <?php endif; ?>
                                    <?php endforeach; ?>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <?php if (!empty($searchKeyword) && $displayCount === 0): ?>
                        <div class="weline-extends-empty-state">
                            <i class="mdi mdi-magnify"></i>
                            <h3><lang>未找到匹配的扩展</lang></h3>
                            <p><lang>搜索关键词</lang>："<?= htmlspecialchars($searchKeyword) ?>" <lang>没有找到匹配的模块或扩展点</lang>。</p>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

