<!-- 扩展列表 -->
<?php
$extends = $this->getData('extends') ?? [];
?>
<div class="extends-list">
    <?php if (empty($extends)): ?>
        <div class="empty-state">
            <i class="mdi mdi-puzzle-outline"></i>
            <h3>暂无扩展信息</h3>
            <p>系统中还没有定义任何扩展点或扩展关系。</p>
        </div>
    <?php else: ?>
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>模块名</th>
                        <th>扩展定义</th>
                        <th>被扩展统计</th>
                        <th>Sticker 扩展</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($extends as $moduleName => $data): ?>
                        <?php
                        $extendsDef = $data['extends'] ?? [];
                        $extendedBy = $data['extended_by'] ?? [];
                        $completeness = $data['completeness'] ?? [];
                        
                        // 统计被扩展数量
                        $totalExtendedBy = 0;
                        $stickerExtensions = 0;
                        $moduleExtensions = 0;
                        $themeExtensions = 0;
                        
                        foreach ($extendedBy as $sourceModule => $extensions) {
                            $totalExtendedBy += count($extensions);
                            foreach ($extensions as $extension) {
                                if (($extension['is_sticker_extension'] ?? false) === true) {
                                    $stickerExtensions++;
                                } elseif (($extension['type'] ?? '') === 'module') {
                                    $moduleExtensions++;
                                } elseif (($extension['type'] ?? '') === 'theme') {
                                    $themeExtensions++;
                                }
                            }
                        }
                        ?>
                        <tr>
                            <td>
                                <div class="module-name">
                                    <strong><?= htmlspecialchars($moduleName) ?></strong>
                                    <?php if (!empty($completeness['errors'])): ?>
                                        <span class="badge badge-danger" title="有错误">错误</span>
                                    <?php endif; ?>
                                    <?php if (!empty($completeness['warnings'])): ?>
                                        <span class="badge badge-warning" title="有警告">警告</span>
                                    <?php endif; ?>
                                </div>
                            </td>
                            <td>
                                <?php if (!empty($extendsDef)): ?>
                                    <div class="extends-def">
                                        <div class="extend-type">
                                            <span class="badge badge-info"><?= $extendsDef['type'] ?? 'unknown' ?></span>
                                        </div>
                                        <div class="extend-points">
                                            <?php
                                            $extendPoints = $extendsDef['extends'] ?? [];
                                            $pointCount = count($extendPoints);
                                            ?>
                                            <small><?= $pointCount ?> 个扩展点</small>
                                        </div>
                                    </div>
                                <?php else: ?>
                                    <span class="text-muted">无扩展定义</span>
                                <?php endif; ?>
                            </td>
                            <td>
                                <div class="extension-stats">
                                    <span class="stat-item">
                                        <i class="mdi mdi-puzzle"></i> 总计: <?= $totalExtendedBy ?>
                                    </span>
                                    <?php if ($moduleExtensions > 0): ?>
                                        <span class="stat-item">
                                            <i class="mdi mdi-cube"></i> 模块: <?= $moduleExtensions ?>
                                        </span>
                                    <?php endif; ?>
                                    <?php if ($themeExtensions > 0): ?>
                                        <span class="stat-item">
                                            <i class="mdi mdi-theme-light-dark"></i> 主题: <?= $themeExtensions ?>
                                        </span>
                                    <?php endif; ?>
                                </div>
                            </td>
                            <td>
                                <?php if ($stickerExtensions > 0): ?>
                                    <span class="badge badge-primary">
                                        <i class="mdi mdi-sticker"></i> <?= $stickerExtensions ?> 个 Sticker
                                    </span>
                                <?php else: ?>
                                    <span class="text-muted">无 Sticker 扩展</span>
                                <?php endif; ?>
                            </td>
                            <td>
                                <div class="actions">
                                    <a href="*/backend/extends/moduleDetail/module/<?= urlencode($moduleName) ?>" 
                                       class="btn btn-sm btn-outline-primary" title="查看详情">
                                        <i class="mdi mdi-eye"></i> 详情
                                    </a>
                                    <?php if ($stickerExtensions > 0): ?>
                                        <a href="*/backend/extends/moduleDetail/module/<?= urlencode($moduleName) ?>#sticker" 
                                           class="btn btn-sm btn-outline-info" title="查看 Sticker 扩展">
                                            <i class="mdi mdi-sticker"></i> Sticker
                                        </a>
                                    <?php endif; ?>
                                </div>
                            </td>
                        </tr>
                        
                        <!-- 展开的详细信息 -->
                        <?php if (!empty($completeness['warnings']) || !empty($completeness['errors'])): ?>
                            <tr class="completeness-row">
                                <td colspan="5">
                                    <div class="completeness-info">
                                        <?php if (!empty($completeness['errors'])): ?>
                                            <div class="alert alert-danger">
                                                <strong>错误：</strong>
                                                <ul>
                                                    <?php foreach ($completeness['errors'] as $error): ?>
                                                        <li><?= htmlspecialchars($error) ?></li>
                                                    <?php endforeach; ?>
                                                </ul>
                                            </div>
                                        <?php endif; ?>
                                        
                                        <?php if (!empty($completeness['warnings'])): ?>
                                            <div class="alert alert-warning">
                                                <strong>警告：</strong>
                                                <ul>
                                                    <?php foreach ($completeness['warnings'] as $warning): ?>
                                                        <li><?= htmlspecialchars($warning) ?></li>
                                                    <?php endforeach; ?>
                                                </ul>
                                            </div>
                                        <?php endif; ?>
                                    </div>
                                </td>
                            </tr>
                        <?php endif; ?>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    <?php endif; ?>
</div>

