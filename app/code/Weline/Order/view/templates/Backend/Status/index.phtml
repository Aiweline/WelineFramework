<script>
(function() {
    'use strict';
    
    function performDelete(id) {
        fetch('<?= $this->getBackendUrl("order/backend/status/delete") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'id=' + encodeURIComponent(id)
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __('状态已删除') ?>');
                }
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __('删除失败') ?>');
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __('删除失败，请重试') ?>');
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        // 切换启用状态
        document.querySelectorAll('.weline-order-toggle-status').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var id = this.getAttribute('data-id');
                
                fetch('<?= $this->getBackendUrl("order/backend/status/toggle") ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'id=' + encodeURIComponent(id)
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        if (typeof AdminToast !== 'undefined') {
                            AdminToast.error(data.message || '<?= __('操作失败') ?>');
                        }
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.error('<?= __('操作失败，请重试') ?>');
                    }
                });
            });
        });
        
        // 删除状态
        document.querySelectorAll('.weline-order-delete-status').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var id = this.getAttribute('data-id');
                var code = this.getAttribute('data-code');
                
                if (typeof AdminConfirm !== 'undefined') {
                    AdminConfirm.show({
                        title: '<?= __('确认删除') ?>',
                        message: '<?= __('确定要删除状态') ?> ' + code + ' <?= __('吗？') ?>',
                        confirmText: '<?= __('确定删除') ?>',
                        cancelText: '<?= __('取消') ?>',
                        type: 'danger',
                        onConfirm: function() {
                            performDelete(id);
                        }
                    });
                } else {
                    performDelete(id);
                }
            });
        });
    });
})();
</script>
