<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('status-form');
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        fetch(form.action, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message || '<?= __('保存成功') ?>');
                location.href = '<?= $this->getBackendUrl("order/backend/status/index") ?>';
            } else {
                alert(data.message || '<?= __('保存失败') ?>');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __('保存失败') ?>');
        });
    });
});
</script>

