<?php
/**
 * Weline_Order module - header orders entry.
 *
 * Hook: header-orders
 *
 * @hook-priority 160
 * @hook-sort-order 10
 * @hook-solo false
 */
$GLOBALS['__weline_order_header_orders_rendered'] = true;
$accountIndexPath = parse_url($this->getFrontendUrl('customer/account/index'), PHP_URL_PATH);
if (!is_string($accountIndexPath) || $accountIndexPath === '') {
    $accountIndexPath = '/customer/account/index';
}
$accountIndexPath = rtrim($accountIndexPath, '/');
?>
<a href="<?= htmlspecialchars($accountIndexPath, ENT_QUOTES, 'UTF-8') ?>#orders"
   class="action-link"
   title="<?= __('我的订单') ?>"
   aria-label="<?= __('我的订单') ?>">
    <span class="action-line-1"><?= __('退货') ?></span>
    <span class="action-line-2"><?= __('与我的订单') ?></span>
</a>
