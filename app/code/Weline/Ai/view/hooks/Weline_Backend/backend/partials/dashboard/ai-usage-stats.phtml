            <div>
                <h6 class="text-muted mb-2"><lang>AI 使用统计</lang>（<lang>今日</lang>）</h6>
                <p class="mb-1"><strong><?= number_format((int)($summary['total_tokens'] ?? 0)) ?></strong> <lang>总令牌</lang></p>
                <p class="mb-0 text-muted small">¥ <?= htmlspecialchars($summary['total_cost_formatted'] ?? '0.00') ?> <lang>约花费</lang></p>
            </div>
            <a href="<?= htmlspecialchars($statsUrl) ?>" class="btn btn-sm btn-outline-primary">
