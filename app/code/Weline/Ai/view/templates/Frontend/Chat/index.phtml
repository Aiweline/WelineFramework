<script>
let isProcessing = false;
let aiApiPromise = null;

function getAiApi() {
    if (!aiApiPromise) {
        aiApiPromise = (async function() {
            if (window.Weline && typeof window.Weline.load === 'function') {
                await window.Weline.load('api');
            }
            if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
                throw new Error('Weline.Api.resource is unavailable.');
            }
            return window.Weline.Api.resource('ai');
        })();
    }
    return aiApiPromise;
}

function toggleSettings() {
    const panel = document.getElementById('settingsPanel');
    panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
}

function appendTextMessage(target, className, prefix, message) {
    target.textContent = '';
    const span = document.createElement('span');
    if (className) {
        span.className = className;
    }
    span.textContent = String(prefix || '') + String(message || '');
    target.appendChild(span);
}

function createWelcomeMessage() {
    const wrapper = document.createElement('div');
    wrapper.className = 'welcome-message';

    const icon = document.createElement('i');
    icon.className = 'mdi mdi-robot mdi-48px';

    const title = document.createElement('h4');
    title.textContent = '<?= addslashes(__('欢迎使用AI聊天助手！')) ?>';

    const copy = document.createElement('p');
    copy.textContent = '<?= addslashes(__('请输入您的问题，我会尽力为您解答。')) ?>';

    wrapper.appendChild(icon);
    wrapper.appendChild(title);
    wrapper.appendChild(copy);
    return wrapper;
}

function confirmClearChat() {
    return new Promise(function(resolve) {
        const overlay = document.createElement('div');
        overlay.className = 'chat-confirm-overlay';

        const dialog = document.createElement('div');
        dialog.className = 'chat-confirm-dialog';
        dialog.setAttribute('role', 'dialog');
        dialog.setAttribute('aria-modal', 'true');

        const message = document.createElement('p');
        message.textContent = '<?= addslashes(__('确定要清空聊天记录吗？')) ?>';

        const actions = document.createElement('div');
        actions.className = 'chat-confirm-actions';

        const cancel = document.createElement('button');
        cancel.type = 'button';
        cancel.className = 'btn btn-sm btn-outline-secondary';
        cancel.textContent = '<?= addslashes(__('取消')) ?>';

        const clear = document.createElement('button');
        clear.type = 'button';
        clear.className = 'btn btn-sm btn-danger';
        clear.textContent = '<?= addslashes(__('清空')) ?>';

        const close = function(value) {
            overlay.remove();
            resolve(value);
        };

        cancel.addEventListener('click', function() { close(false); });
        clear.addEventListener('click', function() { close(true); });
        overlay.addEventListener('click', function(event) {
            if (event.target === overlay) {
                close(false);
            }
        });

        actions.appendChild(cancel);
        actions.appendChild(clear);
        dialog.appendChild(message);
        dialog.appendChild(actions);
        overlay.appendChild(dialog);
        document.body.appendChild(overlay);
        cancel.focus();
    });
}

async function clearChat() {
    if (!(await confirmClearChat())) {
        return;
    }

    const messagesContainer = document.getElementById('chatMessages');
    messagesContainer.textContent = '';
    messagesContainer.appendChild(createWelcomeMessage());
}

function handleKeyDown(event) {
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const chatForm = document.getElementById('chatForm');
    const messageInput = document.getElementById('messageInput');
    if (chatForm) {
        chatForm.addEventListener('submit', function(event) {
            event.preventDefault();
            sendMessage();
        });
    }
    if (messageInput) {
        messageInput.addEventListener('keydown', handleKeyDown);
    }
    document.addEventListener('click', function(event) {
        const trigger = event.target.closest('[data-ai-chat-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();
        const action = trigger.getAttribute('data-ai-chat-action');
        if (action === 'toggle-settings') {
            toggleSettings();
        } else if (action === 'clear-chat') {
            clearChat();
        }
    });
});

async function sendMessage() {
    if (isProcessing) {
        return;
    }

    const input = document.getElementById('messageInput');
    const message = input.value.trim();

    if (!message) {
        return;
    }

    isProcessing = true;
    const sendButton = document.getElementById('sendButton');
    sendButton.disabled = true;

    // 显示用户消息
    addMessage(message, 'user');
    input.value = '';

    // 创建AI消息容器
    const aiMessageDiv = addMessage('', 'ai');
    const aiContentDiv = aiMessageDiv.querySelector('.message-content');

    try {
        const modelCode = document.getElementById('modelSelect').value;
        const scenarioCode = document.getElementById('scenarioSelect').value;

        // 调用API
        const aiApi = await getAiApi();
        const data = await aiApi.chat({
            message: message,
            model_code: modelCode,
            scenario_code: scenarioCode
        }, { silent: true });

        if (data.success) {
            aiContentDiv.textContent = data && data.data ? String(data.data.response || '') : '';
        } else {
            appendTextMessage(aiContentDiv, 'text-danger', '<?= addslashes(__('错误：')) ?>', data ? data.message : '');
        }
    } catch (error) {
        appendTextMessage(aiContentDiv, 'text-danger', '<?= addslashes(__('请求失败：')) ?>', error ? error.message : '');
    } finally {
        isProcessing = false;
        sendButton.disabled = false;
    }

    // 滚动到底部
    scrollToBottom();
}

function addMessage(content, type) {
    const messagesContainer = document.getElementById('chatMessages');

    // 移除欢迎消息
    const welcome = messagesContainer.querySelector('.welcome-message');
    if (welcome) {
        welcome.remove();
    }

    const messageDiv = document.createElement('div');
    messageDiv.className = `message message-${type}`;

    const avatar = document.createElement('div');
    avatar.className = 'message-avatar';

    const icon = document.createElement('i');
    icon.className = type === 'user' ? 'mdi mdi-account' : 'mdi mdi-robot';
    avatar.appendChild(icon);

    const contentDiv = document.createElement('div');
    contentDiv.className = 'message-content';
    contentDiv.textContent = String(content || '');

    messageDiv.appendChild(avatar);
    messageDiv.appendChild(contentDiv);

    messagesContainer.appendChild(messageDiv);
    return messageDiv;
}

function scrollToBottom() {
    const messagesContainer = document.getElementById('chatMessages');
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
}
</script>

