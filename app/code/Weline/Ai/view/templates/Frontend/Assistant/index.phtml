<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function deleteAssistant(id) {
    if (!confirm('<?= __('确定要删除这个助手吗？') ?>')) {
        return;
    }

    fetch('<?= $this->getUrl('*/frontend/assistant/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: id })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('删除成功') ?>');
            location.reload();
        } else {
            alert('<?= __('删除失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('操作失败') ?>');
    });
}
</script>
