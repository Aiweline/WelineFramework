<script>
(function () {
    'use strict';

    var catalogUrl = <?= \json_encode($catalogUrl, JSON_UNESCAPED_SLASHES) ?>;
    var saveUrl = <?= \json_encode($saveUrl, JSON_UNESCAPED_SLASHES) ?>;
    var importUrl = <?= \json_encode($importUrl, JSON_UNESCAPED_SLASHES) ?>;
    var bindUrl = <?= \json_encode($bindUrl, JSON_UNESCAPED_SLASHES) ?>;
    var unbindUrl = <?= \json_encode($unbindUrl, JSON_UNESCAPED_SLASHES) ?>;
    var exportUrl = <?= \json_encode($exportUrl, JSON_UNESCAPED_SLASHES) ?>;
    var initialAdapters = <?= \json_encode($adapters, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE) ?>;
    var i18n = <?= \json_encode($skillI18n, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE) ?: '{}' ?>;

    var state = {
        items: [],
        adapters: Array.isArray(initialAdapters) ? initialAdapters : [],
        selectedCode: '',
        selectedAdapter: ''
    };

    var els = {
        adapter: document.getElementById('ai-skill-adapter'),
        adapterSummary: document.getElementById('ai-skill-adapter-summary'),
        search: document.getElementById('ai-skill-search'),
        statusFilter: document.getElementById('ai-skill-status-filter'),
        sourceFilter: document.getElementById('ai-skill-source-filter'),
        tableBody: document.getElementById('ai-skill-table-body'),
        listStatus: document.getElementById('ai-skill-status'),
        empty: document.getElementById('ai-skill-empty'),
        form: document.getElementById('ai-skill-form'),
        detailTitle: document.getElementById('ai-skill-detail-title'),
        detailMode: document.getElementById('ai-skill-detail-mode'),
        badges: document.getElementById('ai-skill-badges'),
        code: document.getElementById('ai-skill-code'),
        name: document.getElementById('ai-skill-name'),
        status: document.getElementById('ai-skill-edit-status'),
        version: document.getElementById('ai-skill-version'),
        description: document.getElementById('ai-skill-description'),
        body: document.getElementById('ai-skill-body'),
        save: document.getElementById('ai-skill-save-btn'),
        exportBtn: document.getElementById('ai-skill-export-btn'),
        bind: document.getElementById('ai-skill-bind-btn'),
        unbind: document.getElementById('ai-skill-unbind-btn'),
        bindingHelp: document.getElementById('ai-skill-binding-help'),
        formStatus: document.getElementById('ai-skill-form-status'),
        importUrl: document.getElementById('ai-skill-import-url'),
        importBtn: document.getElementById('ai-skill-import-btn'),
        importStatus: document.getElementById('ai-skill-import-status')
    };

    function post(url, data) {
        var body = new URLSearchParams();
        Object.keys(data || {}).forEach(function (key) {
            var value = data[key];
            body.append(key, Array.isArray(value) ? JSON.stringify(value) : String(value));
        });
        return apiRequest(url, {
            method: 'POST',
            headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: body.toString(),
            silent: true
        }).then(function (res) {
            return res && Object.prototype.hasOwnProperty.call(res, 'data') ? res.data : res;
        });
    }

    function apiRequest(url, options) {
        if (window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function') {
            return window.Weline.Api.request(url, options);
        }
        if (window.Weline && typeof window.Weline.load === 'function') {
            return window.Weline.load('api').then(function () {
                if (window.Weline && window.Weline.Api && typeof window.Weline.Api.request === 'function') {
                    return window.Weline.Api.request(url, options);
                }
                throw new Error(i18n.apiUnavailable);
            });
        }
        return Promise.reject(new Error(i18n.apiUnavailable));
    }

    function responseErrorMessage(err, fallback) {
        var data = err && err.response && err.response.data ? err.response.data : null;
        return (data && (data.message || data.msg)) || (err && err.message) || fallback;
    }

    function setStatus(el, text, isError) {
        if (!el) {
            return;
        }
        el.className = 'small mt-2 ' + (isError ? 'text-danger' : 'text-success');
        el.textContent = text || '';
    }

    function clearNode(node) {
        while (node && node.firstChild) {
            node.removeChild(node.firstChild);
        }
    }

    function text(tag, value, className) {
        var node = document.createElement(tag);
        if (className) {
            node.className = className;
        }
        node.textContent = value || '';
        return node;
    }

    function badge(value, className) {
        var span = document.createElement('span');
        span.className = 'badge ' + (className || 'text-bg-secondary');
        span.textContent = value || '';
        return span;
    }

    function chip(value) {
        var span = document.createElement('span');
        span.className = 'skill-chip';
        span.textContent = value || '';
        return span;
    }

    function selectedAdapterCode() {
        return els.adapter ? String(els.adapter.value || '') : '';
    }

    function findSelectedSkill() {
        return state.items.find(function (item) {
            return String(item.code || '') === state.selectedCode;
        }) || null;
    }

    function currentAdapter() {
        var code = selectedAdapterCode();
        return state.adapters.find(function (adapter) {
            return String(adapter.code || '') === code;
        }) || null;
    }

    function sourceGroup(skill) {
        var type = String(skill.source_type || skill.source || '');
        if (type === 'module' || type === 'system') {
            return 'module';
        }
        if (type === 'custom') {
            return 'custom';
        }
        if (type.indexOf('import') > -1 || type === 'platform') {
            return 'import';
        }
        return type;
    }

    function renderAdapters() {
        clearNode(els.adapter);
        if (!state.adapters.length) {
            state.selectedAdapter = '';
            return;
        }

        state.adapters.forEach(function (adapter) {
            var option = document.createElement('option');
            option.value = adapter.code || '';
            option.textContent = (adapter.name || adapter.code || '') + ' (' + (adapter.code || '') + ')';
            els.adapter.appendChild(option);
        });

        var preferred = state.adapters[0];
        state.selectedAdapter = preferred.code || '';
        els.adapter.value = state.selectedAdapter;
    }

    function renderAdapterSummary() {
        var adapter = currentAdapter();
        if (!adapter) {
            els.adapterSummary.textContent = i18n.adapterUnavailable;
            return;
        }
        var locked = Array.isArray(adapter.locked_skill_codes) ? adapter.locked_skill_codes : [];
        var manual = Array.isArray(adapter.manual_skill_codes) ? adapter.manual_skill_codes : [];
        els.adapterSummary.textContent = i18n.lockedLabel + ': ' + (locked.length ? locked.join(', ') : i18n.noneLabel)
            + ' | ' + i18n.manualLabel + ': ' + (manual.length ? manual.join(', ') : i18n.noneLabel);
    }

    function filteredItems() {
        var q = String(els.search.value || '').trim().toLowerCase();
        var status = String(els.statusFilter.value || '');
        var source = String(els.sourceFilter.value || '');
        return state.items.filter(function (skill) {
            var haystack = [
                skill.code || '',
                skill.name || '',
                skill.description || '',
                (Array.isArray(skill.tags) ? skill.tags.join(' ') : ''),
                skill.source || '',
                skill.source_module || '',
                skill.source_platform || ''
            ].join(' ').toLowerCase();
            if (q !== '' && haystack.indexOf(q) === -1) {
                return false;
            }
            if (status !== '' && String(skill.status || '') !== status) {
                return false;
            }
            if (source !== '' && sourceGroup(skill) !== source) {
                return false;
            }
            return true;
        });
    }

    function renderTable() {
        var items = filteredItems();
        clearNode(els.tableBody);
        if (!items.length) {
            var emptyRow = document.createElement('tr');
            var td = document.createElement('td');
            td.colSpan = 6;
            td.className = 'text-center text-muted py-4';
            td.textContent = i18n.noMatch;
            emptyRow.appendChild(td);
            els.tableBody.appendChild(emptyRow);
            els.listStatus.textContent = '0 / ' + state.items.length + i18n.skillsSuffix;
            return;
        }

        items.forEach(function (skill) {
            var tr = document.createElement('tr');
            tr.className = 'skill-row' + (skill.code === state.selectedCode ? ' is-selected' : '');
            tr.dataset.code = skill.code || '';

            var codeTd = document.createElement('td');
            codeTd.setAttribute('data-label', i18n.codeLabel);
            codeTd.title = String(skill.code || '');
            codeTd.appendChild(text('code', skill.code || '', 'skill-code-token'));
            var tagWrap = document.createElement('div');
            (Array.isArray(skill.tags) ? skill.tags.slice(0, 3) : []).forEach(function (tag) {
                tagWrap.appendChild(chip(tag));
            });
            codeTd.appendChild(tagWrap);
            tr.appendChild(codeTd);

            var nameTd = document.createElement('td');
            nameTd.setAttribute('data-label', i18n.skillLabel);
            nameTd.appendChild(text('div', skill.name || skill.code || i18n.untitledSkill, 'fw-semibold'));
            nameTd.appendChild(text('div', skill.description || '', 'small text-muted skill-muted-line'));
            tr.appendChild(nameTd);

            var sourceTd = document.createElement('td');
            sourceTd.setAttribute('data-label', i18n.sourceLabel);
            sourceTd.appendChild(text('div', skill.source_module || skill.source_platform || skill.source || skill.source_type || '', 'small'));
            sourceTd.appendChild(text('div', skill.source_type || '', 'small text-muted'));
            tr.appendChild(sourceTd);

            var statusTd = document.createElement('td');
            statusTd.setAttribute('data-label', i18n.statusLabel);
            var statusClass = skill.status === 'active' ? 'text-bg-success' : (skill.status === 'pending' ? 'text-bg-warning' : 'text-bg-secondary');
            statusTd.appendChild(badge(skill.status || 'unknown', statusClass));
            tr.appendChild(statusTd);

            var bindingTd = document.createElement('td');
            bindingTd.setAttribute('data-label', i18n.bindingLabel);
            if (skill.locked) {
                bindingTd.appendChild(badge(i18n.lockedLabel, 'text-bg-primary'));
            } else if (skill.manual) {
                bindingTd.appendChild(badge(i18n.manualLabel, 'text-bg-info'));
            } else if (skill.temporary) {
                bindingTd.appendChild(badge(i18n.temporaryLabel, 'text-bg-light text-dark'));
            } else {
                bindingTd.appendChild(text('span', '-', 'small text-muted'));
            }
            tr.appendChild(bindingTd);

            var actionTd = document.createElement('td');
            actionTd.setAttribute('data-label', i18n.actionsLabel);
            var manageBtn = document.createElement('button');
            manageBtn.type = 'button';
            manageBtn.className = 'btn btn-outline-primary btn-sm';
            manageBtn.textContent = i18n.manageAction;
            manageBtn.dataset.action = 'select';
            actionTd.appendChild(manageBtn);
            var exportLink = document.createElement('a');
            exportLink.className = 'btn btn-outline-secondary btn-sm ms-1';
            exportLink.textContent = i18n.exportAction;
            exportLink.href = exportUrl + '?code=' + encodeURIComponent(skill.code || '');
            actionTd.appendChild(exportLink);
            tr.appendChild(actionTd);

            els.tableBody.appendChild(tr);
        });
        els.listStatus.textContent = String(items.length) + ' / ' + state.items.length + i18n.skillsSuffix;
    }

    function renderDetail() {
        var skill = findSelectedSkill();
        if (!skill) {
            els.empty.classList.remove('d-none');
            els.form.classList.add('d-none');
            els.detailTitle.textContent = i18n.skillDetail;
            els.detailMode.textContent = i18n.noSelection;
            return;
        }

        var readonly = !!skill.readonly || !!skill.locked;
        els.empty.classList.add('d-none');
        els.form.classList.remove('d-none');
        els.detailTitle.textContent = skill.code ? i18n.managePrefix + skill.code : i18n.newCustomSkill;
        els.detailMode.textContent = readonly ? i18n.readOnly : (skill.id ? i18n.editable : i18n.newLabel);

        clearNode(els.badges);
        els.badges.appendChild(badge(skill.status || 'new', skill.status === 'active' ? 'text-bg-success' : 'text-bg-secondary'));
        els.badges.appendChild(badge(skill.source_type || 'custom', 'text-bg-light text-dark'));
        if (skill.locked) {
            els.badges.appendChild(badge(i18n.lockedBinding, 'text-bg-primary'));
        }
        if (skill.manual) {
            els.badges.appendChild(badge(i18n.manualBinding, 'text-bg-info'));
        }
        if (readonly) {
            els.badges.appendChild(badge(i18n.readonlyBadge, 'text-bg-dark'));
        }

        els.code.value = skill.code || '';
        els.name.value = skill.name || '';
        els.status.value = skill.status || 'active';
        els.version.value = skill.version || '';
        els.description.value = skill.description || '';
        els.body.value = skill.body || skill.normalized_body || '';

        els.code.readOnly = !!skill.id || readonly;
        [els.name, els.status, els.version, els.description, els.body].forEach(function (input) {
            input.disabled = readonly;
        });
        els.save.disabled = readonly;

        document.querySelectorAll('[data-skill-status-action]').forEach(function (btn) {
            btn.disabled = readonly || !skill.id || skill.status === btn.dataset.skillStatusAction;
        });

        els.exportBtn.disabled = !skill.code;
        var canBind = !!skill.code && skill.status === 'active' && !skill.locked && !skill.manual && !skill.readonly;
        var canBindReadonlySkill = !!skill.code && skill.status === 'active' && !skill.locked && !skill.manual && !!skill.exists;
        els.bind.disabled = !(canBind || canBindReadonlySkill);
        els.unbind.disabled = !skill.manual || skill.locked;
        if (skill.locked) {
            els.bindingHelp.textContent = i18n.bindingLockedHelp;
        } else if (skill.manual) {
            els.bindingHelp.textContent = i18n.bindingManualHelp;
        } else if (skill.status !== 'active') {
            els.bindingHelp.textContent = i18n.bindingInactiveHelp;
        } else {
            els.bindingHelp.textContent = i18n.bindingReadyHelp;
        }
    }

    function selectSkill(code) {
        state.selectedCode = code || '';
        renderTable();
        renderDetail();
        setStatus(els.formStatus, '', false);
    }

    function newSkill() {
        var draft = {
            id: 0,
            code: '',
            name: '',
            description: '',
            body: '',
            status: 'active',
            source: 'custom_db',
            source_type: 'custom',
            exists: false,
            readonly: false,
            tags: []
        };
        state.items = state.items.filter(function (item) {
            return item.code !== '';
        });
        state.items.unshift(draft);
        state.selectedCode = '';
        renderTable();
        renderDetail();
        els.code.focus();
    }

    function refreshCatalog() {
        var adapterCode = selectedAdapterCode();
        els.listStatus.textContent = i18n.loading;
        return post(catalogUrl, {
            adapter_code: adapterCode,
            include_inactive: 1
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || i18n.catalogLoadFailed);
            }
            state.items = Array.isArray(payload.items) ? payload.items : [];
            var stillExists = state.items.some(function (item) {
                return item.code === state.selectedCode;
            });
            if (!stillExists) {
                state.selectedCode = state.items.length ? (state.items[0].code || '') : '';
            }
            renderAdapterSummary();
            renderTable();
            renderDetail();
        }).catch(function (err) {
            els.listStatus.textContent = responseErrorMessage(err, i18n.catalogLoadFailed);
        });
    }

    function saveCurrentSkill() {
        setStatus(els.formStatus, i18n.saving, false);
        return post(saveUrl, {
            code: els.code.value || '',
            name: els.name.value || '',
            description: els.description.value || '',
            body: els.body.value || '',
            status: els.status.value || 'active',
            version: els.version.value || ''
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || i18n.saveFailed);
            }
            state.selectedCode = payload.item && payload.item.code ? payload.item.code : (els.code.value || '');
            setStatus(els.formStatus, i18n.saved, false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, responseErrorMessage(err, i18n.saveFailed), true);
        });
    }

    function setCurrentStatus(status) {
        var skill = findSelectedSkill();
        if (!skill || !skill.code) {
            return;
        }
        setStatus(els.formStatus, i18n.updatingStatus, false);
        return post(saveUrl, {
            code: skill.code,
            name: els.name.value || skill.name || '',
            description: els.description.value || skill.description || '',
            body: els.body.value || skill.body || skill.normalized_body || '',
            status: status,
            version: els.version.value || skill.version || ''
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || i18n.statusUpdateFailed);
            }
            setStatus(els.formStatus, i18n.statusUpdated, false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, responseErrorMessage(err, i18n.statusUpdateFailed), true);
        });
    }

    function bindCurrentSkill(bind) {
        var skill = findSelectedSkill();
        if (!skill || !skill.code) {
            return;
        }
        setStatus(els.formStatus, bind ? i18n.binding : i18n.unbinding, false);
        return post(bind ? bindUrl : unbindUrl, {
            adapter_code: selectedAdapterCode(),
            skill_code: skill.code
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || (bind ? i18n.bindFailed : i18n.unbindFailed));
            }
            setStatus(els.formStatus, bind ? i18n.bound : i18n.unbound, false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, responseErrorMessage(err, bind ? i18n.bindFailed : i18n.unbindFailed), true);
        });
    }

    function importSkill() {
        setStatus(els.importStatus, i18n.importing, false);
        return post(importUrl, {
            url: els.importUrl.value || ''
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || i18n.importFailed);
            }
            state.selectedCode = payload.item && payload.item.code ? payload.item.code : '';
            setStatus(els.importStatus, i18n.imported, false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.importStatus, responseErrorMessage(err, i18n.importFailed), true);
        });
    }

    renderAdapters();
    renderAdapterSummary();
    refreshCatalog();

    document.getElementById('ai-skill-refresh').addEventListener('click', refreshCatalog);
    document.getElementById('ai-skill-new').addEventListener('click', newSkill);
    els.adapter.addEventListener('change', function () {
        state.selectedAdapter = selectedAdapterCode();
        refreshCatalog();
    });
    [els.search, els.statusFilter, els.sourceFilter].forEach(function (input) {
        input.addEventListener('input', renderTable);
        input.addEventListener('change', renderTable);
    });
    els.tableBody.addEventListener('click', function (event) {
        var row = event.target.closest('tr[data-code]');
        if (!row) {
            return;
        }
        selectSkill(row.dataset.code || '');
    });
    els.save.addEventListener('click', saveCurrentSkill);
    els.exportBtn.addEventListener('click', function () {
        var skill = findSelectedSkill();
        if (skill && skill.code) {
            window.location.href = exportUrl + '?code=' + encodeURIComponent(skill.code);
        }
    });
    document.querySelectorAll('[data-skill-status-action]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            setCurrentStatus(btn.dataset.skillStatusAction || '');
        });
    });
    els.bind.addEventListener('click', function () { bindCurrentSkill(true); });
    els.unbind.addEventListener('click', function () { bindCurrentSkill(false); });
    els.importBtn.addEventListener('click', importSkill);
})();
</script>
