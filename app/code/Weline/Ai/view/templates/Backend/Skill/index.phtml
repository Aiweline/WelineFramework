<script>
(function () {
    'use strict';
    var catalogUrl = <?= json_encode($catalogUrl, JSON_UNESCAPED_SLASHES) ?>;
    var saveUrl = <?= json_encode($saveUrl, JSON_UNESCAPED_SLASHES) ?>;
    var importUrl = <?= json_encode($importUrl, JSON_UNESCAPED_SLASHES) ?>;
    var disableUrl = <?= json_encode($disableUrl, JSON_UNESCAPED_SLASHES) ?>;
    var tableBody = document.getElementById('ai-skill-table-body');
    var status = document.getElementById('ai-skill-status');
    var formStatus = document.getElementById('ai-skill-form-status');

    function post(url, data) {
        var body = new URLSearchParams();
        Object.keys(data || {}).forEach(function (key) { body.append(key, data[key]); });
        return fetch(url, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: body.toString()
        }).then(function (res) { return res.json(); });
    }

    function setFormStatus(text, isError) {
        if (!formStatus) return;
        formStatus.className = 'small mt-2 ' + (isError ? 'text-danger' : 'text-success');
        formStatus.textContent = text || '';
    }

    function render(items) {
        if (!tableBody) return;
        tableBody.innerHTML = '';
        (items || []).forEach(function (skill) {
            var tr = document.createElement('tr');
            var binding = skill.locked ? 'locked' : (skill.manual ? 'adapter' : (skill.temporary ? 'temporary' : ''));
            tr.innerHTML = '<td><code></code></td><td><div class="fw-semibold"></div><div class="small text-muted"></div></td><td></td><td></td><td class="small text-muted"></td><td></td>';
            tr.children[0].querySelector('code').textContent = skill.code || '';
            tr.children[1].querySelector('.fw-semibold').textContent = skill.name || skill.code || '';
            tr.children[1].querySelector('.small').textContent = skill.description || '';
            tr.children[2].textContent = skill.source || skill.source_type || '';
            tr.children[3].innerHTML = '<span class="badge ' + (skill.status === 'active' ? 'text-bg-success' : 'text-bg-secondary') + '"></span>';
            tr.children[3].querySelector('span').textContent = skill.status || '';
            tr.children[4].textContent = binding;
            tr.children[5].innerHTML = '<a class="btn btn-outline-secondary btn-sm">Export</a>';
            tr.children[5].querySelector('a').href = <?= json_encode($this->getBackendUrl('ai/backend/skill/get-export'), JSON_UNESCAPED_SLASHES) ?> + '?code=' + encodeURIComponent(skill.code || '');
            tableBody.appendChild(tr);
        });
        if (status) status.textContent = String((items || []).length) + ' skills';
    }

    function refresh() {
        return post(catalogUrl, { include_inactive: 1 }).then(function (payload) {
            if (!payload || payload.success === false) throw new Error((payload && payload.message) || 'catalog failed');
            render(payload.items || []);
        }).catch(function (err) {
            if (status) status.textContent = err && err.message ? err.message : 'Catalog load failed';
        });
    }

    document.getElementById('ai-skill-refresh')?.addEventListener('click', refresh);
    document.getElementById('ai-skill-save-btn')?.addEventListener('click', function () {
        setFormStatus('Saving...', false);
        post(saveUrl, {
            code: document.getElementById('ai-skill-code')?.value || '',
            name: document.getElementById('ai-skill-name')?.value || '',
            description: document.getElementById('ai-skill-description')?.value || '',
            body: document.getElementById('ai-skill-body')?.value || '',
            status: 'active'
        }).then(function (payload) {
            if (!payload || payload.success === false) throw new Error((payload && payload.message) || 'save failed');
            setFormStatus('Saved.', false);
            refresh();
        }).catch(function (err) { setFormStatus(err && err.message ? err.message : 'Save failed', true); });
    });
    document.getElementById('ai-skill-import-btn')?.addEventListener('click', function () {
        setFormStatus('Importing...', false);
        post(importUrl, { url: document.getElementById('ai-skill-import-url')?.value || '' }).then(function (payload) {
            if (!payload || payload.success === false) throw new Error((payload && payload.message) || 'import failed');
            setFormStatus('Imported as pending.', false);
            refresh();
        }).catch(function (err) { setFormStatus(err && err.message ? err.message : 'Import failed', true); });
    });
    void disableUrl;
})();
</script>
