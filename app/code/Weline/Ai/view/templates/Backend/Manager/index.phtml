<script>
(function() {
    'use strict';
    var tabs = document.querySelectorAll('.weline-ai-manager-tabs .nav-link');
    var panes = document.querySelectorAll('.weline-ai-manager .tab-pane');
    function switchTab(tab, url) {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        panes.forEach(function(p) {
            p.classList.remove('active');
            if (p.getAttribute('data-tab') === tab) {
                p.classList.add('active');
                var iframe = p.querySelector('iframe');
                if (iframe && url && !iframe.dataset.loaded) {
                    iframe.src = url;
                    iframe.dataset.loaded = '1';
                }
            }
        });
        var activeTabEl = document.querySelector('.weline-ai-manager-tabs .nav-link[data-tab="' + tab + '"]');
        if (activeTabEl) activeTabEl.classList.add('active');
        if (history.replaceState) {
            var params = new URLSearchParams(window.location.search);
            params.set('tab', tab);
            history.replaceState(null, '', window.location.pathname + '?' + params.toString());
        }
    }
    tabs.forEach(function(tabEl) {
        tabEl.addEventListener('click', function(e) {
            e.preventDefault();
            switchTab(this.getAttribute('data-tab'), this.getAttribute('data-url'));
        });
    });
})();
</script>
