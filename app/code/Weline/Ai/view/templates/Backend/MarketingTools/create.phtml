<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';
    
    document.getElementById('campaign-form').addEventListener('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(this);
        var data = {};
        formData.forEach(function(value, key) {
            data[key] = value;
        });
        
        fetch(this.action, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams(data)
        })
        .then(function(response) { return response.json(); })
        .then(function(result) {
            if (result.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: result.message || '<?= __('保存成功') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function() {
                        window.location.href = '<?= $this->getBackendUrl('ai/backend/marketingtools') ?>';
                    });
                } else {
                    console.log(result.message || '保存成功');
                    window.location.href = '<?= $this->getBackendUrl('ai/backend/marketingtools') ?>';
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: result.message || '<?= __('保存失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error(result.message || '保存失败');
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('保存失败');
            }
        });
    });
    
    document.getElementById('start_date').addEventListener('change', function() {
        var endDate = document.getElementById('end_date');
        if (this.value && endDate.value && this.value > endDate.value) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('日期错误') ?>',
                    text: '<?= __('开始日期不能晚于结束日期') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('开始日期不能晚于结束日期');
            }
            this.value = '';
        }
    });
    
    document.getElementById('end_date').addEventListener('change', function() {
        var startDate = document.getElementById('start_date');
        if (this.value && startDate.value && this.value < startDate.value) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('日期错误') ?>',
                    text: '<?= __('结束日期不能早于开始日期') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('结束日期不能早于开始日期');
            }
            this.value = '';
        }
    });
})();
</script>

