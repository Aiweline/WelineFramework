    <script>
        function deleteCampaign(id) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '<?= __('确认删除') ?>',
                    text: '<?= __('确定要删除这个活动吗？') ?>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: '<?= __("确定删除") ?>',
                    cancelButtonText: '<?= __("取消") ?>',
                    confirmButtonColor: '#d33'
                }).then((result) => {
                    if (result.isConfirmed) {
                        performDelete(id);
                    }
                });
            } else {
                if (!confirm('确定要删除这个活动吗？')) {
                    return;
                }
                performDelete(id);
            }
        }
        
        function performDelete(id) {
            fetch('<?= $this->getBackendUrl('ai/backend/marketingtools/delete') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: '<?= __('活动已删除') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    } else {
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('删除失败') ?>',
                            text: data.message || '<?= __('删除失败') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error(data.message || '删除失败');
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('删除失败') ?>',
                        text: '<?= __('请重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('删除失败');
                }
            });
        }
    </script>
