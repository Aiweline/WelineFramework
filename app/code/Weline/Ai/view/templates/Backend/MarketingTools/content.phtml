            </div>
            
            <div class="col-md-6">
                <div class="form-group">
                    <label for="generated_content"><lang>生成的内容</lang></label>
                    <textarea class="form-control" id="generated_content" rows="12" readonly placeholder="生成的内容将显示在这里..."></textarea>
                </div>
                
                <button type="button" class="btn btn-secondary mt-3" onclick="WelineContent.copyContent()" id="copy-btn" disabled>
