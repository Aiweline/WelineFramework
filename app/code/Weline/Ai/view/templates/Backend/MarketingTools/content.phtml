<div class="card mt-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="content_type"><lang>内容类型</lang></label>
                    <select class="form-control" id="content_type">
                        <option value="email"><lang>营销邮件</lang></option>
                        <option value="social"><lang>社交媒体</lang></option>
                        <option value="ad"><lang>广告文案</lang></option>
                        <option value="blog"><lang>博客文章</lang></option>
                    </select>
                </div>
                
                <div class="form-group mt-3">
                    <label for="content_prompt"><lang>内容描述</lang></label>
                    <textarea class="form-control" id="content_prompt" rows="6" placeholder="描述您想要生成的内容..."></textarea>
