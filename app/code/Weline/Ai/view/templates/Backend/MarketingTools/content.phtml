<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';
    
    var WelineContent = {
        generateContent: function() {
            var contentType = document.getElementById('content_type').value;
            var prompt = document.getElementById('content_prompt').value;
            var generatedContent = document.getElementById('generated_content');
            var copyBtn = document.getElementById('copy-btn');
            
            if (!prompt.trim()) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请输入内容描述') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('请输入内容描述');
                }
                return;
            }
            
            generatedContent.value = '正在生成内容...';
            copyBtn.disabled = true;
            
            setTimeout(function() {
                generatedContent.value = '这是生成的内容示例。\n\n实际功能需要集成AI服务。\n\n内容类型: ' + contentType + '\n描述: ' + prompt;
                copyBtn.disabled = false;
            }, 1000);
        },
        
        copyContent: function() {
            var content = document.getElementById('generated_content');
            content.select();
            document.execCommand('copy');
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('复制成功') ?>',
                    text: '<?= __('内容已复制到剪贴板') ?>',
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log('内容已复制到剪贴板');
            }
        }
    };
    
    window.WelineContent = WelineContent;
})();
</script>
