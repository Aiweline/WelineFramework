    <?= $this->getChildHtml('Weline_Admin::Backend/page-layout/main-content-after.phtml') ?>
    
    <script>
        function generateContent() {
            const contentType = document.getElementById('content_type').value;
            const prompt = document.getElementById('content_prompt').value;
            const generatedContent = document.getElementById('generated_content');
            const copyBtn = document.getElementById('copy-btn');
            
            if (!prompt.trim()) {
                alert('请输入内容描述');
                return;
            }
            
            generatedContent.value = '正在生成内容...';
            copyBtn.disabled = true;
            
            // TODO: 调用AI服务生成内容
            setTimeout(() => {
                generatedContent.value = '这是生成的内容示例。\n\n实际功能需要集成AI服务。\n\n内容类型: ' + contentType + '\n描述: ' + prompt;
                copyBtn.disabled = false;
            }, 1000);
        }
        
        function copyContent() {
            const content = document.getElementById('generated_content');
            content.select();
            document.execCommand('copy');
            alert('内容已复制到剪贴板');
        }
    </script>
</body>
</html>

