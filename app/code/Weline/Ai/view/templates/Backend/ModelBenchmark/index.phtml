<script>
function runBenchmark() {
    // 使用更可靠的选择器：查找所有带有 model-checkbox 类的已选中复选框
    const checkboxes = document.querySelectorAll('input.model-checkbox:checked');
    const modelIds = [];
    
    checkboxes.forEach(cb => {
        const value = cb.value;
        if (value && value.trim() !== '') {
            modelIds.push(value.trim());
        }
    });
    
    // 调试信息（可在控制台查看）
    console.log('选中的复选框数量:', checkboxes.length);
    console.log('所有复选框:', document.querySelectorAll('input.model-checkbox'));
    console.log('提取的模型ID:', modelIds);
    
    if (modelIds.length === 0) {
        Swal.fire({
            icon: 'warning',
            title: '<?= __('提示') ?>',
            text: '<?= __('请至少选择一个模型进行测试') ?>',
            confirmButtonText: '<?= __('确定') ?>'
        });
        return;
    }
    
    Swal.fire({
        title: '<?= __('确认运行基准测试') ?>',
        text: '<?= __('确定要对选中的模型运行基准测试吗？') ?>',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: '<?= __('确定') ?>',
        cancelButtonText: '<?= __('取消') ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            const data = new FormData();
            modelIds.forEach(id => {
                data.append('model_ids[]', id);
            });
            data.append('test_suite', 'default');
            
            Swal.fire({
                title: '<?= __('测试中...') ?>',
                text: '<?= __('正在运行基准测试，请稍候...') ?>',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
            
            fetch('<?= $this->getBackendUrl('*/backend/modelbenchmark/run-benchmark') ?>', {
                method: 'POST',
                body: data
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('测试任务已创建') ?>',
                        text: data.message || '<?= __('基准测试任务已成功创建！') ?>',
                        showConfirmButton: false,
                        timer: 2000
                    }).then(() => {
                        // 刷新页面以更新测试历史
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('测试失败') ?>',
                        text: data.message || '<?= __('基准测试创建失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: '<?= __('请求失败：') ?>' + error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        }
    });
}
</script>
