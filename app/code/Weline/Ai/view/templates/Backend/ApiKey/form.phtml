// 创建防抖的搜索函数（500ms延迟，后台搜索适当延长）
const debouncedUserSearch = debounce(searchUsersFromBackend, 500);
const debouncedTenantSearch = debounce(searchTenantsFromBackend, 500);

// 用户搜索输入监听
const userSearch = document.getElementById('user_search');
if (userSearch) {
    userSearch.addEventListener('input', function(e) {
        const keyword = e.target.value.trim();
        
        if (keyword.length >= 2) {
            // 至少2个字符才搜索
            debouncedUserSearch(keyword);
        } else if (keyword.length === 0) {
            // 清空时加载默认列表
            debouncedUserSearch('');
        }
    });
    
    // 添加键盘快捷键支持
    userSearch.addEventListener('keydown', function(e) {
        const userSelect = document.getElementById('user_id_select');
        if (!userSelect) return;
        
        // 按下回车键选择第一个可用选项
        if (e.key === 'Enter') {
            e.preventDefault();
            if (userSelect.options.length > 1 && userSelect.options[1].value) {
                userSelect.value = userSelect.options[1].value;
            }
        }
        // 按下向下箭头聚焦到选择框
        else if (e.key === 'ArrowDown') {
            e.preventDefault();
            userSelect.focus();
        }
    });
    
    // 页面加载时自动搜索一次（加载默认列表）
    debouncedUserSearch('');
}

