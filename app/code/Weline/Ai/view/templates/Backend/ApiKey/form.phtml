<script>
// Debounce工具函数
function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}

// 后台搜索用户
function searchUsersFromBackend(keyword) {
    const userSelect = document.getElementById('user_id_select');
    if (!userSelect) return;
    
    // 显示加载提示
    userSelect.innerHTML = '<option value=""><?= __("搜索中...") ?></option>';
    
    // 构建请求URL
    const url = '<?= $this->getBackendUrl("*/backend/apikey/searchUsers") ?>?keyword=' + encodeURIComponent(keyword);
    
    fetch(url)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // 清空选项
                userSelect.innerHTML = '<option value=""><?= __("请选择用户") ?></option>';
                
                // 添加搜索结果
                if (data.data && data.data.length > 0) {
                    data.data.forEach(user => {
                        const option = document.createElement('option');
                        option.value = user.id;
                        option.textContent = `${user.username} (ID: ${user.id}) - ${user.email}`;
                        userSelect.appendChild(option);
                    });
                } else {
                    userSelect.innerHTML = '<option value=""><?= __("未找到匹配的用户") ?></option>';
                }
            } else {
                userSelect.innerHTML = '<option value=""><?= __("搜索失败") ?></option>';
                console.error(data.message);
            }
        })
        .catch(error => {
            userSelect.innerHTML = '<option value=""><?= __("搜索出错") ?></option>';
            console.error('<?= __("搜索用户失败：") ?>', error);
        });
}

