<!-- JavaScript -->
<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 表单验证
    const form = document.getElementById('apiKeyEditForm');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // 显示加载状态
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("保存中...") ?>';
        
        // 提交表单
        const formData = new FormData(form);
        
        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // 如果是新建，显示 Token
                if (data.data && data.data.token) {
                    document.getElementById('newToken').value = data.data.token;
                    const tokenModal = new bootstrap.Modal(document.getElementById('tokenModal'));
                    tokenModal.show();
                    
                    // 关闭 Offcanvas
                    const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('apiKeyEditOffcanvas'));
                    offcanvas.hide();
                } else {
                    // 显示成功消息
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __("保存成功") ?>',
                            text: '<?= __("API Key已成功保存") ?>',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            // 关闭 Offcanvas
                            const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('apiKeyEditOffcanvas'));
                            offcanvas.hide();
                            // 刷新列表
                            window.location.reload();
                        });
                    } else {
                        console.log('<?= __("保存成功！") ?>');
                        // 关闭 Offcanvas
                        const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('apiKeyEditOffcanvas'));
                        offcanvas.hide();
                        // 刷新列表
                        window.location.reload();
                    }
                }
            } else {
                // 显示错误消息
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("保存失败") ?>',
                        text: data.message || '<?= __("未知错误") ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("保存失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("保存失败") ?>',
                    text: '<?= __("请稍后重试") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("保存失败，请稍后重试") ?>');
            }
        })
        .finally(() => {
            // 恢复按钮状态
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    });
    
    // 自动打开 Offcanvas（如果是新建或编辑模式）
    <?php if ($this->getData('auto_open')): ?>
    const offcanvas = new bootstrap.Offcanvas(document.getElementById('apiKeyEditOffcanvas'));
    offcanvas.show();
    <?php endif; ?>
});

// 复制 Token
function copyToken() {
    const tokenInput = document.getElementById('newToken');
    tokenInput.select();
    document.execCommand('copy');
    
    // 显示复制成功提示
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check"></i> <?= __("已复制") ?>';
    
    setTimeout(() => {
        btn.innerHTML = originalHtml;
    }, 2000);
}

// 撤销 API Key
function revokeApiKey(id) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __("确认撤销") ?>',
            text: '<?= __("确定要撤销此 API Key 吗？此操作不可撤销！") ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定撤销") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#d33'
        }).then((result) => {
            if (result.isConfirmed) {
                performRevoke(id);
            }
        });
    } else {
        if (!confirm('<?= __("确定要撤销此 API Key 吗？此操作不可撤销！") ?>')) {
            return;
        }
        performRevoke(id);
    }
}

function performRevoke(id) {
    fetch('<?= $this->getUrl('*/*/revoke') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: id,
            form_key: '<?= $this->getFormKey($this->getUrl('*/*/revoke')) ?>'
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __("成功") ?>',
                    text: '<?= __("API Key 已撤销") ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => window.location.reload());
            } else {
                console.log('<?= __("API Key 已撤销") ?>');
                window.location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("撤销失败") ?>',
                    text: data.message || '<?= __("未知错误") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("撤销失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __("撤销失败") ?>',
                text: '<?= __("请稍后重试") ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __("撤销失败，请稍后重试") ?>');
        }
    });
}
</script>

