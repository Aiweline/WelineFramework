<script>
function filterByStatus(status) {
    const url = new URL(window.location.href);
    if (status) {
        url.searchParams.set('status', status);
    } else {
        url.searchParams.delete('status');
    }
    url.searchParams.set('page', '1'); // 重置到第一页
    window.location.href = url.toString();
}

function approveKey(id, action) {
    if (!confirm('<?= __("确定要") ?>' + (action === 'approve' ? '<?= __("批准") ?>' : '<?= __("拒绝") ?>') + '<?= __("这个API密钥吗？") ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/apikey/approve') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}&action=${action}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __("操作失败：") ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __("请求失败：") ?>' + error);
    });
}

function setQuota(id, currentQuota) {
    const newQuota = prompt('<?= __("请输入新的配额限制：") ?>', currentQuota);
    if (newQuota === null) return;

    fetch('<?= $this->getBackendUrl('*/backend/apikey/setQuota') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}&quota_limit=${newQuota}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __("设置失败：") ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __("请求失败：") ?>' + error);
    });
}

function deleteKey(id) {
    if (!confirm('<?= __("确定要删除这个API密钥吗？此操作不可恢复！") ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/apikey/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __("删除失败：") ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __("请求失败：") ?>' + error);
    });
}
</script>

