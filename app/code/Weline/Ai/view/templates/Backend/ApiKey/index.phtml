<script>
function filterByStatus(status) {
    const url = new URL(window.location.href);
    if (status) {
        url.searchParams.set('status', status);
    } else {
        url.searchParams.delete('status');
    }
    window.location.href = url.toString();
}

function approveKey(id, action) {
    if (!confirm(`确定要${action === 'approve' ? '批准' : '拒绝'}这个API密钥吗？`)) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/apikey/approve') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}&action=${action}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('操作失败：' + data.message);
        }
    })
    .catch(error => {
        alert('请求失败：' + error);
    });
}

function setQuota(id, currentQuota) {
    const newQuota = prompt('请输入新的配额限制：', currentQuota);
    if (newQuota === null) return;

    fetch('<?= $this->getBackendUrl('*/backend/apikey/setQuota') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}&quota_limit=${newQuota}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('设置失败：' + data.message);
        }
    })
    .catch(error => {
        alert('请求失败：' + error);
    });
}

function deleteKey(id) {
    if (!confirm('确定要删除这个API密钥吗？此操作不可恢复！')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/apikey/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('删除失败：' + data.message);
        }
    })
    .catch(error => {
        alert('请求失败：' + error);
    });
}
</script>

