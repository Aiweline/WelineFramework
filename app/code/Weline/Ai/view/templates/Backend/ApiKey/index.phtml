<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';
    
    var WelineApiKey = {
        searchKeys: function(keyword) {
            var table = document.querySelector('.weline-apikey-table tbody');
            if (!table) return;
            
            var rows = table.querySelectorAll('tr');
            var searchTerm = keyword.toLowerCase().trim();
            
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        },
        
        filterByStatus: function(status) {
            var url = new URL(window.location.href);
            if (status) {
                url.searchParams.set('status', status);
            } else {
                url.searchParams.delete('status');
            }
            url.searchParams.set('page', '1');
            window.location.href = url.toString();
        },
        
        approveKey: function(id, action) {
            var confirmMsg = '<?= __("确定要") ?>' + (action === 'approve' ? '<?= __("批准") ?>' : '<?= __("拒绝") ?>') + '<?= __("这个API密钥吗？") ?>';
            if (!confirm(confirmMsg)) {
                return;
            }

            fetch('<?= $this->getBackendUrl('*/backend/apikey/approve') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id + '&action=' + action
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __("成功") ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        console.log(data.message);
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("操作失败") ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("操作失败：") ?>' + data.message);
                    }
                }
            })
            .catch(function(error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("请求失败") ?>',
                        text: error,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请求失败：") ?>' + error);
                }
            });
        },
        
        setQuota: function(id, currentQuota) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '<?= __("设置配额限制") ?>',
                    input: 'number',
                    inputLabel: '<?= __("请输入新的配额限制：") ?>',
                    inputValue: currentQuota,
                    inputAttributes: {
                        min: '0',
                        step: '1'
                    },
                    showCancelButton: true,
                    confirmButtonText: '<?= __("确定") ?>',
                    cancelButtonText: '<?= __("取消") ?>',
                    inputValidator: function(value) {
                        if (!value || value < 0) {
                            return '<?= __("请输入有效的配额限制") ?>';
                        }
                    }
                }).then(function(result) {
                    if (result.isConfirmed && result.value !== null) {
                        WelineApiKey.updateQuota(id, result.value);
                    }
                });
            } else {
                var newQuota = prompt('<?= __("请输入新的配额限制：") ?>', currentQuota);
                if (newQuota === null) return;
                WelineApiKey.updateQuota(id, newQuota);
            }
        },
        
        updateQuota: function(id, newQuota) {
            fetch('<?= $this->getBackendUrl('*/backend/apikey/setQuota') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id + '&quota_limit=' + newQuota
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __("成功") ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        console.log(data.message);
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("设置失败") ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("设置失败：") ?>' + data.message);
                    }
                }
            })
            .catch(function(error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("请求失败") ?>',
                        text: error,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请求失败：") ?>' + error);
                }
            });
        },
        
        deleteKey: function(id) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '<?= __("确认删除") ?>',
                    text: '<?= __("确定要删除这个API密钥吗？此操作不可恢复！") ?>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: '<?= __("确定删除") ?>',
                    cancelButtonText: '<?= __("取消") ?>',
                    confirmButtonColor: '#d33'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        WelineApiKey.performDelete(id);
                    }
                });
            } else {
                if (!confirm('<?= __("确定要删除这个API密钥吗？此操作不可恢复！") ?>')) {
                    return;
                }
                WelineApiKey.performDelete(id);
            }
        },
        
        performDelete: function(id) {
            fetch('<?= $this->getBackendUrl('*/backend/apikey/delete') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __("成功") ?>',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        console.log(data.message);
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("删除失败") ?>',
                            text: data.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("删除失败：") ?>' + data.message);
                    }
                }
            })
            .catch(function(error) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("请求失败") ?>',
                        text: error,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请求失败：") ?>' + error);
                }
            });
        }
    };
    
    window.WelineApiKey = WelineApiKey;
})();
</script>
