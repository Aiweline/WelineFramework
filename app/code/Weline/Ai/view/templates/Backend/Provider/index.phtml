<script>
let currentPage = 1;
let currentSearch = '';
let currentProvider = '';

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    loadAccounts();
    
    // 代理设置切换
    document.getElementById('proxy_enabled').addEventListener('change', function() {
        document.getElementById('proxySettings').style.display = this.checked ? 'block' : 'none';
    });
    
    // 供应商选择时自动填充基础URL
    document.getElementById('provider_code').addEventListener('change', function() {
        const baseUrl = this.options[this.selectedIndex].getAttribute('data-base-url');
        if (baseUrl && !document.getElementById('base_url').value) {
            document.getElementById('base_url').value = baseUrl;
        }
    });
});

// 加载账户列表
function loadAccounts(page = 1) {
    currentPage = page;
    
    const params = new URLSearchParams({
        page: page,
        limit: 20,
        search: currentSearch,
        provider_code: currentProvider
    });
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/getList') ?>?' + params)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                displayAccounts(data.data);
                displayPagination(data.total, data.page, data.limit);
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('加载失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('加载失败: ' + data.message);
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('加载失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('加载失败');
            }
        });
}

// 显示账户列表
function displayAccounts(accounts) {
    const tbody = document.getElementById('accountsList');
    
    if (accounts.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" class="text-center">暂无数据</td></tr>';
        return;
    }
    
    tbody.innerHTML = accounts.map(account => `
        <tr>
            <td>${account.id}</td>
            <td>${account.provider_name}</td>
            <td>${account.account_name}${account.is_default == 1 ? ' <span class="badge bg-primary">默认</span>' : ''}</td>
            <td><span class="api-key-masked">${account.api_key_masked || '******'}</span></td>
            <td class="${account.balance > 10 ? 'balance-normal' : 'balance-low'}">${account.balance_formatted}</td>
            <td>${account.total_spent_formatted}</td>
            <td>${account.connection_status_text}</td>
            <td>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" ${account.is_active == 1 ? 'checked' : ''} 
                        onchange="toggleActive(${account.id})" ${account.connection_status !== 'success' ? 'disabled' : ''}>
                </div>
            </td>
            <td>${account.created_at_formatted}</td>
            <td>
                <button class="btn btn-sm btn-info" onclick="testConnection(${account.id})" title="测试连接">
                    <i class="mdi mdi-wifi"></i>
                </button>
                <button class="btn btn-sm btn-primary" onclick="editAccount(${account.id})" title="编辑">
                    <i class="mdi mdi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-success" onclick="viewUsage(${account.id})" title="使用记录">
                    <i class="mdi mdi-chart-line"></i>
                </button>
                <button class="btn btn-sm btn-danger" onclick="deleteAccount(${account.id})" title="删除">
                    <i class="mdi mdi-delete"></i>
                </button>
            </td>
        </tr>
    `).join('');
}

// 显示分页
function displayPagination(total, page, limit) {
    const totalPages = Math.ceil(total / limit);
    const pagination = document.getElementById('pagination');
    
    if (totalPages <= 1) {
        pagination.innerHTML = '';
        return;
    }
    
    let html = '<nav><ul class="pagination justify-content-center">';
    
    // 上一页
    html += `<li class="page-item ${page === 1 ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadAccounts(${page - 1}); return false;">上一页</a>
    </li>`;
    
    // 页码
    for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
            html += `<li class="page-item ${i === page ? 'active' : ''}">
                <a class="page-link" href="#" onclick="loadAccounts(${i}); return false;">${i}</a>
            </li>`;
        } else if (i === page - 3 || i === page + 3) {
            html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
    }
    
    // 下一页
    html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="loadAccounts(${page + 1}); return false;">下一页</a>
    </li>`;
    
    html += '</ul></nav>';
    pagination.innerHTML = html;
}

// 搜索账户
function searchAccounts() {
    currentSearch = document.getElementById('searchInput').value;
    loadAccounts(1);
}

// 按供应商筛选
function filterByProvider() {
    currentProvider = document.getElementById('providerFilter').value;
    loadAccounts(1);
}

// 刷新列表
function refreshList() {
    loadAccounts(currentPage);
}

// 激活状态变化时的处理
function onActivateChange() {
    const activateCheckbox = document.getElementById('is_active');
    
    // 如果是要激活账户
    if (activateCheckbox.checked) {
        // 检查必要字段是否已填写
        const providerCode = document.getElementById('provider_code').value;
        const apiKey = document.getElementById('api_key').value;
        
        if (!providerCode) {
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择供应商') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('请先选择供应商');
            }
            return;
        }
        
        if (!apiKey) {
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先填写API密钥') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('请先填写API密钥');
            }
            return;
        }
        
        // 先保存账户，然后进行连接测试
        saveAccountForActivation();
    }
}

// 为激活而保存账户
function saveAccountForActivation() {
    const activateCheckbox = document.getElementById('is_active');
    const form = document.getElementById('accountForm');
    
    // 显示保存中状态
    const originalLabel = document.querySelector('label[for="is_active"]').textContent;
    document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...';
    activateCheckbox.disabled = true;
    
    // 验证表单
    if (!form.checkValidity()) {
        form.reportValidity();
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        return;
    }
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // 确保激活状态为1
    data.is_active = '1';
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 保存成功，更新账户ID
            document.getElementById('accountId').value = data.account_id || data.id;
            
            // 进行连接测试
            testConnectionForActivation(data.account_id || data.id);
        } else {
            // 保存失败
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('保存失败: ' + data.message);
            }
        }
    })
    .catch(error => {
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('保存失败');
        }
    });
}

// 为激活而进行的连接测试
function testConnectionForActivation(accountId) {
    const activateCheckbox = document.getElementById('is_active');
    
    // 更新状态为测试中
    document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>测试中...';
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: accountId })
    })
    .then(response => response.json())
    .then(data => {
        // 恢复状态
        const originalLabel = '激活';
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        
        if (data.success) {
            // 测试成功，保持激活状态
            showResultModal('success', '连接测试成功', 
                `连接测试成功！\n\n使用的测试模型: ${data.model_code || '未知'}\n\n账户已激活。`);
        } else {
            // 测试失败，取消激活状态
            activateCheckbox.checked = false;
            showResultModal('error', '连接测试失败', 
                `连接测试失败，无法激活账户！\n\n错误信息: ${data.message}\n\n请检查API密钥和网络连接后重试。`);
        }
    })
    .catch(error => {
        // 恢复状态
        const originalLabel = '激活';
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        
        console.error('Error:', error);
        showResultModal('error', '连接测试失败', 
            '连接测试失败，无法激活账户！\n\n网络错误，请检查网络连接后重试。');
    });
}

// 供应商选择变化时的处理
function onProviderChange() {
    const providerSelect = document.getElementById('provider_code');
    const accountNameInput = document.getElementById('account_name');
    const baseUrlInput = document.getElementById('base_url');
    
    const selectedOption = providerSelect.options[providerSelect.selectedIndex];
    
    if (selectedOption.value) {
        // 自动填充供应商名称到账户名称
        const providerName = selectedOption.getAttribute('data-name');
        if (providerName && !accountNameInput.value) {
            accountNameInput.value = providerName;
        }
        
        // 自动填充基础URL
        const baseUrl = selectedOption.getAttribute('data-base-url');
        if (baseUrl && !baseUrlInput.value) {
            baseUrlInput.value = baseUrl;
        }
    } else {
        // 如果选择的是"请选择供应商"，清空相关字段
        if (!accountNameInput.value || accountNameInput.value === accountNameInput.defaultValue) {
            accountNameInput.value = '';
        }
        if (!baseUrlInput.value || baseUrlInput.value === baseUrlInput.defaultValue) {
            baseUrlInput.value = '';
        }
    }
}

// 添加账户
function addAccount() {
    document.getElementById('accountModalTitle').textContent = '添加供应商账户';
    document.getElementById('accountForm').reset();
    document.getElementById('accountId').value = '0';
    document.getElementById('api_key').required = true;
    document.getElementById('proxySettings').style.display = 'none';
    
    // 恢复API密钥字段的必填状态和提示
    document.getElementById('api_key_required').style.display = 'inline';
    document.getElementById('api_key_hint').textContent = 'API密钥将被加密存储';
    
    const modal = new bootstrap.Modal(document.getElementById('accountModal'));
    modal.show();
}

// 编辑账户
function editAccount(id) {
    // 先重置表单与状态，避免上一次弹窗残留
    document.getElementById('accountForm').reset();
    document.getElementById('accountId').value = '0';
    document.getElementById('api_key').value = '';
    document.getElementById('api_key').required = false;
    document.getElementById('api_key_required').style.display = 'none';
    document.getElementById('api_key_hint').textContent = '编辑时留空表示不修改API密钥';
    document.getElementById('proxy_enabled').checked = false;
    document.getElementById('proxySettings').style.display = 'none';
    document.getElementById('proxy_type').value = 'http';
    document.getElementById('proxy_host').value = '';
    document.getElementById('proxy_port').value = '';
    document.getElementById('proxy_username').value = '';
    document.getElementById('proxy_password').value = '';

    // 加载账户数据并显示在弹窗中
    fetch('<?= $this->getBackendUrl('*/backend/provider/getAccount') ?>?id=' + encodeURIComponent(id))
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const account = data.data;
            
            // 设置弹窗标题
            document.getElementById('accountModalTitle').textContent = '编辑供应商账户';
            
            // 填充表单数据
            document.getElementById('accountId').value = account.id;
            document.getElementById('provider_code').value = account.provider_code;
            document.getElementById('account_name').value = account.account_name;
            const apiKeyInput = document.getElementById('api_key');
            apiKeyInput.value = '';
            apiKeyInput.required = false; // 编辑时API密钥不是必填
            // 占位符显示掩码，便于用户确认已配置
            if (account.api_key_masked && account.api_key_masked.length > 0) {
                apiKeyInput.placeholder = account.api_key_masked + '（留空不修改）';
            } else {
                apiKeyInput.placeholder = '编辑时留空表示不修改';
            }
            document.getElementById('base_url').value = account.base_url || '';
            document.getElementById('balance').value = account.balance ? Number(account.balance) : 0;
            document.getElementById('currency').value = account.currency || 'USD';
            document.getElementById('is_active').checked = account.is_active == 1;
            document.getElementById('is_default').checked = account.is_default == 1;
            
            // 更新API密钥字段提示
            document.getElementById('api_key_required').style.display = 'none';
            document.getElementById('api_key_hint').textContent =
                (account.api_key_masked && account.api_key_masked.length > 0)
                    ? ('已配置密钥：' + account.api_key_masked + '，编辑时留空表示不修改API密钥')
                    : '编辑时留空表示不修改API密钥';
            
            // 处理代理设置
            if (account.proxy_config) {
                try {
                    const proxyConfig = typeof account.proxy_config === 'string' ? 
                        JSON.parse(account.proxy_config) : account.proxy_config;
                    
                    if (proxyConfig && Object.keys(proxyConfig).length > 0) {
                        document.getElementById('proxy_enabled').checked = true;
                        document.getElementById('proxySettings').style.display = 'block';
                        document.getElementById('proxy_type').value = proxyConfig.type || 'http';
                        document.getElementById('proxy_host').value = proxyConfig.host || '';
                        document.getElementById('proxy_port').value = proxyConfig.port || '';
                        document.getElementById('proxy_username').value = proxyConfig.username || '';
                        document.getElementById('proxy_password').value = ''; // 不显示密码
                    }
                } catch (e) {
                    console.error('解析代理配置失败:', e);
                    // 解析失败则保持代理关闭
                    document.getElementById('proxy_enabled').checked = false;
                    document.getElementById('proxySettings').style.display = 'none';
                }
            } else {
                // 无代理配置则确保关闭
                document.getElementById('proxy_enabled').checked = false;
                document.getElementById('proxySettings').style.display = 'none';
            }
            
            // 显示弹窗
            const modal = new bootstrap.Modal(document.getElementById('accountModal'));
            modal.show();
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('加载失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('加载账户数据失败: ' + data.message);
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('加载失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('加载账户数据失败');
        }
    });
}

// 保存账户
function saveAccount() {
    const form = document.getElementById('accountForm');
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('accountModal')).hide();
            loadAccounts(currentPage);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log(data.message);
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('保存失败: ' + data.message);
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('保存失败');
        }
    });
}

// 测试连接
function testConnection(id) {
    const btn = event.target.closest('button');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
    btn.disabled = true;
    
    // 显示不可关闭的测试中弹窗
    const testModal = createTestModal();
    document.body.appendChild(testModal);
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: id })
    })
    .then(response => response.json())
    .then(data => {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
        
        // 移除测试弹窗
        document.body.removeChild(testModal);
        
        if (data.success) {
            // 显示成功消息，包含模型代码
            const message = data.model_code ? 
                `${data.message}\n\n使用的测试模型: ${data.model_code}` : 
                data.message;
            showResultModal('success', '连接测试成功', message);
            loadAccounts(currentPage);
        } else {
            // 显示失败消息，包含模型代码
            const message = data.model_code ? 
                `测试失败: ${data.message}\n\n尝试使用的模型: ${data.model_code}` : 
                `测试失败: ${data.message}`;
            showResultModal('error', '连接测试失败', message);
        }
    })
    .catch(error => {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
        
        // 移除测试弹窗
        document.body.removeChild(testModal);
        
        console.error('Error:', error);
        showResultModal('error', '连接测试失败', '测试失败: 网络错误');
    });
}

// 创建测试中弹窗
function createTestModal() {
    const modal = document.createElement('div');
    modal.className = 'modal fade show';
    modal.style.display = 'block';
    modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
    modal.innerHTML = `
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">测试中...</span>
                    </div>
                    <h5 class="mb-2">正在测试连接</h5>
                    <p class="text-muted mb-0">请稍候，正在验证API连接...</p>
                </div>
            </div>
        </div>
    `;
    return modal;
}

// 显示结果弹窗
function showResultModal(type, title, message) {
    const modal = document.createElement('div');
    modal.className = 'modal fade show';
    modal.style.display = 'block';
    modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
    
    const iconClass = type === 'success' ? 'mdi-check-circle text-success' : 'mdi-alert-circle text-danger';
    const iconSize = type === 'success' ? '3rem' : '3rem';
    
    modal.innerHTML = `
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">${title}</h5>
                    <button type="button" class="btn-close" onclick="closeResultModal(this)"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="mdi ${iconClass} mb-3" style="font-size: ${iconSize};"></i>
                    <div class="message-content" style="white-space: pre-line; text-align: left; max-height: 300px; overflow-y: auto;">
                        ${message}
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="closeResultModal(this)">确定</button>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
    return modal;
}

// 关闭结果弹窗
function closeResultModal(button) {
    const modal = button.closest('.modal');
    document.body.removeChild(modal);
}

// 加载使用记录
function loadUsageList(accountId, page = 1) {
    document.getElementById('usageLoading').style.display = 'block';
    const params = new URLSearchParams({
        page: page,
        limit: 20,
        account_id: accountId
    });
    fetch('<?= $this->getBackendUrl('*/backend/provider/getUsageList') ?>?' + params)
        .then(r => r.json())
        .then(data => {
            document.getElementById('usageLoading').style.display = 'none';
            const tbody = document.getElementById('usageTbody');
            if (!data.success || !data.data || data.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center">暂无数据</td></tr>';
                document.getElementById('usagePagination').innerHTML = '';
                return;
            }
            tbody.innerHTML = data.data.map(r => `
                <tr>
                    <td>${r.created_at_formatted || '-'}</td>
                    <td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;">${r.request_id || '-'}</td>
                    <td>${r.request_type || '-'}</td>
                    <td>${r.prompt_tokens ?? 0}</td>
                    <td>${r.completion_tokens ?? 0}</td>
                    <td>${r.total_tokens ?? 0}</td>
                    <td>${r.request_time_formatted || '-'}</td>
                    <td>${r.total_cost_formatted || '-'}</td>
                    <td>${r.status || '-'}</td>
                </tr>
            `).join('');
            renderUsagePagination(data.total, data.page, 20);
        })
        .catch(err => {
            document.getElementById('usageLoading').style.display = 'none';
            console.error(err);
            document.getElementById('usageTbody').innerHTML = '<tr><td colspan="9" class="text-center text-danger">加载失败</td></tr>';
        });
}

function renderUsagePagination(total, page, limit) {
    const totalPages = Math.ceil(total / limit);
    const el = document.getElementById('usagePagination');
    if (totalPages <= 1) { el.innerHTML = ''; return; }
    let html = '<nav><ul class="pagination justify-content-center">';
    html += `<li class="page-item ${page === 1 ? 'disabled' : ''}"><a class="page-link" href="#" onclick="loadUsageList(${document.getElementById('usageAccountId').value}, ${page-1}); return false;">上一页</a></li>`;
    for (let i=1;i<=totalPages;i++) {
        if (i === 1 || i === totalPages || (i >= page-2 && i <= page+2)) {
            html += `<li class="page-item ${i===page?'active':''}"><a class="page-link" href="#" onclick="loadUsageList(${document.getElementById('usageAccountId').value}, ${i}); return false;">${i}</a></li>`;
        } else if (i === page-3 || i === page+3) {
            html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
    }
    html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" onclick="loadUsageList(${document.getElementById('usageAccountId').value}, ${page+1}); return false;">下一页</a></li>`;
    html += '</ul></nav>';
    el.innerHTML = html;
}

// 切换激活状态
function toggleActive(id) {
    fetch('<?= $this->getBackendUrl('*/backend/provider/toggleActive') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: id })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message);
            }
            loadAccounts(currentPage);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('操作失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('操作失败');
        }
        loadAccounts(currentPage);
    });
}

// 删除账户
function deleteAccount(id) {
    if (!confirm('确定要删除此账户吗？此操作不可恢复！')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: id })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                });
            } else {
                console.log(data.message);
            }
            loadAccounts(currentPage);
        } else {
            showResultModal('error', '删除失败', '删除失败: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showResultModal('error', '删除失败', '删除失败: 网络错误');
    });
}

// 查看使用记录
function viewUsage(id) {
    // 打开弹窗并加载第一页
    document.getElementById('usageAccountId').value = id;
    document.getElementById('usagePage').value = '1';
    const modal = new bootstrap.Modal(document.getElementById('usageModal'));
    modal.show();
    loadUsageList(id, 1);
}

