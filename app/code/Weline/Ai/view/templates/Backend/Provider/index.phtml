<script>
(function() {
    'use strict';

    var currentPage = 1;
    var currentSearch = '';
    var currentProvider = '';

    // 页面加载完成后初始化
    document.addEventListener('DOMContentLoaded', function() {
        loadAccounts();
        
        // 代理设置切换
        document.getElementById('proxy_enabled').addEventListener('change', function() {
            document.getElementById('proxySettings').style.display = this.checked ? 'block' : 'none';
        });
        
        // 供应商选择时自动填充基础URL
        document.getElementById('provider_code').addEventListener('change', function() {
            var baseUrl = this.options[this.selectedIndex].getAttribute('data-base-url');
            if (baseUrl && !document.getElementById('base_url').value) {
                document.getElementById('base_url').value = baseUrl;
            }
        });
        
        // 回车搜索
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchAccounts();
            }
        });
    });

    // 加载账户列表
    function loadAccounts(page) {
        page = page || 1;
        currentPage = page;
        
        var params = new URLSearchParams({
            page: page,
            limit: 20,
            search: currentSearch,
            provider_code: currentProvider
        });
        
        var listUrl = '<?= $this->getBackendUrl('*/backend/provider/getList') ?>?' + params;
        var req = window.Weline.Api.get(listUrl, { silent: true });
        req.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                    displayAccounts(data.data);
                    displayPagination(data.total, data.page, data.limit);
                } else {
                    if (typeof BackendModal !== 'undefined') {
                        BackendModal.alert('<?= __('加载失败') ?>', data.message);
                    } else if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(data.message);
                    } else {
                        console.error('加载失败: ' + data.message);
                    }
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                if (typeof BackendModal !== 'undefined') {
                    BackendModal.alert('<?= __('加载失败') ?>', '<?= __('请重试') ?>');
                } else if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('请重试') ?>');
                }
            });
    }
    window.loadAccounts = loadAccounts;

    // 显示账户列表
    function displayAccounts(accounts) {
        var tbody = document.getElementById('accountsList');
        
        if (accounts.length === 0) {
            tbody.innerHTML = '<tr><td colspan="10" class="text-center">暂无数据</td></tr>';
            return;
        }
        
        tbody.innerHTML = accounts.map(function(account) {
            return '<tr>' +
                '<td>' + account.id + '</td>' +
                '<td>' + account.provider_name + '</td>' +
                '<td>' + account.account_name + (account.is_default == 1 ? ' <span class="badge bg-primary">默认</span>' : '') + '</td>' +
                '<td><span class="weline-ai-api-key-masked">' + (account.api_key_masked || '******') + '</span></td>' +
                '<td class="' + (account.balance > 10 ? 'weline-ai-balance-normal' : 'weline-ai-balance-low') + '">' + account.balance_formatted + '</td>' +
                '<td>' + account.total_spent_formatted + '</td>' +
                '<td>' + account.connection_status_text + '</td>' +
                '<td>' +
                    '<div class="form-check form-switch">' +
                        '<input class="form-check-input" type="checkbox" ' + (account.is_active == 1 ? 'checked' : '') + ' onchange="toggleActive(' + account.id + ')" ' + (account.connection_status !== 'success' ? 'disabled' : '') + '>' +
                    '</div>' +
                '</td>' +
                '<td>' + account.created_at_formatted + '</td>' +
                '<td>' +
                    '<button class="btn btn-sm btn-info" onclick="testConnection(' + account.id + ')" title="测试连接"><i class="mdi mdi-wifi"></i></button> ' +
                    '<button class="btn btn-sm btn-primary" onclick="editAccount(' + account.id + ')" title="编辑"><i class="mdi mdi-pencil"></i></button> ' +
                    '<button class="btn btn-sm btn-success" onclick="viewUsage(' + account.id + ')" title="使用记录"><i class="mdi mdi-chart-line"></i></button> ' +
                    '<button class="btn btn-sm btn-danger" onclick="deleteAccount(' + account.id + ')" title="删除"><i class="mdi mdi-delete"></i></button>' +
                '</td>' +
            '</tr>';
        }).join('');
    }

    // 显示分页
    function displayPagination(total, page, limit) {
        var totalPages = Math.ceil(total / limit);
        var pagination = document.getElementById('pagination');
        
        if (totalPages <= 1) {
            pagination.innerHTML = '';
            return;
        }
        
        var html = '<nav><ul class="pagination justify-content-center">';
        
        // 上一页
        html += '<li class="page-item ' + (page === 1 ? 'disabled' : '') + '">' +
            '<a class="page-link" href="#" onclick="loadAccounts(' + (page - 1) + '); return false;">上一页</a>' +
        '</li>';
        
        // 页码
        for (var i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
                html += '<li class="page-item ' + (i === page ? 'active' : '') + '">' +
                    '<a class="page-link" href="#" onclick="loadAccounts(' + i + '); return false;">' + i + '</a>' +
                '</li>';
            } else if (i === page - 3 || i === page + 3) {
                html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
            }
        }
        
        // 下一页
        html += '<li class="page-item ' + (page === totalPages ? 'disabled' : '') + '">' +
            '<a class="page-link" href="#" onclick="loadAccounts(' + (page + 1) + '); return false;">下一页</a>' +
        '</li>';
        
        html += '</ul></nav>';
        pagination.innerHTML = html;
    }

    // 搜索账户
    window.searchAccounts = function() {
        currentSearch = document.getElementById('searchInput').value;
        loadAccounts(1);
    };

    // 按供应商筛选
    window.filterByProvider = function() {
        currentProvider = document.getElementById('providerFilter').value;
        loadAccounts(1);
    };

    // 刷新列表
    window.refreshList = function() {
        loadAccounts(currentPage);
    };

    // 激活状态变化时的处理
    window.onActivateChange = function() {
        var activateCheckbox = document.getElementById('is_active');
        
        // 如果是要激活账户
        if (activateCheckbox.checked) {
            // 检查必要字段是否已填写
            var providerCode = document.getElementById('provider_code').value;
            var apiKey = document.getElementById('api_key').value;
            
            if (!providerCode) {
                activateCheckbox.checked = false;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请先选择供应商') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
                return;
            }
            
            if (!apiKey) {
                activateCheckbox.checked = false;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __('提示') ?>',
                        text: '<?= __('请先填写API密钥') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
                return;
            }
            
            // 先保存账户，然后进行连接测试
            saveAccountForActivation();
        }
    };

    // 为激活而保存账户
    function saveAccountForActivation() {
        var activateCheckbox = document.getElementById('is_active');
        var form = document.getElementById('accountForm');
        
        // 显示保存中状态
        var originalLabel = document.querySelector('label[for="is_active"]').textContent;
        document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...';
        activateCheckbox.disabled = true;
        
        // 验证表单
        if (!form.checkValidity()) {
            form.reportValidity();
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            activateCheckbox.checked = false;
            return;
        }
        
        var formData = new FormData(form);
        var data = Object.fromEntries(formData);
        
        // 确保激活状态为1
        data.is_active = '1';
        var saveUrl0 = '<?= $this->getBackendUrl('*/backend/provider/save') ?>';
        var opts0 = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) };
        var req0 = window.Weline.Api.request(saveUrl0, opts0);
        req0.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                // 保存成功，更新账户ID
                document.getElementById('accountId').value = data.account_id || data.id;
                
                // 进行连接测试
                testConnectionForActivation(data.account_id || data.id);
            } else {
                // 保存失败
                document.querySelector('label[for="is_active"]').textContent = originalLabel;
                activateCheckbox.disabled = false;
                activateCheckbox.checked = false;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            }
        })
        .catch(function(error) {
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            activateCheckbox.checked = false;
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
        });
    }

    // 为激活而进行的连接测试
    function testConnectionForActivation(accountId) {
        var activateCheckbox = document.getElementById('is_active');
        
        // 更新状态为测试中
        document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>测试中...';
        
        var tcUrl = '<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>';
        var tcOpts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: accountId }) };
        var req = window.Weline.Api.request(tcUrl, tcOpts);
        req.then(function(res) {
            var data = (res && res.data) || res;
            // 恢复状态
            var originalLabel = '激活';
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            
            if (data.success) {
                // 测试成功，保持激活状态
                showResultModal('success', '连接测试成功', 
                    '连接测试成功！\n\n使用的测试模型: ' + (data.model_code || '未知') + '\n\n账户已激活。');
            } else {
                // 测试失败，取消激活状态
                activateCheckbox.checked = false;
                showResultModal('error', '连接测试失败', 
                    '连接测试失败，无法激活账户！\n\n错误信息: ' + data.message + '\n\n请检查API密钥和网络连接后重试。');
            }
        })
        .catch(function(error) {
            // 恢复状态
            var originalLabel = '激活';
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            activateCheckbox.checked = false;
            
            console.error('Error:', error);
            showResultModal('error', '连接测试失败', 
                '连接测试失败，无法激活账户！\n\n网络错误，请检查网络连接后重试。');
        });
    }

    // 供应商选择变化时的处理
    window.onProviderChange = function() {
        var providerSelect = document.getElementById('provider_code');
        var accountNameInput = document.getElementById('account_name');
        var baseUrlInput = document.getElementById('base_url');
        
        var selectedOption = providerSelect.options[providerSelect.selectedIndex];
        
        if (selectedOption.value) {
            // 自动填充供应商名称到账户名称
            var providerName = selectedOption.getAttribute('data-name');
            if (providerName && !accountNameInput.value) {
                accountNameInput.value = providerName;
            }
            
            // 自动填充基础URL
            var baseUrl = selectedOption.getAttribute('data-base-url');
            if (baseUrl && !baseUrlInput.value) {
                baseUrlInput.value = baseUrl;
            }
        }
    };

    // 添加账户
    window.addAccount = function() {
        document.getElementById('accountModalTitle').textContent = '添加供应商账户';
        document.getElementById('accountForm').reset();
        document.getElementById('accountId').value = '0';
        document.getElementById('api_key').required = true;
        document.getElementById('proxySettings').style.display = 'none';
        
        // 恢复API密钥字段的必填状态和提示
        document.getElementById('api_key_required').style.display = 'inline';
        document.getElementById('api_key_hint').textContent = 'API密钥将被加密存储';
        
        var modal = new bootstrap.Modal(document.getElementById('accountModal'));
        modal.show();
    };

    // 编辑账户
    window.editAccount = function(id) {
        // 先重置表单与状态，避免上一次弹窗残留
        document.getElementById('accountForm').reset();
        document.getElementById('accountId').value = '0';
        document.getElementById('api_key').value = '';
        document.getElementById('api_key').required = false;
        document.getElementById('api_key_required').style.display = 'none';
        document.getElementById('api_key_hint').textContent = '编辑时留空表示不修改API密钥';
        document.getElementById('proxy_enabled').checked = false;
        document.getElementById('proxySettings').style.display = 'none';
        document.getElementById('proxy_type').value = 'http';
        document.getElementById('proxy_host').value = '';
        document.getElementById('proxy_port').value = '';
        document.getElementById('proxy_username').value = '';
        document.getElementById('proxy_password').value = '';

        // 加载账户数据并显示在弹窗中
        var gaUrl = '<?= $this->getBackendUrl('*/backend/provider/getAccount') ?>?id=' + encodeURIComponent(id);
        var gaReq = window.Weline.Api.get(gaUrl, { silent: true });
        gaReq.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                var account = data.data;
                
                // 设置弹窗标题
                document.getElementById('accountModalTitle').textContent = '编辑供应商账户';
                
                // 填充表单数据
                document.getElementById('accountId').value = account.id;
                document.getElementById('provider_code').value = account.provider_code;
                document.getElementById('account_name').value = account.account_name;
                var apiKeyInput = document.getElementById('api_key');
                apiKeyInput.value = '';
                apiKeyInput.required = false;
                // 占位符显示掩码，便于用户确认已配置
                if (account.api_key_masked && account.api_key_masked.length > 0) {
                    apiKeyInput.placeholder = account.api_key_masked + '（留空不修改）';
                } else {
                    apiKeyInput.placeholder = '编辑时留空表示不修改';
                }
                document.getElementById('base_url').value = account.base_url || '';
                document.getElementById('balance').value = account.balance ? Number(account.balance) : 0;
                document.getElementById('currency').value = account.currency || 'USD';
                document.getElementById('is_active').checked = account.is_active == 1;
                document.getElementById('is_default').checked = account.is_default == 1;
                
                // 更新API密钥字段提示
                document.getElementById('api_key_required').style.display = 'none';
                document.getElementById('api_key_hint').textContent =
                    (account.api_key_masked && account.api_key_masked.length > 0)
                        ? ('已配置密钥：' + account.api_key_masked + '，编辑时留空表示不修改API密钥')
                        : '编辑时留空表示不修改API密钥';
                
                // 处理代理设置
                if (account.proxy_config) {
                    try {
                        var proxyConfig = typeof account.proxy_config === 'string' ? 
                            JSON.parse(account.proxy_config) : account.proxy_config;
                        
                        if (proxyConfig && Object.keys(proxyConfig).length > 0) {
                            document.getElementById('proxy_enabled').checked = true;
                            document.getElementById('proxySettings').style.display = 'block';
                            document.getElementById('proxy_type').value = proxyConfig.type || 'http';
                            document.getElementById('proxy_host').value = proxyConfig.host || '';
                            document.getElementById('proxy_port').value = proxyConfig.port || '';
                            document.getElementById('proxy_username').value = proxyConfig.username || '';
                            document.getElementById('proxy_password').value = '';
                        }
                    } catch (e) {
                        console.error('解析代理配置失败:', e);
                        document.getElementById('proxy_enabled').checked = false;
                        document.getElementById('proxySettings').style.display = 'none';
                    }
                } else {
                    document.getElementById('proxy_enabled').checked = false;
                    document.getElementById('proxySettings').style.display = 'none';
                }
                
                // 显示弹窗
                var modal = new bootstrap.Modal(document.getElementById('accountModal'));
                modal.show();
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('加载失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('加载失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
        });
    };

    // 保存账户
    window.saveAccount = function() {
        var form = document.getElementById('accountForm');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        
        var formData = new FormData(form);
        var data = Object.fromEntries(formData);
        var saveUrl2 = '<?= $this->getBackendUrl('*/backend/provider/save') ?>';
        var opts2 = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) };
        var req2 = window.Weline.Api.request(saveUrl2, opts2);
        req2.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                bootstrap.Modal.getInstance(document.getElementById('accountModal')).hide();
                loadAccounts(currentPage);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
        });
    };

    // 测试连接
    window.testConnection = function(id) {
        var btn = event.target.closest('button');
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
        btn.disabled = true;
        
        // 显示不可关闭的测试中弹窗
        var testModal = createTestModal();
        document.body.appendChild(testModal);
        
        var tcUrl2 = '<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>';
        var tcOpts2 = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) };
        var req2 = window.Weline.Api.request(tcUrl2, tcOpts2);
        req2.then(function(res) {
            var data = (res && res.data) || res;
            btn.innerHTML = originalHtml;
            btn.disabled = false;
            
            // 移除测试弹窗
            document.body.removeChild(testModal);
            
            if (data.success) {
                // 显示成功消息，包含模型代码
                var message = data.model_code ? 
                    data.message + '\n\n使用的测试模型: ' + data.model_code : 
                    data.message;
                showResultModal('success', '连接测试成功', message);
                loadAccounts(currentPage);
            } else {
                // 显示失败消息，包含模型代码
                var message = data.model_code ? 
                    '测试失败: ' + data.message + '\n\n尝试使用的模型: ' + data.model_code : 
                    '测试失败: ' + data.message;
                showResultModal('error', '连接测试失败', message);
            }
        })
        .catch(function(error) {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
            
            // 移除测试弹窗
            document.body.removeChild(testModal);
            
            console.error('Error:', error);
            showResultModal('error', '连接测试失败', '测试失败: 网络错误');
        });
    };

    // 创建测试中弹窗
    function createTestModal() {
        var modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
        modal.innerHTML = '<div class="modal-dialog modal-dialog-centered">' +
            '<div class="modal-content">' +
                '<div class="modal-body text-center py-4">' +
                    '<div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">' +
                        '<span class="visually-hidden">测试中...</span>' +
                    '</div>' +
                    '<h5 class="mb-2">正在测试连接</h5>' +
                    '<p class="text-muted mb-0">请稍候，正在验证API连接...</p>' +
                '</div>' +
            '</div>' +
        '</div>';
        return modal;
    }

    // 显示结果弹窗
    function showResultModal(type, title, message) {
        var modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
        
        var iconClass = type === 'success' ? 'mdi-check-circle text-success' : 'mdi-alert-circle text-danger';
        
        modal.innerHTML = '<div class="modal-dialog modal-dialog-centered">' +
            '<div class="modal-content">' +
                '<div class="modal-header">' +
                    '<h5 class="modal-title">' + title + '</h5>' +
                    '<button type="button" class="btn-close" onclick="closeResultModal(this)"></button>' +
                '</div>' +
                '<div class="modal-body text-center py-4">' +
                    '<i class="mdi ' + iconClass + ' mb-3" style="font-size: 3rem;"></i>' +
                    '<div class="message-content" style="white-space: pre-line; text-align: left; max-height: 300px; overflow-y: auto;">' +
                        message +
                    '</div>' +
                '</div>' +
                '<div class="modal-footer">' +
                    '<button type="button" class="btn btn-primary" onclick="closeResultModal(this)">确定</button>' +
                '</div>' +
            '</div>' +
        '</div>';
        
        document.body.appendChild(modal);
        return modal;
    }
    window.showResultModal = showResultModal;

    // 关闭结果弹窗
    window.closeResultModal = function(button) {
        var modal = button.closest('.modal');
        document.body.removeChild(modal);
    };

    // 加载使用记录
    function loadUsageList(accountId, page) {
        page = page || 1;
        document.getElementById('usageLoading').style.display = 'block';
        var params = new URLSearchParams({
            page: page,
            limit: 20,
            account_id: accountId
        });
        var ulUrl = '<?= $this->getBackendUrl('*/backend/provider/getUsageList') ?>?' + params;
        var ulReq = window.Weline.Api.get(ulUrl, { silent: true });
        ulReq.then(function(res) {
            var data = (res && res.data) || res;
                document.getElementById('usageLoading').style.display = 'none';
                var tbody = document.getElementById('usageTbody');
                if (!data.success || !data.data || data.data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center">暂无数据</td></tr>';
                    document.getElementById('usagePagination').innerHTML = '';
                    return;
                }
                tbody.innerHTML = data.data.map(function(r) {
                    return '<tr>' +
                        '<td>' + (r.created_at_formatted || '-') + '</td>' +
                        '<td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;">' + (r.request_id || '-') + '</td>' +
                        '<td>' + (r.request_type || '-') + '</td>' +
                        '<td>' + (r.prompt_tokens || 0) + '</td>' +
                        '<td>' + (r.completion_tokens || 0) + '</td>' +
                        '<td>' + (r.total_tokens || 0) + '</td>' +
                        '<td>' + (r.request_time_formatted || '-') + '</td>' +
                        '<td>' + (r.total_cost_formatted || '-') + '</td>' +
                        '<td>' + (r.status || '-') + '</td>' +
                    '</tr>';
                }).join('');
                renderUsagePagination(data.total, data.page, 20);
            })
            .catch(function(err) {
                document.getElementById('usageLoading').style.display = 'none';
                console.error(err);
                document.getElementById('usageTbody').innerHTML = '<tr><td colspan="9" class="text-center text-danger">加载失败</td></tr>';
            });
    }
    window.loadUsageList = loadUsageList;

    function renderUsagePagination(total, page, limit) {
        var totalPages = Math.ceil(total / limit);
        var el = document.getElementById('usagePagination');
        if (totalPages <= 1) { el.innerHTML = ''; return; }
        var accountId = document.getElementById('usageAccountId').value;
        var html = '<nav><ul class="pagination justify-content-center">';
        html += '<li class="page-item ' + (page === 1 ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="loadUsageList(' + accountId + ', ' + (page-1) + '); return false;">上一页</a></li>';
        for (var i=1;i<=totalPages;i++) {
            if (i === 1 || i === totalPages || (i >= page-2 && i <= page+2)) {
                html += '<li class="page-item ' + (i===page?'active':'') + '"><a class="page-link" href="#" onclick="loadUsageList(' + accountId + ', ' + i + '); return false;">' + i + '</a></li>';
            } else if (i === page-3 || i === page+3) {
                html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
            }
        }
        html += '<li class="page-item ' + (page === totalPages ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="loadUsageList(' + accountId + ', ' + (page+1) + '); return false;">下一页</a></li>';
        html += '</ul></nav>';
        el.innerHTML = html;
    }

    // 切换激活状态
    window.toggleActive = function(id) {
        var taUrl = '<?= $this->getBackendUrl('*/backend/provider/toggleActive') ?>';
        var taReq = window.Weline.Api.request(taUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) });
        taReq.then(function(res) {
            var data = (res && res.data) || res;
            if (!data || !data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
                loadAccounts(currentPage);
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
            loadAccounts(currentPage);
        });
    };

    // 删除账户
    window.deleteAccount = function(id) {
        BackendConfirm.show('<?= __('确定要删除此账户吗？此操作不可恢复！') ?>').then(function(confirmed) {
            if (!confirmed) return;
            var delUrl = '<?= $this->getBackendUrl('*/backend/provider/delete') ?>';
            var delOpts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) };
            var delReq = window.Weline.Api.request(delUrl, delOpts);
            delReq.then(function(res) {
            var data = (res && res.data) || res;
            if (data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
                loadAccounts(currentPage);
            } else {
                showResultModal('error', '<?= __('删除失败') ?>', '<?= __('删除失败') ?>: ' + (data.message || ''));
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            showResultModal('error', '<?= __('删除失败') ?>', '<?= __('删除失败') ?>: <?= __('网络错误') ?>');
        });
        });
    };

    // 查看使用记录
    window.viewUsage = function(id) {
        // 打开弹窗并加载第一页
        document.getElementById('usageAccountId').value = id;
        document.getElementById('usagePage').value = '1';
        var modal = new bootstrap.Modal(document.getElementById('usageModal'));
        modal.show();
        loadUsageList(id, 1);
    };
})();
</script>
