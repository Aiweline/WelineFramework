            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var WelineAiUsage = {
        accountId: <?= $account_id ?: 'null' ?>,
        currentPage: 1,
        currentDateFrom: '',
        currentDateTo: '',
        
        init: function() {
            var self = this;
            
            // 设置默认日期范围（最近30天）
            var today = new Date();
            var thirtyDaysAgo = new Date(today.getTime() - (30 * 24 * 60 * 60 * 1000));
            
            document.getElementById('weline-ai-date-to').value = today.toISOString().split('T')[0];
            document.getElementById('weline-ai-date-from').value = thirtyDaysAgo.toISOString().split('T')[0];
            
            // 绑定事件
            document.getElementById('weline-ai-filter-records').addEventListener('click', function() {
                self.filterRecords();
            });
            
            document.getElementById('weline-ai-reset-filter').addEventListener('click', function() {
                self.resetFilter();
            });
            
            document.getElementById('weline-ai-export-data').addEventListener('click', function() {
                self.exportData();
            });
            
            this.filterRecords();
        },
        
        loadUsageRecords: function(page) {
            var self = this;
            page = page || 1;
            this.currentPage = page;
            
            var params = new URLSearchParams({
                page: page,
                limit: 20,
                date_from: this.currentDateFrom,
                date_to: this.currentDateTo
            });
            
            if (this.accountId) {
                params.append('account_id', this.accountId);
            }
            
            var url = '<?= $this->getBackendUrl('*/backend/provider/getUsageList') ?>?' + params;
            var req = window.Weline.Api.get(url, { silent: true });
            req.then(function(res) {
                var data = (res && res.data) || res;
                    if (data.success) {
                        self.displayRecords(data.data);
                        self.displayPagination(data.total, data.page, data.limit);
                        self.updateStats(data.stats);
                    } else {
                        if (typeof AdminToast !== 'undefined') {
                            AdminToast.error(data.message || '<?= __('加载失败') ?>');
                        }
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    if (typeof AdminToast !== 'undefined') {
                        AdminToast.error('<?= __('加载失败，请重试') ?>');
                    }
                });
        },
        
        displayRecords: function(records) {
            var tbody = document.getElementById('weline-ai-usage-list');
            var self = this;
            
            if (records.length === 0) {
                tbody.innerHTML = '<tr><td colspan="11" class="text-center"><?= __('暂无数据') ?></td></tr>';
                return;
            }
            
            tbody.innerHTML = records.map(function(record) {
                return '<tr>' +
                    '<td>' + record.created_at_formatted + '</td>' +
                    '<td>' + (record.model_name || record.model_code) + '</td>' +
                    '<td>' + (record.user_name || record.user_id || '-') + '</td>' +
                    '<td>' + (record.request_type || 'chat') + '</td>' +
                    '<td>' + record.prompt_tokens.toLocaleString() + '</td>' +
                    '<td>' + record.completion_tokens.toLocaleString() + '</td>' +
                    '<td>' + record.total_tokens.toLocaleString() + '</td>' +
                    '<td>' + record.total_cost_formatted + '</td>' +
                    '<td>' + record.request_time_formatted + '</td>' +
                    '<td>' + (record.status === 'success' 
                        ? '<span class="badge bg-success"><?= __('成功') ?></span>' 
                        : '<span class="badge bg-danger"><?= __('失败') ?></span>') + '</td>' +
                    '<td><button class="btn btn-sm btn-info weline-ai-view-detail" data-record=\'' + JSON.stringify(record) + '\'>' +
                        '<i class="mdi mdi-eye"></i></button></td>' +
                '</tr>';
            }).join('');
            
            // 绑定查看详情事件
            document.querySelectorAll('.weline-ai-view-detail').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var record = JSON.parse(this.getAttribute('data-record'));
                    self.viewDetail(record);
                });
            });
        },
        
        displayPagination: function(total, page, limit) {
            var self = this;
            var totalPages = Math.ceil(total / limit);
            var pagination = document.getElementById('weline-ai-pagination');
            
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                return;
            }
            
            var html = '<nav><ul class="pagination justify-content-center">';
            
            html += '<li class="page-item ' + (page === 1 ? 'disabled' : '') + '">' +
                '<a class="page-link" href="#" data-page="' + (page - 1) + '"><?= __('上一页') ?></a></li>';
            
            for (var i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
                    html += '<li class="page-item ' + (i === page ? 'active' : '') + '">' +
                        '<a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>';
                } else if (i === page - 3 || i === page + 3) {
                    html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
                }
            }
            
            html += '<li class="page-item ' + (page === totalPages ? 'disabled' : '') + '">' +
                '<a class="page-link" href="#" data-page="' + (page + 1) + '"><?= __('下一页') ?></a></li>';
            
            html += '</ul></nav>';
            pagination.innerHTML = html;
            
            pagination.querySelectorAll('a[data-page]').forEach(function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    var p = parseInt(this.getAttribute('data-page'));
                    if (p >= 1 && p <= totalPages) {
                        self.loadUsageRecords(p);
                    }
                });
            });
        },
        
        updateStats: function(stats) {
            if (stats) {
                document.getElementById('weline-ai-total-requests').textContent = stats.total_requests.toLocaleString();
                document.getElementById('weline-ai-total-tokens').textContent = stats.total_tokens.toLocaleString();
                document.getElementById('weline-ai-total-cost').textContent = '$' + stats.total_cost;
                document.getElementById('weline-ai-success-rate').textContent = stats.success_rate + '%';
                document.getElementById('weline-ai-stats-cards').style.display = 'flex';
            }
        },
        
        filterRecords: function() {
            this.currentDateFrom = document.getElementById('weline-ai-date-from').value;
            this.currentDateTo = document.getElementById('weline-ai-date-to').value;
            this.loadUsageRecords(1);
        },
        
        resetFilter: function() {
            document.getElementById('weline-ai-date-from').value = '';
            document.getElementById('weline-ai-date-to').value = '';
            this.currentDateFrom = '';
            this.currentDateTo = '';
            this.loadUsageRecords(1);
        },
        
        viewDetail: function(record) {
            var content = '<div class="row">' +
                '<div class="col-md-6">' +
                    '<p><strong><?= __('请求ID') ?>:</strong> ' + (record.request_id || '-') + '</p>' +
                    '<p><strong><?= __('模型') ?>:</strong> ' + (record.model_name || record.model_code) + '</p>' +
                    '<p><strong><?= __('用户') ?>:</strong> ' + (record.user_name || record.user_id || '-') + '</p>' +
                    '<p><strong><?= __('请求类型') ?>:</strong> ' + (record.request_type || 'chat') + '</p>' +
                    '<p><strong><?= __('时间') ?>:</strong> ' + record.created_at_formatted + '</p>' +
                '</div>' +
                '<div class="col-md-6">' +
                    '<p><strong><?= __('输入令牌') ?>:</strong> ' + record.prompt_tokens.toLocaleString() + '</p>' +
                    '<p><strong><?= __('输出令牌') ?>:</strong> ' + record.completion_tokens.toLocaleString() + '</p>' +
                    '<p><strong><?= __('总令牌') ?>:</strong> ' + record.total_tokens.toLocaleString() + '</p>' +
                    '<p><strong><?= __('花费') ?>:</strong> ' + record.total_cost_formatted + '</p>' +
                    '<p><strong><?= __('耗时') ?>:</strong> ' + record.request_time_formatted + '</p>' +
                '</div>' +
            '</div>';
            
            if (record.error_message) {
                content += '<div class="alert alert-danger mt-3">' +
                    '<strong><?= __('错误信息') ?>:</strong> ' + record.error_message +
                '</div>';
            }
            
            if (record.request_data) {
                content += '<div class="mt-3">' +
                    '<h6><?= __('请求数据') ?>:</h6>' +
                    '<pre class="weline-ai-pre">' + record.request_data + '</pre>' +
                '</div>';
            }
            
            if (record.response_data) {
                content += '<div class="mt-3">' +
                    '<h6><?= __('响应数据') ?>:</h6>' +
                    '<pre class="weline-ai-pre">' + record.response_data + '</pre>' +
                '</div>';
            }
            
            document.getElementById('weline-ai-detail-content').innerHTML = content;
            new bootstrap.Modal(document.getElementById('weline-ai-detail-modal')).show();
        },
        
        exportData: function() {
            var params = new URLSearchParams({
                format: 'csv',
                date_from: this.currentDateFrom,
                date_to: this.currentDateTo
            });
            
            if (this.accountId) {
                params.append('account_id', this.accountId);
            }
            
            window.location.href = '<?= $this->getBackendUrl('*/backend/provider/exportUsage') ?>?' + params;
        }
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        WelineAiUsage.init();
    });
})();
</script>
