<script>
(function() {
    'use strict';
    
    var WelineAiUsage = {
        accountId: <?= $account_id ?: 'null' ?>,
        currentPage: 1,
        currentDateFrom: '',
        currentDateTo: '',
        recordsByKey: new Map(),
        
        init: function() {
            var self = this;
            
            // 设置默认日期范围（最近30天）
            var today = new Date();
            var thirtyDaysAgo = new Date(today.getTime() - (30 * 24 * 60 * 60 * 1000));
            
            document.getElementById('weline-ai-date-to').value = today.toISOString().split('T')[0];
            document.getElementById('weline-ai-date-from').value = thirtyDaysAgo.toISOString().split('T')[0];
            
            // 绑定事件
            document.getElementById('weline-ai-filter-records').addEventListener('click', function() {
                self.filterRecords();
            });
            
            document.getElementById('weline-ai-reset-filter').addEventListener('click', function() {
                self.resetFilter();
            });
            
            document.getElementById('weline-ai-export-data').addEventListener('click', function() {
                self.exportData();
            });
            
            this.filterRecords();
        },
        
        loadUsageRecords: function(page) {
            var self = this;
            page = page || 1;
            this.currentPage = page;
            
            var req = window.Weline.Api.resource('ai').providerGetUsageList({
                page: page,
                limit: 20,
                date_from: this.currentDateFrom,
                date_to: this.currentDateTo,
                account_id: this.accountId || 0
            });
            req.then(function(res) {
                var data = (res && res.data) || res;
                    if (data.success) {
                        self.displayRecords(data.data);
                        self.displayPagination(data.total, data.page, data.limit);
                        self.updateStats(data.stats);
                    } else {
                        if (typeof BackendToast !== 'undefined') {
                            BackendToast.error(data.message || '<?= __('加载失败') ?>');
                        }
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error('<?= __('加载失败，请重试') ?>');
                    }
                });
        },
        
        displayRecords: function(records) {
            var tbody = document.getElementById('weline-ai-usage-list');
            var self = this;
            this.clearElement(tbody);
            this.recordsByKey.clear();
            
            if (records.length === 0) {
                var emptyRow = document.createElement('tr');
                var emptyCell = document.createElement('td');
                emptyCell.colSpan = 11;
                emptyCell.className = 'text-center';
                emptyCell.textContent = '<?= __('暂无数据') ?>';
                emptyRow.appendChild(emptyCell);
                tbody.appendChild(emptyRow);
                return;
            }
            
            records.forEach(function(record, index) {
                var recordKey = self.getRecordKey(record, index);
                self.recordsByKey.set(recordKey, record);

                var row = document.createElement('tr');
                self.appendCell(row, record.created_at_formatted);
                self.appendCell(row, record.model_name || record.model_code);
                self.appendCell(row, record.user_name || record.user_id || '-');
                self.appendCell(row, record.request_type || 'chat');
                self.appendCell(row, self.formatNumber(record.prompt_tokens));
                self.appendCell(row, self.formatNumber(record.completion_tokens));
                self.appendCell(row, self.formatNumber(record.total_tokens));
                self.appendCell(row, record.total_cost_formatted);
                self.appendCell(row, record.request_time_formatted);

                var statusCell = document.createElement('td');
                var statusBadge = document.createElement('span');
                statusBadge.className = record.status === 'success' ? 'badge bg-success' : 'badge bg-danger';
                statusBadge.textContent = record.status === 'success' ? '<?= __('成功') ?>' : '<?= __('失败') ?>';
                statusCell.appendChild(statusBadge);
                row.appendChild(statusCell);

                var actionCell = document.createElement('td');
                var button = document.createElement('button');
                button.type = 'button';
                button.className = 'btn btn-sm btn-info weline-ai-view-detail';
                button.setAttribute('data-record-key', recordKey);
                var icon = document.createElement('i');
                icon.className = 'mdi mdi-eye';
                button.appendChild(icon);
                actionCell.appendChild(button);
                row.appendChild(actionCell);

                tbody.appendChild(row);
            });

            tbody.querySelectorAll('.weline-ai-view-detail').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var record = self.recordsByKey.get(this.getAttribute('data-record-key'));
                    if (record) {
                        self.viewDetail(record);
                    }
                });
            });
        },
        
        displayPagination: function(total, page, limit) {
            var self = this;
            var totalPages = Math.ceil(total / limit);
            var pagination = document.getElementById('weline-ai-pagination');
            
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                return;
            }
            
            var html = '<nav><ul class="pagination justify-content-center">';
            
            html += '<li class="page-item ' + (page === 1 ? 'disabled' : '') + '">' +
                '<a class="page-link" href="#" data-page="' + (page - 1) + '"><?= __('上一页') ?></a></li>';
            
            for (var i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
                    html += '<li class="page-item ' + (i === page ? 'active' : '') + '">' +
                        '<a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>';
                } else if (i === page - 3 || i === page + 3) {
                    html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
                }
            }
            
            html += '<li class="page-item ' + (page === totalPages ? 'disabled' : '') + '">' +
                '<a class="page-link" href="#" data-page="' + (page + 1) + '"><?= __('下一页') ?></a></li>';
            
            html += '</ul></nav>';
            pagination.innerHTML = html;
            
            pagination.querySelectorAll('a[data-page]').forEach(function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    var p = parseInt(this.getAttribute('data-page'));
                    if (p >= 1 && p <= totalPages) {
                        self.loadUsageRecords(p);
                    }
                });
            });
        },
        
        updateStats: function(stats) {
            if (stats) {
                document.getElementById('weline-ai-total-requests').textContent = stats.total_requests.toLocaleString();
                document.getElementById('weline-ai-total-tokens').textContent = stats.total_tokens.toLocaleString();
                document.getElementById('weline-ai-total-cost').textContent = '$' + stats.total_cost;
                document.getElementById('weline-ai-success-rate').textContent = stats.success_rate + '%';
                document.getElementById('weline-ai-stats-cards').style.display = 'flex';
            }
        },
        
        filterRecords: function() {
            this.currentDateFrom = document.getElementById('weline-ai-date-from').value;
            this.currentDateTo = document.getElementById('weline-ai-date-to').value;
            this.loadUsageRecords(1);
        },
        
        resetFilter: function() {
            document.getElementById('weline-ai-date-from').value = '';
            document.getElementById('weline-ai-date-to').value = '';
            this.currentDateFrom = '';
            this.currentDateTo = '';
            this.loadUsageRecords(1);
        },
        
        viewDetail: function(record) {
            var detailContent = document.getElementById('weline-ai-detail-content');
            this.clearElement(detailContent);

            var row = document.createElement('div');
            row.className = 'row';

            var leftCol = document.createElement('div');
            leftCol.className = 'col-md-6';
            this.appendDetailLine(leftCol, '<?= __('请求ID') ?>', record.request_id || '-');
            this.appendDetailLine(leftCol, '<?= __('模型') ?>', record.model_name || record.model_code);
            this.appendDetailLine(leftCol, '<?= __('用户') ?>', record.user_name || record.user_id || '-');
            this.appendDetailLine(leftCol, '<?= __('请求类型') ?>', record.request_type || 'chat');
            this.appendDetailLine(leftCol, '<?= __('时间') ?>', record.created_at_formatted);
            row.appendChild(leftCol);

            var rightCol = document.createElement('div');
            rightCol.className = 'col-md-6';
            this.appendDetailLine(rightCol, '<?= __('输入令牌') ?>', this.formatNumber(record.prompt_tokens));
            this.appendDetailLine(rightCol, '<?= __('输出令牌') ?>', this.formatNumber(record.completion_tokens));
            this.appendDetailLine(rightCol, '<?= __('总令牌') ?>', this.formatNumber(record.total_tokens));
            this.appendDetailLine(rightCol, '<?= __('花费') ?>', record.total_cost_formatted);
            this.appendDetailLine(rightCol, '<?= __('耗时') ?>', record.request_time_formatted);
            row.appendChild(rightCol);

            detailContent.appendChild(row);
            
            if (record.error_message) {
                var errorAlert = document.createElement('div');
                errorAlert.className = 'alert alert-danger mt-3';
                var errorLabel = document.createElement('strong');
                errorLabel.textContent = '<?= __('错误信息') ?>: ';
                errorAlert.appendChild(errorLabel);
                errorAlert.appendChild(document.createTextNode(this.valueToText(record.error_message)));
                detailContent.appendChild(errorAlert);
            }
            
            if (record.request_data) {
                detailContent.appendChild(this.createPreBlock('<?= __('请求数据') ?>', record.request_data));
            }
            
            if (record.response_data) {
                detailContent.appendChild(this.createPreBlock('<?= __('响应数据') ?>', record.response_data));
            }
            
            new bootstrap.Modal(document.getElementById('weline-ai-detail-modal')).show();
        },

        getRecordKey: function(record, index) {
            var rawKey = record.id || record.usage_id || record.request_id || index;
            return 'usage-' + this.currentPage + '-' + index + '-' + String(rawKey);
        },

        clearElement: function(element) {
            while (element.firstChild) {
                element.removeChild(element.firstChild);
            }
        },

        appendCell: function(row, value) {
            var cell = document.createElement('td');
            cell.textContent = this.valueToText(value);
            row.appendChild(cell);
            return cell;
        },

        appendDetailLine: function(parent, label, value) {
            var paragraph = document.createElement('p');
            var strong = document.createElement('strong');
            strong.textContent = label + ': ';
            paragraph.appendChild(strong);
            paragraph.appendChild(document.createTextNode(this.valueToText(value)));
            parent.appendChild(paragraph);
        },

        createPreBlock: function(label, value) {
            var wrapper = document.createElement('div');
            wrapper.className = 'mt-3';
            var heading = document.createElement('h6');
            heading.textContent = label + ':';
            var pre = document.createElement('pre');
            pre.className = 'weline-ai-pre';
            pre.textContent = this.valueToText(value);
            wrapper.appendChild(heading);
            wrapper.appendChild(pre);
            return wrapper;
        },

        valueToText: function(value) {
            if (value === null || typeof value === 'undefined' || value === '') {
                return '-';
            }
            if (typeof value === 'object') {
                try {
                    return JSON.stringify(value, null, 2);
                } catch (error) {
                    return String(value);
                }
            }
            return String(value);
        },

        formatNumber: function(value) {
            var number = Number(value || 0);
            return Number.isFinite(number) ? number.toLocaleString() : this.valueToText(value);
        },
        
        exportData: function() {
            var params = new URLSearchParams({
                format: 'csv',
                date_from: this.currentDateFrom,
                date_to: this.currentDateTo
            });
            
            if (this.accountId) {
                params.append('account_id', this.accountId);
            }
            
            window.location.href = '<?= $this->getBackendUrl('*/backend/provider/exportUsage') ?>?' + params;
        }
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        WelineAiUsage.init();
    });
})();
</script>
