<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    // 代理设置切换
    document.getElementById('proxy_enabled').addEventListener('change', function() {
        document.getElementById('proxySettings').style.display = this.checked ? 'block' : 'none';
    });
    
    // 供应商选择时自动填充基础URL
    document.getElementById('provider_code').addEventListener('change', function() {
        const baseUrl = this.options[this.selectedIndex].getAttribute('data-base-url');
        if (baseUrl && !document.getElementById('base_url').value) {
            document.getElementById('base_url').value = baseUrl;
        }
    });
    
    // 表单提交
    document.getElementById('accountForm').addEventListener('submit', function(e) {
        e.preventDefault();
        saveAccount();
    });
});

// 切换密码可见性
function togglePasswordVisibility(fieldId) {
    const field = document.getElementById(fieldId);
    const button = event.currentTarget;
    const icon = button.querySelector('i');
    
    if (field.type === 'password') {
        field.type = 'text';
        icon.classList.remove('mdi-eye');
        icon.classList.add('mdi-eye-off');
    } else {
        field.type = 'password';
        icon.classList.remove('mdi-eye-off');
        icon.classList.add('mdi-eye');
    }
}

// 激活状态变化时的处理
function onActivateChange() {
    const activateCheckbox = document.getElementById('is_active');
    
    // 如果是要激活账户
    if (activateCheckbox.checked) {
        // 检查必要字段是否已填写
        const providerCode = document.getElementById('provider_code').value;
        const apiKey = document.getElementById('api_key').value;
        
        if (!providerCode) {
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择供应商') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('请先选择供应商');
            }
            return;
        }
        
        if (!apiKey) {
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先填写API密钥') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('请先填写API密钥');
            }
            return;
        }
        
        // 先保存账户，然后进行连接测试
        saveAccountForActivation();
    }
}

// 为激活而保存账户
function saveAccountForActivation() {
    const activateCheckbox = document.getElementById('is_active');
    const form = document.getElementById('accountForm');
    
    // 显示保存中状态
    const originalLabel = document.querySelector('label[for="is_active"]').textContent;
    document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...';
    activateCheckbox.disabled = true;
    
    // 验证表单
    if (!form.checkValidity()) {
        form.reportValidity();
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        return;
    }
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // 确保激活状态为1
    data.is_active = '1';
    
    fetch(form.action, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 保存成功，进行连接测试
            testConnectionForActivation(data.account_id || data.id);
        } else {
            // 保存失败
            document.querySelector('label[for="is_active"]').textContent = originalLabel;
            activateCheckbox.disabled = false;
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('保存失败: ' + data.message);
            }
        }
    })
    .catch(error => {
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('保存失败');
        }
    });
}

// 为激活而进行的连接测试
function testConnectionForActivation(accountId) {
    const activateCheckbox = document.getElementById('is_active');
    
    // 更新状态为测试中
    document.querySelector('label[for="is_active"]').innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>测试中...';
    
    fetch('<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ id: accountId })
    })
    .then(response => response.json())
    .then(data => {
        // 恢复状态
        const originalLabel = '激活账户';
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        
        if (data.success) {
            // 测试成功，保持激活状态
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('连接测试成功') ?>',
                    html: `<?= __('使用的测试模型') ?>: ${data.model_code || '<?= __('未知') ?>'}<br><br><?= __('账户已激活') ?>`,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.log(`连接测试成功！使用的测试模型: ${data.model_code || '未知'}\n账户已激活。`);
            }
        } else {
            // 测试失败，取消激活状态
            activateCheckbox.checked = false;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('连接测试失败') ?>',
                    html: `<?= __('无法激活账户') ?>！<br><br><?= __('错误信息') ?>: ${data.message}<br><br><?= __('请检查API密钥和网络连接后重试') ?>`,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(`连接测试失败，无法激活账户！错误信息: ${data.message}`);
            }
        }
    })
    .catch(error => {
        // 恢复状态
        const originalLabel = '激活账户';
        document.querySelector('label[for="is_active"]').textContent = originalLabel;
        activateCheckbox.disabled = false;
        activateCheckbox.checked = false;
        
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('连接测试失败') ?>',
                html: '<?= __('无法激活账户') ?>！<br><br><?= __('网络错误，请检查网络连接后重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('连接测试失败，无法激活账户！网络错误，请检查网络连接后重试。');
        }
    });
}

// 供应商选择变化时的处理
function onProviderChange() {
    const providerSelect = document.getElementById('provider_code');
    const accountNameInput = document.getElementById('account_name');
    const baseUrlInput = document.getElementById('base_url');
    
    const selectedOption = providerSelect.options[providerSelect.selectedIndex];
    
    if (selectedOption.value) {
        // 自动填充供应商名称到账户名称（仅在账户名称为空时）
        const providerName = selectedOption.getAttribute('data-name');
        if (providerName && !accountNameInput.value.trim()) {
            accountNameInput.value = providerName;
        }
        
        // 自动填充基础URL（仅在基础URL为空时）
        const baseUrl = selectedOption.getAttribute('data-base-url');
        if (baseUrl && !baseUrlInput.value.trim()) {
            baseUrlInput.value = baseUrl;
        }
    }
}

// 保存账户
function saveAccount() {
    const form = document.getElementById('accountForm');
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // 显示加载状态
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i>保存中...';
    submitBtn.disabled = true;
    
    fetch(form.action, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '<?= $this->getBackendUrl('*/backend/provider') ?>';
                });
            } else {
                console.log(data.message);
                window.location.href = '<?= $this->getBackendUrl('*/backend/provider') ?>';
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('保存失败: ' + data.message);
            }
        }
    })
    .catch(error => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('保存失败');
        }
    });
}

