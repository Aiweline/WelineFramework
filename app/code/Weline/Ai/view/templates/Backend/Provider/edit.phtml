<script>
(function() {
    'use strict';
    
    var WelineAiProvider = {
        form: null,
        
        init: function() {
            var self = this;
            this.form = document.getElementById('weline-ai-provider-form');
            
            // 代理设置切换
            document.getElementById('weline-ai-proxy-enabled').addEventListener('change', function() {
                document.getElementById('weline-ai-proxy-settings').style.display = this.checked ? 'block' : 'none';
            });
            
            // 供应商选择时自动填充
            var providerSelect = document.getElementById('weline-ai-provider-code');
            if (providerSelect) {
                providerSelect.addEventListener('change', function() {
                    self.onProviderChange();
                });
            }
            
            // 切换密码可见性
            document.querySelectorAll('.weline-ai-toggle-password').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var targetId = this.getAttribute('data-target');
                    self.togglePasswordVisibility(targetId, this);
                });
            });
            
            // 激活状态变化
            var activeCheckbox = document.getElementById('weline-ai-is-active');
            if (activeCheckbox) {
                activeCheckbox.addEventListener('change', function() {
                    self.onActivateChange();
                });
            }
            
            // 表单提交
            this.form.addEventListener('submit', function(e) {
                e.preventDefault();
                self.saveAccount();
            });
            
            // 测试连接按钮
            var testBtn = document.getElementById('weline-ai-test-connection');
            if (testBtn) {
                testBtn.addEventListener('click', function() {
                    self.testConnection();
                });
            }
        },
        
        togglePasswordVisibility: function(fieldId, button) {
            var field = document.getElementById(fieldId);
            var icon = button.querySelector('i');
            
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('mdi-eye');
                icon.classList.add('mdi-eye-off');
            } else {
                field.type = 'password';
                icon.classList.remove('mdi-eye-off');
                icon.classList.add('mdi-eye');
            }
        },
        
        onProviderChange: function() {
            var providerSelect = document.getElementById('weline-ai-provider-code');
            var accountNameInput = document.getElementById('weline-ai-account-name');
            var baseUrlInput = document.getElementById('weline-ai-base-url');
            
            var selectedOption = providerSelect.options[providerSelect.selectedIndex];
            
            if (selectedOption.value) {
                var providerName = selectedOption.getAttribute('data-name');
                if (providerName && !accountNameInput.value.trim()) {
                    accountNameInput.value = providerName;
                }
                
                var baseUrl = selectedOption.getAttribute('data-base-url');
                if (baseUrl && !baseUrlInput.value.trim()) {
                    baseUrlInput.value = baseUrl;
                }
            }
        },
        
        onActivateChange: function() {
            var activateCheckbox = document.getElementById('weline-ai-is-active');
            
            if (activateCheckbox.checked) {
                var providerCode = document.getElementById('weline-ai-provider-code').value;
                var apiKey = document.getElementById('weline-ai-api-key').value;
                
                if (!providerCode) {
                    activateCheckbox.checked = false;
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.warning('<?= __('请先选择供应商') ?>');
                    }
                    return;
                }
                
                if (!apiKey) {
                    activateCheckbox.checked = false;
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.warning('<?= __('请先填写API密钥') ?>');
                    }
                    return;
                }
            }
        },
        
        saveAccount: function() {
            var self = this;
            if (!this.form.checkValidity()) {
                this.form.reportValidity();
                return;
            }
            
            var formData = new FormData(this.form);
            var data = {};
            formData.forEach(function(value, key) { data[key] = value; });
            
            var submitBtn = this.form.querySelector('button[type="submit"]');
            var originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __('保存中...') ?>';
            submitBtn.disabled = true;
            
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) };
            var req = window.Weline.Api.request(this.form.action, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
                
                if (data.success) {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success(data.message);
                    }
                    setTimeout(function() {
                        window.location.href = '<?= $this->getBackendUrl('*/backend/provider') ?>';
                    }, 1500);
                } else {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(data.message || '<?= __('保存失败') ?>');
                    }
                }
            })
            .catch(function(error) {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
                console.error('Error:', error);
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('保存失败，请重试') ?>');
                }
            });
        },
        
        testConnection: function() {
            var btn = document.getElementById('weline-ai-test-connection');
            var originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin me-1"></i><?= __('测试中...') ?>';
            btn.disabled = true;

            var accountId = <?= isset($account) ? $account->getId() : 'null' ?>;
            var providerCode = '<?= isset($account) ? addslashes((string)$account->getData('provider_code')) : '' ?>';
            var chooseModel = Promise.resolve('');
            if (typeof Swal !== 'undefined' && accountId && providerCode) {
                var modelUrl = '<?= $this->getBackendUrl('*/backend/provider/getRemoteModelsForSelect') ?>';
                var modelForm = new FormData();
                modelForm.set('provider_code', providerCode);
                modelForm.set('account_id', accountId);
                chooseModel = window.Weline.Api.request(modelUrl, {
                    method: 'POST',
                    body: modelForm,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).then(function(res) {
                    var data = (res && res.data) || res;
                    if (!data || !data.success || !Array.isArray(data.data) || !data.data.length) {
                        throw new Error((data && data.message) || 'models endpoint unavailable');
                    }
                    var options = {};
                    window.__welineProviderTestModelMeta = {};
                    data.data.forEach(function(model) {
                        var code = model.code || model.value || '';
                        if (code) options[code] = model.label || model.name || code;
                        if (code) window.__welineProviderTestModelMeta[code] = model;
                    });
                    return Swal.fire({
                        title: '选择测试模型',
                        input: 'select',
                        inputOptions: options,
                        inputPlaceholder: '请选择模型',
                        showCancelButton: true,
                        confirmButtonText: '开始测试',
                        cancelButtonText: '取消',
                        inputValidator: function(value) {
                            if (!value) return '请选择一个模型';
                        }
                    }).then(function(result) {
                        return result.isConfirmed ? (result.value || '') : null;
                    });
                }).catch(function(error) {
                    return Swal.fire({
                        icon: 'warning',
                        title: '无法拉取模型列表',
                        text: error.message || '该供应商不支持 models 接口。',
                        showCancelButton: true,
                        confirmButtonText: '使用默认测试模型',
                        cancelButtonText: '取消'
                    }).then(function(result) {
                        return result.isConfirmed ? '' : null;
                    });
                });
            }

            chooseModel.then(function(modelCode) {
                if (modelCode === null) {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                    return;
                }

            var url = '<?= $this->getBackendUrl('*/backend/provider/testConnection') ?>';
            var payload = { id: accountId };
            if (modelCode) payload.model_code = modelCode;
            var selectedMeta = modelCode && window.__welineProviderTestModelMeta ? window.__welineProviderTestModelMeta[modelCode] : null;
            if (selectedMeta && selectedMeta.primary_modality) payload.primary_modality = selectedMeta.primary_modality;
            if (selectedMeta && Array.isArray(selectedMeta.capabilities)) payload.capabilities = selectedMeta.capabilities;
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) };
            var req = window.Weline.Api.request(url, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                
                if (data.success) {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.success(data.message || '<?= __('连接测试成功') ?>');
                    }
                    setTimeout(function() { window.location.reload(); }, 1500);
                } else {
                    if (typeof BackendToast !== 'undefined') {
                        BackendToast.error(data.message || '<?= __('连接测试失败') ?>');
                    }
                }
            })
            .catch(function(error) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                console.error('Error:', error);
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.error('<?= __('测试失败，请重试') ?>');
                }
            });
            });
        }
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        WelineAiProvider.init();
    });
})();
</script>
