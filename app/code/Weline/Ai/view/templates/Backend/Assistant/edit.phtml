<script>
(function() {
    'use strict';
    
    document.getElementById('assistantForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(this);
        var submitBtn = document.getElementById('submitBtn');
        var originalHtml = submitBtn.innerHTML;
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("保存中...") ?>';
        
        fetch(this.action, {
            method: 'POST',
            body: formData
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success(data.message);
                }
                setTimeout(function() {
                    window.location.href = '<?= $this->getBackendUrl("*/backend/assistant") ?>';
                }, 1500);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __("保存失败") ?>');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
            }
        })
        .catch(function(error) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __("请求失败") ?>');
            }
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalHtml;
        });
    });
    
    document.getElementById('mcp_config').addEventListener('blur', function() {
        var value = this.value.trim();
        if (value && value !== '[]') {
            try {
                JSON.parse(value);
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
            } catch (e) {
                this.classList.remove('is-valid');
                this.classList.add('is-invalid');
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error('<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>');
                }
            }
        } else {
            this.classList.remove('is-invalid', 'is-valid');
        }
    });
})();
</script>
