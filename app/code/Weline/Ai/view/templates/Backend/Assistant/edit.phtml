<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 表单提交处理
document.getElementById('assistantForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const submitBtn = document.getElementById('submitBtn');
    const originalHtml = submitBtn.innerHTML;
    
    // 显示加载状态
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("保存中...") ?>';
    
    fetch(this.action, {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __("成功") ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '<?= $this->getBackendUrl("*/backend/assistant") ?>';
                });
            } else {
                console.log(data.message);
                window.location.href = '<?= $this->getBackendUrl("*/backend/assistant") ?>';
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("保存失败") ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("保存失败：") ?>' + data.message);
            }
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalHtml;
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __("请求失败") ?>',
                text: error,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __("请求失败：") ?>' + error);
        }
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHtml;
    });
});

// MCP配置JSON验证
document.getElementById('mcp_config').addEventListener('blur', function() {
    const value = this.value.trim();
    if (value && value !== '[]') {
        try {
            JSON.parse(value);
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } catch (e) {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("格式错误") ?>',
                    text: '<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>');
            }
        }
    } else {
        this.classList.remove('is-invalid', 'is-valid');
    }
});
</script>

