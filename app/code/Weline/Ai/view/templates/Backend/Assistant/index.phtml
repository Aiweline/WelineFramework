<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
function filterByStatus(status) {
    const url = new URL(window.location.href);
    if (status) {
        url.searchParams.set('status', status);
    } else {
        url.searchParams.delete('status');
    }
    window.location.href = url.toString();
}

function toggleStatus(assistantId) {
    if (confirm('<?= __('确定要切换助手状态吗？') ?>')) {
        fetch('<?= $this->getBackendUrl('*/backend/assistant/toggleStatus') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({id: assistantId})
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: '<?= __('状态切换成功！') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    console.log('<?= __('状态切换成功！') ?>');
                    location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('状态切换失败') ?>',
                        text: data.message || '<?= __('未知错误') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('状态切换失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                }
            }
        })
        .catch(error => {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请求失败：') ?>' + error.message);
            }
        });
    }
}

function deleteAssistant(assistantId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认删除') ?>',
            text: '<?= __('确定要删除这个助手吗？此操作不可恢复！') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定删除") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#d33'
        }).then((result) => {
            if (result.isConfirmed) {
                performDelete(assistantId);
            }
        });
    } else {
        if (confirm('<?= __('确定要删除这个助手吗？此操作不可恢复！') ?>')) {
            performDelete(assistantId);
        }
    }
}

function performDelete(assistantId) {
    fetch('<?= $this->getBackendUrl('*/backend/assistant/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({id: assistantId})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('删除成功！') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log('<?= __('删除成功！') ?>');
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('删除失败') ?>',
                    text: data.message || '<?= __('未知错误') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('删除失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
            }
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('请求失败') ?>',
                text: error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('请求失败：') ?>' + error.message);
        }
    });
}
</script>

</body>
</html>
