<script>
function filterByStatus(status) {
    const url = new URL(window.location.href);
    if (status) {
        url.searchParams.set('status', status);
    } else {
        url.searchParams.delete('status');
    }
    window.location.href = url.toString();
}

function toggleStatus(id) {
    fetch('<?= $this->getBackendUrl('*/backend/assistant/toggleStatus') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('操作失败：' + data.message);
        }
    })
    .catch(error => {
        alert('请求失败：' + error);
    });
}

function deleteAssistant(id) {
    if (!confirm('确定要删除这个助手吗？此操作不可恢复！')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/assistant/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${id}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('删除失败：' + data.message);
        }
    })
    .catch(error => {
        alert('请求失败：' + error);
    });
}
</script>

