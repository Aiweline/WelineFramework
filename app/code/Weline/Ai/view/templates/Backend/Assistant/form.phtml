<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    // 获取所有需要的DOM元素
    let modelSearchTimeout;
    let adapterSearchTimeout;
    const modelSearchInput = document.getElementById('model_search');
    const modelSelect = document.getElementById('model_code');
    const modelLoading = document.getElementById('model_loading');
    const loadModelConfigBtn = document.getElementById('loadModelConfig');
    const modelConfigField = document.getElementById('model_config');
    const adapterSearchInput = document.getElementById('adapter_search');
    const adapterSelect = document.getElementById('adapter_code');
    const adapterLoading = document.getElementById('adapter_loading');
    
    // 搜索适配器
    function searchAdapters(keyword) {
        console.log('searchAdapters called with keyword:', keyword);
        if (!adapterLoading || !adapterSelect) {
            console.error('Required elements not found');
            return;
        }
        
        adapterLoading.style.display = 'block';
        
        <?php if ($isEdit && $assistant && $assistant->getData('adapter_code')): ?>
        const currentAdapterCode = '<?= $assistant->getData('adapter_code') ?>';
        <?php else: ?>
        const currentAdapterCode = 'default'; // 默认使用default适配器
        <?php endif; ?>
        
        const url = '<?= $this->getBackendUrl('*/backend/assistant/searchAdapters') ?>?keyword=' + encodeURIComponent(keyword);
        console.log('Fetching adapters from:', url);
        
        fetch(url)
            .then(response => response.json())
            .then(data => {
                console.log('Adapters received:', data);
                adapterLoading.style.display = 'none';
                adapterSelect.innerHTML = '';
                
                if (data.success && data.adapters && data.adapters.length > 0) {
                    console.log('Processing', data.adapters.length, 'adapters');
                    let currentAdapter = null;
                    const otherAdapters = [];
                    
                    // 分离当前适配器和其他适配器
                    data.adapters.forEach(adapter => {
                        if (adapter.code === currentAdapterCode) {
                            currentAdapter = adapter;
                        } else {
                            otherAdapters.push(adapter);
                        }
                    });
                    
                    // 先添加当前选择的适配器（优先显示）
                    if (currentAdapter) {
                        const option = document.createElement('option');
                        option.value = currentAdapter.code;
                        option.textContent = currentAdapter.name + ' (v' + currentAdapter.version + ') - <?= __("已选择") ?>';
                        option.selected = true;
                        adapterSelect.appendChild(option);
                    }
                    
                    // 再添加其他适配器
                    otherAdapters.forEach(adapter => {
                        const option = document.createElement('option');
                        option.value = adapter.code;
                        option.textContent = adapter.name + ' (v' + adapter.version + ')';
                        adapterSelect.appendChild(option);
                    });
                } else {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = '<?= __("未找到匹配的适配器") ?>';
                    option.disabled = true;
                    adapterSelect.appendChild(option);
                }
            })
            .catch(error => {
                adapterLoading.style.display = 'none';
                console.error('<?= __("搜索失败：") ?>', error);
            });
    }
    
    // 页面加载时自动搜索适配器（会自动将默认适配器设为选中）
    searchAdapters('');
    
    if (adapterSearchInput) {
        // 输入时触发搜索（带防抖）
        adapterSearchInput.addEventListener('input', function() {
            clearTimeout(adapterSearchTimeout);
            adapterSearchTimeout = setTimeout(() => {
                searchAdapters(this.value);
            }, 300);
        });
        
        // 按Enter键选择第一个
        adapterSearchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                if (adapterSelect.options.length > 0 && adapterSelect.options[0].value) {
                    adapterSelect.selectedIndex = 0;
                    adapterSearchInput.focus();
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                adapterSelect.focus();
            }
        });
    }
    
    // 监听适配器选择变化，动态加载参数模板
    if (adapterSelect) {
        adapterSelect.addEventListener('change', function() {
            const selectedCode = this.value;
            if (selectedCode) {
                loadAdapterParams(selectedCode);
            }
        });
    }
    
    // 加载适配器参数模板
    function loadAdapterParams(adapterCode) {
        const url = '<?= $this->getBackendUrl('*/backend/assistant/getAdapterParams') ?>?code=' + encodeURIComponent(adapterCode);
        
        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data.success && data.data) {
                    displayAdapterParams(data.data);
                } else {
                    hideAdapterParams();
                }
            })
            .catch(error => {
                console.error('Failed to load adapter params:', error);
                hideAdapterParams();
            });
    }
    
    // 显示适配器参数配置
    function displayAdapterParams(adapterData) {
        const container = document.getElementById('adapter_params_container');
        const descriptionEl = document.getElementById('adapter_params_description');
        const fieldsEl = document.getElementById('adapter_params_fields');
        const examplesEl = document.getElementById('adapter_params_examples');
        const examplesContent = document.getElementById('adapter_examples_content');
        
        if (!container || !fieldsEl) return;
        
        const paramTemplate = adapterData.param_template || {};
        const fields = paramTemplate.fields || [];
        
        // 如果没有参数字段，隐藏配置区域
        if (fields.length === 0) {
            hideAdapterParams();
            return;
        }
        
        // 显示描述
        if (descriptionEl) {
            descriptionEl.innerHTML = '<i class="mdi mdi-information-outline"></i> ' + (paramTemplate.description || '');
        }
        
        // 生成表单字段
        let fieldsHTML = '';
        <?php
        // 获取现有的适配器参数（编辑模式）
        $existingParams = [];
        if ($isEdit && $assistant && $assistant->getData('adapter_params')) {
            $paramsData = $assistant->getData('adapter_params');
            $existingParams = is_string($paramsData) ? json_decode($paramsData, true) : $paramsData;
            if (!is_array($existingParams)) {
                $existingParams = [];
            }
        }
        ?>
        const existingParams = <?= json_encode($existingParams) ?>;
        
        fields.forEach(field => {
            const value = existingParams[field.name] || field.default || '';
            const required = field.required ? 'required' : '';
            const requiredMark = field.required ? '<span style="color: #dc3545;">*</span>' : '';
            
            fieldsHTML += `
                <div style="margin-bottom: 12px;">
                    <label style="display: block; font-size: 0.9rem; font-weight: 500; color: #495057; margin-bottom: 4px;">
                        ${field.label} ${requiredMark}
                    </label>
            `;
            
            if (field.type === 'select') {
                fieldsHTML += `<select name="adapter_params[${field.name}]" ${required} style="width: 100%; padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px;">`;
                if (field.options) {
                    field.options.forEach(opt => {
                        const selected = opt.value == value ? 'selected' : '';
                        fieldsHTML += `<option value="${opt.value}" ${selected}>${opt.label}</option>`;
                    });
                }
                fieldsHTML += `</select>`;
            } else if (field.type === 'textarea') {
                fieldsHTML += `<textarea name="adapter_params[${field.name}]" ${required} rows="3" style="width: 100%; padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px;" placeholder="${field.placeholder || ''}">${value}</textarea>`;
            } else if (field.type === 'checkbox') {
                const checked = value ? 'checked' : '';
                fieldsHTML += `<div style="display: flex; align-items: center;"><input type="checkbox" name="adapter_params[${field.name}]" value="1" ${checked} style="margin-right: 6px;"><span>${field.description || ''}</span></div>`;
            } else {
                fieldsHTML += `<input type="${field.type || 'text'}" name="adapter_params[${field.name}]" value="${value}" ${required} style="width: 100%; padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px;" placeholder="${field.placeholder || ''}">`;
            }
            
            if (field.description) {
                fieldsHTML += `<small style="display: block; margin-top: 4px; color: #6c757d; font-size: 0.875rem;">${field.description}</small>`;
            }
            
            fieldsHTML += `</div>`;
        });
        
        fieldsEl.innerHTML = fieldsHTML;
        
        // 显示示例
        if (adapterData.examples && adapterData.examples.length > 0 && examplesContent) {
            let examplesHTML = '';
            adapterData.examples.forEach((example, index) => {
                examplesHTML += `
                    <div style="margin-bottom: 12px; padding: 8px; background: #f8f9fa; border-radius: 4px;">
                        <strong style="color: #495057;">${index + 1}. ${example.title}</strong>
                        <p style="margin: 4px 0; font-size: 0.875rem; color: #6c757d;">${example.description}</p>
                        <div style="margin-top: 4px;">
                            <small style="color: #28a745;">输入: ${example.input}</small><br>
                            <small style="color: #007bff;">输出: ${example.expected_output}</small>
                        </div>
                    </div>
                `;
            });
            examplesContent.innerHTML = examplesHTML;
            examplesEl.style.display = 'block';
        } else {
            examplesEl.style.display = 'none';
        }
        
        // 显示配置区域
        container.style.display = 'block';
    }
    
    // 隐藏适配器参数配置
    function hideAdapterParams() {
        const container = document.getElementById('adapter_params_container');
        if (container) {
            container.style.display = 'none';
        }
    }
    
    // 显示适配器帮助信息
    function showAdapterHelp() {
        const adapterCode = adapterSelect.value;
        if (!adapterCode) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __("提示") ?>',
                    text: '<?= __("请先选择一个适配器") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("请先选择一个适配器") ?>');
            }
            return;
        }
        
        fetch('<?= $this->getBackendUrl('*/backend/assistant/getAdapterParams') ?>?code=' + encodeURIComponent(adapterCode))
            .then(response => response.json())
            .then(data => {
                if (data.success && data.data) {
                    let helpText = '<?= __("适配器") ?>: ' + data.data.name + '\n\n';
                    helpText += '<?= __("描述") ?>: ' + data.data.description + '\n\n';
                    
                    if (data.data.examples && data.data.examples.length > 0) {
                        helpText += '<?= __("示例") ?>:\n';
                        data.data.examples.forEach((ex, i) => {
                            helpText += `\n${i + 1}. ${ex.title}\n`;
                            helpText += `   ${ex.description}\n`;
                            helpText += `   输入: ${ex.input}\n`;
                            helpText += `   输出: ${ex.expected_output}\n`;
                        });
                    }
                    
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'info',
                            title: '<?= __("适配器帮助") ?>',
                            html: helpText.replace(/\n/g, '<br>'),
                            confirmButtonText: '<?= __('确定') ?>',
                            width: '600px'
                        });
                    } else {
                        console.log(helpText);
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("错误") ?>',
                            text: '<?= __("无法获取适配器帮助信息") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("无法获取适配器帮助信息") ?>');
                    }
                }
            });
    }
    
    function searchModels(keyword) {
        console.log('searchModels called with keyword:', keyword);
        if (!modelLoading || !modelSelect) {
            console.error('Required elements not found:', {modelLoading: !!modelLoading, modelSelect: !!modelSelect});
            return;
        }
        
        modelLoading.style.display = 'block';
        
        <?php if ($isEdit && $assistant && $assistant->getData('model_code')): ?>
        const currentModelCode = '<?= $assistant->getData('model_code') ?>';
        <?php else: ?>
        const currentModelCode = null;
        <?php endif; ?>
        
        const url = '<?= $this->getBackendUrl('*/backend/assistant/searchModels') ?>?keyword=' + encodeURIComponent(keyword);
        console.log('Fetching models from:', url);
        
        fetch(url)
            .then(response => response.json())
            .then(data => {
                console.log('Models received:', data);
                modelLoading.style.display = 'none';
                modelSelect.innerHTML = '';
                
                if (data.success && data.models && data.models.length > 0) {
                    console.log('Processing', data.models.length, 'models');
                    let currentModel = null;
                    const otherModels = [];
                    
                    // 分离当前模型和其他模型
                    data.models.forEach(model => {
                        if (model.is_active == 1) {
                            if (currentModelCode && model.code === currentModelCode) {
                                currentModel = model;
                            } else {
                                otherModels.push(model);
                            }
                        }
                    });
                    
                    // 先添加当前选择的模型（如果是编辑模式）
                    if (currentModel) {
                        const option = document.createElement('option');
                        option.value = currentModel.code;
                        option.textContent = currentModel.name + ' (' + currentModel.supplier + ') - <?= __("当前选择") ?>';
                        option.selected = true;
                        modelSelect.appendChild(option);
                    }
                    
                    // 再添加其他模型
                    otherModels.forEach(model => {
                        const option = document.createElement('option');
                        option.value = model.code;
                        option.textContent = model.name + ' (' + model.supplier + ')';
                        modelSelect.appendChild(option);
                    });
                } else {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = '<?= __("未找到匹配的模型") ?>';
                    option.disabled = true;
                    modelSelect.appendChild(option);
                }
            })
            .catch(error => {
                modelLoading.style.display = 'none';
                console.error('<?= __("搜索失败：") ?>', error);
            });
    }
    
    // 页面加载时自动搜索（编辑模式会自动将当前模型放在第一位）
    searchModels('');
    
    if (modelSearchInput) {
        // 输入时触发搜索（带防抖）
        modelSearchInput.addEventListener('input', function() {
            clearTimeout(modelSearchTimeout);
            modelSearchTimeout = setTimeout(() => {
                searchModels(this.value);
            }, 300);
        });
        
        // 按Enter键选择第一个
        modelSearchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                if (modelSelect.options.length > 0 && modelSelect.options[0].value) {
                    modelSelect.selectedIndex = 0;
                    modelSearchInput.focus();
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                modelSelect.focus();
            }
        });
    }
    
    // 监听模型选择变化，显示费用信息和配置加载提示
    if (modelSelect) {
        modelSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const modelCode = this.value;
            
            if (modelCode) {
                // 显示模型费用信息
                showModelCostInfo(modelCode);
                
                // 询问是否加载新模型的配置
                if (modelConfigField) {
                    const confirmMessage = '<?= __("检测到模型已切换，是否加载新模型的默认配置？") ?>' + '\n' + '<?= __("（当前配置将被覆盖）") ?>';
                    if (confirm(confirmMessage)) {
                        // 触发加载配置按钮
                        if (loadModelConfigBtn) {
                            loadModelConfigBtn.click();
                        }
                    }
                }
            }
        });
    }
    
    // 显示模型费用信息
    function showModelCostInfo(modelCode) {
        const costInfoDiv = document.getElementById('model_cost_info');
        const costDetailsDiv = document.getElementById('model_cost_details');
        
        if (!costInfoDiv || !costDetailsDiv) return;
        
        // 获取模型配置（包含费用信息）
        fetch('<?= $this->getBackendUrl('*/backend/assistant/getModelConfig') ?>?model_code=' + encodeURIComponent(modelCode))
            .then(response => response.json())
            .then(data => {
                if (data.success && data.model) {
                    const model = data.model;
                    const costPerToken = parseFloat(model.cost_per_token || 0);
                    const maxTokens = parseInt(model.max_tokens || 0);
                    
                    // 计算预估费用（假设使用50%的最大tokens）
                    const estimatedTokens = Math.floor(maxTokens * 0.5);
                    const estimatedCost = (estimatedTokens * costPerToken).toFixed(4);
                    
                    let costHTML = '<div style="line-height: 1.6;">';
                    costHTML += '<div><i class="mdi mdi-tag"></i> <strong><lang>模型</lang>:</strong> ' + (model.name || modelCode) + ' (' + (model.supplier || '') + ')</div>';
                    costHTML += '<div><i class="mdi mdi-currency-cny"></i> <strong><lang>单价</lang>:</strong> ¥' + costPerToken.toFixed(6) + ' / Token</div>';
                    costHTML += '<div><i class="mdi mdi-counter"></i> <strong><lang>最大Tokens</lang>:</strong> ' + maxTokens.toLocaleString() + '</div>';
                    costHTML += '<div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #ffc10730;">';
                    costHTML += '<i class="mdi mdi-calculator"></i> <strong><lang>预估费用</lang>:</strong> ';
                    costHTML += '<span style="color: #d63031; font-size: 1.1em;">¥' + estimatedCost + '</span> ';
                    costHTML += '<small>(<lang>按使用</lang>' + estimatedTokens.toLocaleString() + ' Tokens<lang>计算</lang>)</small>';
                    costHTML += '</div>';
                    
                    // 如果用户配置了自己的API密钥，显示提示
                    const apiKeyInput = document.getElementById('api_key');
                    if (apiKeyInput && apiKeyInput.value.trim()) {
                        costHTML += '<div style="margin-top: 8px; padding: 6px; background: #d4edda; border-radius: 4px; color: #155724;">';
                        costHTML += '<i class="mdi mdi-check-circle"></i> <lang>您已配置自定义密钥，费用将由您的API提供商收取</lang>';
                        costHTML += '</div>';
                    } else {
                        costHTML += '<div style="margin-top: 8px; padding: 6px; background: #f8d7da; border-radius: 4px; color: #721c24;">';
                        costHTML += '<i class="mdi mdi-alert"></i> <lang>未配置自定义密钥，将使用官方模型并从账户余额扣费</lang>';
                        costHTML += '</div>';
                    }
                    
                    costHTML += '</div>';
                    
                    costDetailsDiv.innerHTML = costHTML;
                    costInfoDiv.style.display = 'block';
                } else {
                    costInfoDiv.style.display = 'none';
                }
            })
            .catch(error => {
                console.error('获取模型费用信息失败:', error);
                costInfoDiv.style.display = 'none';
            });
    }
    
    // API密钥输入变化时，更新费用提示
    const apiKeyInput = document.getElementById('api_key');
    if (apiKeyInput) {
        apiKeyInput.addEventListener('input', function() {
            const modelCode = modelSelect ? modelSelect.value : '';
            if (modelCode) {
                showModelCostInfo(modelCode);
            }
        });
    }
    
    // 加载模型配置
    if (loadModelConfigBtn && modelSelect && modelConfigField) {
        loadModelConfigBtn.addEventListener('click', function() {
            const selectedModelCode = modelSelect.value;
            
            if (!selectedModelCode) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __("提示") ?>',
                        text: '<?= __("请先选择一个AI模型") ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请先选择一个AI模型") ?>');
                }
                return;
            }
            
            // 显示加载状态
            this.disabled = true;
            this.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("加载中...") ?>';
            
            fetch('<?= $this->getBackendUrl('*/backend/assistant/getModelConfig') ?>?model_code=' + encodeURIComponent(selectedModelCode))
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.config) {
                        // 格式化JSON并填入textarea
                        const formattedConfig = JSON.stringify(data.config, null, 2);
                        modelConfigField.value = formattedConfig;
                        
                        // 视觉反馈：短暂显示绿色边框
                        modelConfigField.style.borderColor = '#28a745';
                        setTimeout(() => {
                            modelConfigField.style.borderColor = '';
                        }, 2000);
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __("加载失败") ?>',
                                text: data.message || '<?= __("未知错误") ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        } else {
                            console.error('<?= __("加载失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
                        }
                    }
                })
                .catch(error => {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("请求失败") ?>',
                            text: error.message,
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("请求失败：") ?>' + error.message);
                    }
                })
                .finally(() => {
                    // 恢复按钮状态
                    this.disabled = false;
                    this.innerHTML = '<i class="mdi mdi-refresh"></i> <?= __("加载选中模型的默认配置") ?>';
                });
        });
    }
    
    // 模型配置JSON验证
    if (modelConfigField) {
        modelConfigField.addEventListener('blur', function() {
            const value = this.value.trim();
            if (value && value !== '{}') {
                try {
                    JSON.parse(value);
                    this.style.borderColor = '#28a745';
                } catch (e) {
                    this.style.borderColor = '#dc3545';
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("格式错误") ?>',
                            text: '<?= __("模型配置格式错误，请输入有效的JSON格式") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("模型配置格式错误，请输入有效的JSON格式") ?>');
                    }
                }
            } else {
                this.style.borderColor = '';
            }
        });
    }
    
    // MCP配置JSON验证
    const mcpConfigField = document.getElementById('mcp_config');
    if (mcpConfigField) {
        mcpConfigField.addEventListener('blur', function() {
            const value = this.value.trim();
            if (value && value !== '[]') {
                try {
                    JSON.parse(value);
                    this.style.borderColor = '#28a745';
                } catch (e) {
                    this.style.borderColor = '#dc3545';
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("格式错误") ?>',
                            text: '<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>');
                    }
                }
            } else {
                this.style.borderColor = '';
            }
        });
    }
    
    // 代理配置JSON验证
    const proxyConfigField = document.getElementById('proxy_config');
    if (proxyConfigField) {
        proxyConfigField.addEventListener('blur', function() {
            const value = this.value.trim();
            if (value && value !== '{}' && value !== '') {
                try {
                    JSON.parse(value);
                    this.style.borderColor = '#28a745';
                } catch (e) {
                    this.style.borderColor = '#dc3545';
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("格式错误") ?>',
                            text: '<?= __("代理配置格式错误，请输入有效的JSON格式") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("代理配置格式错误，请输入有效的JSON格式") ?>');
                    }
                }
            } else {
                this.style.borderColor = '';
            }
        });
    }
    
    // 租赁设置控制
    const isRentableCheckbox = document.getElementById('is_rentable');
    const rentalSettings = document.getElementById('rentalSettings');
    const rentalPriceGroup = document.getElementById('rentalPriceGroup');
    const categoryGroup = document.getElementById('categoryGroup');
    const tagsGroup = document.getElementById('tagsGroup');
    
    if (isRentableCheckbox) {
        isRentableCheckbox.addEventListener('change', function() {
            const isChecked = this.checked;
            if (rentalSettings) rentalSettings.style.display = isChecked ? 'block' : 'none';
            if (rentalPriceGroup) rentalPriceGroup.style.display = isChecked ? 'block' : 'none';
            if (categoryGroup) categoryGroup.style.display = isChecked ? 'block' : 'none';
            if (tagsGroup) tagsGroup.style.display = isChecked ? 'block' : 'none';
            
            // 如果未勾选，清空租赁相关字段
            if (!isChecked) {
                const rentalPriceInput = document.getElementById('rental_price');
                if (rentalPriceInput) rentalPriceInput.value = '0.00';
            }
        });
    }

    // 表单提交处理
    const form = document.getElementById('assistantForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // 验证必填字段
            const name = document.getElementById('name').value.trim();
            const adapterCode = document.getElementById('adapter_code').value;
            const modelCode = document.getElementById('model_code').value;
            const prompt = document.getElementById('prompt').value.trim();

            if (!name || !adapterCode || !modelCode || !prompt) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: '<?= __("提示") ?>',
                        text: '<?= __("请填写所有必填字段") ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请填写所有必填字段") ?>');
                }
                return false;
            }
            
            // 检查余额（如果没有配置自定义API密钥）
            const apiKeyValue = document.getElementById('api_key').value.trim();
            const userBalance = <?= $userBalance ?>;
            const minBalance = 1.0;
            
            if (!apiKeyValue && userBalance < minBalance) {
                // 余额不足的友好提示
                const confirmMsg = '❌ <?= __("账户余额不足") ?>\n\n' +
                    '<?= __("当前余额") ?>: ¥' + userBalance.toFixed(2) + '\n' +
                    '<?= __("最低要求") ?>: ¥' + minBalance.toFixed(2) + '\n\n' +
                    '<?= __("创建使用官方模型的助手需要至少") ?> ¥1.00 <?= __("的账户余额") ?>\n\n' +
                    '<?= __("您可以选择") ?>:\n' +
                    '1️⃣ <?= __("点击确定前往充值页面") ?>\n' +
                    '2️⃣ <?= __("点击取消，配置自己的API密钥") ?>\n\n' +
                    '<?= __("是否前往充值页面？") ?>';
                
                if (confirm(confirmMsg)) {
                    // 打开充值页面
                    window.open('<?= $this->getBackendUrl('ai/backend/recharge') ?>', '_blank');
                }
                return false;
            }

            // 验证 MCP 配置
            const mcpConfig = document.getElementById('mcp_config').value.trim();
            if (mcpConfig && mcpConfig !== '[]') {
                try {
                    JSON.parse(mcpConfig);
                } catch (error) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("格式错误") ?>',
                            text: '<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("MCP配置格式错误，请输入有效的JSON格式") ?>');
                    }
                    return false;
                }
            }
            
            // 验证代理配置
            const proxyConfig = document.getElementById('proxy_config').value.trim();
            if (proxyConfig && proxyConfig !== '{}' && proxyConfig !== '') {
                try {
                    JSON.parse(proxyConfig);
                } catch (error) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __("格式错误") ?>',
                            text: '<?= __("代理配置格式错误，请输入有效的JSON格式") ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __("代理配置格式错误，请输入有效的JSON格式") ?>');
                    }
                    return false;
                }
            }

            // 提交表单数据
            const formData = new FormData(this);
            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.textContent;
            
            // 显示加载状态
            submitBtn.disabled = true;
            submitBtn.textContent = '<?= __("保存中...") ?>';
            
            // 处理checkbox的is_active字段
            const isActiveCheckbox = document.getElementById('is_active');
            if (isActiveCheckbox && !isActiveCheckbox.checked) {
                formData.set('is_active', '0');
            }
            
            fetch('<?= $this->getBackendUrl('*/backend/assistant/save') ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // 关闭Offcanvas弹窗
                    if (window.parent && window.parent !== window) {
                        // 如果在iframe中（Offcanvas），关闭弹窗并刷新父页面
                        try {
                            // 查找并点击关闭按钮
                            const closeBtn = window.parent.document.querySelector('.offcanvas .btn-close, .offcanvas [data-bs-dismiss="offcanvas"]');
                            if (closeBtn) {
                                closeBtn.click();
                            }
                            // 刷新父页面
                            setTimeout(() => {
                                window.parent.location.reload();
                            }, 300);
                        } catch (e) {
                            // 跨域或其他错误，直接刷新
                            window.parent.location.reload();
                        }
                    } else {
                        // 不在iframe中，直接刷新当前页面
                        location.reload();
                    }
                } else {
                    // 处理余额不足错误
                    if (data.error_code === 'INSUFFICIENT_BALANCE') {
                        const confirmMsg = '❌ <?= __("账户余额不足") ?>\n\n' +
                            '<?= __("当前余额") ?>: ¥' + (data.current_balance || 0).toFixed(2) + '\n' +
                            '<?= __("最低要求") ?>: ¥' + (data.required_balance || 1).toFixed(2) + '\n\n' +
                            data.message + '\n\n' +
                            '<?= __("是否前往充值页面？") ?>';
                        
                        if (confirm(confirmMsg)) {
                            if (data.recharge_url) {
                                window.open(data.recharge_url, '_blank');
                            } else {
                                window.open('<?= $this->getBackendUrl('ai/backend/recharge') ?>', '_blank');
                            }
                        }
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __("保存失败") ?>',
                                text: data.message || '<?= __("未知错误") ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        } else {
                            console.error('<?= __("保存失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
                        }
                    }
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            })
            .catch(error => {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("请求失败") ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("请求失败：") ?>' + error.message);
                }
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            });
        });
    }
})();
</script>

