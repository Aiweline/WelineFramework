<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 提示词模板
const templates = {
    customer_service: `你是一个专业、友好的客服人员。你的任务是：
1. 理解客户的问题和需求
2. 提供准确、清晰的解答
3. 保持礼貌和耐心
4. 如果无法解决问题，引导客户联系人工客服

客户问题：{input}`,
    
    tech_support: `你是一个技术支持专家。你需要：
1. 诊断技术问题
2. 提供详细的解决步骤
3. 使用通俗易懂的语言解释技术概念
4. 必要时提供代码示例

问题描述：{input}
产品版本：{context}`,
    
    sales: `你是一个产品销售顾问。你的职责是：
1. 了解客户需求
2. 推荐合适的产品或方案
3. 解答产品相关问题
4. 促进销售转化

客户咨询：{input}`
};

// 加载模板
function loadTemplate(type) {
    if (templates[type]) {
        document.getElementById('prompt_template').value = templates[type];
    }
}

document.addEventListener('DOMContentLoaded', function() {
    // 表单验证
    const form = document.getElementById('assistantEditForm');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // 显示加载状态
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("保存中...") ?>';
        
        // 提交表单
        const formData = new FormData(form);
        
        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // 显示成功消息
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __("保存成功") ?>',
                        text: '<?= __("助手已成功保存") ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        // 关闭 Offcanvas
                        const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('assistantEditOffcanvas'));
                        offcanvas.hide();
                        // 刷新列表
                        window.location.reload();
                    });
                } else {
                    console.log('<?= __("保存成功！") ?>');
                    // 关闭 Offcanvas
                    const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('assistantEditOffcanvas'));
                    offcanvas.hide();
                    // 刷新列表
                    window.location.reload();
                }
            } else {
                // 显示错误消息
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __("保存失败") ?>',
                        text: data.message || '<?= __("未知错误") ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __("保存失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
                }
            }
        })
        .catch(error => {
            console.error('Error:', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("保存失败") ?>',
                    text: '<?= __("请稍后重试") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("保存失败，请稍后重试") ?>');
            }
        })
        .finally(() => {
            // 恢复按钮状态
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    });
    
    // 自动打开 Offcanvas（如果是新建或编辑模式）
    <?php if ($this->getData('auto_open')): ?>
    const offcanvas = new bootstrap.Offcanvas(document.getElementById('assistantEditOffcanvas'));
    offcanvas.show();
    <?php endif; ?>
});

// 测试助手
function testAssistant(id) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __("测试助手") ?>',
            input: 'textarea',
            inputLabel: '<?= __("请输入测试问题：") ?>',
            inputPlaceholder: '<?= __("请输入您的问题...") ?>',
            showCancelButton: true,
            confirmButtonText: '<?= __("测试") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            inputValidator: (value) => {
                if (!value) {
                    return '<?= __("请输入测试问题") ?>';
                }
            }
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                performTest(id, result.value);
            }
        });
    } else {
        const testInput = prompt('<?= __("请输入测试问题：") ?>');
        if (!testInput) return;
        performTest(id, testInput);
    }
}

function performTest(id, testInput) {
    
    // 显示加载
    const btn = event ? event.target : document.querySelector('[onclick*="testAssistant"]');
    const originalHtml = btn ? btn.innerHTML : '';
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("测试中...") ?>';
    }
    
    // 显示加载提示
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __("测试中") ?>',
            text: '<?= __("正在处理您的问题...") ?>',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });
    }
    
    fetch('<?= $this->getUrl('*/*/test') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            id: id,
            input: testInput,
            form_key: '<?= $this->getFormKey() ?>'
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __("助手响应") ?>',
                    html: data.data.response.replace(/\n/g, '<br>'),
                    confirmButtonText: '<?= __('确定') ?>',
                    width: '600px'
                });
            } else {
                console.log('<?= __("助手响应：\n\n") ?>' + data.data.response);
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("测试失败") ?>',
                    text: data.message || '<?= __("未知错误") ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __("测试失败：") ?>' + (data.message || '<?= __("未知错误") ?>'));
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __("测试失败") ?>',
                text: '<?= __("请稍后重试") ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __("测试失败，请稍后重试") ?>');
        }
    })
    .finally(() => {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });
}
</script>

