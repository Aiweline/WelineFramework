<script>
(function() {
    'use strict';
    
    var WelineAssistant = {
        scanAdapters: function() {
            if (confirm('<?= __('确定要扫描场景适配器吗？') ?>')) {
                fetch('<?= $this->getBackendUrl('*/backend/adapter/scan') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        alert('<?= __('适配器扫描成功！') ?>');
                        location.reload();
                    } else {
                        alert('<?= __('适配器扫描失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                    }
                })
                .catch(function(error) {
                    alert('<?= __('请求失败：') ?>' + error.message);
                });
            }
        },
        
        toggleStatus: function(adapterId) {
            if (confirm('<?= __('确定要切换适配器状态吗？') ?>')) {
                fetch('<?= $this->getBackendUrl('*/backend/adapter/toggleStatus') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({id: adapterId})
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        alert('<?= __('状态切换成功！') ?>');
                        location.reload();
                    } else {
                        alert('<?= __('状态切换失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                    }
                })
                .catch(function(error) {
                    alert('<?= __('请求失败：') ?>' + error.message);
                });
            }
        }
    };
    
    window.WelineAssistant = WelineAssistant;
})();
</script>
