<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';
    
    document.getElementById('copy-form').addEventListener('submit', function(e) {
        e.preventDefault();
        
        var modelName = document.getElementById('model_name').value.trim();
        var modelCode = document.getElementById('model_code').value.trim();
        
        if (!modelName) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请输入新模型名称') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请输入新模型名称') ?>');
            }
            document.getElementById('model_name').focus();
            return false;
        }
        
        if (!modelCode) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请输入新模型代码') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请输入新模型代码') ?>');
            }
            document.getElementById('model_code').focus();
            return false;
        }
        
        var codePattern = /^[a-zA-Z0-9._-]+$/;
        if (!codePattern.test(modelCode)) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('格式错误') ?>',
                    text: '<?= __('模型代码只能包含字母、数字、点号(.)、下划线(_)和中划线(-)') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('模型代码只能包含字母、数字、点号(.)、下划线(_)和中划线(-)') ?>');
            }
            document.getElementById('model_code').focus();
            return false;
        }
        
        var btn = this.querySelector('button[type="submit"]');
        var originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('复制中...') ?>';
        
        var formData = new FormData(this);
        window.Weline.Api.request('<?= $this->getBackendUrl('*/backend/model/copy') ?>', { method: 'POST', body: formData })
        .then(function(response) {
            var data = response.data;
            if (response.ok && data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('复制成功') ?>',
                        text: '<?= __('模型已成功复制') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function() {
                        window.parent.bootstrap.Offcanvas.getInstance(window.frameElement.closest('.offcanvas')).hide();
                        setTimeout(function() {
                            window.parent.location.reload();
                        }, 500);
                    });
                } else {
                    console.log('<?= __('复制成功！') ?>');
                    window.parent.bootstrap.Offcanvas.getInstance(window.frameElement.closest('.offcanvas')).hide();
                    setTimeout(function() {
                        window.parent.location.reload();
                    }, 500);
                }
            } else {
                var errMsg = (data && (data.message || data.msg)) || '<?= __('复制失败') ?>';
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('复制失败') ?>',
                        text: errMsg,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('复制失败：') ?>' + data.message);
                }
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        })
        .catch(function(error) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请求失败：') ?>' + error.message);
            }
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
        
        return false;
    });
    
    document.getElementById('model_name').select();
})();
</script>

