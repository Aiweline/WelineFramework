<script>
document.getElementById('copy-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // 验证必填字段
    const modelName = document.getElementById('model_name').value.trim();
    const modelCode = document.getElementById('model_code').value.trim();
    
    if (!modelName) {
        alert('<?= __('请输入新模型名称') ?>');
        document.getElementById('model_name').focus();
        return false;
    }
    
    if (!modelCode) {
        alert('<?= __('请输入新模型代码') ?>');
        document.getElementById('model_code').focus();
        return false;
    }
    
    // 验证模型代码格式（只允许字母、数字、下划线、中划线）
    const codePattern = /^[a-zA-Z0-9_-]+$/;
    if (!codePattern.test(modelCode)) {
        alert('<?= __('模型代码只能包含字母、数字、下划线和中划线') ?>');
        document.getElementById('model_code').focus();
        return false;
    }
    
    const btn = this.querySelector('button[type="submit"]');
    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('复制中...') ?>';
    
    const formData = new FormData(this);
    
    fetch('<?= $this->getBackendUrl('*/backend/model/copy') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('复制成功！') ?>');
            // 关闭 offcanvas
            window.parent.bootstrap.Offcanvas.getInstance(window.frameElement.closest('.offcanvas')).hide();
            // 刷新父页面
            setTimeout(() => {
                window.parent.location.reload();
            }, 500);
        } else {
            alert('<?= __('复制失败：') ?>' + data.message);
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    });
    
    return false;
});

