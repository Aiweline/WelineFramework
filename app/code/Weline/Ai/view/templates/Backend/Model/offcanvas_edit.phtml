<script>
(function() {
    'use strict';

    var modelConfig = <?= $modelConfigJson ?>;
    var commonModelPresets = <?= $modelPresetsJson ?>;
    var quickRemoteModelOptions = [];

    window.WelineAiModelEdit = {
        toggleProviderConfig: function() {
            var body = document.getElementById('providerConfigBody');
            var icon = document.getElementById('providerConfigIcon');

            if (body.style.display === 'none') {
                body.style.display = 'block';
                icon.classList.remove('bi-chevron-right');
                icon.classList.add('bi-chevron-down');
            } else {
                body.style.display = 'none';
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-right');
            }
        },

        dispatchChange: function(element) {
            if (!element) return;
            if (typeof Event === 'function') {
                element.dispatchEvent(new Event('change', { bubbles: true }));
                return;
            }
            var event = document.createEvent('HTMLEvents');
            event.initEvent('change', true, false);
            element.dispatchEvent(event);
        },

        setFieldValue: function(id, value) {
            var element = document.getElementById(id);
            if (!element) return;
            element.value = value;
            this.dispatchChange(element);
        },

        setRangeValue: function(id, badgeId, value) {
            var element = document.getElementById(id);
            if (!element || value === undefined || value === null) return;
            element.value = value;
            var badge = document.getElementById(badgeId);
            if (badge) {
                badge.textContent = value;
            }
        },

        createElement: function(tag, className, text) {
            var element = document.createElement(tag);
            if (className) {
                element.className = className;
            }
            if (text !== undefined && text !== null) {
                element.textContent = String(text);
            }
            return element;
        },

        appendLabeledText: function(container, label, value, code) {
            container.appendChild(this.createElement('small', 'text-muted', label));
            var valueNode = this.createElement(code ? 'code' : 'span', '', value);
            container.appendChild(valueNode);
            container.appendChild(document.createElement('br'));
        },

        normalizeImageUrl: function(image) {
            var url = image && image.url ? String(image.url).trim() : '';
            if (url) {
                var lower = url.replace(/[\r\n\t ]/g, '').toLowerCase();
                if (/^(https?:\/\/|\/|\.\/|\.\.\/)/.test(url) && !/^(javascript:|data:|vbscript:)/.test(lower)) {
                    return url;
                }
                return '';
            }
            var mime = image && image.mime_type ? String(image.mime_type).toLowerCase() : 'image/png';
            if (!/^(image\/png|image\/jpeg|image\/webp|image\/gif)$/.test(mime)) {
                mime = 'image/png';
            }
            var b64 = image && image.b64_json ? String(image.b64_json).replace(/\s+/g, '') : '';
            if (!b64 || !/^[a-zA-Z0-9+/=]+$/.test(b64)) {
                return '';
            }
            return 'data:' + mime + ';base64,' + b64;
        },

        appendTestImages: function(container, result) {
            var images = Array.isArray(result && result.images) ? result.images : [];
            if (!images.length) {
                return;
            }
            var row = this.createElement('div', 'row g-2 mt-2');
            images.forEach(function(image) {
                var src = window.WelineAiModelEdit.normalizeImageUrl(image);
                if (!src) {
                    return;
                }
                var col = window.WelineAiModelEdit.createElement('div', 'col-6');
                var link = document.createElement('a');
                link.href = src;
                link.target = '_blank';
                link.rel = 'noopener';
                var img = document.createElement('img');
                img.src = src;
                img.alt = '';
                img.className = 'img-fluid rounded border';
                img.style.maxHeight = '220px';
                img.style.width = '100%';
                img.style.objectFit = 'contain';
                img.style.background = '#fff';
                link.appendChild(img);
                col.appendChild(link);
                row.appendChild(col);
            });
            if (row.childNodes.length) {
                container.appendChild(row);
            }
        },

        appendTestCard: function(container, title, result, showAccount) {
            var tested = !!(result && result.tested);
            var success = !!(result && result.success);
            var alertClass = success ? 'success' : (tested ? 'danger' : 'secondary');
            var col = this.createElement('div', 'col-12');
            var alert = this.createElement('div', 'alert alert-' + alertClass + ' py-1 px-2 mb-2');
            var titleNode = this.createElement('small', 'fw-bold', title);
            var badge = this.createElement(
                'span',
                'badge bg-' + (tested ? (success ? 'success' : 'danger') : 'secondary'),
                tested ? (success ? '<?= addslashes(__('成功')) ?>' : '<?= addslashes(__('失败')) ?>') : '<?= addslashes(__('未测')) ?>'
            );

            alert.appendChild(titleNode);
            alert.appendChild(document.createTextNode(' '));
            alert.appendChild(badge);

            if (showAccount && result && result.account_name) {
                alert.appendChild(document.createTextNode(' '));
                alert.appendChild(this.createElement('span', 'badge bg-info', result.account_name));
            }
            alert.appendChild(document.createElement('br'));

            if (tested) {
                this.appendLabeledText(alert, '<?= addslashes(__('耗时：')) ?>', String(result && result.duration ? result.duration : 0) + ' ms', true);
                alert.appendChild(this.createElement('small', 'text-muted', '<?= addslashes(__('消息：')) ?>'));
                alert.appendChild(document.createTextNode(String(result && result.message ? result.message : '')));
                this.appendTestImages(alert, result || {});
            }

            col.appendChild(alert);
            container.appendChild(col);
        },

        renderTestResults: function(resultContent, data) {
            resultContent.textContent = '';
            if (data && data.data && data.data.results) {
                var row = this.createElement('div', 'row g-2');
                var results = data.data.results;
                this.appendTestCard(row, '<?= addslashes(__('自配置')) ?>', results.self_config || {}, false);
                this.appendTestCard(row, '<?= addslashes(__('供应商账户')) ?>', results.provider_account || {}, true);
                resultContent.appendChild(row);
                return;
            }

            var success = !!(data && data.success);
            var alert = this.createElement('div', 'alert alert-' + (success ? 'success' : 'danger') + ' py-1 px-2 mb-2');
            var small = this.createElement('small');
            small.appendChild(this.createElement('strong', '', success ? '<?= addslashes(__('成功!')) ?>' : '<?= addslashes(__('失败!')) ?>'));
            small.appendChild(document.createTextNode(' ' + String(data && data.message ? data.message : '')));
            alert.appendChild(small);
            if (success) {
                this.appendTestImages(alert, data || {});
            }
            resultContent.appendChild(alert);
        },

        renderTestError: function(resultContent, message) {
            resultContent.textContent = '';
            var alert = this.createElement('div', 'alert alert-danger py-1 px-2');
            var small = this.createElement('small');
            small.appendChild(this.createElement('strong', '', '<?= addslashes(__('网络错误!')) ?>'));
            small.appendChild(document.createTextNode(' ' + String(message || '')));
            alert.appendChild(small);
            resultContent.appendChild(alert);
        },

        applyPreset: function(preset) {
            if (!preset) return;

            this.setFieldValue('supplier', preset.provider || '');
            this.setFieldValue('supplier_value', preset.provider || '');
            this.setFieldValue('model_code', preset.model_code || '');
            this.setFieldValue('provider_model_code', preset.provider_model_code || preset.model_code || '');
            this.setFieldValue('name', preset.name || preset.model_code || '');
            this.setFieldValue('version', preset.version || '1.0');
            this.setFieldValue('max_tokens', preset.max_tokens || 4096);

            this.setFieldValue('token_price_input', preset.token_price_input || 0);
            this.setFieldValue('token_price_output', preset.token_price_output || 0);
            if (preset.cost_per_token !== undefined) {
                this.setFieldValue('cost_per_token', preset.cost_per_token || 0);
            }

            this.setRangeValue('config_temperature', 'tempValue', preset.temperature !== undefined ? preset.temperature : 0.7);
            this.setRangeValue('config_top_p', 'topPValue', preset.top_p !== undefined ? preset.top_p : 1);
                    this.setFieldValue('config_timeout', preset.timeout || <?= \Weline\Ai\Service\Provider\ProviderTimeoutPolicy::DEFAULT_REQUEST_TIMEOUT ?>);

            var streamInput = document.getElementById('config_stream');
            if (streamInput) {
                streamInput.checked = preset.stream !== false;
            }

            var providerConfigTextarea = document.getElementById('provider_config_json');
            if (providerConfigTextarea) {
                var config = Object.assign({}, preset.config || {});
                var apiKeyInput = document.getElementById('api_key_input');
                if (apiKeyInput && apiKeyInput.value.trim()) {
                    config.api_key = apiKeyInput.value.trim();
                }
                providerConfigTextarea.value = JSON.stringify(config, null, 2);
            }
        },

        syncApiKeyToProviderConfig: function() {
            var apiKeyInput = document.getElementById('api_key_input');
            var providerConfigTextarea = document.getElementById('provider_config_json');
            if (!apiKeyInput || !providerConfigTextarea || !apiKeyInput.value.trim()) {
                return;
            }

            try {
                var config = {};
                if (providerConfigTextarea.value.trim()) {
                    config = JSON.parse(providerConfigTextarea.value);
                }
                config.api_key = apiKeyInput.value.trim();
                providerConfigTextarea.value = JSON.stringify(config, null, 2);
            } catch (e) {
                // Keep manual JSON untouched until submit-time validation can report the exact error.
            }
        },

        getProviderConfigValue: function(key) {
            var providerConfigTextarea = document.getElementById('provider_config_json');
            if (!providerConfigTextarea || !providerConfigTextarea.value.trim()) {
                return '';
            }
            try {
                var config = JSON.parse(providerConfigTextarea.value);
                return config && config[key] ? String(config[key]) : '';
            } catch (e) {
                return '';
            }
        },

        applyRemoteModel: function(item) {
            if (!item || !item.code) return;
            this.setFieldValue('model_code', item.code);
            this.setFieldValue('provider_model_code', item.code);
            this.setFieldValue('name', item.name || item.code);
            if (item.primary_modality) {
                this.setFieldValue('primary_modality', item.primary_modality);
            }
            if (item.max_tokens && Number(item.max_tokens) > 0) {
                this.setFieldValue('max_tokens', item.max_tokens);
            }
        },

        fillRemoteModelSelect: function(select, items, placeholder) {
            if (!select) return;
            select.innerHTML = '';
            var first = document.createElement('option');
            first.value = '';
            first.textContent = placeholder || '<?= addslashes(__('选择模型')) ?>';
            select.appendChild(first);
            (items || []).forEach(function(item) {
                var option = document.createElement('option');
                option.value = item.code || item.value || '';
                option.textContent = item.label || item.name || item.code || item.value || '';
                option.dataset.modelName = item.name || item.code || item.value || '';
                option.dataset.maxTokens = item.max_tokens || 0;
                option.dataset.primaryModality = item.primary_modality || '';
                select.appendChild(option);
            });
            select.disabled = !items || items.length === 0;
        },

        loadRemoteModels: function(providerCode, accountId) {
            var self = this;
            var remoteSelect = document.getElementById('remote_model_select');
            var testSelect = document.getElementById('test_model_code_select');
            var remoteHelp = document.getElementById('remote_model_help');
            var testHelp = document.getElementById('test_model_code_help');
            var currentModel = document.getElementById('model_code');
            var selectedCurrent = currentModel ? currentModel.value : '';

            this.fillRemoteModelSelect(remoteSelect, [], providerCode ? '<?= addslashes(__('正在加载模型...')) ?>' : '<?= addslashes(__('请先选择供应商')) ?>');
            this.fillRemoteModelSelect(testSelect, [], providerCode ? '<?= addslashes(__('正在加载模型...')) ?>' : '<?= addslashes(__('使用当前模型')) ?>');
            if (!providerCode) return;

            var url = '<?= addslashes($this->getBackendUrl('*/backend/provider/getRemoteModelsForSelect')) ?>';
            var formData = new FormData();
            formData.set('provider_code', providerCode);
            formData.set('account_id', accountId || '');
            if (!accountId) {
                var apiKeyInput = document.getElementById('api_key_input');
                var apiKey = apiKeyInput ? apiKeyInput.value.trim() : '';
                var baseUrl = this.getProviderConfigValue('base_url') || this.getProviderConfigValue('api_url');
                if (apiKey) formData.set('api_key', apiKey);
                if (baseUrl) formData.set('base_url', baseUrl);
            }

            var req = window.Weline.Api.request(url, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            req.then(function(res) {
                var resp = (res && res.data) || res;
                var items = resp && resp.success && Array.isArray(resp.data) ? resp.data : [];
                if (!items.length) {
                    var message = resp && resp.message ? resp.message : '<?= addslashes(__('models 接口不可用，请手动输入模型。')) ?>';
                    if (remoteHelp) remoteHelp.textContent = message;
                    if (testHelp) testHelp.textContent = message;
                    self.fillRemoteModelSelect(remoteSelect, [], '<?= addslashes(__('手动输入模型')) ?>');
                    self.fillRemoteModelSelect(testSelect, [], '<?= addslashes(__('使用当前模型')) ?>');
                    return;
                }

                self.fillRemoteModelSelect(remoteSelect, items, '<?= addslashes(__('选择供应商模型')) ?>');
                self.fillRemoteModelSelect(testSelect, items, '<?= addslashes(__('使用当前模型')) ?>');
                if (remoteHelp) remoteHelp.textContent = '<?= addslashes(__('已从供应商 models 接口加载。')) ?>';
                if (testHelp) testHelp.textContent = '<?= addslashes(__('只能选择当前供应商账户返回的模型。')) ?>';

                if (selectedCurrent && testSelect) {
                    testSelect.value = selectedCurrent;
                }
            }).catch(function() {
                if (remoteHelp) remoteHelp.textContent = '<?= addslashes(__('models 接口请求失败，请手动输入模型。')) ?>';
                if (testHelp) testHelp.textContent = '<?= addslashes(__('models 接口请求失败，测试将使用当前模型。')) ?>';
                self.fillRemoteModelSelect(remoteSelect, [], '<?= addslashes(__('手动输入模型')) ?>');
                self.fillRemoteModelSelect(testSelect, [], '<?= addslashes(__('使用当前模型')) ?>');
            });
        },

        fillModelPresetOptions: function(providerCode) {
            var select = document.getElementById('common_model_preset');
            if (!select) return;

            select.innerHTML = '';
            var placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = providerCode ? '<?= addslashes(__('选择模型')) ?>' : '<?= addslashes(__('先选择供应商')) ?>';
            select.appendChild(placeholder);
            select.disabled = !providerCode;

            var searchInput = document.getElementById('common_model_search');
            if (searchInput) {
                searchInput.value = '';
                searchInput.disabled = !providerCode;
            }
            quickRemoteModelOptions = [];
            if (!providerCode) return;

            placeholder.textContent = '<?= addslashes(__('正在加载供应商模型...')) ?>';
            select.disabled = true;
            if (searchInput) searchInput.disabled = true;
            this.loadQuickRemoteModels(providerCode).then(function(items) {
                quickRemoteModelOptions = items;
                window.WelineAiModelEdit.renderQuickRemoteModels('');
                select.disabled = false;
                if (searchInput) searchInput.disabled = false;
            }).catch(function(error) {
                select.innerHTML = '';
                var option = document.createElement('option');
                option.value = '';
                option.textContent = error && error.message ? error.message : '<?= addslashes(__('无法加载供应商模型')) ?>';
                select.appendChild(option);
                select.disabled = true;
                if (searchInput) searchInput.disabled = true;
            });
            return;

            if (!providerCode || !Array.isArray(commonModelPresets)) return;

            var presets = commonModelPresets.filter(function(preset) {
                return preset.provider === providerCode;
            });
            presets.forEach(function(preset) {
                var option = document.createElement('option');
                option.value = preset.key;
                option.textContent = (preset.name || preset.model_code || '') + ' (' + (preset.model_code || '') + ')';
                select.appendChild(option);
            });

            if (presets.length === 1) {
                select.value = presets[0].key;
                this.applyPreset(presets[0]);
            }
        },

        loadQuickRemoteModels: function(providerCode) {
            var params = new URLSearchParams({
                provider_code: providerCode,
                require_remote: '1'
            });
            var apiKeyInput = document.getElementById('api_key_input');
            if (apiKeyInput && apiKeyInput.value.trim()) {
                params.set('api_key', apiKeyInput.value.trim());
            }
            var url = '<?= addslashes($this->getBackendUrl('*/backend/provider/getRemoteModelsForSelect')) ?>?' + params.toString();
            return fetch(url, {
                method: 'GET',
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
            }).then(function(response) {
                return response.text().then(function(text) {
                    var json = {};
                    try {
                        json = text ? JSON.parse(text) : {};
                    } catch (e) {
                        throw new Error('<?= addslashes(__('models 接口返回了非 JSON 响应')) ?>');
                    }
                    if (!response.ok || !json.success) {
                        throw new Error(json.message || ('<?= addslashes(__('models 接口 HTTP ')) ?>' + response.status));
                    }
                    if (!Array.isArray(json.data) || !json.data.length) {
                        throw new Error('<?= addslashes(__('models 接口返回了空列表')) ?>');
                    }
                    return json.data;
                });
            });
        },

        renderQuickRemoteModels: function(keyword) {
            var select = document.getElementById('common_model_preset');
            if (!select) return;
            var normalizedKeyword = String(keyword || '').trim().toLowerCase();
            select.innerHTML = '';
            var placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = '<?= addslashes(__('选择模型')) ?>';
            select.appendChild(placeholder);
            var matchedCount = 0;
            var firstValue = '';
            quickRemoteModelOptions.filter(function(model) {
                if (!normalizedKeyword) return true;
                var text = [
                    model.code || model.value || '',
                    model.name || '',
                    model.label || '',
                    model.description || '',
                    model.primary_modality || ''
                ].join(' ').toLowerCase();
                return text.indexOf(normalizedKeyword) !== -1;
            }).forEach(function(model) {
                var code = model.code || model.value || '';
                if (!code) return;
                var option = document.createElement('option');
                option.value = code;
                option.textContent = model.label || ((model.name || code) + ' (' + code + ')');
                option.dataset.modelName = model.name || code;
                option.dataset.maxTokens = model.max_tokens || model.context_window || 4096;
                option.dataset.primaryModality = model.primary_modality || '';
                select.appendChild(option);
                matchedCount++;
                if (!firstValue) firstValue = code;
            });
            select.disabled = matchedCount === 0;
            if (matchedCount === 1 && firstValue) {
                select.value = firstValue;
                this.applyQuickRemoteModel(select.options[select.selectedIndex]);
            }
        },

        applyQuickRemoteModel: function(option) {
            if (!option || !option.value) return;
            var code = option.value;
            var maxTokens = parseInt(option.dataset.maxTokens || '4096', 10) || 4096;
            var primaryModality = option.dataset.primaryModality || '';
            var name = option.dataset.modelName || code;
            this.setFieldValue('model_code', code);
            this.setFieldValue('provider_model_code', code);
            this.setFieldValue('name', name);
            this.setFieldValue('max_tokens', maxTokens);
            if (primaryModality) {
                this.setFieldValue('primary_modality', primaryModality);
            }
            var providerConfigTextarea = document.getElementById('provider_config_json');
            if (providerConfigTextarea) {
                providerConfigTextarea.value = JSON.stringify({
                    model: code,
                    model_id: code,
                    max_tokens: maxTokens,
                    temperature: 0,
                    top_p: 1,
                    stream: false,
                    primary_modality: primaryModality || 'text2text'
                }, null, 2);
            }
            var currentModelInput = document.getElementById('model_code');
            if (currentModelInput) {
                currentModelInput.dispatchEvent(new Event('input', { bubbles: true }));
                currentModelInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
        },

        initPresetSelector: function() {
            var providerSelect = document.getElementById('common_provider_preset');
            var modelSelect = document.getElementById('common_model_preset');
            if (!providerSelect || !modelSelect || !Array.isArray(commonModelPresets)) return;

            var self = this;
            var providers = {};
            commonModelPresets.forEach(function(preset) {
                if (!preset.provider) return;
                providers[preset.provider] = preset.provider_name || preset.provider;
            });

            Object.keys(providers).sort(function(a, b) {
                return providers[a].localeCompare(providers[b]);
            }).forEach(function(providerCode) {
                var option = document.createElement('option');
                option.value = providerCode;
                option.textContent = providers[providerCode];
                providerSelect.appendChild(option);
            });

            providerSelect.addEventListener('change', function() {
                self.fillModelPresetOptions(this.value || '');
                self.loadRemoteModels(this.value || '', '');
            });

            modelSelect.addEventListener('change', function() {
                if (!this.value) return;
                self.applyQuickRemoteModel(this.options[this.selectedIndex]);
            });

            var quickSearchInput = document.getElementById('common_model_search');
            if (quickSearchInput) {
                quickSearchInput.addEventListener('input', function() {
                    self.renderQuickRemoteModels(this.value || '');
                });
            }

            var apiKeyInput = document.getElementById('api_key_input');
            if (apiKeyInput) {
                apiKeyInput.addEventListener('input', function() {
                    self.syncApiKeyToProviderConfig();
                    var supplierVal = document.getElementById('supplier_value');
                    var accountSelect = document.getElementById('provider_account_id');
                    if (providerSelect.value) self.fillModelPresetOptions(providerSelect.value);
                    self.loadRemoteModels(supplierVal ? supplierVal.value : '', accountSelect ? accountSelect.value : '');
                });
            }

            var remoteSelect = document.getElementById('remote_model_select');
            if (remoteSelect) {
                remoteSelect.addEventListener('change', function() {
                    if (!this.value) return;
                    self.applyRemoteModel({
                        code: this.value,
                        name: this.options[this.selectedIndex] ? this.options[this.selectedIndex].dataset.modelName : this.value,
                        max_tokens: this.options[this.selectedIndex] ? this.options[this.selectedIndex].dataset.maxTokens : 0,
                        primary_modality: this.options[this.selectedIndex] ? this.options[this.selectedIndex].dataset.primaryModality : ''
                    });
                });
            }
        },

        init: function() {
            // 设置配置参数的值
            if (modelConfig.temperature !== undefined) {
                document.getElementById('config_temperature').value = modelConfig.temperature;
                document.getElementById('tempValue').textContent = modelConfig.temperature;
            }
            if (modelConfig.top_p !== undefined) {
                document.getElementById('config_top_p').value = modelConfig.top_p;
                document.getElementById('topPValue').textContent = modelConfig.top_p;
            }
            if (modelConfig.timeout !== undefined) {
                var timeoutInput = document.getElementById('config_timeout');
                if (timeoutInput) {
                    timeoutInput.value = modelConfig.timeout;
                }
            }

            this.initAccountSelect();
            this.initPresetSelector();
            this.initForm();
            this.initTestPanel();
            this.initSafeEventBindings();
        },

        initSafeEventBindings: function() {
            document.addEventListener('click', function(event) {
                var trigger = event.target.closest('[data-ai-model-edit-action]');
                if (!trigger) {
                    return;
                }
                event.preventDefault();
                if (trigger.getAttribute('data-ai-model-edit-action') === 'toggle-provider-config') {
                    window.WelineAiModelEdit.toggleProviderConfig();
                }
            });

            document.querySelectorAll('[data-range-output]').forEach(function(input) {
                input.addEventListener('input', function() {
                    var output = document.getElementById(input.getAttribute('data-range-output') || '');
                    if (output) {
                        output.textContent = input.value;
                    }
                });
            });
        },

        initAccountSelect: function() {
            var supplierVal = document.getElementById('supplier_value');
            var accountSelect = document.getElementById('provider_account_id');
            if (!supplierVal || !accountSelect) return;
            var self = this;
            var backendUrl = '<?= addslashes($this->getBackendUrl('*/backend/provider/getAccountsForSelect')) ?>';
            var selectedId = '<?= addslashes($selectedAccountId ?? '') ?>';
            function loadAccounts(providerCode) {
                accountSelect.innerHTML = '<option value=""><?= addslashes(__('选择账户或使用自配置')) ?></option>';
                self.loadRemoteModels(providerCode, '');
                if (!providerCode) return;
                var url = backendUrl + '?provider_code=' + encodeURIComponent(providerCode) + '&limit=100';
                var req = window.Weline.Api.get(url, { silent: true });
                req.then(function(res) {
                    var resp = (res && res.data) || res;
                        var items = (resp && resp.success && resp.data) ? resp.data : (Array.isArray(resp) ? resp : []);
                        items.forEach(function(item) {
                            var opt = document.createElement('option');
                            opt.value = item.value;
                            opt.textContent = item.label;
                            if (item.value === selectedId) opt.selected = true;
                            accountSelect.appendChild(opt);
                        });
                        self.loadRemoteModels(providerCode, accountSelect.value || '');
                    })
                    .catch(function() {});
            }
            supplierVal.addEventListener('change', function() {
                loadAccounts(this.value || '');
            });
            accountSelect.addEventListener('change', function() {
                self.loadRemoteModels(supplierVal.value || '', this.value || '');
            });
            if (supplierVal.value) loadAccounts(supplierVal.value);
        },

        initForm: function() {
            var form = document.getElementById('modelEditForm');
            if (!form) return;

            form.addEventListener('submit', function(e) {
                e.preventDefault();

                var submitBtn = form.querySelector('button[type="submit"]');
                var originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __('保存中...') ?>';

                var apiKeyInput = document.getElementById('api_key_input');
                var providerConfigTextarea = document.getElementById('provider_config_json');

                if (apiKeyInput && apiKeyInput.value.trim() && providerConfigTextarea) {
                    try {
                        var config = {};
                        if (providerConfigTextarea.value.trim()) {
                            config = JSON.parse(providerConfigTextarea.value);
                        }
                        config.api_key = apiKeyInput.value.trim();
                        providerConfigTextarea.value = JSON.stringify(config, null, 2);
                    } catch (e) {
                        console.error('同步API密钥到JSON配置失败:', e);
                    }
                }

                if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
                    try {
                        JSON.parse(providerConfigTextarea.value);
                    } catch (e) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('格式错误') ?>',
                                text: '<?= __('提供商配置JSON格式错误，请检查语法') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                        return;
                    }
                }

                var formData = new FormData(form);
                var opts = { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } };
                var req = window.Weline.Api.request(form.action, opts).then(function(res) { return (res && res.data) || res; });
                req.then(function(data) {
                    if (data.success) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('保存成功') ?>',
                                text: '<?= __('模型已成功保存') ?>',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() {
                                if (window.parent) {
                                    window.parent.location.reload();
                                } else {
                                    window.location.reload();
                                }
                            });
                        } else {
                            if (window.parent) {
                                window.parent.location.reload();
                            } else {
                                window.location.reload();
                            }
                        }
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('保存失败') ?>',
                                text: (data.message || '<?= __('未知错误') ?>'),
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    }
                })
                .catch(function(error) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: '<?= __('请稍后重试') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    }
                })
                .finally(function() {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
            });
        },

        initTestPanel: function() {
            <?php if ($isEdit): ?>
            var testModelBtn = document.getElementById('testModelBtn');
            var toggleTestPanel = document.getElementById('toggleTestPanel');
            var testModelPanel = document.getElementById('testModelPanel');
            var closeTestPanel = document.getElementById('closeTestPanel');

            if (toggleTestPanel && testModelPanel) {
                toggleTestPanel.addEventListener('click', function() {
                    testModelPanel.style.display = testModelPanel.style.display === 'none' ? 'block' : 'none';
                });
            }

            if (closeTestPanel && testModelPanel) {
                closeTestPanel.addEventListener('click', function() {
                    testModelPanel.style.display = 'none';
                });
            }

            if (testModelBtn) {
                testModelBtn.addEventListener('click', function() {
                    var prompt = document.getElementById('test_prompt').value.trim();
                    var modelCodeInput = document.getElementById('model_code');
                    var testModelSelect = document.getElementById('test_model_code_select');
                    var modelCode = modelCodeInput ? modelCodeInput.value : <?= $modelCodeJsFallback ?>;
                    if (testModelSelect && testModelSelect.value) {
                        modelCode = testModelSelect.value;
                    }
                    var form = document.getElementById('modelEditForm');

                    if (!prompt) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: '<?= __('提示') ?>',
                                text: '<?= __('请输入测试提示词') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                        return;
                    }

                    testModelBtn.disabled = true;
                    testModelBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> <?= __('测试中...') ?>';

                    document.getElementById('testResult').style.display = 'none';

                    var providerConfigTextarea = document.getElementById('provider_config_json');
                    if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
                        try {
                            JSON.parse(providerConfigTextarea.value);
                        } catch (e) {
                            testModelBtn.disabled = false;
                            testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> Test model';
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Invalid JSON',
                                    text: 'Provider config JSON is invalid. Please check the syntax.',
                                    confirmButtonText: 'OK'
                                });
                            }
                            return;
                        }
                    }

                    var formData = form ? new FormData(form) : new FormData();
                    formData.set('model_code', modelCode);
                    formData.set('provider_model_code', modelCode);
                    formData.set('prompt', prompt);
                    formData.set('test_only', '1');

                    var tcUrl = '<?= $this->getBackendUrl("*/backend/model/testConnection") ?>';
                    var tcReq = window.Weline.Api.request(tcUrl, { method: 'POST', body: formData });
                    tcReq.then(function(res) {
                        var data = (res && res.data) || res;
                        testModelBtn.disabled = false;
                        testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __('测试模型') ?>';

                        var resultDiv = document.getElementById('testResult');
                        var resultContent = document.getElementById('testResultContent');

                        window.WelineAiModelEdit.renderTestResults(resultContent, data || {});
                        if (data && data.data && data.data.results) {
                            try { if (window.parent && window.parent !== window) { window.parent.location.reload(); } } catch (e) {}
                        } else if (data && data.success) {
                            try { if (window.parent && window.parent !== window) { window.parent.location.reload(); } } catch (e) {}
                        }

                        resultDiv.style.display = 'block';
                        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    })
                    .catch(function(error) {
                        testModelBtn.disabled = false;
                        testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __('测试模型') ?>';

                        var resultDiv = document.getElementById('testResult');
                        var resultContent = document.getElementById('testResultContent');

                        window.WelineAiModelEdit.renderTestError(resultContent, error ? error.message : '');

                        resultDiv.style.display = 'block';
                    });
                });
            }
            <?php endif; ?>
        }
    };

    document.addEventListener('DOMContentLoaded', function() {
        window.WelineAiModelEdit.init();
    });
})();
</script>
