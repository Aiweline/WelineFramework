<script>
document.addEventListener('DOMContentLoaded', function() {
    // 初始化配置值
    const modelConfig = <?= $model ? json_encode($model->getConfig()) : '{}' ?>;
    
    // 设置配置参数的值
    if (modelConfig.temperature !== undefined) {
        document.getElementById('config_temperature').value = modelConfig.temperature;
        document.getElementById('tempValue').textContent = modelConfig.temperature;
    }
    if (modelConfig.top_p !== undefined) {
        document.getElementById('config_top_p').value = modelConfig.top_p;
        document.getElementById('topPValue').textContent = modelConfig.top_p;
    }
    
    // 表单验证
    const form = document.getElementById('modelEditForm');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // 显示加载状态
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __("保存中...") ?>';
        
        // 同步API密钥到JSON配置
        const apiKeyInput = document.getElementById('api_key_input');
        const providerConfigTextarea = document.getElementById('provider_config_json');
        
        if (apiKeyInput && apiKeyInput.value.trim() && providerConfigTextarea) {
            try {
                // 获取现有配置
                let config = {};
                if (providerConfigTextarea.value.trim()) {
                    config = JSON.parse(providerConfigTextarea.value);
                }
                
                // 更新API密钥
                config.api_key = apiKeyInput.value.trim();
                
                // 写回textarea
                providerConfigTextarea.value = JSON.stringify(config, null, 2);
            } catch (e) {
                console.error('同步API密钥到JSON配置失败:', e);
            }
        }
        
        // 验证提供商配置JSON
        if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
            try {
                JSON.parse(providerConfigTextarea.value);
            } catch (e) {
                alert('<?= __("提供商配置JSON格式错误，请检查语法") ?>');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }
        }
        
        // 提交表单
        const formData = new FormData(form);
        
        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            // 尝试获取响应文本
            return response.text().then(text => {
                try {
                    return JSON.parse(text);
                } catch (e) {
                    console.error('服务器返回非JSON响应:', text.substring(0, 200));
                    throw new Error('服务器返回的不是有效的JSON格式');
                }
            });
        })
        .then(data => {
            if (data.success) {
                // 显示成功消息
                alert('<?= __("保存成功！") ?>');
                
                // 通知父窗口刷新页面（因为我们在 iframe 中）
                if (window.parent) {
                    window.parent.location.reload();
                } else {
                    window.location.reload();
                }
            } else {
                // 显示错误消息
                let errorMsg = '<?= __("保存失败：") ?>' + (data.message || '<?= __("未知错误") ?>');
                if (data.error) {
                    errorMsg += '\n\n<?= __("详细错误：") ?>' + data.error;
                }
                console.error('Save failed:', data);
                alert(errorMsg);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __("保存失败，请稍后重试") ?>\n\n<?= __("错误：") ?>' + error.message);
        })
        .finally(() => {
            // 恢复按钮状态
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    });
    
    // 模型测试功能
    <?php if ($isEdit): ?>
    const testModelBtn = document.getElementById('testModelBtn');
    if (testModelBtn) {
        testModelBtn.addEventListener('click', function() {
            const prompt = document.getElementById('test_prompt').value.trim();
            const modelId = <?= $model->getId() ?>;
            // 兼容：改为以模型代码为唯一键
            const modelCodeInput = document.getElementById('model_code');
            const modelCode = modelCodeInput ? modelCodeInput.value : '<?= $model ? addslashes($model->getData('model_code')) : '' ?>';
            
            if (!prompt) {
                alert('<?= __("请输入测试提示词") ?>');
                return;
            }
            
            // 禁用按钮并显示加载状态
            testModelBtn.disabled = true;
            testModelBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> <?= __("测试中...") ?>';
            
            // 隐藏之前的结果
            document.getElementById('testResult').style.display = 'none';
            
            // 发送测试请求
            const formData = new FormData();
    // 改为传递模型代码，避免依赖数据库ID
    formData.append('model_code', modelCode);
            formData.append('prompt', prompt);
            
            fetch('<?= $this->getBackendUrl("*/backend/model/testConnection") ?>', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                // 恢复按钮状态
                testModelBtn.disabled = false;
                testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __("测试模型") ?>';
                
                // 显示结果
                const resultDiv = document.getElementById('testResult');
                const resultContent = document.getElementById('testResultContent');
                
                if (data.success) {
                    resultContent.innerHTML = `
                        <div class="alert alert-success py-1 px-2 mb-2">
                            <small><strong><?= __("成功") ?>!</strong> ${data.message}</small>
                        </div>
                        <div class="mb-1">
                            <small class="text-muted"><?= __("响应时间:") ?></small>
                            <code>${data.data.duration} ms</code>
                        </div>
                        <div>
                            <small class="text-muted d-block mb-1"><?= __("响应:") ?></small>
                            <div class="alert alert-light py-1 px-2 mb-0" style="white-space: pre-wrap; font-size: 0.875rem; max-height: 200px; overflow-y: auto;">${data.data.response}</div>
                        </div>
                    `;
                    // 刷新父页面以更新列表的“连通性”状态徽章
                    try { if (window.parent && window.parent !== window) { window.parent.location.reload(); } } catch (e) {}
                } else {
                    resultContent.innerHTML = `
                        <div class="alert alert-danger py-1 px-2 mb-2">
                            <small><strong><?= __("失败") ?>!</strong> ${data.message}</small>
                        </div>
                        ${data.error ? `<div class="alert alert-warning py-1 px-2 mb-0"><small>${data.error}</small></div>` : ''}
                    `;
                }
                
                resultDiv.style.display = 'block';
                
                // 滚动到结果区域
                resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            })
            .catch(error => {
                // 恢复按钮状态
                testModelBtn.disabled = false;
                testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __("测试模型") ?>';
                
                // 显示错误
                const resultDiv = document.getElementById('testResult');
                const resultContent = document.getElementById('testResultContent');
                
                resultContent.innerHTML = `
                    <div class="alert alert-danger py-1 px-2">
                        <small><strong><?= __("网络错误") ?>!</strong> ${error.message}</small>
                    </div>
                `;
                
                resultDiv.style.display = 'block';
            });
        });
    }
    
    // 切换测试面板
    const toggleTestPanel = document.getElementById('toggleTestPanel');
    const testModelPanel = document.getElementById('testModelPanel');
    const closeTestPanel = document.getElementById('closeTestPanel');
    
    if (toggleTestPanel && testModelPanel) {
        toggleTestPanel.addEventListener('click', function() {
            testModelPanel.style.display = testModelPanel.style.display === 'none' ? 'block' : 'none';
        });
    }
    
    if (closeTestPanel && testModelPanel) {
        closeTestPanel.addEventListener('click', function() {
            testModelPanel.style.display = 'none';
        });
    }
    <?php endif; ?>
});

// 切换提供商配置手风琴
function toggleProviderConfig() {
    const body = document.getElementById('providerConfigBody');
    const icon = document.getElementById('providerConfigIcon');
    
    if (body.style.display === 'none') {
        body.style.display = 'block';
        icon.classList.remove('bi-chevron-right');
        icon.classList.add('bi-chevron-down');
        icon.style.transform = 'rotate(0deg)';
    } else {
        body.style.display = 'none';
        icon.classList.remove('bi-chevron-down');
        icon.classList.add('bi-chevron-right');
        icon.style.transform = 'rotate(0deg)';
    }
}
</script>

