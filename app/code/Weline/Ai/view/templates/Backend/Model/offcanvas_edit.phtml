<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';

    var modelConfig = <?= $model ? json_encode($model->getConfig()) : '{}' ?>;

    window.WelineAiModelEdit = {
        toggleProviderConfig: function() {
            var body = document.getElementById('providerConfigBody');
            var icon = document.getElementById('providerConfigIcon');
            
            if (body.style.display === 'none') {
                body.style.display = 'block';
                icon.classList.remove('bi-chevron-right');
                icon.classList.add('bi-chevron-down');
            } else {
                body.style.display = 'none';
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-right');
            }
        },

        init: function() {
            // 设置配置参数的值
            if (modelConfig.temperature !== undefined) {
                document.getElementById('config_temperature').value = modelConfig.temperature;
                document.getElementById('tempValue').textContent = modelConfig.temperature;
            }
            if (modelConfig.top_p !== undefined) {
                document.getElementById('config_top_p').value = modelConfig.top_p;
                document.getElementById('topPValue').textContent = modelConfig.top_p;
            }
            if (modelConfig.timeout !== undefined) {
                var timeoutInput = document.getElementById('config_timeout');
                if (timeoutInput) {
                    timeoutInput.value = modelConfig.timeout;
                }
            }

            this.initForm();
            this.initAccountSelect();
            this.initTestPanel();
        },

        initAccountSelect: function() {
            var supplierVal = document.getElementById('supplier_value');
            var accountSelect = document.getElementById('provider_account_id');
            if (!supplierVal || !accountSelect) return;
            var backendUrl = '<?= addslashes($this->getBackendUrl('*/backend/provider/getAccountsForSelect')) ?>';
            var selectedId = '<?= addslashes($selectedAccountId ?? '') ?>';
            function loadAccounts(providerCode) {
                accountSelect.innerHTML = '<option value=""><?= addslashes(__('使用默认账户')) ?></option>';
                if (!providerCode) return;
                var url = backendUrl + '?provider_code=' + encodeURIComponent(providerCode) + '&limit=100';
                var req = window.Weline.Api.get(url, { silent: true });
                req.then(function(res) {
                    var resp = (res && res.data) || res;
                        var items = (resp && resp.success && resp.data) ? resp.data : (Array.isArray(resp) ? resp : []);
                        items.forEach(function(item) {
                            var opt = document.createElement('option');
                            opt.value = item.value;
                            opt.textContent = item.label;
                            if (item.value === selectedId) opt.selected = true;
                            accountSelect.appendChild(opt);
                        });
                    })
                    .catch(function() {});
            }
            supplierVal.addEventListener('change', function() {
                loadAccounts(this.value || '');
            });
            if (supplierVal.value) loadAccounts(supplierVal.value);
        },

        initForm: function() {
            var form = document.getElementById('modelEditForm');
            if (!form) return;
            
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                var submitBtn = form.querySelector('button[type="submit"]');
                var originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span><?= __('保存中...') ?>';
                
                var apiKeyInput = document.getElementById('api_key_input');
                var providerConfigTextarea = document.getElementById('provider_config_json');
                
                if (apiKeyInput && apiKeyInput.value.trim() && providerConfigTextarea) {
                    try {
                        var config = {};
                        if (providerConfigTextarea.value.trim()) {
                            config = JSON.parse(providerConfigTextarea.value);
                        }
                        config.api_key = apiKeyInput.value.trim();
                        providerConfigTextarea.value = JSON.stringify(config, null, 2);
                    } catch (e) {
                        console.error('同步API密钥到JSON配置失败:', e);
                    }
                }
                
                if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
                    try {
                        JSON.parse(providerConfigTextarea.value);
                    } catch (e) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('格式错误') ?>',
                                text: '<?= __('提供商配置JSON格式错误，请检查语法') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                        return;
                    }
                }
                
                var formData = new FormData(form);
                var opts = { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } };
                var req = window.Weline.Api.request(form.action, opts).then(function(res) { return (res && res.data) || res; });
                req.then(function(data) {
                    if (data.success) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: '<?= __('保存成功') ?>',
                                text: '<?= __('模型已成功保存') ?>',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function() {
                                if (window.parent) {
                                    window.parent.location.reload();
                                } else {
                                    window.location.reload();
                                }
                            });
                        } else {
                            if (window.parent) {
                                window.parent.location.reload();
                            } else {
                                window.location.reload();
                            }
                        }
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: '<?= __('保存失败') ?>',
                                html: (data.message || '<?= __('未知错误') ?>'),
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                    }
                })
                .catch(function(error) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            html: '<?= __('请稍后重试') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    }
                })
                .finally(function() {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
            });
        },

        initTestPanel: function() {
            <?php if ($isEdit): ?>
            var testModelBtn = document.getElementById('testModelBtn');
            var toggleTestPanel = document.getElementById('toggleTestPanel');
            var testModelPanel = document.getElementById('testModelPanel');
            var closeTestPanel = document.getElementById('closeTestPanel');
            
            if (toggleTestPanel && testModelPanel) {
                toggleTestPanel.addEventListener('click', function() {
                    testModelPanel.style.display = testModelPanel.style.display === 'none' ? 'block' : 'none';
                });
            }
            
            if (closeTestPanel && testModelPanel) {
                closeTestPanel.addEventListener('click', function() {
                    testModelPanel.style.display = 'none';
                });
            }
            
            if (testModelBtn) {
                testModelBtn.addEventListener('click', function() {
                    var prompt = document.getElementById('test_prompt').value.trim();
                    var modelCodeInput = document.getElementById('model_code');
                    var modelCode = modelCodeInput ? modelCodeInput.value : '<?= $model ? addslashes($model->getData('model_code')) : '' ?>';
                    var form = document.getElementById('modelEditForm');
                    
                    if (!prompt) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: '<?= __('提示') ?>',
                                text: '<?= __('请输入测试提示词') ?>',
                                confirmButtonText: '<?= __('确定') ?>'
                            });
                        }
                        return;
                    }
                    
                    testModelBtn.disabled = true;
                    testModelBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> <?= __('测试中...') ?>';
                    
                    document.getElementById('testResult').style.display = 'none';

                    var providerConfigTextarea = document.getElementById('provider_config_json');
                    if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
                        try {
                            JSON.parse(providerConfigTextarea.value);
                        } catch (e) {
                            testModelBtn.disabled = false;
                            testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> Test model';
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Invalid JSON',
                                    text: 'Provider config JSON is invalid. Please check the syntax.',
                                    confirmButtonText: 'OK'
                                });
                            }
                            return;
                        }
                    }
                    
                    var formData = form ? new FormData(form) : new FormData();
                    formData.set('model_code', modelCode);
                    formData.set('prompt', prompt);
                    formData.set('test_only', '1');
                    
                    var tcUrl = '<?= $this->getBackendUrl("*/backend/model/testConnection") ?>';
                    var tcReq = window.Weline.Api.request(tcUrl, { method: 'POST', body: formData });
                    tcReq.then(function(res) {
                        var data = (res && res.data) || res;
                        testModelBtn.disabled = false;
                        testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __('测试模型') ?>';
                        
                        var resultDiv = document.getElementById('testResult');
                        var resultContent = document.getElementById('testResultContent');
                        
                        if (data && data.data && data.data.results) {
                            var r = data.data.results;
                            var s = r.self_config || {};
                            var p = r.provider_account || {};
                            var sBadge = s.tested ? (s.success ? '<span class="badge bg-success">成功</span>' : '<span class="badge bg-danger">失败</span>') : '<span class="badge bg-secondary">未测</span>';
                            var pBadge = p.tested ? (p.success ? '<span class="badge bg-success">成功</span>' : '<span class="badge bg-danger">失败</span>') : '<span class="badge bg-secondary">未测</span>';
                            resultContent.innerHTML = '<div class="row g-2"><div class="col-12"><div class="alert alert-' + (s.success ? 'success' : (s.tested ? 'danger' : 'secondary')) + ' py-1 px-2 mb-2"><small class="fw-bold">自配置</small> ' + sBadge + '<br>' + (s.tested ? ('<small class="text-muted">耗时：</small><code>' + (s.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + (s.message || '') + '</div>') : '') + '</div><div class="col-12"><div class="alert alert-' + (p.success ? 'success' : (p.tested ? 'danger' : 'secondary')) + ' py-1 px-2 mb-2"><small class="fw-bold">供应商账户</small> ' + pBadge + (p.account_name ? ' <span class="badge bg-info">' + p.account_name + '</span>' : '') + '<br>' + (p.tested ? ('<small class="text-muted">耗时：</small><code>' + (p.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + (p.message || '') + '</div>') : '') + '</div></div>';
                            try { if (window.parent && window.parent !== window) { window.parent.location.reload(); } } catch (e) {}
                        } else if (data.success) {
                            resultContent.innerHTML = '<div class="alert alert-success py-1 px-2 mb-2"><small><strong>成功!</strong> ' + data.message + '</small></div>';
                            try { if (window.parent && window.parent !== window) { window.parent.location.reload(); } } catch (e) {}
                        } else {
                            resultContent.innerHTML = '<div class="alert alert-danger py-1 px-2 mb-2"><small><strong>失败!</strong> ' + data.message + '</small></div>';
                        }
                        
                        resultDiv.style.display = 'block';
                        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    })
                    .catch(function(error) {
                        testModelBtn.disabled = false;
                        testModelBtn.innerHTML = '<i class="bi bi-play-circle"></i> <?= __('测试模型') ?>';
                        
                        var resultDiv = document.getElementById('testResult');
                        var resultContent = document.getElementById('testResultContent');
                        
                        resultContent.innerHTML = '<div class="alert alert-danger py-1 px-2"><small><strong>网络错误!</strong> ' + error.message + '</small></div>';
                        
                        resultDiv.style.display = 'block';
                    });
                });
            }
            <?php endif; ?>
        }
    };

    document.addEventListener('DOMContentLoaded', function() {
        window.WelineAiModelEdit.init();
    });
})();
</script>
