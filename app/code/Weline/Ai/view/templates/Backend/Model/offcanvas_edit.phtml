 * AI 模型 Offcanvas 编辑模板
 *
 * 用于新建和编辑 AI 模型（在 iframe 中加载）
 *
 * @var \Weline\Ai\Model\AiModel $model
 */

$model = $this->getData('model');
$isEdit = $model && $model->getId();
$title = $isEdit ? __('编辑模型') : __('新建模型');

// 解析配置JSON
$config = [];
if ($isEdit && $model->getConfigJson()) {
    $configJson = $model->getConfigJson();
    $config = is_string($configJson) ? json_decode($configJson, true) : $configJson;
    if (!is_array($config)) {
        $config = [];
    }
}

// 解析提供商配置
$providerConfig = [];
if ($isEdit && $model->getData('provider_config')) {
    $providerConfigData = $model->getData('provider_config');
    $providerConfig = is_string($providerConfigData) ? json_decode($providerConfigData, true) : $providerConfigData;
    if (!is_array($providerConfig)) {
        $providerConfig = [];
    }
}

// 如果没有提供商配置，使用config作为默认值
if (empty($providerConfig) && !empty($config)) {
    $providerConfig = $config;
}
$selectedAccountId = (string)($providerConfig['account_id'] ?? '');
$modelPresetsJson = $this->getData('modelPresetsJson') ?: '[]';
$escapeHtml = static function ($value): string {
    return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
};
$jsonForScriptFlags = JSON_UNESCAPED_UNICODE
    | JSON_UNESCAPED_SLASHES
    | JSON_HEX_TAG
    | JSON_HEX_AMP
    | JSON_HEX_APOS
    | JSON_HEX_QUOT;
$jsonForTextareaFlags = JSON_PRETTY_PRINT | $jsonForScriptFlags;
$modelConfigJson = json_encode($model ? $model->getConfig() : new \stdClass(), $jsonForScriptFlags);
if (!is_string($modelConfigJson)) {
    $modelConfigJson = '{}';
}
$modelCodeJsFallback = json_encode($model ? (string)$model->getData('model_code') : '', $jsonForScriptFlags);
if (!is_string($modelCodeJsFallback)) {
    $modelCodeJsFallback = '""';
}
