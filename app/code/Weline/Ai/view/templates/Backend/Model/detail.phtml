<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';

    window.testConnection = function() {
        BackendConfirm.show('<?= __('确定要测试此模型的连接吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
        var btn = event.target.closest('button');
        btn.disabled = true;
        btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('测试中...') ?>';

        var url = '<?= $this->getBackendUrl('*/backend/model/testConnection') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ model_code: '<?= addslashes((string)$model->getModelCode()) ?>' }) };
        var req = window.Weline.Api.request(url, opts);
        req.then(function(res) {
            var data = (res && res.data) || res;
            var collectImages = function() {
                var collected = [];
                if (data && data.data && data.data.results) {
                    var s = data.data.results.self_config || {};
                    var p = data.data.results.provider_account || {};
                    if (Array.isArray(s.images)) collected = collected.concat(s.images);
                    if (Array.isArray(p.images)) collected = collected.concat(p.images);
                }
                if (Array.isArray(data && data.images)) collected = collected.concat(data.images);
                return collected;
            };
            var renderImagesHtml = function(images) {
                if (!Array.isArray(images) || !images.length) return '';
                var pieces = images.map(function(image) {
                    var src = (image && image.url)
                        ? image.url
                        : (image && image.b64_json ? ('data:' + ((image.mime_type) || 'image/png') + ';base64,' + image.b64_json) : '');
                    if (!src) return '';
                    var safeSrc = String(src).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    return '<a href="' + safeSrc + '" target="_blank" rel="noopener" class="d-inline-block me-2 mb-2">'
                        + '<img src="' + safeSrc + '" class="img-fluid rounded border" style="max-height: 240px; object-fit: contain; background: #fff;" alt="test image">'
                        + '</a>';
                }).join('');
                return pieces ? '<div class="mt-3"><div class="fw-bold mb-2"><i class="mdi mdi-image-multiple me-1"></i><?= __('返回的测试图片') ?></div>' + pieces + '</div>' : '';
            };
            var images = collectImages();
            var summaryParts = [];
            if (data && data.data && data.data.results) {
                var s = data.data.results.self_config || {};
                var p = data.data.results.provider_account || {};
                if (s.tested) summaryParts.push('<?= __('自配置') ?>: ' + (s.success ? '<?= __('成功') ?>' : '<?= __('失败') ?>') + (s.message ? ' (' + s.message + ')' : ''));
                if (p.tested) summaryParts.push('<?= __('供应商账户') ?>: ' + (p.success ? '<?= __('成功') ?>' : '<?= __('失败') ?>') + (p.message ? ' (' + p.message + ')' : ''));
            }
            var summaryHtml = summaryParts.length ? summaryParts.map(function(t) { return '<div>' + t + '</div>'; }).join('') : ((data && data.message) || '');
            if (data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('连接测试成功') ?>',
                        html: summaryHtml + renderImagesHtml(images),
                        confirmButtonText: '<?= __('确定') ?>',
                        width: images.length ? '720px' : '600px'
                    });
                } else {
                    console.log('<?= __('连接测试成功！') ?>\n\n' + summaryParts.join('\n'));
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('连接测试失败') ?>',
                        html: summaryHtml || ((data && data.message) || ''),
                        confirmButtonText: '<?= __('确定') ?>',
                        width: '600px'
                    });
                } else {
                    console.error('<?= __('连接测试失败：') ?>' + (data && data.message));
                }
            }
        })
        .catch(function(err) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: (err && err.message) || '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请求失败：') ?>' + error.message);
            }
        })
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="mdi mdi-connection"></i> <?= __('测试连接') ?>';
        });
        });
    };
})();
</script>
