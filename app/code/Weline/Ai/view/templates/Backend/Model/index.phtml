<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';

    function apiRequest(url, opts) {
        return window.Weline.Api.request(url, opts);
    }

    // 批量选择功能
    window.toggleSelectAll = function() {
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.model-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = selectAll.checked;
        });
        updateBulkActions();
    };

    window.updateBulkActions = function() {
        const checkboxes = document.querySelectorAll('.model-checkbox:checked');
        const count = checkboxes.length;
        const bulkActions = document.getElementById('bulkActions');
        const selectedCount = document.getElementById('selectedCount');
        
        if (count > 0) {
            bulkActions.style.display = 'block';
            selectedCount.textContent = count;
        } else {
            bulkActions.style.display = 'none';
        }
    };

    function getSelectedIds() {
        const checkboxes = document.querySelectorAll('.model-checkbox:checked');
        return Array.from(checkboxes).map(cb => cb.value);
    }

    // 批量激活
    window.bulkActivate = function() {
        const ids = getSelectedIds();
        if (ids.length === 0) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择要激活的模型') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请先选择要激活的模型') ?>');
            }
            return;
        }
        
        BackendConfirm.show('<?= __('确定要激活选中的模型吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            apiRequest('<?= $this->getBackendUrl('*/backend/model/bulkActivate') ?>', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ids: ids})
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    console.log(data.message);
                    location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败：') ?>' + data.message);
                }
            }
        });
        });
    };

    // 批量禁用
    window.bulkDeactivate = function() {
        const ids = getSelectedIds();
        if (ids.length === 0) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择要禁用的模型') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请先选择要禁用的模型') ?>');
            }
            return;
        }
        
        BackendConfirm.show('<?= __('确定要禁用选中的模型吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            apiRequest('<?= $this->getBackendUrl('*/backend/model/bulkDeactivate') ?>', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ids: ids})
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    console.log(data.message);
                    location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败：') ?>' + data.message);
                }
            }
        });
        });
    };

    // 批量删除
    window.bulkDelete = function() {
        const ids = getSelectedIds();
        if (ids.length === 0) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择要删除的模型') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请先选择要删除的模型') ?>');
            }
            return;
        }
        
        BackendConfirm.show('<?= __('确定要删除选中的模型吗？此操作不可恢复！注意：仅复制模型和自定义模型可删除。') ?>').then(function(confirmed) {
            if (!confirmed) return;
            apiRequest('<?= $this->getBackendUrl('*/backend/model/bulkDelete') ?>', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ids: ids})
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    console.log(data.message);
                    location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败：') ?>' + data.message);
                }
            }
        });
        });
    };

    // 批量测试连接
    window.bulkTestConnection = function() {
        const ids = getSelectedIds();
        if (ids.length === 0) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请先选择要测试的模型') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请先选择要测试的模型') ?>');
            }
            return;
        }
        
        var progressModal = createProgressModal();
        progressModal.show();
        
        updateProgress(progressModal, '开始测试 ' + ids.length + ' 个模型...');
        
        apiRequest('<?= $this->getBackendUrl('*/backend/model/batchTestConnection') ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({model_ids: ids})
        })
        .then(function(response) {
            var data = response.data;
            if (response.ok && data && data.success) {
                showTestResults(data.results, data.summary);
                progressModal.hide();
                setTimeout(() => location.reload(), 3000);
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('测试失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('测试失败：') ?>' + data.message);
                }
                progressModal.hide();
            }
        })
        .catch(function(error) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: (error && error.message) || '<?= __('请求失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请求失败：') ?>' + error.message);
            }
            progressModal.hide();
        });
    };

    // 创建进度弹窗
    function createProgressModal() {
        var modalHtml = '<div class="modal fade" id="progressModal" tabindex="-1">' +
            '<div class="modal-dialog modal-dialog-centered">' +
            '<div class="modal-content">' +
            '<div class="modal-body text-center py-4">' +
            '<div class="spinner-border text-primary mb-3" role="status">' +
            '<span class="visually-hidden"><?= __('加载中...') ?></span>' +
            '</div>' +
            '<h5 id="progressText">正在测试...</h5>' +
            '<p class="text-muted mb-0" id="progressDetail">请稍候，正在测试模型连接</p>' +
            '</div></div></div></div>';
        
        var existingModal = document.getElementById('progressModal');
        if (existingModal) {
            existingModal.remove();
        }
        
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        return new bootstrap.Modal(document.getElementById('progressModal'), {
            backdrop: 'static',
            keyboard: false
        });
    }

    // 更新进度文本
    function updateProgress(modal, text, detail) {
        var progressText = document.getElementById('progressText');
        var progressDetail = document.getElementById('progressDetail');
        if (progressText) progressText.textContent = text;
        if (progressDetail) progressDetail.textContent = detail || '';
    }

    // 显示测试结果
    function showTestResults(results, summary) {
        var resultHtml = '<div class="modal fade" id="testResultModal" tabindex="-1">' +
            '<div class="modal-dialog modal-lg modal-dialog-centered">' +
            '<div class="modal-content">' +
            '<div class="modal-header">' +
            '<h5 class="modal-title">批量测试结果</h5>' +
            '<button type="button" class="btn-close" data-bs-dismiss="modal"></button>' +
            '</div>' +
            '<div class="modal-body">' +
            '<div class="alert alert-info mb-3">' +
            '<strong>测试统计：</strong> 总计 ' + summary.total + ' 个，成功 <span class="text-success">' + summary.success + '</span> 个，失败 <span class="text-danger">' + summary.failed + '</span> 个' +
            '</div>' +
            '<div class="table-responsive">' +
            '<table class="table table-sm"><thead><tr><th>模型</th><th>状态</th><th>消息</th><th>耗时</th></tr></thead><tbody>';
        
        results.forEach(function(result) {
            var statusClass = result.success ? 'success' : 'danger';
            var statusText = result.success ? '成功' : '失败';
            var duration = result.duration ? (result.duration + 'ms') : '-';
            
            resultHtml += '<tr>' +
                '<td>' + (result.model_name || result.model_code) + '</td>' +
                '<td><span class="badge bg-' + statusClass + '">' + statusText + '</span></td>' +
                '<td>' + result.message + '</td>' +
                '<td>' + duration + '</td>' +
                '</tr>';
        });
        
        resultHtml += '</tbody></table></div></div>' +
            '<div class="modal-footer">' +
            '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>' +
            '</div></div></div></div>';
        
        var existingModal = document.getElementById('testResultModal');
        if (existingModal) {
            existingModal.remove();
        }
        
        document.body.insertAdjacentHTML('beforeend', resultHtml);
        var resultModal = new bootstrap.Modal(document.getElementById('testResultModal'));
        resultModal.show();
    }

    // 删除单个模型
    window.deleteModel = function(modelId, modelCode, canDelete) {
        if (!canDelete) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('受保护模型不能删除，只能删除复制模型或自定义模型') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('受保护模型不能删除，只能删除复制模型或自定义模型') ?>');
            }
            return;
        }
        
        BackendConfirm.show('<?= __('确定要删除模型') ?> ' + modelCode + ' <?= __('吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            apiRequest('<?= $this->getBackendUrl('*/backend/model/delete') ?>?id=' + modelId, {
                method: 'DELETE',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json'
                }
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: data.message || '<?= __('删除成功') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => window.location.reload());
                } else {
                    console.log(data.message || '<?= __('删除成功') ?>');
                    window.location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('删除失败') ?>',
                        text: data.message || '<?= __('删除失败') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error(data.message || '<?= __('删除失败') ?>');
                }
            }
        })
        .catch(error => {
            console.error('<?= __('删除失败:') ?>', error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('错误') ?>',
                    text: '<?= __('删除失败，请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('删除失败，请重试') ?>');
            }
        });
        });
    };

    window.toggleStatusByCode = function(modelCode) {
        apiRequest('<?= $this->getBackendUrl('*/backend/model/toggleStatus') ?>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'model_code=' + encodeURIComponent(modelCode)
        })
        .then(function(response) {
            var data = response.data;
            if (response.ok && data && data.success) {
                location.reload();
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败：') ?>' + data.message);
                }
            }
        });
    };

    window.applyFilters = function() {
        var vendor = document.getElementById('vendorFilter').value;
        var status = document.getElementById('statusFilter').value;
        var search = document.getElementById('searchInput').value;

        var params = new URLSearchParams();
        if (vendor) params.append('vendor', vendor);
        if (status) params.append('status', status);
        if (search) params.append('search', search);

        window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>?' + params.toString();
    };

    window.resetFilters = function() {
        window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>';
    };

    window.goPage = function(page) {
        var vendor = document.getElementById('vendorFilter').value;
        var status = document.getElementById('statusFilter').value;
        var search = document.getElementById('searchInput').value;
        var params = new URLSearchParams();
        if (vendor) params.append('vendor', vendor);
        if (status) params.append('status', status);
        if (search) params.append('search', search);
        params.append('page', String(page || 1));
        window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>?' + params.toString();
    };

    // 测试模型连通性
    window.testModelConnection = function(modelCode, trigger) {
        if (!modelCode) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('模型代码不能为空') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('模型代码不能为空') ?>');
            }
            return;
        }
        
        var btn = trigger || (window.event && window.event.target ? window.event.target.closest('button') : null);
        var originalHtml = btn ? btn.innerHTML : '';
        if (btn) {
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
            btn.disabled = true;
        }
        
        var testModal = createTestModal();
        document.body.appendChild(testModal);
        
        apiRequest('<?= $this->getBackendUrl('*/backend/model/testConnection') ?>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ model_code: modelCode })
        })
        .then(function(response) {
            var data = response.data;
            if (btn) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
            document.body.removeChild(testModal);
            
            if (data && data.data && data.data.results) {
                var r = data.data.results;
                var s = r.self_config || {};
                var p = r.provider_account || {};
                var sStatus = s.tested ? (s.success ? '<span class="badge bg-success">成功</span>' : '<span class="badge bg-danger">失败</span>') : '<span class="badge bg-secondary">未测</span>';
                var pStatus = p.tested ? (p.success ? '<span class="badge bg-success">成功</span>' : '<span class="badge bg-danger">失败</span>') : '<span class="badge bg-secondary">未测</span>';
                var html = '自配置结果：' + sStatus + '\n' +
                    (s.tested ? '消息：' + (s.message || '') + '\n耗时：' + (s.duration || 0) + 'ms\n响应：' + ((s.response || '').toString().slice(0,500)) + '\n\n' : '\n') +
                    '供应商账户结果：' + pStatus + '\n' +
                    (p.tested ? '消息：' + (p.message || '') + '\n耗时：' + (p.duration || 0) + 'ms\n账户：' + (p.account_name || '') + '\n响应：' + ((p.response || '').toString().slice(0,500)) : '');
                var __ok = !!data.success;
                var __retryName = null;
                if (!__ok) {
                    __retryName = '__retry_test_' + Date.now();
                    window[__retryName] = function() { testModelConnection(modelCode); };
                }
                var images = [];
                if (Array.isArray(s.images)) images = images.concat(s.images);
                if (Array.isArray(p.images)) images = images.concat(p.images);
                showResultModal(__ok ? 'success' : 'error', '连通测试结果', html, __ok, __retryName, null, images);
            } else if (data.success) {
                var images2 = Array.isArray(data.images) ? data.images : [];
                showResultModal('success', '连通测试成功', data.message || '', true, null, null, images2);
            } else {
                var fnName = '__retry_test_' + Date.now();
                window[fnName] = function() { testModelConnection(modelCode); };
                showResultModal('error', '连通测试失败', data.message, false, fnName);
            }
        })
        .catch(error => {
            if (btn) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
            document.body.removeChild(testModal);
            
            console.error('<?= __('错误：') ?>', error);
            var fnName = '__retry_test_' + Date.now();
            window[fnName] = function() { testModelConnection(modelCode); };
            showResultModal('error', '连通测试失败', '<?= __('测试失败: 网络错误') ?>', false, fnName);
        });
    };

    // 测试自配置连通性
    window.testSelfConfigConnection = function(modelCode, trigger) {
        if (!modelCode) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('模型代码不能为空') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('模型代码不能为空') ?>');
            }
            return;
        }
        
        var btn = trigger || (window.event && window.event.target ? window.event.target.closest('button') : null);
        var originalHtml = btn ? btn.innerHTML : '';
        if (btn) {
            btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i>';
            btn.disabled = true;
        }
        
        var testModal = createTestModal();
        document.body.appendChild(testModal);
        
        apiRequest('<?= $this->getBackendUrl('*/backend/model/testSelfConfig') ?>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ model_code: modelCode })
        })
        .then(function(response) {
            var data = response.data;
            if (btn) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
            document.body.removeChild(testModal);
            
            if (data.success) {
                var message = data.data ?
                    data.message + '\n\n响应时间: ' + data.data.duration + 'ms\n响应内容: ' + data.data.response :
                    data.message;
                var imagesSelf = (data.data && Array.isArray(data.data.images)) ? data.data.images : (Array.isArray(data.images) ? data.images : []);
                showResultModal('success', '自配置连通测试成功', message, true, null, null, imagesSelf);
            } else {
                var fnName = '__retry_self_' + Date.now();
                window[fnName] = function() { testSelfConfigConnection(modelCode); };
                showResultModal('error', '自配置连通测试失败', data.message, false, fnName);
            }
        })
        .catch(error => {
            if (btn) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
            document.body.removeChild(testModal);
            
            console.error('<?= __('错误：') ?>', error);
            var fnName = '__retry_self_' + Date.now();
            window[fnName] = function() { testSelfConfigConnection(modelCode); };
            showResultModal('error', '自配置连通测试失败', '<?= __('测试失败: 网络错误') ?>', false, fnName);
        });
    };

    // 创建测试中弹窗
    function createTestModal() {
        var modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
        modal.innerHTML = '<div class="modal-dialog modal-dialog-centered">' +
            '<div class="modal-content">' +
            '<div class="modal-body text-center">' +
            '<div class="spinner-border text-primary mb-3" role="status">' +
            '<span class="visually-hidden"><?= __('加载中...') ?></span>' +
            '</div>' +
            '<h5>正在测试连通性...</h5>' +
            '<p class="text-muted">请稍候，正在连接AI服务</p>' +
            '</div></div></div>';
        return modal;
    }

    function escapeHtmlForResult(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function renderTestImagesBlock(images) {
        if (!Array.isArray(images) || images.length === 0) {
            return '';
        }
        var items = images.map(function(image) {
            var src = (image && image.url)
                ? image.url
                : (image && image.b64_json ? ('data:' + ((image.mime_type) || 'image/png') + ';base64,' + image.b64_json) : '');
            if (!src) return '';
            var safeSrc = escapeHtmlForResult(src);
            var revised = image && image.revised_prompt ? '<div class="small text-muted mt-1">' + escapeHtmlForResult(image.revised_prompt) + '</div>' : '';
            return '<div class="col-12 col-md-6 mb-2">'
                + '<a href="' + safeSrc + '" target="_blank" rel="noopener">'
                + '<img src="' + safeSrc + '" class="img-fluid rounded border" style="max-height: 280px; width: 100%; object-fit: contain; background: #fff;" alt="<?= __('测试图片') ?>">'
                + '</a>' + revised + '</div>';
        }).join('');
        if (!items) return '';
        return '<div class="row g-2 mt-3">'
            + '<div class="col-12 fw-bold mb-1"><i class="mdi mdi-image-multiple me-1"></i><?= __('返回的测试图片') ?></div>'
            + items
            + '</div>';
    }

    // 显示结果弹窗
    function showResultModal(type, title, message, refreshOnClose, retryFnName, retryLabel, images) {
        retryLabel = retryLabel || '<?= __('重试') ?>';
        var modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
        if (refreshOnClose) {
            modal.setAttribute('data-refresh-on-close', '1');
        }
        var uid = 'retryBtn_' + Date.now();
        var retryButtonHtml = retryFnName ? '<button type="button" class="btn btn-outline-primary" id="' + uid + '">' + retryLabel + '</button>' : '';
        var imagesHtml = renderTestImagesBlock(images);
        var dialogClass = imagesHtml !== '' ? 'modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable' : 'modal-dialog modal-dialog-centered';
        modal.innerHTML = '<div class="' + dialogClass + '">' +
            '<div class="modal-content">' +
            '<div class="modal-header">' +
            '<h5 class="modal-title">' +
            '<i class="mdi mdi-' + (type === 'success' ? 'check-circle text-success' : 'alert-circle text-danger') + '"></i> ' + title +
            '</h5>' +
            '<button type="button" class="btn-close" data-model-action="close-result-modal"></button>' +
            '</div>' +
            '<div class="modal-body">' +
            '<pre style="white-space: pre-wrap; font-size: 14px;">' + message + '</pre>' +
            imagesHtml +
            '</div>' +
            '<div class="modal-footer">' +
            retryButtonHtml +
            '<button type="button" class="btn btn-primary" data-model-action="close-result-modal"><?= __('确定') ?></button>' +
            '</div></div></div>';
        document.body.appendChild(modal);
        if (retryFnName && typeof window[retryFnName] === 'function') {
            var btn = modal.querySelector('#' + uid);
            if (btn) {
                btn.addEventListener('click', function() {
                    try { window[retryFnName](); } catch (e) {}
                    closeResultModal(btn);
                });
            }
        }
    }

    // 关闭结果弹窗
    window.closeResultModal = function(btn) {
        var modal = btn.closest('.modal');
        var shouldRefresh = modal && modal.getAttribute('data-refresh-on-close') === '1';
        document.body.removeChild(modal);
        if (shouldRefresh) {
            window.location.reload();
        }
    };

    window.showActivateBlocked = function(btn) {
        try {
            var reason = btn.getAttribute('data-reason') || '<?= __('条件不足') ?>';
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('无法激活') ?>',
                    text: reason,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('无法激活: ') ?>' + reason);
            }
        } catch (e) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('无法激活') ?>',
                    text: '<?= __('条件不足') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('无法激活') ?>');
            }
        }
    };
    function readModelInt(trigger, name, fallback) {
        var value = parseInt(trigger.getAttribute(name) || '', 10);
        return Number.isNaN(value) ? fallback : value;
    }

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-model-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();

        var action = trigger.getAttribute('data-model-action') || '';
        var modelCode = trigger.getAttribute('data-model-code') || '';
        var modelId = readModelInt(trigger, 'data-model-id', 0);
        var page = readModelInt(trigger, 'data-page', 1);

        switch (action) {
            case 'bulk-test':
                window.bulkTestConnection();
                break;
            case 'bulk-activate':
                window.bulkActivate();
                break;
            case 'bulk-deactivate':
                window.bulkDeactivate();
                break;
            case 'bulk-delete':
                window.bulkDelete();
                break;
            case 'reset-filters':
                window.resetFilters();
                break;
            case 'test-provider':
                window.testModelConnection(modelCode, trigger);
                break;
            case 'test-self':
                window.testSelfConfigConnection(modelCode, trigger);
                break;
            case 'toggle-status':
                window.toggleStatusByCode(modelCode);
                break;
            case 'show-activate-blocked':
                window.showActivateBlocked(trigger);
                break;
            case 'delete':
                window.deleteModel(modelId, modelCode, trigger.getAttribute('data-can-delete') === '1');
                break;
            case 'page':
                window.goPage(page);
                break;
            case 'close-result-modal':
                window.closeResultModal(trigger);
                break;
        }
    });

    document.addEventListener('change', function(event) {
        var trigger = event.target.closest('[data-model-change]');
        if (trigger && (trigger.getAttribute('data-model-change') || '') === 'select-all') {
            window.toggleSelectAll();
            return;
        }
        if (event.target && event.target.classList && event.target.classList.contains('model-checkbox')) {
            window.updateBulkActions();
        }
    });

    var filterForm = document.getElementById('filterForm');
    if (filterForm) {
        filterForm.addEventListener('submit', function(event) {
            event.preventDefault();
            window.applyFilters();
        });
    }
})();
</script>
