<script>
// 批量选择功能
function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.model-checkbox');
    checkboxes.forEach(cb => {
        cb.checked = selectAll.checked;
    });
    updateBulkActions();
}

function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.model-checkbox:checked');
    const count = checkboxes.length;
    const bulkActions = document.getElementById('bulkActions');
    const selectedCount = document.getElementById('selectedCount');
    
    if (count > 0) {
        bulkActions.style.display = 'block';
        selectedCount.textContent = count;
    } else {
        bulkActions.style.display = 'none';
    }
}

function getSelectedIds() {
    const checkboxes = document.querySelectorAll('.model-checkbox:checked');
    return Array.from(checkboxes).map(cb => cb.value);
}

// 批量激活
function bulkActivate() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要激活的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要激活选中的 {count} 个模型吗？', ['count' => "' + ids.length + '"]) ?>'.replace('{count}', ids.length))) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkActivate') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 批量禁用
function bulkDeactivate() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要禁用的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要禁用选中的模型吗？') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkDeactivate') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 批量删除
function bulkDelete() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要删除的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要删除选中的模型吗？此操作不可恢复！\n注意：只能删除复制的模型，原始模型无法删除。') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkDelete') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 批量测试连接
function bulkTestConnection() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要测试的模型') ?>');
        return;
    }
    
    // 创建进度弹窗
    const progressModal = createProgressModal();
    progressModal.show();
    
    // 更新进度文本
    updateProgress(progressModal, `开始测试 ${ids.length} 个模型...`);
    
    fetch('<?= $this->getBackendUrl('*/backend/model/batchTestConnection') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({model_ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 显示测试结果
            showTestResults(data.results, data.summary);
            progressModal.hide();
            
            // 刷新页面以更新连接状态
            setTimeout(() => location.reload(), 3000);
        } else {
            alert('<?= __('测试失败：') ?>' + data.message);
            progressModal.hide();
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
        progressModal.hide();
    });
}

// 创建进度弹窗
function createProgressModal() {
    const modalHtml = `
        <div class="modal fade" id="progressModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center py-4">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h5 id="progressText">正在测试...</h5>
                        <p class="text-muted mb-0" id="progressDetail">请稍候，正在测试模型连接</p>
                    </div>
                </div>
            </div>
        </div>
    `;
    
    // 如果已存在则移除
    const existingModal = document.getElementById('progressModal');
    if (existingModal) {
        existingModal.remove();
    }
    
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    return new bootstrap.Modal(document.getElementById('progressModal'), {
        backdrop: 'static',
        keyboard: false
    });
}

// 更新进度文本
function updateProgress(modal, text, detail = '') {
    const progressText = document.getElementById('progressText');
    const progressDetail = document.getElementById('progressDetail');
    if (progressText) progressText.textContent = text;
    if (progressDetail) progressDetail.textContent = detail;
}

// 显示测试结果
function showTestResults(results, summary) {
    let resultHtml = `
        <div class="modal fade" id="testResultModal" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">批量测试结果</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info mb-3">
                            <strong>测试统计：</strong>
                            总计 ${summary.total} 个，
                            成功 <span class="text-success">${summary.success}</span> 个，
                            失败 <span class="text-danger">${summary.failed}</span> 个
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>模型</th>
                                        <th>状态</th>
                                        <th>消息</th>
                                        <th>耗时</th>
                                    </tr>
                                </thead>
                                <tbody>`;
    
    results.forEach(result => {
        const statusClass = result.success ? 'success' : 'danger';
        const statusText = result.success ? '成功' : '失败';
        const duration = result.duration ? `${result.duration}ms` : '-';
        
        resultHtml += `
            <tr>
                <td>${result.model_name || result.model_code}</td>
                <td><span class="badge bg-${statusClass}">${statusText}</span></td>
                <td>${result.message}</td>
                <td>${duration}</td>
            </tr>`;
    });
    
    resultHtml += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>
                    </div>
                </div>
            </div>
        </div>`;
    
    // 如果已存在则移除
    const existingModal = document.getElementById('testResultModal');
    if (existingModal) {
        existingModal.remove();
    }
    
    document.body.insertAdjacentHTML('beforeend', resultHtml);
    const resultModal = new bootstrap.Modal(document.getElementById('testResultModal'));
    resultModal.show();
}

// 清空模型表
function clearAllModels() {
    // 第一次确认 - 使用更醒目的提示
    const firstConfirm = confirm('<?= __('🚨 危险操作警告！') ?>\n\n' +
        '<?= __('您即将执行以下操作：') ?>\n' +
        '• <?= __('删除所有AI模型数据') ?>\n' +
        '• <?= __('包括原始模型和复制模型') ?>\n' +
        '• <?= __('包括所有配置和测试记录') ?>\n' +
        '• <?= __('此操作不可恢复！') ?>\n\n' +
        '<?= __('确定要继续吗？') ?>');
    
    if (!firstConfirm) {
        return;
    }
    
    // 第二次确认 - 输入确认文本
    const confirmText = prompt('<?= __('⚠️ 最终确认') ?>\n\n' +
        '<?= __('为了确保您了解此操作的严重性，') ?>\n' +
        '<?= __('请输入以下文本以确认：') ?>\n\n' +
        'CLEAR ALL MODELS\n\n' +
        '<?= __('（区分大小写）') ?>');
    
    if (confirmText !== 'CLEAR ALL MODELS') {
        alert('<?= __('❌ 确认文本不正确，操作已取消') ?>\n\n' +
            '<?= __('请确保输入：') ?>CLEAR ALL MODELS\n' +
            '<?= __('（区分大小写）') ?>');
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/clearAll') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

function collectModels() {
    const btn = event.target.closest('button');
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('收集中...') ?>';

    fetch('<?= $this->getBackendUrl('*/backend/model/collect') ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('收集成功！') ?>\n' + data.message);
            location.reload();
        } else {
            alert('<?= __('收集失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    })
    .finally(() => {
        btn.disabled = false;
        btn.innerHTML = '<i class="mdi mdi-download"></i> <?= __('收集模型') ?>';
    });
}

function toggleStatusByCode(modelCode) {
    fetch('<?= $this->getBackendUrl('*/backend/model/toggleStatus') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'model_code=' + encodeURIComponent(modelCode)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

function deleteModel(modelId, modelCode, isCopied) {
    if (!isCopied) {
        alert('<?= __('原始模型不能删除，只能删除复制的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要删除模型') ?> ' + modelCode + ' <?= __('吗？') ?>')) {
        return;
    }

    // 使用 fetch 发送 DELETE 请求
    fetch('<?= $this->getBackendUrl('*/backend/model/delete') ?>?id=' + modelId, {
        method: 'DELETE',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 删除成功，刷新页面
            alert(data.message || '<?= __('删除成功') ?>');
            window.location.reload();
        } else {
            // 删除失败，显示错误消息
            alert(data.message || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('删除失败:', error);
        alert('<?= __('删除失败，请重试') ?>');
    });
}

function applyFilters() {
    const vendor = document.getElementById('vendorFilter').value;
    const status = document.getElementById('statusFilter').value;
    const search = document.getElementById('searchInput').value;

    const params = new URLSearchParams();
    if (vendor) params.append('vendor', vendor);
    if (status) params.append('status', status);
    if (search) params.append('search', search);

    window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>?' + params.toString();
}

function resetFilters() {
    window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>';
}
