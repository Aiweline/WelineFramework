<script>
// 批量选择功能
function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.model-checkbox');
    checkboxes.forEach(cb => {
        cb.checked = selectAll.checked;
    });
    updateBulkActions();
}

function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.model-checkbox:checked');
    const count = checkboxes.length;
    const bulkActions = document.getElementById('bulkActions');
    const selectedCount = document.getElementById('selectedCount');
    
    if (count > 0) {
        bulkActions.style.display = 'block';
        selectedCount.textContent = count;
    } else {
        bulkActions.style.display = 'none';
    }
}

function getSelectedIds() {
    const checkboxes = document.querySelectorAll('.model-checkbox:checked');
    return Array.from(checkboxes).map(cb => cb.value);
}

// 批量激活
function bulkActivate() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要激活的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要激活选中的 {count} 个模型吗？', ['count' => "' + ids.length + '"]) ?>'.replace('{count}', ids.length))) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkActivate') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 批量禁用
function bulkDeactivate() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要禁用的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要禁用选中的模型吗？') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkDeactivate') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 批量删除
function bulkDelete() {
    const ids = getSelectedIds();
    if (ids.length === 0) {
        alert('<?= __('请先选择要删除的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要删除选中的模型吗？此操作不可恢复！\n注意：只能删除复制的模型，原始模型无法删除。') ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/bulkDelete') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ids: ids})
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

// 清空模型表
function clearAllModels() {
    if (!confirm('<?= __('⚠️ 危险操作！\n\n确定要清空所有模型吗？\n这将删除所有模型数据，包括原始模型和复制模型！\n此操作不可恢复！\n\n请再次确认！') ?>')) {
        return;
    }
    
    const confirmText = prompt('<?= __('请输入 "CLEAR ALL MODELS" 以确认清空操作：') ?>');
    if (confirmText !== 'CLEAR ALL MODELS') {
        alert('<?= __('确认文本不正确，操作已取消') ?>');
        return;
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/model/clearAll') ?>', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

function collectModels() {
    const btn = event.target.closest('button');
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('收集中...') ?>';

    fetch('<?= $this->getBackendUrl('*/backend/model/collect') ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('收集成功！') ?>\n' + data.message);
            location.reload();
        } else {
            alert('<?= __('收集失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    })
    .finally(() => {
        btn.disabled = false;
        btn.innerHTML = '<i class="mdi mdi-download"></i> <?= __('收集模型') ?>';
    });
}

function toggleStatus(modelId) {
    fetch('<?= $this->getBackendUrl('*/backend/model/toggleStatus') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + modelId
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('<?= __('操作失败：') ?>' + data.message);
        }
    });
}

function deleteModel(modelId, modelCode, isCopied) {
    if (!isCopied) {
        alert('<?= __('原始模型不能删除，只能删除复制的模型') ?>');
        return;
    }
    
    if (!confirm('<?= __('确定要删除模型') ?> ' + modelCode + ' <?= __('吗？') ?>')) {
        return;
    }

    // 使用 fetch 发送 DELETE 请求
    fetch('<?= $this->getBackendUrl('*/backend/model/delete') ?>?id=' + modelId, {
        method: 'DELETE',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // 删除成功，刷新页面
            alert(data.message || '<?= __('删除成功') ?>');
            window.location.reload();
        } else {
            // 删除失败，显示错误消息
            alert(data.message || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('删除失败:', error);
        alert('<?= __('删除失败，请重试') ?>');
    });
}

function applyFilters() {
    const vendor = document.getElementById('vendorFilter').value;
    const status = document.getElementById('statusFilter').value;
    const search = document.getElementById('searchInput').value;

    const params = new URLSearchParams();
    if (vendor) params.append('vendor', vendor);
    if (status) params.append('status', status);
    if (search) params.append('search', search);

    window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>?' + params.toString();
}

function resetFilters() {
    window.location.href = '<?= $this->getBackendUrl('*/backend/model') ?>';
}
</script>

