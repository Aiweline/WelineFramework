<script>
function collectModels() {
    if (confirm('确定要收集AI模型配置吗？')) {
        fetch('<?= $this->getBackendUrl('*/backend/model/collect') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('模型收集成功！');
                location.reload();
            } else {
                alert('模型收集失败：' + (data.message || '未知错误'));
            }
        })
        .catch(error => {
            alert('请求失败：' + error.message);
        });
    }
}

function toggleStatus(modelId) {
    if (confirm('确定要切换模型状态吗？')) {
        fetch('<?= $this->getBackendUrl('*/backend/model/toggleStatus') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({id: modelId})
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('状态切换成功！');
                location.reload();
            } else {
                alert('状态切换失败：' + (data.message || '未知错误'));
            }
        })
        .catch(error => {
            alert('请求失败：' + error.message);
        });
    }
}

function setDefault(modelId) {
    if (confirm('确定要设置为默认模型吗？')) {
        fetch('<?= $this->getBackendUrl('*/backend/model/setDefault') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({id: modelId})
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('默认模型设置成功！');
                location.reload();
            } else {
                alert('设置失败：' + (data.message || '未知错误'));
            }
        })
        .catch(error => {
            alert('请求失败：' + error.message);
        });
    }
}
</script>

