<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';
    
    document.getElementById('model-form').addEventListener('submit', function(e) {
        var vendor = document.getElementById('vendor').value.trim();
        var modelCode = document.getElementById('model_code').value.trim();
        var modelName = document.getElementById('model_name').value.trim();
        
        if (!vendor || !modelCode || !modelName) {
            e.preventDefault();
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请填写必填项：供应商、模型代码、模型名称') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请填写必填项：供应商、模型代码、模型名称') ?>');
            }
            return false;
        }
        
        var providerConfigTextarea = document.getElementById('provider_config_json');
        if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
            try {
                JSON.parse(providerConfigTextarea.value);
            } catch (err) {
                e.preventDefault();
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('格式错误') ?>',
                        text: '<?= __('提供商配置JSON格式错误，请检查语法') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('提供商配置JSON格式错误，请检查语法') ?>');
                }
                providerConfigTextarea.focus();
                return false;
            }
        }
        
        return true;
    });
    
    <?php if ($isEdit): ?>
    var testModelBtn = document.getElementById('testModelBtn');
    testModelBtn.addEventListener('click', function() {
        var prompt = document.getElementById('test_prompt').value.trim();
        var modelId = <?= $model->getId() ?>;
        
        if (!prompt) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请输入测试提示词') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请输入测试提示词') ?>');
            }
            return;
        }
        
        testModelBtn.disabled = true;
        testModelBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('测试中...') ?>';
        
        document.getElementById('testResult').style.display = 'none';
        
        var formData = new FormData();
        formData.append('id', modelId);
        formData.append('prompt', prompt);
        
        var tcUrl = '<?= $this->getBackendUrl("*/backend/model/testConnection") ?>';
        var tcReq = window.Weline.Api.request(tcUrl, { method: 'POST', body: formData });
        tcReq.then(function(res) {
            var data = (res && res.data) || res;
            testModelBtn.disabled = false;
            testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> <?= __('测试模型') ?>';
            
            var resultDiv = document.getElementById('testResult');
            var resultContent = document.getElementById('testResultContent');
            
            if (data && data.data && data.data.results) {
                var r = data.data.results;
                var s = r.self_config || {};
                var p = r.provider_account || {};
                var sBadge = s.tested ? (s.success ? '<span class="badge bg-success"><?= __('成功') ?></span>' : '<span class="badge bg-danger"><?= __('失败') ?></span>') : '<span class="badge bg-secondary"><?= __('未测') ?></span>';
                var pBadge = p.tested ? (p.success ? '<span class="badge bg-success"><?= __('成功') ?></span>' : '<span class="badge bg-danger"><?= __('失败') ?></span>') : '<span class="badge bg-secondary"><?= __('未测') ?></span>';
                resultContent.innerHTML = '<div class="row g-2"><div class="col-12"><div class="alert alert-' + (s.success ? 'success' : (s.tested ? 'danger' : 'secondary')) + ' py-2 px-3 mb-2"><strong>自配置</strong> ' + sBadge + '<br>' + (s.tested ? ('<small class="text-muted">耗时：</small><code>' + (s.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + (s.message || '') + '<br><div class="alert alert-light mb-0" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">' + (s.response || '') + '</div>') : '') + '</div></div><div class="col-12"><div class="alert alert-' + (p.success ? 'success' : (p.tested ? 'danger' : 'secondary')) + ' py-2 px-3 mb-2"><strong>供应商账户</strong> ' + pBadge + (p.account_name ? ' <span class="badge bg-info">' + p.account_name + '</span>' : '') + '<br>' + (p.tested ? ('<small class="text-muted">耗时：</small><code>' + (p.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + (p.message || '') + '<br><div class="alert alert-light mb-0" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">' + (p.response || '') + '</div>') : '') + '</div></div></div>';
            } else if (data.success) {
                resultContent.innerHTML = '<div class="alert alert-success"><strong><?= __('测试成功') ?>!</strong> ' + data.message + '</div>';
            } else {
                resultContent.innerHTML = '<div class="alert alert-danger"><strong><?= __('测试失败') ?>!</strong> ' + data.message + '</div>' + (data.error ? '<div class="alert alert-warning"><small>' + data.error + '</small></div>' : '');
            }
            
            resultDiv.style.display = 'block';
            resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        })
        .catch(function(error) {
            testModelBtn.disabled = false;
            testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> <?= __('测试模型') ?>';
            
            var resultDiv = document.getElementById('testResult');
            var resultContent = document.getElementById('testResultContent');
            
            resultContent.innerHTML = '<div class="alert alert-danger"><strong><?= __('网络错误') ?>!</strong> ' + error.message + '</div>';
            resultDiv.style.display = 'block';
        });
    });
    <?php endif; ?>
})();
</script>

