use Weline\Ai\Model\AiModel;

$themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);
$model = $this->getData('model');
$isEdit = $model && $model->getId();
$isCopied = $isEdit && $model->isCopied();
$isReadonly = $isEdit && !$isCopied; // 只有原始模型（非复制）才只读
$pageTitle = $isEdit ? __('编辑模型: %{1}', $model->getModelName()) : __('新建模型');

// 解析配置JSON
$config = [];
if ($isEdit && $model->getConfigJson()) {
    $configJson = $model->getConfigJson();
    $config = is_string($configJson) ? json_decode($configJson, true) : $configJson;
    if (!is_array($config)) {
        $config = [];
    }
}

// 解析代理信息
$proxyInfo = [];
if ($isEdit && $model->getProxyInfo()) {
    $proxyInfoData = $model->getProxyInfo();
    $proxyInfo = is_string($proxyInfoData) ? json_decode($proxyInfoData, true) : $proxyInfoData;
    if (!is_array($proxyInfo)) {
        $proxyInfo = [];
    }
}

// 解析提供商配置
$providerConfig = [];
if ($isEdit && $model->getData('provider_config')) {
    $providerConfigData = $model->getData('provider_config');
    $providerConfig = is_string($providerConfigData) ? json_decode($providerConfigData, true) : $providerConfigData;
    if (!is_array($providerConfig)) {
        $providerConfig = [];
    }
}

// 如果没有提供商配置，使用config作为默认值
if (empty($providerConfig) && !empty($config)) {
    $providerConfig = $config;
}
