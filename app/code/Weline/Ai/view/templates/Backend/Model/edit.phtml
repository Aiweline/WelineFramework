<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';

    var commonModelPresets = <?= $modelPresetsJson ?>;

    function setFieldValue(id, value) {
        var element = document.getElementById(id);
        if (!element) return;
        element.value = value === undefined || value === null ? '' : value;
        element.dispatchEvent(new Event('input', { bubbles: true }));
        element.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function setCheckboxValue(id, checked) {
        var element = document.getElementById(id);
        if (!element) return;
        element.checked = !!checked;
    }

    function applyPreset(preset) {
        if (!preset) return;

        var config = Object.assign({}, preset.config || {});
        setFieldValue('vendor', preset.provider || '');
        setFieldValue('model_code', preset.model_code || '');
        setFieldValue('provider_model_code', preset.provider_model_code || preset.model_code || '');
        setFieldValue('model_name', preset.name || preset.model_code || '');
        setFieldValue('model_version', preset.version || '1.0');
        setFieldValue('api_url', config.base_url || '');
        setFieldValue('max_tokens', preset.max_tokens || config.max_tokens || 4096);
        setFieldValue('record_max_tokens', preset.max_tokens || config.max_tokens || 4096);
        setFieldValue('temperature', preset.temperature !== undefined ? preset.temperature : (config.temperature || 0.7));
        setFieldValue('top_p', preset.top_p !== undefined ? preset.top_p : (config.top_p || 1));
                    setFieldValue('timeout', preset.timeout || config.timeout || <?= \Weline\Ai\Service\Provider\ProviderTimeoutPolicy::DEFAULT_REQUEST_TIMEOUT ?>);
        setCheckboxValue('stream', preset.stream !== false);
        setFieldValue('token_price_input', preset.token_price_input || 0);
        setFieldValue('token_price_output', preset.token_price_output || 0);
        setFieldValue('cost_per_token', preset.cost_per_token || preset.token_price_input || 0);

        var providerConfigTextarea = document.getElementById('provider_config_json');
        if (providerConfigTextarea) {
            providerConfigTextarea.value = JSON.stringify(config, null, 2);
        }
    }

    var remoteModelOptions = [];

    function fillModelPresetOptions(providerCode, accountId) {
        var select = document.getElementById('common_model_preset');
        if (!select) return;

        select.innerHTML = '';
        var placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = providerCode && accountId ? '<?= addslashes(__('选择模型')) ?>' : '<?= addslashes(__('请先选择供应商账户')) ?>';
        select.appendChild(placeholder);
        select.disabled = !providerCode || !accountId;

        var searchInput = document.getElementById('common_model_search');
        if (searchInput) {
            searchInput.value = '';
            searchInput.disabled = !providerCode || !accountId;
        }
        remoteModelOptions = [];
        if (!providerCode || !accountId) return;

        placeholder.textContent = '正在从供应商 models 接口加载...';
        select.disabled = true;
        if (searchInput) searchInput.disabled = true;
        loadProviderRemoteModels(providerCode, accountId).then(function(models) {
            remoteModelOptions = models;
            renderRemoteModelOptions('');
            select.disabled = false;
            if (searchInput) searchInput.disabled = false;
        }).catch(function(error) {
            select.innerHTML = '';
            var option = document.createElement('option');
            option.value = '';
            option.textContent = error && error.message ? error.message : 'Unable to load provider models';
            select.appendChild(option);
            select.disabled = true;
            if (searchInput) searchInput.disabled = true;
        });
        return;

        if (!providerCode || !Array.isArray(commonModelPresets)) return;

        var presets = commonModelPresets.filter(function(preset) {
            return preset.provider === providerCode;
        });
        presets.forEach(function(preset) {
            var option = document.createElement('option');
            option.value = preset.key;
            option.textContent = (preset.name || preset.model_code || '') + ' (' + (preset.model_code || '') + ')';
            select.appendChild(option);
        });

        if (presets.length === 1) {
            select.value = presets[0].key;
            applyPreset(presets[0]);
        }
    }

    function loadProviderRemoteModels(providerCode, accountId) {
        var payload = { provider_code: providerCode, account_id: parseInt(accountId || '0', 10) || 0 };
        if (!window.Weline || !window.Weline.Api || typeof window.Weline.Api.resource !== 'function') {
            return Promise.reject(new Error('Weline.Api.resource is unavailable.'));
        }
        return window.Weline.Api.resource('ai').providerRemoteModelsForSelect(payload).then(function(data) {
            if (!data || data.success === false) {
                throw new Error((data && data.message) || 'models endpoint failed');
            }
            var models = Array.isArray(data.data) ? data.data : (Array.isArray(data.items) ? data.items : []);
            if (!models.length) {
                throw new Error('models endpoint returned empty list');
            }
            return models;
        });
    }

    function renderRemoteModelOptions(keyword) {
        var select = document.getElementById('common_model_preset');
        if (!select) return;
        var normalizedKeyword = String(keyword || '').trim().toLowerCase();
        select.innerHTML = '';
        var placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = '选择模型';
        select.appendChild(placeholder);

        var matchedCount = 0;
        var firstValue = '';
        remoteModelOptions.filter(function(model) {
            if (!normalizedKeyword) return true;
            var text = [
                model.code || model.value || '',
                model.name || '',
                model.label || '',
                model.description || '',
                model.primary_modality || ''
            ].join(' ').toLowerCase();
            return text.indexOf(normalizedKeyword) !== -1;
        }).forEach(function(model) {
            var code = model.code || model.value || '';
            if (!code) return;
            var option = document.createElement('option');
            option.value = code;
            option.textContent = model.label || ((model.name || code) + ' (' + code + ')');
            option.dataset.modelName = model.name || code;
            option.dataset.maxTokens = model.max_tokens || model.context_window || 4096;
            option.dataset.primaryModality = model.primary_modality || '';
            option.dataset.description = model.description || '';
            select.appendChild(option);
            matchedCount++;
            if (!firstValue) firstValue = code;
        });
        select.disabled = matchedCount === 0;
        if (matchedCount === 1 && firstValue) {
            select.value = firstValue;
            applyRemoteModelOption(select.options[select.selectedIndex]);
        }
    }

    function applyRemoteModelOption(option) {
        if (!option || !option.value) return;
        var providerSelect = document.getElementById('common_provider_preset');
        var accountSelect = document.getElementById('common_provider_account');
        var providerCode = providerSelect ? providerSelect.value : '';
        var code = option.value;
        var maxTokens = parseInt(option.dataset.maxTokens || '4096', 10) || 4096;
        var primaryModality = option.dataset.primaryModality || '';
        var name = option.dataset.modelName || code;
        var preset = {
            provider: providerCode,
            model_code: code,
            provider_model_code: code,
            name: name,
            version: '1.0',
            max_tokens: maxTokens,
            token_price_input: 0,
            token_price_output: 0,
            config: {
                account_id: accountSelect ? parseInt(accountSelect.value || '0', 10) || 0 : 0,
                model: code,
                model_id: code,
                max_tokens: maxTokens,
                temperature: 0,
                top_p: 1,
                stream: false
            }
        };
        if (primaryModality) {
            preset.primary_modality = primaryModality;
            preset.config.primary_modality = primaryModality;
        }
        applyPreset(preset);
        setFieldValue('primary_modality', primaryModality || 'text2text');
        var currentModelInput = document.getElementById('model_code');
        if (currentModelInput) {
            currentModelInput.dispatchEvent(new Event('input', { bubbles: true }));
            currentModelInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }

    (function initQuickCreate() {
        var providerSelect = document.getElementById('common_provider_preset');
        var accountSelect = document.getElementById('common_provider_account');
        var modelSelect = document.getElementById('common_model_preset');
        if (!providerSelect || !accountSelect || !modelSelect || !Array.isArray(commonModelPresets)) return;

        var providers = {};
        commonModelPresets.forEach(function(preset) {
            if (!preset.provider) return;
            providers[preset.provider] = preset.provider_name || preset.provider;
        });

        Object.keys(providers).sort(function(a, b) {
            return providers[a].localeCompare(providers[b]);
        }).forEach(function(providerCode) {
            var option = document.createElement('option');
            option.value = providerCode;
            option.textContent = providers[providerCode];
            providerSelect.appendChild(option);
        });

        function resetQuickModels(message) {
            modelSelect.innerHTML = '<option value="">' + message + '</option>';
            modelSelect.disabled = true;
            var search = document.getElementById('common_model_search');
            if (search) { search.value = ''; search.disabled = true; }
            remoteModelOptions = [];
        }

        function loadQuickAccounts(providerCode) {
            accountSelect.innerHTML = '<option value="">' + (providerCode ? '<?= addslashes(__('选择供应商账户')) ?>' : '<?= addslashes(__('先选择供应商')) ?>') + '</option>';
            accountSelect.disabled = !providerCode;
            resetQuickModels(providerCode ? '<?= addslashes(__('请先选择供应商账户')) ?>' : '<?= addslashes(__('先选择供应商')) ?>');
            if (!providerCode) return;
            window.Weline.Api.resource('ai').providerListAccounts({ provider_code: providerCode, limit: 100 }).then(function(response) {
            var data = response;
            while (data && data.success === undefined && data.data && !Array.isArray(data.data)) data = data.data;
                var accounts = data && Array.isArray(data.data) ? data.data : (Array.isArray(data) ? data : []);
                accounts.forEach(function(account) {
                    var option = document.createElement('option');
                    option.value = String(account.id || '');
                    option.textContent = (account.account_name || '<?= addslashes(__('未命名账户')) ?>') + ' (' + (account.connection_status_text || account.connection_status || 'pending') + ')';
                    option.disabled = Number(account.is_active || 0) !== 1;
                    accountSelect.appendChild(option);
                });
            }).catch(function() {
                accountSelect.innerHTML = '<option value=""><?= addslashes(__('账户加载失败')) ?></option>';
                accountSelect.disabled = true;
            });
        }

        providerSelect.addEventListener('change', function() {
            loadQuickAccounts(this.value || '');
        });

        accountSelect.addEventListener('change', function() {
            if (!this.value) {
                resetQuickModels('<?= addslashes(__('请先选择供应商账户')) ?>');
                return;
            }
            fillModelPresetOptions(providerSelect.value || '', this.value);
        });

        modelSelect.addEventListener('change', function() {
            if (!this.value) return;
            applyRemoteModelOption(this.options[this.selectedIndex]);
        });

        var searchInput = document.getElementById('common_model_search');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                renderRemoteModelOptions(this.value || '');
            });
        }

    })();
    
    document.getElementById('model-form').addEventListener('submit', function(e) {
        var vendor = document.getElementById('vendor').value.trim();
        var modelCode = document.getElementById('model_code').value.trim();
        var modelName = document.getElementById('model_name').value.trim();
        var quickAccount = document.getElementById('common_provider_account');
        
        if (!vendor || !modelCode || !modelName) {
            e.preventDefault();
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请填写必填项：供应商、模型代码、模型名称') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请填写必填项：供应商、模型代码、模型名称') ?>');
            }
            return false;
        }
        if (quickAccount && !quickAccount.value) {
            e.preventDefault();
            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'warning', title: '<?= __('提示') ?>', text: '<?= __('快速新增请按顺序选择供应商、供应商账户和模型') ?>', confirmButtonText: '<?= __('确定') ?>' });
            }
            return false;
        }
        
        var providerConfigTextarea = document.getElementById('provider_config_json');
        if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
            try {
                JSON.parse(providerConfigTextarea.value);
            } catch (err) {
                e.preventDefault();
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('格式错误') ?>',
                        text: '<?= __('提供商配置JSON格式错误，请检查语法') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('提供商配置JSON格式错误，请检查语法') ?>');
                }
                providerConfigTextarea.focus();
                return false;
            }
        }
        
        return true;
    });
    
    <?php if ($isEdit): ?>
    var testModelBtn = document.getElementById('testModelBtn');
    testModelBtn.addEventListener('click', function() {
        var prompt = document.getElementById('test_prompt').value.trim();
        var modelId = <?= $model->getId() ?>;
        var form = document.getElementById('model-form');
        
        if (!prompt) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: '<?= __('提示') ?>',
                    text: '<?= __('请输入测试提示词') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请输入测试提示词') ?>');
            }
            return;
        }
        
        testModelBtn.disabled = true;
        testModelBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('测试中...') ?>';
        
        document.getElementById('testResult').style.display = 'none';

        var providerConfigTextarea = document.getElementById('provider_config_json');
        if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
            try {
                JSON.parse(providerConfigTextarea.value);
            } catch (err) {
                testModelBtn.disabled = false;
                testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> Test model';
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid JSON',
                        text: 'Provider config JSON is invalid. Please check the syntax.',
                        confirmButtonText: 'OK'
                    });
                }
                return;
            }
        }
        
        var formData = form ? new FormData(form) : new FormData();
        var testPayload = Object.fromEntries(formData.entries());
        testPayload.id = String(modelId);
        testPayload.prompt = prompt;
        testPayload.test_only = '1';
        var escapeHtml = function(value) {
            return String(value === undefined || value === null ? '' : value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        };
        var escapeTextWithBreaks = function(value) {
            return escapeHtml(value).replace(/\n/g, '<br>');
        };
        var safeImageSrc = function(value) {
            var src = String(value || '').trim();
            if (/^https?:\/\//i.test(src) || /^data:image\/[a-z0-9.+-]+;base64,/i.test(src)) {
                return src;
            }
            return '';
        };
        var tcReq = window.Weline.Api.resource('ai').providerTestConnection({ payload: testPayload });
        tcReq.then(function(res) {
            var data = res;
            while (data && data.success === undefined && data.data && !Array.isArray(data.data)) data = data.data;
            testModelBtn.disabled = false;
            testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> <?= __('测试模型') ?>';
            
            var resultDiv = document.getElementById('testResult');
            var resultContent = document.getElementById('testResultContent');
            var renderTestImages = function(result) {
                var images = Array.isArray(result.images) ? result.images : [];
                if (!images.length) {
                    return '';
                }
                var items = images.map(function(image) {
                    var src = safeImageSrc(image.url || (image.b64_json ? ('data:' + (image.mime_type || 'image/png') + ';base64,' + image.b64_json) : ''));
                    if (!src) {
                        return '';
                    }
                    src = escapeHtml(src);
                    return '<div class="col-sm-6 col-lg-4"><a href="' + src + '" target="_blank" rel="noopener"><img src="' + src + '" class="img-fluid rounded border" style="max-height: 260px; width: 100%; object-fit: contain; background: #fff;"></a></div>';
                }).join('');
                return items ? '<div class="row g-2 mt-2">' + items + '</div>' : '';
            };
            
            if (data && data.data && data.data.results) {
                var r = data.data.results;
                var s = r.self_config || {};
                var p = r.provider_account || {};
                var pTrace = Array.isArray(p.trace) && p.trace.length
                    ? ('<hr class="my-2"><small class="text-muted">详细过程：</small><div class="alert alert-light mb-0 mt-1" style="white-space: pre-wrap; max-height: 240px; overflow-y: auto;">' + escapeHtml(p.trace.join('\n')) + '</div>')
                    : '';
                var sBadge = s.tested ? (s.success ? '<span class="badge bg-success"><?= __('成功') ?></span>' : '<span class="badge bg-danger"><?= __('失败') ?></span>') : '<span class="badge bg-secondary"><?= __('未测') ?></span>';
                var pBadge = p.tested ? (p.success ? '<span class="badge bg-success"><?= __('成功') ?></span>' : '<span class="badge bg-danger"><?= __('失败') ?></span>') : '<span class="badge bg-secondary"><?= __('未测') ?></span>';
                resultContent.innerHTML = '<div class="row g-2"><div class="col-12"><div class="alert alert-' + (s.success ? 'success' : (s.tested ? 'danger' : 'secondary')) + ' py-2 px-3 mb-2"><strong>自配置</strong> ' + sBadge + '<br>' + (s.tested ? ('<small class="text-muted">耗时：</small><code>' + escapeHtml(s.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + escapeTextWithBreaks(s.message || '') + '<br><div class="alert alert-light mb-0" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">' + escapeHtml(s.response || '') + '</div>' + renderTestImages(s)) : '') + '</div></div><div class="col-12"><div class="alert alert-' + (p.success ? 'success' : (p.tested ? 'danger' : 'secondary')) + ' py-2 px-3 mb-2"><strong>供应商账户</strong> ' + pBadge + (p.account_name ? ' <span class="badge bg-info">' + escapeHtml(p.account_name) + '</span>' : '') + '<br>' + (p.tested ? ('<small class="text-muted">耗时：</small><code>' + escapeHtml(p.duration || 0) + ' ms</code><br><small class="text-muted">消息：</small>' + escapeTextWithBreaks(p.message || '') + '<br><div class="alert alert-light mb-0" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">' + escapeHtml(p.response || '') + '</div>' + renderTestImages(p) + pTrace) : '') + '</div></div></div>';
            } else if (data.success) {
                resultContent.innerHTML = '<div class="alert alert-success"><strong><?= __('测试成功') ?>!</strong> ' + escapeTextWithBreaks(data.message || '') + renderTestImages(data) + '</div>';
            } else {
                resultContent.innerHTML = '<div class="alert alert-danger"><strong><?= __('测试失败') ?>!</strong> ' + escapeTextWithBreaks(data.message || '') + '</div>' + (data.error ? '<div class="alert alert-warning"><small>' + escapeTextWithBreaks(data.error) + '</small></div>' : '');
            }
            
            resultDiv.style.display = 'block';
            resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        })
        .catch(function(error) {
            testModelBtn.disabled = false;
            testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> <?= __('测试模型') ?>';
            
            var resultDiv = document.getElementById('testResult');
            var resultContent = document.getElementById('testResultContent');
            
            resultContent.innerHTML = '<div class="alert alert-danger"><strong><?= __('网络错误') ?>!</strong> ' + escapeTextWithBreaks(error.message || '') + '</div>';
