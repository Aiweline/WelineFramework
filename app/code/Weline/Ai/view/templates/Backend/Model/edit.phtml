                            $providerOk = (($model ? $model->getData('provider_test_status') : 'pending') === 'success');
                            // 判断是否存在自配置api_key
                            $hasSelfConfig = false;
                            $providerCfgRaw = $model ? $model->getData('provider_config') : '';
                            if (!empty($providerCfgRaw)) {
                                $pCfg = is_string($providerCfgRaw) ? json_decode($providerCfgRaw, true) : $providerCfgRaw;
                                $hasSelfConfig = is_array($pCfg) && !empty($pCfg['api_key']);
                            }
                            if (!$hasSelfConfig) {
                                $cfgRaw = $model ? $model->getData('config') : '';
                                if (!empty($cfgRaw)) {
                                    $cCfg = is_string($cfgRaw) ? json_decode($cfgRaw, true) : $cfgRaw;
                                    $hasSelfConfig = is_array($cCfg) && !empty($cCfg['api_key']);
                                }
                            }
                            $selfOk = !$hasSelfConfig || (($model ? $model->getData('self_config_test_status') : 'pending') === 'success');
                            $canActivate = $providerOk && $selfOk;
                            $disableReason = '';
                            if (!$providerOk) {
                                $disableReason = '供应商连通性未通过';
                            } elseif ($hasSelfConfig && !$selfOk) {
                                $disableReason = '自配置连通性未通过';
                            }
