$displayConfig = $providerConfig;
if (empty($displayConfig) && !empty($config)) {
    $displayConfig = $config;
}

if (!empty($displayConfig)) {
    // 如果是数组，转换为JSON
    if (is_array($displayConfig)) {
        echo json_encode($displayConfig, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    } else if (is_string($displayConfig)) {
        // 如果是JSON字符串，尝试解析并格式化
        $decoded = json_decode($displayConfig, true);
        if (json_last_error() === JSON_ERROR_NONE) {
            echo json_encode($decoded, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        } else {
            echo $displayConfig;
        }
    } else {
        echo $displayConfig;
    }
}
?></textarea>
