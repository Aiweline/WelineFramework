<script>
// 表单验证
document.getElementById('model-form').addEventListener('submit', function(e) {
    // 基本验证
    const vendor = document.getElementById('vendor').value.trim();
    const modelCode = document.getElementById('model_code').value.trim();
    const modelName = document.getElementById('model_name').value.trim();
    
    if (!vendor || !modelCode || !modelName) {
        e.preventDefault();
        alert(__('请填写必填项：供应商、模型代码、模型名称'));
        return false;
    }
    
    // 验证提供商配置JSON
    const providerConfigTextarea = document.getElementById('provider_config_json');
    if (providerConfigTextarea && providerConfigTextarea.value.trim()) {
        try {
            JSON.parse(providerConfigTextarea.value);
        } catch (e) {
            e.preventDefault();
            alert(__('提供商配置JSON格式错误，请检查语法'));
            providerConfigTextarea.focus();
            return false;
        }
    }
    
    return true;
});

// 模型测试功能
<?php if ($isEdit): ?>
const testModelBtn = document.getElementById('testModelBtn');
testModelBtn.addEventListener('click', function() {
    const prompt = document.getElementById('test_prompt').value.trim();
    const modelId = <?= $model->getId() ?>;
    
    if (!prompt) {
        alert(__('请输入测试提示词'));
        return;
    }
    
    // 禁用按钮并显示加载状态
    testModelBtn.disabled = true;
    testModelBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> ' + __('测试中...');
    
    // 隐藏之前的结果
    document.getElementById('testResult').style.display = 'none';
    
    // 发送测试请求
    const formData = new FormData();
    formData.append('id', modelId);
    formData.append('prompt', prompt);
    
    fetch('<?= $this->getBackendUrl("*/backend/model/testConnection") ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        // 恢复按钮状态
        testModelBtn.disabled = false;
        testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> ' + __('测试模型');
        
        // 显示结果
        const resultDiv = document.getElementById('testResult');
        const resultContent = document.getElementById('testResultContent');
        
        if (data && data.data && data.data.results) {
            const r = data.data.results;
            const s = r.self_config || {};
            const p = r.provider_account || {};
            const sBadge = s.tested ? (s.success ? '<span class="badge bg-success">' + __('成功') + '</span>' : '<span class="badge bg-danger">' + __('失败') + '</span>') : '<span class="badge bg-secondary">' + __('未测') + '</span>';
            const pBadge = p.tested ? (p.success ? '<span class="badge bg-success">' + __('成功') + '</span>' : '<span class="badge bg-danger">' + __('失败') + '</span>') : '<span class="badge bg-secondary">' + __('未测') + '</span>';
            resultContent.innerHTML = `
                <div class="row g-2">
                    <div class="col-12">
                        <div class="alert alert-${(s.success ? 'success' : (s.tested ? 'danger' : 'secondary'))} py-2 px-3 mb-2">
                            <strong>自配置</strong> ${sBadge}<br>
                            ${s.tested ? (`<small class=\"text-muted\">耗时：</small><code>${s.duration || 0} ms</code><br>` +
                            `<small class=\"text-muted\">消息：</small>${(s.message || '')}<br>` +
                            `<div class=\"alert alert-light mb-0\" style=\"white-space: pre-wrap; max-height: 200px; overflow-y: auto;\">${(s.response || '')}</div>`) : ''}
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="alert alert-${(p.success ? 'success' : (p.tested ? 'danger' : 'secondary'))} py-2 px-3 mb-2">
                            <strong>供应商账户</strong> ${pBadge} ${p.account_name ? ` <span class=\"badge bg-info\">${p.account_name}</span>` : ''}<br>
                            ${p.tested ? (`<small class=\"text-muted\">耗时：</small><code>${p.duration || 0} ms</code><br>` +
                            `<small class=\"text-muted\">消息：</small>${(p.message || '')}<br>` +
                            `<div class=\"alert alert-light mb-0\" style=\"white-space: pre-wrap; max-height: 200px; overflow-y: auto;\">${(p.response || '')}</div>`) : ''}
                        </div>
                    </div>
                </div>`;
        } else if (data.success) {
            resultContent.innerHTML = `
                <div class="alert alert-success">
            <strong>${__('测试成功')}!</strong> ${data.message}
                </div>`;
        } else {
            resultContent.innerHTML = `
                <div class="alert alert-danger">
            <strong>${__('测试失败')}!</strong> ${data.message}
                </div>
                ${data.error ? `<div class="alert alert-warning"><small>${data.error}</small></div>` : ''}
            `;
        }
        
        resultDiv.style.display = 'block';
        
        // 滚动到结果区域
        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    })
    .catch(error => {
        // 恢复按钮状态
        testModelBtn.disabled = false;
        testModelBtn.innerHTML = '<i class="mdi mdi-play-circle"></i> ' + __('测试模型');
        
        // 显示错误
        const resultDiv = document.getElementById('testResult');
        const resultContent = document.getElementById('testResultContent');
        
        resultContent.innerHTML = `
            <div class="alert alert-danger">
                <strong>${__('网络错误')}!</strong> ${error.message}
            </div>
        `;
        
        resultDiv.style.display = 'block';
    });
});
<?php endif; ?>
</script>

