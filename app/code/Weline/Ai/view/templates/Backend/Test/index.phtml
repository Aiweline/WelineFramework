<script>
let startTime = 0;

function testAI() {
    const prompt = document.getElementById('prompt').value;
    const modelCode = document.getElementById('modelCode').value;
    const scenarioCode = document.getElementById('scenarioCode').value;
    const streamMode = document.getElementById('streamMode').checked;

    if (!prompt.trim()) {
        alert('<?= __('请输入提示词') ?>');
        return;
    }

    const resultContainer = document.getElementById('resultContainer');
    resultContainer.innerHTML = '<div class="spinner-border" role="status"><span class="sr-only"><?= __('生成中...') ?></span></div>';

    startTime = Date.now();

    if (streamMode) {
        testStreamMode(prompt, modelCode, scenarioCode);
    } else {
        testNormalMode(prompt, modelCode, scenarioCode);
    }
}

function testNormalMode(prompt, modelCode, scenarioCode) {
    const data = new FormData();
    data.append('prompt', prompt);
    if (modelCode) data.append('model_code', modelCode);
    if (scenarioCode) data.append('scenario_code', scenarioCode);

    fetch('<?= $this->getBackendUrl('*/backend/test/generate') ?>', {
        method: 'POST',
        body: data
    })
    .then(response => response.json())
    .then(data => {
        const endTime = Date.now();
        const duration = endTime - startTime;

        if (data.success) {
            displayResult(data.data.response, duration, data.data);
        } else {
            displayError(data.message);
        }
    })
    .catch(error => {
        displayError(error.message);
    });
}

function testStreamMode(prompt, modelCode, scenarioCode) {
    const resultContainer = document.getElementById('resultContainer');
    resultContainer.innerHTML = '<div class="stream-content"></div>';
    const streamContent = resultContainer.querySelector('.stream-content');

    let url = `<?= $this->getBackendUrl('*/backend/test/stream') ?>?prompt=${encodeURIComponent(prompt)}`;
    if (modelCode) url += `&model_code=${encodeURIComponent(modelCode)}`;
    if (scenarioCode) url += `&scenario_code=${encodeURIComponent(scenarioCode)}`;

    const eventSource = new EventSource(url);
    let fullResponse = '';

    eventSource.addEventListener('message', (e) => {
        const data = JSON.parse(e.data);
        fullResponse += data.chunk;
        streamContent.textContent = fullResponse;
    });

    eventSource.addEventListener('done', (e) => {
        eventSource.close();
        const endTime = Date.now();
        const duration = endTime - startTime;
        displayMetrics(duration, { mode: 'stream', length: fullResponse.length });
    });

    eventSource.addEventListener('error', (e) => {
        eventSource.close();
        displayError('<?= __('流式传输出错') ?>');
    });
}

function displayResult(response, duration, metadata = {}) {
    const resultContainer = document.getElementById('resultContainer');
    resultContainer.innerHTML = `
        <div class="alert alert-success">
            <strong><?= __('生成成功！') ?></strong>
        </div>
        <div class="response-text">${escapeHtml(response)}</div>
    `;

    displayMetrics(duration, metadata);
}

function displayError(message) {
    const resultContainer = document.getElementById('resultContainer');
    resultContainer.innerHTML = `
        <div class="alert alert-danger">
            <strong><?= __('错误：') ?></strong> ${escapeHtml(message)}
        </div>
    `;
}

function displayMetrics(duration, metadata = {}) {
    const metricsContainer = document.getElementById('metricsContainer');
    metricsContainer.innerHTML = `
        <table class="table table-sm">
            <tr>
                <th><?= __('响应时间') ?></th>
                <td>${duration}ms</td>
            </tr>
            <tr>
                <th><?= __('模型') ?></th>
                <td>${metadata.model_code || '<?= __('默认') ?>'}</td>
            </tr>
            <tr>
                <th><?= __('场景适配器') ?></th>
                <td>${metadata.scenario_code || '<?= __('无') ?>'}</td>
            </tr>
            <tr>
                <th><?= __('响应长度') ?></th>
                <td>${metadata.length || 0} <?= __('字符') ?></td>
            </tr>
        </table>
    `;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>

