<script>
(function () {
    'use strict';

    var catalogUrl = <?= \json_encode($catalogUrl, JSON_UNESCAPED_SLASHES) ?>;
    var saveUrl = <?= \json_encode($saveUrl, JSON_UNESCAPED_SLASHES) ?>;
    var cloneUrl = <?= \json_encode($cloneUrl, JSON_UNESCAPED_SLASHES) ?>;
    var matchUrl = <?= \json_encode($matchUrl, JSON_UNESCAPED_SLASHES) ?>;
    var bindUrl = <?= \json_encode($bindUrl, JSON_UNESCAPED_SLASHES) ?>;
    var unbindUrl = <?= \json_encode($unbindUrl, JSON_UNESCAPED_SLASHES) ?>;
    var initialItems = <?= \json_encode($styles, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE) ?: '[]' ?>;
    var initialAdapters = <?= \json_encode($adapters, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE) ?: '[]' ?>;

    var state = {
        items: Array.isArray(initialItems) ? initialItems : [],
        adapters: Array.isArray(initialAdapters) ? initialAdapters : [],
        selectedCode: '',
        selectedAdapter: '',
        draft: null
    };

    var els = {
        adapter: document.getElementById('ai-style-adapter'),
        adapterSummary: document.getElementById('ai-style-adapter-summary'),
        search: document.getElementById('ai-style-search'),
        statusFilter: document.getElementById('ai-style-status-filter'),
        sourceFilter: document.getElementById('ai-style-source-filter'),
        tableBody: document.getElementById('ai-style-table-body'),
        listStatus: document.getElementById('ai-style-status'),
        empty: document.getElementById('ai-style-empty'),
        form: document.getElementById('ai-style-form'),
        detailTitle: document.getElementById('ai-style-detail-title'),
        detailMode: document.getElementById('ai-style-detail-mode'),
        badges: document.getElementById('ai-style-badges'),
        code: document.getElementById('ai-style-code'),
        name: document.getElementById('ai-style-name'),
        status: document.getElementById('ai-style-edit-status'),
        description: document.getElementById('ai-style-description'),
        cta: document.getElementById('ai-style-cta'),
        supplemental: document.getElementById('ai-style-supplemental'),
        save: document.getElementById('ai-style-save-btn'),
        clone: document.getElementById('ai-style-clone-btn'),
        bind: document.getElementById('ai-style-bind-btn'),
        unbind: document.getElementById('ai-style-unbind-btn'),
        bindingHelp: document.getElementById('ai-style-binding-help'),
        formStatus: document.getElementById('ai-style-form-status'),
        matchTitle: document.getElementById('ai-style-match-title'),
        matchBrief: document.getElementById('ai-style-match-brief'),
        matchBtn: document.getElementById('ai-style-match-btn'),
        matchStatus: document.getElementById('ai-style-match-status')
    };

    function post(url, data) {
        var body = new URLSearchParams();
        Object.keys(data || {}).forEach(function (key) {
            var value = data[key];
            if (value && typeof value === 'object') {
                body.append(key, JSON.stringify(value));
            } else {
                body.append(key, String(value == null ? '' : value));
            }
        });
        return fetch(url, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'},
            body: body.toString()
        }).then(function (res) {
            return res.json();
        });
    }

    function clearNode(node) {
        while (node && node.firstChild) {
            node.removeChild(node.firstChild);
        }
    }

    function text(tag, value, className) {
        var node = document.createElement(tag);
        if (className) {
            node.className = className;
        }
        node.textContent = value || '';
        return node;
    }

    function badge(value, className) {
        var span = document.createElement('span');
        span.className = 'badge ' + (className || 'text-bg-secondary');
        span.textContent = value || '';
        return span;
    }

    function chip(value) {
        var span = document.createElement('span');
        span.className = 'style-chip';
        span.textContent = value || '';
        return span;
    }

    function setStatus(el, message, isError) {
        if (!el) {
            return;
        }
        el.className = 'small mt-2 ' + (isError ? 'text-danger' : 'text-success');
        el.textContent = message || '';
    }

    function toList(value) {
        if (Array.isArray(value)) {
            return value;
        }
        if (value && typeof value === 'object') {
            return Object.keys(value).map(function (key) {
                var item = value[key];
                return typeof item === 'string' ? item : JSON.stringify(item);
            });
        }
        if (typeof value === 'string' && value !== '') {
            return [value];
        }
        return [];
    }

    function flatten(value) {
        return toList(value).join(' ');
    }

    function parseLines(value) {
        var raw = String(value || '').trim();
        if (raw === '') {
            return [];
        }
        try {
            var parsed = JSON.parse(raw);
            if (parsed && typeof parsed === 'object') {
                return parsed;
            }
        } catch (e) {}
        return raw.split(/\r?\n/).map(function (line) {
            return line.trim();
        }).filter(Boolean);
    }

    function parseObject(value) {
        var raw = String(value || '').trim();
        if (raw === '') {
            return {};
        }
        try {
            var parsed = JSON.parse(raw);
            if (parsed && typeof parsed === 'object') {
                return parsed;
            }
        } catch (e) {}
        return parseLines(raw);
    }

    function formatStructured(value) {
        if (Array.isArray(value)) {
            return value.map(function (item) {
                return typeof item === 'string' ? item : JSON.stringify(item);
            }).join("\n");
        }
        if (value && typeof value === 'object') {
            return JSON.stringify(value, null, 2);
        }
        return String(value || '');
    }

    function selectedAdapterCode() {
        return els.adapter ? String(els.adapter.value || '') : '';
    }

    function currentAdapter() {
        var code = selectedAdapterCode();
        return state.adapters.find(function (adapter) {
            return String(adapter.code || '') === code;
        }) || null;
    }

    function sourceGroup(style) {
        var sourceType = String(style.source_type || style.source || '');
        if (sourceType === 'system' || sourceType === 'module' || sourceType === 'builtin') {
            return 'module';
        }
        if (sourceType === 'custom') {
            return 'custom';
        }
        if (sourceType === 'missing') {
            return 'missing';
        }
        return sourceType;
    }

    function findSelectedStyle() {
        if (state.selectedCode === '__new__') {
            return state.draft;
        }
        return state.items.find(function (item) {
            return String(item.code || '') === state.selectedCode;
        }) || null;
    }

    function renderAdapters() {
        clearNode(els.adapter);
        if (!state.adapters.length) {
            var fallback = document.createElement('option');
            fallback.value = 'pagebuilder_component_generation';
            fallback.textContent = 'pagebuilder_component_generation';
            els.adapter.appendChild(fallback);
            state.selectedAdapter = fallback.value;
            return;
        }

        state.adapters.forEach(function (adapter) {
            var option = document.createElement('option');
            option.value = adapter.code || '';
            option.textContent = (adapter.name || adapter.code || '') + ' (' + (adapter.code || '') + ')';
            els.adapter.appendChild(option);
        });

        var preferred = state.adapters.find(function (adapter) {
            return adapter.code === 'pagebuilder_component_generation';
        }) || state.adapters.find(function (adapter) {
            return adapter.code === 'pagebuilder_plan_generation';
        }) || state.adapters[0];
        state.selectedAdapter = preferred.code || '';
        els.adapter.value = state.selectedAdapter;
    }

    function renderAdapterSummary() {
        var adapter = currentAdapter();
        if (!adapter) {
            els.adapterSummary.textContent = 'Adapter context unavailable.';
            return;
        }
        var defaults = Array.isArray(adapter.default_style_codes) ? adapter.default_style_codes : [];
        var manual = Array.isArray(adapter.manual_style_codes) ? adapter.manual_style_codes : [];
        els.adapterSummary.textContent = 'Default: ' + (defaults.length ? defaults.join(', ') : 'none')
            + ' | Manual: ' + (manual.length ? manual.join(', ') : 'none');
    }

    function filteredItems() {
        var q = String(els.search.value || '').trim().toLowerCase();
        var status = String(els.statusFilter.value || '');
        var source = String(els.sourceFilter.value || '');
        var items = state.items.slice();
        if (state.draft) {
            items.unshift(state.draft);
        }
        return items.filter(function (style) {
            var haystack = [
                style.code || '',
                style.name || '',
                style.description || '',
                style.source || '',
                style.source_type || '',
                style.source_module || '',
                flatten(style.industry_tags),
                flatten(style.match_keywords),
                flatten(style.visual_keywords),
                flatten(style.layout_patterns)
            ].join(' ').toLowerCase();
            if (q !== '' && haystack.indexOf(q) === -1) {
                return false;
            }
            if (status !== '' && String(style.status || '') !== status) {
                return false;
            }
            if (source !== '' && sourceGroup(style) !== source) {
                return false;
            }
            return true;
        });
    }

    function renderTable() {
        var items = filteredItems();
        clearNode(els.tableBody);
        if (!items.length) {
            var emptyRow = document.createElement('tr');
            var td = document.createElement('td');
            td.colSpan = 6;
            td.className = 'text-center text-muted py-4';
            td.textContent = 'No styles match the current filters.';
            emptyRow.appendChild(td);
            els.tableBody.appendChild(emptyRow);
            els.listStatus.textContent = '0 / ' + state.items.length + ' styles';
            return;
        }

        items.forEach(function (style) {
            var code = style._draft ? '__new__' : String(style.code || '');
            var tr = document.createElement('tr');
            tr.className = 'style-row' + (code === state.selectedCode ? ' is-selected' : '');
            tr.dataset.code = code;

            var codeTd = document.createElement('td');
            codeTd.appendChild(text('code', style._draft ? '(new custom style)' : style.code || ''));
            var chipWrap = document.createElement('div');
            toList(style.industry_tags).slice(0, 3).forEach(function (item) {
                chipWrap.appendChild(chip(item));
            });
            codeTd.appendChild(chipWrap);
            tr.appendChild(codeTd);

            var nameTd = document.createElement('td');
            nameTd.appendChild(text('div', style.name || style.code || 'Untitled style', 'fw-semibold'));
            nameTd.appendChild(text('div', style.description || '', 'small text-muted style-muted-line'));
            tr.appendChild(nameTd);

            var sourceTd = document.createElement('td');
            sourceTd.appendChild(text('div', style.source_module || style.source || style.source_type || '', 'small'));
            sourceTd.appendChild(text('div', style.source_type || '', 'small text-muted'));
            tr.appendChild(sourceTd);

            var statusTd = document.createElement('td');
            var statusClass = style.status === 'active' ? 'text-bg-success' : (style.status === 'missing' ? 'text-bg-danger' : 'text-bg-secondary');
            statusTd.appendChild(badge(style.status || 'new', statusClass));
            tr.appendChild(statusTd);

            var bindingTd = document.createElement('td');
            if (style.adapter_default) {
                bindingTd.appendChild(badge('default', 'text-bg-primary'));
            } else if (style.manual) {
                bindingTd.appendChild(badge('manual', 'text-bg-info'));
            } else if (style.temporary) {
                bindingTd.appendChild(badge('temporary', 'text-bg-light text-dark'));
            } else {
                bindingTd.appendChild(text('span', '-', 'small text-muted'));
            }
            tr.appendChild(bindingTd);

            var actionTd = document.createElement('td');
            var manageBtn = document.createElement('button');
            manageBtn.type = 'button';
            manageBtn.className = 'btn btn-outline-primary btn-sm';
            manageBtn.textContent = 'Manage';
            actionTd.appendChild(manageBtn);
            tr.appendChild(actionTd);

            els.tableBody.appendChild(tr);
        });

        els.listStatus.textContent = String(items.length) + ' / ' + state.items.length + ' styles';
    }

    function setFieldsDisabled(disabled) {
        [els.name, els.status, els.description, els.cta, els.supplemental].forEach(function (input) {
            input.disabled = disabled;
        });
        document.querySelectorAll('[data-style-array], [data-style-object]').forEach(function (input) {
            input.disabled = disabled;
        });
    }

    function renderDetail() {
        var style = findSelectedStyle();
        if (!style) {
            els.empty.classList.remove('d-none');
            els.form.classList.add('d-none');
            els.detailTitle.textContent = 'Style detail';
            els.detailMode.textContent = 'No selection';
            return;
        }

        var readonly = !!style.readonly || sourceGroup(style) === 'module' || sourceGroup(style) === 'missing';
        els.empty.classList.add('d-none');
        els.form.classList.remove('d-none');
        els.detailTitle.textContent = style._draft ? 'New custom style' : 'Manage ' + (style.code || '');
        els.detailMode.textContent = readonly ? 'Readonly' : (style.exists ? 'Editable' : 'New');

        clearNode(els.badges);
        els.badges.appendChild(badge(style.status || 'new', style.status === 'active' ? 'text-bg-success' : 'text-bg-secondary'));
        els.badges.appendChild(badge(style.source_type || 'custom', 'text-bg-light text-dark'));
        if (style.adapter_default) {
            els.badges.appendChild(badge('default binding', 'text-bg-primary'));
        }
        if (style.manual) {
            els.badges.appendChild(badge('manual binding', 'text-bg-info'));
        }
        if (readonly) {
            els.badges.appendChild(badge('readonly', 'text-bg-dark'));
        }

        els.code.value = style._draft ? '' : String(style.code || '');
        els.name.value = String(style.name || '');
        els.status.value = String(style.status || 'active') === 'disabled' ? 'disabled' : 'active';
        els.description.value = String(style.description || '');
        els.cta.value = String(style.cta_style || '');
        els.supplemental.value = String(style.supplemental_prompt || '');

        document.querySelectorAll('[data-style-array]').forEach(function (input) {
            var field = input.getAttribute('data-style-array') || '';
            input.value = formatStructured(style[field] || []);
        });
        document.querySelectorAll('[data-style-object]').forEach(function (input) {
            var field = input.getAttribute('data-style-object') || '';
            input.value = formatStructured(style[field] || {});
        });

        els.code.readOnly = readonly || (!!style.exists && !style._draft);
        setFieldsDisabled(readonly);
        els.save.disabled = readonly;
        document.querySelectorAll('[data-style-status-action]').forEach(function (btn) {
            btn.disabled = readonly || style._draft || String(style.status || '') === String(btn.getAttribute('data-style-status-action') || '');
        });
        els.clone.disabled = !style.code || sourceGroup(style) === 'custom' || sourceGroup(style) === 'missing';

        var active = String(style.status || '') === 'active';
        els.bind.disabled = !active || !style.code || !!style.adapter_default || !!style.manual || !style.exists;
        els.unbind.disabled = !style.manual || !!style.adapter_default;
        if (style.adapter_default) {
            els.bindingHelp.textContent = 'This style is declared by adapter code as a default binding and cannot be unbound here.';
        } else if (style.manual) {
            els.bindingHelp.textContent = 'This style is manually bound to the selected adapter. You can remove only this manual binding.';
        } else if (!active) {
            els.bindingHelp.textContent = 'Only active styles can be bound to adapters.';
        } else {
            els.bindingHelp.textContent = 'Bind this style as a long-term manual adapter style for the selected context.';
        }
    }

    function selectStyle(code) {
        state.selectedCode = code || '';
        renderTable();
        renderDetail();
        setStatus(els.formStatus, '', false);
    }

    function newStyle() {
        state.draft = {
            _draft: true,
            exists: false,
            readonly: false,
            source: 'custom',
            source_type: 'custom',
            status: 'active',
            code: '',
            name: '',
            description: '',
            industry_tags: [],
            match_keywords: [],
            visual_keywords: [],
            color_system: {},
            layout_patterns: [],
            image_strategy: [],
            forbidden_patterns: [],
            block_rules: {},
            qa_rules: [],
            example_refs: [],
            cta_style: '',
            supplemental_prompt: ''
        };
        state.selectedCode = '__new__';
        renderTable();
        renderDetail();
        els.code.focus();
    }

    function collectPayload(statusOverride) {
        var payload = {
            code: els.code.value || '',
            name: els.name.value || '',
            description: els.description.value || '',
            status: statusOverride || els.status.value || 'active',
            cta_style: els.cta.value || '',
            supplemental_prompt: els.supplemental.value || ''
        };
        document.querySelectorAll('[data-style-array]').forEach(function (input) {
            payload[input.getAttribute('data-style-array') || ''] = parseLines(input.value);
        });
        document.querySelectorAll('[data-style-object]').forEach(function (input) {
            payload[input.getAttribute('data-style-object') || ''] = parseObject(input.value);
        });
        return payload;
    }

    function refreshCatalog() {
        var adapterCode = selectedAdapterCode();
        els.listStatus.textContent = 'Loading...';
        return post(catalogUrl, {
            adapter_code: adapterCode,
            include_inactive: 1
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || 'Catalog load failed');
            }
            state.items = Array.isArray(payload.items) ? payload.items : [];
            state.draft = null;
            var stillExists = state.items.some(function (item) {
                return String(item.code || '') === state.selectedCode;
            });
            if (!stillExists && state.items.length) {
                state.selectedCode = String(state.items[0].code || '');
            }
            renderAdapterSummary();
            renderTable();
            renderDetail();
        }).catch(function (err) {
            els.listStatus.textContent = err && err.message ? err.message : 'Catalog load failed';
        });
    }

    function saveCurrent(statusOverride) {
        setStatus(els.formStatus, 'Saving...', false);
        return post(saveUrl, collectPayload(statusOverride)).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || 'Save failed');
            }
            state.selectedCode = payload.item && payload.item.code ? String(payload.item.code) : String(els.code.value || '');
            setStatus(els.formStatus, 'Saved.', false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, err && err.message ? err.message : 'Save failed', true);
        });
    }

    function cloneSelected() {
        var style = findSelectedStyle();
        if (!style || !style.code) {
            return;
        }
        setStatus(els.formStatus, 'Cloning...', false);
        return post(cloneUrl, {code: style.code}).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || 'Clone failed');
            }
            state.selectedCode = payload.item && payload.item.code ? String(payload.item.code) : '';
            setStatus(els.formStatus, 'Cloned as custom style.', false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, err && err.message ? err.message : 'Clone failed', true);
        });
    }

    function bindSelected(bind) {
        var style = findSelectedStyle();
        if (!style || !style.code) {
            return;
        }
        setStatus(els.formStatus, bind ? 'Binding style...' : 'Removing binding...', false);
        return post(bind ? bindUrl : unbindUrl, {
            adapter_code: selectedAdapterCode(),
            style_code: style.code
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || (bind ? 'Bind failed' : 'Unbind failed'));
            }
            setStatus(els.formStatus, bind ? 'Style bound to adapter.' : 'Manual binding removed.', false);
            return refreshCatalog();
        }).catch(function (err) {
            setStatus(els.formStatus, err && err.message ? err.message : (bind ? 'Bind failed' : 'Unbind failed'), true);
        });
    }

    function matchStyle() {
        setStatus(els.matchStatus, 'Matching...', false);
        return post(matchUrl, {
            adapter_code: selectedAdapterCode(),
            site_title: els.matchTitle.value || '',
            brief_description: els.matchBrief.value || ''
        }).then(function (payload) {
            if (!payload || payload.success === false) {
                throw new Error((payload && payload.message) || 'Match failed');
            }
            var item = payload.item || payload.style || payload.direction || null;
            if (item && item.code) {
                state.selectedCode = String(item.code);
                setStatus(els.matchStatus, 'Matched ' + item.code + ' (score ' + String(payload.score || 0) + ').', false);
                renderTable();
                renderDetail();
                return;
            }
            setStatus(els.matchStatus, payload.reason || 'No matching style found.', true);
        }).catch(function (err) {
            setStatus(els.matchStatus, err && err.message ? err.message : 'Match failed', true);
        });
    }

    renderAdapters();
    renderAdapterSummary();
    if (state.items.length) {
        state.selectedCode = String(state.items[0].code || '');
    }
    refreshCatalog();

    document.getElementById('ai-style-refresh').addEventListener('click', refreshCatalog);
    document.getElementById('ai-style-new').addEventListener('click', newStyle);
    els.adapter.addEventListener('change', function () {
        state.selectedAdapter = selectedAdapterCode();
        refreshCatalog();
    });
    [els.search, els.statusFilter, els.sourceFilter].forEach(function (input) {
        input.addEventListener('input', renderTable);
        input.addEventListener('change', renderTable);
    });
    els.tableBody.addEventListener('click', function (event) {
        var row = event.target.closest('tr[data-code]');
        if (!row) {
            return;
        }
        selectStyle(row.dataset.code || '');
    });
    els.save.addEventListener('click', function () {
        saveCurrent('');
    });
    document.querySelectorAll('[data-style-status-action]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            saveCurrent(btn.getAttribute('data-style-status-action') || '');
        });
    });
    els.clone.addEventListener('click', cloneSelected);
    els.bind.addEventListener('click', function () {
        bindSelected(true);
    });
    els.unbind.addEventListener('click', function () {
        bindSelected(false);
    });
    els.matchBtn.addEventListener('click', matchStyle);
})();
</script>
