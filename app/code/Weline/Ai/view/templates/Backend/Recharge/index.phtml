<script>
document.addEventListener('DOMContentLoaded', function() {
    const packages = document.querySelectorAll('.recharge-package');
    const customAmountInput = document.getElementById('customAmount');
    const rechargeBtn = document.getElementById('rechargeBtn');
    let selectedAmount = 0;

    // 充值套餐选择
    packages.forEach(pkg => {
        pkg.addEventListener('click', function() {
            packages.forEach(p => p.classList.remove('selected'));
            this.classList.add('selected');
            selectedAmount = parseFloat(this.dataset.amount);
            customAmountInput.value = '';
        });
    });

    // 自定义金额输入
    customAmountInput.addEventListener('input', function() {
        packages.forEach(p => p.classList.remove('selected'));
        selectedAmount = parseFloat(this.value) || 0;
    });

    // 立即充值按钮
    rechargeBtn.addEventListener('click', function() {
        if (selectedAmount < 1) {
            alert('<?= __("请选择充值套餐或输入充值金额（最低1元）") ?>');
            return;
        }

        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

        if (!confirm('<?= __("确认充值 ¥") ?>' + selectedAmount.toFixed(2) + '<?= __(" 吗？") ?>')) {
            return;
        }

        // 显示加载状态
        rechargeBtn.disabled = true;
        rechargeBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __("处理中...") ?>';

        // 发送充值请求
        fetch('<?= $this->getUrl("*/backend/recharge/create") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'amount=' + selectedAmount + '&payment_method=' + paymentMethod
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('<?= __("充值订单创建成功！订单ID：") ?>' + data.data.recharge_id);
                // TODO: 跳转到支付页面或显示支付二维码
                setTimeout(() => {
                    location.reload();
                }, 1000);
            } else {
                alert('<?= __("充值失败：") ?>' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('<?= __("充值请求失败，请稍后重试") ?>');
        })
        .finally(() => {
            rechargeBtn.disabled = false;
            rechargeBtn.innerHTML = '<i class="mdi mdi-cash-plus me-2"></i><?= __("立即充值") ?>';
        });
    });
});
</script>

