<script>
(function() {
    'use strict';
    
    var packages = document.querySelectorAll('.weline-ai-recharge-package');
    var customAmountInput = document.getElementById('customAmount');
    var rechargeBtn = document.getElementById('rechargeBtn');
    var selectedAmount = 0;

    packages.forEach(function(pkg) {
        pkg.addEventListener('click', function() {
            packages.forEach(function(p) { p.classList.remove('selected'); });
            this.classList.add('selected');
            selectedAmount = parseFloat(this.dataset.amount);
            customAmountInput.value = '';
        });
    });

    customAmountInput.addEventListener('input', function() {
        packages.forEach(function(p) { p.classList.remove('selected'); });
        selectedAmount = parseFloat(this.value) || 0;
    });

    rechargeBtn.addEventListener('click', function() {
        if (selectedAmount < 1) {
            if (typeof AdminToast !== 'undefined') {
                AdminToast.warning('<?= __("请选择充值套餐或输入充值金额（最低1元）") ?>');
            }
            return;
        }

        var paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

        if (typeof AdminConfirm !== 'undefined') {
            AdminConfirm.show({
                title: '<?= __("确认充值") ?>',
                message: '<?= __("确认充值 ¥") ?>' + selectedAmount.toFixed(2) + '<?= __(" 吗？") ?>',
                confirmText: '<?= __("确定充值") ?>',
                cancelText: '<?= __("取消") ?>',
                onConfirm: function() {
                    performRecharge(selectedAmount, paymentMethod);
                }
            });
        } else {
            performRecharge(selectedAmount, paymentMethod);
        }
    });

    function performRecharge(amount, paymentMethod) {
        rechargeBtn.disabled = true;
        rechargeBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><?= __("处理中...") ?>';

        fetch('<?= $this->getUrl("*/backend/recharge/create") ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'amount=' + amount + '&payment_method=' + paymentMethod
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.success('<?= __("充值订单创建成功！订单ID：") ?>' + data.data.recharge_id);
                }
                setTimeout(function() {
                    location.reload();
                }, 1500);
            } else {
                if (typeof AdminToast !== 'undefined') {
                    AdminToast.error(data.message || '<?= __("充值失败") ?>');
                }
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            if (typeof AdminToast !== 'undefined') {
                AdminToast.error('<?= __("充值请求失败，请稍后重试") ?>');
            }
        })
        .finally(function() {
            rechargeBtn.disabled = false;
            rechargeBtn.innerHTML = '<i class="mdi mdi-cash-plus me-2"></i><?= __("立即充值") ?>';
        });
    }
})();
</script>
