<?php
/**
 * 我的评分列表页面模板
 * 
 * @var array $ratings
 * @var int $total
 */
/**@var \Weline\Framework\View\Template $this */

$ratings = $this->ratings ?? [];
$total = $this->total ?? 0;
$page = $this->page ?? 1;
$pageSize = $this->pageSize ?? 20;
$totalPages = $this->totalPages ?? 1;
?>
<!-- 面包屑导航 -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">
                <i class="mdi mdi-star"></i> <lang>我的评分</lang>
            </h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);"><lang>AI助手</lang></a></li>
                    <li class="breadcrumb-item active"><lang>我的评分</lang></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- 页面统计卡片 -->
<div class="row mb-3">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <p class="text-muted mb-0">
                    <i class="mdi mdi-information-outline"></i> 
                    <lang>共</lang> <strong><?= $total ?></strong> <lang>条评分记录</lang>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- 评分列表卡片 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4">
                    <i class="mdi mdi-format-list-bulleted"></i> <lang>评分列表</lang>
                    <span class="badge bg-info"><?= $total ?></span>
                </h4>
                
                <?php if (empty($ratings)): ?>
                    <div class="text-center py-5">
                        <i class="mdi mdi-star-outline" style="font-size: 64px; color: var(--backend-color-text-muted, #ccc);"></i>
                        <h4 class="mt-3 text-muted"><?= __('暂无评分记录') ?></h4>
                        <p class="text-muted"><?= __('您还没有对任何助手进行评分') ?></p>
                    </div>
                <?php else: ?>
                    <div class="list-group">
                        <?php foreach ($ratings as $rating): 
                            $ratingScore = (int)$rating->getData('rating');
                            $status = $rating->getData('status');
                            $accuracyRating = (int)($rating->getData('accuracy_rating') ?? 0);
                            $speedRating = (int)($rating->getData('speed_rating') ?? 0);
                            $usefulnessRating = (int)($rating->getData('usefulness_rating') ?? 0);
                            
                            $statusClass = [
                                'pending' => 'warning',
                                'approved' => 'success',
                                'rejected' => 'danger'
                            ];
                            
                            $statusLabel = [
                                'pending' => __('待审核'),
                                'approved' => __('已通过'),
                                'rejected' => __('已拒绝')
                            ];
                        ?>
                            <div class="list-group-item mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="mb-1"><?= htmlspecialchars($rating->getData('assistant_name')) ?></h5>
                                        <p class="text-muted small mb-0"><?= htmlspecialchars(mb_substr($rating->getData('assistant_description') ?? '', 0, 100)) ?></p>
                                    </div>
                                    <div class="text-end">
                                        <small class="text-muted"><?= date('Y-m-d H:i', strtotime($rating->getData('created_time'))) ?></small>
                                        <span class="badge bg-<?= $statusClass[$status] ?? 'secondary' ?> ms-2">
                                            <?= $statusLabel[$status] ?? $status ?>
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <span class="text-warning">
                                        <?php for ($i = 1; $i <= 5; $i++): ?>
                                            <i class="mdi mdi-star<?= $i <= $ratingScore ? '' : '-outline' ?>"></i>
                                        <?php endfor; ?>
                                    </span>
                                </div>

                                <?php if ($accuracyRating || $speedRating || $usefulnessRating): ?>
                                    <div class="row mb-2">
                                        <?php if ($accuracyRating): ?>
                                            <div class="col-md-4">
                                                <small class="text-muted"><lang>准确性</lang>:</small>
                                                <span class="text-warning ms-1">
                                                    <?php for ($i = 1; $i <= 5; $i++): ?>
                                                        <i class="mdi mdi-star<?= $i <= $accuracyRating ? '' : '-outline' ?> small"></i>
                                                    <?php endfor; ?>
                                                </span>
                                            </div>
                                        <?php endif; ?>
                                        
                                        <?php if ($speedRating): ?>
                                            <div class="col-md-4">
                                                <small class="text-muted"><lang>速度</lang>:</small>
                                                <span class="text-warning ms-1">
                                                    <?php for ($i = 1; $i <= 5; $i++): ?>
                                                        <i class="mdi mdi-star<?= $i <= $speedRating ? '' : '-outline' ?> small"></i>
                                                    <?php endfor; ?>
                                                </span>
                                            </div>
                                        <?php endif; ?>
                                        
                                        <?php if ($usefulnessRating): ?>
                                            <div class="col-md-4">
                                                <small class="text-muted"><lang>实用性</lang>:</small>
                                                <span class="text-warning ms-1">
                                                    <?php for ($i = 1; $i <= 5; $i++): ?>
                                                        <i class="mdi mdi-star<?= $i <= $usefulnessRating ? '' : '-outline' ?> small"></i>
                                                    <?php endfor; ?>
                                                </span>
                                            </div>
                                        <?php endif; ?>
                                    </div>
                                <?php endif; ?>

                                <?php if ($rating->getData('comment')): ?>
                                    <div class="alert alert-light mb-2">
                                        <?= nl2br(htmlspecialchars($rating->getData('comment'))) ?>
                                    </div>
                                <?php endif; ?>

                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-sm btn-outline-primary" onclick="editRating(<?= $rating->getId() ?>)">
                                        <i class="mdi mdi-pencil"></i> <lang>编辑</lang>
                                    </button>
                                </div>
                            </div>
                        <?php endforeach; ?>
                    </div>

                    <!-- 分页 -->
                    <?php if ($totalPages > 1): ?>
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item <?= $page <= 1 ? 'disabled' : '' ?>">
                                    <a class="page-link" href="javascript:void(0)" onclick="changePage(<?= $page - 1 ?>)">
                                        <i class="mdi mdi-chevron-left"></i> <lang>上一页</lang>
                                    </a>
                                </li>

                                <?php for ($i = max(1, $page - 2); $i <= min($totalPages, $page + 2); $i++): ?>
                                    <li class="page-item <?= $i === $page ? 'active' : '' ?>">
                                        <a class="page-link" href="javascript:void(0)" onclick="changePage(<?= $i ?>)"><?= $i ?></a>
                                    </li>
                                <?php endfor; ?>

                                <li class="page-item <?= $page >= $totalPages ? 'disabled' : '' ?>">
                                    <a class="page-link" href="javascript:void(0)" onclick="changePage(<?= $page + 1 ?>)">
                                        <lang>下一页</lang> <i class="mdi mdi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>
<!-- 评分列表卡片结束 -->

<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';

    window.changePage = function(page) {
        window.location.href = '<?= $this->getBackendUrl('*/backend/rating/mylist') ?>?page=' + page;
    };

    window.editRating = function(ratingId) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'info',
                title: '<?= __('功能开发中') ?>',
                text: '<?= __('编辑评分功能待实现，评分ID：') ?>' + ratingId,
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.log('编辑评分功能待实现，评分ID：' + ratingId);
        }
    };
})();
</script>
