    <!-- ============================================================== -->
    <div class="main-content">
        <div class="page-content">
            <div class="container-fluid">

<div class="adapter-detail-container">
    <!-- 基本信息 -->
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('基本信息') ?></h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th width="200"><?= __('适配器ID') ?></th>
                    <td><?= $adapter->getId() ?></td>
                </tr>
                <tr>
                    <th><?= __('适配器代码') ?></th>
                    <td><code><?= $adapter->getData('code') ?></code></td>
                </tr>
                <tr>
                    <th><?= __('适配器名称') ?></th>
                    <td><?= $adapter->getData('name') ?></td>
                </tr>
                <tr>
                    <th><?= __('版本') ?></th>
                    <td><?= $adapter->getData('version') ?></td>
                </tr>
                <tr>
                    <th><?= __('描述') ?></th>
                    <td><?= $adapter->getData('description') ?></td>
                </tr>
                <tr>
                    <th><?= __('状态') ?></th>
                    <td>
                        <?php if ($adapter->getData('is_active')): ?>
                            <span class="badge badge-success"><?= __('激活') ?></span>
                        <?php else: ?>
                            <span class="badge badge-secondary"><?= __('未激活') ?></span>
                        <?php endif; ?>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <!-- 支持的模型类型 -->
    <?php if (!empty($supportedModels)): ?>
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('支持的模型类型') ?></h5>
        </div>
        <div class="card-body">
            <?php if (is_array($supportedModels)): ?>
                <div class="d-flex flex-wrap gap-2">
                    <?php foreach ($supportedModels as $model): ?>
                        <span class="badge bg-info"><?= $model ?></span>
                    <?php endforeach; ?>
                </div>
            <?php else: ?>
                <pre class="bg-light p-3"><?= json_encode($supportedModels, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) ?></pre>
            <?php endif; ?>
        </div>
    </div>
    <?php endif; ?>

    <!-- 参数模板 -->
    <?php if (!empty($paramTemplate)): ?>
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('参数模板') ?></h5>
        </div>
        <div class="card-body">
            <pre class="bg-light p-3"><?= json_encode($paramTemplate, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) ?></pre>
        </div>
    </div>
    <?php endif; ?>

    <!-- 使用示例 -->
    <?php if (!empty($examples)): ?>
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('使用示例') ?></h5>
        </div>
        <div class="card-body">
            <pre class="bg-light p-3"><?= json_encode($examples, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) ?></pre>
        </div>
    </div>
    <?php endif; ?>

    <!-- 适配器实例信息 -->
    <?php if ($adapterInstance): ?>
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('实例信息') ?></h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th width="200"><?= __('类名') ?></th>
                    <td><code><?= get_class($adapterInstance) ?></code></td>
                </tr>
                <?php if (method_exists($adapterInstance, 'getVersion')): ?>
                <tr>
                    <th><?= __('运行时版本') ?></th>
                    <td><?= $adapterInstance->getVersion() ?></td>
                </tr>
                <?php endif; ?>
            </table>
        </div>
    </div>
    <?php endif; ?>

    <!-- 时间信息 -->
    <div class="card mb-3">
        <div class="card-header">
            <h5><?= __('时间信息') ?></h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th width="200"><?= __('创建时间') ?></th>
                    <td><?= date('Y-m-d H:i:s', $adapter->getData('created_time')) ?></td>
                </tr>
                <tr>
                    <th><?= __('更新时间') ?></th>
                    <td><?= date('Y-m-d H:i:s', $adapter->getData('updated_time')) ?></td>
                </tr>
            </table>
        </div>
    </div>
</div>

