<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 切换适配器状态
function toggleStatus(id) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __('确认切换状态') ?>',
            text: '<?= __('确定要切换适配器状态吗？') ?>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定切换") ?>',
            cancelButtonText: '<?= __("取消") ?>'
        }).then((result) => {
            if (result.isConfirmed) {
                performToggleStatus(id);
            }
        });
    } else {
        if (!confirm('<?= __('确定要切换适配器状态吗？') ?>')) {
            return;
        }
        performToggleStatus(id);
    }
}

function performToggleStatus(id) {
    fetch('<?= $this->_url->getBackendUrl('*/backend/adapter/toggleStatus') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            id: id
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('状态已切换') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: data.message || '<?= __('未知错误') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('操作失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('网络错误') ?>',
                text: '<?= __('请稍后重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('网络错误，请稍后重试') ?>');
        }
    });
}
</script>

