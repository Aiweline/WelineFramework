<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';
    
    var WelineAdapter = {
        confirmAction: function(message, onConfirm) {
            if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
                window.BackendConfirm.show(message).then(function(confirmed) {
                    if (confirmed) {
                        onConfirm();
                    }
                });
                return;
            }
            if (window.BackendToast && typeof window.BackendToast.error === 'function') {
                window.BackendToast.error('<?= __('确认组件不可用，请刷新页面后重试。') ?>');
            }
        },

        toggleStatus: function(id) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '<?= __('确认切换状态') ?>',
                    text: '<?= __('确定要切换适配器状态吗？') ?>',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: '<?= __("确定切换") ?>',
                    cancelButtonText: '<?= __("取消") ?>'
                }).then(function(result) {
                    if (result.isConfirmed) {
                        WelineAdapter.performToggleStatus(id);
                    }
                });
            } else {
                WelineAdapter.confirmAction('<?= __('确定要切换适配器状态吗？') ?>', function() {
                    WelineAdapter.performToggleStatus(id);
                });
            }
        },
        
        performToggleStatus: function(id) {
            var url = '<?= $this->_url->getBackendUrl('*/backend/adapter/toggleStatus') ?>';
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) };
            var req = window.Weline.Api.request(url, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                if (data && data.success) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('成功') ?>',
                            text: '<?= __('状态已切换') ?>',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(function() { location.reload(); });
                    } else {
                        location.reload();
                    }
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('操作失败') ?>',
                            text: data.message || '<?= __('未知错误') ?>',
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    } else {
                        console.error('<?= __('操作失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                    }
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('网络错误') ?>',
                        text: '<?= __('请稍后重试') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('网络错误，请稍后重试') ?>');
                }
            });
        }
    };
    
    window.WelineAdapter = WelineAdapter;

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-adapter-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();
        if (trigger.getAttribute('data-adapter-action') === 'toggle-status') {
            WelineAdapter.toggleStatus(parseInt(trigger.getAttribute('data-adapter-id') || '0', 10) || 0);
        }
    });
})();
</script>
