<script>
function scanAdapters() {
    if (confirm('确定要扫描场景适配器吗？')) {
        fetch('<?= $this->getBackendUrl('*/backend/adapter/scan') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('适配器扫描成功！');
                location.reload();
            } else {
                alert('适配器扫描失败：' + (data.message || '未知错误'));
            }
        })
        .catch(error => {
            alert('请求失败：' + error.message);
        });
    }
}

function toggleStatus(adapterId) {
    if (confirm('确定要切换适配器状态吗？')) {
        fetch('<?= $this->getBackendUrl('*/backend/adapter/toggleStatus') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({id: adapterId})
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('状态切换成功！');
                location.reload();
            } else {
                alert('状态切换失败：' + (data.message || '未知错误'));
            }
        })
        .catch(error => {
            alert('请求失败：' + error.message);
        });
    }
}
</script>

