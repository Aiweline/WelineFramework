    $(document).ready(function() {
        // 为所有offcanvas绑定事件
        $('.offcanvas').on('show.bs.offcanvas', function () {
            let iframe = $(this).find('iframe');
            if (iframe.length && !iframe.attr('src')) {
                iframe.attr('src', iframe.attr('data-src'));
            }
        });
    });
    </script>
