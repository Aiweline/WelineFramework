<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';
    
    window.scanAdapters = function() {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: '<?= __('确认扫描') ?>',
                text: '<?= __('确定要扫描场景适配器吗？') ?>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定扫描") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    showLoading();
                    window.location.href = '<?= $this->getBackendUrl('*/backend/adapter/scan') ?>';
                }
            });
        } else {
            if (confirm('<?= __('确定要扫描场景适配器吗？') ?>')) {
                showLoading();
                window.location.href = '<?= $this->getBackendUrl('*/backend/adapter/scan') ?>';
            }
        }
    };
    
    window.toggleStatus = function(adapterId) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: '<?= __('确认切换状态') ?>',
                text: '<?= __('确定要切换适配器状态吗？') ?>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定切换") ?>',
                cancelButtonText: '<?= __("取消") ?>'
            }).then(function(result) {
                if (result.isConfirmed) {
                    performToggleStatus(adapterId);
                }
            });
        } else {
            if (confirm('<?= __('确定要切换适配器状态吗？') ?>')) {
                performToggleStatus(adapterId);
            }
        }
    };
    
    function performToggleStatus(adapterId) {
        showLoading();
        fetch('<?= $this->getBackendUrl('*/backend/adapter/toggleStatus') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({id: adapterId})
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            hideLoading();
            if (data.success) {
                location.reload();
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('状态切换失败') ?>',
                        text: data.message || '<?= __('未知错误') ?>',
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('状态切换失败：') ?>' + (data.message || '<?= __('未知错误') ?>'));
                }
            }
        })
        .catch(function(error) {
            hideLoading();
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('请求失败：') ?>' + error.message);
            }
        });
    }
})();
</script>
