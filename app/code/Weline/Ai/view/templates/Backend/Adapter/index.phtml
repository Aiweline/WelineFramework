<script>
(function() {
    'use strict';
    
    var WelineAdapterManager = {
        urls: {
            scan: '<?= $this->getBackendUrl('*/backend/adapter/scan') ?>',
            toggleStatus: '<?= $this->getBackendUrl('*/backend/adapter/toggleStatus') ?>',
            delete: '<?= $this->getBackendUrl('*/backend/adapter/delete') ?>',
            batchDelete: '<?= $this->getBackendUrl('*/backend/adapter/batchDelete') ?>',
            batchToggle: '<?= $this->getBackendUrl('*/backend/adapter/batchToggle') ?>',
            batchSaveDefaultModel: '<?= $this->getBackendUrl('*/backend/adapter/batchSaveDefaultModel') ?>',
            batchSaveModelBindings: '<?= $this->getBackendUrl('*/backend/adapter/batchSaveModelBindings') ?>',
            getModelOptions: '<?= $this->getBackendUrl('*/backend/adapter/getModelOptions') ?>',
            cleanup: '<?= $this->getBackendUrl('*/backend/adapter/cleanup') ?>'
        },

        scan: function() {
            BackendConfirm.show('<?= __('确定要扫描场景适配器吗？这将发现所有模块中的适配器并更新数据库记录。') ?>', {
                title: '<?= __('扫描适配器') ?>',
                confirmText: '<?= __('确定扫描') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'info'
            }).then(function(confirmed) {
                if (confirmed) {
                    showLoading();
                    window.location.href = WelineAdapterManager.urls.scan;
                }
            });
        },

        toggleStatus: function(id) {
            BackendConfirm.show('<?= __('确定要切换此适配器的状态吗？') ?>', {
                title: '<?= __('切换状态') ?>',
                confirmText: '<?= __('确定') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doToggleStatus(id);
                }
            });
        },

        _doToggleStatus: function(id) {
            showLoading();
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({id: id}) };
            var req = window.Weline.Api.request(this.urls.toggleStatus, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('状态更新成功') ?>');
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message || '<?= __('状态更新失败') ?>');
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        delete: function(id) {
            BackendConfirm.show('<?= __('确定要删除此适配器吗？此操作不可恢复。') ?>', {
                title: '<?= __('删除适配器') ?>',
                confirmText: '<?= __('确定删除') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'danger'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doDelete(id);
                }
            });
        },

        _doDelete: function(id) {
            showLoading();
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({id: id}) };
            var req = window.Weline.Api.request(this.urls.delete, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('删除成功') ?>');
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message || '<?= __('删除失败') ?>');
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        getSelectedIds: function() {
            var ids = [];
            document.querySelectorAll('.row-checkbox:checked').forEach(function(cb) {
                ids.push(parseInt(cb.value));
            });
            return ids;
        },

        updateSelection: function() {
            var ids = this.getSelectedIds();
            var toolbar = document.getElementById('batchToolbar');
            var countEl = document.getElementById('selectCount');
            var selectAll = document.getElementById('selectAll');
            var total = document.querySelectorAll('.row-checkbox').length;
            
            countEl.textContent = ids.length;
            
            if (ids.length > 0) {
                toolbar.classList.add('show');
            } else {
                toolbar.classList.remove('show');
            }
            
            selectAll.checked = ids.length === total && total > 0;
            selectAll.indeterminate = ids.length > 0 && ids.length < total;
        },

        toggleSelectAll: function(checkbox) {
            var checked = checkbox.checked;
            document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                cb.checked = checked;
            });
            this.updateSelection();
        },

        clearSelection: function() {
            document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                cb.checked = false;
            });
            document.getElementById('selectAll').checked = false;
            this.updateSelection();
        },

        batchDelete: function() {
            var ids = this.getSelectedIds();
            if (ids.length === 0) {
                BackendToast.warning('<?= __('请先选择要删除的适配器') ?>');
                return;
            }

            BackendConfirm.show('<?= __('确定要删除选中的') ?> ' + ids.length + ' <?= __('个适配器吗？此操作不可恢复。') ?>', {
                title: '<?= __('批量删除') ?>',
                confirmText: '<?= __('确定删除') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'danger'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doBatchDelete(ids);
                }
            });
        },

        _doBatchDelete: function(ids) {
            showLoading();
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ids: ids}) };
            var req = window.Weline.Api.request(this.urls.batchDelete, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        batchToggle: function(status) {
            var ids = this.getSelectedIds();
            if (ids.length === 0) {
                BackendToast.warning('<?= __('请先选择要操作的适配器') ?>');
                return;
            }

            var statusText = status ? '<?= __('激活') ?>' : '<?= __('禁用') ?>';
            BackendConfirm.show('<?= __('确定要') ?>' + statusText + '<?= __('选中的') ?> ' + ids.length + ' <?= __('个适配器吗？') ?>', {
                title: '<?= __('批量') ?>' + statusText,
                confirmText: '<?= __('确定') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doBatchToggle(ids, status);
                }
            });
        },

        _doBatchToggle: function(ids, status) {
            showLoading();
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ids: ids, status: status}) };
            var req = window.Weline.Api.request(this.urls.batchToggle, opts);
            req.then(function(res) {
                var data = (res && res.data) || res;
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        cleanup: function() {
            BackendConfirm.show('<?= __('确定要清理无效的适配器吗？这将删除代码文件已不存在的适配器记录。') ?>', {
                title: '<?= __('清理无效适配器') ?>',
                confirmText: '<?= __('确定清理') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    showLoading();
                    window.location.href = WelineAdapterManager.urls.cleanup;
                }
            });
        },

        batchSetDefaultModel: function() {
            return this.batchSetModelBindings();
        },

        batchSetModelBindings: function(ids, presetBindings) {
            ids = Array.isArray(ids) && ids.length ? ids : this.getSelectedIds();
            presetBindings = this.normalizeModelBindingPreset(presetBindings || {});
            if (ids.length === 0) {
                BackendToast.warning('<?= __('请先选择要配置模型绑定的适配器') ?>');
                return;
            }
            if (Object.keys(presetBindings).length === 0 && ids.length === 1) {
                presetBindings = this.getSelectedRowModelBindings(ids[0]);
            }
            this.activeBindingIds = ids;
            var modal = document.getElementById('batchModelBindingModal');
            var selects = Array.prototype.slice.call(document.querySelectorAll('.js-modality-model-select'));
            if (!modal || !selects.length) return;
            var saveBtn = document.getElementById('batchModelBindingSaveBtn');
            if (saveBtn) saveBtn.disabled = true;
            var api = window.Weline && window.Weline.Api ? window.Weline.Api : { request: function(u, o) { return fetch(u, o).then(function(r) { return r.json(); }); } };
            var requests = selects.map(function(select) {
                var modality = select.getAttribute('data-modality') || '';
                select.innerHTML = '';
                var emptyOption = document.createElement('option');
                emptyOption.value = '';
                emptyOption.textContent = '<?= __('不启用') ?>';
                select.appendChild(emptyOption);
                select.disabled = true;
                return api.request(WelineAdapterManager.urls.getModelOptions + '?primary_modality=' + encodeURIComponent(modality), { method: 'GET' }).then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success && data.items && data.items.length) {
                        data.items.forEach(function(item) {
                            var opt = document.createElement('option');
                            opt.value = item.model_code || '';
                            opt.textContent = ((item.name || item.model_code || '').trim() || item.model_code) + ' (' + modality + ')';
                            select.appendChild(opt);
                        });
                    }
                    if (presetBindings[modality]) {
                        select.value = presetBindings[modality];
                        if (select.value !== presetBindings[modality]) {
                            var presetOption = document.createElement('option');
                            presetOption.value = presetBindings[modality];
                            presetOption.textContent = presetBindings[modality] + ' (' + modality + ')';
                            presetOption.dataset.missingModel = '1';
                            select.appendChild(presetOption);
                            select.value = presetBindings[modality];
                        }
                    }
                }).catch(function(e) {
                    BackendToast.error('<?= __('加载模型列表失败：') ?>' + (e.message || e));
                }).finally(function() {
                    select.disabled = false;
                });
            });
            Promise.all(requests).finally(function() { if (saveBtn) saveBtn.disabled = false; });
            var bsModal = typeof bootstrap !== 'undefined' && bootstrap.Modal ? new bootstrap.Modal(modal) : null;
            if (bsModal) bsModal.show();
        },

        normalizeModelBindingPreset: function(presetBindings) {
            var normalized = {};
            if (!presetBindings || typeof presetBindings !== 'object') return normalized;
            ['text2text', 'text2image', 'text2video'].forEach(function(modality) {
                var value = presetBindings[modality];
                if (value == null || String(value).trim() === '') return;
                normalized[modality] = String(value).trim();
            });
            return normalized;
        },

        getSelectedRowModelBindings: function(id) {
            var checkbox = document.querySelector('.row-checkbox[value="' + String(id).replace(/"/g, '\\"') + '"]');
            if (!checkbox) return {};
            try {
                return this.normalizeModelBindingPreset(JSON.parse(checkbox.getAttribute('data-model-bindings') || '{}'));
            } catch (e) {
                return {};
            }
        },

        _doBatchSaveDefaultModel: function() {
            return this._doBatchSaveModelBindings();
        },

        _doBatchSaveModelBindings: function() {
            var ids = this.activeBindingIds && this.activeBindingIds.length ? this.activeBindingIds : this.getSelectedIds();
            var bindings = {};
            document.querySelectorAll('.js-modality-model-select').forEach(function(select) {
                var modality = select.getAttribute('data-modality') || '';
                var modelCode = (select.value || '').trim();
                if (modality && modelCode) bindings[modality] = modelCode;
            });
            if (Object.keys(bindings).length === 0) {
                BackendToast.warning('<?= __('请至少选择一个能力模型') ?>');
                return;
            }
            showLoading();
            var opts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify({ ids: ids, model_bindings: bindings }) };
            var api = window.Weline && window.Weline.Api ? window.Weline.Api : { request: function(u, o) { return fetch(u, o).then(function(r) { return r.json(); }); } };
            api.request(WelineAdapterManager.urls.batchSaveModelBindings, opts).then(function(res) {
                var data = (res && res.data) || res;
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('模型绑定已保存') ?>');
                    var modal = document.getElementById('batchModelBindingModal');
                    if (modal && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        var m = bootstrap.Modal.getInstance(modal);
                        if (m) m.hide();
                    }
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message || '<?= __('模型绑定保存失败') ?>');
                }
            }).catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + (e.message || e));
            });
        },

        filterRows: function(keyword) {
            var normalized = (keyword || '').trim().toLowerCase();
            var rows = document.querySelectorAll('.adapter-table tbody tr');
            var visibleCount = 0;

            rows.forEach(function(row) {
                var text = [
                    row.children[1] ? row.children[1].innerText : '',
                    row.children[2] ? row.children[2].innerText : '',
                    row.children[4] ? row.children[4].innerText : '',
                    row.children[5] ? row.children[5].innerText : '',
                    row.children[6] ? row.children[6].innerText : ''
                ].join(' ').toLowerCase();
                var matched = normalized === '' || text.indexOf(normalized) !== -1;
                row.style.display = matched ? '' : 'none';
                if (!matched) {
                    var checkbox = row.querySelector('.row-checkbox');
                    if (checkbox) checkbox.checked = false;
                } else {
                    visibleCount++;
                }
            });

            var emptyState = document.getElementById('adapterSearchEmpty');
            if (emptyState) {
                emptyState.classList.toggle('show', normalized !== '' && visibleCount === 0);
            }

            this.updateSelection();
        }
    };

    window.WelineAdapterManager = WelineAdapterManager;

    (function bindBatchModelBindingSave() {
        var saveBtn = document.getElementById('batchModelBindingSaveBtn');
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                WelineAdapterManager._doBatchSaveDefaultModel();
            });
        }
    })();

    (function bindAdapterSearch() {
        var input = document.getElementById('adapterSearchInput');
        if (!input) return;
        input.addEventListener('input', function() {
            WelineAdapterManager.filterRows(input.value);
        });
    })();
})();
</script>
