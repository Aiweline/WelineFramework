<script>
(function() {
    'use strict';
    
    var WelineAdapterManager = {
        urls: {
            scan: '<?= $this->getBackendUrl('*/backend/adapter/scan') ?>',
            toggleStatus: '<?= $this->getBackendUrl('*/backend/adapter/toggleStatus') ?>',
            delete: '<?= $this->getBackendUrl('*/backend/adapter/delete') ?>',
            batchDelete: '<?= $this->getBackendUrl('*/backend/adapter/batchDelete') ?>',
            batchToggle: '<?= $this->getBackendUrl('*/backend/adapter/batchToggle') ?>',
            cleanup: '<?= $this->getBackendUrl('*/backend/adapter/cleanup') ?>'
        },

        scan: function() {
            BackendConfirm.show('<?= __('确定要扫描场景适配器吗？这将发现所有模块中的适配器并更新数据库记录。') ?>', {
                title: '<?= __('扫描适配器') ?>',
                confirmText: '<?= __('确定扫描') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'info'
            }).then(function(confirmed) {
                if (confirmed) {
                    showLoading();
                    window.location.href = WelineAdapterManager.urls.scan;
                }
            });
        },

        toggleStatus: function(id) {
            BackendConfirm.show('<?= __('确定要切换此适配器的状态吗？') ?>', {
                title: '<?= __('切换状态') ?>',
                confirmText: '<?= __('确定') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doToggleStatus(id);
                }
            });
        },

        _doToggleStatus: function(id) {
            showLoading();
            fetch(this.urls.toggleStatus, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({id: id})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('状态更新成功') ?>');
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message || '<?= __('状态更新失败') ?>');
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        delete: function(id) {
            BackendConfirm.show('<?= __('确定要删除此适配器吗？此操作不可恢复。') ?>', {
                title: '<?= __('删除适配器') ?>',
                confirmText: '<?= __('确定删除') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'danger'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doDelete(id);
                }
            });
        },

        _doDelete: function(id) {
            showLoading();
            fetch(this.urls.delete, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({id: id})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message || '<?= __('删除成功') ?>');
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message || '<?= __('删除失败') ?>');
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        getSelectedIds: function() {
            var ids = [];
            document.querySelectorAll('.row-checkbox:checked').forEach(function(cb) {
                ids.push(parseInt(cb.value));
            });
            return ids;
        },

        updateSelection: function() {
            var ids = this.getSelectedIds();
            var toolbar = document.getElementById('batchToolbar');
            var countEl = document.getElementById('selectCount');
            var selectAll = document.getElementById('selectAll');
            var total = document.querySelectorAll('.row-checkbox').length;
            
            countEl.textContent = ids.length;
            
            if (ids.length > 0) {
                toolbar.classList.add('show');
            } else {
                toolbar.classList.remove('show');
            }
            
            selectAll.checked = ids.length === total && total > 0;
            selectAll.indeterminate = ids.length > 0 && ids.length < total;
        },

        toggleSelectAll: function(checkbox) {
            var checked = checkbox.checked;
            document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                cb.checked = checked;
            });
            this.updateSelection();
        },

        clearSelection: function() {
            document.querySelectorAll('.row-checkbox').forEach(function(cb) {
                cb.checked = false;
            });
            document.getElementById('selectAll').checked = false;
            this.updateSelection();
        },

        batchDelete: function() {
            var ids = this.getSelectedIds();
            if (ids.length === 0) {
                BackendToast.warning('<?= __('请先选择要删除的适配器') ?>');
                return;
            }

            BackendConfirm.show('<?= __('确定要删除选中的') ?> ' + ids.length + ' <?= __('个适配器吗？此操作不可恢复。') ?>', {
                title: '<?= __('批量删除') ?>',
                confirmText: '<?= __('确定删除') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'danger'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doBatchDelete(ids);
                }
            });
        },

        _doBatchDelete: function(ids) {
            showLoading();
            fetch(this.urls.batchDelete, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ids: ids})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        batchToggle: function(status) {
            var ids = this.getSelectedIds();
            if (ids.length === 0) {
                BackendToast.warning('<?= __('请先选择要操作的适配器') ?>');
                return;
            }

            var statusText = status ? '<?= __('激活') ?>' : '<?= __('禁用') ?>';
            BackendConfirm.show('<?= __('确定要') ?>' + statusText + '<?= __('选中的') ?> ' + ids.length + ' <?= __('个适配器吗？') ?>', {
                title: '<?= __('批量') ?>' + statusText,
                confirmText: '<?= __('确定') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    WelineAdapterManager._doBatchToggle(ids, status);
                }
            });
        },

        _doBatchToggle: function(ids, status) {
            showLoading();
            fetch(this.urls.batchToggle, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ids: ids, status: status})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                hideLoading();
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() { location.reload(); }, 500);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(e) {
                hideLoading();
                BackendToast.error('<?= __('请求失败：') ?>' + e.message);
            });
        },

        cleanup: function() {
            BackendConfirm.show('<?= __('确定要清理无效的适配器吗？这将删除代码文件已不存在的适配器记录。') ?>', {
                title: '<?= __('清理无效适配器') ?>',
                confirmText: '<?= __('确定清理') ?>',
                cancelText: '<?= __('取消') ?>',
                type: 'warning'
            }).then(function(confirmed) {
                if (confirmed) {
                    showLoading();
                    window.location.href = WelineAdapterManager.urls.cleanup;
                }
            });
        }
    };

    window.WelineAdapterManager = WelineAdapterManager;
})();
</script>
