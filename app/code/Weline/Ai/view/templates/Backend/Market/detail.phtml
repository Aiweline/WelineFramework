<script>
function rentAssistant(assistantId) {
    if (!confirm('<?= __("确定要租用此助手吗？") ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/market/rent') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'assistant_id=' + assistantId
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            // 可以跳转到我的租用列表
            location.href = '<?= $this->getBackendUrl('*/backend/market/index') ?>';
        } else {
            alert(data.message);
        }
    })
    .catch(error => {
        alert('<?= __("操作失败，请稍后重试") ?>');
        console.error('Error:', error);
    });
}

function showRatingForm() {
    document.getElementById('ratingFormContainer').style.display = 'block';
    document.getElementById('showRatingFormBtn').style.display = 'none';
}

function hideRatingForm() {
    document.getElementById('ratingFormContainer').style.display = 'none';
    document.getElementById('showRatingFormBtn').style.display = 'inline-block';
}

// 评分表单提交
document.addEventListener('DOMContentLoaded', function() {
    const ratingForm = document.getElementById('ratingForm');
    if (ratingForm) {
        ratingForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(ratingForm);
            const params = new URLSearchParams(formData).toString();
            
            fetch('<?= $this->getBackendUrl('*/backend/rating/submit') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: params
            })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
                if (data.success) {
                    hideRatingForm();
                    ratingForm.reset();
                    // 刷新页面显示新评分
                    location.reload();
                }
            })
            .catch(error => {
                alert('<?= __("提交失败，请稍后重试") ?>');
                console.error('Error:', error);
            });
        });
    }
});
</script>

