<script>
// 分页跳转
function changePage(page) {
    const url = new URL(window.location.href);
    url.searchParams.set('page', page);
    window.location.href = url.toString();
}

// 租用助手
function rentAssistant(assistantId) {
    if (!confirm('<?= __("确定要租用此助手吗？") ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/market/rent') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'assistant_id=' + assistantId
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            // 刷新页面或跳转到我的租用列表
            location.reload();
        } else {
            alert(data.message);
        }
    })
    .catch(error => {
        alert('<?= __("操作失败，请稍后重试") ?>');
        console.error('Error:', error);
    });
}
</script>

