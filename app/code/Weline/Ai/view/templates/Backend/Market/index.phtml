<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
// 分页跳转
function changePage(page) {
    const url = new URL(window.location.href);
    url.searchParams.set('page', page);
    window.location.href = url.toString();
}

// 租用助手
function rentAssistant(assistantId) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            title: '<?= __("确认租用") ?>',
            text: '<?= __("确定要租用此助手吗？") ?>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '<?= __("确定租用") ?>',
            cancelButtonText: '<?= __("取消") ?>',
            confirmButtonColor: '#28a745'
        }).then((result) => {
            if (result.isConfirmed) {
                performRent(assistantId);
            }
        });
    } else {
        if (!confirm('<?= __("确定要租用此助手吗？") ?>')) {
            return;
        }
        performRent(assistantId);
    }
}

function performRent(assistantId) {
    fetch('<?= $this->getBackendUrl('*/backend/market/rent') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'assistant_id=' + assistantId
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __("成功") ?>',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log(data.message);
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __("失败") ?>',
                    text: data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message);
            }
        }
    })
    .catch(error => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __("操作失败") ?>',
                text: '<?= __("请稍后重试") ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __("操作失败，请稍后重试") ?>');
        }
        console.error('Error:', error);
    });
}
</script>

