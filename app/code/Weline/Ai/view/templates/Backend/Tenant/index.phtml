<script>
function doSearch() {
    const keyword = document.getElementById('searchInput').value.trim();
    const status = document.getElementById('statusFilter').value;
    window.location.href = '?keyword=' + encodeURIComponent(keyword) + '&status=' + status;
}

document.getElementById('searchInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        doSearch();
    }
});

function filterByStatus(status) {
    const keyword = document.getElementById('searchInput').value.trim();
    window.location.href = '?keyword=' + encodeURIComponent(keyword) + '&status=' + status;
}

function deleteTenant(id, name) {
    if (!confirm('<?= __("确定要删除租户") ?> "' + name + '" <?= __("吗？") ?>')) {
        return;
    }
    
    fetch('<?= $this->getBackendUrl("*/backend/tenant/delete") ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'id=' + id
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('<?= __("删除失败：") ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __("请求失败：") ?>' + error);
    });
}
</script>

