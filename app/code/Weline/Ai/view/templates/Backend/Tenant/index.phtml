<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';

    window.changePage = function(page) {
        var url = new URL(window.location.href);
        url.searchParams.set('p', page);
        window.location.href = url.toString();
    };

    window.toggleTenantStatus = function(tenantId) {
        if (!confirm('<?= __('确定要切换租户状态吗？') ?>')) {
            return;
        }

        fetch('<?= $this->getBackendUrl('*/backend/tenant/toggleStatus') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: tenantId })
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                location.reload();
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('操作失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('操作失败：') ?>' + data.message);
                }
            }
        })
        .catch(function(error) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('操作失败') ?>');
            }
        });
    };

    window.deleteTenant = function(tenantId) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                title: '<?= __('确认删除') ?>',
                text: '<?= __('确定要删除这个租户吗？此操作不可恢复！') ?>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<?= __("确定删除") ?>',
                cancelButtonText: '<?= __("取消") ?>',
                confirmButtonColor: '#d33'
            }).then(function(result) {
                if (result.isConfirmed) {
                    performDelete(tenantId);
                }
            });
        } else {
            if (!confirm('<?= __('确定要删除这个租户吗？此操作不可恢复！') ?>')) {
                return;
            }
            performDelete(tenantId);
        }
    };

    function performDelete(tenantId) {
        fetch('<?= $this->getBackendUrl('*/backend/tenant/delete') ?>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: tenantId })
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: '<?= __('租户已删除') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(function() { location.reload(); });
                } else {
                    location.reload();
                }
            } else {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('删除失败') ?>',
                        text: data.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('删除失败：') ?>' + data.message);
                }
            }
        })
        .catch(function(error) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('操作失败') ?>',
                    text: '<?= __('请重试') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error('<?= __('操作失败') ?>');
            }
        });
    }
})();
</script>
