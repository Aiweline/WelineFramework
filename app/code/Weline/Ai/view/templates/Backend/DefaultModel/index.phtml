<script>
function saveDefaultModel(serviceType) {
    const form = document.getElementById('defaultModelForm');
    // 通过 data-service-type 属性查找对应的隐藏输入框
    const hiddenInput = form.querySelector(`input[data-service-type="${serviceType}"]`);
    let modelCode = hiddenInput ? hiddenInput.value : '';
    // 如果隐藏字段为空，尝试从全局选中状态读取（key 是 id）
    if (!modelCode && window.AiModelSelectSelected) {
        // 通过 data-service-type 查找对应的容器，获取其 id
        const container = form.querySelector(`div[data-service-type="${serviceType}"]`);
        if (container) {
            const selectId = container.id.replace('_container', '');
            modelCode = window.AiModelSelectSelected[selectId] || '';
        }
    }
    const priority = form.querySelector(`input[name="priority_${serviceType}"]`).value;
    const isActive = form.querySelector(`input[name="active_${serviceType}"]`).checked ? 1 : 0;

    if (!modelCode) {
        Swal.fire({
            icon: 'warning',
            title: '<?= __('提示') ?>',
            text: '<?= __('请选择模型') ?>',
            confirmButtonText: '<?= __('确定') ?>'
        });
        return;
    }

    const data = new FormData();
    data.append('service_type', serviceType);
    data.append('model_code', modelCode);
    data.append('priority', priority);
    data.append('is_active', isActive);

    fetch('<?= $this->getBackendUrl('*/backend/default-model/set-default') ?>', {
        method: 'POST',
        body: data
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: '<?= __('成功') ?>',
                text: '<?= __('保存成功！') ?>',
                showConfirmButton: false,
                timer: 1500
            });
            updateProtectedModelsList();
        } else {
            Swal.fire({
                icon: 'error',
                title: '<?= __('错误') ?>',
                text: '<?= __('保存失败：') ?>' + data.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        }
    })
    .catch(error => {
        Swal.fire({
            icon: 'error',
            title: '<?= __('请求失败') ?>',
            text: '<?= __('请求失败：') ?>' + error.message,
            confirmButtonText: '<?= __('确定') ?>'
        });
    });
}

function saveAllDefaultModels() {
    Swal.fire({
        title: '<?= __('确认') ?>',
        text: '<?= __('确定要保存所有默认模型配置吗？') ?>',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: '<?= __('确定') ?>',
        cancelButtonText: '<?= __('取消') ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            const form = document.getElementById('defaultModelForm');
            const configurations = [];
            
            // 收集所有服务类型的配置
            <?php foreach ($serviceTypes as $type => $label): ?>
            {
                const serviceType = '<?= $type ?>';
                // 通过 data-service-type 属性查找对应的隐藏输入框
                const hiddenInput = form.querySelector(`input[data-service-type="${serviceType}"]`);
                let modelCode = hiddenInput ? hiddenInput.value : '';
                
                // 如果隐藏字段为空，尝试从全局选中状态读取
                if (!modelCode && window.AiModelSelectSelected) {
                    const container = form.querySelector(`div[data-service-type="${serviceType}"]`);
                    if (container) {
                        const selectId = container.id.replace('_container', '');
                        modelCode = window.AiModelSelectSelected[selectId] || '';
                    }
                }
                
                const priority = form.querySelector(`input[name="priority_${serviceType}"]`).value || 100;
                const isActive = form.querySelector(`input[name="active_${serviceType}"]`).checked ? 1 : 0;
                
                configurations.push({
                    service_type: serviceType,
                    model_code: modelCode,
                    priority: parseInt(priority) || 100,
                    is_active: isActive
                });
            }
            <?php endforeach; ?>
            
            // 发送批量保存请求
            const data = new FormData();
            data.append('configurations', JSON.stringify(configurations));
            
            Swal.fire({
                title: '<?= __('保存中...') ?>',
                text: '<?= __('正在保存所有配置，请稍候...') ?>',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
            
            fetch('<?= $this->getBackendUrl('*/backend/default-model/batch-set') ?>', {
                method: 'POST',
                body: data
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('保存成功') ?>',
                        text: '<?= __('所有默认模型配置已成功保存！') ?>',
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        // 刷新页面以更新数据
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: '<?= __('保存失败：') ?>' + (data.message || '<?= __('未知错误') ?>'),
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('请求失败') ?>',
                    text: '<?= __('请求失败：') ?>' + error.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            });
        }
    });
}

function clearCache() {
    Swal.fire({
        title: '<?= __('确定要清除默认模型缓存吗？') ?>',
        text: '<?= __('此操作将刷新默认模型配置缓存。') ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: '<?= __('确定清除') ?>',
        cancelButtonText: '<?= __('取消') ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('<?= $this->getBackendUrl('*/backend/default-model/clear-cache') ?>', {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire(
                        '<?= __('已清除！') ?>',
                        '<?= __('默认模型缓存已成功清除。') ?>',
                        'success'
                    );
                } else {
                    Swal.fire(
                        '<?= __('清除失败！') ?>',
                        '<?= __('清除失败：') ?>' + data.message,
                        'error'
                    );
                }
            })
            .catch(error => {
                Swal.fire(
                    '<?= __('请求失败！') ?>',
                    '<?= __('请求失败：') ?>' + error.message,
                    'error'
                );
            });
        }
    });
}

function initDefaultModels() {
    Swal.fire({
        title: '<?= __('确定要初始化所有默认模型配置吗？') ?>',
        text: '<?= __('此操作将重置所有服务类型的默认模型为系统推荐配置。') ?>',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: '<?= __('确定初始化') ?>',
        cancelButtonText: '<?= __('取消') ?>'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('<?= $this->getBackendUrl('*/backend/default-model/initialize') ?>', {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire(
                        '<?= __('初始化成功！') ?>',
                        '<?= __('默认配置已成功初始化。') ?>',
                        'success'
                    ).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire(
                        '<?= __('初始化失败！') ?>',
                        '<?= __('初始化失败：') ?>' + data.message,
                        'error'
                    );
                }
            })
            .catch(error => {
                Swal.fire(
                    '<?= __('请求失败！') ?>',
                    '<?= __('请求失败：') ?>' + error.message,
                    'error'
                );
            });
        }
    });
}

function updateProtectedModelsList() {
    fetch('<?= $this->getBackendUrl('*/backend/default-model/get-protected') ?>')
        .then(response => response.json())
        .then(data => {
            const container = document.getElementById('protectedModelsList');
            if (data.success && data.data.length > 0) {
                let html = '<ul class="list-group">';
                data.data.forEach(model => {
                    html += `<li class="list-group-item">
                        <strong>${model.model_name}</strong> (${model.vendor}) 
                        - <span class="badge badge-primary">${model.service_types.join(', ')}</span>
                    </li>`;
                });
                html += '</ul>';
                container.innerHTML = html;
            } else {
                container.innerHTML = '<p class="text-muted"><?= __('暂无受保护的模型') ?></p>';
            }
        });
}

// 页面加载时获取受保护的模型列表
document.addEventListener('DOMContentLoaded', updateProtectedModelsList);
