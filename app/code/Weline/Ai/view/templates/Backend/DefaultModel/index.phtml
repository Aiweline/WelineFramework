    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5><?= __('受保护的模型') ?></h5>
    </div>
    <div class="card-body">
        <p class="text-muted"><?= __('以下模型被设置为默认模型，无法删除：') ?></p>
        <div id="protectedModelsList"></div>
    </div>
</div>

<script>
function saveDefaultModel(serviceType) {
    const form = document.getElementById('defaultModelForm');
    const modelCode = form.querySelector(`select[name="model_${serviceType}"]`).value;
    const priority = form.querySelector(`input[name="priority_${serviceType}"]`).value;
    const isActive = form.querySelector(`input[name="active_${serviceType}"]`).checked ? 1 : 0;

    if (!modelCode) {
        alert('<?= __('请选择模型') ?>');
        return;
    }

    const data = new FormData();
    data.append('service_type', serviceType);
    data.append('model_code', modelCode);
    data.append('priority', priority);
    data.append('is_active', isActive);

    fetch('<?= $this->getBackendUrl('*/backend/defaultModel/save') ?>', {
        method: 'POST',
        body: data
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('保存成功！') ?>');
            updateProtectedModelsList();
        } else {
            alert('<?= __('保存失败：') ?>' + data.message);
        }
    })
    .catch(error => {
        alert('<?= __('请求失败：') ?>' + error.message);
    });
}

function saveAllDefaultModels() {
    if (!confirm('<?= __('确定要保存所有默认模型配置吗？') ?>')) {
        return;
    }

    // 实现批量保存逻辑
    alert('<?= __('功能开发中...') ?>');
}

function clearCache() {
    if (!confirm('<?= __('确定要清除默认模型缓存吗？') ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/defaultModel/clearCache') ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('缓存已清除！') ?>');
        } else {
            alert('<?= __('清除失败：') ?>' + data.message);
        }
    });
}

function initDefaultModels() {
    if (!confirm('<?= __('这将初始化所有默认模型配置，确定继续吗？') ?>')) {
        return;
    }

    fetch('<?= $this->getBackendUrl('*/backend/defaultModel/init') ?>', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('初始化成功！') ?>');
            location.reload();
        } else {
            alert('<?= __('初始化失败：') ?>' + data.message);
        }
    });
}

function updateProtectedModelsList() {
    fetch('<?= $this->getBackendUrl('*/backend/defaultModel/getProtected') ?>')
        .then(response => response.json())
        .then(data => {
            const container = document.getElementById('protectedModelsList');
            if (data.success && data.data.length > 0) {
                let html = '<ul class="list-group">';
                data.data.forEach(model => {
                    html += `<li class="list-group-item">
                        <strong>${model.model_name}</strong> (${model.vendor}) 
                        - <span class="badge badge-primary">${model.service_types.join(', ')}</span>
                    </li>`;
                });
                html += '</ul>';
                container.innerHTML = html;
            } else {
                container.innerHTML = '<p class="text-muted"><?= __('暂无受保护的模型') ?></p>';
            }
        });
}

// 页面加载时获取受保护的模型列表
document.addEventListener('DOMContentLoaded', updateProtectedModelsList);
</script>

