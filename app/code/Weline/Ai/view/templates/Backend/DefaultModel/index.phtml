<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>

<script>
(function() {
    'use strict';
    
    window.saveDefaultModel = function(serviceType) {
        var form = document.getElementById('defaultModelForm');
        var hiddenInput = form.querySelector('input[data-service-type="' + serviceType + '"]');
        var modelCode = hiddenInput ? hiddenInput.value : '';
        if (!modelCode && window.AiModelSelectSelected) {
            var container = form.querySelector('div[data-service-type="' + serviceType + '"]');
            if (container) {
                var selectId = container.id.replace('_container', '');
                modelCode = window.AiModelSelectSelected[selectId] || '';
            }
        }
        var priority = form.querySelector('input[name="priority_' + serviceType + '"]').value;
        var isActive = form.querySelector('input[name="active_' + serviceType + '"]').checked ? 1 : 0;

        if (!modelCode) {
            Swal.fire({
                icon: 'warning',
                title: '<?= __('提示') ?>',
                text: '<?= __('请选择模型') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
            return;
        }

        var req = window.Weline.Api.resource('ai').defaultSet({
            service_type: serviceType,
            model_code: modelCode,
            priority: parseInt(priority) || 100,
            is_active: isActive
        });
        req.then(function(res) {
            var data = (res && res.data) || res;
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('保存成功！') ?>',
                    showConfirmButton: false,
                    timer: 1500
                });
                updateProtectedModelsList();
            } else {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('错误') ?>',
                    text: '<?= __('保存失败：') ?>' + data.message,
                    confirmButtonText: '<?= __('确定') ?>'
                });
            }
        })
        .catch(function(error) {
            Swal.fire({
                icon: 'error',
                title: '<?= __('请求失败') ?>',
                text: '<?= __('请求失败：') ?>' + error.message,
                confirmButtonText: '<?= __('确定') ?>'
            });
        });
    };

    window.saveAllDefaultModels = function() {
        Swal.fire({
            title: '<?= __('确认') ?>',
            text: '<?= __('确定要保存所有默认模型配置吗？') ?>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: '<?= __('确定') ?>',
            cancelButtonText: '<?= __('取消') ?>'
        }).then(function(result) {
            if (result.isConfirmed) {
                var form = document.getElementById('defaultModelForm');
                var configurations = [];
                
                <?php foreach ($serviceTypes as $type => $label): ?>
                (function() {
                    var serviceType = '<?= $type ?>';
                    var hiddenInput = form.querySelector('input[data-service-type="' + serviceType + '"]');
                    var modelCode = hiddenInput ? hiddenInput.value : '';
                    
                    if (!modelCode && window.AiModelSelectSelected) {
                        var container = form.querySelector('div[data-service-type="' + serviceType + '"]');
                        if (container) {
                            var selectId = container.id.replace('_container', '');
                            modelCode = window.AiModelSelectSelected[selectId] || '';
                        }
                    }
                    
                    var priority = form.querySelector('input[name="priority_' + serviceType + '"]').value || 100;
                    var isActive = form.querySelector('input[name="active_' + serviceType + '"]').checked ? 1 : 0;
                    
                    configurations.push({
                        service_type: serviceType,
                        model_code: modelCode,
                        priority: parseInt(priority) || 100,
                        is_active: isActive
                    });
                })();
                <?php endforeach; ?>
                
                Swal.fire({
                    title: '<?= __('保存中...') ?>',
                    text: '<?= __('正在保存所有配置，请稍候...') ?>',
                    allowOutsideClick: false,
                    didOpen: function() {
                        Swal.showLoading();
                    }
                });
                
                var req = window.Weline.Api.resource('ai').defaultBatchSet({ configurations: configurations });
                req.then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: '<?= __('保存成功') ?>',
                            text: '<?= __('所有默认模型配置已成功保存！') ?>',
                            showConfirmButton: false,
                            timer: 1500
                        }).then(function() {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: '<?= __('保存失败') ?>',
                            text: '<?= __('保存失败：') ?>' + (data.message || '<?= __('未知错误') ?>'),
                            confirmButtonText: '<?= __('确定') ?>'
                        });
                    }
                })
                .catch(function(error) {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('请求失败') ?>',
                        text: '<?= __('请求失败：') ?>' + error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                });
            }
        });
    };

    window.clearCache = function() {
        Swal.fire({
            title: '<?= __('确定要清除默认模型缓存吗？') ?>',
            text: '<?= __('此操作将刷新默认模型配置缓存。') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: '<?= __('确定清除') ?>',
            cancelButtonText: '<?= __('取消') ?>'
        }).then(function(result) {
            if (result.isConfirmed) {
                var req = window.Weline.Api.resource('ai').defaultClearCache();
                req.then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success) {
                        Swal.fire(
                            '<?= __('已清除！') ?>',
                            '<?= __('默认模型缓存已成功清除。') ?>',
                            'success'
                        );
                    } else {
                        Swal.fire(
                            '<?= __('清除失败！') ?>',
                            '<?= __('清除失败：') ?>' + data.message,
                            'error'
                        );
                    }
                })
                .catch(function(error) {
                    Swal.fire(
                        '<?= __('请求失败！') ?>',
                        '<?= __('请求失败：') ?>' + error.message,
                        'error'
                    );
                });
            }
        });
    };

    window.initDefaultModels = function() {
        Swal.fire({
            title: '<?= __('确定要初始化所有默认模型配置吗？') ?>',
            text: '<?= __('此操作将重置所有服务类型的默认模型为系统推荐配置。') ?>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: '<?= __('确定初始化') ?>',
            cancelButtonText: '<?= __('取消') ?>'
        }).then(function(result) {
            if (result.isConfirmed) {
                var req = window.Weline.Api.resource('ai').defaultInitialize();
                req.then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success) {
                        Swal.fire(
                            '<?= __('初始化成功！') ?>',
                            '<?= __('默认配置已成功初始化。') ?>',
                            'success'
                        ).then(function() {
                            location.reload();
                        });
                    } else {
                        Swal.fire(
                            '<?= __('初始化失败！') ?>',
                            '<?= __('初始化失败：') ?>' + data.message,
                            'error'
                        );
                    }
                })
                .catch(function(error) {
                    Swal.fire(
                        '<?= __('请求失败！') ?>',
                        '<?= __('请求失败：') ?>' + error.message,
                        'error'
                    );
                });
            }
        });
    };

    function updateProtectedModelsList() {
        var req = window.Weline.Api.resource('ai').defaultProtected();
        req.then(function(res) {
            var data = (res && res.data) || res;
                var container = document.getElementById('protectedModelsList');
                if (!container) {
                    return;
                }
                container.replaceChildren();
                if (data.success && data.data.length > 0) {
                    var list = document.createElement('ul');
                    list.className = 'list-group';
                    data.data.forEach(function(model) {
                        var item = document.createElement('li');
                        item.className = 'list-group-item';
                        var name = document.createElement('strong');
                        name.textContent = model.model_name || '';
                        var meta = document.createTextNode(' (' + (model.vendor || '') + ') - ');
                        var badge = document.createElement('span');
                        badge.className = 'badge badge-primary';
                        badge.textContent = Array.isArray(model.service_types) ? model.service_types.join(', ') : '';
                        item.appendChild(name);
                        item.appendChild(meta);
                        item.appendChild(badge);
                        list.appendChild(item);
                    });
                    container.appendChild(list);
                } else {
                    var empty = document.createElement('p');
                    empty.className = 'text-muted';
                    empty.textContent = '<?= __('暂无受保护的模型') ?>';
                    container.appendChild(empty);
                }
            });
    }

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-ai-default-action]');
        if (!trigger) {
            return;
        }
        event.preventDefault();
        var action = trigger.getAttribute('data-ai-default-action');
        if (action === 'init') {
            initDefaultModels();
        } else if (action === 'save') {
            saveDefaultModel(trigger.getAttribute('data-service-type') || '');
        } else if (action === 'save-all') {
            saveAllDefaultModels();
        } else if (action === 'clear-cache') {
            clearCache();
        }
    });

    document.addEventListener('DOMContentLoaded', updateProtectedModelsList);
})();
</script>

