<?php /** @var \Weline\Framework\View\Template $this */ ?>
<div class="position-relative <?= htmlspecialchars($class ?? '') ?>" style="<?= htmlspecialchars($style ?? '') ?>">
    <button type="button" class="btn btn-outline-secondary w-100 text-start" id="<?= htmlspecialchars($id) ?>_trigger" style="height: 38px;">
        <span id="<?= htmlspecialchars($id) ?>_display"><?= !empty($display) ? htmlspecialchars($display) : '<lang>' . __('使用默认模型') . '</lang>' ?></span>
    </button>
    <div id="<?= htmlspecialchars($id) ?>_container" style="display:none; position:absolute; left:0; right:0; top:0; z-index:1060;">
        <input type="text" class="form-control mb-2" id="<?= htmlspecialchars($id) ?>_search" placeholder="<?= htmlspecialchars($placeholder ?? '') ?>" autocomplete="off">
        <input type="hidden" id="<?= htmlspecialchars($id) ?>_code" name="<?= htmlspecialchars($name ?? '') ?>" value="<?= htmlspecialchars($value ?? '') ?>">
        <div class="border rounded shadow bg-white" style="max-height:300px; overflow-y:auto; position:relative;">
            <div id="<?= htmlspecialchars($id) ?>_loading" style="padding:1rem; text-align:center; display:none;"></div>
            <div id="<?= htmlspecialchars($id) ?>_list" style="padding:0.25rem;"></div>
        </div>
    </div>
    <small class="text-muted d-block mt-1"><lang><?= __('提示：点击选择AI模型，输入关键词搜索（800ms防抖）') ?></lang></small>
</div>
<script>(function(){
  const ep = <?= json_encode($api ?? '') ?>;
  const id = <?= json_encode($id) ?>;
  const limit = <?= (int)($limit ?? 50) ?>;
  const serviceType = <?= json_encode($service_type ?? '') ?>;
  const trigger = document.getElementById(id+"_trigger");
  const box = document.getElementById(id+"_container");
  const list = document.getElementById(id+"_list");
  const loading = document.getElementById(id+"_loading");
  const search = document.getElementById(id+"_search");
  const hidden = document.getElementById(id+"_code");
  const display = document.getElementById(id+"_display");
  let cache = null;
  function render(items){
    if(!items||!items.length){ list.innerHTML = '<div class="p-2 text-muted">'+<?= json_encode(__('未找到匹配的模型')) ?>+'</div>'; return; }
    list.innerHTML = items.slice(0,limit).map(function(m){
      const txt = `${m.name} (${m.supplier}) - ${m.version}`;
      return `<div class="p-2 border-bottom model-item" style="cursor:pointer" data-code="${m.code}" data-text="${txt}">${txt}</div>`;
    }).join("");
    list.querySelectorAll('[data-code]').forEach(function(el){
      el.addEventListener('click', function(){
        hidden.value = this.dataset.code;
        try{ hidden.setAttribute('value', this.dataset.code); }catch(e){}
        try{ hidden.dispatchEvent(new Event('change')); }catch(e){}
        try{ window.AiModelSelectSelected = window.AiModelSelectSelected||{}; window.AiModelSelectSelected[serviceType]=this.dataset.code; }catch(e){}
        display.textContent = this.dataset.text;
        box.style.display = 'none';
        trigger.style.display = 'block';
        list.querySelectorAll('.model-item').forEach(function(li){ li.classList.remove('active'); });
        this.classList.add('active');
      });
    });
    if(hidden.value){
      const act = list.querySelector(`.model-item[data-code="${hidden.value}"]`);
      if(act) act.classList.add('active');
    }
  }
  function firstLoad(){
    loading.style.display = 'block';
    var url = ep+'?limit='+limit;
    window.Weline.Api.get(url, { silent: true })
      .then(function(res){ var body = (res&&res.data)||res; loading.style.display='none'; cache=(body&&body.success)?(body.data||[]):[]; render(cache); })
      .catch(()=>{ loading.style.display='none'; list.innerHTML='<div class="p-2 text-danger">'+<?= json_encode(__('加载失败')) ?>+'</div>'; });
  }
  const debounce=(fn,t)=>{let id=null;return (...a)=>{clearTimeout(id);id=setTimeout(()=>fn.apply(null,a),t);}};
  const doFilter = debounce(function(kw){ kw=(kw||'').toLowerCase().trim(); if(!kw){ render(cache||[]); return;} var u=ep+'?search='+encodeURIComponent(kw); window.Weline.Api.get(u, { silent: true }).then(function(res){ var body=(res&&res.data)||res; render((body&&body.success)?(body.data||[]):[]); }).catch(function(){ var data=(cache||[]).filter(function(m){ return (`${m.name} ${m.supplier} ${m.code} ${m.version}`).toLowerCase().includes(kw); }); render(data); }); },800);
  trigger.addEventListener('click', function(e){ e.stopPropagation(); box.style.top=(trigger.offsetHeight+6)+'px'; box.style.width='100%'; box.style.display='block'; firstLoad(); setTimeout(()=>search.focus(),50); setTimeout(function(){ document.addEventListener('click', closeOutside); document.addEventListener('keydown', esc); },0); });
  search.addEventListener('input', function(){ doFilter(this.value); });
  function closeOutside(ev){ if(!(box.contains(ev.target)||trigger.contains(ev.target))){ box.style.display='none'; trigger.style.display='block'; document.removeEventListener('click', closeOutside); document.removeEventListener('keydown', esc); }}
  function esc(e){ if(e.key==='Escape'){ box.style.display='none'; trigger.style.display='block'; document.removeEventListener('click', closeOutside); document.removeEventListener('keydown', esc); }}
})();</script>


