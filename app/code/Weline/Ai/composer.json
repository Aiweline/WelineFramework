{
    "name": "weline/module-ai",
    "description": "AI助手工具模块 - 统一的AI模型管理和助手工具平台",
    "type": "weline-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Aiweline",
            "email": "aiweline@qq.com",
            "homepage": "https://aiweline.com"
        }
    ],
  "require": {
    "php": "^8.4",
    "weline/framework": "@dev",
    "weline/module-admin": "@dev",
    "weline/module-backend": "@dev"
  },
    "suggest": {
        "weline/module-i18n": "Enables the optional I18n machine-translation event integration."
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Weline\\Ai\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Weline\\Ai\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "stan": "phpstan analyse",
        "quality": [
            "@cs-check",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
