    "account_setup_guide": {
        "title": "VectorEngine 接入指南",
        "summary": "VectorEngine 使用 OpenAI 兼容的 Bearer Token 鉴权方式，支持 models 列表、聊天补全、Embedding 和部分文生图模型。",
        "links": [
            {
                "label": "VectorEngine 文档库",
                "url": "https://vectorengine.apifox.cn"
            },
            {
                "label": "模型列表接口",
                "url": "https://vectorengine.apifox.cn/api-349239086"
            }
        ],
        "steps": [
            "打开 VectorEngine 控制台或文档库，创建并复制 API Key / Bearer Token。",
            "回到 Weline 后台 AI > 供应商账户，供应商选择 VectorEngine。",
            "账户名称建议填写 VectorEngine 或业务用途名称。",
            "API 密钥粘贴 VectorEngine 提供的 API Key，不需要手动加 Bearer 前缀。",
            "API 基础 URL 默认使用 https://api.vectorengine.ai/v1；如果你的控制台给出 https://api.vectorengine.cn/v1，也可以按实际地址填写。",
            "保存后点击连接测试，系统会先调用 /v1/models 拉取当前账户可用模型，并让你选择一个模型进行测试。",
            "测试通过后，到 AI 模型中新建或从供应商 models 接口选择模型；文生图模型会标记为 text2image，供 AI 建站工作台选择。"
        ],
        "field_hints": {
            "provider_code": "VectorEngine",
            "account_name": "VectorEngine",
            "api_key": "粘贴 VectorEngine API Key / Bearer Token",
            "base_url": "默认 https://api.vectorengine.ai/v1；如控制台给出 .cn 域名则以控制台为准",
            "balance": "可选，仅用于后台展示/排序；不了解可先填 1",
            "currency": "USD"
        },
        "notes": [
            "models 接口为 GET /v1/models，鉴权为 Authorization: Bearer <token>。",
            "文本模型走 POST /v1/chat/completions。",
            "Embedding 模型走 POST /v1/embeddings。",
            "OpenAI 兼容文生图模型走 POST /v1/images/generations。"
        ]
    },
