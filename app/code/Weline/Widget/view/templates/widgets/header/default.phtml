<?php
/** @var \Weline\Framework\View\Template $this */
$title = $this->getData('title') ?? '网站标题';
$logo = $this->getData('logo') ?? '';
$showSearch = $this->getData('show_search') ?? true;
$navItems = $this->getData('nav_items') ?? [];
?>
<header class="widget-header widget-header-default">
    <div class="container">
        <div class="row align-items-center py-3">
            <div class="col-auto">
                <?php if ($logo): ?>
                    <img src="<?= htmlspecialchars($logo) ?>" alt="<?= htmlspecialchars($title) ?>" class="logo" style="max-height: 50px;">
                <?php else: ?>
                    <h4 class="mb-0"><?= htmlspecialchars($title) ?></h4>
                <?php endif; ?>
            </div>
            <div class="col">
                <?php if (!empty($navItems)): ?>
                <nav class="main-nav">
                    <ul class="nav">
                        <?php foreach ($navItems as $item): ?>
                        <li class="nav-item">
                            <a class="nav-link" href="<?= htmlspecialchars($item['url'] ?? '#') ?>">
                                <?= htmlspecialchars($item['label'] ?? '') ?>
                            </a>
                        </li>
                        <?php endforeach; ?>
                    </ul>
                </nav>
                <?php endif; ?>
            </div>
            <?php if ($showSearch): ?>
            <div class="col-auto">
                <form class="search-form d-flex">
                    <input type="search" class="form-control" placeholder="搜索...">
                    <button type="submit" class="btn btn-primary ms-2">
                        <i class="ri-search-line"></i>
                    </button>
                </form>
            </div>
            <?php endif; ?>
        </div>
    </div>
</header>
<style>
.widget-header {
    background-color: #fff;
    border-bottom: 1px solid #dee2e6;
}
.widget-header .main-nav .nav {
    margin-bottom: 0;
}
</style>

