<script>
function viewWidgetDetail(type, name) {
    const modal = new bootstrap.Modal(document.getElementById('widget-detail-modal'));
    const content = document.getElementById('widget-detail-content');
    
    content.innerHTML = '<div class="text-center py-5"><div class="spinner-border" role="status"></div></div>';
    modal.show();
    
    fetch('<?= $this->getUrlBuilder()->getBackendUrl('widget/backend/widget/detail') ?>&type=' + encodeURIComponent(type) + '&name=' + encodeURIComponent(name))
        .then(response => response.json())
        .then(data => {
            if (data.success && data.widget) {
                const widget = data.widget;
                let html = '<div class="widget-detail">';
                html += '<h6>' + (widget.name || name) + '</h6>';
                html += '<p class="text-muted">' + (widget.description || '') + '</p>';
                html += '<table class="table table-sm">';
                html += '<tr><th><?= __('类型') ?>:</th><td>' + type + '</td></tr>';
                html += '<tr><th><?= __('名称') ?>:</th><td>' + name + '</td></tr>';
                html += '<tr><th><?= __('来源模块') ?>:</th><td>' + (widget.module || '') + '</td></tr>';
                html += '<tr><th><?= __('版本') ?>:</th><td>' + (widget.version || '1.0.0') + '</td></tr>';
                html += '</table>';
                
                if (widget.params && Object.keys(widget.params).length > 0) {
                    html += '<h6 class="mt-3"><?= __('参数配置') ?></h6>';
                    html += '<table class="table table-sm">';
                    html += '<thead><tr><th><?= __('参数名') ?></th><th><?= __('类型') ?></th><th><?= __('默认值') ?></th><th><?= __('说明') ?></th></tr></thead>';
                    html += '<tbody>';
                    for (const [key, param] of Object.entries(widget.params)) {
                        html += '<tr>';
                        html += '<td>' + key + '</td>';
                        html += '<td><span class="badge bg-secondary">' + (param.type || 'string') + '</span></td>';
                        html += '<td>' + (param.default !== undefined ? JSON.stringify(param.default) : '') + '</td>';
                        html += '<td>' + (param.description || '') + '</td>';
                        html += '</tr>';
                    }
                    html += '</tbody></table>';
                }
                
                html += '</div>';
                content.innerHTML = html;
            } else {
                content.innerHTML = '<div class="alert alert-danger">' + (data.message || '<?= __('获取详情失败') ?>') + '</div>';
            }
        })
        .catch(error => {
            content.innerHTML = '<div class="alert alert-danger"><?= __('加载失败') ?>: ' + error.message + '</div>';
        });
}
</script>

