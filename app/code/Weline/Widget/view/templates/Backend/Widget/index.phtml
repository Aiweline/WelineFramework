<js:part>
(function () {
    'use strict';

    var WIDGET_DETAIL_URL = <?= json_encode($this->getBackendUrl('widget/backend/widget/detail'), $jsonForScriptFlags) ?>;

    function escapeHtml(str) {
        if (str === null || str === undefined) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function ensureModal() {
        var modalEl = document.getElementById('widgetDetailModal');
        if (modalEl) return modalEl;

        modalEl = document.createElement('div');
        modalEl.className = 'modal fade';
        modalEl.id = 'widgetDetailModal';
        modalEl.tabIndex = -1;
        modalEl.setAttribute('aria-hidden', 'true');
        modalEl.innerHTML = '' +
            '<div class="modal-dialog modal-lg">' +
            '  <div class="modal-content">' +
            '    <div class="modal-header">' +
            '      <h5 class="modal-title" id="widgetDetailModalLabel"><?= __('部件详情') ?></h5>' +
            '      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<?= __('关闭') ?>"></button>' +
            '    </div>' +
            '    <div class="modal-body" id="widgetDetailModalBody">' +
            '      <div class="text-muted"><?= __('加载中...') ?></div>' +
            '    </div>' +
            '    <div class="modal-footer">' +
            '      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('关闭') ?></button>' +
            '    </div>' +
            '  </div>' +
            '</div>';

        document.body.appendChild(modalEl);
        return modalEl;
    }

    window.viewWidgetDetail = function (type, name) {
        if (!type || !name) return;

        var modalEl = ensureModal();
        var bodyEl = modalEl.querySelector('#widgetDetailModalBody');
        var labelEl = modalEl.querySelector('#widgetDetailModalLabel');
        if (bodyEl) bodyEl.innerHTML = '<div class="text-muted"><?= __('加载中...') ?></div>';
        if (labelEl) labelEl.textContent = '<?= __('部件详情') ?>';

        var url = WIDGET_DETAIL_URL + '?type=' + encodeURIComponent(type) + '&name=' + encodeURIComponent(name);
        fetch(url, { credentials: 'include' })
            .then(function (resp) { return resp.json(); })
            .then(function (data) {
                if (!data || !data.success) {
                    if (bodyEl) bodyEl.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml((data && data.message) ? data.message : '<?= __('操作失败') ?>') + '</div>';
                    return;
                }

                var widget = data.widget || {};
                if (labelEl) labelEl.textContent = widget.name ? escapeHtml(widget.name) : (name || '');

                var params = widget.params || {};
                var description = widget.description || '';
                var module = widget.module || '';
                var version = widget.version || '';

                var paramsText = '';
                try {
                    paramsText = JSON.stringify(params, null, 2);
                } catch (e) {
                    paramsText = String(params);
                }

                if (bodyEl) {
                    bodyEl.innerHTML =
                        '<div class="row g-3">' +
                        '  <div class="col-12">' +
                        '    <div class="card border-0 bg-light">' +
                        '      <div class="card-body">' +
                        '        <div class="d-flex flex-wrap gap-2 mb-2">' +
                        '          <span class="badge text-bg-info"><?= __('类型') ?>: ' + escapeHtml(type || '') + '</span>' +
                        '          <span class="badge text-bg-secondary"><?= __('模块') ?>: ' + escapeHtml(module) + '</span>' +
                        '          <span class="badge text-bg-primary"><?= __('版本') ?>: ' + escapeHtml(version || '') + '</span>' +
                        '        </div>' +
                        '        <div class="text-muted mb-0">' + escapeHtml(description) + '</div>' +
                        '      </div>' +
                        '    </div>' +
                        '  </div>' +
                        '  <div class="col-12">' +
                        '    <h6 class="mb-2"><?= __('参数配置') ?></h6>' +
                        '    <pre class="bg-light p-2 rounded mb-0" style="white-space: pre-wrap;">' + escapeHtml(paramsText) + '</pre>' +
                        '  </div>' +
                        '</div>';
                }

                try {
                    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                } catch (e) {
                    // ignore: 不影响主要功能
                }
            })
            .catch(function () {
                if (bodyEl) bodyEl.innerHTML = '<div class="alert alert-danger mb-0"><?= __('操作失败') ?></div>';
                try {
                    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                } catch (e) {
                    // ignore
                }
            });
    };

    if (!window.__widgetDetailActionsBound) {
        window.__widgetDetailActionsBound = true;
        document.addEventListener('click', function (event) {
            var trigger = event.target.closest('[data-widget-detail-trigger]');
            if (!trigger) return;

            event.preventDefault();
            window.viewWidgetDetail(
                trigger.getAttribute('data-widget-type') || '',
                trigger.getAttribute('data-widget-name') || ''
            );
        });
    }
})();
</js:part>

