$jsonAttribute = static function (mixed $value): string {
    $json = \json_encode(
        $value,
        JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT
    ) ?: '{}';
    return htmlspecialchars($json, ENT_QUOTES, 'UTF-8');
};
