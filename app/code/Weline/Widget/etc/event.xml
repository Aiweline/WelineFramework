<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 系统升级后：自动收集部件并生成注册表（在标签收集之后执行） -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Widget::setup_upgrade_after" instance="Weline\Widget\Observer\SetupUpgradeAfter" disabled="false" shared="true" sort="50"/>
    </event>
    
    <!-- 模块升级后：重新收集部件（检测到模块升级时） -->
    <event name="Weline_Framework_Module::module_upgrade">
        <observer name="Weline_Widget::module_upgrade_after" instance="Weline\Widget\Observer\ModuleUpgradeAfter" disabled="false" shared="true" sort="0"/>
    </event>
    
    <!-- 模块安装后：收集部件（检测到模块安装时） -->
    <event name="Weline_Framework_Module::module_install_after">
        <observer name="Weline_Widget::module_install_after" instance="Weline\Widget\Observer\ModuleInstallAfter" disabled="false" shared="true" sort="0"/>
    </event>
</config>
