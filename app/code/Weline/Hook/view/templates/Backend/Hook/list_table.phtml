                                    <span class="text-muted">无文件</span>
                                <?php endif; ?>
                            </div>
                        </td>
                        <td>
                            <div class="hook-status">
                                <?php if ($hookInfo['is_registered'] ?? false): ?>
                                    <span class="badge badge-success" title="已进入编译 Hook 注册表">已注册</span>
                                <?php else: ?>
