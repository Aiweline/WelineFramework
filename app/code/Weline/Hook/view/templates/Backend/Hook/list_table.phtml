                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>

    <?php if ($totalPages > 1): ?>
        <div class="pagination-bar">
            <div class="pagination-summary">
                每页 <?= $perPage ?> 条，共 <?= $totalPages ?> 页
            </div>
            <div class="pagination-actions">
                <a class="btn btn-sm btn-secondary pagination-link<?= $currentPage <= 1 ? ' disabled' : '' ?>"
                   href="<?= $currentPage <= 1 ? '#' : ('?' . $buildQuery(['page' => $currentPage - 1])) ?>"
                   aria-disabled="<?= $currentPage <= 1 ? 'true' : 'false' ?>"
                   data-page="<?= max(1, $currentPage - 1) ?>">
                    上一页
                </a>
                <?php
                $startPage = max(1, $currentPage - 2);
                $endPage = min($totalPages, $currentPage + 2);
                for ($page = $startPage; $page <= $endPage; $page++):
                ?>
                    <a class="btn btn-sm <?= $page === $currentPage ? 'btn-primary' : 'btn-outline-primary' ?> pagination-link"
                       href="?<?= $buildQuery(['page' => $page]) ?>"
                       data-page="<?= $page ?>">
                        <?= $page ?>
                    </a>
                <?php endfor; ?>
                <a class="btn btn-sm btn-secondary pagination-link<?= $currentPage >= $totalPages ? ' disabled' : '' ?>"
                   href="<?= $currentPage >= $totalPages ? '#' : ('?' . $buildQuery(['page' => $currentPage + 1])) ?>"
                   aria-disabled="<?= $currentPage >= $totalPages ? 'true' : 'false' ?>"
                   data-page="<?= min($totalPages, $currentPage + 1) ?>">
                    下一页
                </a>
            </div>
        </div>
    <?php endif; ?>
<?php endif; ?>
