<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
document.addEventListener('click', function(event) {
    const trigger = event.target.closest('[data-hook-copy]');
    if (!trigger) return;
    event.preventDefault();
    copyHookName();
});

function copyHookName() {
    const hookCode = document.getElementById('hook-code-value');
    if (!hookCode) return;
    
    const text = hookCode.textContent;
    
    // 使用现代 Clipboard API
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            showCopySuccess();
        }).catch(function(err) {
            console.error('复制失败:', err);
            fallbackCopyText(text);
        });
    } else {
        // 降级方案
        fallbackCopyText(text);
    }
}

function fallbackCopyText(text) {
    const textArea = document.createElement('textarea');
    textArea.value = text;
    textArea.style.position = 'fixed';
    textArea.style.left = '-999999px';
    document.body.appendChild(textArea);
    textArea.select();
    try {
        document.execCommand('copy');
        showCopySuccess();
    } catch (err) {
        console.error('复制失败:', err);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'warning',
                title: '<?= __('复制失败') ?>',
                text: '<?= __('请手动复制') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('复制失败，请手动复制');
        }
    }
    document.body.removeChild(textArea);
}

function showCopySuccess() {
    const btn = document.querySelector('.btn-copy');
    if (!btn) return;
    
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<i class="mdi mdi-check"></i>';
    btn.style.color = '#28a745';
    setTimeout(function() {
        btn.innerHTML = originalHTML;
        btn.style.color = '';
    }, 2000);
}
</script>
