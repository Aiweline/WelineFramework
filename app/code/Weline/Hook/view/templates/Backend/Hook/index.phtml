<script>
// 异步搜索功能
(function() {
    let searchTimeout = null;
    const backendUrlPrefix = '<?= $backendUrlPrefix ?>';
    const hooksListContainer = document.querySelector('.hooks-list');
    const filterForm = document.querySelector('.filter-form');

    function escapeHtml(value) {
        const div = document.createElement('div');
        div.textContent = value == null ? '' : String(value);
        return div.innerHTML;
    }
    
    // 执行异步搜索
    function performSearch() {
        if (!filterForm || !hooksListContainer) return;
        
        // 显示加载状态
        hooksListContainer.innerHTML = '<div class="text-center p-5"><div class="spinner-border" role="status"><span class="visually-hidden">加载中...</span></div><p class="mt-3">正在搜索...</p></div>';
        
        // 收集表单数据
        const formData = new FormData(filterForm);
        const params = new URLSearchParams();
        for (const [key, value] of formData.entries()) {
            if (value) {
                params.append(key, value);
            }
        }
        
        // 构建 AJAX URL
        const searchUrl = backendUrlPrefix + '/hook/backend/hook/search-ajax?' + params.toString();
        
        var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } };
        window.Weline.Api.get(searchUrl, opts)
        .then(function(response) {
            var data = (response && response.data) || response;
            if (!response || response.ok === false) {
                throw new Error((data && (data.message || data.msg)) || 'HTTP error');
            }
            if (data.success) {
                // 更新列表内容
                if (data.html) {
                    hooksListContainer.innerHTML = data.html;
                    // 重新绑定详情按钮事件
                    bindDetailButtons();
                }
                
                // 更新统计信息
                if (data.stats) {
                    updateStats(data.stats);
                }
                
                // 更新 URL（不刷新页面）
                const newUrl = window.location.pathname + '?' + params.toString();
                window.history.pushState({path: newUrl}, '', newUrl);
            } else {
                hooksListContainer.innerHTML = '<div class="alert alert-danger">' + escapeHtml(data.message || '搜索失败') + '</div>';
            }
        })
        .catch(function(error) {
            console.error('搜索失败:', error);
            hooksListContainer.innerHTML = '<div class="alert alert-danger">' + escapeHtml('搜索失败，请稍后重试。错误：' + (error && error.message ? error.message : '')) + '</div>';
        });
    }
    
    // 更新统计信息
    function updateStats(stats) {
        const statsCards = document.querySelectorAll('.stats-cards .card-value');
        if (statsCards.length >= 6) {
            statsCards[0].textContent = stats.total_hooks || 0;
            statsCards[1].textContent = stats.registered_hooks || 0;
            statsCards[2].textContent = stats.hooks_with_files || 0;
            statsCards[3].textContent = stats.unregistered_hooks || 0;
            statsCards[4].textContent = stats.total_files || 0;
            statsCards[5].textContent = stats.hooks_without_files || 0;
        }
    }
    
    // 绑定详情按钮事件
    function bindDetailButtons() {
        // 详情按钮事件已经在下面的代码中通过事件委托绑定，这里不需要重复绑定
    }
    
    // 初始化
    document.addEventListener('DOMContentLoaded', function() {
        if (!filterForm) return;
        
        // 阻止表单默认提交
        filterForm.addEventListener('submit', function(e) {
            e.preventDefault();
            performSearch();
        });
        
        // 下拉框改变时自动搜索
        const selects = filterForm.querySelectorAll('select');
        selects.forEach(select => {
            select.addEventListener('change', function() {
                // 延迟搜索，避免频繁请求
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function() {
                    performSearch();
                }, 300);
            });
        });
        
        // 快速搜索框输入时自动搜索（防抖）
        const quickSearch = document.getElementById('q');
        if (quickSearch) {
            quickSearch.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function() {
                    performSearch();
                }, 500); // 输入后500ms才搜索
            });
            
            // 回车键立即搜索
            quickSearch.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    clearTimeout(searchTimeout);
                    performSearch();
                }
            });
        }
        
        // 排序链接改为异步
        document.addEventListener('click', function(e) {
            const sortLink = e.target.closest('.sort-link');
            if (sortLink && sortLink.dataset.sort) {
                e.preventDefault();
                const sort = sortLink.dataset.sort;
                const order = sortLink.dataset.order;
                
                // 更新表单中的排序值
                const sortSelect = document.getElementById('sort');
                const orderSelect = document.getElementById('order');
                if (sortSelect) sortSelect.value = sort;
                if (orderSelect) orderSelect.value = order;
                
                // 执行搜索
                performSearch();
            }
        });
    });
})();

// Offcanvas 详情功能
(function() {
    let offcanvasElement = null;
    let offcanvasTitle = null;
    let offcanvasBody = null;
    let offcanvasInstance = null;
    
    // 获取 offcanvas 元素
    function getOffcanvasElements() {
        if (!offcanvasElement) {
            offcanvasElement = document.getElementById('hookDetailOffcanvas');
        }
        if (!offcanvasTitle) {
            offcanvasTitle = document.getElementById('hookDetailOffcanvasTitle');
        }
        if (!offcanvasBody) {
            offcanvasBody = document.getElementById('hookDetailOffcanvasBody');
        }
        return offcanvasElement && offcanvasTitle && offcanvasBody;
    }
    
    // 初始化 Bootstrap Offcanvas
    function initOffcanvasInstance() {
        if (!getOffcanvasElements()) {
            return false;
        }
        
        if (typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            if (!offcanvasInstance) {
                offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
            }
            return true;
        }
        return false;
    }
    
    // 打开 offcanvas
    function showOffcanvas() {
        if (!getOffcanvasElements()) {
            console.error('Offcanvas 元素未找到');
            return;
        }
        
        if (initOffcanvasInstance() && offcanvasInstance) {
            offcanvasInstance.show();
        } else if (typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
            offcanvasInstance.show();
        } else {
            // 降级方案：直接操作 DOM
            offcanvasElement.classList.add('show');
            offcanvasElement.setAttribute('aria-hidden', 'false');
            document.body.classList.add('offcanvas-backdrop', 'modal-open');
            // 添加背景遮罩
            const backdrop = document.createElement('div');
            backdrop.className = 'offcanvas-backdrop fade show';
            backdrop.setAttribute('data-bs-dismiss', 'offcanvas');
            backdrop.addEventListener('click', function() {
                hideOffcanvas();
            });
            document.body.appendChild(backdrop);
        }
    }
    
    // 关闭 offcanvas
    function hideOffcanvas() {
        if (offcanvasElement) {
            offcanvasElement.classList.remove('show');
            offcanvasElement.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('offcanvas-backdrop', 'modal-open');
            const backdrop = document.querySelector('.offcanvas-backdrop');
            if (backdrop) {
                backdrop.remove();
            }
        }
    }
    
    // 绑定查看详情按钮事件（使用事件委托）
    function bindDetailButtons() {
        document.addEventListener('click', function(e) {
            const btn = e.target.closest('.btn-view-detail');
            if (!btn) return;
            
            e.preventDefault();
            e.stopPropagation();
            
            const hookName = btn.getAttribute('data-hook-name');
            if (!hookName) {
                console.error('Hook 名未找到', btn);
                return;
            }
            
            // 确保元素已获取
            if (!getOffcanvasElements()) {
                console.error('Offcanvas 元素未找到，请刷新页面重试');
                return;
            }
            
            // 显示加载状态
            offcanvasBody.innerHTML = '<div class="text-center p-5"><div class="spinner-border" role="status"><span class="visually-hidden">加载中...</span></div><p class="mt-3">正在加载 Hook 详情...</p></div>';
            
            // 设置标题
            offcanvasTitle.textContent = 'Hook 详情';
            
            // 打开 offcanvas
            showOffcanvas();
            
            const backendUrlPrefix = '<?= $backendUrlPrefix ?>';
            const detailUrl = backendUrlPrefix + '/hook/backend/hook/detail?hook=' + encodeURIComponent(hookName) + '&isAjax=1';
            var opts = { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } };
            window.Weline.Api.get(detailUrl, opts)
            .then(function(response) {
                var data = (response && response.data) || response;
                if (data.success && data.html) {
                    offcanvasBody.innerHTML = data.html;
                    if (data.title) {
                        offcanvasTitle.textContent = data.title;
                    }
                } else {
                    offcanvasBody.innerHTML = '<div class="alert alert-danger">' + escapeHtml(data.message || '加载失败') + '</div>';
                }
            })
            .catch(function(error) {
                console.error('加载详情失败:', error);
                offcanvasBody.innerHTML = '<div class="alert alert-danger">' + escapeHtml('加载详情失败，请稍后重试。错误：' + (error && error.message ? error.message : '')) + '</div>';
            });
        });
    }
    
    // 初始化
    function init() {
        // 绑定按钮事件
        bindDetailButtons();
        
        // 初始化 offcanvas 实例
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(initOffcanvasInstance, 100);
            });
        } else {
            setTimeout(initOffcanvasInstance, 100);
        }
        
        // 如果 Bootstrap 延迟加载，等待一下
        if (typeof bootstrap === 'undefined') {
            setTimeout(function() {
                if (typeof bootstrap !== 'undefined') {
                    initOffcanvasInstance();
                }
            }, 500);
        }
    }
    
    // 启动初始化
    init();
})();
</script>

