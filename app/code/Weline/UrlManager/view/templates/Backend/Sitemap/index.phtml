<script>
function generateSitemap() {
    const websiteId = document.getElementById('website_id').value;
    const generateAll = websiteId === '0';
    
    if (!confirm('<?= __('确定要生成Sitemap吗？') ?>')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('website_id', websiteId);
    formData.append('generate_all', generateAll ? '1' : '0');
    
    fetch('<?= $this->getBackendUrl('*/backend/sitemap/generate') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('生成Sitemap失败') ?>');
    });
}
</script>

