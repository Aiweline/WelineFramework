                            <div class="wfm-log-meta">
                                <span><?= $escapeHtml($log['time'] ?? '') ?></span>
                                <span><?= $escapeHtml(__('根目录')) ?>: <?= $escapeHtml($log['root'] ?? '') ?></span>
                                <span><?= $escapeHtml(__('路径')) ?>: <?= $escapeHtml($log['relative_path'] ?? '-') ?></span>
                                <?php if (!empty($log['domain'])): ?>
                                    <span><?= $escapeHtml(__('域名')) ?>: <?= $escapeHtml($log['domain']) ?></span>
                                <?php endif; ?>
                                <?php if (!empty($log['ip'])): ?>
                                    <span>IP: <?= $escapeHtml($log['ip']) ?></span>
                                <?php endif; ?>
                            </div>
                            <?php if (!empty($log['message'])): ?>
                                <div class="wfm-help"><?= $escapeHtml($log['message']) ?></div>
                            <?php endif; ?>
                        </article>
                    <?php endforeach; ?>
                </div>
            <?php else: ?>
                <div class="wfm-empty">
                    <?= $escapeHtml(!empty($operationLogSummary['filtered']) ? __('No matching file operation logs.') : __('暂无文件操作日志。')) ?>
                </div>
            <?php endif; ?>
        </section>

        <section class="wfm-section" id="capabilities" aria-labelledby="wfm-capabilities-title">
            <h2 class="wfm-section-title" id="wfm-capabilities-title"><?= $escapeHtml(__('能力阶段')) ?></h2>
            <div class="wfm-capabilities">
                <?php foreach ($capabilities as $capability): ?>
                    <article class="wfm-card">
                        <div class="wfm-card-head">
                            <h3 class="wfm-card-title"><?= $escapeHtml($capability['title'] ?? '') ?></h3>
                            <span class="wfm-status"><?= $escapeHtml($capability['state'] ?? '') ?></span>
                        </div>
                        <p class="wfm-description"><?= $escapeHtml($capability['description'] ?? '') ?></p>
                    </article>
                <?php endforeach; ?>
            </div>
        </section>
    </main>
</div>

<script>
    (function () {
        var shell = document.querySelector('[data-wls-file-manager-shell]');
        var toggle = document.querySelector('[data-wfm-theme-toggle]');
        var label = document.querySelector('[data-wfm-theme-label]');
        var storageKey = 'wls_panel_theme';

        function applyTheme(theme) {
            var nextTheme = theme === 'dark' ? 'dark' : 'light';
            shell.setAttribute('data-theme', nextTheme);
            if (label) {
                label.textContent = nextTheme === 'dark'
                    ? '<?= $escapeHtml(__('浅色')) ?>'
                    : '<?= $escapeHtml(__('深色')) ?>';
            }
        }

        if (!shell) {
            return;
        }

        var savedTheme = 'light';
        try {
            savedTheme = localStorage.getItem(storageKey) || savedTheme;
        } catch (error) {
            savedTheme = 'light';
        }
        applyTheme(savedTheme);

        if (toggle) {
            toggle.addEventListener('click', function () {
                var currentTheme = shell.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
                var nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
                try {
                    localStorage.setItem(storageKey, nextTheme);
                } catch (error) {
                    return;
                }
                applyTheme(nextTheme);
            });
        }
    })();

    (function () {
        var form = document.querySelector('[data-wfm-save-text-form]');
        if (!form) {
            return;
        }

        var shell = form.querySelector('[data-wfm-editor-shell]');
        var textarea = form.querySelector('[data-wfm-editor-textarea]');
        if (!shell || !textarea) {
            return;
        }

        var wrapButton = form.querySelector('[data-wfm-editor-wrap]');
        var fontSizeSelect = form.querySelector('[data-wfm-editor-font-size]');
        var revertButton = form.querySelector('[data-wfm-editor-revert]');
        var dirtyIndicator = form.querySelector('[data-wfm-editor-dirty]');
        var lineCounter = form.querySelector('[data-wfm-editor-lines]');
        var charCounter = form.querySelector('[data-wfm-editor-chars]');
        var byteCounter = form.querySelector('[data-wfm-editor-bytes]');
        var positionLabel = form.querySelector('[data-wfm-editor-position]');
        var confirmPhraseInput = form.querySelector('input[name="confirm_phrase"]');
        var confirmCheckbox = form.querySelector('input[name="confirm_write"]');
        var submitButton = form.querySelector('button[type="submit"]');
        var initialValue = textarea.value;
        var maxBytes = parseInt(textarea.getAttribute('maxlength') || '131072', 10);
        var cleanLabel = shell.getAttribute('data-label-clean') || 'Clean';
        var dirtyLabel = shell.getAttribute('data-label-dirty') || 'Modified';
        var limitLabel = shell.getAttribute('data-label-limit') || 'Over limit';
        var cursorLabel = shell.getAttribute('data-label-cursor') || 'Cursor';

        function byteLength(value) {
            if (typeof Blob !== 'undefined') {
                return new Blob([value]).size;
            }
            return value.length;
        }

        function cursorPosition(value, index) {
            var before = value.slice(0, index).replace(/\r\n/g, '\n').replace(/\r/g, '\n');
            var parts = before.split('\n');
            return {
                line: parts.length,
                column: (parts[parts.length - 1] || '').length + 1
            };
        }

        function updateEditorState() {
            var value = textarea.value;
            var normalized = value.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
            var lines = normalized === '' ? 1 : normalized.split('\n').length;
            var chars = Array.from ? Array.from(value).length : value.length;
            var bytes = byteLength(value);
            var changed = value !== initialValue;
            var overLimit = bytes > maxBytes;
            var position = cursorPosition(value, textarea.selectionStart || 0);

            if (lineCounter) {
                lineCounter.textContent = String(lines);
            }
            if (charCounter) {
                charCounter.textContent = String(chars);
            }
            if (byteCounter) {
                byteCounter.textContent = String(bytes);
            }
            if (positionLabel) {
                positionLabel.textContent = cursorLabel + ' ' + position.line + ':' + position.column;
            }
            if (dirtyIndicator) {
                dirtyIndicator.textContent = overLimit ? limitLabel : (changed ? dirtyLabel : cleanLabel);
                dirtyIndicator.classList.toggle('is-dirty', changed || overLimit);
            }
            if (revertButton) {
                revertButton.disabled = !changed;
            }
            shell.classList.toggle('is-over-limit', overLimit);
        }

        if (wrapButton) {
            wrapButton.addEventListener('click', function () {
                var nextWrap = textarea.classList.toggle('is-nowrap') === false;
                wrapButton.classList.toggle('is-active', nextWrap);
                wrapButton.setAttribute('aria-pressed', nextWrap ? 'true' : 'false');
                textarea.focus();
            });
        }

        if (fontSizeSelect) {
            fontSizeSelect.addEventListener('change', function () {
                textarea.style.fontSize = fontSizeSelect.value + 'px';
                textarea.focus();
            });
            textarea.style.fontSize = fontSizeSelect.value + 'px';
        }

        if (revertButton) {
            revertButton.addEventListener('click', function () {
                textarea.value = initialValue;
                updateEditorState();
                textarea.focus();
            });
        }

        textarea.addEventListener('input', updateEditorState);
        textarea.addEventListener('keyup', updateEditorState);
        textarea.addEventListener('click', updateEditorState);
        textarea.addEventListener('select', updateEditorState);
        textarea.addEventListener('keydown', function (event) {
            var key = String(event.key || '').toLowerCase();
            if (key !== 's' || (!event.ctrlKey && !event.metaKey)) {
                return;
            }

            event.preventDefault();
            if (confirmCheckbox && !confirmCheckbox.checked) {
                confirmCheckbox.focus();
                return;
            }
            if (confirmPhraseInput && confirmPhraseInput.value.trim() === '') {
                confirmPhraseInput.focus();
                return;
            }
            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit();
                return;
            }
            if (submitButton) {
                submitButton.click();
            }
        });

        updateEditorState();
    })();
</script>
