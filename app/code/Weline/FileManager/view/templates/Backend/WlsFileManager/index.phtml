$buildBrowseUrl = static function (array $params) use ($browseBaseUrl, $operation, $projectId, $domain, $projectType): string {
    $query = array_merge([
        'operation' => $operation !== '' ? $operation : 'files.read',
        'project_id' => $projectId,
        'domain' => $domain,
        'project_type' => $projectType,
    ], $params);
    $query = array_filter($query, static fn (mixed $value): bool => $value !== null && $value !== '');

    return $browseBaseUrl . ($query !== [] ? '?' . http_build_query($query) : '');
};
$buildFileManagerAnchorUrl = static function (string $anchor) use ($buildBrowseUrl, $selectedRootKey, $currentRelativePath): string {
    return $buildBrowseUrl([
        'root' => $selectedRootKey,
        'path' => $currentRelativePath,
    ]) . '#' . ltrim($anchor, '#');
};
$buildDownloadUrl = static function (array $params) use ($downloadBaseUrl, $operation, $projectId, $domain, $projectType): string {
    $query = array_merge([
        'operation' => $operation !== '' ? $operation : 'files.read',
        'project_id' => $projectId,
        'domain' => $domain,
        'project_type' => $projectType,
    ], $params);
    $query = array_filter($query, static fn (mixed $value): bool => $value !== null && $value !== '');

    return $downloadBaseUrl . ($query !== [] ? '?' . http_build_query($query) : '');
