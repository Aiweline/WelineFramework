<?php
/**
 * @var \Weline\Framework\View\Template $this
 * @var \Weline\GenerativeEngineOptimization\Model\Feed $feed
 * @var array $feed_types
 * @var array $source_types
 * @var array $update_frequencies
 */
$isEdit = $feed->getId() > 0;
?>
<div class="content-header">
    <h1><?= $isEdit ? __('编辑Feed') : __('添加Feed') ?></h1>
</div>

<div class="content-body">
    <form id="feed-form" class="form-horizontal">
        <input type="hidden" name="id" value="<?= $feed->getId() ?>">
        
        <div class="form-group">
            <label class="control-label"><?= __('Feed名称') ?> <span class="required">*</span></label>
            <input type="text" name="feed_name" class="form-control" 
                   value="<?= htmlspecialchars($feed->getData('feed_name') ?? '') ?>" required>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('Feed类型') ?></label>
            <select name="feed_type" class="form-control">
                <?php foreach ($feed_types as $value => $label): ?>
                    <option value="<?= $value ?>" 
                            <?= ($feed->getData('feed_type') ?? 'content') === $value ? 'selected' : '' ?>>
                        <?= htmlspecialchars($label) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('数据源类型') ?></label>
            <select name="source_type" class="form-control">
                <?php foreach ($source_types as $value => $label): ?>
                    <option value="<?= $value ?>" 
                            <?= ($feed->getData('source_type') ?? 'database') === $value ? 'selected' : '' ?>>
                        <?= htmlspecialchars($label) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('数据源配置（JSON）') ?></label>
            <textarea name="source_config" class="form-control" rows="5"><?= htmlspecialchars($feed->getData('source_config') ?? '{}') ?></textarea>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('Feed URL') ?></label>
            <input type="text" name="feed_url" class="form-control" 
                   value="<?= htmlspecialchars($feed->getData('feed_url') ?? '') ?>"
                   placeholder="https://example.com/feed.json">
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('更新频率') ?></label>
            <select name="update_frequency" class="form-control">
                <?php foreach ($update_frequencies as $value => $label): ?>
                    <option value="<?= $value ?>" 
                            <?= ($feed->getData('update_frequency') ?? 'daily') === $value ? 'selected' : '' ?>>
                        <?= htmlspecialchars($label) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('自动推送') ?></label>
            <div class="checkbox">
                <label>
                    <input type="checkbox" name="is_auto_push" value="1" 
                           <?= ($feed->getData('is_auto_push') !== 0 && $feed->getData('is_auto_push') !== null) || !$feed->getId() ? 'checked' : '' ?>>
                    <?= __('启用自动推送') ?>
                    <small class="text-muted">（关闭后Cron任务将不再推送此Feed）</small>
                </label>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('是否启用') ?></label>
            <div class="checkbox">
                <label>
                    <input type="checkbox" name="is_enabled" value="1" 
                           <?= $feed->getData('is_enabled') !== 0 ? 'checked' : '' ?>>
                    <?= __('启用') ?>
                </label>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label"><?= __('配置（JSON）') ?></label>
            <textarea name="config" class="form-control" rows="5"><?= htmlspecialchars($feed->getData('config') ?? '{}') ?></textarea>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">
                <i class="mdi mdi-content-save"></i> <?= __('保存') ?>
            </button>
            <a href="<?= $this->getUrl('generativeengineoptimization/backend/feed') ?>" class="btn btn-secondary">
                <?= __('取消') ?>
            </a>
        </div>
    </form>
</div>

<script>
document.getElementById('feed-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    fetch('<?= $this->getUrl('generativeengineoptimization/backend/feed/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('保存成功') ?>');
            window.location.href = '<?= $this->getUrl('generativeengineoptimization/backend/feed') ?>';
        } else {
            alert(data.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败') ?>');
    });
});
</script>

