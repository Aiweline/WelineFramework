</div>

<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
document.getElementById('platform-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    var url = '<?= $this->getUrl('generativeengineoptimization/backend/platform/save') ?>';
    var opts = { method: 'POST', body: formData };
    window.Weline.Api.request(url, opts)
    .then(function(res) {
        var data = (res && res.data) !== undefined ? res.data : res;
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('保存成功') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '<?= $this->getUrl('generativeengineoptimization/backend/platform') ?>';
                });
            } else {
                console.log('<?= __('保存成功') ?>');
                window.location.href = '<?= $this->getUrl('generativeengineoptimization/backend/platform') ?>';
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message || '<?= __('保存失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('保存失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('保存失败') ?>');
        }
    });
});
</script>
