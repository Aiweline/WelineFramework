    <table class="table table-striped">
        <thead>
            <tr>
                <th><?= __('ID') ?></th>
                <th><?= __('账户名称') ?></th>
                <th><?= __('默认账户') ?></th>
                <th><?= __('激活状态') ?></th>
                <th><?= __('连接状态') ?></th>
                <th><?= __('最后测试') ?></th>
                <th><?= __('操作') ?></th>
            </tr>
        </thead>
        <tbody>
