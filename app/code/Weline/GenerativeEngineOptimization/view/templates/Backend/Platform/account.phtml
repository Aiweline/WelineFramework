                <?php foreach ($accounts as $account): ?>
                    <tr>
                        <td><?= $account['id'] ?></td>
                        <td><?= htmlspecialchars($account['account_name']) ?></td>
                        <td>
                            <?php if ($account['is_default']): ?>
                                <span class="badge badge-primary"><?= __('是') ?></span>
                            <?php else: ?>
                                <span class="badge badge-secondary"><?= __('否') ?></span>
                            <?php endif; ?>
                        </td>
                        <td>
                            <?php if ($account['is_active']): ?>
                                <span class="badge badge-success"><?= __('激活') ?></span>
                            <?php else: ?>
                                <span class="badge badge-secondary"><?= __('未激活') ?></span>
                            <?php endif; ?>
