                        <td><?= $account['last_test_time'] ? date('Y-m-d H:i:s', $account['last_test_time']) : '-' ?></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-info" 
                                    onclick="testConnection(<?= $account['id'] ?>)">
                                <i class="mdi mdi-connection"></i> <?= __('测试连接') ?>
                            </button>
