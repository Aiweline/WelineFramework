                        <td>
                            <?php if ($account['status'] === 'active'): ?>
                                <span class="badge badge-success"><?= __('成功') ?></span>
                            <?php elseif ($account['status'] === 'failed'): ?>
                                <span class="badge badge-danger"><?= __('失败') ?></span>
                            <?php else: ?>
                                <span class="badge badge-warning"><?= __('待测试') ?></span>
