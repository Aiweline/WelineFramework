<!-- SweetAlert2 CSS -->
<link href='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.css)' rel='stylesheet' type='text/css'/>
<!-- SweetAlert2 JS -->
<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
function showAddAccountModal() {
    document.getElementById('addAccountModal').style.display = 'block';
}

function hideAddAccountModal() {
    document.getElementById('addAccountModal').style.display = 'none';
}

function testConnection(accountId) {
    const formData = new FormData();
    formData.append('account_id', accountId);
    
    fetch('<?= $this->getUrl('generativeengineoptimization/backend/platform/testConnection') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: data.success ? 'success' : 'error',
                title: data.success ? '<?= __('测试成功') ?>' : '<?= __('测试失败') ?>',
                text: data.message,
                timer: data.success ? 2000 : 0,
                showConfirmButton: !data.success
            });
        } else {
            console.log(data.message);
        }
        if (data.success) {
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('测试失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('测试失败') ?>');
        }
    });
}

document.getElementById('account-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    fetch('<?= $this->getUrl('generativeengineoptimization/backend/platform/saveAccount') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '<?= __('成功') ?>',
                    text: '<?= __('保存成功') ?>',
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                console.log('<?= __('保存成功') ?>');
                location.reload();
            }
        } else {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: '<?= __('保存失败') ?>',
                    text: data.message || '<?= __('保存失败') ?>',
                    confirmButtonText: '<?= __('确定') ?>'
                });
            } else {
                console.error(data.message || '<?= __('保存失败') ?>');
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('保存失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('保存失败') ?>');
        }
    });
});
</script>
