    <div class="action-bar">
        <button type="button" class="btn btn-primary" onclick="showAddAccountModal()">
            <i class="mdi mdi-plus"></i> <?= __('添加账户') ?>
        </button>
        <a href="<?= $this->getUrl('generativeengineoptimization/backend/platform') ?>" class="btn btn-secondary">
