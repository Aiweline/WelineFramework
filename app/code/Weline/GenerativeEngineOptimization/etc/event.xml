<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    
    <!-- Feed条目添加事件 -->
    <event name="Weline_GenerativeEngineOptimization::feed_item_add">
        <observer name="Weline_GenerativeEngineOptimization::feed_item_add_observer" 
                  instance="Weline\GenerativeEngineOptimization\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- Feed条目更新事件 -->
    <event name="Weline_GenerativeEngineOptimization::feed_item_update">
        <observer name="Weline_GenerativeEngineOptimization::feed_item_update_observer" 
                  instance="Weline\GenerativeEngineOptimization\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
    
    <!-- Feed条目删除事件 -->
    <event name="Weline_GenerativeEngineOptimization::feed_item_delete">
        <observer name="Weline_GenerativeEngineOptimization::feed_item_delete_observer" 
                  instance="Weline\GenerativeEngineOptimization\Observer\FeedItemObserver" 
                  disabled="false" 
                  shared="true" 
                  sort="10"/>
    </event>
</config>

