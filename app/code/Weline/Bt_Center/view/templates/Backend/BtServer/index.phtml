<script>
(function() {
    'use strict';

    document.querySelectorAll('.weline-bt-delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.dataset.id;
            if (typeof AdminConfirm !== 'undefined') {
                AdminConfirm.show({
                    title: '<?= __('зЎ®и®ӨеҲ йҷӨ') ?>',
                    message: '<?= __('зЎ®е®ҡиҰҒеҲ йҷӨиҝҷдёӘжңҚеҠЎеҷЁеҗ—пјҹ') ?>',
                    confirmText: '<?= __('зЎ®е®ҡеҲ йҷӨ') ?>',
                    cancelText: '<?= __('еҸ–ж¶Ҳ') ?>',
                    type: 'danger',
                    onConfirm: function() {
                        deleteServer(id);
                    }
                });
            } else {
                deleteServer(id);
            }
        });
    });

    document.querySelectorAll('.weline-bt-delete-btn').forEach(function(btn) {
        var replacement = btn.cloneNode(true);
        btn.parentNode.replaceChild(replacement, btn);
        replacement.addEventListener('click', function() {
            var id = this.dataset.id;
            if (typeof AdminConfirm !== 'undefined') {
                AdminConfirm.show('<?= __('зәӯоҶјз•ҫз‘•дҪёеһ№й—„гӮҲз№–ж¶“оҒ…ж№ҮйҚ”вҖіж«’йҚҡжҘӢзҙө') ?>', {
                    title: '<?= __('зәӯоҶҝо…»йҚ’зҠ»ж«Һ') ?>',
                    confirmText: '<?= __('зәӯоҶјз•ҫйҚ’зҠ»ж«Һ') ?>',
                    cancelText: '<?= __('йҚҷж Ёз§·') ?>',
                    type: 'danger'
                }).then(function(confirmed) {
                    if (confirmed) {
                        deleteServer(id);
                    }
                });
            } else {
                deleteServer(id);
            }
        });
    });

    var stableDeleteConfirm = window.BackendConfirm || window.AdminConfirm;
    var stableDeleteConfirmMessage = <?= json_encode(__('зЎ®е®ҡиҰҒеҲ йҷӨиҝҷдёӘжңҚеҠЎеҷЁеҗ—пјҹ'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
    var stableDeleteConfirmTitle = <?= json_encode(__('зЎ®и®ӨеҲ йҷӨ'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
    var stableDeleteConfirmText = <?= json_encode(__('зЎ®е®ҡеҲ йҷӨ'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
    var stableCancelText = <?= json_encode(__('еҸ–ж¶Ҳ'), JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

    document.querySelectorAll('.weline-bt-delete-btn').forEach(function(btn) {
        var stableReplacement = btn.cloneNode(true);
        btn.parentNode.replaceChild(stableReplacement, btn);
        stableReplacement.addEventListener('click', function() {
            var id = this.dataset.id;
            if (stableDeleteConfirm && typeof stableDeleteConfirm.show === 'function') {
                stableDeleteConfirm.show(stableDeleteConfirmMessage, {
                    title: stableDeleteConfirmTitle,
                    confirmText: stableDeleteConfirmText,
                    cancelText: stableCancelText,
                    type: 'danger'
                }).then(function(confirmed) {
                    if (confirmed) {
                        deleteServer(id);
                    }
                });
            } else {
                deleteServer(id);
            }
        });
    });

    function deleteServer(id) {
        var formData = new URLSearchParams();
        formData.append('id', id);

        fetch('<?= $deleteUrl ?>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData.toString()
        })
        .then(function(response) {
            return response.json();
        })
        .then(function(resp) {
            if (resp.success) {
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.success(resp.message);
                }
                setTimeout(function() {
                    window.location.reload();
                }, 800);
            } else if (typeof BackendToast !== 'undefined') {
                BackendToast.error(resp.message || '<?= __('еҲ йҷӨеӨұиҙҘ') ?>');
            }
        })
        .catch(function() {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.error('<?= __('иҜ·жұӮеӨұиҙҘ') ?>');
            }
        });
    }
})();
</script>
