<script>
function deleteServer(id) {
    if (!confirm('<?= __('确定要删除这个服务器吗？') ?>')) {
        return;
    }

    const formData = new URLSearchParams();
    formData.append('id', id);

    fetch('<?= $this->getBackendUrl('bt_center/backend/bt_server/delete') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: formData
    })
        .then(response => response.json())
        .then(resp => {
            if (resp.success) {
                showPageMessage('success', resp.message);
                setTimeout(() => {
                    window.location.reload();
                }, 800);
            } else {
                showPageMessage('error', resp.message || '删除失败');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showPageMessage('error', '请求失败');
        });
}
</script>
