<script>
(function() {
    'use strict';

    document.querySelectorAll('.weline-bt-delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.dataset.id;
            if (typeof AdminConfirm !== 'undefined') {
                AdminConfirm.show({
                    title: '<?= __('确认删除') ?>',
                    message: '<?= __('确定要删除这个服务器吗？') ?>',
                    confirmText: '<?= __('确定删除') ?>',
                    cancelText: '<?= __('取消') ?>',
                    type: 'danger',
                    onConfirm: function() {
                        deleteServer(id);
                    }
                });
            } else {
                deleteServer(id);
            }
        });
    });

    function deleteServer(id) {
        var formData = new URLSearchParams();
        formData.append('id', id);

        window.Weline.Api.request('<?= $deleteUrl ?>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData
        })
        .then(function(response) {
            var resp = (response && response.data) || response;
            if (resp.success) {
                if (typeof BackendToast !== 'undefined') {
                    BackendToast.success(resp.message);
                }
                setTimeout(function() {
                    window.location.reload();
                }, 800);
            } else if (typeof BackendToast !== 'undefined') {
                BackendToast.error(resp.message || '<?= __('删除失败') ?>');
            }
        })
        .catch(function() {
            if (typeof BackendToast !== 'undefined') {
                BackendToast.error('<?= __('请求失败') ?>');
            }
        });
    }
})();
</script>
