<script>
function togglePassword() {
    const passwordInput = document.getElementById('password');
    const toggleIcon = document.getElementById('passwordToggleIcon');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        toggleIcon.classList.remove('mdi-eye');
        toggleIcon.classList.add('mdi-eye-off');
    } else {
        passwordInput.type = 'password';
        toggleIcon.classList.remove('mdi-eye-off');
        toggleIcon.classList.add('mdi-eye');
    }
}

function saveBtServer(event) {
    event.preventDefault();
    const form = document.getElementById('btServerForm');
    const formData = new FormData(form);

    const data = {};
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }

    fetch('<?= $this->getBackendUrl('bt_center/backend/bt_server/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
        .then(response => response.json())
        .then(resp => {
            if (resp.success) {
                showPageMessage('success', resp.message);
                setTimeout(() => {
                    window.location.href = '<?= $this->getBackendUrl('bt_center/backend/bt_server/index') ?>';
                }, 800);
            } else {
                showPageMessage('error', resp.message || '保存失败');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showPageMessage('error', '请求失败');
        });
}
</script>
