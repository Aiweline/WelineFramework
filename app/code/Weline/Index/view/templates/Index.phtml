    $fullRequestUri = (string)\Weline\Framework\Env\WelineEnv::server('WELINE_FULL_REQUEST_URI', '');
    if ($fullRequestUri !== '' && preg_match('/^https?:\/\//i', $fullRequestUri)) {
        $parts = parse_url($fullRequestUri);
        if (is_array($parts) && !empty($parts['host'])) {
            $scheme = 'https';
            $host = (string)$parts['host'];
            $port = isset($parts['port']) ? ':' . (string)$parts['port'] : '';
            $seoCanonicalUrl = $scheme . '://' . $host . $port . '/';
        }
    }
    if ($seoCanonicalUrl === '' && isset($this->request)) {
        $scheme = 'https';
        $host = (string)($this->request->getServer('HTTP_HOST') ?: $this->request->getServer('SERVER_NAME') ?: '');
        if ($host !== '') {
            $seoCanonicalUrl = $scheme . '://' . $host . '/';
        }
    }
} catch (\Throwable) {
}
