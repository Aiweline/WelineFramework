<?php
/** @var \Weline\Framework\View\Template $this */
$isLoggedIn = false;
$displayName = '';
try {
    $frontendSession = \Weline\Framework\Session\SessionFactory::getInstance()->createFrontendSession();
    $isLoggedIn = $frontendSession->isLoggedIn();
    $user = $frontendSession->getUser();
    if (is_object($user) && method_exists($user, 'getUsername')) {
        $displayName = (string)($user->getUsername() ?? '');
    }
    if ($displayName === '' && is_object($user) && method_exists($user, 'getEmail')) {
        $displayName = (string)$user->getEmail();
    }
} catch (\Throwable) {
}
$loginUrl = '/customer/account/login';
$registerUrl = '/customer/account/register';
$accountUrl = '/customer/account';
$identityUrl = '/customer/account/index#identity-bridge';
?>
