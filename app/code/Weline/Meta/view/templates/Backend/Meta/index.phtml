<!-- JSON 预览 Modal -->
<div class="modal fade" id="metaDetailModal" tabindex="-1" aria-labelledby="metaDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="metaDetailModalLabel"><?= __('元数据详情') ?></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<?= __('关闭') ?>"></button>
            </div>
            <div class="modal-body">
                <pre class="meta-json-preview p-4" id="meta-json-content">{}</pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal"><?= __('关闭') ?></button>
                <button type="button" class="btn btn-primary" id="copyMetaJson">
                    <i class="ri-file-copy-line me-1"></i><?= __('复制 JSON') ?>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    var modalEl = document.getElementById('metaDetailModal');
    var modalBody = document.getElementById('meta-json-content');
    var copyBtn = document.getElementById('copyMetaJson');
    var currentJson = '{}';
    var metaModal;

    document.querySelectorAll('[data-meta-refresh]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            window.location.reload();
        });
    });

    var ensureModal = function() {
        if (!metaModal) {
            metaModal = new bootstrap.Modal(modalEl);
        }
        return metaModal;
    };

    document.querySelectorAll('.js-meta-json').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var raw = btn.getAttribute('data-meta-json') || '{}';
            var title = btn.getAttribute('data-meta-title') || 'Meta';
            try {
                var parsed = JSON.parse(raw);
                currentJson = JSON.stringify(parsed, null, 2);
            } catch (e) {
                currentJson = raw;
            }
            document.getElementById('metaDetailModalLabel').textContent = title;
            modalBody.textContent = currentJson;
            ensureModal().show();
        });
    });

    copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(currentJson).then(function() {
            copyBtn.innerHTML = '<i class="ri-check-line me-1"></i><?= __('已复制') ?>';
            setTimeout(function() {
                copyBtn.innerHTML = '<i class="ri-file-copy-line me-1"></i><?= __('复制 JSON') ?>';
            }, 1500);
        });
    });

    document.querySelectorAll('.js-copy-key').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var key = btn.getAttribute('data-clipboard-text');
            if (!key) {
                return;
            }
            navigator.clipboard.writeText(key).then(function() {
                btn.innerHTML = '<small class="text-success"><i class="ri-check-line me-1"></i><?= __('已复制') ?></small>';
                setTimeout(function() {
                    btn.innerHTML = '<small><i class="ri-file-copy-line me-1"></i><?= __('复制Key') ?></small>';
                }, 1500);
            });
        });
    });
})();
</script>
