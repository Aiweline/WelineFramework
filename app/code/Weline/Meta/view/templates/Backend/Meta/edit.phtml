<script src='@static(Weline_Admin::assets/libs/sweetalert2/sweetalert2.min.js)'></script>
<script>
(function() {
    'use strict';
    
    var beautify = function(textarea) {
        if (!textarea) {
            return;
        }
        try {
            var value = textarea.value.trim();
            if (!value) {
                return;
            }
            textarea.value = JSON.stringify(JSON.parse(value), null, 2);
        } catch (e) {
            if (window.AdminToast) {
                AdminToast.error('JSON 解析失败：' + e.message);
            } else if (window.Toast) {
                Toast.error('JSON 解析失败：' + e.message);
            }
        }
    };

    var metaJsonTextarea = document.getElementById('metaJsonTextarea');
    var settingTextarea = document.getElementById('settingJsonTextarea');

    document.getElementById('beautifyMetaJson').addEventListener('click', function() {
        beautify(metaJsonTextarea);
    });
    
    document.getElementById('beautifySettingJson').addEventListener('click', function() {
        beautify(settingTextarea);
    });
    
    document.getElementById('validateMetaJson').addEventListener('click', function() {
        try {
            JSON.parse(metaJsonTextarea.value);
            if (window.AdminToast) {
                AdminToast.success('<?= __('JSON 校验通过') ?>');
            } else if (window.Toast) {
                Toast.success('JSON 校验通过');
            }
        } catch (e) {
            if (window.AdminToast) {
                AdminToast.error(e.message);
            } else if (window.Toast) {
                Toast.error(e.message);
            }
        }
    });

    var translationKeyPreview = document.getElementById('translationKeyPreview').textContent;
    document.getElementById('copyTranslationKey').addEventListener('click', function() {
        navigator.clipboard.writeText(translationKeyPreview).then(function() {
            var btn = document.getElementById('copyTranslationKey');
            btn.innerHTML = '<i class="ri-check-line me-1"></i><?= __('已复制') ?>';
            setTimeout(function() {
                btn.innerHTML = '<i class="ri-file-copy-line me-1"></i><?= __('复制') ?>';
            }, 1500);
        });
    });
})();
</script>
