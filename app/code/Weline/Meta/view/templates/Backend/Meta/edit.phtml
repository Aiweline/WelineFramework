<script>
    (function () {
        const beautify = (textarea) => {
            if (!textarea) {
                return;
            }
            try {
                const value = textarea.value.trim();
                if (!value) {
                    return;
                }
                textarea.value = JSON.stringify(JSON.parse(value), null, 2);
            } catch (e) {
                window.Toast && Toast.error('JSON 解析失败：' + e.message);
            }
        };

        const metaJsonTextarea = document.getElementById('metaJsonTextarea');
        const settingTextarea = document.getElementById('settingJsonTextarea');

        document.getElementById('beautifyMetaJson').addEventListener('click', () => beautify(metaJsonTextarea));
        document.getElementById('beautifySettingJson').addEventListener('click', () => beautify(settingTextarea));
        document.getElementById('validateMetaJson').addEventListener('click', () => {
            try {
                JSON.parse(metaJsonTextarea.value);
                window.Toast ? Toast.success('JSON 校验通过') : alert('JSON 校验通过');
            } catch (e) {
                window.Toast ? Toast.error(e.message) : alert(e.message);
            }
        });

        const translationKeyPreview = document.getElementById('translationKeyPreview').textContent;
        document.getElementById('copyTranslationKey').addEventListener('click', () => {
            navigator.clipboard.writeText(translationKeyPreview).then(() => {
                const btn = document.getElementById('copyTranslationKey');
                btn.innerHTML = '<i class="ri-check-line me-1"></i><?= __('已复制') ?>';
                setTimeout(() => {
                    btn.innerHTML = '<i class="ri-file-copy-line me-1"></i><?= __('复制') ?>';
                }, 1500);
            });
        });
    })();
</script>
