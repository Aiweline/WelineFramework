                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('保存失败') ?>: ' + error.message);
                }
            });
    }

    if (metaNameDescTranslationSaveBtn) {
        metaNameDescTranslationSaveBtn.addEventListener('click', saveMetaNameDescriptionTranslation);
    }

    // 命名空间选择变化时自动加载
    const namespaceSelect = document.getElementById('namespace-select');
    if (namespaceSelect) {
        namespaceSelect.addEventListener('change', function() {
            // 如果选择了命名空间，自动加载文件树
            if (this.value && this.value.trim() !== '') {
                loadTree();
            } else {
                treeContainer.innerHTML = '<div class="text-center text-muted py-4"><?= __('请先选择命名空间') ?></div>';
                editorContainer.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-file-tree-outline" style="font-size: 3rem;"></i><p class="mt-3 mb-0"><?= __('请选择左侧文件以查看详情') ?></p></div>';
            }
        });
    }

    // 初始化时，如果有默认命名空间，自动加载一次
    const defaultNamespace = namespaceSelect ? namespaceSelect.value : '';
    if (defaultNamespace && defaultNamespace.trim() !== '') {
        loadTree();
    }
})();
</script>
