<script>
(function() {
    const app = document.getElementById('meta-config-app');
    if (!app) {
        return;
    }

    const endpoints = {
        tree: app.dataset.treeUrl,
        file: app.dataset.metaUrl,
        save: app.dataset.saveUrl,
        translation: app.dataset.translationUrl,
        translationSave: app.dataset.translationSaveUrl,
        locales: app.dataset.localesUrl,
        metaNameDescTranslation: app.dataset.metaNameDescTranslationUrl,
        metaNameDescTranslationSave: app.dataset.metaNameDescTranslationSaveUrl,
    };

    const filtersForm = document.getElementById('meta-filter-form');
    const treeContainer = document.getElementById('meta-file-tree');
    const treeCount = document.getElementById('meta-tree-count');
    const editorContainer = document.getElementById('meta-file-editor');
    const translationModalEl = document.getElementById('metaParamTranslationModal');
    const translationModalBody = document.getElementById('metaParamTranslationModalBody');
    const translationSaveBtn = document.getElementById('metaSaveParamTranslationBtn');
    let translationModal = null;

    // 原生弹窗类 - 兼容亮色/暗色主题
    class NativeModal {
        constructor(element) {
            this.element = element;
            this.isVisible = false;
            this.backdrop = null;
            this.init();
        }

        // 检测当前主题
        getCurrentTheme() {
            // 方法1: 检测 data-theme 属性
            const dataTheme = document.documentElement.getAttribute('data-theme');
            if (dataTheme) {
                return dataTheme === 'dark' ? 'dark' : 'light';
            }
            
            // 方法2: 检测 body 或 html 的 class
            if (document.documentElement.classList.contains('dark') || 
                document.body.classList.contains('dark')) {
                return 'dark';
            }
            
            // 方法3: 检测 prefers-color-scheme
            if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
            }
            
            return 'light';
        }

        // 更新主题样式
        updateThemeStyles() {
            const theme = this.getCurrentTheme();
            const isDark = theme === 'dark';
            
            // 更新背景遮罩颜色
            if (this.backdrop) {
                if (isDark) {
                    this.backdrop.style.backgroundColor = 'rgba(0, 0, 0, 0.7)';
                } else {
                    this.backdrop.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
                }
            }
        }

        init() {
            // 创建背景遮罩
            this.backdrop = document.createElement('div');
            this.backdrop.className = 'modal-backdrop fade';
            this.updateThemeStyles();
            this.backdrop.style.cssText += 'position: fixed; top: 0; left: 0; z-index: 1040; width: 100vw; height: 100vh;';
            document.body.appendChild(this.backdrop);

            // 绑定关闭按钮事件
            const closeButtons = this.element.querySelectorAll('[data-bs-dismiss="modal"]');
            closeButtons.forEach(btn => {
                btn.addEventListener('click', () => this.hide());
            });

            // 点击背景关闭
            this.backdrop.addEventListener('click', () => this.hide());

            // ESC键关闭
            this.escapeHandler = (e) => {
                if (e.key === 'Escape' && this.isVisible) {
                    this.hide();
                }
            };

            // 监听主题变化
            if (window.matchMedia) {
                this.themeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
                this.themeChangeHandler = () => {
                    this.updateThemeStyles();
                };
                this.themeMediaQuery.addEventListener('change', this.themeChangeHandler);
            }

            // 监听 data-theme 属性变化
            this.themeObserver = new MutationObserver(() => {
                this.updateThemeStyles();
            });
            this.themeObserver.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ['data-theme', 'class']
            });
        }

        show() {
            if (this.isVisible) return;
            
            this.isVisible = true;
            this.element.style.display = 'block';
            this.element.classList.remove('fade');
            this.element.classList.add('show');
            this.element.setAttribute('aria-hidden', 'false');
            this.element.setAttribute('aria-modal', 'true');
            
            // 设置弹窗样式
            const currentStyle = this.element.getAttribute('style') || '';
            if (!currentStyle.includes('position')) {
                this.element.style.position = 'fixed';
            }
            if (!currentStyle.includes('top')) {
                this.element.style.top = '0';
            }
            if (!currentStyle.includes('left')) {
                this.element.style.left = '0';
            }
            if (!currentStyle.includes('z-index')) {
                this.element.style.zIndex = '1050';
            }
            if (!currentStyle.includes('width')) {
                this.element.style.width = '100%';
            }
            if (!currentStyle.includes('height')) {
                this.element.style.height = '100%';
            }
            this.element.style.overflowX = 'hidden';
            this.element.style.overflowY = 'auto';
            this.element.style.outline = '0';
            
            // 显示背景遮罩
            this.backdrop.classList.add('show');
            this.backdrop.style.display = 'block';
            
            // 防止body滚动
            document.body.style.overflow = 'hidden';
            document.body.style.paddingRight = '0px';
            
            // 绑定ESC键
            document.addEventListener('keydown', this.escapeHandler);
            
            // 触发显示事件
            this.element.dispatchEvent(new Event('shown', { bubbles: true }));
        }

        hide() {
            if (!this.isVisible) return;
            
            this.isVisible = false;
            this.element.classList.remove('show');
            this.element.classList.add('fade');
            this.element.setAttribute('aria-hidden', 'true');
            this.element.setAttribute('aria-modal', 'false');
            
            // 隐藏背景遮罩
            this.backdrop.classList.remove('show');
            
            // 延迟隐藏，等待动画完成
            setTimeout(() => {
                this.element.style.display = 'none';
                this.backdrop.style.display = 'none';
                
                // 恢复body滚动
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            }, 150);
            
            // 移除ESC键绑定
            document.removeEventListener('keydown', this.escapeHandler);
            
            // 触发隐藏事件
            this.element.dispatchEvent(new Event('hidden', { bubbles: true }));
        }

        dispose() {
            if (this.backdrop && this.backdrop.parentNode) {
                this.backdrop.parentNode.removeChild(this.backdrop);
            }
            document.removeEventListener('keydown', this.escapeHandler);
            
            // 清理主题监听
            if (this.themeMediaQuery && this.themeChangeHandler) {
                this.themeMediaQuery.removeEventListener('change', this.themeChangeHandler);
            }
            if (this.themeObserver) {
                this.themeObserver.disconnect();
            }
        }
    }
    const translationState = {
        metaIdentify: null,
        param: null,
        scope: 'default',
        locale: null,
        area: null,
    };
    let lastFilters = {};

    function escapeHtml(value) {
        const div = document.createElement('div');
        div.textContent = value == null ? '' : String(value);
        return div.innerHTML;
    }

    function escapeAttr(value) {
        return escapeHtml(value).replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    filtersForm.addEventListener('submit', function (e) {
        e.preventDefault();
        loadTree();
    });

    document.getElementById('reload-tree-btn').addEventListener('click', function(e) {
        e.preventDefault();
        loadTree();
    });

    treeContainer.addEventListener('click', function (e) {
        const label = e.target.closest('.tree-label');
        if (!label) {
            return;
        }

        const nodeType = label.dataset.nodeType;
        if (nodeType === 'dir') {
            const children = label.parentElement.querySelector(':scope > .tree-node-children');
            if (children) {
                children.classList.toggle('collapsed');
            }
            return;
        }

        const metaIdentify = label.dataset.metaIdentify;
        const area = label.dataset.nodeArea || lastFilters.area || 'frontend';
        treeContainer.querySelectorAll('.tree-label').forEach(el => el.classList.remove('active'));
        label.classList.add('active');
        loadMetaFile(metaIdentify, area);
    });

    editorContainer.addEventListener('click', function(e) {
        const translateBtn = e.target.closest('.param-translate-btn');
        if (translateBtn) {
            openParamTranslation({
                metaIdentify: translateBtn.dataset.metaIdentify,
                param: translateBtn.dataset.param,
                scope: translateBtn.dataset.scope,
            });
            return;
        }
        
        const metaNameDescTranslateBtn = e.target.closest('.meta-name-desc-translate-btn');
        if (metaNameDescTranslateBtn) {
            openMetaNameDescriptionTranslation({
                metaIdentify: metaNameDescTranslateBtn.dataset.metaIdentify,
                field: metaNameDescTranslateBtn.dataset.field,
                scope: metaNameDescTranslateBtn.dataset.scope,
            });
        }
    });

    translationSaveBtn.addEventListener('click', saveParamTranslation);

    function getFilters() {
        const formData = new FormData(filtersForm);
        return {
            namespace: formData.get('namespace') || '',
            area: formData.get('area') || '',
            scope: formData.get('scope') || 'default',
            locale: formData.get('locale') || '',
            type: formData.get('type') || '',
            category: formData.get('category') || '',
            identity_id: formData.get('identity_id') || '',
        };
    }

    function loadTree() {
        const filters = getFilters();
        
        // 验证 namespace 不能为空
        if (!filters.namespace || filters.namespace.trim() === '') {
            treeContainer.innerHTML = '<div class="alert alert-warning mb-0"><?= __('请先选择命名空间') ?></div>';
            return;
        }
        
        lastFilters = filters;
        treeContainer.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="text-muted mt-2 mb-0"><?= __('正在加载...') ?></p></div>';
        treeCount.textContent = '';

        const params = new URLSearchParams(filters);
        fetch(endpoints.tree + '?' + params.toString(), { credentials: 'same-origin' })
            .then(response => response.json())
            .then(json => {
                if (json.code !== 200) {
                    throw new Error(json.msg || json.message || '<?= __('加载失败') ?>');
                }
                const tree = json.data.tree || [];
                treeCount.textContent = tree.length ? sprintf('<?= __('共 %s 个节点') ?>', tree.length) : '';
                renderTree(tree);
                editorContainer.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-file-tree-outline" style="font-size: 3rem;"></i><p class="mt-3 mb-0"><?= __('请选择左侧文件以查看详情') ?></p></div>';
            })
            .catch(error => {
                console.error(error);
                treeContainer.innerHTML = '<div class="alert alert-danger mb-0"><?= __('加载失败') ?>: ' + escapeHtml(error && error.message ? error.message : '') + '</div>';
            });
    }

    function renderTree(nodes) {
        if (!nodes.length) {
            treeContainer.innerHTML = '<div class="text-muted text-center py-4"><?= __('未找到符合条件的元数据文件') ?></div>';
            return;
        }
        treeContainer.innerHTML = '';
        const ul = document.createElement('ul');
        ul.classList.add('meta-tree-root');
        nodes.forEach(node => {
            ul.appendChild(createTreeNode(node));
        });
        treeContainer.appendChild(ul);
    }

    function createTreeNode(node) {
        const li = document.createElement('li');
        const label = document.createElement('div');
        label.className = 'tree-label';
        label.dataset.nodeType = node.type || 'dir';
        label.textContent = node.title || node.meta_identify || '…';

        if (node.type === 'file') {
            label.dataset.metaIdentify = node.meta_identify;
            label.dataset.nodeArea = node.area || '';
            const icon = document.createElement('i');
            icon.className = 'mdi mdi-file-document-outline text-primary';
            label.prepend(icon);
        } else {
            const icon = document.createElement('i');
            icon.className = 'mdi mdi-folder-outline text-warning';
            label.prepend(icon);
        }

        li.appendChild(label);

        if (node.children && node.children.length) {
            const childrenContainer = document.createElement('div');
            childrenContainer.className = 'tree-node-children';
            const childUl = document.createElement('ul');
            node.children.forEach(child => childUl.appendChild(createTreeNode(child)));
            childrenContainer.appendChild(childUl);
            li.appendChild(childrenContainer);
        }

        return li;
    }

    function loadMetaFile(metaIdentify, area) {
        editorContainer.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="text-muted mt-2 mb-0"><?= __('正在加载元数据...') ?></p></div>';

        const params = new URLSearchParams({
            meta_identify: metaIdentify,
            scope: lastFilters.scope || 'default',
            locale: lastFilters.locale || '',
            area: area || lastFilters.area || '',
            identity_id: lastFilters.identity_id || '',
        });

        fetch(endpoints.file + '?' + params.toString(), { credentials: 'same-origin' })
            .then(response => response.json())
            .then(json => {
                if (json.code !== 200) {
                    throw new Error(json.msg || json.message || '<?= __('加载失败') ?>');
                }
                renderMetaEditor(json.data, params);
            })
            .catch(error => {
                console.error(error);
                editorContainer.innerHTML = '<div class="alert alert-danger mb-0"><?= __('加载失败') ?>: ' + escapeHtml(error && error.message ? error.message : '') + '</div>';
            });
    }

    function renderMetaEditor(data, params) {
        const meta = data.meta || {};
        const paramsList = data.params || [];

        let html = '';
        html += '<div class="mb-3">';
        html += '<div class="d-flex justify-content-between align-items-center">';
        html += '<div class="flex-grow-1">';
        // Name 显示区域
        html += '<div class="d-flex justify-content-between align-items-center mb-1">';
        html += '<h5 class="mb-0">' + escapeHtml(meta.name || meta.meta_identify || 'meta') + '</h5>';
        if (meta.name_translatable) {
            html += '<button type="button" class="btn btn-sm btn-outline-secondary meta-name-desc-translate-btn" data-meta-identify="' + escapeAttr(meta.meta_identify || '') + '" data-field="name" data-scope="' + escapeAttr(params.get('scope') || 'default') + '" title="<?= __('翻译名称') ?>"><i class="mdi mdi-translate"></i></button>';
        }
        html += '</div>';
        // Description 显示区域
        if (meta.description) {
            html += '<div class="d-flex justify-content-between align-items-center mb-1">';
            html += '<div class="text-muted small">' + escapeHtml(meta.description) + '</div>';
            if (meta.description_translatable) {
                html += '<button type="button" class="btn btn-sm btn-outline-secondary meta-name-desc-translate-btn" data-meta-identify="' + escapeAttr(meta.meta_identify || '') + '" data-field="description" data-scope="' + escapeAttr(params.get('scope') || 'default') + '" title="<?= __('翻译描述') ?>"><i class="mdi mdi-translate"></i></button>';
            }
            html += '</div>';
        }
        html += '<div class="text-muted small">' + escapeHtml(meta.file_path || meta.file_full_path || '') + '</div>';
        html += '</div>';
        html += '<span class="badge bg-light text-dark align-self-center" style="height: fit-content;">' + escapeHtml(meta.meta_type || 'meta') + '</span>';
        html += '</div>';
        html += '</div>';

        html += '<form id="meta-file-form" data-meta-identify="' + escapeAttr(meta.meta_identify || '') + '" data-area="' + escapeAttr(meta.area || params.get('area') || '') + '">';
        html += '<input type="hidden" name="meta_identify" value="' + escapeAttr(meta.meta_identify || '') + '">';
        html += '<input type="hidden" name="scope" value="' + escapeAttr(params.get('scope') || 'default') + '">';
        html += '<input type="hidden" name="area" value="' + escapeAttr(meta.area || params.get('area') || '') + '">';
        html += '<input type="hidden" name="identity_id" value="' + escapeAttr(params.get('identity_id') || '') + '">';
        html += '<input type="hidden" name="locale" value="' + escapeAttr(params.get('locale') || lastFilters.locale || '') + '">';

        if (!paramsList.length) {
            html += '<div class="alert alert-info mb-0"><?= __('该文件没有可配置的参数。') ?></div>';
        } else {
            html += '<div class="list-group meta-param-list mb-3">';
            paramsList.forEach(function (item) {
                const value = item.value ?? '';
                html += '<div class="list-group-item">';
                html += '<div class="d-flex justify-content-between align-items-center mb-1">';
                html += '<div><strong>' + escapeHtml(item.label || item.name) + '</strong> <code class="text-muted ms-1" style="font-size: 11px;">' + escapeHtml(item.name) + '</code> <button type="button" class="btn btn-sm btn-outline-secondary param-translate-btn ms-1" data-meta-identify="' + escapeAttr(meta.meta_identify || '') + '" data-param="' + escapeAttr(item.name) + '" data-scope="' + escapeAttr(params.get('scope') || 'default') + '" title="<?= __('翻译参数') ?>"><i class="mdi mdi-translate"></i></button></div>';
                html += '</div>';
                if (item.description) {
                    html += '<div class="text-muted small mb-2">' + escapeHtml(item.description) + '</div>';
                }

                if ((item.input === 'textarea') || (typeof value === 'string' && value.length > 80)) {
                    html += '<textarea class="form-control form-control-sm" rows="3" name="params[' + escapeAttr(item.name) + ']">' + escapeHtml(value || '') + '</textarea>';
                } else if ((item.input === 'select' || item.options && Object.keys(item.options).length)) {
                    html += '<select class="form-select form-select-sm" name="params[' + escapeAttr(item.name) + ']">';
                    const options = item.options || {};
                    Object.keys(options).forEach(function (optValue) {
                        const selected = String(optValue) === String(value) ? 'selected' : '';
                        html += '<option value="' + escapeAttr(optValue) + '" ' + selected + '>' + escapeHtml(options[optValue]) + '</option>';
                    });
                    html += '</select>';
                } else {
                    html += '<input type="text" class="form-control form-control-sm" name="params[' + escapeAttr(item.name) + ']" value="' + escapeAttr(value || '') + '">';
                }

                html += '</div>';
            });
            html += '</div>';
            html += '<div class="text-end">';
            html += '<button type="submit" class="btn btn-primary"><i class="mdi mdi-content-save me-1"></i><?= __('保存配置') ?></button>';
            html += '</div>';
        }

        html += '</form>';

        editorContainer.innerHTML = html;
        const form = document.getElementById('meta-file-form');
        if (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                saveMetaConfig(form);
            });
        }
    }

    function saveMetaConfig(form) {
        const formData = new FormData(form);
        const formArea = form.getAttribute('data-area') || (lastFilters.area || '');
        treeContainer.querySelectorAll('.tree-label').forEach(el => el.classList.remove('saving'));
        const activeNode = treeContainer.querySelector('.tree-label.active');
        if (activeNode) {
            activeNode.classList.add('saving');
        }

        fetch(endpoints.save, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
        })
            .then(response => response.json())
            .then(json => {
                if (json.code !== 200) {
                    throw new Error(json.msg || json.message || '<?= __('保存失败') ?>');
                }
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'success',
                        title: '<?= __('成功') ?>',
                        text: json.msg || json.message || '<?= __('配置保存成功') ?>',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    console.log(json.msg || json.message || '<?= __('配置保存成功') ?>');
                }
                notifyParentConfigSaved(formArea);
            })
            .catch(error => {
                console.error(error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: '<?= __('保存失败') ?>',
                        text: error.message,
                        confirmButtonText: '<?= __('确定') ?>'
                    });
                } else {
                    console.error('<?= __('保存失败') ?>: ' + error.message);
                }
            })
            .finally(() => {
                if (activeNode) {
                    activeNode.classList.remove('saving');
                }
            });
    }

    function openParamTranslation(payload) {
        translationState.metaIdentify = payload.metaIdentify;
        translationState.param = payload.param;
        translationState.scope = payload.scope || lastFilters.scope || 'default';
        translationState.locale = lastFilters.locale || '';
        translationState.area = payload.area || lastFilters.area || '';

        if (!translationModal) {
            translationModal = new NativeModal(translationModalEl);
        }
        translationModal.show();
        loadParamTranslation();
    }

    function loadParamTranslation() {
        const params = new URLSearchParams({
            meta_identify: translationState.metaIdentify,
            param: translationState.param,
            scope: translationState.scope,
        });

        translationModalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="text-muted mt-2 mb-0"><?= __('正在加载翻译...') ?></p></div>';

        fetch(endpoints.translation + '?' + params.toString(), { credentials: 'same-origin' })
            .then(response => response.json())
            .then(json => {
                if (json.code !== 200) {
                    throw new Error(json.msg || json.message || '<?= __('加载失败') ?>');
                }

                const data = json.data || {};
                const translations = data.translations || [];

                let html = '';
                html += '<form id="metaParamTranslationForm">';
                html += '<input type="hidden" name="meta_identify" value="' + escapeAttr(data.meta_identify || translationState.metaIdentify) + '">';
                html += '<input type="hidden" name="param" value="' + escapeAttr(data.param || translationState.param) + '">';
                html += '<input type="hidden" name="scope" value="' + escapeAttr(data.scope || translationState.scope) + '">';

                html += '<div class="mb-3">';
                html += '<label class="form-label"><strong><?= __('默认值') ?> (' + escapeHtml(data.label || translationState.param) + ')</strong></label>';
                html += '<div class="form-control-plaintext bg-light p-2 rounded">' + escapeHtml(data.default_value || '') + '</div>';
                html += '<div class="form-text"><?= __('如果某语言没有翻译，将使用此默认值') ?></div>';
                if (data.description) {
                    html += '<div class="text-muted small mt-1">' + escapeHtml(data.description) + '</div>';
                }
                html += '</div>';

                html += '<div class="mb-3">';
                html += '<label class="form-label"><strong><?= __('多语言翻译') ?></strong></label>';
                if (translations.length === 0) {
                    html += '<div class="alert alert-info mb-0"><?= __('没有可用的语言') ?></div>';
                } else {
                    html += '<div class="list-group">';
                    translations.forEach(function(trans) {
                        html += '<div class="list-group-item">';
                        html += '<div class="row align-items-center">';
                        html += '<div class="col-md-3">';
                        html += '<label class="form-label mb-0"><strong>' + escapeHtml(trans.name || trans.code) + '</strong></label>';
                        html += '<div class="text-muted small">' + escapeHtml(trans.code) + '</div>';
                        html += '</div>';
                        html += '<div class="col-md-9">';
                        html += '<input type="text" class="form-control" name="translations[' + escapeAttr(trans.code) + ']" value="' + escapeAttr(trans.value || '') + '" placeholder="<?= __('留空则使用默认值') ?>">';
                        html += '</div>';
                        html += '</div>';
                        html += '</div>';
                    });
                    html += '</div>';
                }
                html += '</div>';

                html += '</form>';
                translationModalBody.innerHTML = html;
            })
            .catch(error => {
                console.error(error);
                translationModalBody.innerHTML = '<div class="alert alert-danger mb-0"><?= __('加载失败') ?>: ' + escapeHtml(error && error.message ? error.message : '') + '</div>';
            });
    }

    function saveParamTranslation() {
        const form = document.getElementById('metaParamTranslationForm');
        if (!form) {
