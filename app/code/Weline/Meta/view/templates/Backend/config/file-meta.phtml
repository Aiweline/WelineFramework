                // 重新加载当前文件以更新显示
                const activeNode = treeContainer.querySelector('.tree-label.active');
                if (activeNode) {
                    const metaIdentify = activeNode.dataset.metaIdentify;
                    const area = activeNode.dataset.nodeArea || lastFilters.area || 'frontend';
                    loadMetaFile(metaIdentify, area);
