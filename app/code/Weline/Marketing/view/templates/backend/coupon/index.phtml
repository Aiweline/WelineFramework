 * @var \Weline\Framework\Pagination\Pagination $pagination
 */
?>
<link rel="stylesheet" href="@static(Weline_Marketing::css/coupon-index.css)">
<div class="row marketing-coupon-page">
    <template>Weline_Component::message.phtml</template>
</div>

<div class="row marketing-coupon-page">
