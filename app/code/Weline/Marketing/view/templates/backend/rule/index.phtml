    <div class='col-12'>
        <div class='card'>
            <div class='card-header d-flex justify-content-between align-items-center'>
                <h5 class='card-title mb-0'><lang>规则列表</lang></h5>
                <a href="<?= $this->getUrl('marketing/backend/rule/getAdd') ?>" class="btn btn-primary btn-sm">
                    <i class="ri-add-line me-1"></i><lang>添加规则</lang>
                </a>
            </div>
            <div class='card-body'>
                <div class="table-responsive">
                    <table class="table table-bordered table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th><?= __('ID') ?></th>
                                <th><?= __('规则名称') ?></th>
                                <th><?= __('类型') ?></th>
                                <th><?= __('状态') ?></th>
                                <th><?= __('优先级') ?></th>
                                <th><?= __('使用次数') ?></th>
                                <th><?= __('操作') ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php if (empty($rules)): ?>
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                                    <lang>暂无数据</lang>
                                </td>
                            </tr>
                            <?php else: ?>
                            <?php foreach ($rules as $rule): ?>
                            <?php $this->assign('rule', $rule); ?>
                            <tr>
                                <td><?= $rule['id'] ?></td>
                                <td>
                                    <?php if (isset($rule['id']) && $rule['id']): ?>
                                        <local model="Weline\Marketing\Model\Rule\LocalDescription" 
                                               field="name" 
                                               id="rule.id" 
                                               name="rule-name">{{rule.local_name|rule.name}}</local>
                                    <?php else: ?>
                                        <?= $this->escapeHtml($rule['name'] ?? '') ?>
                                    <?php endif; ?>
                                </td>
                                <td><?= $this->escapeHtml($rule['rule_type'] ?? '') ?></td>
                                <td>
                                    <?php if (($rule['status'] ?? '') == '1' || ($rule['status'] ?? '') == 'active'): ?>
                                        <span class="badge bg-success"><lang>启用</lang></span>
                                    <?php else: ?>
                                        <span class="badge bg-secondary"><lang>禁用</lang></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= $rule['priority'] ?? 0 ?></td>
                                <td><?= $rule['usage_count'] ?? 0 ?></td>
                                <td>
                                    <a href="<?= $this->getUrl('marketing/backend/rule/getEdit', ['id' => $rule['id']]) ?>" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                            <?php endif; ?>
                        </tbody>
                    </table>
                </div>
                <?= $this->getChildHtml('pagination') ?>
            </div>
        </div>
