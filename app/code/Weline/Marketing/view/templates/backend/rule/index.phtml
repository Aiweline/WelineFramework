            <div class="marketing-rule-card-body">
                <div class="marketing-rule-table-wrap">
                    <table class="marketing-rule-table">
                        <thead>
                            <tr>
                                <th><?= __('ID') ?></th>
                                <th><?= __('规则名称') ?></th>
                                <th><?= __('类型') ?></th>
                                <th><?= __('状态') ?></th>
