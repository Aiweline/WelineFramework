                <h5 class="marketing-rule-card-title"><lang>规则列表</lang></h5>
                <a href="<?= $this->getUrl('marketing/backend/rule/getAdd') ?>" class="marketing-rule-add-btn">
                    <i class="ri-add-line"></i><lang>添加规则</lang>
