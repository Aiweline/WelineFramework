                            <?php if (empty($rules)): ?>
                            <tr>
                                <td colspan="7">
                                    <div class="marketing-rule-empty">
                                        <i class="ri-inbox-2-line marketing-rule-empty-icon"></i>
                                        <span class="marketing-rule-empty-text"><lang>暂无数据</lang></span>
                                    </div>
                                </td>
                            </tr>
                            <?php else: ?>
                            <?php foreach ($rules as $rule): ?>
                            <?php $this->assign('rule', $rule); ?>
                            <?php $isActive = ($rule['status'] ?? '') == '1' || ($rule['status'] ?? '') == 'active'; ?>
                            <tr>
                                <td><?= $rule['id'] ?></td>
                                <td>
                                    <?php if (isset($rule['id']) && $rule['id']): ?>
                                        <local model="Weline\Marketing\Model\Rule\LocalDescription" 
                                               field="name" 
                                               id="rule.id" 
                                               name="rule-name">{{rule.local_name|rule.name}}</local>
                                    <?php else: ?>
                                        <?= $this->escapeHtml($rule['name'] ?? '') ?>
                                    <?php endif; ?>
                                </td>
                                <td><?= $this->escapeHtml($rule['rule_type'] ?? '') ?></td>
                                <td>
                                    <?php if ($isActive): ?>
                                    <span class="marketing-rule-badge marketing-rule-badge--active"><lang>启用</lang></span>
                                    <?php else: ?>
                                    <span class="marketing-rule-badge marketing-rule-badge--inactive"><lang>禁用</lang></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= $rule['priority'] ?? 0 ?></td>
                                <td><?= $rule['usage_count'] ?? 0 ?></td>
                                <td>
                                    <a href="<?= $this->getUrl('marketing/backend/rule/getEdit', ['id' => $rule['id']]) ?>" 
                                       class="marketing-rule-action-btn" title="<?= __('编辑') ?>">
                                        <i class="ri-edit-line"></i>
                                    </a>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                            <?php endif; ?>
                        </tbody>
                    </table>
                </div>
                <?= $this->getChildHtml('pagination') ?>
            </div>
