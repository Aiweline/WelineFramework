<script>
(function() {
    'use strict';
    
    var offcanvasRightAdd = document.getElementById('offcanvasRightAdd');
    if (offcanvasRightAdd) {
        offcanvasRightAdd.addEventListener('show.bs.offcanvas', function() {
            var iframe = document.getElementById('attributeAddIframe');
            if (iframe) {
                iframe.src = iframe.getAttribute('data-src');
            }
        });
    }
    
    var flushEditBtn = document.querySelector('.weline-ddns-flush-edit-btn');
    if (flushEditBtn) {
        flushEditBtn.addEventListener('click', function() {
            var iframe = document.getElementById('attributeIframe_edit');
            if (iframe) {
                iframe.src = iframe.src;
            }
        });
    }
})();
</script>
