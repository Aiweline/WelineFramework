                    <th><?= __('平均响应时间') ?></th>
                    <th><?= __('操作') ?></th>
                </tr>
            </thead>
            <tbody>
                <?php if (empty($agents)): ?>
                    <tr>
                        <td colspan="10" class="text-center"><?= __('暂无客服人员') ?></td>
                    </tr>
                <?php else: ?>
                    <?php foreach ($agents as $agent): ?>
