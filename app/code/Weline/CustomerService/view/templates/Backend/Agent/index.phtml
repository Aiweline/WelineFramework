<script>
const AgentManager = {
    saveUrl: '<?= $saveUrl ?>',
    deleteUrl: '<?= $deleteUrl ?>',
    statisticsUrl: '<?= $statisticsUrl ?>',
    agents: <?= json_encode($agents, JSON_UNESCAPED_UNICODE) ?>
};

const CustomerServiceLanguageUtils = window.WelineLanguageSelectUtils || null;
const CustomerServiceDefaultLocale = <?= json_encode($customerServiceDefaultLocale, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

if (CustomerServiceLanguageUtils && typeof CustomerServiceLanguageUtils.bindDefaultToMultiple === 'function') {
    CustomerServiceLanguageUtils.bindDefaultToMultiple({
        singleId: 'customer_service_primary_locale_selector',
        multipleId: 'customer_service_supported_locales_selector'
    });
}

function getAgentLanguageSelector(id) {
    if (CustomerServiceLanguageUtils && typeof CustomerServiceLanguageUtils.get === 'function') {
        return CustomerServiceLanguageUtils.get(id);
    }
    if (window.WelineLanguageSelect && window.WelineLanguageSelect[id]) {
        return window.WelineLanguageSelect[id];
    }
    return null;
}

function syncAgentLanguageSelection(locale, supportedLocales) {
    const primarySelector = getAgentLanguageSelector('customer_service_primary_locale_selector');
    const supportedSelector = getAgentLanguageSelector('customer_service_supported_locales_selector');
    const primaryLocale = String(locale || CustomerServiceDefaultLocale || '').trim();

    let nextSupportedLocales = Array.isArray(supportedLocales) ? supportedLocales.slice() : [];
    nextSupportedLocales = nextSupportedLocales
        .map(value => String(value || '').trim())
        .filter((value, index, list) => value && list.indexOf(value) === index);

    if (primaryLocale && nextSupportedLocales.indexOf(primaryLocale) === -1) {
        nextSupportedLocales.unshift(primaryLocale);
    }

    if (primarySelector) {
        primarySelector.setValue(primaryLocale);
    }

    if (supportedSelector) {
        supportedSelector.setValues(nextSupportedLocales);
    }
}

function showAgentModal(agentId = 0) {
    const modal = document.getElementById('agent-modal');
    const form = document.getElementById('agent-form');
    const title = document.getElementById('modal-title');
    
    form.reset();
    document.getElementById('agent_id').value = 0;
    document.getElementById('is_active').checked = true;
    
    // 重置所有语言复选框
    syncAgentLanguageSelection(CustomerServiceDefaultLocale, CustomerServiceDefaultLocale ? [CustomerServiceDefaultLocale] : []);
    
    if (agentId > 0) {
        title.textContent = '<?= __('编辑客服') ?>';
        const agent = AgentManager.agents.find(a => parseInt(a.agent_id) === agentId);
        if (agent) {
            document.getElementById('agent_id').value = agent.agent_id;
            document.getElementById('user_id').value = agent.user_id;
            document.getElementById('name').value = agent.name;
            document.getElementById('email').value = agent.email;
            document.getElementById('max_sessions').value = agent.max_sessions;
            document.getElementById('is_active').checked = agent.is_active == 1;
            
            // 设置支持的语言
            let supportedLocales = agent.supported_locales || [];
            if (typeof supportedLocales === 'string') {
                try {
                    supportedLocales = JSON.parse(supportedLocales);
                } catch (e) {
                    supportedLocales = [agent.locale];
                }
            }
            if (!Array.isArray(supportedLocales) || supportedLocales.length === 0) {
                supportedLocales = [agent.locale];
            }
            syncAgentLanguageSelection(agent.locale, supportedLocales);
        }
    } else {
        title.textContent = '<?= __('添加客服') ?>';
        // 默认选中简体中文
        syncAgentLanguageSelection(CustomerServiceDefaultLocale, CustomerServiceDefaultLocale ? [CustomerServiceDefaultLocale] : []);
    }
    
    modal.style.display = 'flex';
}

function closeAgentModal() {
    document.getElementById('agent-modal').style.display = 'none';
}

function csToastError(message) {
    if (typeof BackendToast !== 'undefined' && BackendToast && typeof BackendToast.error === 'function') {
        BackendToast.error(message);
        return;
    }

    // 兜底：不使用浏览器原生 alert，改为页面内提示
    let el = document.getElementById('cs-agent-toast-error');
    if (!el) {
        el = document.createElement('div');
        el.id = 'cs-agent-toast-error';
        el.style.cssText = [
            'position:fixed',
            'left:50%',
            'top:20px',
            'transform:translateX(-50%)',
            'z-index:10050',
            'background:#dc3545',
            'color:#fff',
            'padding:10px 14px',
            'border-radius:8px',
            'max-width:92vw',
            'white-space:pre-wrap',
            'box-shadow:0 8px 24px rgba(0,0,0,.15)',
            'opacity:0',
            'transition:opacity .15s ease-in-out',
        ].join(';');
        document.body.appendChild(el);
    }

    el.textContent = message || '';
    el.style.opacity = '1';
    if (el._timer) clearTimeout(el._timer);
    el._timer = setTimeout(function () {
        el.style.opacity = '0';
    }, 3000);
}

function csShowConfirmDialog(message, options) {
    options = options || {};

    if (typeof BackendConfirm !== 'undefined' && BackendConfirm && typeof BackendConfirm.show === 'function') {
        return BackendConfirm.show(message, options).then(function (confirmed) {
            return !!confirmed;
        });
    }

    // 兜底：自建确认弹窗（避免使用浏览器原生 confirm）
    return new Promise(function (resolve) {
        const overlay = document.createElement('div');
        overlay.style.cssText = [
            'position:fixed',
            'inset:0',
            'background:rgba(0,0,0,.5)',
            'z-index:10004',
            'display:flex',
            'align-items:center',
            'justify-content:center',
            'padding:1rem'
        ].join(';');

        const dlg = document.createElement('div');
        dlg.style.cssText = [
            'background:#fff',
            'border-radius:12px',
            'padding:16px 18px',
            'max-width:92vw',
            'width:560px',
            'box-shadow:0 10px 30px rgba(0,0,0,.2)'
        ].join(';');

        const title = options.title || '<?= __('提示') ?>';
        const confirmText = options.confirmText || '<?= __('确认') ?>';
        const cancelText = options.cancelText || '<?= __('取消') ?>';
        const type = options.type || '';

        const titleEl = document.createElement('div');
        titleEl.style.cssText = 'font-weight:600;margin-bottom:8px;color:#6c757d;';
        titleEl.textContent = title;
        dlg.appendChild(titleEl);

        const msgEl = document.createElement('div');
        msgEl.style.cssText = 'white-space:pre-wrap;line-height:1.4;margin-bottom:14px;';
        msgEl.textContent = message || '';
        dlg.appendChild(msgEl);

        const btnRow = document.createElement('div');
        btnRow.style.cssText = 'display:flex;justify-content:flex-end;gap:10px;';

        const cancelBtn = document.createElement('button');
        cancelBtn.type = 'button';
        cancelBtn.className = 'btn btn-outline-secondary';
        cancelBtn.textContent = cancelText;
        btnRow.appendChild(cancelBtn);

        const confirmBtn = document.createElement('button');
        confirmBtn.type = 'button';
        confirmBtn.className = 'btn ' + (type === 'danger' ? 'btn-danger' : 'btn-primary');
        confirmBtn.textContent = confirmText;
        btnRow.appendChild(confirmBtn);

        dlg.appendChild(btnRow);
        overlay.appendChild(dlg);
        document.body.appendChild(overlay);

        function cleanup() {
            overlay.remove();
        }

        cancelBtn.addEventListener('click', function () {
            cleanup();
            resolve(false);
        });

        confirmBtn.addEventListener('click', function () {
            cleanup();
            resolve(true);
        });
    });
}

function editAgent(agentId) {
    showAgentModal(agentId);
}

function saveAgent() {
    const form = document.getElementById('agent-form');
    const formData = new FormData(form);
    
    // 处理复选框
    formData.set('is_active', document.getElementById('is_active').checked ? '1' : '0');
    
    fetch(AgentManager.saveUrl, {
        method: 'POST',
        body: new URLSearchParams(formData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            closeAgentModal();
            location.reload();
        } else {
            csToastError(data.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        csToastError('<?= __('保存失败') ?>');
    });
}

function deleteAgent(agentId) {
    csShowConfirmDialog(
        '<?= __('确定要删除此客服吗？') ?>',
        {
            title: '<?= __('删除确认') ?>',
            confirmText: '<?= __('确认') ?>',
            cancelText: '<?= __('取消') ?>',
            type: 'danger'
        }
    ).then(function (confirmed) {
        if (!confirmed) return;

        fetch(AgentManager.deleteUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ agent_id: agentId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                csToastError(data.message || '<?= __('删除失败') ?>');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            csToastError('<?= __('删除失败') ?>');
        });
    });
}

function viewStatistics(agentId) {
    const url = AgentManager.statisticsUrl + '?agent_id=' + agentId + '&period=all';
    
    fetch(url)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showStatisticsModal(data.data);
            } else {
                csToastError(data.message || '<?= __('获取统计数据失败') ?>');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            csToastError('<?= __('获取统计数据失败') ?>');
        });
}

function showStatisticsModal(statistics) {
    const modal = document.createElement('div');
    modal.className = 'statistics-modal';
    modal.innerHTML = `
        <div class="modal-content">
            <div class="modal-header">
                <h3><?= __('客服统计详情') ?></h3>
                <button class="close-btn" onclick="this.closest('.statistics-modal').remove()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="stat-detail-section">
                    <h4><?= __('会话统计') ?></h4>
                    <p><?= __('总会话数') ?>: ${statistics.sessions.total}</p>
                    <p><?= __('已关闭') ?>: ${statistics.sessions.closed}</p>
                    <p><?= __('进行中') ?>: ${statistics.sessions.active}</p>
                </div>
                <div class="stat-detail-section">
                    <h4><?= __('消息统计') ?></h4>
                    <p><?= __('总消息数') ?>: ${statistics.messages.total}</p>
                </div>
                <div class="stat-detail-section">
                    <h4><?= __('响应时间') ?></h4>
                    <p><?= __('平均') ?>: ${formatResponseTime(statistics.response_time.average)}</p>
                    <p><?= __('最快') ?>: ${formatResponseTime(statistics.response_time.min)}</p>
                    <p><?= __('最慢') ?>: ${formatResponseTime(statistics.response_time.max)}</p>
                </div>
                <div class="stat-detail-section">
                    <h4><?= __('会话时长') ?></h4>
                    <p><?= __('平均') ?>: ${statistics.session_duration.average} <?= __('分钟') ?></p>
                    <p><?= __('最短') ?>: ${statistics.session_duration.min} <?= __('分钟') ?></p>
                    <p><?= __('最长') ?>: ${statistics.session_duration.max} <?= __('分钟') ?></p>
                </div>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
    
    // 点击遮罩层关闭
    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            modal.remove();
        }
    });
}

function formatResponseTime(seconds) {
    if (!seconds || seconds === 0) return '-';
    if (seconds < 60) {
        return seconds.toFixed(1) + '<?= __('秒') ?>';
    } else {
        return (seconds / 60).toFixed(1) + '<?= __('分钟') ?>';
    }
}

// 点击遮罩层关闭弹窗
document.getElementById('agent-modal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeAgentModal();
    }
});
</script>

