    </div>
    
    <div class="config-form">
        <form id="config-form" onsubmit="return false;">
            <div class="form-group">
                <label><?= __('启用客服服务') ?></label>
                <select name="config[enabled]" class="form-control">
                    <option value="1" <?= ($configs['enabled'] ?? '1') == '1' ? 'selected' : '' ?>><?= __('启用') ?></option>
                    <option value="0" <?= ($configs['enabled'] ?? '1') == '0' ? 'selected' : '' ?>><?= __('禁用') ?></option>
                </select>
            </div>
            
            <div class="form-group">
                <label><?= __('默认客服语言') ?></label>
                <select name="config[default_agent_locale]" class="form-control">
                    <option value="zh_Hans_CN" <?= ($configs['default_agent_locale'] ?? 'zh_Hans_CN') == 'zh_Hans_CN' ? 'selected' : '' ?>><?= __('简体中文') ?></option>
                    <option value="en_US" <?= ($configs['default_agent_locale'] ?? 'zh_Hans_CN') == 'en_US' ? 'selected' : '' ?>><?= __('English') ?></option>
                </select>
            </div>
            
            <div class="form-group">
                <label><?= __('默认客户语言') ?></label>
                <select name="config[default_customer_locale]" class="form-control">
                    <option value="zh_Hans_CN" <?= ($configs['default_customer_locale'] ?? 'zh_Hans_CN') == 'zh_Hans_CN' ? 'selected' : '' ?>><?= __('简体中文') ?></option>
                    <option value="en_US" <?= ($configs['default_customer_locale'] ?? 'zh_Hans_CN') == 'en_US' ? 'selected' : '' ?>><?= __('English') ?></option>
                </select>
            </div>

            <!-- AI 智能客服配置 -->
            <hr style="margin: 20px 0;">
            <h3><?= __('AI 智能客服') ?></h3>
            <p style="color: #6b7280; font-size: 13px; margin-bottom: 15px;"><?= __('当没有客服人员在线时，可启用 AI 自动回复客户消息。') ?></p>

            <div class="form-group">
                <label><?= __('启用 AI 自动回复') ?></label>
                <select name="config[ai_enabled]" class="form-control">
                    <option value="0" <?= ($configs['ai_enabled'] ?? '0') == '0' ? 'selected' : '' ?>><?= __('禁用') ?></option>
                    <option value="1" <?= ($configs['ai_enabled'] ?? '0') == '1' ? 'selected' : '' ?>><?= __('启用') ?></option>
                </select>
                <small style="color: #9ca3af;"><?= __('启用后，客户端将显示蓝色"AI 智能客服"状态而非灰色"离线"') ?></small>
            </div>

            <div class="form-group">
                <label><?= __('AI 模型') ?></label>
                <input type="text" name="config[ai_model]" class="form-control" 
                       value="<?= htmlspecialchars($configs['ai_model'] ?? 'gpt-4o') ?>" 
                       placeholder="gpt-4o">
                <small style="color: #9ca3af;"><?= __('使用的 AI 模型标识，需在 Weline_Ai 模块中配置对应供应商') ?></small>
            </div>
            
            <div class="form-actions">
                <button type="button" class="btn btn-primary" onclick="saveConfig()">
                    <?= __('保存配置') ?>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function saveConfig() {
    const form = document.getElementById('config-form');
    const formData = new FormData(form);
    const data = {};
    
    for (let [key, value] of formData.entries()) {
        data[key] = value;
    }
    
    fetch('<?= $this->getBackendUrl("customerservice/backend/config/save") ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('<?= __('保存成功') ?>');
        } else {
            alert(data.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败') ?>');
    });
}
</script>

