    <script>
    function openChat() {
        // 尝试打开客服聊天窗口
        if (typeof CustomerServiceWidget !== 'undefined') {
            CustomerServiceWidget.toggleChat();
        } else {
            // 如果客服组件不可用，跳转到首页
            window.location.href = '/';
        }
    }

    document.addEventListener('click', function(event) {
        const backTrigger = event.target.closest('[data-cs-bind-back]');
        if (backTrigger) {
            event.preventDefault();
            history.back();
            return;
        }

        const chatTrigger = event.target.closest('[data-cs-bind-open-chat]');
        if (chatTrigger) {
            event.preventDefault();
            openChat();
        }
    });
    </script>
