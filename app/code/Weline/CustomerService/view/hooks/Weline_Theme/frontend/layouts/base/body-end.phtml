<script>
// 初始化客服组件的配置（必须在外部脚本加载前定义）
var customerServiceConfig = {
    chatUrl: '<?= htmlspecialchars($chatUrl) ?>',
    bindUrl: '<?= htmlspecialchars($bindUrl) ?>',
    customerId: <?= $customerId ? (int)$customerId : 'null' ?>,
    isLoggedIn: <?= $isLoggedIn ? 'true' : 'false' ?>
};

// 初始化客服组件（等待脚本加载完成）
function initCustomerServiceWidget() {
    // 确保 CustomerServiceWidget 已加载
    if (typeof CustomerServiceWidget === 'undefined') {
        // 如果未加载，延迟重试
        setTimeout(initCustomerServiceWidget, 100);
        return;
    }
    
    // 初始化
    try {
        CustomerServiceWidget.init(customerServiceConfig);
        
        // 检查是否需要显示绑定提示
        <?php if (!$isLoggedIn): ?>
        setTimeout(function() {
            if (typeof CustomerServiceWidget !== 'undefined' && typeof CustomerServiceWidget.showBindPrompt === 'function') {
                CustomerServiceWidget.showBindPrompt();
            }
        }, 5000); // 5秒后提示
        <?php endif; ?>
    } catch (error) {
        console.error('[CustomerService] 初始化失败:', error);
    }
}
</script>
<script src="@static(Weline_CustomerService::js/customer-service.js)" onload="initCustomerServiceWidget()"></script>
<script>
// 备用初始化：如果 onload 未触发，使用 DOMContentLoaded
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof CustomerServiceWidget !== 'undefined' && typeof initCustomerServiceWidget === 'function') {
            initCustomerServiceWidget();
        }
    });
} else {
    // DOM 已加载，延迟检查脚本是否已加载
    setTimeout(function() {
        if (typeof CustomerServiceWidget !== 'undefined' && typeof initCustomerServiceWidget === 'function') {
            initCustomerServiceWidget();
        }
    }, 100);
}
</script>

