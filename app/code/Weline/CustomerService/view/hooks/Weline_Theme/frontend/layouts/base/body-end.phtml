            <button class="cs-btn cs-btn-secondary" onclick="CustomerServiceWidget.closeBindModal()">
                <?= __('取消') ?>
            </button>
            <button class="cs-btn cs-btn-primary" onclick="CustomerServiceWidget.sendBindEmail()">
                <?= __('发送验证邮件') ?>
