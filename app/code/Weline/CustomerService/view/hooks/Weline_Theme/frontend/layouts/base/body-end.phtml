// 获取前端URL
/** @var \Weline\Framework\Http\Url $urlBuilder */
$urlBuilder = ObjectManager::getInstance(\Weline\Framework\Http\Url::class);
$chatUrl = $urlBuilder->getFrontendUrl('customerservice/frontend/chat');
$bindUrl = $urlBuilder->getFrontendUrl('customerservice/frontend/bind');
?>
<!-- 客服服务组件 -->
<link rel="stylesheet" href="@static(Weline_CustomerService::css/customer-service.css)">
<div id="customer-service-widget" class="customer-service-widget">
    <!-- 悬浮聊天按钮 -->
    <div id="cs-chat-button" class="cs-chat-button" onclick="CustomerServiceWidget.toggleChat()">
        <i class="mdi mdi-message-text"></i>
        <span class="cs-badge" id="cs-unread-badge" style="display: none;">0</span>
    </div>
    
    <!-- 聊天窗口 -->
    <div id="cs-chat-window" class="cs-chat-window" style="display: none;">
        <div class="cs-chat-header">
            <div class="cs-chat-title">
                <i class="mdi mdi-headset"></i>
                <span><?= __('客服服务') ?></span>
            </div>
            <div class="cs-chat-actions">
                <button class="cs-btn-icon" onclick="CustomerServiceWidget.toggleChat()" title="<?= __('收起') ?>">
                    <i class="mdi mdi-window-minimize"></i>
                </button>
            </div>
        </div>
        
        <div class="cs-chat-body" id="cs-chat-messages">
            <div class="cs-welcome-message">
                <p><?= __('欢迎使用客服服务！') ?></p>
                <p><?= __('请输入您的问题，我们的客服将尽快为您解答。') ?></p>
            </div>
        </div>
        
        <div class="cs-chat-footer">
            <div class="cs-language-selector" id="cs-language-selector" style="display: none;">
                <select id="cs-locale-select" onchange="CustomerServiceWidget.changeLanguage(this.value)">
                    <option value="zh_Hans_CN"><?= __('简体中文') ?></option>
                    <option value="en_US"><?= __('English') ?></option>
                </select>
            </div>
            <div class="cs-input-area">
                <textarea 
                    id="cs-message-input" 
                    class="cs-message-input" 
                    placeholder="<?= __('输入消息...') ?>"
                    rows="2"
                    onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();CustomerServiceWidget.sendMessage();}"></textarea>
                <button class="cs-send-button" onclick="CustomerServiceWidget.sendMessage()">
                    <i class="mdi mdi-send"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 邮件绑定弹窗 -->
<div id="cs-bind-modal" class="cs-modal" style="display: none;">
    <div class="cs-modal-content">
        <div class="cs-modal-header">
            <h3><?= __('绑定邮箱') ?></h3>
            <button class="cs-modal-close" onclick="CustomerServiceWidget.closeBindModal()">
                <i class="mdi mdi-close"></i>
            </button>
        </div>
