<script>
var customerServiceConfig = {
    chatUrl: '<?= htmlspecialchars($chatUrl) ?>',
    bindUrl: '<?= htmlspecialchars($bindUrl) ?>',
    customerId: <?= $customerId ? (int)$customerId : 'null' ?>,
    isLoggedIn: <?= $isLoggedIn ? 'true' : 'false' ?>,
    showGuestBindPrompt: <?= $showGuestBindPrompt ? 'true' : 'false' ?>,
    supportedLocales: <?= json_encode($supportedLocales, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>,
    widgetTranslations: <?= json_encode($widgetTranslations, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>
};

function initCustomerServiceWidget() {
    if (typeof CustomerServiceWidget === 'undefined') {
        setTimeout(initCustomerServiceWidget, 100);
        return;
    }

    try {
        CustomerServiceWidget.init(customerServiceConfig);
    } catch (error) {
        console.error('[CustomerService] 初始化失败', error);
    }
}
</script>
<script src="@static(Weline_CustomerService::js/customer-service.js)?v=<?= $customerServiceAssetVersion ?>" onload="initCustomerServiceWidget()"></script>
<script>
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof CustomerServiceWidget !== 'undefined' && typeof initCustomerServiceWidget === 'function') {
            initCustomerServiceWidget();
        }
    });
} else {
    setTimeout(function() {
        if (typeof CustomerServiceWidget !== 'undefined' && typeof initCustomerServiceWidget === 'function') {
            initCustomerServiceWidget();
        }
    }, 100);
}
</script>
