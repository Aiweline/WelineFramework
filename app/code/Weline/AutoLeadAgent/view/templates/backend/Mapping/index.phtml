<script>
let currentPage = 1;
let pageSize = 20;

// 页面加载时获取列表
document.addEventListener('DOMContentLoaded', function() {
    loadMappingList();
});

// 加载映射列表
function loadMappingList(page = 1) {
    currentPage = page;
    const tbody = document.getElementById('mapping-tbody');
    tbody.innerHTML = '<tr><td colspan="7" class="text-center"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">加载中...</span></div></td></tr>';

    const params = new URLSearchParams({
        page: currentPage,
        page_size: pageSize,
        region: document.getElementById('filter-region').value,
        language: document.getElementById('filter-language').value,
        is_active: document.getElementById('filter-status').value
    });

    fetch('@backend-url("auto-lead-agent/backend/mapping/list")?' + params.toString(), {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            renderMappingList(data.data);
            document.getElementById('mapping-pagination').innerHTML = data.pagination || '';
        } else {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger">' + (data.message || '加载失败') + '</td></tr>';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger">加载失败：' + error.message + '</td></tr>';
    });
}

// 渲染映射列表
function renderMappingList(items) {
    const tbody = document.getElementById('mapping-tbody');
    
    if (!items || items.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="text-center"><?= __('暂无数据') ?></td></tr>';
        return;
    }

    let html = '';
    items.forEach(item => {
        const enginesHtml = item.search_engines.map(engine => 
            '<span class="search-engines-badge">' + engine + '</span>'
        ).join('');
        
        const statusClass = item.is_active ? 'status-active' : 'status-inactive';
        const statusText = item.is_active ? '<?= __('启用') ?>' : '<?= __('禁用') ?>';
        
        html += `
            <tr>
                <td>${item.mapping_id}</td>
                <td>${item.region}</td>
                <td>${item.language}</td>
                <td>${enginesHtml}</td>
                <td>${item.sort_order}</td>
                <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                <td>
                    <button class="btn btn-sm btn-primary" onclick="editMapping(${item.mapping_id})">
                        <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                    </button>
                    <button class="btn btn-sm btn-${item.is_active ? 'warning' : 'success'}" onclick="toggleMapping(${item.mapping_id}, ${item.is_active ? 0 : 1})">
                        <i class="mdi mdi-${item.is_active ? 'close' : 'check'}"></i> ${item.is_active ? '<?= __('禁用') ?>' : '<?= __('启用') ?>'}
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="deleteMapping(${item.mapping_id})">
                        <i class="mdi mdi-delete"></i> <?= __('删除') ?>
                    </button>
                </td>
            </tr>
        `;
    });
    
    tbody.innerHTML = html;
}

// 显示添加表单
function showMappingForm() {
    document.getElementById('mapping-form-title').textContent = '<?= __('添加映射') ?>';
    document.getElementById('mapping-form').reset();
    document.getElementById('mapping-id').value = '0';
    document.getElementById('mapping-is-active').checked = true;
    
    // 清除所有搜索引擎选择
    document.querySelectorAll('input[name="search_engines[]"]').forEach(cb => cb.checked = false);
    
    const modal = new bootstrap.Modal(document.getElementById('mapping-form-modal'));
    modal.show();
}

// 编辑映射
function editMapping(mappingId) {
    fetch('@backend-url("auto-lead-agent/backend/mapping/get-form")?mapping_id=' + mappingId, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const item = data.data;
            document.getElementById('mapping-form-title').textContent = '<?= __('编辑映射') ?>';
            document.getElementById('mapping-id').value = item.mapping_id;
            document.getElementById('mapping-region').value = item.region;
            document.getElementById('mapping-language').value = item.language;
            document.getElementById('mapping-sort-order').value = item.sort_order;
            document.getElementById('mapping-is-active').checked = item.is_active;
            
            // 设置搜索引擎选择
            document.querySelectorAll('input[name="search_engines[]"]').forEach(cb => {
                cb.checked = item.search_engines.includes(cb.value);
            });
            
            const modal = new bootstrap.Modal(document.getElementById('mapping-form-modal'));
            modal.show();
        } else {
            alert(data.message || '<?= __('获取数据失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('获取数据失败') ?>：' + error.message);
    });
}

// 保存映射
document.getElementById('mapping-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const searchEngines = [];
    document.querySelectorAll('input[name="search_engines[]"]:checked').forEach(cb => {
        searchEngines.push(cb.value);
    });
    
    if (searchEngines.length === 0) {
        alert('<?= __('至少需要选择一个搜索引擎') ?>');
        return;
    }
    
    // 添加搜索引擎数组
    searchEngines.forEach(engine => {
        formData.append('search_engines[]', engine);
    });
    
    fetch('@backend-url("auto-lead-agent/backend/mapping/save")', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message || '<?= __('保存成功') ?>');
            bootstrap.Modal.getInstance(document.getElementById('mapping-form-modal')).hide();
            loadMappingList(currentPage);
        } else {
            alert(data.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('保存失败') ?>：' + error.message);
    });
});

// 切换启用状态
function toggleMapping(mappingId, newStatus) {
    if (!confirm('<?= __('确定要切换状态吗？') ?>')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('mapping_id', mappingId);
    
    fetch('@backend-url("auto-lead-agent/backend/mapping/toggle")', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            loadMappingList(currentPage);
        } else {
            alert(data.message || '<?= __('操作失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('操作失败') ?>：' + error.message);
    });
}

// 删除映射
function deleteMapping(mappingId) {
    if (!confirm('<?= __('确定要删除这条映射吗？删除后无法恢复。') ?>')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('mapping_id', mappingId);
    
    fetch('@backend-url("auto-lead-agent/backend/mapping/delete")', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message || '<?= __('删除成功') ?>');
            loadMappingList(currentPage);
        } else {
            alert(data.message || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('删除失败') ?>：' + error.message);
    });
}
</script>

