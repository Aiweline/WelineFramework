    // 下载扩展包
    window.downloadExtension = function() {
        var downloadUrl = '<?= $this->getBackendUrl('auto-lead-agent/backend/index/download-extension') ?>';
        window.location.href = downloadUrl;
    };
    
    // 打开扩展管理页面
    window.openExtensionPage = function() {
        var isEdge = navigator.userAgent.indexOf('Edg') !== -1;
        var isChrome = navigator.userAgent.indexOf('Chrome') !== -1 && !isEdge;
        var isFirefox = navigator.userAgent.indexOf('Firefox') !== -1;
        
        var extensionUrl = '';
        if (isEdge) {
            extensionUrl = 'edge://extensions/';
        } else if (isChrome) {
            extensionUrl = 'chrome://extensions/';
        } else if (isFirefox) {
            extensionUrl = 'about:debugging#/runtime/this-firefox';
        } else {
            alert('<?= __('请手动打开浏览器扩展管理页面') ?>');
            return;
        }
        
        // 尝试打开（可能被浏览器拦截）
        var newWindow = window.open(extensionUrl, '_blank');
        
        // 如果被拦截，显示提示
        if (!newWindow || newWindow.closed || typeof newWindow.closed === 'undefined') {
            // 复制到剪贴板
            navigator.clipboard.writeText(extensionUrl).then(function() {
                alert('<?= __('浏览器安全策略限制，无法自动打开。\n\n扩展页面地址已复制到剪贴板：') ?>\n' + extensionUrl + '\n\n<?= __('请手动粘贴到地址栏访问。') ?>');
            }).catch(function() {
                alert('<?= __('浏览器安全策略限制，请手动访问：') ?>\n' + extensionUrl);
            });
        }
    };
})();
