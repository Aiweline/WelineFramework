<script>
// 初始化任务页模型生命周期管理
document.addEventListener('DOMContentLoaded', function() {
    if (typeof ModelLifecycle !== 'undefined') {
        ModelLifecycle.init({
            onStatusChange: function(state) {
                console.log('[TaskPage] 模型状态变化:', state);
                // 更新模型状态显示
                var statusIndicator = document.getElementById('model-status-indicator');
                var unloadBtn = document.getElementById('task-model-unload-btn');
                
                if (statusIndicator) {
                    if (state.loaded) {
                        var typeLabel = state.modelType === 'chrome_ai' ? 'Chrome AI' : 'WebLLM';
                        statusIndicator.innerHTML = '<span class="badge bg-success"><i class="mdi mdi-check-circle"></i> 已加载 (' + typeLabel + ')</span>';
                    } else if (state.loading) {
                        statusIndicator.innerHTML = '<span class="badge bg-warning"><span class="spinner-border spinner-border-sm"></span> 加载中</span>';
                    } else {
                        statusIndicator.innerHTML = '<span class="badge bg-secondary"><i class="mdi mdi-sleep"></i> <?= __('待机') ?></span>';
                    }
                }
                
                if (unloadBtn) {
                    unloadBtn.style.display = state.loaded ? 'inline-block' : 'none';
                }
            },
            onUnload: function() {
                console.log('[TaskPage] 模型已卸载');
                // 更新内存显示
                var memoryIndicator = document.getElementById('memory-usage-indicator');
                if (memoryIndicator) {
                    memoryIndicator.innerHTML = '<span class="text-muted">-- MB</span>';
                }
            }
        });
        
        // 绑定卸载按钮
        var unloadBtn = document.getElementById('task-model-unload-btn');
        if (unloadBtn) {
            unloadBtn.addEventListener('click', function() {
                if (confirm('<?= __('确定要卸载模型吗？卸载后将释放内存，但需要重新加载才能执行任务。') ?>')) {
                    ModelLifecycle.unloadModel();
                }
            });
        }
    }
});
</script>

<script>
// 模型性能监控、配置状态与日志面板
(function() {
    'use strict';
    
    var CONFIG_GET_URL = '<?= $this->getBackendUrl('auto-lead-agent/backend/config/getConfig') ?>';
    
    var modelStatusEl = document.getElementById('model-status-indicator');
    var inferenceTimeEl = document.getElementById('inference-time-indicator');
    var memoryUsageEl = document.getElementById('memory-usage-indicator');
    var modelConfigSummaryEl = document.getElementById('model-config-summary');
    var reloadModelStatusBtn = document.getElementById('reload-model-status-btn');
    
    // 日志面板元素
    var taskRunningPanel = document.getElementById('task-running-panel');
    var runningTaskIdEl = document.getElementById('running-task-id');
    var runningStatusBadge = document.getElementById('running-status-badge');
    var runningFoundCountEl = document.getElementById('running-found-count');
    var inferenceLogContainer = document.getElementById('inference-log-container');
    var crawlLogContainer = document.getElementById('crawl-log-container');
    var inferenceLogCountEl = document.getElementById('inference-log-count');
    var crawlLogCountEl = document.getElementById('crawl-log-count');
    
    var inferenceLogCount = 0;
    var crawlLogCount = 0;
    var currentDisplayedTaskId = null; // 当前显示的任务ID
    
    // 状态映射
    var statusMap = {
        'idle': { icon: 'mdi-sleep', text: '<?= __('待机') ?>', class: 'bg-secondary' },
        'loading': { icon: 'mdi-information-outline', text: '<?= __('加载中') ?>', class: 'bg-warning' },
        'inferring': { icon: 'mdi-brain mdi-spin', text: '<?= __('推理中') ?>', class: 'bg-info' },
        'crawling': { icon: 'mdi-web mdi-spin', text: '<?= __('爬取中') ?>', class: 'bg-success' },
        'running': { icon: 'mdi-cog mdi-spin', text: '<?= __('运行中') ?>', class: 'bg-primary' },
        'paused': { icon: 'mdi-pause-circle', text: '<?= __('已暂停') ?>', class: 'bg-warning' },
        'completed': { icon: 'mdi-check-circle', text: '<?= __('已完成') ?>', class: 'bg-success' },
        'failed': { icon: 'mdi-alert-circle', text: '<?= __('失败') ?>', class: 'bg-danger' },
        'success': { icon: 'mdi-check-circle', text: '<?= __('完成') ?>', class: 'bg-success' },
        'error': { icon: 'mdi-alert-circle', text: '<?= __('错误') ?>', class: 'bg-danger' }
    };
    
    // 更新模型状态显示
    window.updateModelStatus = function(status, inferenceTime, memoryMB) {
        if (modelStatusEl) {
            var info = statusMap[status] || statusMap['idle'];
            modelStatusEl.innerHTML = '<span class="badge ' + info.class + '">' +
                '<i class="mdi ' + info.icon + '"></i> ' + info.text + '</span>';
        }
        
        // 同步更新运行面板状态
        if (runningStatusBadge) {
            var info = statusMap[status] || statusMap['idle'];
            runningStatusBadge.innerHTML = '<span class="badge ' + info.class + '">' +
                '<i class="mdi ' + info.icon + '"></i> ' + info.text + '</span>';
        }
        
        if (inferenceTimeEl && typeof inferenceTime === 'number') {
            var timeText = inferenceTime < 1000 
                ? inferenceTime.toFixed(0) + ' ms' 
                : (inferenceTime / 1000).toFixed(2) + ' s';
            inferenceTimeEl.innerHTML = '<span class="fw-bold text-warning">' + timeText + '</span>';
        }
        
        if (memoryUsageEl && typeof memoryMB === 'number') {
            var memoryText = memoryMB < 1024 
                ? memoryMB.toFixed(1) + ' MB' 
                : (memoryMB / 1024).toFixed(2) + ' GB';
            var memoryClass = memoryMB < 512 ? 'text-success' : (memoryMB < 2048 ? 'text-warning' : 'text-danger');
            memoryUsageEl.innerHTML = '<span class="fw-bold ' + memoryClass + '">' + memoryText + '</span>';
        }
    };

    // 从后端获取模型配置并更新摘要
    function refreshModelConfigSummary() {
        if (!CONFIG_GET_URL || !modelConfigSummaryEl) {
            return;
        }

        modelConfigSummaryEl.textContent = '<?= __('正在检测端侧模型配置...') ?>';

        fetch(CONFIG_GET_URL, {
            method: 'GET',
            headers: {
                'Accept': 'application/json'
            }
        })
            .then(function (res) {
                return res.json();
            })
            .then(function (data) {
                if (!data || data.success !== true || !data.data) {
                    modelConfigSummaryEl.textContent = (data && data.message) || '<?= __('无法获取模型配置，请稍后重试。') ?>';
                    return;
                }

                var cfg = data.data || {};
                var modelId = cfg.hf_model_id || '';
                var enabled = !!cfg.hf_model_enabled;
                var cacheSize = parseInt(cfg.hf_model_cache_size || '0', 10);

                if (!modelId) {
                    modelConfigSummaryEl.innerHTML =
                        '<span class="text-danger">' +
                        '<?= __('未配置端侧模型，任务启动前需要先在“配置管理”中选择 Hugging Face 模型。') ?>' +
                        '</span>';
                    return;
                }

                var statusText = '';
                if (!enabled) {
                    statusText =
                        '<?= __('当前模型：') ?>' + modelId +
                        '（<span class="text-warning"><?= __('未启用') ?></span>）' +
                        '，<?= __('请在配置页启用后再启动任务。') ?>';
                } else {
                    var cachePart = cacheSize > 0
                        ? '，<?= __('缓存上限：') ?>' + cacheSize + ' MB'
                        : '';
                    statusText =
                        '<?= __('当前已启用端侧模型：') ?>' + modelId + cachePart;
                }

                modelConfigSummaryEl.innerHTML = statusText;
            })
            .catch(function (err) {
                console.error('[AutoLeadAgent] Failed to load model config:', err);
                modelConfigSummaryEl.textContent = '<?= __('获取模型配置失败，请检查网络或稍后重试。') ?>';
            });
    }

    if (reloadModelStatusBtn) {
        reloadModelStatusBtn.addEventListener('click', function () {
            refreshModelConfigSummary();
        });
    }

    // 页面加载后自动检测一次
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', refreshModelConfigSummary);
    } else {
        refreshModelConfigSummary();
    }

    // ========== 浏览器 & MCP 扩展状态 ==========
    var browserMcpStatusText = document.getElementById('browser-mcp-status-text');

    function initBrowserAndMCPStatus() {
        var browserName = 'Unknown';
        var browserVersion = '';
        var isChrome = false;

        if (typeof BrowserDetector !== 'undefined' && BrowserDetector && typeof BrowserDetector.getBrowserInfo === 'function') {
            try {
                var info = BrowserDetector.getBrowserInfo();
                browserName = info.name || browserName;
                browserVersion = info.version || browserVersion;
                isChrome = !!info.isChrome;
            } catch (e) {
                console.warn('[AutoLeadAgent] BrowserDetector.getBrowserInfo failed:', e);
            }
        } else if (typeof navigator !== 'undefined') {
            var ua = navigator.userAgent || '';
            if (ua.indexOf('Chrome') !== -1 && ua.indexOf('Edg') === -1 && ua.indexOf('OPR') === -1) {
                browserName = 'Chrome';
                isChrome = true;
            } else if (ua.indexOf('Edg') !== -1) {
                browserName = 'Edge';
            } else if (ua.indexOf('Firefox') !== -1) {
                browserName = 'Firefox';
            }
        }

        var baseText = '<?= __('当前浏览器：') ?>' + browserName + (browserVersion ? (' ' + browserVersion) : '');

        if (browserMcpStatusText) {
            browserMcpStatusText.textContent = baseText + '，<?= __('正在检测 Browser MCP 扩展状态...') ?>';
        }

        var hasMCPClient = typeof MCPClient !== 'undefined' &&
                           MCPClient &&
                           typeof MCPClient.isMCPAvailable === 'function';

        if (hasMCPClient) {
            MCPClient.isMCPAvailable()
                .then(function (available) {
                    if (!browserMcpStatusText) return;
                    if (available) {
                        browserMcpStatusText.textContent =
                            baseText + '，<?= __('已检测到 Browser MCP 扩展，可使用 AI 浏览器工具。') ?>';
                    } else {
                        browserMcpStatusText.textContent =
                            baseText + '，<?= __('未检测到 Browser MCP 扩展，将无法使用 AI 浏览器工具自动操作页面。') ?>';
                    }
                })
                .catch(function (err) {
                    console.warn('[AutoLeadAgent] MCP availability check failed:', err);
                    if (browserMcpStatusText) {
                        browserMcpStatusText.textContent =
                            baseText + '，<?= __('检测 Browser MCP 扩展状态失败。') ?>';
                    }
                });
        } else if (browserMcpStatusText) {
            browserMcpStatusText.textContent =
                baseText + '，<?= __('当前环境不支持 Browser MCP 状态检测。') ?>';
        }

        // 非 Chrome 时给出一次性兼容性提示（不阻塞后续逻辑）
        if (!isChrome &&
            typeof BrowserDetector !== 'undefined' &&
            BrowserDetector &&
            typeof BrowserDetector.showIncompatibleDialog === 'function') {
            try {
                BrowserDetector.showIncompatibleDialog({
                    title: '<?= __('浏览器不兼容提示') ?>',
                    message: '<?= __('自动寻客功能推荐在 Chrome 浏览器中运行，以获得最佳的端侧模型与 MCP 工具支持。') ?>'
                });
            } catch (e) {
                console.warn('[AutoLeadAgent] showIncompatibleDialog failed:', e);
            }
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initBrowserAndMCPStatus);
    } else {
        initBrowserAndMCPStatus();
    }
    
    // 添加日志条目
    function addLogEntry(container, countEl, entry, type) {
        if (!container) return;
        
        // 首次添加时清空占位内容（改进：检查多种可能的占位文本格式）
        var placeholderElements = container.querySelectorAll('.text-muted.text-center, .text-center, [class*="loading"], [class*="等待"], .mdi-loading');
        if (placeholderElements.length > 0) {
            container.innerHTML = '';
        }
        
        // 如果容器内容只有占位文本（通过文本内容判断）
        var containerText = container.textContent || '';
        if (containerText.indexOf('任务启动中') !== -1 || 
            containerText.indexOf('等待爬取开始') !== -1 ||
            containerText.indexOf('等待任务开始') !== -1 ||
            containerText.indexOf('loading') !== -1 ||
            containerText.trim() === '任务启动中...' ||
            containerText.trim() === '等待爬取开始...' ||
            containerText.trim() === '等待任务开始...') {
            container.innerHTML = '';
        }
        
        // 如果是第一条推理日志，隐藏"任务启动中..."提示
        // 检查容器中是否已有日志条目（不包括占位文本）
        if (type === 'inference') {
            var existingLogs = container.querySelectorAll('.log-entry');
            if (existingLogs.length === 0) {
                var taskStartingStatus = document.getElementById('task-starting-status');
                if (taskStartingStatus) {
                    taskStartingStatus.style.display = 'none';
                }
            }
        }
        
        var logDiv = document.createElement('div');
        logDiv.className = 'log-entry px-3 py-1 border-bottom';
        
        // 根据内容添加不同样式
        var textClass = 'text-dark';
        if (entry.message.indexOf('✓') !== -1 || entry.message.indexOf('成功') !== -1) {
            textClass = 'text-success';
        } else if (entry.message.indexOf('失败') !== -1 || entry.message.indexOf('错误') !== -1 || entry.message.indexOf('❌') !== -1) {
            textClass = 'text-danger';
        } else if (entry.message.indexOf('正在') !== -1 || entry.message.indexOf('开始') !== -1 || entry.message.indexOf('【') !== -1) {
            textClass = 'text-primary';
        } else if (entry.message.indexOf('⚠️') !== -1 || entry.message.indexOf('💡') !== -1) {
            textClass = 'text-warning';
        }
        
        logDiv.innerHTML = '<span class="text-muted me-2">[' + entry.time + ']</span>' +
            '<span class="' + textClass + '">' + escapeHtml(entry.message) + '</span>';
        
        container.appendChild(logDiv);
        
        // 自动滚动到底部
        container.scrollTop = container.scrollHeight;
        
        // 更新计数（只更新爬取日志计数，推理日志计数由实际推理次数决定）
        if (countEl) {
            if (type === 'crawl') {
                crawlLogCount++;
                countEl.textContent = crawlLogCount;
            }
            // 推理日志计数不再基于日志条目数，而是基于实际的推理调用次数
            // 实际推理次数通过 taskRunnerStatusChange 或 taskRunnerProgress 事件更新
        }
    }
    
    // HTML转义
    function escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    // 显示任务运行面板
    window.showTaskRunningPanel = function(taskId) {
        if (taskRunningPanel) {
            taskRunningPanel.style.display = 'block';
            if (runningTaskIdEl) {
                runningTaskIdEl.textContent = '<?= __('任务') ?> #' + taskId;
            }
            
            // 只在任务ID变化时清空日志（避免状态变化时清空已有日志）
            var isNewTask = currentDisplayedTaskId !== taskId;
            if (isNewTask) {
                currentDisplayedTaskId = taskId;
                // 显示任务启动中状态在row align-items-center内
                var taskStartingStatus = document.getElementById('task-starting-status');
                if (taskStartingStatus) {
                    taskStartingStatus.style.display = 'block';
                }
                // 清空日志（新任务）
                inferenceLogCount = 0;
                crawlLogCount = 0;
                if (inferenceLogContainer) {
                    inferenceLogContainer.innerHTML = '';
                }
                if (crawlLogContainer) {
                    crawlLogContainer.innerHTML = '<div class="p-3 text-muted text-center"><i class="mdi mdi-information-outline"></i> <?= __('等待爬取开始...') ?></div>';
                }
                if (inferenceLogCountEl) inferenceLogCountEl.textContent = '0';
                if (crawlLogCountEl) crawlLogCountEl.textContent = '0';
            }
        }
    };
    
    // 隐藏任务运行面板
    window.hideTaskRunningPanel = function() {
        if (taskRunningPanel) {
            taskRunningPanel.style.display = 'none';
            currentDisplayedTaskId = null; // 重置任务ID，下次显示时识别为新任务
        }
    };
    
    // 更新找到的客户数量
    window.updateFoundCount = function(count) {
        if (runningFoundCountEl) {
            runningFoundCountEl.textContent = count;
        }
    };
    
    // 监听TaskRunner日志事件
    window.addEventListener('taskRunnerLog', function(e) {
        var detail = e.detail;
        if (detail.type === 'inference') {
            addLogEntry(inferenceLogContainer, inferenceLogCountEl, detail.entry, 'inference');
        } else if (detail.type === 'crawl') {
            addLogEntry(crawlLogContainer, crawlLogCountEl, detail.entry, 'crawl');
        }
    });
    
    // 监听状态变化事件
    window.addEventListener('taskRunnerStatusChange', function(e) {
        var detail = e.detail;
        window.updateModelStatus(detail.status);
        
        if (detail.foundCount !== undefined) {
            window.updateFoundCount(detail.foundCount);
        }
        
        // 更新推理日志计数为实际的推理次数
        if (detail.totalInferences !== undefined && inferenceLogCountEl) {
            inferenceLogCount = detail.totalInferences;
            inferenceLogCountEl.textContent = inferenceLogCount;
        }
        
        // 如果任务开始运行，显示面板
        if (detail.status === 'running' || detail.status === 'inferring' || 
            detail.status === 'crawling' || detail.status === 'loading') {
            if (detail.taskId) {
                window.showTaskRunningPanel(detail.taskId);
            }
        }
        
        // 如果任务结束，延迟隐藏面板
        if (detail.status === 'idle' || detail.status === 'completed' || detail.status === 'failed') {
            // 保留面板显示，让用户查看日志
        }
    });
    
    // 监听进度更新事件
    window.addEventListener('taskRunnerProgress', function(e) {
        var detail = e.detail;
        if (detail.foundCount !== undefined) {
            window.updateFoundCount(detail.foundCount);
        }
        
        // 更新推理日志计数为实际的推理次数
        if (detail.totalInferences !== undefined && inferenceLogCountEl) {
            inferenceLogCount = detail.totalInferences;
            inferenceLogCountEl.textContent = inferenceLogCount;
        }
    });
    
    // 暂停按钮事件
