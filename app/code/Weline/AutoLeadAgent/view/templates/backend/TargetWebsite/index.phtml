<script>
let currentPage = 1;
let pageSize = 20;

// 加载目标网站列表
function loadTargetWebsiteList(page = 1) {
    currentPage = page;
    const search = document.getElementById('filter-search').value;
    const status = document.getElementById('filter-status').value;
    
    const params = new URLSearchParams({
        page: currentPage,
        page_size: pageSize
    });
    
    if (search) {
        params.append('search', search);
    }
    if (status !== '') {
        params.append('is_active', status);
    }
    
    fetch('@backend-url("auto-lead-agent/backend/target-website/list")?' + params.toString(), {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            renderTargetWebsiteList(result.data);
            document.getElementById('target-website-pagination').innerHTML = result.pagination || '';
        } else {
            alert(result.message || '<?= __('加载失败') ?>');
        }
    })
    .catch(error => {
        console.error('Load target website list error:', error);
        alert('<?= __('加载失败') ?>');
    });
}

// 渲染目标网站列表
function renderTargetWebsiteList(data) {
    const tbody = document.getElementById('target-website-tbody');
    
    if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="text-center"><?= __('暂无数据') ?></td></tr>';
        return;
    }
    
    let html = '';
    data.forEach(item => {
        const statusClass = item.is_active ? 'status-active' : 'status-inactive';
        const statusText = item.is_active ? '<?= __('启用') ?>' : '<?= __('禁用') ?>';
        const syntaxPreview = item.search_syntax_template ? 
            (item.search_syntax_template.length > 50 ? 
                item.search_syntax_template.substring(0, 50) + '...' : 
                item.search_syntax_template) : 
            '-';
        
        html += `
            <tr>
                <td>${item.target_website_id}</td>
                <td><strong>${item.name}</strong></td>
                <td><code>${item.domain}</code></td>
                <td>
                    <div class="syntax-template" title="${item.search_syntax_template || ''}">
                        ${syntaxPreview}
                    </div>
                </td>
                <td>${item.sort_order}</td>
                <td>
                    <span class="status-badge ${statusClass}">${statusText}</span>
                </td>
                <td>
                    <button class="btn btn-sm btn-primary me-1" onclick="editTargetWebsite(${item.target_website_id})">
                        <i class="mdi mdi-pencil"></i> <?= __('编辑') ?>
                    </button>
                    <button class="btn btn-sm btn-${item.is_active ? 'warning' : 'success'}" onclick="toggleTargetWebsiteActive(${item.target_website_id}, ${item.is_active ? 0 : 1})">
                        <i class="mdi mdi-toggle-switch${item.is_active ? '-off' : ''}"></i> ${item.is_active ? '<?= __('禁用') ?>' : '<?= __('启用') ?>'}
                    </button>
                    <button class="btn btn-sm btn-danger ms-1" onclick="deleteTargetWebsite(${item.target_website_id})">
                        <i class="mdi mdi-delete"></i> <?= __('删除') ?>
                    </button>
                </td>
            </tr>
        `;
    });
    
    tbody.innerHTML = html;
}

// 显示添加表单
function showTargetWebsiteForm() {
    document.getElementById('target-website-form').reset();
    document.getElementById('target-website-id').value = '0';
    document.getElementById('target-website-form-title').textContent = '<?= __('添加目标网站') ?>';
    document.getElementById('target-website-is-active').checked = true;
    const modal = new bootstrap.Modal(document.getElementById('target-website-form-modal'));
    modal.show();
}

// 编辑目标网站
function editTargetWebsite(id) {
    fetch('@backend-url("auto-lead-agent/backend/target-website/list")?page=1&page_size=1', {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            const item = result.data.find(i => i.target_website_id === id);
            if (item) {
                document.getElementById('target-website-id').value = item.target_website_id;
                document.getElementById('target-website-name').value = item.name;
                document.getElementById('target-website-domain').value = item.domain;
                document.getElementById('target-website-syntax-template').value = item.search_syntax_template || '';
                document.getElementById('target-website-description').value = item.description || '';
                document.getElementById('target-website-icon-url').value = item.icon_url || '';
                document.getElementById('target-website-sort-order').value = item.sort_order || 0;
                document.getElementById('target-website-is-active').checked = item.is_active;
                document.getElementById('target-website-form-title').textContent = '<?= __('编辑目标网站') ?>';
                const modal = new bootstrap.Modal(document.getElementById('target-website-form-modal'));
                modal.show();
            }
        }
    })
    .catch(error => {
        console.error('Load target website error:', error);
        alert('<?= __('加载失败') ?>');
    });
}

// 保存目标网站
document.getElementById('target-website-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const data = {};
    for (const [key, value] of formData.entries()) {
        if (key === 'is_active') {
            data[key] = document.getElementById('target-website-is-active').checked ? 1 : 0;
        } else {
            data[key] = value;
        }
    }
    
    fetch('@backend-url("auto-lead-agent/backend/target-website/save")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: new URLSearchParams(data).toString()
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert(result.message || '<?= __('保存成功') ?>');
            bootstrap.Modal.getInstance(document.getElementById('target-website-form-modal')).hide();
            loadTargetWebsiteList(currentPage);
        } else {
            alert(result.message || '<?= __('保存失败') ?>');
        }
    })
    .catch(error => {
        console.error('Save target website error:', error);
        alert('<?= __('保存失败') ?>');
    });
});

// 启用/禁用目标网站
function toggleTargetWebsiteActive(id, newStatus) {
    if (!confirm(newStatus ? '<?= __('确定要启用该目标网站吗？') ?>' : '<?= __('确定要禁用该目标网站吗？') ?>')) {
        return;
    }
    
    const formData = new URLSearchParams({
        target_website_id: id
    });
    
    fetch('@backend-url("auto-lead-agent/backend/target-website/toggle-active")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData.toString()
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert(result.message || '<?= __('操作成功') ?>');
            loadTargetWebsiteList(currentPage);
        } else {
            alert(result.message || '<?= __('操作失败') ?>');
        }
    })
    .catch(error => {
        console.error('Toggle target website active error:', error);
        alert('<?= __('操作失败') ?>');
    });
}

// 删除目标网站
function deleteTargetWebsite(id) {
    if (!confirm('<?= __('确定要删除该目标网站吗？此操作不可恢复！') ?>')) {
        return;
    }
    
    const formData = new URLSearchParams({
        target_website_id: id
    });
    
    fetch('@backend-url("auto-lead-agent/backend/target-website/delete")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: formData.toString()
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert(result.message || '<?= __('删除成功') ?>');
            loadTargetWebsiteList(currentPage);
        } else {
            alert(result.message || '<?= __('删除失败') ?>');
        }
    })
    .catch(error => {
        console.error('Delete target website error:', error);
        alert('<?= __('删除失败') ?>');
    });
}

// 页面加载时初始化
document.addEventListener('DOMContentLoaded', function() {
    loadTargetWebsiteList();
});
</script>

