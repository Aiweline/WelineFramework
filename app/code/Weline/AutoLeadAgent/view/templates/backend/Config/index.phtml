        // ── 规则引擎回退（AI 不可用或 AI 输出解析失败时） ──
        c.info('<?= __('规则引擎分析') ?>: lastAction=' + completedActions[completedActions.length - 1] + ', hasSnapshot=' + !!snapshot);
        var ruleResult = rulePlanNextAction(originalInput, snapshot, completedActions);
        if (ruleResult) {
            c.info('<?= __('规则引擎决策') ?>: ' + ruleResult.action + ' - ' + (ruleResult.reason || ''));
        } else {
            c.info('<?= __('规则引擎：无后续动作') ?>');
