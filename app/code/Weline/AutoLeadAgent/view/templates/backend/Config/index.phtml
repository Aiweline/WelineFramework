<script>
// AutoLeadAgent 扩展ID配置
// 注意：实际扩展ID需要根据打包后的扩展ID进行修改
// 可以通过 chrome://extensions/ 页面查看已安装扩展的ID
window.AUTOLEADAGENT_EXTENSION_IDS = [
    'your-extension-id-here', // 请替换为实际的扩展ID
    'autoleadagent-weline-extension', // 备用ID1
    'weline-auto-lead-agent' // 备用ID2
];

// 打开缓存目录数据库
    async function openCacheDirDB() {
        return new Promise((resolve, reject) => {
            const request = indexedDB.open('AutoLeadAgentCacheDir', 1);
            
            request.onerror = () => reject(request.error);
            request.onsuccess = () => resolve(request.result);
            
            request.onupgradeneeded = (event) => {
                const db = event.target.result;
                if (!db.objectStoreNames.contains('cacheDir')) {
                    db.createObjectStore('cacheDir');
                }
            };
        });
    }
    
    // 获取缓存的目录句柄
    async function getCachedDirectoryHandle() {
        try {
            const db = await openCacheDirDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(['cacheDir'], 'readonly');
                const store = tx.objectStore('cacheDir');
                const request = store.get('default');
                
                request.onsuccess = () => resolve(request.result ? request.result.handle : null);
                request.onerror = () => reject(request.error);
            });
        } catch (error) {
            console.error('[Config] 获取缓存目录句柄失败:', error);
            return null;
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
    
    // 表单提交
    var form = document.getElementById('config-form');
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            saveConfig();
        });
    }
    
    // 确认重置按钮
    var confirmResetBtn = document.getElementById('btn-confirm-reset');
    if (confirmResetBtn) {
        confirmResetBtn.addEventListener('click', function() {
            doResetConfig();
        });
    }
});

function saveConfig() {
    var form = document.getElementById('config-form');
    var btn = document.getElementById('btn-save-config');
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在保存...') ?>';
    
    var formData = new FormData(form);
    
    // 处理checkbox
    if (!formData.has('wasm_model_enabled')) {
        formData.set('wasm_model_enabled', '0');
    }
    
    
    // 使用当前页面的路径构建保存URL
    var currentPath = window.location.pathname;
    var saveUrl = currentPath + '/save';
    console.log('[Config] 保存 URL:', saveUrl, '当前路径:', currentPath);
    
    // 打印表单数据便于调试
    for (var pair of formData.entries()) {
        console.log('[Config] 表单数据:', pair[0], '=', pair[1]);
    }
    
    fetch(saveUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(response) {
        console.log('[Config] 响应状态:', response.status, response.statusText);
        return response.text().then(function(text) {
            console.log('[Config] 响应内容:', text);
            try {
                return JSON.parse(text);
            } catch (e) {
                console.error('[Config] JSON 解析失败:', e);
                throw new Error('服务器响应格式错误: ' + text.substring(0, 200));
            }
        });
    })
    .then(function(result) {
        console.log('[Config] 解析结果:', result);
        if (result.success) {
            showToast('success', result.message || '<?= __('配置保存成功') ?>');
        } else {
            showToast('error', result.message || '<?= __('配置保存失败') ?>');
        }
    })
    .catch(function(error) {
        console.error('[Config] 保存配置错误:', error);
        showToast('error', '<?= __('配置保存失败') ?>: ' + error.message);
    })
    .finally(function() {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    });
}

function resetConfig() {
    var modal = new bootstrap.Modal(document.getElementById('resetConfirmModal'));
    modal.show();
}

function doResetConfig() {
    var btn = document.getElementById('btn-confirm-reset');
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在重置...') ?>';
    
    var currentPath = window.location.pathname;
    var resetUrl = currentPath + '/reset';
    
    fetch(resetUrl, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
        }
    })
    .then(function(response) {
        return response.json();
    })
    .then(function(result) {
        var modal = bootstrap.Modal.getInstance(document.getElementById('resetConfirmModal'));
        if (modal) {
            modal.hide();
        }
        
        if (result.success) {
            showToast('success', result.message || '<?= __('配置已重置为默认值') ?>');
            // 刷新页面以加载默认配置
            setTimeout(function() {
                window.location.reload();
            }, 1000);
        } else {
            showToast('error', result.message || '<?= __('重置配置失败') ?>');
        }
    })
    .catch(function(error) {
        console.error('Reset config error:', error);
        showToast('error', '<?= __('重置配置失败') ?>');
    })
    .finally(function() {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    });
}

function showToast(type, message) {
    // 如果有全局的 toast 函数则使用，否则使用 alert
    if (typeof Toastify !== 'undefined') {
        Toastify({
            text: message,
            duration: 3000,
            gravity: 'top',
            position: 'right',
            backgroundColor: type === 'success' ? '#28a745' : '#dc3545'
        }).showToast();
    } else if (typeof toastr !== 'undefined') {
        toastr[type](message);
    } else {
        // 降级方案：使用 console 输出，不使用 alert
        console.log('[Toast]', type, ':', message);
    }
}
</script>
