use Weline\AutoLeadAgent\Model\AgentConfig;


$configs = $this->getData('configs') ?? [];
$keywordStrategyOptions = $this->getData('keyword_strategy_options') ?? [];
$defaultConfigs = $this->getData('default_configs') ?? [];

// 处理目标网站数组为文本（确保每行一个）
$targetSites = $configs['default_target_sites'] ?? [];
$targetSitesText = '';

// 处理各种格式的数据，统一转换为每行一个的文本格式
// 确保始终处理为数组
if (!is_array($targetSites)) {
    // 如果不是数组，尝试转换
    if (is_string($targetSites)) {
        $trimmed = trim($targetSites);
        // 排除布尔值字符串
        if ($trimmed === 'true' || $trimmed === 'false' || $trimmed === '1' || $trimmed === '0') {
            // 如果是布尔值字符串，使用默认值
            $targetSites = AgentConfig::getDefaultConfigs()[AgentConfig::CONFIG_DEFAULT_TARGET_SITES] ?? [];
        } elseif (preg_match('/^\[.*\]$/s', $trimmed)) {
            // JSON 数组格式
            $decoded = json_decode($trimmed, true);
            if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
                $targetSites = $decoded;
            } else {
                // 解码失败，使用默认值
                $targetSites = AgentConfig::getDefaultConfigs()[AgentConfig::CONFIG_DEFAULT_TARGET_SITES] ?? [];
            }
        } else {
            // 每行一个的文本格式
            $targetSites = array_filter(array_map('trim', explode("\n", $targetSites)));
        }
    } elseif (is_bool($targetSites)) {
        // 如果是布尔值，使用默认值
        $targetSites = AgentConfig::getDefaultConfigs()[AgentConfig::CONFIG_DEFAULT_TARGET_SITES] ?? [];
    } else {
        // 其他类型，使用默认值
        $targetSites = AgentConfig::getDefaultConfigs()[AgentConfig::CONFIG_DEFAULT_TARGET_SITES] ?? [];
    }
}

// 确保是数组后，转换为每行一个的文本
if (is_array($targetSites)) {
    $targetSitesText = implode("\n", array_filter(array_map('trim', $targetSites)));
} else {
    $targetSitesText = '';
}
