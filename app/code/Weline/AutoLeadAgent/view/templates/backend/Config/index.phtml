                try {
                    var raw = null;
                    // 优先通过扩展推理（模型在扩展内运行）— 流式输出
                    var isExtModel = (typeof ModelLifecycle !== 'undefined' && ModelLifecycle.getState && ModelLifecycle.getState().modelType === 'extension');
                    if (isExtModel) {
                        raw = await streamGenerate(c, analysisPrompt, { maxTokens: 512, temperature: 0.3, label: '<?= __('AI 分析指令') ?>' });
                    } else if (typeof HFModelManager !== 'undefined' && HFModelManager.isLoaded && HFModelManager.isLoaded()) {
                        c.log('<?= __('通过页面端模型推理...') ?>');
                        raw = await HFModelManager.generate(analysisPrompt, { maxTokens: 512, temperature: 0.3 });
                    } else {
                        raw = await streamGenerate(c, analysisPrompt, { maxTokens: 512, temperature: 0.3, label: '<?= __('AI 分析指令') ?>' });
                    }
                    if (raw) {
                        var rawStr = typeof raw === 'string' ? raw : (raw.text || raw.generated_text || JSON.stringify(raw));
                        var jsonMatch = rawStr.match(/\{[\s\S]*\}/);
                        if (jsonMatch) actionPlan = JSON.parse(jsonMatch[0]);
                    }
                } catch (modelErr) {
                    c.warn('<?= __('模型分析失败，降级到智能匹配') ?>: ' + modelErr.message);
                }
            }

            if (!actionPlan || !actionPlan.action) {
                c.info('<?= __('使用智能关键词匹配...') ?>');
                actionPlan = smartParseCommand(input);
            }

            // ── 如果还是无法解析，且 MCP 可用，尝试直接委派给扩展 ──
            if (!actionPlan || !actionPlan.action) {
                if (mcpAvailable && typeof MCPClient !== 'undefined' && MCPClient.sendTaskToExtension) {
                    c.info('<?= __('智能匹配无法解析，尝试委派给扩展 Agent 执行...') ?>');
                    actionPlan = {
                        action: 'natural_language_task',
                        params: { task: input, fullCommand: input },
                        reason: '<?= __('无法本地解析，委派给扩展 AI Agent') ?>',
                        requiresMCP: true
                    };
                } else {
                    throw new Error('<?= __('无法解析指令。可用命令示例：') ?>\n' +
                        '  • <?= __('访问') ?> https://www.google.com\n' +
                        '  • <?= __('搜索 "关键词"') ?>\n' +
                        '  • https://example.com <?= __('帮我提取联系方式') ?>\n' +
                        '  • <?= __('点击第3个按钮') ?>\n' +
                        '  • <?= __('输入 "文字内容"') ?>\n' +
                        '<?= __('提示：安装浏览器扩展可执行复杂自动化任务') ?>');
                }
            }

            c.success('<?= __('解析结果') ?>');
            c.json('actionPlan', actionPlan);

            // ── 执行操作 ──
            async function executeSingleAction(plan, stepIndex) {
                var prefix = stepIndex !== undefined ? ('[<?= __('步骤') ?> ' + (stepIndex + 1) + '] ') : '';
                c.section(prefix + '<?= __('执行') ?>: ' + plan.action);

                // 自然语言任务 → 委派给扩展 Agent
                if (plan.action === 'natural_language_task') {
                    if (!mcpAvailable || typeof MCPClient === 'undefined' || !MCPClient.sendTaskToExtension) {
                        c.warn('<?= __('此操作需要浏览器扩展 Agent，请确保扩展已安装并启用') ?>');
                        return { success: false, reason: 'MCP not available' };
                    }
                    var taskDesc = (plan.params && plan.params.fullCommand) || (plan.params && plan.params.task) || '';
                    c.info('<?= __('委派给扩展 Agent') ?>: ' + taskDesc);
                    c.log('<?= __('扩展将使用内置 AI 分解任务并自动执行...') ?>');
                    try {
                        var taskResult = await MCPClient.sendTaskToExtension(taskDesc);
                        c.success('<?= __('扩展 Agent 已接收任务') ?>');
                        c.json('<?= __('扩展响应') ?>', taskResult);
                        return { success: true, method: '<?= __('扩展 Agent') ?>', result: taskResult };
                    } catch (taskErr) {
                        c.warn('<?= __('扩展 Agent 执行异常') ?>: ' + taskErr.message);
                        c.info('<?= __('请确保扩展 Side Panel 已打开，或扩展已配置 API Key') ?>');
                        return { success: false, error: taskErr.message };
                    }
                }

                // ── 输入文本并提交（搜索框输入 → 回车） ──
                if (plan.action === 'input_and_submit') {
                    if (!mcpAvailable || typeof MCPClient === 'undefined') {
                        c.warn('<?= __('需要 MCP 扩展支持') ?>');
                        return { success: false, reason: 'MCP not available' };
                    }
                    var inputText = (plan.params && plan.params.text) || '';
                    var inputIndex = (plan.params && plan.params.index != null) ? plan.params.index : -1;
                    c.info('<?= __('输入') ?>: "' + inputText + '"');
                    try {
                        // 先点击搜索框（聚焦）— 使用 click_element
                        if (inputIndex >= 0) {
                            c.log('<?= __('点击元素') ?> [' + inputIndex + '] <?= __('聚焦') ?>');
                            await MCPClient.callTool('click_element', { index: inputIndex });
                            await new Promise(function(r){ setTimeout(r, 500); });
                        }
                        // 输入文本 — 使用 input_text，传 snapshotIndex 以精确定位
                        await MCPClient.callTool('input_text', { snapshotIndex: inputIndex, text: inputText });
                        c.success('<?= __('已输入文本') ?>');
                        // 按回车提交 — 使用 send_keys
                        if (plan.params && plan.params.pressEnter) {
                            await new Promise(function(r){ setTimeout(r, 300); });
                            await MCPClient.callTool('send_keys', { keys: 'Enter' });
                            c.info('<?= __('已按下回车键') ?>');

                            // 等待看页面是否变化（提交是否生效）
                            await new Promise(function(r){ setTimeout(r, 2000); });
                            try {
                                var afterSnap = await MCPClient.callTool('browser_snapshot', {});
                                var afterData = afterSnap ? ((afterSnap.result !== undefined) ? afterSnap.result : afterSnap) : null;
                                var afterUrl = afterData && afterData.url ? afterData.url : '';
                                // 如果页面没变（还在搜索引擎首页），尝试直接导航到搜索结果页
                                var isStillOnSearchHome = /google\.com\/?(\?|$)|google\.com\.hk\/?(\?|$)|baidu\.com\/?$|bing\.com\/?$/.test(afterUrl);
                                if (isStillOnSearchHome && inputText) {
                                    c.log('<?= __('表单提交未生效，直接导航到搜索结果...') ?>');
                                    var searchUrl = 'https://www.google.com/search?q=' + encodeURIComponent(inputText);
                                    if (afterUrl.includes('baidu.com')) searchUrl = 'https://www.baidu.com/s?wd=' + encodeURIComponent(inputText);
                                    else if (afterUrl.includes('bing.com')) searchUrl = 'https://www.bing.com/search?q=' + encodeURIComponent(inputText);
                                    await MCPClient.callTool('go_to_url', { url: searchUrl });
                                    c.success('<?= __('已直接导航到搜索结果') ?>');
                                }
                            } catch (_) {}
                        }
                        return { success: true, method: 'MCP', result: { action: 'input_and_submit', text: inputText }, action: 'input_and_submit' };
                    } catch (inputErr) {
                        c.warn('<?= __('输入操作失败') ?>: ' + inputErr.message);
                        return { success: false, error: inputErr.message, action: 'input_and_submit' };
                    }
                }

                // ── 等待并拍快照 ──
                if (plan.action === 'wait_and_snapshot') {
                    var waitMs = (plan.params && plan.params.waitMs) || 3000;
                    c.info('<?= __('等待页面加载') ?> (' + (waitMs / 1000) + 's)...');
                    await new Promise(function(r){ setTimeout(r, waitMs); });
                    try {
                        var snap = await MCPClient.callTool('browser_snapshot', {});
                        var snapData = snap ? ((snap.result !== undefined) ? snap.result : snap) : null;
                        if (snapData) {
                            renderPageSnapshot(c, snapData);
                        }
                        return { success: true, method: 'MCP', result: Object.assign({ _snapshot: snapData }, snapData || {}), action: 'wait_and_snapshot' };
                    } catch (snapErr) {
                        c.warn('<?= __('快照失败') ?>: ' + snapErr.message);
                        return { success: false, error: snapErr.message, action: 'wait_and_snapshot' };
                    }
                }

                // ── 总结页面内容（利用页面文本 + 搜索结果提取） ──
                if (plan.action === 'summarize_page') {
                    var query = (plan.params && plan.params.query) || input || '';
                    c.info('<?= __('正在分析页面内容...') ?>');
                    try {
                        // 获取最新快照
                        var summSnap = await MCPClient.callTool('browser_snapshot', {});
                        var summData = summSnap ? ((summSnap.result !== undefined) ? summSnap.result : summSnap) : null;
                        if (!summData || !summData.textContent || summData.textContent.length < 30) {
                            c.warn('<?= __('页面内容不足，无法提取有效信息') ?>');
                            return { success: false, reason: 'no content', action: 'summarize_page' };
                        }
                        var pageText = summData.textContent;
                        var pageTitle = summData.title || '';
                        var pageUrl = summData.url || '';
                        var elements = summData.interactiveElements || [];

                        // 提取搜索结果条目（链接列表）
                        var resultLinks = [];
                        for (var ri = 0; ri < elements.length; ri++) {
                            var el = elements[ri];
                            if ((el.tag || '').toLowerCase() === 'a' && el.href && el.text && el.text.length > 5) {
                                // 过滤掉导航和功能链接
                                var href = el.href || '';
                                if (href.includes('google.com/search') || href.includes('accounts.google') || href.includes('support.google')) continue;
                                if (href.startsWith('javascript:')) continue;
                                resultLinks.push({ title: el.text.substring(0, 80), url: href });
                            }
                        }

                        c.section('<?= __('页面分析结果') ?>');
                        c.log('<?= __('页面标题') ?>: ' + pageTitle);
                        c.log('<?= __('页面 URL') ?>: ' + pageUrl);

                        // 截取核心内容（去掉导航/页脚噪音）
                        var coreText = pageText.replace(/\s+/g, ' ').trim();
                        if (coreText.length > 3000) coreText = coreText.substring(0, 3000);

                        // 尝试通过模型总结
                        var summarized = false;
                        var summaryPrompt = '<?= __('请根据以下网页内容，回答用户的问题。') ?>\n\n'
                            + '<?= __('用户问题') ?>: ' + query + '\n\n'
                            + '<?= __('网页标题') ?>: ' + pageTitle + '\n'
                            + '<?= __('网页内容') ?>:\n' + coreText + '\n\n'
                            + '<?= __('请提取相关信息，用简洁的中文分点列出要点。如果页面内容中没有相关信息，请说明。') ?>';

                        try {
                            var summaryRaw = null;
                            var isExtModel = (typeof ModelLifecycle !== 'undefined' && ModelLifecycle.getState && ModelLifecycle.getState().modelType === 'extension');
                            if (isExtModel) {
                                summaryRaw = await streamGenerate(c, summaryPrompt, { maxTokens: 1024, temperature: 0.5, label: '<?= __('AI 分析页面内容') ?>' });
                            } else if (typeof HFModelManager !== 'undefined' && HFModelManager.isLoaded && HFModelManager.isLoaded()) {
                                summaryRaw = await HFModelManager.generate(summaryPrompt, { maxTokens: 1024, temperature: 0.5 });
                            }
                            if (summaryRaw && summaryRaw.length > 10) {
                                summarized = true;
                            }
                        } catch (summErr) {
                            c.log('<?= __('AI 模型未就绪，使用规则提取') ?>');
                        }

                        // 规则兜底：直接展示链接列表 + 内容摘要
                        if (!summarized) {
                            if (resultLinks.length > 0) {
                                c.section('<?= __('页面搜索结果') ?> (' + resultLinks.length + ' <?= __('条') ?>)');
                                var showMax = Math.min(15, resultLinks.length);
                                for (var li = 0; li < showMax; li++) {
                                    c.log((li + 1) + '. ' + resultLinks[li].title);
                                    c.log('   ' + resultLinks[li].url);
                                }
                            }
                            if (coreText.length > 50) {
                                c.section('<?= __('内容摘要') ?>');
                                // 按句子拆分，取前 20 个句子
                                var sentences = coreText.split(/[。！？\.\!\?]+/).filter(function(s){ return s.trim().length > 10; });
                                var showSentences = sentences.slice(0, 20);
                                for (var si = 0; si < showSentences.length; si++) {
                                    c.log('• ' + showSentences[si].trim());
                                }
                            }
                        }

                        return {
                            success: true,
                            method: summarized ? 'AI' : '<?= __('规则提取') ?>',
                            result: { _snapshot: summData, summary: summarized, linksCount: resultLinks.length },
                            action: 'summarize_page'
                        };
                    } catch (summPageErr) {
                        c.warn('<?= __('页面分析失败') ?>: ' + summPageErr.message);
                        return { success: false, error: summPageErr.message, action: 'summarize_page' };
                    }
                }

                // ── 画像分析 ──
                if (plan.action === 'analyze_profile') {
                    c.info('<?= __('正在分析商家画像...') ?>');
                    if (typeof AgentTools === 'undefined') {
                        c.warn('AgentTools <?= __('未加载') ?>');
                        return { success: false, action: 'analyze_profile' };
                    }
                    try {
                        var profileData = (plan.params && plan.params.profile) || {};
                        var aiOpts = { useAI: false };
                        // 如果模型可用，启用 AI 增强（带流式输出）
                        var isExtModel = (typeof ModelLifecycle !== 'undefined' && ModelLifecycle.getState && ModelLifecycle.getState().modelType === 'extension');
                        if (isExtModel) {
                            aiOpts = { useAI: true, generateFn: function(p, o) { return streamGenerate(c, p, Object.assign({ label: '<?= __('AI 画像分析') ?>' }, o || {})); } };
                        }
                        var analysis = await AgentTools.analyzeProfile(profileData, aiOpts);
                        c.section('<?= __('画像分析结果') ?>');
                        c.log('<?= __('行业') ?>: ' + analysis.industry);
                        c.log('<?= __('地区') ?>: ' + analysis.region);
                        c.log('<?= __('搜索词') ?> (' + analysis.searchQueries.length + '): ' + analysis.searchQueries.slice(0, 8).join(' | '));
                        if (analysis.siteSearchQueries.length > 0) {
                            c.log('<?= __('站内搜索词') ?> (' + analysis.siteSearchQueries.length + '): ' + analysis.siteSearchQueries.slice(0, 5).join(' | '));
                        }
                        c.log('<?= __('平台建议') ?>:');
                        for (var pi = 0; pi < Math.min(4, analysis.platformHints.length); pi++) {
                            c.log('  • ' + analysis.platformHints[pi].platform + ': ' + analysis.platformHints[pi].strategy);
                        }
                        c.success(analysis.description);
                        return { success: true, method: aiOpts.useAI ? 'AI+<?= __('规则') ?>' : '<?= __('规则') ?>', result: analysis, action: 'analyze_profile' };
                    } catch (apErr) {
                        c.warn('<?= __('画像分析失败') ?>: ' + apErr.message);
                        return { success: false, error: apErr.message, action: 'analyze_profile' };
                    }
                }

                // ── 提取页面结构化内容 ──
                if (plan.action === 'extract_page_content') {
                    c.info('<?= __('正在提取页面结构化内容...') ?>');
                    if (typeof AgentTools === 'undefined') {
                        c.warn('AgentTools <?= __('未加载') ?>');
                        return { success: false, action: 'extract_page_content' };
                    }
                    try {
                        var snap = plan.params && plan.params.snapshot;
                        if (!snap && mcpAvailable) {
                            var snapRes = await MCPClient.callTool('browser_snapshot', {});
                            snap = snapRes ? ((snapRes.result !== undefined) ? snapRes.result : snapRes) : null;
                        }
                        var extracted = AgentTools.extractStructuredContent(snap);
                        c.section('<?= __('提取结果') ?>');
                        c.log(extracted.summary);
                        if (extracted.contacts.emails.length > 0) c.success('<?= __('邮箱') ?>: ' + extracted.contacts.emails.join(', '));
                        if (extracted.contacts.phones.length > 0) c.success('<?= __('电话') ?>: ' + extracted.contacts.phones.join(', '));
                        if (extracted.contacts.wechats.length > 0) c.success('<?= __('微信') ?>: ' + extracted.contacts.wechats.join(', '));
                        if (extracted.contacts.qqs.length > 0) c.success('QQ: ' + extracted.contacts.qqs.join(', '));
                        if (extracted.articles.length > 0) {
                            c.log('<?= __('文章/结果') ?> (' + extracted.articles.length + '):');
                            for (var ai = 0; ai < Math.min(10, extracted.articles.length); ai++) {
                                c.log('  ' + (ai + 1) + '. ' + extracted.articles[ai].title);
                            }
                        }
                        return { success: true, method: '<?= __('规则提取') ?>', result: Object.assign({ _snapshot: snap }, extracted), action: 'extract_page_content' };
                    } catch (epErr) {
                        c.warn('<?= __('内容提取失败') ?>: ' + epErr.message);
                        return { success: false, error: epErr.message, action: 'extract_page_content' };
                    }
                }

                // ── 客户匹配评估 ──
                if (plan.action === 'evaluate_customer') {
                    c.info('<?= __('正在评估客户匹配度...') ?>');
                    if (typeof AgentTools === 'undefined') {
                        c.warn('AgentTools <?= __('未加载') ?>');
                        return { success: false, action: 'evaluate_customer' };
                    }
                    try {
                        var snap = plan.params && plan.params.snapshot;
                        if (!snap && mcpAvailable) {
                            var snapRes = await MCPClient.callTool('browser_snapshot', {});
                            snap = snapRes ? ((snapRes.result !== undefined) ? snapRes.result : snapRes) : null;
                        }
                        var profileData = (plan.params && plan.params.profile) || {};
                        var aiOpts = { useAI: false };
                        var isExtModel = (typeof ModelLifecycle !== 'undefined' && ModelLifecycle.getState && ModelLifecycle.getState().modelType === 'extension');
                        if (isExtModel) {
                            aiOpts = { useAI: true, generateFn: function(p, o) { return streamGenerate(c, p, Object.assign({ label: '<?= __('AI 客户评估') ?>' }, o || {})); } };
                        }
                        var evaluation = await AgentTools.evaluateCustomerMatch(snap, profileData, aiOpts);
                        c.section('<?= __('客户匹配评估') ?>');
                        var scoreColor = evaluation.score >= 70 ? '#a6e3a1' : evaluation.score >= 40 ? '#f9e2af' : '#f38ba8';
                        c.log('<?= __('匹配度') ?>: ' + evaluation.score + '/100 (' + (evaluation.isMatch ? '<?= __('匹配') ?>' : '<?= __('不匹配') ?>') + ')');
                        for (var ri = 0; ri < evaluation.reasons.length; ri++) {
                            c.log('  • ' + evaluation.reasons[ri]);
                        }
                        if (evaluation.matchedKeywords.length > 0) {
                            c.log('<?= __('命中关键词') ?>: ' + evaluation.matchedKeywords.join(', '));
                        }
                        var info = evaluation.extractedInfo;
                        if (info && info.contacts) {
                            var ctTotal = (info.contacts.emails || []).length + (info.contacts.phones || []).length + (info.contacts.wechats || []).length;
                            if (ctTotal > 0) c.success('<?= __('发现') ?> ' + ctTotal + ' <?= __('个联系方式') ?>');
                        }
                        return { success: true, method: aiOpts.useAI ? 'AI+<?= __('规则') ?>' : '<?= __('规则') ?>', result: evaluation, action: 'evaluate_customer' };
                    } catch (ecErr) {
                        c.warn('<?= __('客户评估失败') ?>: ' + ecErr.message);
                        return { success: false, error: ecErr.message, action: 'evaluate_customer' };
                    }
                }

                // ── 从搜索结果提取线索列表 ──
                if (plan.action === 'extract_leads') {
                    c.info('<?= __('正在从搜索结果中提取潜在线索...') ?>');
                    if (typeof AgentTools === 'undefined') {
                        c.warn('AgentTools <?= __('未加载') ?>');
                        return { success: false, action: 'extract_leads' };
                    }
                    try {
                        var snap = plan.params && plan.params.snapshot;
                        if (!snap && mcpAvailable) {
                            var snapRes = await MCPClient.callTool('browser_snapshot', {});
                            snap = snapRes ? ((snapRes.result !== undefined) ? snapRes.result : snapRes) : null;
                        }
                        var profileData = (plan.params && plan.params.profile) || {};
                        var leads = AgentTools.extractLeadsFromSearch(snap, profileData);
                        c.section('<?= __('潜在线索') ?> (' + leads.length + ')');
                        for (var li = 0; li < Math.min(15, leads.length); li++) {
                            var lead = leads[li];
                            var icon = lead.isProfileUrl ? '👤' : '📄';
                            c.log(icon + ' [' + lead.score + '<?= __('分') ?>] ' + lead.title);
                            c.log('   ' + lead.url);
                            c.log('   <?= __('原因') ?>: ' + lead.reasons.join(', '));
                        }
                        if (leads.length === 0) c.log('<?= __('未发现明显的潜在线索') ?>');
                        return { success: true, method: '<?= __('规则') ?>', result: { leads: leads, _snapshot: snap }, action: 'extract_leads' };
                    } catch (elErr) {
                        c.warn('<?= __('线索提取失败') ?>: ' + elErr.message);
                        return { success: false, error: elErr.message, action: 'extract_leads' };
                    }
                }

                // ── 深度提取用户资料（通过 MCP 注入脚本到目标页面） ──
                if (plan.action === 'extract_user_profile') {
                    c.info('<?= __('正在深度提取用户资料...') ?>');
                    if (!mcpAvailable || typeof MCPClient === 'undefined') {
                        c.warn('<?= __('需要 MCP 扩展支持') ?>');
                        return { success: false, action: 'extract_user_profile' };
                    }
                    try {
                        var profileResult = await MCPClient.callTool('extract_user_profile', {});
                        var data = profileResult ? ((profileResult.result !== undefined) ? profileResult.result : profileResult) : null;
                        if (data) {
                            c.section('<?= __('用户资料') ?>');
                            if (data.name) c.log('<?= __('用户名') ?>: ' + data.name);
                            if (data.bio) c.log('<?= __('简介') ?>: ' + data.bio);
                            if (data.stats && Object.keys(data.stats).length > 0) {
                                c.log('<?= __('统计') ?>: ' + Object.entries(data.stats).map(function(e){ return e[0] + ': ' + e[1]; }).join(' | '));
                            }
                            var ct = data.contacts || {};
                            if (ct.emails && ct.emails.length > 0) c.success('<?= __('邮箱') ?>: ' + ct.emails.join(', '));
                            if (ct.phones && ct.phones.length > 0) c.success('<?= __('电话') ?>: ' + ct.phones.join(', '));
                            if (ct.wechats && ct.wechats.length > 0) c.success('<?= __('微信') ?>: ' + ct.wechats.join(', '));
                            if (ct.qqs && ct.qqs.length > 0) c.success('QQ: ' + ct.qqs.join(', '));
                            if (ct.links && ct.links.length > 0) c.log('<?= __('社交链接') ?>: ' + ct.links.join(', '));
                            if (data.recentPosts && data.recentPosts.length > 0) {
                                c.log('<?= __('近期内容') ?> (' + data.recentPosts.length + '):');
                                for (var pi = 0; pi < data.recentPosts.length; pi++) {
                                    c.log('  ' + (pi + 1) + '. ' + (data.recentPosts[pi].title || data.recentPosts[pi].preview.substring(0, 60)));
                                }
                            }
                            // 如果有画像，进行评分
                            if (typeof AgentTools !== 'undefined' && plan.params && plan.params.profile) {
                                var scoring = AgentTools.scoreLead(data, plan.params.profile);
                                c.section('<?= __('线索评分') ?>');
                                c.log('<?= __('得分') ?>: ' + scoring.score + '/100 (<?= __('等级') ?>: ' + scoring.level + ')');
                                for (var si = 0; si < scoring.reasons.length; si++) {
                                    c.log('  • ' + scoring.reasons[si]);
                                }
                            }
                        }
                        return { success: true, method: 'MCP', result: data, action: 'extract_user_profile' };
                    } catch (eupErr) {
                        c.warn('<?= __('用户资料提取失败') ?>: ' + eupErr.message);
                        return { success: false, error: eupErr.message, action: 'extract_user_profile' };
                    }
                }

                var toolResult = null;
                var executionMethod = '';

                // MCP 工具调用
                if (mcpAvailable && typeof MCPClient !== 'undefined') {
                    c.info(prefix + '<?= __('通过 MCP 扩展执行') ?>...');
                    executionMethod = 'MCP';
                    try {
                        c.log('<?= __('调用工具') ?>: ' + plan.action + ' ' + JSON.stringify(plan.params || {}));
                        toolResult = await MCPClient.callTool(plan.action, plan.params || {});
                        c.success('MCP <?= __('调用成功') ?>');
                        var navSuccess = toolResult && (toolResult.success === true || (toolResult.result && toolResult.result.success));
                        if (isNavigationTool(plan.action) && navSuccess) {
                            c.info('<?= __('页面加载中，等待快照...') ?>');
                            await new Promise(function (r) { setTimeout(r, 2500); });
                            try {
                                var snapshot = await MCPClient.callTool('browser_snapshot', {});
                                if (snapshot) {
                                    var snapData = (snapshot.result !== undefined) ? snapshot.result : snapshot;
                                    renderPageSnapshot(c, snapData);
                                    if (!toolResult.result) toolResult.result = {};
                                    toolResult.result._snapshot = snapData;
                                }
                            } catch (snapErr) {
                                c.warn('<?= __('快照失败') ?>: ' + snapErr.message);
                            }
                        } else {
                            c.json('toolResult', toolResult);
                        }
                    } catch (mcpErr) {
                        c.warn('MCP <?= __('调用失败') ?>: ' + mcpErr.message);
                        toolResult = null;
                    }
                }

                // 浏览器原生回退
                if (!toolResult) {
                    if (plan.action === 'browser_navigate' || plan.action === 'go_to_url') {
                        var targetUrl = (plan.params && plan.params.url) || '';
                        if (targetUrl) {
                            executionMethod = '<?= __('浏览器原生') ?>';
                            c.info('<?= __('使用 window.open 打开') ?>: ' + targetUrl);
                            var newTab = window.open(targetUrl, '_blank');
                            toolResult = { success: !!newTab, url: targetUrl, method: 'window.open' };
                            if (newTab) { c.success('<?= __('新标签页已打开') ?>'); }
                            else { c.warn('<?= __('弹窗被浏览器拦截，请允许弹窗') ?>'); }
                        }
                    } else if (plan.action === 'search_google') {
                        var q = (plan.params && (plan.params.query || plan.params.text)) || '';
                        var sUrl = (plan.params && plan.params.url) || ('https://www.google.com/search?q=' + encodeURIComponent(q));
                        if (q || sUrl) {
                            executionMethod = '<?= __('浏览器原生') ?>';
                            c.info('<?= __('搜索') ?>: ' + q);
                            var newTab = window.open(sUrl, '_blank');
                            toolResult = { success: !!newTab, url: sUrl, method: 'window.open' };
                        }
                    }
                }

                // 统一提取 snapshot 到顶层，确保续行循环能拿到
                var resultSnapshot = null;
                if (toolResult) {
                    resultSnapshot = (toolResult._snapshot) || (toolResult.result && toolResult.result._snapshot) || null;
                }
                return { success: !!toolResult, method: executionMethod, result: toolResult, action: plan.action, _snapshot: resultSnapshot };
            }

            // ── 执行计划（支持多步骤）──
            var overallResult = null;

            if (actionPlan.action === 'multi_step_task' && actionPlan.steps) {
                c.section('<?= __('多步骤任务') ?> (' + actionPlan.steps.length + ' <?= __('步') ?>)');
                for (var si = 0; si < actionPlan.steps.length; si++) {
                    var stepResult = await executeSingleAction(actionPlan.steps[si], si);
                    if (!stepResult.success && actionPlan.steps[si].action !== 'natural_language_task') {
                        c.warn('<?= __('步骤') ?> ' + (si + 1) + ' <?= __('执行失败，继续下一步') ?>');
                    }
                    overallResult = stepResult;
                }
            } else {
                overallResult = await executeSingleAction(actionPlan);
            }

            // ══════════════════════════════════════════════
            // ReAct 续行循环：观察 → 思考 → 行动，直到任务完成
            // ══════════════════════════════════════════════
            var MAX_CONTINUE_ROUNDS = 12;
            // 从首次执行结果中提取 snapshot
            var lastSnapshot = (overallResult && overallResult._snapshot)
                || (overallResult && overallResult.result && overallResult.result._snapshot) || null;
            var completedActions = [actionPlan.action || (actionPlan.steps && actionPlan.steps.map(function(s){ return s.action; }).join(','))];

            for (var round = 0; round < MAX_CONTINUE_ROUNDS; round++) {
                // 如果上一步没有快照，主动获取一次
                if (!lastSnapshot && mcpAvailable && typeof MCPClient !== 'undefined') {
                    try {
                        var freshSnap = await MCPClient.callTool('browser_snapshot', {});
                        if (freshSnap) lastSnapshot = (freshSnap.result !== undefined) ? freshSnap.result : freshSnap;
                    } catch (_) {}
                }

                // AI 驱动决策：让模型根据当前状态决定下一步
                var nextAction = await aiPlanNextAction(c, input, lastSnapshot, completedActions, mcpAvailable, modelLoaded);
                if (!nextAction) break;

                c.section('<?= __('续行') ?> [' + (round + 1) + '/' + MAX_CONTINUE_ROUNDS + ']: ' + (nextAction.reason || nextAction.action));

                var contResult = await executeSingleAction(nextAction, round);
                completedActions.push(nextAction.action);

                // 提取 snapshot（统一从顶层 _snapshot 字段取）
                lastSnapshot = (contResult && contResult._snapshot)
                    || (contResult && contResult.result && contResult.result._snapshot) || null;
                overallResult = contResult;

                // done 动作表示任务完成
                if (nextAction.action === 'done') break;

                await new Promise(function (r) { setTimeout(r, 500); });
            }

            // ── 完成 ──
            c.section('<?= __('任务完成') ?>');
            var stepsStr = completedActions.join(' → ');
            c.info('<?= __('执行链') ?>: ' + stepsStr + ' (' + completedActions.length + ' <?= __('步') ?>)');
            if (overallResult && overallResult.success) {
                if (completedActions.indexOf('summarize_page') >= 0) {
                    c.success('<?= __('信息收集和分析已完成') ?>');
                } else if (completedActions.indexOf('input_and_submit') >= 0 || completedActions.indexOf('search_google') >= 0) {
                    c.success('<?= __('搜索操作已完成') ?>');
                } else if (completedActions.length === 1 && (completedActions[0] === 'go_to_url' || completedActions[0] === 'browser_navigate')) {
                    var navSnap = lastSnapshot || (overallResult._snapshot) || null;
                    c.success('<?= __('已导航到') ?>: ' + (navSnap ? navSnap.title || navSnap.url : ''));
                } else {
                    c.success('<?= __('任务已完成') ?>');
                }
            } else {
                c.warn('<?= __('操作可能未完全成功，请检查浏览器扩展状态') ?>');
            }
            if (!mcpAvailable) c.warn('<?= __('提示：安装 AutoLeadAgent 扩展可获得更强的自动化能力') ?>');

            c.setStatus('<?= __('就绪') ?>', 'success');
        } catch (err) {
            c.error(err.message);
            c.setStatus('<?= __('失败') ?>', 'danger');
        } finally {
            c.setRunning(false);
        }
    }

    // ===== 测试按钮 → 打开控制台弹窗 =====
    var activeConsole = null;

    if (testBtn) {
        testBtn.addEventListener('click', async function() {
            var input = testInput ? testInput.value.trim() : '';
            if (!input) {
                if (typeof ConfigUtils !== 'undefined') ConfigUtils.safeToast('warning', '<?= __('请输入测试指令') ?>');
                return;
            }

            testBtn.disabled = true;
            var c = createTestConsoleModal(input);
            activeConsole = c;

            // 绑定持续输入回调
            c.onSubmit = async function(cmd) {
                c.addSeparator();
                await executeCommandInConsole(c, cmd);
            };

