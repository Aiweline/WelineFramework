<script>
// 初始化模型生命周期管理
document.addEventListener('DOMContentLoaded', function() {
    if (typeof ModelLifecycle !== 'undefined') {
        ModelLifecycle.init({
            onStatusChange: function(state) {
                console.log('[Config] 模型状态变化:', state);
            },
            onLoadComplete: function(info) {
                console.log('[Config] 模型加载完成:', info);
                // 隐藏加载进度
                var progressContainer = document.getElementById('hf-model-loading-progress');
                if (progressContainer) {
                    progressContainer.style.display = 'none';
                }
            },
            onUnload: function() {
                console.log('[Config] 模型已卸载');
            }
        });
    }
    
    // 监听模型加载进度事件
    window.addEventListener('hf-model-loading-progress', function(event) {
        var detail = event.detail || {};
        var progressContainer = document.getElementById('hf-model-loading-progress');
        var progressBar = document.getElementById('hf-loading-progress-bar');
        var percentText = document.getElementById('hf-loading-percent');
        var statusText = document.getElementById('hf-loading-status-text');
        var fileNameText = document.getElementById('hf-loading-file-name');
        
        if (!progressContainer) return;
        
        if (detail.status === 'start') {
            // 开始加载，显示进度条
            progressContainer.style.display = 'block';
            if (progressBar) {
                progressBar.style.width = '0%';
                progressBar.setAttribute('aria-valuenow', '0');
            }
            if (percentText) percentText.textContent = '0%';
            if (statusText) statusText.textContent = '<?= __('正在初始化模型...') ?>';
            if (fileNameText) fileNameText.textContent = '';
        } else if (detail.status === 'ready' || detail.percent >= 100) {
            // 加载完成
            if (progressBar) {
                progressBar.style.width = '100%';
                progressBar.setAttribute('aria-valuenow', '100');
                progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
                progressBar.classList.add('bg-success');
            }
            if (percentText) percentText.textContent = '100%';
            if (statusText) statusText.textContent = '<?= __('加载完成') ?>';
            if (fileNameText) fileNameText.textContent = '';
            
            // 延迟隐藏进度条
            setTimeout(function() {
                progressContainer.style.display = 'none';
                // 重置进度条样式
                if (progressBar) {
                    progressBar.classList.add('progress-bar-striped', 'progress-bar-animated');
                    progressBar.classList.remove('bg-success');
                }
            }, 1500);
        } else if (detail.status === 'progress' || detail.status === 'download' || detail.status === 'initiate') {
            // 加载中
            progressContainer.style.display = 'block';
            var percent = detail.percent || 0;
            if (progressBar) {
                progressBar.style.width = percent + '%';
                progressBar.setAttribute('aria-valuenow', percent);
            }
            if (percentText) percentText.textContent = percent + '%';
            
            // 更新状态文本
            if (statusText) {
                if (detail.status === 'download' || detail.status === 'initiate') {
                    statusText.textContent = '<?= __('下载模型文件...') ?>';
                } else {
                    statusText.textContent = '<?= __('加载模型中...') ?>';
                }
            }
            
            // 显示当前文件名
            if (fileNameText && detail.file) {
                var fileName = detail.file;
                // 缩短文件名显示
                if (fileName.length > 50) {
                    fileName = '...' + fileName.slice(-47);
                }
                fileNameText.textContent = fileName;
            }
        }
    });
    
    // ========== 智能体测试控制台（弹窗 + 流式日志） ==========
    var testBtn = document.getElementById('hf_agent_test_btn');
    var testInput = document.getElementById('hf_agent_test_input');
    var testClearBtn = document.getElementById('hf_agent_test_clear_btn');

    function updateTestButtonState() {
        if (testBtn) testBtn.disabled = false;
    }

    if (typeof ModelLifecycle !== 'undefined') {
        var observer = new MutationObserver(function() { updateTestButtonState(); });
        var statusIcon = document.getElementById('hf-runtime-status-icon');
        if (statusIcon) observer.observe(statusIcon, { attributes: true, attributeFilter: ['style'] });
    }

    // HTML 转义
    function escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = String(text);
        return div.innerHTML;
    }

    // 时间戳
    function ts() {
        var d = new Date();
        return ('0' + d.getHours()).slice(-2) + ':' + ('0' + d.getMinutes()).slice(-2) + ':' + ('0' + d.getSeconds()).slice(-2) + '.' + ('00' + d.getMilliseconds()).slice(-3);
    }

    /**
     * 创建并显示测试控制台弹窗
     */
    function createTestConsoleModal(inputText) {
        // 移除旧弹窗
        var old = document.getElementById('agentTestConsoleModal');
        if (old) old.remove();

        var html =
            '<div class="modal fade" id="agentTestConsoleModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">' +
            '<div class="modal-dialog modal-lg modal-dialog-scrollable">' +
            '<div class="modal-content" style="height:80vh;">' +
            '<div class="modal-header py-2" style="background:#1e1e2e;color:#cdd6f4;border-bottom:1px solid #45475a;">' +
                '<div class="d-flex align-items-center gap-2">' +
                    '<i class="mdi mdi-console text-success"></i>' +
                    '<strong style="font-family:monospace;font-size:14px;"><?= __('智能体测试控制台') ?></strong>' +
                    '<span class="badge bg-secondary ms-2" id="atc-status"><?= __('初始化') ?></span>' +
                    '<span class="badge bg-dark ms-1" id="atc-timer" style="font-family:monospace;">0.00s</span>' +
                '</div>' +
                '<button type="button" class="btn btn-sm btn-outline-light" id="atc-close-btn">' +
                    '<i class="mdi mdi-close"></i> <?= __('关闭') ?>' +
                '</button>' +
            '</div>' +
            '<div class="modal-body p-0" style="background:#1e1e2e;overflow:hidden;display:flex;flex-direction:column;">' +
                '<!-- 日志区 -->' +
                '<div id="atc-log" style="flex:1;overflow-y:auto;padding:8px 12px;font-family:\'Consolas\',\'Monaco\',\'Courier New\',monospace;font-size:12.5px;line-height:1.7;color:#cdd6f4;"></div>' +
                '<!-- 底部输入栏 -->' +
                '<div style="padding:8px 12px;background:#313244;border-top:1px solid #45475a;display:flex;align-items:center;gap:8px;flex-shrink:0;">' +
                    '<span style="color:#89b4fa;font-family:monospace;font-size:14px;flex-shrink:0;">$</span>' +
                    '<input type="text" id="atc-cmd-input" placeholder="<?= __('输入指令后按 Enter 或点击发送...') ?>" ' +
                        'style="flex:1;background:#1e1e2e;border:1px solid #45475a;border-radius:6px;padding:7px 12px;color:#cdd6f4;font-family:monospace;font-size:13px;outline:none;transition:border-color 0.2s;" ' +
                        'onfocus="this.style.borderColor=\'#89b4fa\'" onblur="this.style.borderColor=\'#45475a\'">' +
                    '<button type="button" id="atc-send-btn" style="flex-shrink:0;background:#89b4fa;border:none;border-radius:6px;padding:7px 14px;color:#1e1e2e;font-weight:600;font-size:13px;cursor:pointer;transition:background 0.15s;" ' +
                        'onmouseenter="this.style.background=\'#74c7ec\'" onmouseleave="this.style.background=\'#89b4fa\'">' +
                        '<i class="mdi mdi-send"></i> <?= __('发送') ?>' +
                    '</button>' +
                '</div>' +
            '</div>' +
            '</div></div></div>' +
            '<style>' +
            '#atc-log::-webkit-scrollbar { width: 8px; }' +
            '#atc-log::-webkit-scrollbar-track { background: #181825; border-radius: 4px; }' +
            '#atc-log::-webkit-scrollbar-thumb { background: #45475a; border-radius: 4px; border: 2px solid #181825; }' +
            '#atc-log::-webkit-scrollbar-thumb:hover { background: #585b70; }' +
            '#atc-log { scrollbar-width: thin; scrollbar-color: #45475a #181825; }' +
            '</style>';

        document.body.insertAdjacentHTML('beforeend', html);

        var modalEl = document.getElementById('agentTestConsoleModal');
        var logEl = document.getElementById('atc-log');
        var statusEl = document.getElementById('atc-status');
        var timerEl = document.getElementById('atc-timer');
        var closeBtn = document.getElementById('atc-close-btn');
        var cmdInput = document.getElementById('atc-cmd-input');
        var sendBtn = document.getElementById('atc-send-btn');

        var modal = new bootstrap.Modal(modalEl);
        modal.show();

        // 打开后自动聚焦输入框
        modalEl.addEventListener('shown.bs.modal', function() {
            if (cmdInput) { cmdInput.value = inputText; cmdInput.focus(); cmdInput.select(); }
        }, { once: true });

        // 计时器
        var timerRunning = false;
        var startMs = 0;
        var timerInterval = null;
        function startTimer() {
            startMs = performance.now();
            timerRunning = true;
            if (timerInterval) clearInterval(timerInterval);
            timerInterval = setInterval(function() {
                if (timerEl && timerRunning) timerEl.textContent = ((performance.now() - startMs) / 1000).toFixed(2) + 's';
            }, 100);
        }
        function stopTimer() {
            timerRunning = false;
            if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
        }

        function scrollBottom() {
            if (!logEl) return;
            // 使用 rAF 确保 DOM 渲染后再滚动（解决快速连续追加时不跟进的问题）
            requestAnimationFrame(function() {
                logEl.scrollTop = logEl.scrollHeight;
            });
        }

        function appendLine(color, prefix, text) {
            if (!logEl) return;
            var line = document.createElement('div');
            line.style.cssText = 'white-space:pre-wrap;word-break:break-all;';
            line.innerHTML = '<span style="color:#6c7086;">[' + ts() + ']</span> ' +
                '<span style="color:' + color + ';">' + prefix + '</span> ' +
                '<span>' + escapeHtml(text) + '</span>';
            logEl.appendChild(line);
            scrollBottom();
        }

        // 分隔线
        function addSeparator() {
            if (!logEl) return;
            var sep = document.createElement('div');
            sep.style.cssText = 'border-top:1px dashed #45475a;margin:10px 0 6px;';
            logEl.appendChild(sep);
            scrollBottom();
        }

        // 显示指令行
        function showCommandLine(cmd) {
            if (!logEl) return;
            var line = document.createElement('div');
            line.style.cssText = 'padding:4px 6px;margin:2px 0 4px;background:#313244;border-radius:4px;font-family:monospace;font-size:13px;';
            line.innerHTML = '<span style="color:#89b4fa;">$</span> <span style="color:#cdd6f4;">' + escapeHtml(cmd) + '</span>';
            logEl.appendChild(line);
            scrollBottom();
        }

        var isRunning = false;

        var api = {
            el: modalEl,
            log:     function(t) { appendLine('#a6adc8', '   ', t); },
            info:    function(t) { appendLine('#89b4fa', '\u2139\ufe0f ', t); },
            warn:    function(t) { appendLine('#f9e2af', '\u26a0\ufe0f ', t); },
            error:   function(t) { appendLine('#f38ba8', '\u274c ', t); },
            success: function(t) { appendLine('#a6e3a1', '\u2705 ', t); },
            section: function(t) {
                if (!logEl) return;
                var line = document.createElement('div');
                line.style.cssText = 'margin:6px 0 2px;padding:2px 6px;background:#313244;border-radius:3px;color:#89dceb;font-weight:bold;';
                line.innerHTML = '<span style="color:#6c7086;">[' + ts() + ']</span> \u25b6 ' + escapeHtml(t);
                logEl.appendChild(line);
                scrollBottom();
            },
            json: function(label, obj) {
                if (!logEl) return;
                var line = document.createElement('div');
                line.style.cssText = 'white-space:pre-wrap;word-break:break-all;';
                var jsonStr = '';
                try { jsonStr = JSON.stringify(obj, null, 2); } catch(e) { jsonStr = String(obj); }
                line.innerHTML = '<span style="color:#6c7086;">[' + ts() + ']</span> ' +
                    '<span style="color:#cba6f7;">\ud83d\udce6 ' + escapeHtml(label) + '</span>\n' +
                    '<span style="color:#94e2d5;margin-left:16px;">' + escapeHtml(jsonStr) + '</span>';
                logEl.appendChild(line);
                scrollBottom();
            },
            setStatus: function(text, color) {
                if (statusEl) {
                    statusEl.textContent = text;
                    statusEl.className = 'badge ms-2 bg-' + (color || 'secondary');
                }
            },
            setRunning: function(running) {
                isRunning = running;
                if (sendBtn) {
                    sendBtn.disabled = running;
                    sendBtn.style.opacity = running ? '0.5' : '1';
                }
                if (cmdInput) cmdInput.disabled = running;
                if (running) startTimer(); else stopTimer();
            },
            close: function() {
                stopTimer();
                modal.hide();
                modalEl.addEventListener('hidden.bs.modal', function() { modalEl.remove(); }, { once: true });
            },
            addSeparator: addSeparator,
            showCommandLine: showCommandLine,
            getInput: function() { return cmdInput; },
            isRunning: function() { return isRunning; },
            /* 创建一个流式输出块 — 逐 token 追加文字，返回 {append, finish, getText, el} */
            createStreamBlock: function(label) {
                if (!logEl) return { append: function(){}, finish: function(){}, el: null };
                var block = document.createElement('div');
                block.style.cssText = 'margin:4px 0;padding:6px 10px;background:#262637;border-left:3px solid #89b4fa;border-radius:0 4px 4px 0;font-family:monospace;font-size:12.5px;line-height:1.7;white-space:pre-wrap;word-break:break-all;color:#cdd6f4;';
                var labelSpan = document.createElement('div');
                labelSpan.style.cssText = 'color:#89b4fa;font-weight:bold;font-size:11px;margin-bottom:2px;';
                labelSpan.innerHTML = '🤖 ' + escapeHtml(label || '<?= __('AI 推理中') ?>') + ' <span class="stream-cursor" style="display:inline-block;width:6px;height:14px;background:#89b4fa;animation:blink 0.8s infinite;vertical-align:middle;margin-left:2px;"></span>';
                block.appendChild(labelSpan);
                var textSpan = document.createElement('span');
                textSpan.style.cssText = 'color:#a6adc8;';
                block.appendChild(textSpan);
                logEl.appendChild(block);
                scrollBottom();
                // 注入闪烁光标动画
                if (!document.getElementById('atc-stream-cursor-style')) {
                    var style = document.createElement('style');
                    style.id = 'atc-stream-cursor-style';
                    style.textContent = '@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}';
                    document.head.appendChild(style);
                }
                return {
                    el: block,
                    append: function(token) {
                        textSpan.textContent += token;
                        scrollBottom();
                    },
                    finish: function() {
                        var cursor = labelSpan.querySelector('.stream-cursor');
                        if (cursor) cursor.remove();
                        block.style.borderLeftColor = '#a6e3a1';
                        labelSpan.style.color = '#a6e3a1';
                    },
                    getText: function() {
                        return textSpan.textContent;
                    }
                };
            }
        };

        closeBtn.addEventListener('click', function() { api.close(); });

        // 底部输入框：Enter 发送 / 点击发送按钮
        function submitFromInput() {
            if (isRunning) return;
            var cmd = cmdInput ? cmdInput.value.trim() : '';
            if (!cmd) return;
            if (cmdInput) { cmdInput.value = ''; }
            // 触发执行回调
            if (api.onSubmit) api.onSubmit(cmd);
        }

        if (cmdInput) {
            cmdInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitFromInput(); }
            });
        }
        if (sendBtn) {
            sendBtn.addEventListener('click', submitFromInput);
        }

        // onSubmit 回调：外部设置
        api.onSubmit = null;

        return api;
    }

    // 智能解析常见指令
    /**
     * 智能解析指令 — 支持复合命令、URL 开头、多步骤任务分解
     * 返回 actionPlan 或 taskPlan（多步骤）
     */
    function smartParseCommand(input) {
        var lo = input.toLowerCase().trim();
        var urlMatch = input.match(/https?:\/\/[^\s]+/i);
        var url = urlMatch ? urlMatch[0] : null;

        // ── 知名站点别名 ──
        var sites = { 'google': 'https://www.google.com', '谷歌': 'https://www.google.com', 'baidu': 'https://www.baidu.com', '百度': 'https://www.baidu.com', 'bing': 'https://www.bing.com', '必应': 'https://www.bing.com', 'linkedin': 'https://www.linkedin.com', 'twitter': 'https://twitter.com', 'x.com': 'https://twitter.com', 'facebook': 'https://www.facebook.com', '知乎': 'https://www.zhihu.com', 'zhihu': 'https://www.zhihu.com', 'github': 'https://github.com', 'youtube': 'https://www.youtube.com' };

        // ── 1. 导航指令（可能是复合的：导航 + 后续任务） ──
        var hasNavKeyword = lo.includes('访问') || lo.includes('打开') || lo.includes('去') || lo.includes('navigate') || lo.includes('open');

        if (hasNavKeyword) {
            var navUrl = url;
            var navSiteName = '';
            if (!navUrl) {
                for (var k in sites) {
                    if (lo.includes(k)) { navUrl = sites[k]; navSiteName = k; break; }
                }
            }
            if (navUrl) {
                // 判断是否有导航之后的实质任务：去掉导航部分，看剩余内容
                var afterNav = input
                    .replace(/https?:\/\/[^\s]+/gi, '')
                    .replace(/(?:你好[，,]?\s*)?(?:帮我|请|请帮我)?\s*(?:访问|打开|去|navigate|open)\s*(?:google|谷歌|百度|baidu|bing|必应|知乎|zhihu|github|youtube|linkedin|twitter|facebook|x\.com)(?:首页|主页|官网|网站|\.com|\.cn)?\s*[，,。]?\s*/gi, '')
                    .replace(/(?:你好[，,]?\s*)?(?:帮我|请|请帮我)?\s*/gi, '')
                    .trim();
                var hasPostTask = afterNav.length > 2 && /找出|找到|查找|搜索|什么|哪些|发生|大事|新闻|提取|联系方式|回答|评论|查询|总结|分析|列出|浏览|看看/.test(afterNav);

                if (hasPostTask) {
                    // 复合指令：导航到站点 + 后续有任务 → 只返回导航，续行循环会处理后续
                    return { action: 'go_to_url', params: { url: navUrl }, reason: '<?= __('访问') ?> ' + (navSiteName || navUrl) + '<?= __('（后续将自动执行任务）') ?>' };
                }
                // 纯导航
                return { action: 'go_to_url', params: { url: navUrl }, reason: '<?= __('访问') ?> ' + (navSiteName || navUrl) };
            }
        }

        // ── 2. URL 开头 + 后续动作（复合指令）──
        if (url) {
            var afterUrl = input.replace(url, '').trim();
            if (!afterUrl) {
                // 纯 URL，直接导航
                return { action: 'go_to_url', params: { url: url }, reason: '<?= __('导航到指定URL') ?>' };
            }
            // 复合指令：先导航，后续描述作为自然语言任务
            return {
                action: 'multi_step_task',
                steps: [
                    { action: 'go_to_url', params: { url: url }, reason: '<?= __('先导航到目标页面') ?>' },
                    { action: 'natural_language_task', params: { task: afterUrl, fullCommand: input }, reason: '<?= __('执行后续操作') ?>' }
                ],
                reason: '<?= __('复合指令：导航 + 自动化任务') ?>',
                requiresMCP: true
            };
        }

        // ── 3. 搜索指令 ──
        if (lo.includes('搜索') || lo.includes('search') || lo.includes('查找') || lo.includes('找')) {
            var sm = input.match(/(?:搜索|search|查找|找)\s*[：:"]?\s*(.+)/i);
            var kw = sm ? sm[1].trim().replace(/["""]/g, '') : '';
            if (kw) {
                var engine = 'https://www.google.com/search?q=';
                if (lo.includes('baidu') || lo.includes('百度')) engine = 'https://www.baidu.com/s?wd=';
                else if (lo.includes('bing') || lo.includes('必应')) engine = 'https://www.bing.com/search?q=';
                return { action: 'search_google', params: { query: kw, url: engine + encodeURIComponent(kw) }, reason: '<?= __('搜索关键词') ?>' };
            }
        }

        // ── 4. 快照/截图 ──
        if (lo.includes('快照') || lo.includes('截图') || lo.includes('页面内容') || lo.includes('snapshot')) {
            return { action: 'browser_snapshot', params: {}, reason: '<?= __('获取当前页面快照') ?>' };
        }

        // ── 5. 提取信息 ──
        if (lo.includes('提取') || lo.includes('联系方式') || lo.includes('邮箱') || lo.includes('电话') || lo.includes('extract')) {
            return { action: 'browser_extract', params: { selectors: { email: true, phone: true } }, reason: '<?= __('提取联系方式') ?>' };
        }

        // ── 6. 点击操作 ──
        if (lo.includes('点击') || lo.includes('click')) {
            var clickMatch = input.match(/(?:点击|click)\s*[：:"]?\s*(.+)/i);
            var target = clickMatch ? clickMatch[1].trim() : '';
            var indexMatch = target.match(/第?\s*(\d+)\s*个?/);
            if (indexMatch) return { action: 'click_element', params: { index: parseInt(indexMatch[1]) }, reason: '<?= __('点击第') ?>' + indexMatch[1] + '<?= __('个元素') ?>' };
            if (target) return { action: 'click_element', params: { text: target }, reason: '<?= __('点击元素') ?>: ' + target };
        }

        // ── 7. 输入操作 ──
        if (lo.includes('输入') || lo.includes('填写') || lo.includes('type') || lo.includes('input')) {
            var typeMatch = input.match(/(?:输入|填写|type|input)\s*[：:"]?\s*(.+)/i);
            var text = typeMatch ? typeMatch[1].trim().replace(/["""]/g, '') : '';
            if (text) return { action: 'input_text', params: { text: text }, reason: '<?= __('输入文本') ?>' };
        }

        // ── 8. 滚动操作 ──
        if (lo.includes('滚动') || lo.includes('scroll') || lo.includes('翻页')) {
            if (lo.includes('顶部') || lo.includes('top')) return { action: 'scroll_to_percent', params: { percent: 0 }, reason: '<?= __('滚动到顶部') ?>' };
            if (lo.includes('底部') || lo.includes('bottom')) return { action: 'scroll_to_percent', params: { percent: 100 }, reason: '<?= __('滚动到底部') ?>' };
            var scrollMatch = lo.match(/(\d+)\s*%/);
            if (scrollMatch) return { action: 'scroll_to_percent', params: { percent: parseInt(scrollMatch[1]) }, reason: '<?= __('滚动到') ?>' + scrollMatch[1] + '%' };
            return { action: 'scroll_to_percent', params: { percent: 50 }, reason: '<?= __('向下滚动') ?>' };
        }

        // ── 9. 返回 ──
        if (lo.includes('返回') || lo.includes('后退') || lo.includes('go back') || lo.includes('back')) {
            return { action: 'go_back', params: {}, reason: '<?= __('返回上一页') ?>' };
        }

        // ── 10. 等待 ──
        if (lo.includes('等待') || lo.includes('wait')) {
            var waitMatch = lo.match(/(\d+)\s*(?:秒|s|sec)/);
            return { action: 'wait', params: { seconds: waitMatch ? parseInt(waitMatch[1]) : 3 }, reason: '<?= __('等待') ?>' };
        }

        // ── 11. 包含任何自然语言动作描述（最后兜底）──
        var actionKeywords = ['回答', '评论', '点赞', '关注', '发送', '提交', '注册', '登录', '下载', '上传', '分享', '收藏', '转发', '删除', '编辑', '修改', '查看', '浏览'];
        for (var i = 0; i < actionKeywords.length; i++) {
            if (lo.includes(actionKeywords[i])) {
                return {
                    action: 'natural_language_task',
                    params: { task: input, fullCommand: input },
                    reason: '<?= __('自然语言任务：') ?>' + actionKeywords[i],
                    requiresMCP: true
                };
            }
        }

        return null;
    }

