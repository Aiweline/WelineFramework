    /**
     * ══════════════════════════════════════════════════════════════
     * aiPlanNextAction —— AI 驱动的 ReAct 续行决策引擎
     * 先尝试用 AI 模型分析，失败时回退到智能规则匹配
     * 返回 actionPlan 对象 或 null（任务完成）
     * ══════════════════════════════════════════════════════════════
     */
    async function aiPlanNextAction(c, originalInput, snapshot, completedActions, mcpAvailable, modelLoaded) {
        if (!mcpAvailable) return null;
        var lastAction = completedActions[completedActions.length - 1];

        // ── 构建当前状态描述 ──
        var pageState = '<?= __('（无页面快照）') ?>';
        var elementsDesc = '';
        if (snapshot) {
            pageState = '<?= __('页面标题') ?>: ' + (snapshot.title || '(<?= __('无') ?>)') + '\n' +
                'URL: ' + (snapshot.url || '') + '\n' +
                '<?= __('页面文本') ?> (<?= __('前') ?> 2000 <?= __('字') ?>): ' + ((snapshot.textContent || '').substring(0, 2000));
            // 列出前 15 个可交互元素
            var els = snapshot.interactiveElements || [];
            if (els.length > 0) {
                var elLines = [];
                for (var ei = 0; ei < Math.min(els.length, 15); ei++) {
                    var e = els[ei];
                    var desc = '[' + (e.index != null ? e.index : ei) + '] ' + (e.tag || '') + ' "' + (e.text || '').substring(0, 40) + '"';
                    if (e.type) desc += ' type=' + e.type;
                    if (e.name) desc += ' name=' + e.name;
                    if (e.placeholder) desc += ' placeholder="' + e.placeholder + '"';
                    if (e.href) desc += ' -> ' + e.href.substring(0, 60);
                    elLines.push(desc);
                }
                elementsDesc = '\n<?= __('可交互元素') ?> (' + els.length + ' <?= __('个') ?>):\n' + elLines.join('\n');
            }
        }

        var historyStr = completedActions.join(' -> ');

        // ── 尝试 AI 决策 ──
        if (modelLoaded) {
            var reactPrompt =
                '你是浏览器自动化 AI Agent 的决策引擎。根据用户原始指令、已完成的步骤、当前页面状态，决定下一步行动。\n\n' +
                '## 可用动作\n' +
                '- go_to_url: 导航到URL。参数: {"url":"..."}\n' +
                '- search_google: Google搜索。参数: {"query":"..."}\n' +
                '- click_element: 点击元素。参数: {"index":数字}\n' +
                '- input_and_submit: 在输入框输入并提交。参数: {"index":数字,"text":"...","pressEnter":true}\n' +
                '- scroll_to_percent: 滚动页面。参数: {"percent":0-100}\n' +
                '- wait_and_snapshot: 等待并获取页面快照。参数: {"waitMs":毫秒}\n' +
                '- summarize_page: 总结当前页面内容。参数: {"query":"关注的问题"}\n' +
                '- extract_page_content: 提取页面联系方式/链接。参数: {}\n' +
                '- done: 任务已完成，不再需要操作。参数: {"summary":"完成总结"}\n\n' +
                '## 决策原则\n' +
                '1. 仔细分析用户原始指令的完整意图，不要只做一半\n' +
                '2. 如果指令包含"看看/查找/找出/告诉我"等意图，必须持续操作直到获取到信息\n' +
                '3. 到达搜索引擎首页 → 应该输入搜索词搜索\n' +
                '4. 到达搜索结果页 → 应该总结结果或点击相关链接\n' +
                '5. 只有当用户想要的信息已经获取到并展示时，才返回 done\n' +
                '6. 不要重复已经完成的步骤\n\n' +
                '## 当前状态\n' +
                '用户原始指令: "' + originalInput + '"\n' +
                '已完成步骤: ' + historyStr + '\n' +
                '当前页面:\n' + pageState + elementsDesc + '\n\n' +
                '## 输出格式（仅 JSON，不要解释）\n' +
                '如果任务未完成: {"action":"动作名","params":{参数},"reason":"原因"}\n' +
                '如果任务已完成: {"action":"done","params":{"summary":"完成总结"},"reason":"任务已完成"}\n';

            try {
                c.info('<?= __('AI 思考下一步...') ?>');
                var isExtModel = (typeof ModelLifecycle !== 'undefined' && ModelLifecycle.getState && ModelLifecycle.getState().modelType === 'extension');
                var raw = null;
                if (isExtModel) {
                    raw = await streamGenerate(c, reactPrompt, { maxTokens: 256, temperature: 0.2, label: '<?= __('AI 续行决策') ?>' });
                } else if (typeof HFModelManager !== 'undefined' && HFModelManager.isLoaded && HFModelManager.isLoaded()) {
                    raw = await HFModelManager.generate(reactPrompt, { maxTokens: 256, temperature: 0.2 });
                }
                if (raw) {
                    var rawStr = typeof raw === 'string' ? raw : (raw.text || raw.generated_text || JSON.stringify(raw));
                    var jsonMatch = rawStr.match(/\{[\s\S]*\}/);
                    if (jsonMatch) {
                        var parsed = JSON.parse(jsonMatch[0]);
                        if (parsed.action === 'done') {
                            if (parsed.params && parsed.params.summary) {
                                c.success('AI: ' + parsed.params.summary);
                            }
                            return null;
