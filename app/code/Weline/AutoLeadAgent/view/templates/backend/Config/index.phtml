            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <?= __('取消') ?>
                </button>
                <button type="button" class="btn btn-danger" id="btn-confirm-reset">
                    <?= __('确认重置') ?>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 表单提交
    var form = document.getElementById('config-form');
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            saveConfig();
        });
    }
    
    // 确认重置按钮
    var confirmResetBtn = document.getElementById('btn-confirm-reset');
    if (confirmResetBtn) {
        confirmResetBtn.addEventListener('click', function() {
            doResetConfig();
        });
    }
});

function saveConfig() {
    var form = document.getElementById('config-form');
    var btn = document.getElementById('btn-save-config');
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在保存...') ?>';
    
    var formData = new FormData(form);
    
    // 处理checkbox
    if (!formData.has('wasm_model_enabled')) {
        formData.set('wasm_model_enabled', '0');
    }
    
    var currentPath = window.location.pathname;
    var saveUrl = currentPath.replace(/\/[^\/]+$/, '/save');
    
    fetch(saveUrl, {
        method: 'POST',
        body: formData
    })
    .then(function(response) {
        return response.json();
    })
    .then(function(result) {
        if (result.success) {
            showToast('success', result.message || '<?= __('配置保存成功') ?>');
        } else {
            showToast('error', result.message || '<?= __('配置保存失败') ?>');
        }
    })
    .catch(function(error) {
        console.error('Save config error:', error);
        showToast('error', '<?= __('配置保存失败') ?>');
    })
    .finally(function() {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    });
}

function resetConfig() {
    var modal = new bootstrap.Modal(document.getElementById('resetConfirmModal'));
    modal.show();
}

function doResetConfig() {
    var btn = document.getElementById('btn-confirm-reset');
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在重置...') ?>';
    
    var currentPath = window.location.pathname;
    var resetUrl = currentPath.replace(/\/[^\/]+$/, '/reset');
    
    fetch(resetUrl, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
        }
    })
    .then(function(response) {
        return response.json();
    })
    .then(function(result) {
        var modal = bootstrap.Modal.getInstance(document.getElementById('resetConfirmModal'));
        if (modal) {
            modal.hide();
        }
        
        if (result.success) {
            showToast('success', result.message || '<?= __('配置已重置为默认值') ?>');
            // 刷新页面以加载默认配置
            setTimeout(function() {
                window.location.reload();
            }, 1000);
        } else {
            showToast('error', result.message || '<?= __('重置配置失败') ?>');
        }
    })
    .catch(function(error) {
        console.error('Reset config error:', error);
        showToast('error', '<?= __('重置配置失败') ?>');
    })
    .finally(function() {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    });
}

function showToast(type, message) {
    // 如果有全局的 toast 函数则使用，否则使用 alert
    if (typeof Toastify !== 'undefined') {
        Toastify({
            text: message,
            duration: 3000,
            gravity: 'top',
            position: 'right',
            backgroundColor: type === 'success' ? '#28a745' : '#dc3545'
        }).showToast();
    } else if (typeof toastr !== 'undefined') {
        toastr[type](message);
    } else {
        alert(message);
    }
}
</script>

