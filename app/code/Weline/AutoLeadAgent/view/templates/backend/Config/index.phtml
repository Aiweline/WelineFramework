<script>
// 初始化模型生命周期管理
document.addEventListener('DOMContentLoaded', function() {
    if (typeof ModelLifecycle !== 'undefined') {
        ModelLifecycle.init({
            onStatusChange: function(state) {
                console.log('[Config] 模型状态变化:', state);
            },
            onLoadComplete: function(info) {
                console.log('[Config] 模型加载完成:', info);
                // 隐藏加载进度
                var progressContainer = document.getElementById('hf-model-loading-progress');
                if (progressContainer) {
                    progressContainer.style.display = 'none';
                }
            },
            onUnload: function() {
                console.log('[Config] 模型已卸载');
            }
        });
    }
    
    // 监听模型加载进度事件
    window.addEventListener('hf-model-loading-progress', function(event) {
        var detail = event.detail || {};
        var progressContainer = document.getElementById('hf-model-loading-progress');
        var progressBar = document.getElementById('hf-loading-progress-bar');
        var percentText = document.getElementById('hf-loading-percent');
        var statusText = document.getElementById('hf-loading-status-text');
        var fileNameText = document.getElementById('hf-loading-file-name');
        
        if (!progressContainer) return;
        
        if (detail.status === 'start') {
            // 开始加载，显示进度条
            progressContainer.style.display = 'block';
            if (progressBar) {
                progressBar.style.width = '0%';
                progressBar.setAttribute('aria-valuenow', '0');
            }
            if (percentText) percentText.textContent = '0%';
            if (statusText) statusText.textContent = '<?= __('正在初始化模型...') ?>';
            if (fileNameText) fileNameText.textContent = '';
        } else if (detail.status === 'ready' || detail.percent >= 100) {
            // 加载完成
            if (progressBar) {
                progressBar.style.width = '100%';
                progressBar.setAttribute('aria-valuenow', '100');
                progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
                progressBar.classList.add('bg-success');
            }
            if (percentText) percentText.textContent = '100%';
            if (statusText) statusText.textContent = '<?= __('加载完成') ?>';
            if (fileNameText) fileNameText.textContent = '';
            
            // 延迟隐藏进度条
            setTimeout(function() {
                progressContainer.style.display = 'none';
                // 重置进度条样式
                if (progressBar) {
                    progressBar.classList.add('progress-bar-striped', 'progress-bar-animated');
                    progressBar.classList.remove('bg-success');
                }
            }, 1500);
        } else if (detail.status === 'progress' || detail.status === 'download' || detail.status === 'initiate') {
            // 加载中
            progressContainer.style.display = 'block';
            var percent = detail.percent || 0;
            if (progressBar) {
                progressBar.style.width = percent + '%';
                progressBar.setAttribute('aria-valuenow', percent);
            }
            if (percentText) percentText.textContent = percent + '%';
            
            // 更新状态文本
            if (statusText) {
                if (detail.status === 'download' || detail.status === 'initiate') {
                    statusText.textContent = '<?= __('下载模型文件...') ?>';
                } else {
                    statusText.textContent = '<?= __('加载模型中...') ?>';
                }
            }
            
            // 显示当前文件名
            if (fileNameText && detail.file) {
                var fileName = detail.file;
                // 缩短文件名显示
                if (fileName.length > 50) {
                    fileName = '...' + fileName.slice(-47);
                }
                fileNameText.textContent = fileName;
            }
        }
    });
    
    // 智能体测试功能
    var testBtn = document.getElementById('hf_agent_test_btn');
    var testInput = document.getElementById('hf_agent_test_input');
    var testClearBtn = document.getElementById('hf_agent_test_clear_btn');
    var testResult = document.getElementById('hf_agent_test_result');
    var testLoading = document.getElementById('hf_agent_test_loading');
    var testOutput = document.getElementById('hf_agent_test_output');
    var testInputDisplay = document.getElementById('hf_agent_test_input_display');
    var testTime = document.getElementById('hf_agent_test_time');
    var testError = document.getElementById('hf_agent_test_error');
    var testSteps = document.getElementById('hf_agent_test_steps');
    var testStepsContent = document.getElementById('hf_agent_test_steps_content');
    
    // 初始化测试按钮状态
    function updateTestButtonState() {
        if (testBtn) {
            // 检查模型是否已加载
            var modelLoaded = false;
            if (typeof ModelLifecycle !== 'undefined') {
                modelLoaded = ModelLifecycle.isLoaded();
            } else if (typeof HFModelManager !== 'undefined') {
                modelLoaded = HFModelManager.isLoaded();
            }
            testBtn.disabled = !modelLoaded;
        }
    }
    
    // 监听模型状态变化
    if (typeof ModelLifecycle !== 'undefined') {
        // 使用 MutationObserver 监听模型状态变化
        var observer = new MutationObserver(function(mutations) {
            updateTestButtonState();
        });
        var statusIcon = document.getElementById('hf-runtime-status-icon');
        if (statusIcon) {
            observer.observe(statusIcon, { attributes: true, attributeFilter: ['style'] });
        }
    }
    
    if (testBtn) {
        testBtn.addEventListener('click', async function() {
            var input = testInput ? testInput.value.trim() : '';
            if (!input) {
                if (typeof ConfigUtils !== 'undefined') {
                    ConfigUtils.safeToast('warning', '<?= __('请输入测试指令') ?>');
                }
                return;
            }
            
            // 检查模型是否已加载
            var modelLoaded = false;
            if (typeof ModelLifecycle !== 'undefined') {
                modelLoaded = ModelLifecycle.isLoaded();
            } else if (typeof HFModelManager !== 'undefined') {
                modelLoaded = HFModelManager.isLoaded();
            }
            
            if (!modelLoaded) {
                if (typeof ConfigUtils !== 'undefined') {
                    ConfigUtils.safeToast('warning', '<?= __('请先加载模型') ?>');
                }
                return;
            }
            
            // 检查 MCP 是否可用
            var mcpAvailable = false;
            var mcpStatus = null;
            if (typeof MCPClient !== 'undefined' && MCPClient.isMCPAvailable) {
                try {
                    mcpAvailable = await MCPClient.isMCPAvailable();
                    if (MCPClient.getMCPStatus) {
                        mcpStatus = MCPClient.getMCPStatus();
                        console.log('[Config] MCP 状态:', mcpStatus);
                    }
                } catch (e) {
                    console.warn('[Config] MCP 检查失败:', e);
                }
            }
            
            if (!mcpAvailable) {
                // 显示扩展安装引导，附带检测状态
                showExtensionInstallGuide(mcpStatus);
                return;
            }
            
            // 显示 MCP 连接成功信息
            if (mcpStatus && mcpStatus.mcpType) {
                console.log('[Config] MCP 已连接，类型:', mcpStatus.mcpType);
            }
            
            // 显示加载状态
            if (testLoading) testLoading.style.display = 'block';
            if (testResult) testResult.style.display = 'none';
            testBtn.disabled = true;
            
            var startTime = performance.now();
            var steps = []; // 记录执行步骤
            
            try {
                // Step 1: 使用模型分析用户指令，确定要执行的操作
                steps.push({ step: 1, action: '分析指令', status: 'running' });
                updateStepsDisplay(steps);
                
                var analysisPrompt = '你是一个浏览器自动化助手。分析用户指令并返回要执行的操作。\n\n' +
                    '可用的操作：\n' +
                    '1. browser_navigate: 导航到URL (参数: url)\n' +
                    '2. browser_click: 点击元素 (参数: selector)\n' +
                    '3. browser_type: 在输入框输入文本 (参数: selector, text)\n' +
                    '4. browser_snapshot: 获取页面快照\n' +
                    '5. browser_extract: 提取页面信息（邮箱、电话等）\n\n' +
                    '用户指令: "' + input + '"\n\n' +
                    '请以JSON格式返回要执行的操作，格式如下：\n' +
                    '{"action": "操作名称", "params": {参数对象}, "reason": "执行原因"}\n\n' +
                    '如果是访问网页，返回例如: {"action": "browser_navigate", "params": {"url": "https://www.google.com"}, "reason": "用户要求访问Google"}\n' +
                    '如果是搜索，返回例如: {"action": "browser_navigate", "params": {"url": "https://www.google.com/search?q=搜索词"}, "reason": "用户要求搜索"}\n\n' +
                    '只返回JSON，不要其他内容。';
                
                var analysisResult = '';
                if (typeof HFModelManager !== 'undefined' && HFModelManager.isLoaded()) {
                    analysisResult = await HFModelManager.generate(analysisPrompt, {
                        maxTokens: 256,
                        temperature: 0.3
                    });
                }
                
                steps[0].status = 'done';
                steps[0].result = analysisResult.substring(0, 100) + '...';
                updateStepsDisplay(steps);
                
                // Step 2: 解析模型返回的操作
                steps.push({ step: 2, action: '解析操作', status: 'running' });
                updateStepsDisplay(steps);
                
                var actionPlan = null;
                try {
                    // 尝试从响应中提取 JSON
                    var jsonMatch = analysisResult.match(/\{[\s\S]*\}/);
                    if (jsonMatch) {
                        actionPlan = JSON.parse(jsonMatch[0]);
                    }
                } catch (parseError) {
                    console.warn('[Config] JSON解析失败，尝试智能匹配:', parseError);
                }
                
                // 如果模型返回的不是有效JSON，尝试智能匹配常见指令
                if (!actionPlan || !actionPlan.action) {
                    actionPlan = smartParseCommand(input);
                }
                
                if (!actionPlan || !actionPlan.action) {
                    throw new Error('无法解析指令，请尝试更明确的命令，如"访问 https://www.google.com" 或 "搜索 AI"');
                }
                
                steps[1].status = 'done';
                steps[1].result = '操作: ' + actionPlan.action + ', 原因: ' + (actionPlan.reason || '用户指令');
                updateStepsDisplay(steps);
                
                // Step 3: 执行浏览器操作
                steps.push({ step: 3, action: '执行操作: ' + actionPlan.action, status: 'running' });
                updateStepsDisplay(steps);
                
                var toolResult = null;
                if (typeof MCPClient !== 'undefined') {
                    // 确保连接到 MCP
                    if (!MCPClient.isConnected()) {
                        await MCPClient.connectMCP();
                    }
                    
                    // 调用工具
                    toolResult = await MCPClient.callTool(actionPlan.action, actionPlan.params || {});
                }
                
                steps[2].status = 'done';
                steps[2].result = toolResult ? JSON.stringify(toolResult).substring(0, 200) : '执行完成';
                updateStepsDisplay(steps);
                
                var endTime = performance.now();
                var duration = ((endTime - startTime) / 1000).toFixed(2);
                
                // 构建响应文本
                var responseText = '✅ 操作执行成功！\n\n';
                responseText += '📋 执行的操作: ' + actionPlan.action + '\n';
                if (actionPlan.params) {
                    responseText += '📝 参数: ' + JSON.stringify(actionPlan.params) + '\n';
                }
                if (actionPlan.reason) {
                    responseText += '💡 原因: ' + actionPlan.reason + '\n';
                }
                if (toolResult) {
                    responseText += '\n📊 执行结果:\n';
                    if (toolResult.url) responseText += '  - URL: ' + toolResult.url + '\n';
                    if (toolResult.title) responseText += '  - 页面标题: ' + toolResult.title + '\n';
                    if (toolResult.tabId) responseText += '  - 标签页ID: ' + toolResult.tabId + '\n';
                    if (toolResult.success !== undefined) responseText += '  - 成功: ' + (toolResult.success ? '是' : '否') + '\n';
                }
                
                // 显示结果
                if (testLoading) testLoading.style.display = 'none';
                if (testResult) testResult.style.display = 'block';
                if (testInputDisplay) testInputDisplay.textContent = input;
                if (testOutput) testOutput.innerHTML = '<pre style="white-space: pre-wrap; margin: 0;">' + escapeHtml(responseText) + '</pre>';
                if (testTime) testTime.textContent = duration + ' <?= __('秒') ?>';
                if (testError) testError.style.display = 'none';
                if (testSteps) testSteps.style.display = 'block';
                
            } catch (error) {
                console.error('[Config] 智能体测试失败:', error);
                
                // 更新失败步骤
                if (steps.length > 0) {
                    var lastStep = steps[steps.length - 1];
                    if (lastStep.status === 'running') {
                        lastStep.status = 'error';
                        lastStep.result = error.message;
                        updateStepsDisplay(steps);
                    }
                }
                
                if (testLoading) testLoading.style.display = 'none';
                if (testResult) testResult.style.display = 'block';
                if (testInputDisplay) testInputDisplay.textContent = input;
                if (testOutput) testOutput.textContent = '';
                if (testError) {
                    testError.style.display = 'block';
                    testError.textContent = '<?= __('测试失败') ?>: ' + error.message;
                }
                if (testSteps) testSteps.style.display = 'block';
            } finally {
                testBtn.disabled = false;
                updateTestButtonState();
            }
        });
    }
    
    // 智能解析常见指令
    function smartParseCommand(input) {
        var lowerInput = input.toLowerCase();
        
        // 访问网站
        if (lowerInput.includes('访问') || lowerInput.includes('打开') || lowerInput.includes('去')) {
            // 提取URL
            var urlMatch = input.match(/https?:\/\/[^\s]+/i);
            if (urlMatch) {
                return { action: 'browser_navigate', params: { url: urlMatch[0] }, reason: '用户要求访问指定URL' };
            }
            
            // 常见网站映射
            if (lowerInput.includes('google') || lowerInput.includes('谷歌')) {
                return { action: 'browser_navigate', params: { url: 'https://www.google.com' }, reason: '用户要求访问Google' };
            }
            if (lowerInput.includes('baidu') || lowerInput.includes('百度')) {
                return { action: 'browser_navigate', params: { url: 'https://www.baidu.com' }, reason: '用户要求访问百度' };
            }
            if (lowerInput.includes('bing') || lowerInput.includes('必应')) {
                return { action: 'browser_navigate', params: { url: 'https://www.bing.com' }, reason: '用户要求访问Bing' };
            }
            if (lowerInput.includes('linkedin')) {
                return { action: 'browser_navigate', params: { url: 'https://www.linkedin.com' }, reason: '用户要求访问LinkedIn' };
            }
            if (lowerInput.includes('twitter') || lowerInput.includes('x.com')) {
                return { action: 'browser_navigate', params: { url: 'https://twitter.com' }, reason: '用户要求访问Twitter' };
            }
            if (lowerInput.includes('facebook')) {
                return { action: 'browser_navigate', params: { url: 'https://www.facebook.com' }, reason: '用户要求访问Facebook' };
            }
        }
        
        // 搜索
        if (lowerInput.includes('搜索') || lowerInput.includes('search') || lowerInput.includes('查找') || lowerInput.includes('找')) {
            // 提取搜索关键词
            var searchMatch = input.match(/(?:搜索|search|查找|找)\s*[：:"]?\s*(.+)/i);
            var keyword = searchMatch ? searchMatch[1].trim().replace(/["""]/g, '') : '';
            
            if (keyword) {
                // 根据上下文选择搜索引擎
                if (lowerInput.includes('google') || lowerInput.includes('谷歌')) {
                    return { action: 'browser_navigate', params: { url: 'https://www.google.com/search?q=' + encodeURIComponent(keyword) }, reason: '使用Google搜索关键词' };
                }
                if (lowerInput.includes('baidu') || lowerInput.includes('百度')) {
                    return { action: 'browser_navigate', params: { url: 'https://www.baidu.com/s?wd=' + encodeURIComponent(keyword) }, reason: '使用百度搜索关键词' };
                }
                if (lowerInput.includes('bing') || lowerInput.includes('必应')) {
                    return { action: 'browser_navigate', params: { url: 'https://www.bing.com/search?q=' + encodeURIComponent(keyword) }, reason: '使用Bing搜索关键词' };
                }
                // 默认使用Google
                return { action: 'browser_navigate', params: { url: 'https://www.google.com/search?q=' + encodeURIComponent(keyword) }, reason: '使用Google搜索关键词' };
            }
        }
        
        // 获取页面信息
        if (lowerInput.includes('快照') || lowerInput.includes('截图') || lowerInput.includes('页面内容')) {
            return { action: 'browser_snapshot', params: {}, reason: '获取当前页面快照' };
        }
        
        // 提取联系方式
        if (lowerInput.includes('提取') || lowerInput.includes('获取') || lowerInput.includes('联系方式') || lowerInput.includes('邮箱') || lowerInput.includes('电话')) {
            return { action: 'browser_extract', params: { selectors: { email: true, phone: true, social: ['linkedin', 'twitter', 'facebook'] } }, reason: '提取页面联系方式' };
        }
        
        return null;
    }
    
    // 更新步骤显示
    function updateStepsDisplay(steps) {
        if (!testStepsContent) return;
        
        var html = '<ol class="mb-0">';
        for (var i = 0; i < steps.length; i++) {
            var s = steps[i];
            var statusClass = s.status === 'done' ? 'text-success' : (s.status === 'error' ? 'text-danger' : 'text-info');
            var statusIcon = s.status === 'done' ? 'mdi-check-circle' : (s.status === 'error' ? 'mdi-alert-circle' : 'mdi-loading mdi-spin');
            html += '<li class="' + statusClass + '">';
            html += '<i class="mdi ' + statusIcon + ' me-1"></i>';
            html += escapeHtml(s.action);
            if (s.result) {
                html += '<div class="small text-muted ms-3">' + escapeHtml(s.result) + '</div>';
            }
            html += '</li>';
        }
        html += '</ol>';
        testStepsContent.innerHTML = html;
        
        if (testSteps) testSteps.style.display = 'block';
    }
    
    // HTML转义
    function escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
