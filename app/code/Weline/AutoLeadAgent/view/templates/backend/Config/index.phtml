    /* 规则引擎：硬编码的续行逻辑作为 fallback */
    function rulePlanNextAction(originalInput, snapshot, completedActions) {
        var lo = originalInput.toLowerCase();
        var lastAction = completedActions[completedActions.length - 1];

        var wantSearch = /搜索|search|查找|找出|找到|查询|lookup/.test(lo);
        var wantInfo = /哪些|什么|有什么|发生|新闻|大事|事件|内容|信息|结果|列出|总结|看看|summarize|summary|tell me|find out|what/.test(lo);
        var wantExtract = /提取|联系方式|邮箱|电话|extract|contact/.test(lo);

        function extractSearchQuery() {
            var cleaned = originalInput
                .replace(/https?:\/\/[^\s]+/gi, '')
                .replace(/(?:你好[，,]?\s*)?(?:帮我|请|请帮我)?\s*(?:访问|打开|去|navigate|open)\s*(?:google|谷歌|百度|baidu|bing|必应|知乎|zhihu|github|youtube|linkedin|twitter|facebook|x\.com)(?:首页|主页|官网|网站|\.com|\.cn)?\s*[，,。]?\s*/gi, '')
                .replace(/(?:你好[，,]?\s*)?(?:帮我|请|请帮我)?\s*/gi, '')
                .trim();
            cleaned = cleaned.replace(/^(?:找出|找到|查找|搜索|查询|告诉我|列出)\s*/gi, '').trim();
            return cleaned || null;
        }

        function findSearchInput(snap) {
            if (!snap) return null;
            var elements = snap.interactiveElements || [];
            for (var i = 0; i < elements.length; i++) {
                var el = elements[i];
                var tag = (el.tag || '').toLowerCase();
                var elType = (el.type || '').toLowerCase();
                var elName = (el.name || '').toLowerCase();
                var elPlaceholder = (el.placeholder || '').toLowerCase();
                if ((tag === 'input' && (elType === 'text' || elType === 'search' || elType === ''))
                    || tag === 'textarea'
                    || elName.includes('search') || elName.includes('q')
                    || elPlaceholder.includes('搜索') || elPlaceholder.includes('search')) {
                    return el;
                }
            }
            return null;
        }

        // 导航刚完成 → 页面有搜索框且用户想查信息 → 搜索
        if (lastAction === 'go_to_url' || lastAction === 'browser_navigate') {
            if (!snapshot) {
                console.warn('[RuleEngine] No snapshot after navigation — cannot plan next step');
                return null;
            }
            var searchInput = findSearchInput(snapshot);
            var q = extractSearchQuery();
            console.log('[RuleEngine] nav done: searchInput=', searchInput ? searchInput.index : 'null', 'wantSearch=', wantSearch, 'wantInfo=', wantInfo, 'query=', q, 'elements=', (snapshot.interactiveElements || []).length);
            if (searchInput && (wantSearch || wantInfo)) {
                if (q) {
                    return {
                        action: 'input_and_submit',
                        params: { index: searchInput.index != null ? searchInput.index : null, text: q, pressEnter: true },
                        reason: '<?= __('在搜索框中输入') ?>: ' + q
                    };
                }
            }
            if (wantInfo && snapshot.textContent && snapshot.textContent.length > 50) {
                return { action: 'summarize_page', params: { query: q || originalInput }, reason: '<?= __('分析页面内容') ?>' };
            }
        }

        // 搜索/输入提交完成 → 等待结果
        if (lastAction === 'input_and_submit' || lastAction === 'search_google') {
            return { action: 'wait_and_snapshot', params: { waitMs: 3000 }, reason: '<?= __('等待搜索结果加载') ?>' };
        }

        // 快照就绪 → 总结或提取
        if (lastAction === 'wait_and_snapshot') {
            if (!snapshot) return null;
            if (wantExtract) {
                return { action: 'extract_page_content', params: {}, reason: '<?= __('提取页面信息') ?>' };
            }
            if (wantInfo && snapshot.textContent && snapshot.textContent.length > 50) {
                return { action: 'summarize_page', params: { query: extractSearchQuery() || originalInput }, reason: '<?= __('总结搜索结果') ?>' };
            }
        }

        // 总结/提取完成 → 任务结束
        if (lastAction === 'summarize_page' || lastAction === 'browser_extract' || lastAction === 'extract_page_content') {
            return null;
        }

        return null;
    }

    /**
     * 通过扩展执行模型推理（支持流式 token 输出）
     * 通过 content script 中继: 页面 → content → background → offscreen → worker
     *
     * @param {string} prompt - 提示词
     * @param {Object} options - { maxTokens, temperature, onToken: function(token, fullText) }
     * @returns {Promise<string>} 最终生成的完整文本
     */
    function generateViaExtension(prompt, options) {
        options = options || {};
        var onToken = typeof options.onToken === 'function' ? options.onToken : null;

        return new Promise(function (resolve, reject) {
            var inferenceId = 'inf_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4);
            var timer = setTimeout(function () {
                window.removeEventListener('message', handler);
                reject(new Error('<?= __('扩展推理超时（120s）') ?>'));
            }, 120000);

            function handler(event) {
                if (event.source !== window || !event.data) return;
                // 流式 token 事件
                if (event.data.type === 'MODEL_INFERENCE_TOKEN' && event.data.inferenceId === inferenceId) {
                    if (onToken) {
                        onToken(event.data.token || '', event.data.fullText || '');
                    }
                    return;
                }
                // 最终结果
                if (event.data.type === 'MODEL_INFERENCE_RESPONSE' && event.data.inferenceId === inferenceId) {
                    window.removeEventListener('message', handler);
                    clearTimeout(timer);
                    if (event.data.error) {
                        reject(new Error(event.data.error));
                    } else if (event.data.response && event.data.response.success) {
                        // 二次检查：result 本身可能包含 error（offscreen 层错误透传）
                        var r = event.data.response.result;
                        if (r && typeof r === 'object' && r.error && !r.text && !r.generated_text) {
                            reject(new Error(r.error));
                        } else {
                            resolve(r);
                        }
                    } else {
                        reject(new Error((event.data.response && event.data.response.error) || '<?= __('推理失败') ?>'));
                    }
                }
            }
            window.addEventListener('message', handler);
            window.postMessage({
                type: 'MODEL_INFERENCE_REQUEST',
                prompt: prompt,
                options: { maxTokens: options.maxTokens || 512, temperature: options.temperature || 0.3 },
                inferenceId: inferenceId
            }, '*');
        });
    }

    /**
     * 流式推理 — 在控制台中实时显示模型思考过程
     * @param {Object} c 控制台实例（带 createStreamBlock）
     * @param {string} prompt 提示词
     * @param {Object} options { maxTokens, temperature, label }
     * @returns {Promise<string>} 完整输出文本
     */
    async function streamGenerate(c, prompt, options) {
        options = options || {};
        var label = options.label || '<?= __('AI 推理中') ?>';
        var stream = c.createStreamBlock(label);
        try {
            var result = await generateViaExtension(prompt, {
                maxTokens: options.maxTokens || 512,
                temperature: options.temperature || 0.3,
                onToken: function(token) {
                    stream.append(token);
                }
            });
            stream.finish();
            // 如果流式没收到任何 token（fallback），直接显示最终结果
            if (!stream.getText() && result) {
                stream.append(typeof result === 'string' ? result : JSON.stringify(result));
                stream.finish();
            }
            return typeof result === 'string' ? result : (result && (result.text || result.generated_text || JSON.stringify(result)));
        } catch (err) {
            stream.finish();
            throw err;
        }
    }

