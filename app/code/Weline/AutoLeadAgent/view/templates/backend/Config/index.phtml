<js>Weline_AutoLeadAgent::js/config-utils.js</js>
<js>Weline_AutoLeadAgent::js/config-extension-client.js</js>
<js>Weline_AutoLeadAgent::js/config-ui-renderer.js</js>
<js>Weline_AutoLeadAgent::js/config-download-manager.js</js>
<js>Weline_AutoLeadAgent::js/hf-model-manager.js</js>
<js>Weline_AutoLeadAgent::js/model-inference.js</js>
<js>Weline_AutoLeadAgent::js/prompts.js</js>
<js>Weline_AutoLeadAgent::js/mcp-client.js</js>
<js>Weline_AutoLeadAgent::js/react-agent.js</js>
<js>Weline_AutoLeadAgent::js/model-lifecycle.js</js>
<js>Weline_AutoLeadAgent::js/config-models.js</js>
<script>
// 初始化模型生命周期管理
document.addEventListener('DOMContentLoaded', function() {
    if (typeof ModelLifecycle !== 'undefined') {
        ModelLifecycle.init({
            onStatusChange: function(state) {
                console.log('[Config] 模型状态变化:', state);
            },
            onLoadComplete: function(info) {
                console.log('[Config] 模型加载完成:', info);
            },
            onUnload: function() {
                console.log('[Config] 模型已卸载');
            }
        });
    }
    
    // 智能体测试功能
    var testBtn = document.getElementById('hf_agent_test_btn');
    var testInput = document.getElementById('hf_agent_test_input');
    var testClearBtn = document.getElementById('hf_agent_test_clear_btn');
    var testResult = document.getElementById('hf_agent_test_result');
    var testLoading = document.getElementById('hf_agent_test_loading');
    var testOutput = document.getElementById('hf_agent_test_output');
    var testInputDisplay = document.getElementById('hf_agent_test_input_display');
    var testTime = document.getElementById('hf_agent_test_time');
    var testError = document.getElementById('hf_agent_test_error');
    var testSteps = document.getElementById('hf_agent_test_steps');
    var testStepsContent = document.getElementById('hf_agent_test_steps_content');
    
    // 初始化测试按钮状态
    function updateTestButtonState() {
        if (testBtn) {
            // 检查模型是否已加载
            var modelLoaded = false;
            if (typeof ModelLifecycle !== 'undefined') {
                modelLoaded = ModelLifecycle.isLoaded();
            } else if (typeof HFModelManager !== 'undefined') {
                modelLoaded = HFModelManager.isLoaded();
            }
            testBtn.disabled = !modelLoaded;
        }
    }
    
    // 监听模型状态变化
    if (typeof ModelLifecycle !== 'undefined') {
        // 使用 MutationObserver 监听模型状态变化
        var observer = new MutationObserver(function(mutations) {
            updateTestButtonState();
        });
        var statusIcon = document.getElementById('hf-runtime-status-icon');
        if (statusIcon) {
            observer.observe(statusIcon, { attributes: true, attributeFilter: ['style'] });
        }
    }
    
    if (testBtn) {
        testBtn.addEventListener('click', async function() {
            var input = testInput ? testInput.value.trim() : '';
            if (!input) {
                if (typeof showToast === 'function') {
                    showToast('warning', '<?= __('请输入测试指令') ?>');
                }
                return;
            }
            
            // 检查模型是否已加载
            var modelLoaded = false;
            if (typeof ModelLifecycle !== 'undefined') {
                modelLoaded = ModelLifecycle.isLoaded();
            } else if (typeof HFModelManager !== 'undefined') {
                modelLoaded = HFModelManager.isLoaded();
            }
            
            if (!modelLoaded) {
                if (typeof showToast === 'function') {
                    showToast('warning', '<?= __('请先加载模型') ?>');
                }
                return;
            }
            
            // 显示加载状态
            if (testLoading) testLoading.style.display = 'block';
            if (testResult) testResult.style.display = 'none';
            testBtn.disabled = true;
            
            var startTime = performance.now();
            
            try {
                var response = '';
                
                // 使用 HFModelManager 进行推理
                if (typeof HFModelManager !== 'undefined' && HFModelManager.isLoaded()) {
                    response = await HFModelManager.generate(input, {
                        maxTokens: 256,
                        temperature: 0.7
                    });
                } else if (typeof ReactAgent !== 'undefined') {
                    // 使用 ReactAgent（如果可用）
                    var result = await ReactAgent.run(input);
                    response = result.response || result.output || JSON.stringify(result);
                } else {
                    throw new Error('<?= __('模型未加载或不可用') ?>');
                }
                
                var endTime = performance.now();
                var duration = ((endTime - startTime) / 1000).toFixed(2);
                
                // 显示结果
                if (testLoading) testLoading.style.display = 'none';
                if (testResult) testResult.style.display = 'block';
                if (testInputDisplay) testInputDisplay.textContent = input;
                if (testOutput) testOutput.textContent = response;
                if (testTime) testTime.textContent = duration + ' <?= __('秒') ?>';
                if (testError) testError.style.display = 'none';
                
            } catch (error) {
                console.error('[Config] 智能体测试失败:', error);
                
                if (testLoading) testLoading.style.display = 'none';
                if (testResult) testResult.style.display = 'block';
                if (testInputDisplay) testInputDisplay.textContent = input;
                if (testOutput) testOutput.textContent = '';
                if (testError) {
                    testError.style.display = 'block';
                    testError.textContent = '<?= __('测试失败') ?>: ' + error.message;
                }
            } finally {
                testBtn.disabled = false;
                updateTestButtonState();
            }
        });
    }
    
    if (testClearBtn) {
        testClearBtn.addEventListener('click', function() {
            if (testResult) testResult.style.display = 'none';
            if (testInput) testInput.value = '';
            if (testOutput) testOutput.textContent = '';
            if (testError) testError.style.display = 'none';
            if (testSteps) testSteps.style.display = 'none';
        });
    }
    
    
    // 清理所有模型
    var clearCacheBtn = document.getElementById('hf_model_clear_cache');
    if (clearCacheBtn) {
        clearCacheBtn.addEventListener('click', async function() {
            if (!confirm('确定要清理所有已下载的模型吗？此操作不可恢复！')) {
                return;
            }
            
            try {
                if (typeof LocalFileStorage !== 'undefined') {
                    const metadata = LocalFileStorage.getModelMetadata();
                    var modelIds = Object.keys(metadata);
                    
                    if (modelIds.length === 0) {
                        ConfigUtils.safeToast('info', '没有已下载的模型需要清理');
                        return;
                    }
                    
                    clearCacheBtn.disabled = true;
                    clearCacheBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> 清理中...';
                    
                    var deletedCount = 0;
                    var deletedSize = 0;
                    
                    for (var i = 0; i < modelIds.length; i++) {
                        var modelId = modelIds[i];
                        try {
                            var result = await LocalFileStorage.deleteModel(modelId);
                            deletedCount++;
                            deletedSize += result.deletedSize;
                        } catch (error) {
                            console.error('[Config] 删除模型失败:', modelId, error);
                        }
                    }
                    
                    clearCacheBtn.disabled = false;
                    clearCacheBtn.innerHTML = '<i class="mdi mdi-delete me-1"></i><?= __('清理所有模型') ?>';
                    
                    ConfigUtils.safeToast('success', '已清理 ' + deletedCount + ' 个模型，释放空间: ' + ConfigUtils.formatFileSize(deletedSize));
                    
                    // 刷新模型列表
                    var searchBtn = document.getElementById('hf_model_search_btn');
                    if (searchBtn) {
                        searchBtn.click();
                    }
                } else {
                    ConfigUtils.safeToast('error', 'LocalFileStorage 不可用');
                }
            } catch (error) {
                console.error('[Config] 清理模型失败:', error);
                clearCacheBtn.disabled = false;
                clearCacheBtn.innerHTML = '<i class="mdi mdi-delete me-1"></i><?= __('清理所有模型') ?>';
                ConfigUtils.safeToast('error', '清理模型失败: ' + error.message);
            }
        });
    }
    
    // 查看缓存信息
    var showCacheInfoBtn = document.getElementById('hf_model_show_cache_info');
    if (showCacheInfoBtn) {
        showCacheInfoBtn.addEventListener('click', function() {
            try {
                if (typeof LocalFileStorage !== 'undefined') {
                    const metadata = LocalFileStorage.getModelMetadata();
                    var modelIds = Object.keys(metadata);
                    
                    if (modelIds.length === 0) {
                        ConfigUtils.safeToast('info', '没有已下载的模型');
                        return;
                    }
                    
                    var totalSize = 0;
                    var totalFiles = 0;
                    var modelInfo = [];
                    
                    modelIds.forEach(function(modelId) {
                        var modelData = metadata[modelId];
                        totalSize += modelData.totalSize || 0;
                        totalFiles += modelData.fileCount || 0;
                        modelInfo.push({
                            id: modelId,
                            files: modelData.fileCount || 0,
                            size: modelData.totalSize || 0
                        });
                    });
                    
                    var info = '缓存信息:\n\n';
                    info += '模型数量: ' + modelIds.length + '\n';
                    info += '文件总数: ' + totalFiles + '\n';
                    info += '总大小: ' + ConfigUtils.formatFileSize(totalSize) + '\n\n';
                    info += '模型列表:\n';
                    
                    modelInfo.forEach(function(m) {
                        info += '• ' + m.id + '\n';
                        info += '  文件数: ' + m.files + ', 大小: ' + ConfigUtils.formatFileSize(m.size) + '\n';
                    });
                    
                    alert(info);
                } else {
                    ConfigUtils.safeToast('error', 'LocalFileStorage 不可用');
                }
            } catch (error) {
                console.error('[Config] 获取缓存信息失败:', error);
                ConfigUtils.safeToast('error', '获取缓存信息失败: ' + error.message);
            }
        });
    }
    
    // 初始化按钮状态
    setTimeout(updateTestButtonState, 1000);
});
</script>

@template(Weline_Admin::common/vendor-scripts.phtml)
</body>
</html>
