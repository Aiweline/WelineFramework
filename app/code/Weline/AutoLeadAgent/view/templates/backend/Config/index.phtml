            '<div class="mb-3 pb-3 border-bottom">' +
            '<div class="d-flex align-items-center mb-2">' +
            '<span class="badge bg-primary rounded-circle me-2" style="width:24px;height:24px;display:flex;align-items:center;justify-content:center;">2</span>' +
            '<strong><?= __('打开 Chrome 扩展管理页面') ?></strong>' +
            '</div>' +
            '<div class="ms-4">' +
            '<button class="btn btn-sm btn-outline-primary" onclick="window.openExtensionsPage()">' +
            '<i class="mdi mdi-open-in-new me-1"></i>chrome://extensions/' +
            '</button>' +
            '<p class="small text-muted mt-2 mb-0"><?= __('在页面右上角开启') ?> <strong>"<?= __('开发者模式') ?>"</strong></p>' +
            '</div>' +
            '</div>' +
            
            '<div class="mb-0">' +
            '<div class="d-flex align-items-center mb-2">' +
            '<span class="badge bg-primary rounded-circle me-2" style="width:24px;height:24px;display:flex;align-items:center;justify-content:center;">3</span>' +
            '<strong><?= __('加载扩展程序') ?></strong>' +
            '</div>' +
            '<div class="ms-4">' +
            '<p class="small text-muted mb-0"><?= __('点击') ?> <strong>"<?= __('加载已解压的扩展程序') ?>"</strong><?= __('，选择解压后的文件夹即可') ?></p>' +
            '</div>' +
            '</div>' +
            
            '</div>' +
            '</div>' +
            
            '<!-- 配置 API 密钥 -->' +
            '<div class="card border-warning mb-3">' +
            '<div class="card-header bg-warning text-dark py-2">' +
            '<i class="mdi mdi-key me-1"></i><?= __('配置 LLM API 密钥（必须）') ?>' +
            '</div>' +
            '<div class="card-body small">' +
            '<p class="mb-2"><?= __('扩展安装后，需要配置 LLM 提供商的 API 密钥才能使用：') ?></p>' +
            '<ol class="mb-0">' +
            '<li><?= __('点击扩展图标，打开侧边栏') ?></li>' +
            '<li><?= __('点击设置图标，进入 Models 标签页') ?></li>' +
            '<li><?= __('添加 LLM 提供商（如 OpenAI、Gemini、Claude 或本地 Ollama）') ?></li>' +
            '</ol>' +
            '</div>' +
            '</div>' +
            
            '<div class="alert alert-success mb-0">' +
            '<i class="mdi mdi-check-circle me-2"></i>' +
            '<strong><?= __('安装完成后') ?></strong>: <?= __('刷新此页面，然后在测试框中输入自然语言指令（如"去百度搜索 AI"），智能体将自动执行。') ?>' +
            '</div>' +
            
            '</div>' + // modal-body
            '<div class="modal-footer">' +
            '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('关闭') ?></button>' +
            '<button type="button" class="btn btn-primary" onclick="window.location.reload()">' +
            '<i class="mdi mdi-refresh me-1"></i><?= __('刷新页面') ?>' +
            '</button>' +
            '</div>' +
