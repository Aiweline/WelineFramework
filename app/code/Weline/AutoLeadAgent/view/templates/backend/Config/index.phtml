    // ===== 监听浮动按钮消息（来自扩展 content script） =====
    window.addEventListener('message', function(event) {
        if (event.source !== window || !event.data) return;

        // 打开测试控制台
        if (event.data.type === 'ALA_OPEN_TEST_CONSOLE') {
            if (activeConsole) return; // 已打开
            var defaultInput = '<?= __('你好，帮我测试浏览器自动化') ?>';
            var c = createTestConsoleModal(defaultInput);
            activeConsole = c;
            c.onSubmit = async function(cmd) {
                c.addSeparator();
                await executeCommandInConsole(c, cmd);
            };
        }

        // 执行命令（从浮动按钮的输入栏发来）
        if (event.data.type === 'ALA_EXECUTE_COMMAND' && event.data.command) {
            var cmd = event.data.command;
            if (!activeConsole) {
                var c = createTestConsoleModal(cmd);
                activeConsole = c;
                c.onSubmit = async function(innerCmd) {
                    c.addSeparator();
                    await executeCommandInConsole(c, innerCmd);
                };
            }
            if (activeConsole) {
                activeConsole.addSeparator();
                executeCommandInConsole(activeConsole, cmd);
            }
        }
    });

