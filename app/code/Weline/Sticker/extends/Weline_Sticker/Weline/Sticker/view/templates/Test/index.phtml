<!-- Sticker 测试文件：替换标题 -->
<w:sticker action="replace" position="1">
    <w:sticker:target>
        <h1>测试标题</h1>
    </w:sticker:target>
    <w:sticker:code>
        <h1 class="sticker-modified">Sticker 测试文件：替换标题 </h1>
    </w:sticker:code>
</w:sticker>

<!-- Sticker 测试文件：在按钮前插入内容 -->
<w:sticker action="before" position="1">
    <w:sticker:target>
        <button class="btn btn-primary">点击按钮</button>
    </w:sticker:target>
    <w:sticker:code>
        <div class="sticker-inserted">Sticker 测试文件：在按钮前插入内容</div>
    </w:sticker:code>
</w:sticker>

<!-- Sticker 测试文件：在页脚后追加内容 -->
<w:sticker action="after" position="1">
    <w:sticker:target>
        <p>这是页脚内容。</p>
    </w:sticker:target>
    <w:sticker:code>
        <p class="sticker-appended">Sticker 测试文件：在页脚后追加内容</p>
    </w:sticker:code>
</w:sticker>

