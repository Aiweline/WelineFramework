<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- setup:upgrade 后检测冲突并更新注册表 -->
    <event name="setup_upgrade_after">
        <observer name="Weline_Sticker::setup_upgrade_after" 
                  instance="Weline\Sticker\Observer\SetupUpgradeAfter" 
                  disabled="false" 
                  shared="true" 
                  sort="0"/>
    </event>
    
    <!-- 模板文件加载事件，拦截模板加载 -->
    <event name="Framework_View::fetch_file">
        <observer name="Weline_Sticker::template_fetch_file" 
                  instance="Weline\Sticker\Observer\TemplateFetchFile" 
                  disabled="false" 
                  shared="true" 
                  sort="100"/>
    </event>
</config>

