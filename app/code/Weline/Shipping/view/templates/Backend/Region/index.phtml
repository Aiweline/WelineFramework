                                        <?= __('当前国家暂无地区数据，请先从i18n同步或手动添加。') ?>
                                    </div>
                                <?php else: ?>
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle">
                                            <thead class="table-light">
                                            <tr>
                                                <th style="width: 50%;"><?= __('地区名称') ?></th>
                                                <th><?= __('地区代码') ?></th>
                                                <th><?= __('类型') ?></th>
                                                <th><?= __('启用') ?></th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            <?php
                                            $renderNode = function (array $node, int $level = 0) use (&$renderNode) {
                                                $indent = str_repeat('&mdash; ', $level);
                                                ?>
                                                <tr>
                                                    <td><?= $indent . htmlspecialchars($node['region_name']) ?></td>
                                                    <td><?= htmlspecialchars($node['region_code']) ?></td>
                                                    <td><?= htmlspecialchars($node['region_type']) ?></td>
                                                    <td>
                                                        <?php if (!empty($node['is_active'])): ?>
                                                            <span class="badge bg-success"><?= __('启用') ?></span>
                                                        <?php else: ?>
                                                            <span class="badge bg-secondary"><?= __('禁用') ?></span>
                                                        <?php endif; ?>
                                                    </td>
                                                </tr>
                                                <?php if (!empty($node['children'])): ?>
                                                    <?php foreach ($node['children'] as $child): ?>
                                                        <?php $renderNode($child, $level + 1); ?>
                                                    <?php endforeach; ?>
                                                <?php endif; ?>
                                                <?php
                                            };
                                            ?>
                                            <?php foreach ($regionTree as $rootNode): ?>
                                                <?php $renderNode($rootNode, 0); ?>
                                            <?php endforeach; ?>
                                            </tbody>
                                        </table>
