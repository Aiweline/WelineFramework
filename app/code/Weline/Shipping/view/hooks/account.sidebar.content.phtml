<?php
/**
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$user = $this->getData('user');
if (!$user) {
    return;
}

$shippingAddresses = [];
$deliveryAddresses = [];
$shippingLoadError = '';
$deliveryLoadError = '';

try {
    $shippingService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Shipping\Service\ShippingAddressService::class);
    $shippingAddresses = $shippingService->getList();
} catch (\Throwable) {
    $shippingLoadError = (string)__('发货地址加载失败，请稍后重试');
}

try {
    $deliveryService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Shipping\Service\DeliveryAddressService::class);
    $deliveryAddresses = $deliveryService->getListByCustomer((int)$user->getId());
} catch (\Throwable) {
    $deliveryLoadError = (string)__('收货地址加载失败，请稍后重试');
}

$escape = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$addressFormatter = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Shipping\Service\AddressFormatter::class);

$addressData = static function ($address, string $idField, string $type) use ($addressFormatter): array {
    return $addressFormatter->toPayload([
        'id' => (int)$address->getId(),
        $idField => (int)$address->getId(),
        'type' => $type,
        'name' => (string)$address->getData('name'),
        'contact_name' => (string)$address->getData('contact_name'),
        'contact_phone' => (string)$address->getData('contact_phone'),
        'country_code' => (string)$address->getData('country_code'),
        'country' => (string)($address->getData('country') ?: __('中国')),
        'province' => (string)$address->getData('province'),
        'province_code' => (string)$address->getData('province_code'),
        'province_region_id' => $address->getData('province_region_id'),
        'city' => (string)$address->getData('city'),
        'city_code' => (string)$address->getData('city_code'),
        'city_region_id' => $address->getData('city_region_id'),
        'district' => (string)$address->getData('district'),
        'district_code' => (string)$address->getData('district_code'),
        'district_region_id' => $address->getData('district_region_id'),
        'street' => (string)$address->getData('street'),
        'postal_code' => (string)$address->getData('postal_code'),
        'is_default' => $address->isDefault() ? 1 : 0,
        'full_address' => (string)$address->getFullAddress(),
    ]);
};

$json = static fn(array $data): string => htmlspecialchars(
    json_encode($data, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT),
    ENT_QUOTES,
    'UTF-8'
);

$shippingPayloads = array_map(
    static fn($address): array => $addressData($address, 'shipping_address_id', 'shipping'),
    $shippingAddresses
);
$deliveryPayloads = array_map(
    static fn($address): array => $addressData($address, 'delivery_address_id', 'delivery'),
    $deliveryAddresses
);

$renderAddressCard = static function (array $address, string $contactLabel) use ($escape, $json): void {
    $addressParts = $address['address_tokens'] ?? [
        ['icon' => 'country', 'label' => (string)__('国家/地区'), 'value' => $address['country']],
        ['icon' => 'region', 'label' => (string)__('省/州'), 'value' => $address['province']],
        ['icon' => 'city', 'label' => (string)__('城市'), 'value' => $address['city']],
        ['icon' => 'district', 'label' => (string)__('区县'), 'value' => $address['district']],
        ['icon' => 'street', 'label' => (string)__('详细地址'), 'value' => $address['street']],
    ];
    $icons = [
        'country' => '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5"></circle><path d="M3.8 12h16.4M12 3.5c2.2 2.3 3.3 5.2 3.3 8.5S14.2 18.2 12 20.5M12 3.5C9.8 5.8 8.7 8.7 8.7 12s1.1 6.2 3.3 8.5"></path></svg>',
        'region' => '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 5.5 9 3.8l6 2.2 4.5-1.7v14.2L15 20.2 9 18l-4.5 1.7V5.5Z"></path><path d="M9 3.8V18M15 6v14.2"></path></svg>',
        'city' => '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 20V8.5h5V20M9.5 20V4h5v16M14.5 20v-9h5v9"></path><path d="M6.5 11h1M6.5 14h1M11.5 7h1M11.5 10h1M11.5 13h1M16.5 14h1"></path></svg>',
        'district' => '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6.5-5.7 6.5-11A6.5 6.5 0 0 0 5.5 10c0 5.3 6.5 11 6.5 11Z"></path><circle cx="12" cy="10" r="2.3"></circle></svg>',
        'street' => '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11.5 12 5l8 6.5"></path><path d="M6.5 10.5V20h11v-9.5"></path><path d="M10 20v-5h4v5"></path></svg>',
        'postal' => '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6.5h14v11H5z"></path><path d="m5.5 7 6.5 5 6.5-5"></path></svg>',
    ];
    ?>
    <article class="account-address-card<?= $address['is_default'] ? ' account-address-card--default' : '' ?>" data-address-card data-address-id="<?= (int)$address['id'] ?>">
        <header class="account-address-card__header">
            <div>
                <strong data-address-name><?= $escape($address['name']) ?></strong>
                <p><span data-address-contact><?= $escape($address['contact_name']) ?></span> &middot; <span data-address-phone><?= $escape($address['contact_phone']) ?></span></p>
            </div>
            <span class="account-address-card__badge" data-address-default-badge<?= $address['is_default'] ? '' : ' hidden' ?>><lang>默认</lang></span>
        </header>
        <div class="account-address-card__body">
            <span class="account-address-card__term" data-address-contact-label><?= $escape($contactLabel) ?></span>
            <span class="account-address-card__value" data-address-full aria-label="<?= $escape($address['full_address']) ?>">
                <?php foreach ($addressParts as $part): ?>
                    <?php if ($part['value'] !== ''): ?>
                        <span class="account-address-part" title="<?= $escape($part['label']) ?>" data-address-part="<?= $escape($part['label']) ?>">
                            <span class="account-address-part__icon"><?= $icons[$part['icon']] ?? $icons['street'] ?></span>
                            <span class="account-address-part__text"><?= $escape($part['value']) ?></span>
                        </span>
                    <?php endif; ?>
                <?php endforeach; ?>
            </span>
            <span class="account-address-card__postal" data-address-postal<?= $address['postal_code'] ? '' : ' hidden' ?>><lang>邮编：</lang><?= $escape($address['postal_code']) ?></span>
        </div>
        <div class="account-address-card__actions">
            <button type="button" class="account-address-card__action" data-address-edit data-address-json="<?= $json($address) ?>"><lang>编辑</lang></button>
            <button type="button" class="account-address-card__action" data-address-default data-id="<?= (int)$address['id'] ?>"<?= $address['is_default'] ? ' hidden' : '' ?>><lang>设为默认</lang></button>
            <button type="button" class="account-address-card__action account-address-card__action--danger" data-address-delete data-id="<?= (int)$address['id'] ?>"><lang>删除</lang></button>
        </div>
    </article>
    <?php
};

