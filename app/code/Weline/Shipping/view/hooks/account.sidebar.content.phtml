<?php
/**
 * @hook-priority 50
 * @hook-sort-order 0
 * @hook-solo false
 */
/** @var \Weline\Framework\View\Template $this */

$user = $this->getData('user');
if (!$user) {
    return;
}

$shippingAddresses = [];
$deliveryAddresses = [];
$shippingLoadError = '';
$deliveryLoadError = '';

try {
    $shippingService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Shipping\Service\ShippingAddressService::class);
    $shippingAddresses = $shippingService->getList();
} catch (\Throwable) {
    $shippingLoadError = (string)__('发货地址加载失败，请稍后重试');
}

try {
    $deliveryService = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Shipping\Service\DeliveryAddressService::class);
    $deliveryAddresses = $deliveryService->getListByCustomer((int)$user->getId());
} catch (\Throwable) {
    $deliveryLoadError = (string)__('收货地址加载失败，请稍后重试');
}

$escape = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');

$addressData = static function ($address, string $idField, string $type): array {
    return [
        'id' => (int)$address->getId(),
        $idField => (int)$address->getId(),
        'type' => $type,
        'name' => (string)$address->getData('name'),
        'contact_name' => (string)$address->getData('contact_name'),
        'contact_phone' => (string)$address->getData('contact_phone'),
        'country' => (string)($address->getData('country') ?: '中国'),
        'province' => (string)$address->getData('province'),
        'city' => (string)$address->getData('city'),
        'district' => (string)$address->getData('district'),
        'street' => (string)$address->getData('street'),
        'postal_code' => (string)$address->getData('postal_code'),
        'is_default' => $address->isDefault() ? 1 : 0,
        'full_address' => (string)$address->getFullAddress(),
    ];
};

$json = static fn(array $data): string => htmlspecialchars(
    json_encode($data, JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT),
    ENT_QUOTES,
    'UTF-8'
);

$shippingPayloads = array_map(
    static fn($address): array => $addressData($address, 'shipping_address_id', 'shipping'),
    $shippingAddresses
);
$deliveryPayloads = array_map(
    static fn($address): array => $addressData($address, 'delivery_address_id', 'delivery'),
    $deliveryAddresses
);

$renderAddressCard = static function (array $address, string $contactLabel) use ($escape, $json): void {
    ?>
    <article class="account-address-card<?= $address['is_default'] ? ' account-address-card--default' : '' ?>" data-address-card data-address-id="<?= (int)$address['id'] ?>">
        <header class="account-address-card__header">
            <div>
                <strong data-address-name><?= $escape($address['name']) ?></strong>
                <p data-address-contact><?= $escape($address['contact_name']) ?> · <?= $escape($address['contact_phone']) ?></p>
            </div>
            <span class="account-address-card__badge" data-address-default-badge<?= $address['is_default'] ? '' : ' hidden' ?>><lang>默认</lang></span>
        </header>
        <div class="account-address-card__body">
            <span class="account-address-card__term"><?= $escape($contactLabel) ?></span>
            <span class="account-address-card__value" data-address-full><?= $escape($address['full_address']) ?></span>
            <span class="account-address-card__postal" data-address-postal<?= $address['postal_code'] ? '' : ' hidden' ?>><lang>邮编：</lang><?= $escape($address['postal_code']) ?></span>
        </div>
        <div class="account-address-card__actions">
            <button type="button" class="account-address-card__action" data-address-edit data-address-json="<?= $json($address) ?>"><lang>编辑</lang></button>
            <button type="button" class="account-address-card__action" data-address-default data-id="<?= (int)$address['id'] ?>"<?= $address['is_default'] ? ' hidden' : '' ?>><lang>设为默认</lang></button>
            <button type="button" class="account-address-card__action account-address-card__action--danger" data-address-delete data-id="<?= (int)$address['id'] ?>"><lang>删除</lang></button>
        </div>
    </article>
    <?php
};

$renderAddressForm = static function (string $idField, string $typeLabel, string $contactLabel): void {
    ?>
    <div class="account-address-form-wrap" data-address-form-wrap hidden>
        <form class="account-address-form" data-address-form>
            <input type="hidden" name="<?= $idField ?>" value="">
            <input type="hidden" name="is_enabled" value="1">
            <header class="account-address-form__header">
                <div>
                    <h3 class="account-address-form__title" data-address-form-title><lang>新增</lang><?= $typeLabel ?></h3>
                    <p><lang>保存后当前页面会自动刷新地址卡片，不会跳转页面。</lang></p>
                </div>
                <button type="button" class="account-address-form__close" data-address-close aria-label="<?= __('关闭') ?>">×</button>
            </header>
            <div class="account-address-form__grid">
                <label class="account-address-form__field">
                    <span><lang>地址名称</lang></span>
                    <input name="name" type="text" required placeholder="<?= __('例如：华东仓 / 家') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><?= $contactLabel ?></span>
                    <input name="contact_name" type="text" required placeholder="<?= __('请输入联系人') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>联系电话</lang></span>
                    <input name="contact_phone" type="text" required placeholder="<?= __('请输入联系电话') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>国家/地区</lang></span>
                    <input name="country" type="text" value="<?= __('中国') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>省份</lang></span>
                    <input name="province" type="text" required placeholder="<?= __('省份') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>城市</lang></span>
                    <input name="city" type="text" required placeholder="<?= __('城市') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>区县</lang></span>
                    <input name="district" type="text" placeholder="<?= __('区县') ?>">
                </label>
                <label class="account-address-form__field">
                    <span><lang>邮政编码</lang></span>
                    <input name="postal_code" type="text" placeholder="<?= __('可选') ?>">
                </label>
                <label class="account-address-form__field account-address-form__field--wide">
                    <span><lang>详细地址</lang></span>
                    <textarea name="street" required placeholder="<?= __('街道、门牌号、仓库或收件说明') ?>"></textarea>
                </label>
            </div>
            <label class="account-address-form__checkbox">
                <input type="checkbox" name="is_default" value="1">
                <span><lang>设为默认地址</lang></span>
            </label>
            <div class="account-address-form__actions">
                <button type="submit" class="account-address-form__submit"><lang>保存地址</lang></button>
                <button type="button" class="account-address-form__cancel" data-address-cancel><lang>取消</lang></button>
            </div>
        </form>
    </div>
    <?php
};
?>
<section class="account-hook-section account-index__section d-none motor-account-section" id="shipping-address-section" data-account-section="shipping-address" hidden>
    <div class="account-card account-address-panel" data-address-panel="shipping" data-save-url="/shipping/frontend/shipping-address/save" data-delete-url="/shipping/frontend/shipping-address/delete" data-default-url="/shipping/frontend/shipping-address/set-default" data-id-field="shipping_address_id">
        <textarea hidden readonly data-address-seed><?= $json($shippingPayloads) ?></textarea>
        <header class="account-card__header account-address-panel__header">
            <div>
                <h2 class="account-card__title"><lang>发货地址</lang></h2>
                <p class="account-address-panel__desc"><lang>管理店铺或账户发货时使用的寄出地址。</lang></p>
            </div>
            <button type="button" class="account-address-panel__action" data-address-new><lang>新增发货地址</lang></button>
        </header>
        <div class="account-card__body">
            <div class="account-address-message" data-address-message hidden></div>
            <?php if ($shippingLoadError): ?>
                <div class="account-card__alert account-card__alert--danger"><?= $escape($shippingLoadError) ?></div>
            <?php endif; ?>
            <div class="account-address-grid" data-address-list>
                <?php foreach ($shippingPayloads as $address): ?>
                    <?php $renderAddressCard($address, (string)__('联系人')); ?>
                <?php endforeach; ?>
            </div>
            <div class="account-address-empty" data-address-empty<?= empty($shippingPayloads) && !$shippingLoadError ? '' : ' hidden' ?>>
                <strong><lang>还没有发货地址</lang></strong>
                <span><lang>点击“新增发货地址”，直接在当前页面维护。</lang></span>
            </div>
            <?php $renderAddressForm('shipping_address_id', (string)__('发货地址'), (string)__('联系人')); ?>
        </div>
    </div>
</section>

<section class="account-hook-section account-index__section d-none motor-account-section" id="delivery-address-section" data-account-section="delivery-address" hidden>
