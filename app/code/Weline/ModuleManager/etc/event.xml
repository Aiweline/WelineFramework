<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- model_update_before/after 已废弃，由 table_ddl_before/after 替代 -->
    <event name="Weline_Framework_Schema::table_ddl_before">
        <observer name="Weline_ModuleManager::table_ddl_before" instance="Weline\ModuleManager\Observer\TableDdlBefore" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Schema::table_ddl_after">
        <observer name="Weline_ModuleManager::table_ddl_after" instance="Weline\ModuleManager\Observer\TableDdlAfter" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::module_upgrade_before">
        <observer name="Weline_ModuleManager::module_upgrade_before" instance="Weline\ModuleManager\Observer\ModuleUpdateBefore" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::remove_before_backup">
        <observer name="Weline_ModuleManager::remove_before_backup" instance="Weline\ModuleManager\Observer\RemoveBeforeBackup" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_UninstallService::module_db_backup">
        <observer name="Weline_ModuleManager::uninstall_module_db_backup" instance="Weline\ModuleManager\Observer\UninstallServiceModuleDbBackup" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_UninstallService::module_db_restore">
        <observer name="Weline_ModuleManager::uninstall_module_db_restore" instance="Weline\ModuleManager\Observer\UninstallServiceModuleDbRestore" disabled="false" shared="true" sort="0"/>
    </event>
</config>