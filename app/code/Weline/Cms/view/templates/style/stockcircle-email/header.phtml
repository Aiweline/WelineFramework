<?php
/**
 * StockCircle Email Template - Header
 * 邮件模板 - 头部（Logo区域）
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:logo => Logo设置
 * logo.display => 显示Logo:select:yes|yes,no
 * logo.url_dark => Logo地址(暗色主题):text:https://www.stockcircle.to/img/1bf70688-5b65-6f4c-d07f-a9b3ae860f76.png
 * logo.url_light => Logo地址(亮色主题):text:https://www.stockcircle.to/img/6f4c8f67-73c6-3b76-d65f-e2472e328c7d.png
 * logo.width => Logo宽度:responsive:60/60|px[移动端60px，PC端60px]
 * logo.link => Logo链接地址:text:https://www.stockcircle.to
 * 
 * group:theme => 全局主题设置[重要]:💡主题模式说明:这是全局主题配置，会控制整个模板（Header、Content、Footer）的色系\n• 暗色（dark）：深色背景、浅色文字\n• 亮色（light）：浅色背景、深色文字\n• 三个文件的主题模式会自动同步
 * theme.mode => 主题模式:select:dark|dark,light
 * 
 * group:header_style => 头部样式设置
 * header_style.background_color_dark => 背景颜色(暗色主题):color:#212a37
 * header_style.background_color_light => 背景颜色(亮色主题):color:#ffffff
 * header_style.padding_v => 上下内边距:responsive:30/30|px[移动端30px，PC端30px]
 * header_style.padding_h => 左右内边距:responsive:30/30|px[移动端30px，PC端30px]
 * 
 * group:header_container => 容器设置
 * header_container.max_width => 最大宽度:responsive:100/600|%/px[移动端100%，PC端600px]
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// Helper function
function getEmailHeaderConfig($settings, $key, $default = '') {
    return $settings[$key] ?? $default;
}

if (!function_exists('parseResponsive')) {
function parseResponsive($value) {
    if (empty($value)) return ['mobile' => '', 'desktop' => '', 'unit' => ''];
    $value = trim($value);
    $unit = '';
    if (preg_match('/([a-z%]+)$/i', $value, $matches)) {
        $unit = $matches[1];
        $value = preg_replace('/[a-z%]+$/i', '', $value);
    }
    $parts = explode('/', trim($value));
    $result = ['mobile' => '', 'desktop' => '', 'unit' => $unit ?: 'px'];
    switch (count($parts)) {
        case 1: $result['mobile'] = $result['desktop'] = trim($parts[0]); break;
        case 2: $result['mobile'] = trim($parts[0]); $result['desktop'] = trim($parts[1]); break;
    }
    return $result;
}
}

if (!function_exists('genResponsiveCSS')) {
function genResponsiveCSS($parsed) {
    $mobile = floatval($parsed['mobile']);
    $desktop = floatval($parsed['desktop']);
    $unit = $parsed['unit'];
    if ($mobile === $desktop) return $mobile . $unit;
    $diff = $desktop - $mobile;
    return "clamp({$mobile}{$unit}, calc({$mobile}{$unit} + {$diff} * ((100vw - 375px) / 905)), {$desktop}{$unit})";
}
}

// 主题配置 - 全局主题控制，此配置会同步到 Content 和 Footer
// 修改此配置后，整个模板（Header、Content、Footer）的主题都会改变
$themeMode = getEmailHeaderConfig($styleSettings, 'theme.mode', 'dark');

// Logo配置
$logoDisplay = getEmailHeaderConfig($styleSettings, 'logo.display', 'yes');
$logoUrlDark = getEmailHeaderConfig($styleSettings, 'logo.url_dark', 'https://www.stockcircle.to/img/1bf70688-5b65-6f4c-d07f-a9b3ae860f76.png');
$logoUrlLight = getEmailHeaderConfig($styleSettings, 'logo.url_light', 'https://www.stockcircle.to/img/6f4c8f67-73c6-3b76-d65f-e2472e328c7d.png');
$logoUrl = ($themeMode === 'dark') ? $logoUrlDark : $logoUrlLight;
// 优先使用 page 的 logo 字段
$pageLogo = $page ? ($page->getData('logo') ?: '') : '';
$finalLogoUrl = !empty($pageLogo) ? $pageLogo : $logoUrl;
$logoWidth = genResponsiveCSS(parseResponsive(getEmailHeaderConfig($styleSettings, 'logo.width', '60/60') . 'px'));
$logoLink = getEmailHeaderConfig($styleSettings, 'logo.link', 'https://www.stockcircle.to');

// 样式配置
$bgColorDark = getEmailHeaderConfig($styleSettings, 'header_style.background_color_dark', '#212a37');
$bgColorLight = getEmailHeaderConfig($styleSettings, 'header_style.background_color_light', '#ffffff');
$bgColor = ($themeMode === 'dark') ? $bgColorDark : $bgColorLight;
$paddingV = genResponsiveCSS(parseResponsive(getEmailHeaderConfig($styleSettings, 'header_style.padding_v', '30/30') . 'px'));
$paddingH = genResponsiveCSS(parseResponsive(getEmailHeaderConfig($styleSettings, 'header_style.padding_h', '30/30') . 'px'));

// 容器配置
$containerMaxWidth = genResponsiveCSS(parseResponsive(getEmailHeaderConfig($styleSettings, 'header_container.max_width', '100/600')));

$pageTitle = ($page && $page->getData('title')) ? (string)$page->getData('title') : '';

// 检测是否为预览模式
$pathInfo = $this->getRequest()->getPathInfo();
$isPreview = $pathInfo ? (strpos($pathInfo, '/preview/') !== false) : false;

// SEO信息
$metaTitle = ($page && $page->getData('meta_title')) ? (string)$page->getData('meta_title') : (($page && $page->getData('title')) ? (string)$page->getData('title') : '');
$metaDescription = ($page && $page->getData('meta_description')) ? (string)$page->getData('meta_description') : '';
$metaKeywords = ($page && $page->getData('meta_keywords')) ? (string)$page->getData('meta_keywords') : '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($metaTitle ?: $pageTitle) ?></title>
    
    <!-- Favicon -->
    <?php $pageIcon = $page ? ($page->getData('icon') ?: '') : ''; ?>
    <?php if (!empty($pageIcon)): ?>
    <link rel="icon" type="image/x-icon" href="<?= htmlspecialchars($pageIcon ?? '') ?>">
    <link rel="shortcut icon" type="image/x-icon" href="<?= htmlspecialchars($pageIcon ?? '') ?>">
    <?php else: ?>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <?php endif; ?>
    
    <?php if ($metaDescription): ?>
    <meta name="description" content="<?= htmlspecialchars($metaDescription ?? '') ?>">
    <?php endif; ?>
    
    <?php if ($metaKeywords): ?>
    <meta name="keywords" content="<?= htmlspecialchars($metaKeywords ?? '') ?>">
    <?php endif; ?>
    
    <!-- 统计代码 -->
    <w:template>Weline_Cms::base/tracking.phtml</w:template>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: <?= htmlspecialchars($bgColor ?? '') ?>;
            color: <?= $themeMode === 'dark' ? '#e0e0e0' : '#666666' ?>;
        }
        
        .email-header {
            width: 100%;
            background-color: <?= htmlspecialchars($bgColor ?? '') ?>;
            padding: <?= $paddingV ?> <?= $paddingH ?>;
        }
        
        .email-header-container {
            max-width: <?= $containerMaxWidth ?>;
            margin-left: auto;
            margin-right: auto;
        }
        
        .email-logo {
            display: <?= $logoDisplay === 'yes' ? 'block' : 'none' ?>;
            width: <?= $logoWidth ?>;
            height: auto;
        }
        
        .email-logo img {
            width: 100%;
            height: auto;
            display: block;
        }
        
        /* 移动端优化 */
        @media (max-width: 600px) {
            .email-header {
                padding: 20px !important;
            }
            
            .email-header-container {
                max-width: 100% !important;
            }
        }
    </style>
</head>
<body>
    
    <header class="email-header">
        <div class="email-header-container">
            <?php if ($logoDisplay === 'yes' && $finalLogoUrl): ?>
            <a href="<?= htmlspecialchars($logoLink ?? '') ?>" style="display: inline-block;">
                <div class="email-logo">
                    <img src="<?= htmlspecialchars($finalLogoUrl ?? '') ?>" alt="<?= htmlspecialchars($pageTitle ?? '') ?>" loading="lazy">
                </div>
            </a>
            <?php endif; ?>
        </div>
    </header>


