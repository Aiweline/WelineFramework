<?php
/**
 * Market Mastery 模板 - Header
 * 顶部横条，包含右侧按钮（复用 jion-landing 的 header）
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * @fields_start
 * 
 * group:header => 头部设置
 * header.logo_image => Logo图片地址:text:
 * header.logo_display => 显示Logo:select:yes|yes,no
 * header.logo_position => Logo位置:select:left|left,center
 * header.button_text => 按钮文本:text:Start Learning
 * header.button_url => 按钮链接地址:text:#
 * header.button_event_name => 按钮事件名称:text:
 * header.padding_v => 上下内边距:responsive:12/16|px
 * header.padding_h => 左右内边距:responsive:16/24|px
 * 
 * @fields_end
 */

$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 加载颜色配置
$templateCode = $page ? $page->getData('style') : 'market-mastery';
// 如果还没有，尝试从请求参数获取（预览模式）
if (empty($templateCode)) {
    $request = $this->getRequest();
    if ($request) {
        $templateCode = $request->getParam('style_code') ?: '';
    }
}
if (empty($templateCode)) {
    $templateCode = 'market-mastery';
}
// 加载颜色配置：统一从 base/colors.phtml 引入
$colors = [];
$this->assign('template_code', $templateCode);
$this->assign('style', $styleSettings);
$this->assign('style_settings', $styleSettings);
?>
<div>
    <w:template>Weline_Cms::base/colors.phtml</w:template>
