// 打开图片预览
function openImagePreview(imageSrc, title) {
    const modalHtml = `
        <div id="previewImageModal" style="
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
        " onclick="closePreviewImageModal()">
            <div style="
                max-width: 95%;
                max-height: 95%;
                position: relative;
            ">
                <img src="${imageSrc}" 
                     alt="${title}" 
                     style="
                         max-width: 100%;
                         max-height: 95vh;
                         object-fit: contain;
                         border-radius: 8px;
                         box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
                     ">
                <button onclick="closePreviewImageModal()" 
                        style="
                            position: absolute;
                            top: -40px;
                            right: 0;
                            background: rgba(255, 255, 255, 0.9);
                            border: none;
                            border-radius: 50%;
                            width: 36px;
                            height: 36px;
                            font-size: 20px;
                            cursor: pointer;
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
                        ">
                    ×
                </button>
            </div>
        </div>
    `;
    
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    document.body.style.overflow = 'hidden';
}

function closePreviewImageModal() {
    const modal = document.getElementById('previewImageModal');
    if (modal) {
        modal.remove();
    }
    document.body.style.overflow = '';
}

// ESC键关闭模态框
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closePreviewImageModal();
    }
});

/**
 * 截取iframe预览并转换为canvas显示
 * 复用页面编辑时的逻辑
 */
async function captureIframePreview(iframeId, canvasId, previewId) {
    console.log('🎬 开始截取预览:', iframeId);
    
    const iframe = document.getElementById(iframeId);
    const canvas = document.getElementById(canvasId);
    const previewContainer = document.getElementById(previewId);
    const loadingEl = previewContainer ? previewContainer.querySelector('.style-card-preview-loading') : null;
    
    if (!iframe || !canvas || !previewContainer) {
        console.error('❌ 截图失败：找不到必要的DOM元素');
        if (loadingEl) {
            loadingEl.innerHTML = '<div class="text-danger small"><?= __('预览生成失败') ?></div>';
        }
        return;
    }
    
    // 检查html2canvas是否可用
    if (typeof html2canvas === 'undefined') {
        console.error('❌ html2canvas 未加载');
        if (loadingEl) {
            loadingEl.innerHTML = '<div class="style-card-preview-placeholder"><i class="mdi mdi-alert-circle"></i><div style="font-size: 12px; margin-top: 5px;"><?= __('预览生成失败') ?></div></div>';
        }
        return;
    }
    
    try {
        // 等待iframe完全加载
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问iframe内容');
        }
        
        console.log('📸 开始使用html2canvas截图...');
        
        // 使用html2canvas截取iframe内容
        const screenshotCanvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.25, // 降低分辨率以提高性能
            width: 1200,
            height: 800,
            logging: false,
            removeContainer: false
        });
        
        // 将截图绘制到目标canvas（调整尺寸以适应卡片）
        const ctx = canvas.getContext('2d');
        canvas.width = 400; // 卡片宽度
        canvas.height = 200; // 卡片高度
        
        // 计算缩放比例（保持宽高比）
        const scale = Math.min(canvas.width / screenshotCanvas.width, canvas.height / screenshotCanvas.height);
        const x = (canvas.width / 2) - (screenshotCanvas.width / 2) * scale;
        const y = (canvas.height / 2) - (screenshotCanvas.height / 2) * scale;
        
        ctx.drawImage(screenshotCanvas, x, y, screenshotCanvas.width * scale, screenshotCanvas.height * scale);
        
        // 显示canvas，隐藏加载状态
        canvas.style.display = 'block';
        if (loadingEl) {
            loadingEl.style.display = 'none';
        }
        
        // 移除iframe（已经不需要了）
        setTimeout(() => {
            if (iframe.parentElement) {
                iframe.remove();
            }
        }, 100);
        
        console.log('✅ 预览截图成功');
        
    } catch (error) {
        console.error('❌ 截图失败:', error);
        
        // 显示错误提示
        if (loadingEl) {
            loadingEl.innerHTML = `
                <div class="style-card-preview-placeholder">
                    <i class="mdi mdi-alert-circle"></i>
                    <div style="font-size: 12px; margin-top: 5px;"><?= __('预览生成失败') ?></div>
                </div>
            `;
        }
        
        // 移除iframe
        if (iframe.parentElement) {
            iframe.remove();
        }
    }
}

/**
 * 打开默认模板预览
 */
function openDefaultPreview(styleCode, styleName) {
    const previewUrl = '<?= $this->getBackendUrl('cms/backend/preview/stylePreview') ?>?style_code=' + encodeURIComponent(styleCode);
    window.open(previewUrl, '_blank');
