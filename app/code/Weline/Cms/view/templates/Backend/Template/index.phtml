<script>
// 切换发布状态
function togglePublish(styleId, isPublished) {
    if (!confirm(isPublished ? '<?= __('确定要发布此模板吗？发布后，新建页面时将可以选择此模板。') ?>' : '<?= __('确定要取消发布此模板吗？取消发布后，新建页面时将无法选择此模板。') ?>')) {
        return;
    }
    
    const formData = new FormData();
    formData.append('style_id', styleId);
    formData.append('is_published', isPublished);
    
    fetch('<?= $this->getBackendUrl('*/backend/template/togglePublish') ?>', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert(data.message || '<?= __('操作失败') ?>');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('<?= __('操作失败，请稍后重试') ?>');
    });
}

// 搜索功能 - 回车键搜索
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('templateSearchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const form = this.closest('form');
                if (form) {
                    form.submit();
                }
            }
