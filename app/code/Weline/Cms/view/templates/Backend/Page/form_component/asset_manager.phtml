<!-- 文件管理器样式与弹窗 -->
<style>
.asset-manager-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:10000;align-items:center;justify-content:center}
.asset-manager-modal.active{display:flex}
.asset-manager-content{background:#fff;width:90%;max-width:1100px;max-height:85vh;border-radius:10px;display:flex;flex-direction:column;overflow:hidden}
.asset-manager-header{padding:12px 16px;background:#2c3e50;color:#fff;display:flex;align-items:center;justify-content:space-between}
.asset-manager-body{padding:0;overflow:auto}
.asset-manager-toolbar{padding:10px;background:#f8f9fa;border-bottom:1px solid #e0e0e0;display:flex;gap:10px;align-items:center}
.asset-path{font-family:monospace}

/* 文件列表样式 */
.asset-item-wrapper{display:flex;align-items:center;gap:12px;padding:8px 12px;border-bottom:1px solid #f0f0f0;transition:background-color 0.2s;text-decoration:none;color:inherit}
.asset-item-wrapper:hover{background-color:#f8f9fa}
.asset-item-wrapper.dir-wrapper{cursor:pointer}
.asset-item-preview{flex-shrink:0;width:80px;height:80px;display:flex;align-items:center;justify-content:center;background:#f5f5f5;border:1px solid #e0e0e0;border-radius:4px;overflow:hidden;cursor:pointer;position:relative}
.asset-item-preview img{max-width:100%;max-height:100%;object-fit:contain;border-radius:4px}
.asset-item-preview .preview-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.5);display:none;align-items:center;justify-content:center;color:#fff;font-size:24px;border-radius:4px}
.asset-item-preview:hover .preview-overlay{display:flex}
.asset-item-info{flex:1;min-width:0}
.asset-item-name{font-weight:500;margin-bottom:4px;word-break:break-all}
.asset-item-meta{font-size:12px;color:#666}
.asset-item-actions{display:flex;gap:6px;flex-shrink:0}

/* 网格样式（图片优先展示） */
.asset-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px;padding:16px}
.asset-card{border:1px solid #e5e7eb;border-radius:8px;background:#fff;overflow:hidden;display:flex;flex-direction:column}
.asset-card .thumb{position:relative;background:#fafafa;display:flex;align-items:center;justify-content:center;aspect-ratio:1/1;overflow:hidden}
.asset-card .thumb img{width:100%;height:100%;object-fit:contain}
.asset-card .thumb .preview-overlay{position:absolute;inset:0;background:rgba(0,0,0,.35);opacity:0;transition:.2s;color:#fff;display:flex;align-items:center;justify-content:center;font-size:28px}
.asset-card .thumb:hover .preview-overlay{opacity:1}
.asset-card .meta{padding:8px 10px}
.asset-card .name{font-size:12px;line-height:1.4;word-break:break-all;margin-bottom:6px}
.asset-card .desc{font-size:11px;color:#6b7280}
.asset-card .actions{display:flex;gap:8px;border-top:1px solid #eef0f2}
.asset-card .actions a,.asset-card .actions button{flex:1;border:0;background:#f8fafc;padding:8px 6px;font-size:12px;cursor:pointer;display:flex;gap:6px;align-items:center;justify-content:center}
.asset-card .actions a:hover,.asset-card .actions button:hover{background:#eef2f7}

/* 图片预览弹窗 */
.image-preview-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:10001;align-items:center;justify-content:center;padding:20px}
.image-preview-modal.active{display:flex}
.image-preview-content{position:relative;max-width:90vw;max-height:90vh;display:flex;align-items:center;justify-content:center}
.image-preview-content img{max-width:100%;max-height:90vh;object-fit:contain;border-radius:4px;box-shadow:0 4px 20px rgba(0,0,0,0.5)}
.image-preview-close{position:absolute;top:-40px;right:0;background:rgba(255,255,255,0.9);border:none;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;color:#333;transition:all 0.2s}
.image-preview-close:hover{background:#fff;transform:scale(1.1)}
.image-preview-info{position:absolute;bottom:-40px;left:0;right:0;text-align:center;color:#fff;font-size:14px}

/* 移动端响应式 */
@media (max-width: 768px) {
    .asset-item-preview{width:60px;height:60px}
    .asset-item-actions{flex-wrap:wrap}
    .asset-item-actions .btn{flex:1;min-width:auto}
    .image-preview-close{top:10px;right:10px;background:rgba(0,0,0,0.7);color:#fff}
    .image-preview-info{bottom:10px;font-size:12px}
}
</style>

<div class="asset-manager-modal" id="assetManagerModal">
    <div class="asset-manager-content">
        <div class="asset-manager-header">
            <strong><i class="mdi mdi-folder"></i> <?= __('文件管理器') ?></strong>
            <div>
                <button type="button" class="btn btn-sm btn-light" onclick="closeAssetManager()"><i class="mdi mdi-close"></i> <?= __('关闭') ?></button>
            </div>
        </div>
        <div class="asset-manager-toolbar">
            <button type="button" id="assetUpBtn" class="btn btn-sm btn-outline-secondary" onclick="upAssetDir()" disabled><i class="mdi mdi-arrow-up-bold"></i> <?= __('上一级') ?></button>
            <button type="button" class="btn btn-sm btn-primary" onclick="pickAssetUpload()"><i class="mdi mdi-upload"></i> <?= __('上传文件') ?></button>
            <span class="ms-auto small text-muted">Path: <span class="asset-path" id="assetPathText"></span></span>
            <input id="assetFileInput" type="file" accept="image/*" style="display:none" onchange="handleAssetUpload(event)">
        </div>
        <div class="asset-manager-body" id="assetListBody">
            <div class="p-4 text-center text-muted"><i class="mdi mdi-loading mdi-spin"></i> <?= __('加载中...') ?></div>
        </div>
    </div>
</div>

<!-- 图片预览弹窗 -->
<div class="image-preview-modal" id="imagePreviewModal" onclick="closeImagePreview()">
    <div class="image-preview-content" onclick="event.stopPropagation()">
        <button type="button" class="image-preview-close" onclick="closeImagePreview()" title="<?= __('关闭') ?>">×</button>
        <img id="imagePreviewImg" src="" alt="">
        <div class="image-preview-info" id="imagePreviewInfo"></div>
    </div>
</div>

<script>
(function(){
    // 打开/关闭
    window.openAssetManager = function() {
        const modal = document.getElementById('assetManagerModal');
        if (modal) {
            loadAssetList();
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    };
    window.closeAssetManager = function() {
        const modal = document.getElementById('assetManagerModal');
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        }
    };

    function getCurrentHandle(){
        var hEl = document.getElementById('handle');
        var val = hEl ? (hEl.value || '').trim() : '';
        if (!val && <?= ($this->getData('page') && $this->getData('page')->getId()) ? 'true' : 'false' ?>) {
            return '<?= $this->getData('page') ? htmlspecialchars((($this->getData('page') ?? '')->getData('handle')) ?? '') : '' ?>';
        }
        return val;
    }

    window.loadAssetList = async function(sub=''){
        try{
            const handle = getCurrentHandle();
            if (!handle){
                document.getElementById('assetListBody').innerHTML = '<div class="alert alert-warning m-3"><?= __('请先填写页面句柄 handle') ?></div>';
                return;
            }
            const listUrl = '<?= $this->getBackendUrl('cms/backend/page/listAssets') ?>' +
                '?handle=' + encodeURIComponent(handle) + (sub ? ('&sub=' + encodeURIComponent(sub)) : '');
            const res = await fetch(listUrl, { credentials: 'same-origin' });
            const data = await res.json();
            if (!data.success){
                document.getElementById('assetListBody').innerHTML = '<div class="alert alert-danger m-3">' + (data.message || '<?= __('加载失败') ?>') + '</div>';
                return;
            }
            document.getElementById('assetPathText').textContent = '/pub/media/page-build/' + handle + (data.sub ? '/' + data.sub : '');
            document.getElementById('assetUpBtn').disabled = (data.sub === '');
            document.getElementById('assetUpBtn').setAttribute('data-sub', data.sub || '');

            // 检查是否是图片文件
            function isImageFile(filename) {
                const ext = filename.split('.').pop().toLowerCase();
                return ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg', 'bmp', 'ico'].includes(ext);
            }
            
            // 格式化文件大小
            function formatFileSize(bytes) {
                if (bytes === 0) return '0 B';
                const k = 1024;
                const sizes = ['B', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
            }

            let html = '<div class="asset-grid">';
            data.items.forEach(it => {
                // HTML 转义函数
                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }
                
                // 转义 JavaScript 字符串
                function escapeJs(text) {
                    return String(text).replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '\\r');
                }
                
                if (it.type === 'dir'){
                    const dirPath = (data.sub ? data.sub + '/' : '') + it.name;
                    html += '<div class="asset-card" onclick="enterAssetDir(\'' + escapeJs(dirPath) + '\')">'
                          + '  <div class="thumb" style="background:#fff3cd">'
                          + '    <i class="mdi mdi-folder" style="font-size:48px;color:#ff9800"></i>'
                          + '  </div>'
                          + '  <div class="meta">'
                          + '    <div class="name"><strong>' + escapeHtml(it.name) + '</strong></div>'
                          + '    <div class="desc"><?= __('文件夹') ?></div>'
                          + '  </div>'
                          + '</div>';
                } else {
                    const isImage = isImageFile(it.name);
                    const fileSize = formatFileSize(it.size || 0);
                    const fileDate = new Date(it.mtime * 1000).toLocaleString('zh-CN');
                    const escapedUrl = escapeJs(it.url);
                    const escapedName = escapeJs(it.name);
                    const htmlName = escapeHtml(it.name);
                    
                    html += '<div class="asset-card">';
                    if (isImage) {
                        html += '  <div class="thumb" onclick="previewImage(\'' + escapedUrl + '\', \'' + escapedName + '\')">'
                              + '    <img src="' + escapeHtml(it.url) + '" alt="' + htmlName + '" loading="lazy">'
                              + '    <div class="preview-overlay"><i class="mdi mdi-eye"></i></div>'
                              + '  </div>';
                    } else {
                        html += '  <div class="thumb" style="background:#e9ecef">'
                              + '    <i class="mdi mdi-file" style="font-size:42px;color:#6c757d"></i>'
                              + '  </div>';
                    }
                    html += '  <div class="meta">'
                          + '    <div class="name">' + htmlName + '</div>'
                          + '    <div class="desc">' + escapeHtml(fileSize) + ' · ' + escapeHtml(fileDate) + '</div>'
                          + '  </div>';
                    html += '  <div class="actions">'
                          + '    <button type="button" onclick="copyAssetUrl(\'' + escapedUrl + '\')"><i class="mdi mdi-content-copy"></i><span><?= __('复制URL') ?></span></button>';
                    if (isImage) {
                        html += '    <button type="button" onclick="previewImage(\'' + escapedUrl + '\', \'' + escapedName + '\')"><i class="mdi mdi-eye"></i><span><?= __('预览') ?></span></button>';
                    }
                    html += '  </div>'
                          + '</div>';
                }
            });
            html += '</div>';
            document.getElementById('assetListBody').innerHTML = html;
        }catch(e){
            document.getElementById('assetListBody').innerHTML = '<div class="alert alert-danger m-3">' + (e && e.message ? e.message : '<?= __('加载失败') ?>') + '</div>';
        }
    }
    window.enterAssetDir = function(nextSub){ loadAssetList(nextSub); }
    window.upAssetDir = function(){
        const btn = document.getElementById('assetUpBtn');
        const sub = btn.getAttribute('data-sub') || '';
        if (!sub) return;
        const parts = sub.split('/').filter(Boolean);
        parts.pop();
        loadAssetList(parts.join('/'));
    }
    window.copyAssetUrl = function(url){
        if (navigator.clipboard && navigator.clipboard.writeText){
            navigator.clipboard.writeText(url).then(()=>{
                if (typeof showToast === 'function') showToast('success', '<?= __('已复制') ?>', url);
            });
        } else {
            const ta = document.createElement('textarea');
            ta.value = url; document.body.appendChild(ta); ta.select();
            try{ document.execCommand('copy'); if (typeof showToast === 'function') showToast('success', '<?= __('已复制') ?>', url);}catch(_){}
            document.body.removeChild(ta);
        }
    }
    window.pickAssetUpload = function(){
        const input = document.getElementById('assetFileInput');
        if (input) input.click();
    }
    window.handleAssetUpload = async function(ev){
        const files = ev.target.files; if (!files || !files.length) return;
        const handle = getCurrentHandle();
        const sub = (document.getElementById('assetUpBtn').getAttribute('data-sub') || '');
        const fd = new FormData();
        fd.append('file', files[0]);
        fd.append('handle', handle);
        fd.append('sub', sub);
        try{
            const res = await fetch('<?= $this->getBackendUrl('cms/backend/page/uploadAssetTo') ?>', { method: 'POST', body: fd, credentials: 'same-origin' });
            const data = await res.json();
            if (data && data.success){
                if (typeof showToast === 'function') showToast('success', '<?= __('上传成功') ?>', '');
                loadAssetList(sub);
            } else {
                if (typeof showToast === 'function') showToast('error', '<?= __('上传失败') ?>', (data && data.message) ? data.message : '');
            }
        }catch(e){
            if (typeof showToast === 'function') showToast('error', '<?= __('上传失败') ?>', e && e.message ? e.message : '');
        } finally {
            ev.target.value = '';
        }
    }
    
    // 图片预览功能
    window.previewImage = function(url, name) {
        const modal = document.getElementById('imagePreviewModal');
        const img = document.getElementById('imagePreviewImg');
        const info = document.getElementById('imagePreviewInfo');
        if (modal && img) {
            img.src = url;
            img.alt = name || '';
            if (info) {
                info.textContent = name || '';
            }
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    };
    
    window.closeImagePreview = function() {
        const modal = document.getElementById('imagePreviewModal');
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
            // 清空图片源，释放内存
            const img = document.getElementById('imagePreviewImg');
            if (img) {
                img.src = '';
            }
        }
    };
    
    // ESC 键关闭预览
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            const modal = document.getElementById('imagePreviewModal');
            if (modal && modal.classList.contains('active')) {
                closeImagePreview();
            }
        }
    });
})();
</script>


