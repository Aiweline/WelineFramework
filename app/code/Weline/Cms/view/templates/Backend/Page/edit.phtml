<script>
(function () {
    const select = document.querySelector('.cms-page-settings-bar select[name="website_id"]');
    const codeInput = document.querySelector('[data-cms-website-code]');
    if (!select || !codeInput) {
        return;
    }
    const syncCode = function () {
        const option = select.options[select.selectedIndex];
        codeInput.value = option ? (option.getAttribute('data-code') || '') : '';
    };
    select.addEventListener('change', syncCode);
    syncCode();
})();
</script>
