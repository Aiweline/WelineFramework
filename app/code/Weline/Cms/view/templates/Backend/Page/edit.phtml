$websites = $this->getData('websites') ?: [];
$layoutOptions = $this->getData('layout_options') ?: [];
$layoutSelection = $this->getData('layout_selection') ?: [];
$themeEditorUrl = (string)($this->getData('theme_editor_url') ?: '');
$previewUrl = (string)($this->getData('preview_url') ?: '');
$pageId = (int)($page['page_id'] ?? 0);
$hasPage = $pageId > 0;
$currentWebsiteId = (int)($page['website_id'] ?? 0);
$currentWebsiteCode = (string)($page['website_code'] ?? 'default');
$hasPathGroupContext = $hasPage && trim((string)($page['path_group'] ?? '')) !== '';
$currentLayoutOption = (string)($layoutSelection['layout_option'] ?? 'default');
$layoutOptionsPairs = [];
foreach ($layoutOptions as $option) {
    $value = (string)($option['value'] ?? 'default');
    $label = (string)($option['label'] ?? $value);
    $layoutOptionsPairs[] = str_replace([',', ':'], [' ', ' '], $value) . ':' . str_replace([',', ':'], [' ', ' '], $label);
}
$layoutOptionsStr = implode(',', $layoutOptionsPairs);
$layoutPlaceholder = __('请选择或搜索布局...');
