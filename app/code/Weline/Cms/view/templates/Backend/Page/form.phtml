window.publishPage = function() {
    const statusSelect = document.getElementById('status');
    const publishBtn = document.getElementById('publishPageBtn');
    const form = document.getElementById('page-form');
    
    if (!statusSelect || !form) {
        console.error('❌ 找不到状态选择器或表单');
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('系统错误') ?>',
                text: '<?= __('请刷新页面重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('系统错误，请刷新页面重试') ?>');
        }
        return;
    }
    
    // 设置状态为已发布
    statusSelect.value = '1';
    
    // 显示加载状态
    const originalHTML = publishBtn.innerHTML;
    publishBtn.disabled = true;
    publishBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('发布中...') ?>';
    
    console.log('📤 正在发布页面...');
    console.log('📊 状态已设置为: 已发布 (1)');
    console.log('📋 表单ID:', form.id);
    
    // 提交表单
    try {
        form.submit();
    } catch (error) {
        console.error('❌ 发布失败:', error);
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: '<?= __('发布失败') ?>',
                text: '<?= __('请重试') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('发布失败，请重试') ?>');
        }
        
        // 恢复按钮状态
        publishBtn.disabled = false;
        publishBtn.innerHTML = originalHTML;
    }
};

