 * @var \Weline\Cms\Model\Page $page
 */
$page = $this->getData('page');
$isEdit = $page && $page->getId();
$selectedLocales = $this->getData('selected_locales') ?? [];
$parentId = $this->getData('parent_id') ?? 0;

// 初始化可视化配置所需的 PHP 变量（必须在文件开头定义，避免在 JavaScript 中使用未定义变量）
if ($isEdit && $page && $page->getId()) {
    $visualPageId = $page->getId();
    $visualStyleSettings = $page->getStyleSetting(); // 注意：方法名是单数形式
    $pageDefaultLocale = ($page ? $page->getData('default_locale') : null) ?: \Weline\Framework\Http\Cookie::getLang();
    $pageLocales = json_decode(($page ? ($page->getData('locales') ?? '') : ''), true) ?: [];
} else {
    $visualPageId = null;
    $visualStyleSettings = [];
    // 新建页面时，默认语言使用框架当前语言
    $pageDefaultLocale = \Weline\Framework\Http\Cookie::getLang();
    $pageLocales = [];
}
if (!is_array($pageLocales)) $pageLocales = [];

// 确保默认语言在支持的语言列表中
if ($pageDefaultLocale && !in_array($pageDefaultLocale, $pageLocales)) {
    $pageLocales[] = $pageDefaultLocale;
}

// 确保 selectedLocales 包含默认语言
if ($pageDefaultLocale && !in_array($pageDefaultLocale, $selectedLocales)) {
    $selectedLocales[] = $pageDefaultLocale;
}
