// ==================== 语言标签管理功能 ====================

/**
 * 添加语言标签
 */
function addLocaleTag(localeCode, localeName) {
    // 检查是否已存在
    if (document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`)) {
        return;
    }
    
    // 创建标签
    const tag = document.createElement('span');
    tag.className = 'badge bg-primary me-2 mb-2 py-2 px-3 selected-locale-tag';
    tag.setAttribute('data-locale-code', localeCode);
    tag.style.fontSize = '0.875rem';
    tag.innerHTML = `
        ${localeName} (${localeCode})
        <i class="mdi mdi-close ms-1" 
           style="cursor: pointer;"
           onclick="removeLocaleTag('${localeCode}')"></i>
    `;
    
    // 添加到标签区域
    document.getElementById('selectedLocalesTags').appendChild(tag);
    
    // 勾选对应的checkbox
    const checkbox = document.getElementById('locale_' + localeCode);
    if (checkbox) {
        checkbox.checked = true;
    }
    
    // 隐藏下拉列表中的选项
    const option = document.querySelector(`.locale-option[data-locale-code="${localeCode}"]`);
    if (option) {
        option.style.display = 'none';
    }
    
    // 清空搜索框
    const searchInput = document.getElementById('localeSearch');
    searchInput.value = '';
    
    // 重置下拉列表显示
    resetLocaleDropdown();
    
    // 隐藏提示信息（如果存在）
    updateLocalesHint();
    
    // 更新删除按钮状态（如果是默认语言则禁用删除按钮）
    updateLocaleTagsDeleteButton();
    
    // 保持下拉列表打开并聚焦搜索框，方便继续选择
    const dropdown = document.getElementById('localeDropdown');
    if (dropdown.style.display === 'block') {
        searchInput.focus();
    }
}

/**
 * 移除语言标签
 */
function removeLocaleTag(localeCode) {
    // 检查是否是默认语言，默认语言不能删除
    const defaultLocale = document.getElementById('default_locale').value;
    if (localeCode === defaultLocale) {
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'warning',
                title: '<?= __('提示') ?>',
                text: '<?= __('默认语言不能从支持的语言列表中删除！如需更改，请先切换默认语言。') ?>',
                confirmButtonText: '<?= __('确定') ?>'
            });
        } else {
            console.error('<?= __('默认语言不能从支持的语言列表中删除！如需更改，请先切换默认语言。') ?>');
        }
        return false;
    }
    
    // 移除标签
    const tag = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
    if (tag) {
        tag.remove();
    }
    
    // 取消勾选checkbox
    const checkbox = document.getElementById('locale_' + localeCode);
    if (checkbox) {
        checkbox.checked = false;
    }
    
    // 显示下拉列表中的选项
    const option = document.querySelector(`.locale-option[data-locale-code="${localeCode}"]`);
    if (option) {
        option.style.display = 'block';
    }
    
    // 重置下拉列表显示
    resetLocaleDropdown();
    
    // 更新提示信息（如果没有标签了则显示提示）
    updateLocalesHint();
}

/**
 * 更新语言选择提示信息的显示/隐藏
 */
function updateLocalesHint() {
    const tagsContainer = document.getElementById('selectedLocalesTags');
    const existingHint = document.getElementById('noLocalesHint');
    const selectedTags = document.querySelectorAll('.selected-locale-tag');
    
    if (selectedTags.length === 0) {
        // 没有选择任何语言，显示提示
        if (!existingHint) {
            const hint = document.createElement('div');
            hint.className = 'alert alert-info py-2 px-3 mb-0';
            hint.id = 'noLocalesHint';
            hint.style.fontSize = '0.875rem';
            hint.innerHTML = '<i class="mdi mdi-information-outline me-1"></i>暂未选择支持的语言，请使用下方搜索框添加语言';
            tagsContainer.appendChild(hint);
        }
    } else {
        // 已有选择的语言，隐藏提示
        if (existingHint) {
            existingHint.remove();
        }
    }
}

/**
 * 更新语言标签的删除按钮状态
 * 默认语言的删除按钮应该被禁用
 */
function updateLocaleTagsDeleteButton() {
    const defaultLocale = document.getElementById('default_locale').value;
    const allTags = document.querySelectorAll('.selected-locale-tag');
    
    allTags.forEach(tag => {
        const localeCode = tag.getAttribute('data-locale-code');
        const closeIcon = tag.querySelector('.mdi-close');
        
        if (localeCode === defaultLocale) {
            // 默认语言：禁用删除按钮
            if (closeIcon) {
                closeIcon.style.opacity = '0.3';
                closeIcon.style.cursor = 'not-allowed';
                closeIcon.title = '<?= __('默认语言不能删除') ?>';
            }
            // 添加一个标识符
            tag.style.borderLeft = '3px solid #ffc107';
        } else {
            // 非默认语言：启用删除按钮
            if (closeIcon) {
                closeIcon.style.opacity = '1';
                closeIcon.style.cursor = 'pointer';
                closeIcon.title = '<?= __('移除此语言') ?>';
            }
            tag.style.borderLeft = 'none';
        }
    });
}

/**
 * 切换语言下拉列表显示/隐藏
 */
function toggleLocaleDropdown() {
    const dropdown = document.getElementById('localeDropdown');
    const btn = document.getElementById('localeDropdownBtn');
    const icon = btn.querySelector('i');
    
    if (dropdown.style.display === 'none' || dropdown.style.display === '') {
        dropdown.style.display = 'block';
        icon.classList.remove('mdi-chevron-down');
        icon.classList.add('mdi-chevron-up');
        // 自动聚焦搜索框
        document.getElementById('localeSearch').focus();
    } else {
        dropdown.style.display = 'none';
        icon.classList.remove('mdi-chevron-up');
        icon.classList.add('mdi-chevron-down');
    }
}

/**
 * 搜索语言功能
 */
document.getElementById('localeSearch')?.addEventListener('input', function() {
    const searchText = this.value.toLowerCase();
    const options = document.querySelectorAll('.locale-option');
    const dropdown = document.getElementById('localeDropdown');
    const noMatchHint = document.getElementById('noMatchHint');
    
    let hasVisibleOptions = false;
    
    options.forEach(option => {
        const localeCode = option.getAttribute('data-locale-code');
        const localeName = option.getAttribute('data-locale-name');
        const text = `${localeName} ${localeCode}`.toLowerCase();
        
        // 如果已被选中，不显示
        const isSelected = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
        if (isSelected) {
            option.style.display = 'none';
            return;
        }
        
        // 根据搜索文本显示/隐藏
        if (text.includes(searchText)) {
            option.style.display = 'block';
            hasVisibleOptions = true;
        } else {
            option.style.display = 'none';
        }
    });
    
    // 显示/隐藏"未找到匹配"提示
    if (!hasVisibleOptions && searchText) {
        noMatchHint.style.display = 'block';
    } else {
        noMatchHint.style.display = 'none';
    }
    
    // 自动展开下拉列表
    if (dropdown.style.display === 'none' && searchText) {
        dropdown.style.display = 'block';
        const btn = document.getElementById('localeDropdownBtn');
        const icon = btn.querySelector('i');
        icon.classList.remove('mdi-chevron-down');
        icon.classList.add('mdi-chevron-up');
    }
});

/**
 * 点击搜索框时自动展开下拉列表
 */
document.getElementById('localeSearch')?.addEventListener('focus', function() {
    const dropdown = document.getElementById('localeDropdown');
    const btn = document.getElementById('localeDropdownBtn');
    const icon = btn.querySelector('i');
    
    // 先过滤一遍选项（隐藏已选中的）
    resetLocaleDropdown();
    
    // 展开下拉列表
    dropdown.style.display = 'block';
    icon.classList.remove('mdi-chevron-down');
    icon.classList.add('mdi-chevron-up');
});

/**
 * 点击页面其他地方关闭下拉列表
 */
document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('localeDropdown');
    const searchInput = document.getElementById('localeSearch');
    const dropdownBtn = document.getElementById('localeDropdownBtn');
    
    // 如果点击的不是下拉列表、搜索框或按钮，则关闭下拉列表
    if (dropdown && 
        !dropdown.contains(event.target) && 
        event.target !== searchInput && 
        event.target !== dropdownBtn &&
        !dropdownBtn.contains(event.target)) {
        dropdown.style.display = 'none';
        const btn = document.getElementById('localeDropdownBtn');
        const icon = btn.querySelector('i');
        icon.classList.remove('mdi-chevron-up');
        icon.classList.add('mdi-chevron-down');
        // 清空搜索框
        if (searchInput) {
            searchInput.value = '';
            resetLocaleDropdown();
        }
    }
});
/**
 * 重置下拉列表显示（过滤已选中的）
 */
function resetLocaleDropdown() {
    const options = document.querySelectorAll('.locale-option');
    options.forEach(option => {
        const localeCode = option.getAttribute('data-locale-code');
        const isSelected = document.querySelector(`.selected-locale-tag[data-locale-code="${localeCode}"]`);
        
        if (isSelected) {
            option.style.display = 'none';
        } else {
            // 如果有搜索文本，按搜索文本过滤
            const searchText = document.getElementById('localeSearch').value.toLowerCase();
            if (searchText) {
                const localeName = option.getAttribute('data-locale-name');
                const text = `${localeName} ${localeCode}`.toLowerCase();
                option.style.display = text.includes(searchText) ? 'block' : 'none';
            } else {
                option.style.display = 'block';
            }
        }
    });
}
// 页面加载时初始化下拉列表
document.addEventListener('DOMContentLoaded', function() {
    resetLocaleDropdown();
    // 初始化语言标签的删除按钮状态
    updateLocaleTagsDeleteButton();
});

/**
 * ========================================
 * 样式配置动态加载功能
 * ========================================
 */

// 页面ID（用于翻译功能）
const pageIdForm = <?= ($isEdit && $page && $page->getId()) ? $page->getId() : 'null' ?>;

// 样式选择器
const styleSelect = document.getElementById('style');
const styleDescContainer = document.getElementById('style-description-container');
const styleDescText = document.getElementById('style-description-text');


/**
 * 通过AJAX加载样式列表
 * 实时扫描样式目录并渲染为卡片
 */
let allStyles = []; // 存储所有样式数据用于搜索
loadStyleList();
async function loadStyleList() {
    console.log('🚀 开始加载样式列表...');
    
    const styleSelect = document.getElementById('style');
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsLoading = document.getElementById('styleCardsLoading');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    if (!styleSelect || !styleCardsContainer) {
        console.error('❌ 未找到必要的DOM元素');
        return;
    }
    
    const currentStyle = '<?= $page ? htmlspecialchars((($page->getData('style') ?? '')) ?? '') : '' ?>';
    const currentPageId = '<?= $page ? $page->getId() : '' ?>';
    console.log('🎯 当前选择的样式:', currentStyle || '(无)');
    console.log('📄 当前页面ID:', currentPageId || '(新建)');
    
    try {
        // 显示加载状态
        styleCardsLoading.style.display = 'block';
        styleCardsEmpty.style.display = 'none';
        styleCardsContainer.innerHTML = '';
        
        // 构建请求 URL
        const apiUrl = '<?= $this->getBackendUrl('cms/backend/page/getStyles') ?>';
        console.log('📡 请求 URL:', apiUrl);
        
        // 发送AJAX请求
        const response = await fetch(apiUrl, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        console.log('📥 收到响应:', response.status, response.statusText);
        
        // 检查响应状态
        if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ HTTP错误响应:', response.status, errorText);
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        // 解析JSON
        const result = await response.json();
        console.log('📦 解析响应数据:', result);
        
        if (result.success && result.data) {
            allStyles = result.data; // 保存到全局变量
            
            // 更新隐藏的select（用于表单提交）
            styleSelect.innerHTML = '<option value=""><?= __('请选择样式') ?></option>';
            result.data.forEach(style => {
                const option = document.createElement('option');
                option.value = style.code;
                option.textContent = style.name;
                if (currentStyle && style.code === currentStyle) {
                    option.selected = true;
                }
                styleSelect.appendChild(option);
            });
            
            // 渲染样式卡片
            renderStyleCards(result.data, currentStyle, currentPageId);
        } else {
            console.error('❌ 加载样式列表失败:', result);
            styleCardsEmpty.innerHTML = '<i class="mdi mdi-alert"></i> ' + (result.message || '加载失败，请刷新重试');
            styleCardsEmpty.style.display = 'block';
        }
    } catch (error) {
        console.error('❌ 加载样式列表异常:', error);
        console.error('错误堆栈:', error.stack);
        
        // 显示详细的错误信息
        const errorMessage = error.message || '未知错误';
        styleCardsEmpty.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle"></i>
                <strong>加载失败</strong><br>
                <small>${errorMessage}</small><br>
                <button class="btn btn-sm btn-outline-danger mt-2" onclick="loadStyleList()">
                    <i class="mdi mdi-refresh"></i> 重试
                </button>
            </div>
        `;
        styleCardsEmpty.style.display = 'block';
    } finally {
        styleCardsLoading.style.display = 'none';
    }
}

/**
 * 渲染样式卡片
 */
function renderStyleCards(styles, currentStyle, currentPageId) {
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    styleCardsContainer.innerHTML = '';
    
    if (!styles || styles.length === 0) {
        styleCardsEmpty.style.display = 'block';
        return;
    }
    
    styleCardsEmpty.style.display = 'none';
    
    const previewImageUrl = '<?= $this->getBackendUrl('cms/backend/page/stylePreviewImage') ?>';
    const previewFullUrl = '<?= $this->getBackendUrl('cms/backend/preview/full') ?>';
    
    styles.forEach(style => {
        const col = document.createElement('div');
        col.className = 'col';
        
        const isSelected = currentStyle && style.code === currentStyle;
        const hasPreviewImage = style.preview_image && style.preview_image.trim() !== '';
        
        const card = document.createElement('div');
        card.className = 'card style-card' + (isSelected ? ' selected' : '');
        card.dataset.styleCode = style.code;
        card.dataset.styleName = style.name;
        card.dataset.styleDescription = style.description || '';
        
        // 预览区域
        let previewHtml = '';
        let previewActionsHtml = '';
        
        if (hasPreviewImage) {
            // 有预览图，通过控制器获取图片
            const imageUrl = `${previewImageUrl}?code=${encodeURIComponent(style.code)}`;
            
            // 预览操作按钮：放大预览 + 真实预览 + 默认预览
            previewActionsHtml = currentPageId ? `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            ` : `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview">
                    ${previewActionsHtml}
                    <img src="${imageUrl}" 
                         alt="${style.name}" 
                         onerror="this.parentElement.innerHTML='<div class=\\'style-card-preview-placeholder\\'><i class=\\'mdi mdi-image-broken\\'></i><div>图片加载失败</div></div>'">
                </div>
            `;
        } else if (currentPageId) {
            // 没有预览图但有页面ID，使用iframe实时预览并转换为canvas
            const iframeUrl = `${previewFullUrl}?page_id=${currentPageId}&style_code=${encodeURIComponent(style.code)}`;
            const canvasId = `style-preview-canvas-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            const iframeId = `style-preview-iframe-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            
            // 预览操作按钮：真实预览 + 默认预览
            previewActionsHtml = `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview" id="preview-${style.code}">
                    ${previewActionsHtml}
                    <div class="style-card-preview-loading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <div style="margin-top: 10px; font-size: 12px;">正在生成预览...</div>
                    </div>
                    <canvas id="${canvasId}" style="display: none; width: 100%; height: 100%;"></canvas>
                    <iframe id="${iframeId}" 
                            src="${iframeUrl}" 
                            style="position: absolute; left: -9999px; width: 1200px; height: 800px; border: none;"
                            onload="captureIframePreview('${iframeId}', '${canvasId}', 'preview-${style.code}')">
                    </iframe>
                </div>
            `;
        } else {
            // 没有预览图也没有页面ID，使用默认模板预览生成实时预览
            const defaultPreviewUrl = '<?= $this->getBackendUrl('cms/backend/preview/stylePreview') ?>?style_code=' + encodeURIComponent(style.code);
            const canvasId = `style-preview-canvas-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            const iframeId = `style-preview-iframe-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            
            // 预览操作按钮：默认预览
            previewActionsHtml = `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview" id="preview-${style.code}">
                    ${previewActionsHtml}
                    <div class="style-card-preview-loading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <div style="margin-top: 10px; font-size: 12px;">正在生成默认预览...</div>
                    </div>
