<!-- 全局Toast通知函数 -->
<script>
// ==================== Toast 通知函数（全局） ====================
function showToast(type, title, message) {
    // 检查是否有全局的 Toast 方法
    if (typeof Toastify !== 'undefined') {
        Toastify({
            text: title + (message ? '<br>' + message : ''),
            duration: 3000,
            gravity: "top",
            position: "right",
            backgroundColor: type === 'success' ? "#28a745" : "#dc3545",
            escapeMarkup: false
        }).showToast();
    } else if (typeof toastr !== 'undefined') {
        toastr[type](message || '', title);
    } else {
        // 降级为简单的通知元素
        if (type === 'success') {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;top:20px;right:20px;background:#28a745;color:white;padding:15px 20px;border-radius:5px;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:11000;max-width:400px;';
            toast.innerHTML = '<strong>' + title + '</strong><br>' + (message || '');
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.transition = 'opacity 0.3s';
                toast.style.opacity = '0';
                setTimeout(() => document.body.removeChild(toast), 300);
            }, 3000);
        } else {
            alert(title + '\n' + (message || ''));
        }
    }
}
</script>

<!-- 页面关系树复制功能 -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ==================== 点击 Handle 文本复制 ====================
    const clickableHandles = document.querySelectorAll('.clickable-handle');
    clickableHandles.forEach(function(element) {
        element.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const handle = this.getAttribute('data-handle');
            const pageName = this.getAttribute('data-page-name');
            const originalBg = this.style.backgroundColor;
            const originalText = this.textContent;
            
            // 添加 / 前缀
            const handleWithSlash = '/' + handle;
            
            copyToClipboard(handleWithSlash, null, null, null, 
                '<?= __("Handle 已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("Handle") ?>: ' + handleWithSlash);
            
            // 视觉反馈
            this.style.backgroundColor = '#d4edda';
            this.textContent = '✓ ' + handleWithSlash;
            setTimeout(() => {
                this.style.backgroundColor = originalBg;
                this.textContent = originalText;
            }, 1500);
        });
    });
    
    // ==================== 点击链接文本复制 ====================
    const clickableUrls = document.querySelectorAll('.clickable-url');
    clickableUrls.forEach(function(element) {
        element.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const url = this.getAttribute('data-url');
            const pageName = this.getAttribute('data-page-name');
            const originalColor = this.style.color;
            const originalText = this.textContent;
            
            copyToClipboard(url, null, null, null, 
                '<?= __("链接已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
            
            // 视觉反馈
            this.style.color = '#198754';
            this.style.fontWeight = 'bold';
            this.textContent = '✓ ' + originalText;
            setTimeout(() => {
                this.style.color = originalColor;
                this.style.fontWeight = '';
                this.textContent = originalText;
            }, 1500);
        });
    });
    
    // ==================== 复制 Handle 按钮功能 ====================
    const copyHandleButtons = document.querySelectorAll('.copy-handle-btn');
    copyHandleButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const handle = this.getAttribute('data-handle');
            const pageName = this.getAttribute('data-page-name');
            const originalHtml = this.innerHTML;
            const originalClass = this.className;
            
            // 添加 / 前缀
            const handleWithSlash = '/' + handle;
            
            copyToClipboard(handleWithSlash, this, originalHtml, originalClass, 
                '<?= __("Handle 已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("Handle") ?>: ' + handleWithSlash);
        });
    });
    
    // ==================== 复制链接按钮功能 ====================
    const copyUrlButtons = document.querySelectorAll('.copy-page-url-btn');
    copyUrlButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            
            const url = this.getAttribute('data-url');
            const pageName = this.getAttribute('data-page-name');
            const originalHtml = this.innerHTML;
            const originalClass = this.className;
            
            copyToClipboard(url, this, originalHtml, originalClass, 
                '<?= __("链接已复制") ?>', 
                '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
        });
    });
    
    // ==================== 复制到剪贴板的通用函数 ====================
    function copyToClipboard(text, button, originalHtml, originalClass, successTitle, successMessage) {
        // 使用现代 Clipboard API
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text)
                .then(() => {
                    showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage);
                })
                .catch(err => {
                    console.error('<?= __("复制失败") ?>:', err);
                    fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage);
                });
        } else {
            // 降级方案
            fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage);
        }
    }
    
    // ==================== 降级复制方法 ====================
    function fallbackCopy(text, button, originalHtml, originalClass, successTitle, successMessage) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        textArea.style.top = '-999999px';
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        
        try {
            const successful = document.execCommand('copy');
            if (successful) {
                showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage);
            } else {
                throw new Error('execCommand failed');
            }
        } catch (err) {
            console.error('<?= __("复制失败") ?>:', err);
            // 最后降级方案：提示用户手动复制
            prompt('<?= __("请手动复制以下内容") ?>:', text);
        } finally {
            document.body.removeChild(textArea);
        }
    }
    
    // ==================== 显示复制成功状态 ====================
    function showCopySuccess(button, originalHtml, originalClass, successTitle, successMessage) {
        // Toast 通知
        showToast('success', successTitle, successMessage);
        
        // 如果是按钮，更新按钮状态
        if (button) {
            button.innerHTML = '<i class="mdi mdi-check"></i> <?= __("已复制") ?>';
            button.className = 'btn btn-sm btn-success copy-success-btn';
            
            // 2秒后恢复原状
            setTimeout(() => {
                button.innerHTML = originalHtml;
                button.className = originalClass;
            }, 2000);
        }
    }
    
    // ==================== Toast 通知函数（已在全局定义） ====================
    // showToast 函数现在是全局函数，可以在任何地方调用
    
    // ==================== 配置导入导出功能 ====================
    
    /**
     * 导出页面配置到Excel
     */
    window.exportPageConfig = async function() {
        try {
            const pageId = window.visualPageId || currentPageId;
            
            // 获取样式代码
            const styleSelect = document.getElementById('style');
            let styleCode = styleSelect ? styleSelect.value : '';
            
            // 如果select没有值，尝试从全局变量获取
            if (!styleCode && typeof currentStyle !== 'undefined' && currentStyle) {
                styleCode = currentStyle;
            }
            
            // 如果还是没有值，尝试从页面数据获取
            if (!styleCode) {
                styleCode = '<?= $page && $page->getData('style') ? htmlspecialchars($page->getData('style')) : '' ?>';
            }
            
            if (!pageId || !styleCode) {
                showToast('error', '<?= __("导出失败") ?>', '<?= __("请先选择样式模板") ?>');
                return;
            }
            
            // 显示加载状态
            const exportBtn = document.getElementById('exportConfigBtn');
            const originalHtml = exportBtn ? exportBtn.innerHTML : '';
            if (exportBtn) {
                exportBtn.disabled = true;
                exportBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("导出中...") ?>';
            }
            
            // 调用导出接口
            const url = '<?= $this->getBackendUrl("cms/backend/page/exportConfig") ?>' + 
                '?page_id=' + encodeURIComponent(pageId) + 
                '&style_code=' + encodeURIComponent(styleCode);
            
            const response = await fetch(url, {
                method: 'GET',
                credentials: 'same-origin'
            });
            
            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }
            
            // 获取文件名（从Content-Disposition头或使用默认名称）
            const contentDisposition = response.headers.get('Content-Disposition');
            let filename = 'page-config-' + pageId + '-' + styleCode + '.xlsx';
            if (contentDisposition) {
                const filenameMatch = contentDisposition.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
                if (filenameMatch && filenameMatch[1]) {
                    filename = filenameMatch[1].replace(/['"]/g, '');
                }
            }
            
            // 下载文件
            const blob = await response.blob();
            const downloadUrl = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = downloadUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(downloadUrl);
            
            showToast('success', '<?= __("导出成功") ?>', '<?= __("配置已导出到Excel文件") ?>');
            
            // 恢复按钮状态
            if (exportBtn) {
                exportBtn.innerHTML = originalHtml;
                exportBtn.disabled = false;
            }
        } catch (error) {
            console.error('导出配置失败:', error);
            showToast('error', '<?= __("导出失败") ?>', error.message || '<?= __("未知错误") ?>');
            
            // 恢复按钮状态
            const exportBtn = document.getElementById('exportConfigBtn');
            if (exportBtn) {
                exportBtn.disabled = false;
                exportBtn.innerHTML = '<i class="mdi mdi-download"></i> <?= __("导出配置") ?>';
            }
        }
    };
    
    /**
     * 从Excel导入页面配置
     */
    window.importPageConfig = function() {
        // 创建隐藏的文件输入元素
        let fileInput = document.getElementById('configImportFileInput');
        if (!fileInput) {
            fileInput = document.createElement('input');
            fileInput.type = 'file';
            fileInput.id = 'configImportFileInput';
            fileInput.accept = '.xlsx,.xls';
            fileInput.style.display = 'none';
            fileInput.onchange = handleConfigImport;
            document.body.appendChild(fileInput);
        }
        fileInput.click();
    };
    
    /**
     * 处理配置文件导入
     */
    async function handleConfigImport(event) {
        const file = event.target.files[0];
        if (!file) {
            return;
        }
        
        // 验证文件类型
        const fileName = file.name.toLowerCase();
        if (!fileName.endsWith('.xlsx') && !fileName.endsWith('.xls')) {
            showToast('error', '<?= __("导入失败") ?>', '<?= __("请选择Excel文件(.xlsx或.xls)") ?>');
            event.target.value = '';
            return;
        }
        
        try {
            const pageId = window.visualPageId || currentPageId;
            
            // 获取样式代码
            const styleSelect = document.getElementById('style');
            let styleCode = styleSelect ? styleSelect.value : '';
            
            // 如果select没有值，尝试从全局变量获取
            if (!styleCode && typeof currentStyle !== 'undefined' && currentStyle) {
                styleCode = currentStyle;
            }
            
            // 如果还是没有值，尝试从页面数据获取
            if (!styleCode) {
                styleCode = '<?= $page && $page->getData('style') ? htmlspecialchars($page->getData('style')) : '' ?>';
            }
            
            if (!pageId || !styleCode) {
                showToast('error', '<?= __("导入失败") ?>', '<?= __("请先选择样式模板") ?>');
                event.target.value = '';
                return;
            }
            
            // 显示确认对话框
            const confirmed = confirm('<?= __("确认导入配置？此操作将更新当前页面的配置值，已存在的配置会被覆盖。") ?>');
            if (!confirmed) {
                event.target.value = '';
                return;
            }
            
            // 显示加载状态
            const importBtn = document.getElementById('importConfigBtn');
            const originalHtml = importBtn ? importBtn.innerHTML : '';
            if (importBtn) {
                importBtn.disabled = true;
                importBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __("导入中...") ?>';
            }
            
            // 创建FormData并上传文件
            const formData = new FormData();
            formData.append('config_file', file);
            formData.append('page_id', pageId);
            formData.append('style_code', styleCode);
            
            const url = '<?= $this->getBackendUrl("cms/backend/page/importConfig") ?>';
            const response = await fetch(url, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('success', '<?= __("导入成功") ?>', result.message || '<?= __("配置已成功导入") ?>');
                
                // 重新加载可视化配置以显示更新后的值
                if (typeof window.loadVisualStyleConfig === 'function') {
                    setTimeout(() => {
                        window.loadVisualStyleConfig();
                    }, 500);
                }
                
                // 刷新预览以显示更新后的配置效果
                if (typeof window.refreshVisualPreview === 'function') {
                    setTimeout(() => {
                        window.refreshVisualPreview();
                    }, 800);
                }
            } else {
                showToast('error', '<?= __("导入失败") ?>', result.message || '<?= __("未知错误") ?>');
            }
            
            // 恢复按钮状态
            if (importBtn) {
                importBtn.innerHTML = originalHtml;
                importBtn.disabled = false;
            }
            
            // 清空文件输入
            event.target.value = '';
        } catch (error) {
            console.error('导入配置失败:', error);
            showToast('error', '<?= __("导入失败") ?>', error.message || '<?= __("未知错误") ?>');
            
            // 恢复按钮状态
            const importBtn = document.getElementById('importConfigBtn');
            if (importBtn) {
                importBtn.disabled = false;
                importBtn.innerHTML = '<i class="mdi mdi-upload"></i> <?= __("导入配置") ?>';
            }
            
            // 清空文件输入
            event.target.value = '';
        }
    }
});
</script>

