// 保存当前预览URL，用于刷新
let currentPreviewUrl = '';
let currentPreviewDevice = 'desktop';

/**
 * 切换预览设备
 * @param {string} device - 设备类型: mobile, tablet, desktop
 */
function switchPreviewDevice(device) {
    console.log('📱 切换设备预览:', device);
    
    const modalBody = document.getElementById('previewModalBody');
    const deviceButtons = document.querySelectorAll('.device-button');
    
    // 更新按钮状态
    deviceButtons.forEach(btn => {
        if (btn.dataset.device === device) {
            btn.classList.add('active');
        } else {
            btn.classList.remove('active');
        }
    });
    
    // 更新modalBody的设备类
    modalBody.className = 'style-preview-modal-body device-' + device;
    currentPreviewDevice = device;
}

/**
 * 刷新样式预览
 */
function refreshStylePreview() {
    console.log('🔄 刷新预览');
    
    const modalBody = document.getElementById('previewModalBody');
    const iframe = modalBody.querySelector('iframe');
    
    if (iframe && currentPreviewUrl) {
        // 显示加载状态
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'style-preview-loading';
        loadingDiv.innerHTML = `
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2">正在刷新预览...</div>
        `;
        loadingDiv.style.display = 'flex';
        modalBody.insertBefore(loadingDiv, iframe);
        
        // 重新加载iframe
        iframe.src = currentPreviewUrl + '&_refresh=' + Date.now();
        iframe.onload = function() {
            loadingDiv.style.display = 'none';
        };
    }
}
/**
 * 关闭样式预览模态框
 */
function closeStylePreviewModal() {
    const modal = document.getElementById('stylePreviewModal');
    modal.classList.remove('active');
    
    // 恢复body滚动
    document.body.style.overflow = '';
    
    // 清空内容（移除iframe）
    setTimeout(() => {
        const modalBody = document.getElementById('previewModalBody');
        modalBody.innerHTML = '';
        modalBody.className = 'style-preview-modal-body device-desktop';
        currentPreviewUrl = '';
        currentPreviewDevice = 'desktop';
        
        // 重置设备按钮状态
        const deviceButtons = document.querySelectorAll('.device-button');
        deviceButtons.forEach(btn => {
            if (btn.dataset.device === 'desktop') {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
    }, 300);
}

// 点击模态框背景关闭
document.addEventListener('click', function(e) {
    const modal = document.getElementById('stylePreviewModal');
    if (e.target === modal) {
        closeStylePreviewModal();
    }
});

// ESC键关闭模态框
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('stylePreviewModal');
        if (modal && modal.classList.contains('active')) {
            closeStylePreviewModal();
        }
    }
});

/**
 * 截取iframe内容并转换为canvas预览
 * 
 * @param {string} iframeId - iframe元素ID
 * @param {string} canvasId - canvas元素ID
 * @param {string} previewId - 预览容器ID
 */
async function captureIframePreview(iframeId, canvasId, previewId) {
    console.log('🎬 开始截取预览:', iframeId);
    
    const iframe = document.getElementById(iframeId);
    const canvas = document.getElementById(canvasId);
    const previewContainer = document.getElementById(previewId);
    const loadingEl = previewContainer ? previewContainer.querySelector('.style-card-preview-loading') : null;
    
    if (!iframe || !canvas || !previewContainer) {
        console.error('❌ 截图失败：找不到必要的DOM元素');
        if (loadingEl) {
            loadingEl.innerHTML = '<div class="text-danger small">预览生成失败</div>';
        }
        return;
    }
    
    try {
        // 等待iframe完全加载
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        const iframeBody = iframeDoc.body;
        
        if (!iframeBody) {
            throw new Error('无法访问iframe内容');
        }
        
        console.log('📸 开始使用html2canvas截图...');
        
        // 使用html2canvas截取iframe内容
        const screenshotCanvas = await html2canvas(iframeBody, {
            allowTaint: true,
            useCORS: true,
            scale: 0.25, // 降低分辨率以提高性能
            width: 1200,
            height: 800,
            logging: false,
            removeContainer: false
        });
        
        // 将截图绘制到目标canvas（调整尺寸以适应卡片）
        const ctx = canvas.getContext('2d');
        canvas.width = 400; // 卡片宽度
        canvas.height = 200; // 卡片高度
        
        // 计算缩放比例（保持宽高比）
        const scale = Math.min(canvas.width / screenshotCanvas.width, canvas.height / screenshotCanvas.height);
        const x = (canvas.width / 2) - (screenshotCanvas.width / 2) * scale;
        const y = (canvas.height / 2) - (screenshotCanvas.height / 2) * scale;
        
        ctx.drawImage(screenshotCanvas, x, y, screenshotCanvas.width * scale, screenshotCanvas.height * scale);
        
        // 显示canvas，隐藏加载状态
        canvas.style.display = 'block';
        if (loadingEl) {
            loadingEl.style.display = 'none';
        }
        
        // 移除iframe（已经不需要了）
        setTimeout(() => {
            if (iframe.parentElement) {
                iframe.remove();
            }
        }, 100);
        
        console.log('✅ 预览截图成功');
        
    } catch (error) {
        console.error('❌ 截图失败:', error);
        
        // 显示错误提示
        if (loadingEl) {
            loadingEl.innerHTML = `
                <div class="style-card-preview-placeholder">
                    <i class="mdi mdi-alert-circle"></i>
                    <div style="font-size: 12px; margin-top: 5px;">预览生成失败</div>
                    <div style="font-size: 11px; color: #999; margin-top: 3px;">点击卡片可选择此样式</div>
                </div>
            `;
        }
        
        // 移除iframe
        if (iframe.parentElement) {
            iframe.remove();
        }
    }
}

/**
 * 搜索过滤样式
 */
function filterStyles(searchTerm) {
    const term = searchTerm.toLowerCase().trim();
    
    if (!term) {
        // 如果搜索框为空，显示所有样式
        renderStyleCards(allStyles, document.getElementById('style').value, '<?= $page ? $page->getId() : '' ?>');
        return;
    }
    
    // 过滤样式：匹配名称、描述或代码
    const filtered = allStyles.filter(style => {
        const name = (style.name || '').toLowerCase();
        const description = (style.description || '').toLowerCase();
        const code = (style.code || '').toLowerCase();
        return name.includes(term) || description.includes(term) || code.includes(term);
    });
    
    // 渲染过滤后的结果
    renderStyleCards(filtered, document.getElementById('style').value, '<?= $page ? $page->getId() : '' ?>');
}

