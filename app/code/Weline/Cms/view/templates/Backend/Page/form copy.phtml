    // 加载样式配置（暴露到全局作用域供其他函数使用）
    window.loadVisualStyleConfig = async function() {
        try {
            // 优先从隐藏的select获取样式代码
            const styleSelect = document.getElementById('style');
            let styleCode = styleSelect ? styleSelect.value : '';
            
            // 如果select没有值，尝试从全局变量获取
            if (!styleCode && typeof currentStyle !== 'undefined' && currentStyle) {
                styleCode = currentStyle;
            }
            
            // 如果还是没有值，尝试从页面数据获取
            if (!styleCode) {
                styleCode = '<?= $page && $page->getData('style') ? htmlspecialchars($page->getData('style')) : '' ?>';
            }
            
            if (!styleCode) {
                console.error('样式代码为空，无法加载配置');
                document.getElementById('visualConfigFields').innerHTML = 
                    '<div class="alert alert-warning m-3"><?= __('请先选择样式模板') ?></div>';
                return;
            }
            
            // 构建URL，包含 page_id 和 locale 参数
            let url = '<?= $this->getBackendUrl('cms/backend/page/getStyleConfig') ?>?style_code=' + styleCode;
            if (visualPageId) {
                url += '&page_id=' + visualPageId;
            }
            if (currentVisualLanguage) {
                url += '&locale=' + currentVisualLanguage;
            }
            
            console.log('🔄 正在加载样式配置:', {
                styleCode: styleCode,
                pageId: visualPageId,
                locale: currentVisualLanguage,
                url: url
            });
            
            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            
            console.log('API响应状态:', response.status);
            
            const result = await response.json();
            console.log('📦 API返回结果:', result);
            
            // 显示调试信息
            if (result.debug) {
                console.log('🐛 调试信息:', result.debug);
                console.log('📊 数据结构:', {
                    'all_settings': result.debug.all_settings_structure,
                    'style_settings': result.debug.style_settings_structure,
                    'page_settings_keys': result.debug.page_settings ? Object.keys(result.debug.page_settings) : []
                });
            }
            
            if (result.success && result.data) {
                visualConfigGroups = result.data;
                console.log('配置分组数量:', Object.keys(visualConfigGroups).length);
                renderVisualConfig(visualConfigGroups);
            } else {
                console.error('配置加载失败:', result);
                document.getElementById('visualConfigFields').innerHTML = 
                    '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?>: ' + (result.message || '未知错误') + '</div>';
            }
        } catch (error) {
            console.error('加载配置异常:', error);
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-danger m-3"><?= __('加载配置失败') ?>: ' + error.message + '</div>';
        }
    }
    
    // 为 IIFE 内部创建局部引用（保持兼容性）
    const loadVisualStyleConfig = window.loadVisualStyleConfig;

    // 检测页面是否有自定义内容
    const hasCustomContent = <?= ($isEdit && $page && !empty($page->getData('content'))) ? 'true' : 'false' ?>;
    // 渲染配置表单（支持两级分组：文件 -> 分组）
    function renderVisualConfig(configGroups) {
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log('🎨 开始渲染可视化配置表单');
        console.log('当前语言:', currentVisualLanguage);
        console.log('配置文件数量:', Object.keys(configGroups || {}).length);
        console.log('📝 页面是否有自定义内容:', hasCustomContent);
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        
        // 验证数据
        if (!configGroups || typeof configGroups !== 'object') {
            console.error('❌ 配置分组数据无效:', configGroups);
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-danger m-3"><?= __('配置数据格式错误') ?></div>';
            return;
        }
        
        let html = '';
        let configCount = 0;
        
        // 遍历文件级别（header, content, footer）
        for (const fileKey in configGroups) {
            const fileGroup = configGroups[fileKey];
            
            // 跳过没有分组的文件
            if (!fileGroup || !fileGroup.groups || Object.keys(fileGroup.groups).length === 0) {
                console.log('跳过空文件分组:', fileKey);
                continue;
            }
            
            const fileIcon = fileGroup.icon || 'mdi-file';
            
            // 检测是否为 content 文件且有自定义内容
            const isContentFile = fileKey === 'content';
            const isDisabled = hasCustomContent && isContentFile;
            
            // 文件级别的大区块（一级折叠）
            // 如果是content且有自定义内容，则默认收起并添加灰色样式
            html += `
                <div class="config-file-section config-section ${isDisabled ? 'collapsed has-custom-content' : ''}" id="visual_${fileKey}_file">
                    <div class="config-section-header ${isDisabled ? 'bg-secondary text-white-50' : 'bg-primary text-white'}" 
                         onclick="toggleSection('visual_${fileKey}_file')">
                        <div class="d-flex justify-content-between align-items-center w-100">
                            <span><i class="mdi ${fileIcon}"></i> ${fileGroup.label || fileKey}`;
            
            // 如果有自定义内容，显示警告徽章
            if (isDisabled) {
                html += ` <span class="badge bg-warning text-dark ms-2" style="font-size: 0.8rem;">
                            <i class="mdi mdi-alert"></i> <?= __('已使用自定义内容') ?>
                          </span>`;
            }
            
            html += `</span>
                            <div class="d-flex align-items-center" style="gap: 0.5rem;">
                                <a href="javascript:void(0)" 
                                   class="text-warning" 
                                   onclick="event.stopPropagation(); resetVisualConfigFile('visual_${fileKey}_file')"
                                   title="<?= __('恢复此部件所有字段为默认值') ?>"
                                   style="font-size: 1.1rem; line-height: 1;">
                                    <i class="mdi mdi-restore"></i>
                                </a>
                                <i class="mdi mdi-chevron-down" style="font-size: 1.2rem;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="config-section-body">`;
            
            // 如果是content且有自定义内容，显示醒目提示
            if (isDisabled) {
                html += `
                    <div class="alert alert-warning m-3" role="alert">
                        <h6 class="alert-heading">
                            <i class="mdi mdi-alert-circle-outline"></i> <?= __('此区域配置已被自定义内容覆盖') ?>
                        </h6>
                        <p class="mb-2">
                            <?= __('您已在"内容配置"中填写了自定义页面内容，该内容将替代此处的样式模板配置。') ?>
                        </p>
                        <p class="mb-0 small text-muted">
                            <i class="mdi mdi-information-outline"></i> 
                            <?= __('如果您想使用此处的样式模板配置，请清空"内容配置"中的自定义内容。') ?>
                        </p>
                    </div>
                `;
            }
            
            // 遍历该文件下的分组（layout, style, size等）
            for (const groupKey in fileGroup.groups) {
                const group = fileGroup.groups[groupKey];
                
                if (!group || !group.configs || Object.keys(group.configs).length === 0) {
                    console.log('跳过空分组:', groupKey);
                    continue;
                }
                
                configCount++;
                const icon = group.icon || 'mdi-cog';
                
                // 分组级别的二级折叠（默认收起）
                // 使用 fileKey + groupKey 确保ID唯一性
                html += `
                    <div class="config-section collapsed ms-3" id="visual_${fileKey}_${groupKey}_config">
                        <div class="config-section-header bg-light" onclick="toggleSection('visual_${fileKey}_${groupKey}_config')">
                            <div class="d-flex justify-content-between align-items-center w-100">
                                <span><i class="mdi ${icon}"></i> ${group.label || groupKey}`;
                
                // 如果分组有标记（如 MD, MTD），显示响应式徽章
                if (group.tag) {
                    let tagIcons = '';
                    if (group.tag.includes('M')) tagIcons += '<i class="mdi mdi-cellphone" style="font-size: 0.85rem;"></i> ';
                    if (group.tag.includes('T')) tagIcons += '<i class="mdi mdi-tablet" style="font-size: 0.85rem;"></i> ';
                    if (group.tag.includes('D')) tagIcons += '<i class="mdi mdi-monitor" style="font-size: 0.85rem;"></i> ';
                    
                    html += ` <span class="badge bg-info ms-2" style="font-size: 0.65rem; vertical-align: middle;">
                                ${tagIcons}
                             </span>`;
                }
                
                html += `</span>
                                <div class="d-flex align-items-center" style="gap: 0.5rem;">
                                    <a href="javascript:void(0)" 
                                       class="link-warning" 
                                       onclick="event.stopPropagation(); resetVisualConfigGroup('visual_${fileKey}_${groupKey}_config')"
                                       title="<?= __('恢复此组所有字段为默认值') ?>"
                                       style="font-size: 0.95rem; line-height: 1;">
                                        <i class="mdi mdi-restore"></i>
                                    </a>
                                    <i class="mdi mdi-chevron-down" style="font-size: 1rem;"></i>
                                </div>
                            </div>
                        </div>
                        <div class="config-section-body">
                `;
                
                // 如果有说明信息，直接显示（不折叠）
                if (group.help_title || group.help_content) {
                    // 处理帮助内容：保留换行符并转义HTML
                    let helpContentText = group.help_content || '';
                    helpContentText = escapeHtml(helpContentText);
                    
                    html += `
                        <div class="alert alert-info mb-3" role="alert">
                            <h6 class="alert-heading mb-2">
                                <i class="mdi mdi-information-outline"></i> ${escapeHtml(group.help_title || '说明')}
                            </h6>
                            <div class="help-content-static">
                                ${helpContentText}
                            </div>
                        </div>`;
                }
                
                for (const configKey in group.configs) {
                    const config = group.configs[configKey];
                    // 优先使用 config.value（后端已合并的值），否则使用 config.default
                    const rawValue = config.value !== undefined ? config.value : (config.default || '');
                    const currentValue = escapeHtml(rawValue); // 转义 HTML 特殊字符
                    const fieldId = `visual_config_${configKey.replace(/\./g, '_')}`;
                    
                    // 调试日志：显示配置值
                    if (config.value !== undefined) {
                        console.log(`✅ [${currentVisualLanguage}] ${configKey}: "${config.value}" (来自页面配置)`);
                    } else if (config.default) {
                        console.log(`⚪ [${currentVisualLanguage}] ${configKey}: "${config.default}" (使用模板默认值)`);
                    } else {
                        console.log(`❌ [${currentVisualLanguage}] ${configKey}: 无值`);
                    }
                    
                    html += `<div class="mb-3">`;
                    
                    // 渲染标签和响应式徽章
                    html += `<label for="${fieldId}" class="form-label">${escapeHtml(config.label)}`;
                    
                    // 添加响应式标记图标
                    if (config.responsive) {
                        html += ` <span class="badge bg-info ms-1" 
                                        title="支持响应式配置（移动端/平板/PC端）" 
                                        style="font-size: 0.75rem; vertical-align: middle;">
                                    <i class="mdi mdi-cellphone" style="font-size: 0.85rem;"></i>
                                    <i class="mdi mdi-tablet" style="font-size: 0.85rem;"></i>
                                    <i class="mdi mdi-monitor" style="font-size: 0.85rem;"></i>
                                 </span>`;
                    }
                    
                    // 添加翻译按钮（仅在编辑模式下且不是颜色选择器）
                    if (visualPageId && visualPageId !== 'null' && config.type !== 'color' && config.type !== 'select') {
                        html += ` <a href="javascript:void(0)" 
                                     class="link-info ms-1" 
                                     onclick="openVisualConfigTranslation('${configKey}', '${escapeHtml(config.label)}', '${escapeHtml(rawValue)}')"
                                     title="<?= __('翻译此配置项') ?>">
                                    <i class="mdi mdi-translate"></i>
                                 </a>`;
                    }
                    
                    // 添加恢复默认按钮
                    const escapedDefault = escapeHtml(config.default || '');
                    html += ` <a href="javascript:void(0)" 
                                 class="link-warning ms-1 visual-config-reset-btn" 
                                 data-field-id="${fieldId}"
                                 data-config-key="${configKey}"
                                 data-config-type="${config.type}"
                                 data-default-value="${escapedDefault}"
                                 onclick="resetVisualConfigField(this)"
                                 title="<?= __('恢复默认值') ?>">
                                <i class="mdi mdi-restore"></i>
                             </a>`;
                    
                    html += `</label>`;
                    
                    // 添加描述信息
                    if (config.description) {
                        html += `<div class="form-text text-muted mb-2" 
                                      style="margin-top: -8px; font-size: 0.85rem;">
                                    <i class="mdi mdi-information-outline"></i> 
                                    ${escapeHtml(config.description)}
                                 </div>`;
                    }
                    
                    switch (config.type) {
                        case 'color':
                            // 处理颜色值：如果是 transparent 或空值，使用 #ffffff 作为默认显示
                            let colorValue = currentValue;
                            let displayValue = currentValue;
                            if (!colorValue || colorValue === 'transparent' || colorValue === '') {
                                displayValue = '#ffffff';
                                colorValue = config.default || '';
                            }
                            // 确保颜色值是有效的hex格式（HTML color input要求）
                            if (!displayValue.startsWith('#')) {
                                displayValue = '#' + displayValue;
                            }
                            
                            html += `
                                <div class="input-group">
                                    <input type="color" 
                                           class="form-control form-control-color auto-save-field" 
                                           id="${fieldId}_picker"
                                           data-config-key="${configKey}"
                                           data-linked-input="${fieldId}_text"
                                           value="${displayValue}">
                                    <input type="text" 
                                           class="form-control auto-save-field" 
                                           id="${fieldId}_text"
                                           data-config-key="${configKey}"
                                           data-linked-picker="${fieldId}_picker"
                                           value="${escapeHtml(colorValue)}"
                                           placeholder="${escapeHtml(config.default || '')}"
                                           style="flex: 1;">
                                </div>
                            `;
                            break;
                            
                        case 'select':
                            html += `<select class="form-select auto-save-field" id="${fieldId}" data-config-key="${configKey}">`;
                            if (config.options && config.options.length > 0) {
                                config.options.forEach(opt => {
                                    const selected = opt === rawValue ? 'selected' : '';
                                    html += `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(opt)}</option>`;
                                });
                            }
                            html += `</select>`;
                            break;
                            
                        case 'responsive':
                            // 响应式配置：支持 60/80 或 60/70/80 格式，使用 text 输入框
                            html += `
                                <div class="input-group">
                                    <input type="text" 
                                           class="form-control auto-save-field" 
                                           id="${fieldId}"
                                           data-config-key="${configKey}"
                                           value="${currentValue}"
                                           placeholder="${escapeHtml(config.default || '')}"
                                           title="<?= __('支持单一值(如: 80)或多端值(如: 60/80 或 60/70/80)') ?>">
                                    ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit)}</span>` : ''}
                                </div>
                            `;
                            break;
                            
                        case 'number':
                            html += `
                                <div class="input-group">
                                    <input type="number" 
                                           class="form-control auto-save-field" 
                                           id="${fieldId}"
                                           data-config-key="${configKey}"
                                           value="${currentValue}"
                                           placeholder="${escapeHtml(config.default)}">
                                    ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit)}</span>` : ''}
                                </div>
                            `;
                            break;
                            
                        case 'textarea':
                            html += `
                                <textarea class="form-control auto-save-field" 
                                          id="${fieldId}"
                                          data-config-key="${configKey}"
                                          rows="3">${currentValue}</textarea>
                            `;
                            break;
                            
                        case 'text':
                        default:
                            // text 类型和其他类型，如果有单位则显示
                            html += `
                                <div class="input-group">
                                    <input type="text" 
                                           class="form-control auto-save-field" 
                                           id="${fieldId}"
                                           data-config-key="${configKey}"
                                           value="${currentValue}"
                                           placeholder="${escapeHtml(config.default || '')}">
                                    ${config.unit ? `<span class="input-group-text">${escapeHtml(config.unit)}</span>` : ''}
                                </div>
                            `;
                    }
                    
                    html += `</div>`;
                }
                
                // 关闭分组
                html += `
                        </div>
                    </div>
                `;
            }
            
            // 关闭文件分组
            html += `
                    </div>
                </div>
            `;
        }
        
        // 检查是否有配置
        if (configCount === 0) {
            console.warn('⚠️ 没有找到任何配置分组');
            document.getElementById('visualConfigFields').innerHTML = 
                '<div class="alert alert-warning m-3"><?= __('当前样式模板没有可配置项') ?></div>';
            return;
        }
        
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        console.log(`✅ 配置表单渲染完成`);
        console.log(`   - 语言: ${currentVisualLanguage}`);
        console.log(`   - 配置分组数: ${configCount}`);
        console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        document.getElementById('visualConfigFields').innerHTML = html;
        
        // 监听所有自动保存字段
        document.querySelectorAll('#visualConfigFields .auto-save-field').forEach(field => {
            // 颜色选择器和文本框的同步
            if (field.type === 'color') {
                field.addEventListener('input', function() {
                    const linkedInput = this.getAttribute('data-linked-input');
                    if (linkedInput) {
                        const textField = document.getElementById(linkedInput);
                        if (textField) {
                            textField.value = this.value;
                        }
                    }
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            } else if (field.type === 'text' && field.hasAttribute('data-linked-picker')) {
                field.addEventListener('input', function() {
                    const linkedPicker = this.getAttribute('data-linked-picker');
                    if (linkedPicker && this.value.startsWith('#')) {
                        const pickerField = document.getElementById(linkedPicker);
                        if (pickerField) {
                            pickerField.value = this.value;
                        }
                    }
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            } else {
                field.addEventListener('input', function() {
                    updateVisualSaveStatus('', '<?= __('未保存') ?>');
                    autoSaveVisualConfig();
                });
            }
            
            field.addEventListener('change', function() {
                updateVisualSaveStatus('', '<?= __('未保存') ?>');
                autoSaveVisualConfig();
            });
        });
        
        // 检查是否有重置标记，如果有则展开并定位到指定位置
        const resetTarget = localStorage.getItem('cms_reset_target');
        if (resetTarget) {
            try {
                const target = JSON.parse(resetTarget);
                console.log('📍 发现重置标记:', target);
                
                // 清除标记
                localStorage.removeItem('cms_reset_target');
                
                // 使用 setTimeout 确保 DOM 已完全渲染
                setTimeout(() => {
                    const targetElement = document.getElementById(target.id);
                    
                    if (targetElement) {
                        console.log('✅ 找到目标元素:', target.id, targetElement);
                        
                        // 如果是组级别，需要先展开父部件
                        if (target.type === 'group') {
                            const parentFile = targetElement.closest('.config-file-section, .config-section');
                            if (parentFile && parentFile.id !== target.id) {
                                console.log('📂 展开父部件:', parentFile.id);
                                if (parentFile.classList.contains('collapsed')) {
                                    parentFile.classList.remove('collapsed');
                                    
                                    const parentIcon = parentFile.querySelector('.config-section-header i.mdi');
                                    if (parentIcon) {
                                        parentIcon.classList.remove('mdi-chevron-right');
                                        parentIcon.classList.add('mdi-chevron-down');
                                        console.log('  ↪ 更新父图标');
                                    }
                                }
                            }
                        }
                        
                        // 展开目标元素（移除 collapsed 类）
                        if (targetElement.classList.contains('collapsed')) {
                            console.log('📂 展开目标元素:', target.id);
                            targetElement.classList.remove('collapsed');
                            
                            const icon = targetElement.querySelector('.config-section-header i.mdi');
                            if (icon) {
                                icon.classList.remove('mdi-chevron-right');
                                icon.classList.add('mdi-chevron-down');
                                console.log('  ↪ 更新目标图标');
                            }
                        }
                        
                        // 滚动到可见区域
                        setTimeout(() => {
                            targetElement.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                            console.log('📍 滚动到目标位置');
                        }, 50);
                        
                        // 添加临时高亮效果
                        setTimeout(() => {
                            targetElement.style.backgroundColor = '#fff3cd';
                            console.log('✨ 添加高亮效果');
                            
                            setTimeout(() => {
                                targetElement.style.transition = 'background-color 1s ease';
                                targetElement.style.backgroundColor = '';
                            }, 800);
                        }, 100);
                        
                        // 如果标记了需要刷新预览，则刷新
                        if (target.needRefreshPreview) {
                            setTimeout(() => {
                                if (typeof refreshStylePreview === 'function') {
                                    console.log('🔄 自动刷新预览（延迟执行）...');
                                    refreshStylePreview();
                                } else {
                                    console.warn('⚠️ refreshStylePreview 函数未定义');
                                }
                            }, 300);
                        }
                        
                        console.log('✅ 已定位到重置的', target.type === 'file' ? '部件' : '配置组', ':', target.id);
                    } else {
                        console.warn('⚠️ 未找到目标元素:', target.id);
                    }
                }, 200);
            } catch (e) {
                console.error('❌ 解析重置标记失败:', e);
                localStorage.removeItem('cms_reset_target');
            }
        }
        
    }

    // 键盘快捷键
    document.addEventListener('keydown', function(e) {
        // ESC 退出全屏
        if (e.key === 'Escape') {
            const wrapper = document.getElementById('visualConfigWrapper');
            if (wrapper.classList.contains('active')) {
                closeVisualConfig();
            }
        }
    });
    
    /**
     * 切换页面关系树的展开/收起状态
     */
    window.toggleVisualPageTree = function() {
        const treeBody = document.getElementById('visualPageTreeBody');
        const icon = document.getElementById('visualPageTreeIcon');
        const header = icon ? icon.parentElement : null;
        
        if (treeBody && icon && header) {
            if (treeBody.style.display === 'none') {
                // 展开
                treeBody.style.display = 'block';
                icon.classList.add('expanded');
                header.classList.add('has-body');
            } else {
                // 收起
                treeBody.style.display = 'none';
                icon.classList.remove('expanded');
                header.classList.remove('has-body');
            }
        }
    };
    
    /**
     * 初始化可视化编辑器中页面树的复制功能
     */
    window.initVisualPageTreeCopy = function() {
        // ==================== 点击 Handle 文本复制（可视化编辑器） ====================
        const visualHandles = document.querySelectorAll('.clickable-handle-visual');
        visualHandles.forEach(function(element) {
            // 移除旧的事件监听器（避免重复绑定）
            const newElement = element.cloneNode(true);
            element.parentNode.replaceChild(newElement, element);
            
            newElement.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const handle = this.getAttribute('data-handle');
                const pageName = this.getAttribute('data-page-name');
                const originalBg = this.style.backgroundColor || '#f8f9fa';
                const originalText = this.textContent;
                
                // 添加 / 前缀
                const handleWithSlash = '/' + handle;
                
                // 复制到剪贴板
                copyTextToClipboard(handleWithSlash, '<?= __("Handle 已复制") ?>', 
                    '<?= __("页面") ?>: ' + pageName + '<br><?= __("Handle") ?>: ' + handleWithSlash);
                
                // 视觉反馈
                this.style.backgroundColor = '#d4edda';
                this.style.color = '#155724';
                this.textContent = '✓ ' + handleWithSlash;
                setTimeout(() => {
                    this.style.backgroundColor = originalBg;
                    this.style.color = '';
                    this.textContent = originalText;
                }, 1500);
            });
        });
        
        // ==================== 点击链接文本复制（可视化编辑器） ====================
        const visualUrls = document.querySelectorAll('.clickable-url-visual');
        visualUrls.forEach(function(element) {
            // 移除旧的事件监听器（避免重复绑定）
            const newElement = element.cloneNode(true);
            element.parentNode.replaceChild(newElement, element);
            
            newElement.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const url = this.getAttribute('data-url');
                const pageName = this.getAttribute('data-page-name');
                const originalColor = this.style.color || '#6c757d';
                const originalContent = this.innerHTML;
                
                // 复制到剪贴板
                copyTextToClipboard(url, '<?= __("链接已复制") ?>', 
                    '<?= __("页面") ?>: ' + pageName + '<br><?= __("链接") ?>: ' + url);
                
                // 视觉反馈
                this.style.color = '#155724';
                this.style.fontWeight = 'bold';
                this.innerHTML = '<small>✓ 已复制</small>';
                setTimeout(() => {
                    this.style.color = originalColor;
                    this.style.fontWeight = '';
                    this.innerHTML = originalContent;
                }, 1500);
            });
        });
        
        console.log('✅ 可视化编辑器页面树复制功能已初始化');
    };
    
    /**
     * 复制文本到剪贴板（简化版）
     */
    function copyTextToClipboard(text, successTitle, successMessage) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text)
                .then(() => {
                    showVisualToast('success', successTitle, successMessage);
                })
                .catch(err => {
                    console.error('复制失败:', err);
                    fallbackCopyText(text, successTitle, successMessage);
                });
        } else {
            fallbackCopyText(text, successTitle, successMessage);
        }
    }
    
    /**
     * 降级复制方法
     */
    function fallbackCopyText(text, successTitle, successMessage) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        
        try {
            document.execCommand('copy');
            showVisualToast('success', successTitle, successMessage);
        } catch (err) {
            console.error('复制失败:', err);
            prompt('<?= __("请手动复制") ?>:', text);
        } finally {
            document.body.removeChild(textArea);
        }
    }
    
    /**
     * 显示 Toast 通知（可视化编辑器专用）
     */
    function showVisualToast(type, title, message) {
        const toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;top:80px;right:20px;background:#28a745;color:white;padding:12px 20px;border-radius:5px;box-shadow:0 4px 8px rgba(0,0,0,0.2);z-index:99999;max-width:350px;font-size:14px;';
        toast.innerHTML = '<strong>' + title + '</strong><br>' + (message || '');
        document.body.appendChild(toast);
        
        setTimeout(() => {
            toast.style.transition = 'opacity 0.3s';
            toast.style.opacity = '0';
            setTimeout(() => document.body.removeChild(toast), 300);
        }, 2000);
    }
})();

/**
 * 打开预览图模态框（查看大图）
 */
function openPreviewImageModal(imageSrc) {
    // 创建模态框HTML
    const modalHtml = `
        <div id="previewImageModal" style="
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
        " onclick="closePreviewImageModal()">
            <div style="
                max-width: 95%;
                max-height: 95%;
                position: relative;
            ">
                <img src="${imageSrc}" 
                     alt="<?= __('预览图') ?>" 
                     style="
                         max-width: 100%;
                         max-height: 95vh;
                         object-fit: contain;
                         border-radius: 8px;
                         box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
                     ">
                <button onclick="closePreviewImageModal()" 
                        style="
                            position: absolute;
                            top: -40px;
                            right: 0;
                            background: rgba(255, 255, 255, 0.9);
                            border: none;
                            border-radius: 50%;
                            width: 36px;
                            height: 36px;
                            font-size: 20px;
                            cursor: pointer;
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
                        ">
                    ×
                </button>
            </div>
        </div>
    `;
    
    // 添加到页面
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    
    // 禁止页面滚动
    document.body.style.overflow = 'hidden';
}

/**
 * 关闭预览图模态框
 */
function closePreviewImageModal() {
    const modal = document.getElementById('previewImageModal');
    if (modal) {
        modal.remove();
    }
    
