/**
 * ========================================
 * 自定义内容配置监听
 * ========================================
 */
document.addEventListener('DOMContentLoaded', function() {
    const customContentTextarea = document.getElementById('custom_content');
    const contentStatusAlert = document.getElementById('contentStatusAlert');
    const contentStatusText = document.getElementById('contentStatusText');
    const accordionButton = document.querySelector('#customContentHeading .accordion-button');
    
    if (!customContentTextarea) return;
    
    // 初始化：如果有内容，显示徽章
    function updateContentStatus() {
        const content = customContentTextarea.value.trim();
        const badge = accordionButton.querySelector('.badge');
        
        if (content) {
            // 有内容时更新徽章和状态
            badge.textContent = '<?= __('已自定义') ?>';
            badge.classList.remove('bg-info');
            badge.classList.add('bg-success');
            
            // 显示状态提示
            contentStatusAlert.classList.remove('d-none');
            const wordCount = content.length;
            contentStatusText.textContent = `<?= __('当前已填写 ') ?>${wordCount}<?= __(' 个字符。页面将使用此自定义内容替代 content.phtml 模板。') ?>`;
        } else {
            // 无内容时恢复默认
            badge.textContent = '<?= __('我要自定义内容') ?>';
            badge.classList.remove('bg-success');
            badge.classList.add('bg-info');
            
            // 隐藏状态提示
            contentStatusAlert.classList.add('d-none');
        }
    }
    
    // 页面加载时检查初始状态
    updateContentStatus();
    
    // 监听内容变化
    customContentTextarea.addEventListener('input', updateContentStatus);
    customContentTextarea.addEventListener('change', updateContentStatus);
    
    // 监听折叠面板展开事件
    const customContentCollapse = document.getElementById('customContentCollapse');
    customContentCollapse.addEventListener('shown.bs.collapse', function() {
