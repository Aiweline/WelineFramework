<script>
// 可视化配置相关的JavaScript函数
(function() {
    // 全局变量（将关键变量暴露到全局作用域，供其他函数使用）
    window.visualPageId = <?= $visualPageId ? (int)$visualPageId : 'null' ?>;
    window.currentVisualLanguage = '<?= $pageDefaultLocale ?: '' ?>'; // 当前选择的语言
    window.defaultLanguage = '<?= $pageDefaultLocale ?: '' ?>'; // 页面默认语言
    let visualAutoSaveTimer = null;
    const VISUAL_AUTO_SAVE_DELAY = 1000; // 1秒
    let visualConfigGroups = null;
    
    // 为 IIFE 内部创建局部引用（保持代码兼容性）
    let currentVisualLanguage = window.currentVisualLanguage;
    const defaultLanguage = window.defaultLanguage;
    
    // 批量操作标志：在批量操作期间禁用自动保存
    window.isBatchResetting = false;
    
    // 调试信息
    console.log('📋 可视化配置初始化', {
        visualPageId: visualPageId,
        pageIdType: typeof visualPageId,
        pageIdValid: visualPageId > 0,
        currentLanguage: currentVisualLanguage,
        defaultLanguage: defaultLanguage
    });

    // 打开可视化配置
    window.openVisualConfig = function() {
        document.getElementById('visualConfigWrapper').classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // 始终重新加载配置以确保获取最新的语言配置
        loadVisualStyleConfig();
        
        // 初始化页面树的复制功能
        initVisualPageTreeCopy();
    };

    // 文件管理器实现由组件 Backend/Page/form_component/asset_manager.phtml 提供

    // 关闭可视化配置
    window.closeVisualConfig = function() {
        document.getElementById('visualConfigWrapper').classList.remove('active');
        document.body.style.overflow = '';
    };

    // 复制页面URL
    window.copyPageUrl = function() {
        const urlInput = document.getElementById('pageUrlDisplay');
        if (!urlInput) return;
        
        // 选择文本
        urlInput.select();
        urlInput.setSelectionRange(0, 99999); // 兼容移动设备
        
        // 复制到剪贴板
        try {
            document.execCommand('copy');
            
            // 显示成功提示
            const btn = event.target.closest('button');
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<i class="mdi mdi-check"></i> <?= __('已复制') ?>';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-success');
            
            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-primary');
            }, 2000);
            
            console.log('✅ 页面地址已复制:', urlInput.value);
        } catch (err) {
            console.error('❌ 复制失败:', err);
            alert('<?= __('复制失败，请手动复制') ?>');
        }
    };
    
    // 打开页面URL
    window.openPageUrl = function() {
        const urlInput = document.getElementById('pageUrlDisplay');
        if (!urlInput || !urlInput.value) return;
        
        // 在新窗口打开
        window.open(urlInput.value, '_blank');
        console.log('🌐 打开页面:', urlInput.value);
    };
    
    // 打开前端在线预览
    window.openFrontendPreview = function() {
        const handleInput = document.getElementById('handle');
        const handle = handleInput ? handleInput.value.trim() : '';
        
        if (!handle) {
            alert('<?= __('页面句柄不能为空，无法预览') ?>');
            return;
        }
        
        // 使用友好的重写URL格式：/handle?preview=1（不带语言、货币等参数）
        const baseUrl = '<?= rtrim(rtrim($this->request->getBaseHost(), '/'), ':') ?>';
        const previewUrl = baseUrl + '/' + handle + '?preview=1';
        
        // 在新窗口打开前端预览
        window.open(previewUrl, '_blank');
        
        console.log('🌐 打开前端预览:', previewUrl);
    };

    // 打开 PageSpeed Insights（手机端）- 使用当前页面的预览地址 (?preview=1)
    window.openPageSpeedMobile = function(){
        const handleInput = document.getElementById('handle');
        const handle = handleInput ? handleInput.value.trim() : '';
        if (!handle){
            alert('<?= __('页面句柄不能为空，无法测试 PageSpeed') ?>');
            return;
        }
        const baseUrl = '<?= rtrim(rtrim($this->request->getBaseHost(), '/'), ':') ?>';
        // 本地环境不启用
        try {
            const u = new URL(baseUrl);
            const h = u.hostname || '';
            const isPrivate = (
                h === 'localhost' || h === '127.0.0.1' || h === '::1' ||
                /\.local$/i.test(h) || /^10\./.test(h) || /^192\.168\./.test(h) || /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(h)
            );
            if (isPrivate) {
                const btn = document.getElementById('psiMobileBtn');
                if (btn) {
                    btn.disabled = true;
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-secondary');
                    btn.title = '<?= __('本地或内网地址无法使用 PageSpeed，请部署到公网或提供可访问 URL') ?>';
                }
                return;
            }
        } catch(_) {}
        const previewUrl = baseUrl + '/' + handle + '?preview=1';
        // 使用官方 analysis 接口并传入 url 参数，默认手机端
        const psiUrl = 'https://pagespeed.web.dev/analysis?url=' + encodeURIComponent(previewUrl) + '&form_factor=mobile';
        window.open(psiUrl, '_blank', 'noopener');
    };

    // 初始化时根据 base-url 禁用按钮（避免首次点击才反馈）
    (function(){
        const btn = document.getElementById('psiMobileBtn');
        if (!btn) return;
        const baseUrl = btn.getAttribute('data-base-url') || '';
        try {
            const u = new URL(baseUrl);
            const h = u.hostname || '';
            const isPrivate = (
                h === 'localhost' || h === '127.0.0.1' || h === '::1' ||
                /\.local$/i.test(h) || /^10\./.test(h) || /^192\.168\./.test(h) || /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(h)
            );
            if (isPrivate) {
                btn.disabled = true;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-secondary');
                btn.title = '<?= __('本地或内网地址无法使用 PageSpeed，请部署到公网或提供可访问 URL') ?>';
            }
        } catch(_) {}
    })();

    // 打开可视化配置项翻译
    window.openVisualConfigTranslation = function(configKey, configLabel, currentValue) {
        if (!visualPageId || visualPageId === 'null') {
            alert('<?= __('只有在编辑模式下才能翻译配置项') ?>');
            return;
        }
        
        // 转义特殊字符
        currentValue = (currentValue || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
        
        // 生成唯一ID
        const translationId = `visual-config-translation-${configKey.replace(/\./g, '-')}`;
        
        // 检查是否已存在翻译界面
        let existingOffcanvas = document.getElementById(translationId);
        if (!existingOffcanvas) {
            // 构建翻译界面的 URL
            const translationUrl = '<?= $this->getBackendUrl('i18n/backend/taglib/local') ?>' +
                '?model=' + encodeURIComponent('Weline\\Cms\\Model\\Page\\LocalDescription') +
                '&field=' + encodeURIComponent('config.' + configKey) +
                '&id=' + visualPageId +
                '&value=' + encodeURIComponent(currentValue);
            
            console.log('🌐 打开可视化配置翻译界面:', translationUrl);
            
            // 创建 Offcanvas HTML
            const offcanvasHtml = `
                <div class="offcanvas offcanvas-end w-75 h-100" tabindex="-1" id="${translationId}" 
                     aria-labelledby="${translationId}Label">
                    <div class="offcanvas-header">
                        <h5 id="${translationId}Label">
                            <?= __('翻译配置项') ?>: ${configLabel}
                        </h5>
                        <div class="d-flex gap-2 ms-auto">
                            <button id="${translationId}SubmitBtn" type="button" class="btn btn-primary btn-sm">
                                <i class="mdi mdi-content-save me-1"></i><?= __('保存') ?>
                            </button>
                            <a id="${translationId}RefreshBtn" class="btn btn-info btn-sm" href="javascript:void(0)">
                                <i class="mdi mdi-refresh me-1"></i><?= __('刷新') ?>
                            </a>
                            <button type="button" class="btn-close btn-sm" data-bs-dismiss="offcanvas"
                                    aria-label="<?= __('关闭') ?>"></button>
                        </div>
                    </div>
                    <div class="offcanvas-body">
                        <div class="position-relative w-100 h-100">
                            <iframe id="${translationId}Iframe" class="w-100 h-100"
                                    data-src="${translationUrl}"
                                    frameborder="0"></iframe>
                        </div>
                    </div>
                </div>
            `;
            
            // 添加到页面
            document.body.insertAdjacentHTML('beforeend', offcanvasHtml);
            existingOffcanvas = document.getElementById(translationId);
            
            // 绑定事件
            const iframe = document.getElementById(`${translationId}Iframe`);
            const submitBtn = document.getElementById(`${translationId}SubmitBtn`);
            const refreshBtn = document.getElementById(`${translationId}RefreshBtn`);
            
            // 显示时加载 iframe
            existingOffcanvas.addEventListener('show.bs.offcanvas', function() {
                if (!iframe.src) {
                    iframe.src = iframe.getAttribute('data-src');
                }
            });
            
            // 刷新按钮
            refreshBtn.addEventListener('click', function() {
                iframe.src = iframe.getAttribute('data-src');
            });
            
            // 提交按钮
            submitBtn.addEventListener('click', function() {
                const iframeDoc = iframe.contentWindow?.document;
                if (!iframeDoc) {
                    console.error('❌ 无法访问 iframe 文档');
                    return;
                }
                
                const form = iframeDoc.querySelector('form');
                if (form) {
                    form.submit();
                    console.log('✅ 翻译表单已提交');
                } else {
                    console.error('❌ 未找到翻译表单');
                }
            });
        }
        
        // 显示 Offcanvas
        const offcanvas = new bootstrap.Offcanvas(existingOffcanvas);
        offcanvas.show();
    };

