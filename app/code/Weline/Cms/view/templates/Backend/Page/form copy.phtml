                console.log(`✅ 已收集 ${configKeys.length} 个配置键:`, configKeys);
                
                // 调用后端接口重置为默认值
                updateVisualSaveStatus('saving', '<?= __('重置中...') ?>');
                
                const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
                const requestData = {
                    page_id: visualPageId,
                    style_code: styleCode,
                    config_keys: configKeys,
                    locale: currentVisualLanguage || defaultLanguage
                };
                
                const response = await fetch('<?= $this->getBackendUrl('cms/backend/preview/resetFieldsToDefault') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(requestData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    console.log('✅ 重置成功，重新加载配置...');
                    
                    // 标记需要展开和定位的组（使用 localStorage）
                    localStorage.setItem('cms_reset_target', JSON.stringify({
                        type: 'group',
                        id: groupId,
                        timestamp: Date.now(),
                        needRefreshPreview: true  // 标记需要刷新预览
                    }));
                    
                    // 重新加载配置（从模板中提取默认值）
                    await loadVisualStyleConfig();
                    
                    updateVisualSaveStatus('saved', '<?= __('已重置') ?>');
                    showToast('success', '<?= __('成功') ?>', `<?= __('已恢复') ?> ${result.reset_count || configKeys.length} <?= __('个字段为默认值') ?>`);
                } else {
                    updateVisualSaveStatus('error', '<?= __('重置失败') ?>: ' + result.message);
                    console.error('❌ 重置失败:', result);
                    showToast('error', '<?= __('失败') ?>', result.message || '<?= __('重置失败') ?>');
                }
            } catch (error) {
                updateVisualSaveStatus('error', '<?= __('重置失败') ?>');
                console.error('❌ 重置操作异常:', error);
                showToast('error', '<?= __('错误') ?>', error.message || '<?= __('操作失败') ?>');
            }
        }
    );
}

/**
 * 通过AJAX加载样式列表
 * 实时扫描样式目录并渲染为卡片
 */
let allStyles = []; // 存储所有样式数据用于搜索

async function loadStyleList() {
    console.log('🚀 开始加载样式列表...');
    
    const styleSelect = document.getElementById('style');
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsLoading = document.getElementById('styleCardsLoading');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    if (!styleSelect || !styleCardsContainer) {
        console.error('❌ 未找到必要的DOM元素');
        return;
    }
    
    const currentStyle = '<?= $page ? htmlspecialchars((($page->getData('style') ?? '')) ?? '') : '' ?>';
    const currentPageId = '<?= $page ? $page->getId() : '' ?>';
    console.log('🎯 当前选择的样式:', currentStyle || '(无)');
    console.log('📄 当前页面ID:', currentPageId || '(新建)');
    
    try {
        // 显示加载状态
        styleCardsLoading.style.display = 'block';
        styleCardsEmpty.style.display = 'none';
        styleCardsContainer.innerHTML = '';
        
        // 构建请求 URL
        const apiUrl = '<?= $this->getBackendUrl('cms/backend/page/getStyles') ?>';
        console.log('📡 请求 URL:', apiUrl);
        
        // 发送AJAX请求
        const response = await fetch(apiUrl, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        });
        
        console.log('📥 收到响应:', response.status, response.statusText);
        
        // 检查响应状态
        if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ HTTP错误响应:', response.status, errorText);
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        // 解析JSON
        const result = await response.json();
        console.log('📦 解析响应数据:', result);
        
        if (result.success && result.data) {
            allStyles = result.data; // 保存到全局变量
            
            // 更新隐藏的select（用于表单提交）
            styleSelect.innerHTML = '<option value=""><?= __('请选择样式') ?></option>';
            result.data.forEach(style => {
                const option = document.createElement('option');
                option.value = style.code;
                option.textContent = style.name;
                if (currentStyle && style.code === currentStyle) {
                    option.selected = true;
                }
                styleSelect.appendChild(option);
            });
            
            // 渲染样式卡片
            renderStyleCards(result.data, currentStyle, currentPageId);
            
            // 启用可视化配置按钮
            const visualBtn = document.getElementById('openVisualConfigBtn');
            if (visualBtn && currentStyle) {
                visualBtn.disabled = false;
                console.log('✅ 可视化配置按钮已启用');
            }
            
            // 加载样式配置（如果有选中的样式）
            if (currentStyle) {
                console.log(`🔧 开始加载样式配置: ${currentStyle}`);
                loadStyleConfig(currentStyle);
            }
            
            console.log(`✅ 样式列表加载成功，共 ${result.count} 个样式`);
        } else {
            console.error('❌ 加载样式列表失败:', result);
            styleCardsEmpty.innerHTML = '<i class="mdi mdi-alert"></i> ' + (result.message || '加载失败，请刷新重试');
            styleCardsEmpty.style.display = 'block';
        }
    } catch (error) {
        console.error('❌ 加载样式列表异常:', error);
        console.error('错误堆栈:', error.stack);
        
        // 显示详细的错误信息
        const errorMessage = error.message || '未知错误';
        styleCardsEmpty.innerHTML = `
            <div class="alert alert-danger">
                <i class="mdi mdi-alert-circle"></i>
                <strong>加载失败</strong><br>
                <small>${errorMessage}</small><br>
                <button class="btn btn-sm btn-outline-danger mt-2" onclick="loadStyleList()">
                    <i class="mdi mdi-refresh"></i> 重试
                </button>
            </div>
        `;
        styleCardsEmpty.style.display = 'block';
    } finally {
        styleCardsLoading.style.display = 'none';
    }
}

/**
 * 渲染样式卡片
 */
function renderStyleCards(styles, currentStyle, currentPageId) {
    const styleCardsContainer = document.getElementById('styleCardsContainer');
    const styleCardsEmpty = document.getElementById('styleCardsEmpty');
    
    styleCardsContainer.innerHTML = '';
    
    if (!styles || styles.length === 0) {
        styleCardsEmpty.style.display = 'block';
        return;
    }
    
    styleCardsEmpty.style.display = 'none';
    
    const previewImageUrl = '<?= $this->getBackendUrl('cms/backend/page/stylePreviewImage') ?>';
    const previewFullUrl = '<?= $this->getBackendUrl('cms/backend/preview/full') ?>';
    
    styles.forEach(style => {
        const col = document.createElement('div');
        col.className = 'col';
        
        const isSelected = currentStyle && style.code === currentStyle;
        const hasPreviewImage = style.preview_image && style.preview_image.trim() !== '';
        
        const card = document.createElement('div');
        card.className = 'card style-card' + (isSelected ? ' selected' : '');
        card.dataset.styleCode = style.code;
        card.dataset.styleName = style.name;
        card.dataset.styleDescription = style.description || '';
        
        // 预览区域
        let previewHtml = '';
        let previewActionsHtml = '';
        
        if (hasPreviewImage) {
            // 有预览图，通过控制器获取图片
            const imageUrl = `${previewImageUrl}?code=${encodeURIComponent(style.code)}`;
            
            // 预览操作按钮：放大预览 + 真实预览 + 默认预览
            previewActionsHtml = currentPageId ? `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            ` : `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openImagePreview('${imageUrl}', '${style.name}')" 
                         title="放大预览图">
                        <i class="mdi mdi-magnify-plus"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview">
                    ${previewActionsHtml}
                    <img src="${imageUrl}" 
                         alt="${style.name}" 
                         onerror="this.parentElement.innerHTML='<div class=\\'style-card-preview-placeholder\\'><i class=\\'mdi mdi-image-broken\\'></i><div>图片加载失败</div></div>'">
                </div>
            `;
        } else if (currentPageId) {
            // 没有预览图但有页面ID，使用iframe实时预览并转换为canvas
            const iframeUrl = `${previewFullUrl}?page_id=${currentPageId}&style_code=${encodeURIComponent(style.code)}`;
            const canvasId = `style-preview-canvas-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            const iframeId = `style-preview-iframe-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            
            // 预览操作按钮：真实预览 + 默认预览
            previewActionsHtml = `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openRealPreview('${style.code}', '${style.name}', ${currentPageId})" 
                         title="真实页面预览">
                        <i class="mdi mdi-monitor"></i>
                    </div>
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview" id="preview-${style.code}">
                    ${previewActionsHtml}
                    <div class="style-card-preview-loading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <div style="margin-top: 10px; font-size: 12px;">正在生成预览...</div>
                    </div>
                    <canvas id="${canvasId}" style="display: none; width: 100%; height: 100%;"></canvas>
                    <iframe id="${iframeId}" 
                            src="${iframeUrl}" 
                            style="position: absolute; left: -9999px; width: 1200px; height: 800px; border: none;"
                            onload="captureIframePreview('${iframeId}', '${canvasId}', 'preview-${style.code}')">
                    </iframe>
                </div>
            `;
        } else {
            // 没有预览图也没有页面ID，使用默认模板预览生成实时预览
            const defaultPreviewUrl = '<?= $this->getBackendUrl('cms/backend/preview/stylePreview') ?>?style_code=' + encodeURIComponent(style.code);
            const canvasId = `style-preview-canvas-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            const iframeId = `style-preview-iframe-${style.code.replace(/[^a-zA-Z0-9]/g, '-')}`;
            
            // 预览操作按钮：默认预览
            previewActionsHtml = `
                <div class="style-card-preview-actions">
                    <div class="style-card-preview-btn" 
                         onclick="event.stopPropagation(); openDefaultPreview('${style.code}', '${style.name}')" 
                         title="默认模板预览">
                        <i class="mdi mdi-file-eye"></i>
                    </div>
                </div>
            `;
            
            previewHtml = `
                <div class="style-card-preview" id="preview-${style.code}">
                    ${previewActionsHtml}
                    <div class="style-card-preview-loading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <div style="margin-top: 10px; font-size: 12px;">正在生成默认预览...</div>
                    </div>
                    <canvas id="${canvasId}" style="display: none; width: 100%; height: 100%;"></canvas>
                    <iframe id="${iframeId}" 
                            src="${defaultPreviewUrl}" 
                            style="position: absolute; left: -9999px; width: 1200px; height: 800px; border: none;"
                            onload="captureIframePreview('${iframeId}', '${canvasId}', 'preview-${style.code}')">
                    </iframe>
                </div>
            `;
        }
        
        // 卡片内容
        card.innerHTML = `
            ${previewHtml}
            <div class="style-card-body">
                <div class="style-card-title">
                    <span>${style.name}</span>
                    <span class="style-card-selected-badge">
                        <i class="mdi mdi-check"></i> 已选择
                    </span>
                </div>
                ${style.description ? `<div class="style-card-description">${style.description}</div>` : ''}
                <div class="style-card-meta">
                    <span class="style-card-code">${style.code}</span>
                    ${hasPreviewImage ? '<i class="mdi mdi-image text-success" title="有预览图"></i>' : '<i class="mdi mdi-monitor text-muted" title="实时预览"></i>'}
                </div>
            </div>
        `;
        
        // 点击卡片选择样式
        card.addEventListener('click', () => selectStyle(style.code));
        
        col.appendChild(card);
        styleCardsContainer.appendChild(col);
    });
}

/**
 * 选择样式
 */
async function selectStyle(styleCode) {
    console.log('🎯 选择样式:', styleCode);
    
    const styleSelect = document.getElementById('style');
    const oldStyle = styleSelect.value;
    
    // 更新隐藏的select
    styleSelect.value = styleCode;
    
    // 更新卡片选中状态
    document.querySelectorAll('.style-card').forEach(card => {
        if (card.dataset.styleCode === styleCode) {
            card.classList.add('selected');
        } else {
            card.classList.remove('selected');
        }
    });
    
    // 启用可视化配置按钮
    const visualBtn = document.getElementById('openVisualConfigBtn');
    if (visualBtn) {
        visualBtn.disabled = false;
    }
    
    // 加载样式配置
    loadStyleConfig(styleCode);
    
    // 🚫 如果正在应用继承配置，跳过自动保存
    if (window.isApplyingInheritance) {
        console.log('🚫 正在应用继承配置，跳过样式自动保存');
        return;
    }
    
    // 如果是编辑模式，自动保存样式切换
    const pageId = '<?= $isEdit && $page ? $page->getId() : '' ?>';
    if (pageId && styleCode !== oldStyle) {
        await autoSaveStyleChange(styleCode);
    }
}

