            customContentTextarea.focus();
        }, 300);
    });
    
    customContentCollapse.addEventListener('hidden.bs.collapse', function() {
        console.log('ℹ️ 自定义内容配置面板已折叠');
    });
    
    console.log('✅ 自定义内容配置监听器初始化完成');
});
</script>

