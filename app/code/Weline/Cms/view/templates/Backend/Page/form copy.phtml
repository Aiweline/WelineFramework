/**
 * 恢复可视化配置字段为默认值
 * @param {Element} button - 恢复按钮元素
 * @param {boolean} skipSave - 是否跳过自动保存（用于批量操作）
 * @returns {Object} 返回字段配置信息（用于批量操作）
 */
function resetVisualConfigField(button, skipSave = false) {
    // 从按钮的data属性中读取信息
    const fieldId = button.getAttribute('data-field-id');
    const fieldType = button.getAttribute('data-config-type');
    const defaultValue = button.getAttribute('data-default-value');
    const configKey = button.getAttribute('data-config-key');
    
    console.log('🔄 恢复可视化配置默认值:', { fieldId, fieldType, defaultValue, skipSave });
    
    // 如果是批量操作，只返回配置信息，不修改DOM
    if (skipSave) {
        return {
            configKey: configKey,
            defaultValue: defaultValue || '',
            fieldId: fieldId
        };
    }
    
    // 单个字段操作：修改DOM并触发保存
    switch (fieldType) {
        case 'text':
        case 'number':
        case 'responsive':
        case 'textarea':
            const textField = document.getElementById(fieldId);
            if (textField) {
                textField.value = defaultValue || '';
                textField.dispatchEvent(new Event('change', { bubbles: true }));
            }
            break;
            
        case 'select':
            const selectField = document.getElementById(fieldId);
            if (selectField) {
                if (defaultValue) {
                    for (let i = 0; i < selectField.options.length; i++) {
                        if (selectField.options[i].value === defaultValue) {
                            selectField.selectedIndex = i;
                            break;
                        }
                    }
                } else {
                    selectField.selectedIndex = 0;
                }
                selectField.dispatchEvent(new Event('change', { bubbles: true }));
            }
            break;
            
        case 'color':
            const pickerField = document.getElementById(fieldId + '_picker');
            const textFieldColor = document.getElementById(fieldId + '_text');
            const resetValue = defaultValue || '#ffffff';
            
            if (pickerField) pickerField.value = resetValue;
            if (textFieldColor) {
                textFieldColor.value = resetValue;
                textFieldColor.dispatchEvent(new Event('change', { bubbles: true }));
            }
            break;
            
        default:
            console.warn('未知字段类型:', fieldType);
    }
    
    showToast('success', '<?= __('成功') ?>', '<?= __('已恢复为默认值') ?>');
    console.log('✅ 可视化配置字段已恢复默认值');
    
    // 刷新预览
    if (typeof refreshStylePreview === 'function') {
        console.log('🔄 自动刷新预览...');
        refreshStylePreview();
    }
}

/**
 * 恢复整个可视化部件（文件）的所有字段为默认值
 */
function resetVisualConfigFile(fileId) {
    console.log('🔄 恢复可视化部件默认值:', fileId);
    
    const fileElement = document.getElementById(fileId);
    if (!fileElement) {
        console.error('❌ 找不到部件:', fileId);
        return;
    }
    
    // 获取部件信息
    const fileLabel = fileElement.querySelector('.config-section-header span')?.textContent.trim() || '此部件';
    const resetButtons = fileElement.querySelectorAll('.visual-config-reset-btn');
    const groupCount = fileElement.querySelectorAll('.config-section.ms-3').length;
    
    // 显示确认模态框
    showResetConfigConfirmModal(
        '<?= __('确认恢复部件') ?>',
        `<?= __('确定要恢复') ?> "${fileLabel}" <?= __('下所有字段为默认值吗？') ?>`,
        `<i class="mdi mdi-alert"></i> <?= __('这将影响') ?> <strong>${groupCount}</strong> <?= __('个配置组，共') ?> <strong>${resetButtons.length}</strong> <?= __('个字段！修改将自动保存。') ?>`,
        async function() {
            try {
                // 收集需要重置的字段的 configKey
                const configKeys = [];
                
                resetButtons.forEach(button => {
                    try {
                        const configKey = button.getAttribute('data-config-key');
                        if (configKey) {
                            configKeys.push(configKey);
                        }
                    } catch (error) {
                        console.error('收集字段配置键失败:', error);
                    }
                });
                
                console.log(`✅ 已收集 ${configKeys.length} 个配置键:`, configKeys);
                
                // 调用后端接口重置为默认值
                updateVisualSaveStatus('saving', '<?= __('重置中...') ?>');
                
                const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
                const requestData = {
                    page_id: visualPageId,
                    style_code: styleCode,
                    config_keys: configKeys,
                    locale: currentVisualLanguage || defaultLanguage
                };
                
                const response = await fetch('<?= $this->getBackendUrl('cms/backend/preview/resetFieldsToDefault') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(requestData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    console.log('✅ 重置成功，重新加载配置...');
                    
                    // 标记需要展开和定位的部件（使用 localStorage）
                    localStorage.setItem('cms_reset_target', JSON.stringify({
                        type: 'file',
                        id: fileId,
                        timestamp: Date.now(),
                        needRefreshPreview: true  // 标记需要刷新预览
                    }));
                    
                    // 重新加载配置（从模板中提取默认值）
                    await loadVisualStyleConfig();
                    
                    updateVisualSaveStatus('saved', '<?= __('已重置') ?>');
                    showToast('success', '<?= __('成功') ?>', `<?= __('已恢复') ?> ${result.reset_count || configKeys.length} <?= __('个字段为默认值') ?>`);
                } else {
                    updateVisualSaveStatus('error', '<?= __('重置失败') ?>: ' + result.message);
                    console.error('❌ 重置失败:', result);
                    showToast('error', '<?= __('失败') ?>', result.message || '<?= __('重置失败') ?>');
                }
            } catch (error) {
                updateVisualSaveStatus('error', '<?= __('重置失败') ?>');
                console.error('❌ 重置操作异常:', error);
                showToast('error', '<?= __('错误') ?>', error.message || '<?= __('操作失败') ?>');
            }
        }
    );
}

