/**
 * 恢复配置字段为默认值
 */
function resetConfigField(button) {
    // 从按钮的data属性中读取信息
    const fieldId = button.getAttribute('data-field-id');
    const fieldType = button.getAttribute('data-config-type');
    const defaultValue = button.getAttribute('data-default-value');
    
    console.log('🔄 恢复默认值:', { fieldId, fieldType, defaultValue });
    
    const field = document.getElementById(fieldId);
    if (!field) {
        console.error('❌ 找不到字段:', fieldId);
        return;
    }
    
    // 根据字段类型进行不同的处理
    switch (fieldType) {
        case 'text':
        case 'number':
        case 'responsive':
        case 'textarea':
            // 文本类型：设置为默认值（如果为空则清空）
            field.value = defaultValue || '';
            break;
            
        case 'select':
            // 下拉框：设置为默认值或第一个选项
            if (defaultValue) {
                // 尝试找到并选择默认值
                for (let i = 0; i < field.options.length; i++) {
                    if (field.options[i].value === defaultValue) {
                        field.selectedIndex = i;
                        break;
                    }
                }
            } else {
                field.selectedIndex = 0;
            }
            break;
            
        case 'color':
            // 颜色选择器：找到同一输入组的两个输入框
            const inputGroup = field.closest('.input-group');
            if (inputGroup) {
                const colorInput = inputGroup.querySelector('input[type="color"]');
                const textInput = inputGroup.querySelector('input[type="text"]');
                const resetValue = defaultValue || '#ffffff';
                
                if (colorInput) colorInput.value = resetValue;
                if (textInput) textInput.value = resetValue;
            }
            break;
            
        default:
            // 其他类型：设置为默认值
            field.value = defaultValue || '';
    }
    
    // 主表单不触发change事件，避免导致表单重新渲染
    // 用户需要手动保存表单
    
    // 显示提示信息
    showToast('success', '<?= __('成功') ?>', '<?= __('已恢复为默认值') ?>');
    
    console.log('✅ 字段已恢复默认值');
    
    // 注意：主表单需要手动保存后才能在预览中看到效果
    // 这里刷新预览只是让预览保持最新状态（如果用户已经保存了其他修改）
    if (typeof refreshStylePreview === 'function') {
        console.log('🔄 提示刷新预览（需要保存后生效）...');
        // 可以选择不刷新，或者添加一个提示"请保存后查看效果"
        // refreshStylePreview();
    }
}

/**
 * 显示恢复默认值确认模态框
 */
function showResetConfigConfirmModal(title, message, details, onConfirm) {
    console.log('🔔 showResetConfigConfirmModal 被调用');
    console.log('  title:', title);
    console.log('  message:', message);
    
    // 检查 bootstrap 是否可用
    if (typeof bootstrap === 'undefined') {
        console.error('❌ Bootstrap 未加载！');
        alert('Bootstrap 未加载，无法显示确认对话框！');
        return;
    }
    
    const modalElement = document.getElementById('resetConfigConfirmModal');
    console.log('  modalElement:', modalElement);
    
    if (!modalElement) {
        console.error('❌ 找不到模态框元素！');
        alert('模态框初始化失败！');
        return;
    }
    
    let modal;
    try {
        modal = new bootstrap.Modal(modalElement);
        console.log('  modal 创建成功:', modal);
    } catch (error) {
        console.error('❌ 创建 modal 失败:', error);
        alert('模态框创建失败: ' + error.message);
        return;
    }
    
    const messageEl = document.getElementById('resetConfigMessage');
    const detailsEl = document.getElementById('resetConfigDetails');
    const confirmBtn = document.getElementById('confirmResetConfigBtn');
    
    console.log('  messageEl:', messageEl);
    console.log('  confirmBtn:', confirmBtn);
    
    // 设置内容
    messageEl.textContent = message;
    detailsEl.innerHTML = details;
    
    // 清除之前的事件监听器
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
    
    // 添加确认事件
    newConfirmBtn.addEventListener('click', function() {
        modal.hide();
        if (typeof onConfirm === 'function') {
            onConfirm();
        }
    });
    
    // 显示模态框
    console.log('  📤 调用 modal.show()...');
    modal.show();
    
    // 手动设置 backdrop 和 modal 的 z-index，并检查样式
    setTimeout(() => {
        const backdrop = document.querySelector('.modal-backdrop');
        if (backdrop) {
            backdrop.style.zIndex = '9998';
            console.log('  ✅ backdrop 已找到，设置 z-index: 9998');
            console.log('  backdrop 样式:', window.getComputedStyle(backdrop).cssText.substring(0, 200));
        } else {
            console.warn('  ⚠️ 未找到 backdrop');
        }
        
        modalElement.style.zIndex = '9999';
        modalElement.style.display = 'block';
        
        const computedStyle = window.getComputedStyle(modalElement);
        console.log('  ✅ modal 样式:');
        console.log('    - display:', computedStyle.display);
        console.log('    - opacity:', computedStyle.opacity);
        console.log('    - z-index:', computedStyle.zIndex);
        console.log('    - position:', computedStyle.position);
        console.log('    - visibility:', computedStyle.visibility);
        
        // 检查模态框是否在视口内
        const rect = modalElement.getBoundingClientRect();
        console.log('  📐 modal 位置:', {
            top: rect.top,
            left: rect.left,
            width: rect.width,
            height: rect.height,
            inViewport: rect.top >= 0 && rect.left >= 0 && rect.bottom <= window.innerHeight && rect.right <= window.innerWidth
        });
    }, 100);
}

