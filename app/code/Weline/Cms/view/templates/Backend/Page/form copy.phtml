    // 立即触发保存（用于批量操作）
    window.triggerVisualAutoSave = async function() {
        updateVisualSaveStatus('saving', '<?= __('保存中...') ?>');
        
        try {
            // 收集所有配置
            const config = {};
            document.querySelectorAll('#visualConfigFields .auto-save-field').forEach(field => {
                const key = field.getAttribute('data-config-key');
                config[key] = field.value;
            });
            
            // 准备请求数据（包含样式代码和语言参数）
            const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
            const requestData = {
                page_id: visualPageId,
                style_code: styleCode,
                style_config: config,
                locale: currentVisualLanguage || defaultLanguage
            };
            
            console.log('💾 批量保存配置', {
                url: '<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>',
                configKeys: Object.keys(config),
                requestData: requestData
            });
            
            // 发送保存请求
            const response = await fetch('<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(requestData)
            });
            
            const result = await response.json();
            
            console.log('✅ 批量保存完成', result);
            
            if (result.success) {
                updateVisualSaveStatus('saved', '<?= __('已保存') ?>');
            } else {
                updateVisualSaveStatus('error', '<?= __('保存失败') ?>: ' + result.message);
                console.error('❌ 保存失败:', result);
            }
        } catch (error) {
            updateVisualSaveStatus('error', '<?= __('保存失败') ?>');
            console.error('保存异常:', error);
        }
    };

    // 自动保存配置
    function autoSaveVisualConfig() {
        // 如果正在进行批量操作，跳过自动保存
        if (window.isBatchResetting) {
            console.log('⏸️ 批量操作中，跳过自动保存');
            return;
        }
        
        // 清除之前的定时器
        if (visualAutoSaveTimer) {
            clearTimeout(visualAutoSaveTimer);
        }
        
        // 设置新的定时器
        visualAutoSaveTimer = setTimeout(async () => {
            updateVisualSaveStatus('saving', '<?= __('保存中...') ?>');
            
            try {
                // 收集所有配置
                const config = {};
                document.querySelectorAll('#visualConfigFields .auto-save-field').forEach(field => {
                    const key = field.getAttribute('data-config-key');
                    config[key] = field.value;
                });
                
                // 准备请求数据（包含样式代码和语言参数）
                const styleCode = '<?= $page && $page->getData('style') ? $page->getData('style') : 'default' ?>';
                const requestData = {
                    page_id: visualPageId,
                    style_code: styleCode, // 添加样式代码
                    style_config: config,
                    locale: currentVisualLanguage || defaultLanguage // 添加语言参数
                };
                
                console.log('💾 自动保存配置', {
                    url: '<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>',
                    pageId: visualPageId,
                    styleCode: styleCode,
                    locale: currentVisualLanguage,
                    configKeys: Object.keys(config),
                    requestData: requestData
                });
                
                // 发送保存请求
                const response = await fetch('<?= $this->getBackendUrl('cms/backend/preview/autoSave') ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(requestData)
                });
                
                const result = await response.json();
                
                console.log('✅ 保存响应', {
                    success: result.success,
                    message: result.message,
                    debug: result.debug,
                    fullResult: result
                });
                
                if (result.success) {
                    updateVisualSaveStatus('saved', '<?= __('已保存') ?>');
                    
                    // 自动刷新预览
                    refreshVisualPreview();
                } else {
                    updateVisualSaveStatus('error', '<?= __('保存失败') ?>: ' + result.message);
                    console.error('❌ 保存失败:', result);
                }
            } catch (error) {
                updateVisualSaveStatus('error', '<?= __('保存失败') ?>');
                console.error('保存异常:', error);
            }
        }, VISUAL_AUTO_SAVE_DELAY);
    }

