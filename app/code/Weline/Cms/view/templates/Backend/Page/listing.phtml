<script>
(function () {
    function initCmsListingCollapse(attempt) {
        var root = document.querySelector('.cms-page-listing');
        if (!root) {
            if ((attempt || 0) < 20) {
                setTimeout(function () {
                    initCmsListingCollapse((attempt || 0) + 1);
                }, 50);
            }
            return;
        }
        if (root.getAttribute('data-cms-collapse-ready') === '1') {
            return;
        }
        root.setAttribute('data-cms-collapse-ready', '1');

        var storageKey = 'weline.cms.pageListing.collapse.v2';
        var state = {};

        try {
            state = JSON.parse(localStorage.getItem(storageKey) || '{}') || {};
        } catch (error) {
            state = {};
        }

        function persist() {
            try {
                localStorage.setItem(storageKey, JSON.stringify(state));
            } catch (error) {
                // Ignore private-mode or quota failures; collapse still works for this page load.
            }
        }

        function setExpanded(toggle, expanded, shouldPersist) {
            var key = toggle.getAttribute('data-cms-collapse-key') || '';
            var targetId = toggle.getAttribute('data-cms-collapse-target') || '';
            var panel = targetId ? document.getElementById(targetId) : null;
            var item = toggle.closest('[data-cms-collapse-item]');
            if (!key || !panel) {
                return;
            }

            toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            panel.hidden = !expanded;
            if (item) {
                item.classList.toggle('is-collapsed', !expanded);
            }

            if (shouldPersist) {
                var defaultExpanded = toggle.getAttribute('data-cms-collapse-default') === 'expanded';
                if (expanded === defaultExpanded) {
                    delete state[key];
                } else {
                    state[key] = expanded;
                }
                persist();
            }
        }

        root.querySelectorAll('[data-cms-collapse-toggle]').forEach(function (toggle) {
            var key = toggle.getAttribute('data-cms-collapse-key') || '';
            var defaultExpanded = toggle.getAttribute('data-cms-collapse-default') === 'expanded';
            var hasSavedState = Object.prototype.hasOwnProperty.call(state, key);
            var item = toggle.closest('[data-cms-collapse-item]');
            var forceExpanded = item && item.getAttribute('data-cms-force-expanded') === '1';
            setExpanded(toggle, forceExpanded ? true : (hasSavedState ? state[key] === true : defaultExpanded), false);
            toggle.addEventListener('click', function () {
                setExpanded(toggle, toggle.getAttribute('aria-expanded') !== 'true', true);
            });
        });
    }

    function cleanupCopyParams(keys) {
        try {
            var url = new URL(window.location.href);
            keys.forEach(function (key) {
                url.searchParams.delete(key);
            });
            window.history.replaceState({}, document.title, url.toString());
        } catch (error) {
            // URL cleanup is cosmetic; leave the page behavior intact if history is unavailable.
        }
    }

    function initCmsCopyFeedback(attempt) {
        var root = document.querySelector('.cms-page-listing');
        if (!root) {
            if ((attempt || 0) < 20) {
                setTimeout(function () {
                    initCmsCopyFeedback((attempt || 0) + 1);
                }, 50);
            }
            return;
        }
        if (root.getAttribute('data-cms-copy-feedback-ready') === '1') {
            return;
        }
        root.setAttribute('data-cms-copy-feedback-ready', '1');

        var noticeKeys = [
            'copy_notice',
            'copy_target_website_id',
            'copy_target_website_code',
            'copy_target_label',
            'copy_target_path_group',
            'copy_target_page_id',
            'copy_target_title',
            'copy_target_identifier',
            'copy_target_page_count',
            'copy_theme_partial'
        ];
        root.querySelectorAll('[data-cms-copy-notice-close]').forEach(function (button) {
            button.addEventListener('click', function () {
                var notice = button.closest('[data-cms-copy-notice]');
                if (notice) {
                    notice.remove();
                }
                cleanupCopyParams(noticeKeys);
            });
        });

        var highlights = Array.prototype.slice.call(root.querySelectorAll('.cms-copy-highlight'));
        if (highlights.length > 0) {
            setTimeout(function () {
                highlights[0].scrollIntoView({ block: 'center', behavior: 'smooth' });
            }, 80);
            setTimeout(function () {
                highlights.forEach(function (item) {
                    item.classList.remove('cms-copy-highlight');
                });
                cleanupCopyParams([
                    'copy_highlight',
                    'copy_highlight_website_id',
                    'copy_highlight_website_code',
                    'copy_highlight_path_group',
                    'copy_highlight_page_id'
                ]);
            }, 10000);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
            initCmsListingCollapse(0);
            initCmsCopyFeedback(0);
        });
    } else {
        initCmsListingCollapse(0);
        initCmsCopyFeedback(0);
    }
})();
</script>
