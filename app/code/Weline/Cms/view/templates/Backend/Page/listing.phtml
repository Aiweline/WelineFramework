/**
 * @var \Weline\Framework\View\Template $this
 */
$siteGroups = $this->getData('site_groups') ?: [];
$pagination = $this->getData('pagination');
$search = (string)($this->getData('search') ?: '');
$status = (string)($this->getData('status') ?: '');
$scope = (string)($this->getData('scope') ?: '');
$websiteIdFilter = (string)($this->getData('website_id') ?: '');
$pathGroupFilter = (string)($this->getData('path_group') ?: '');
$websites = $this->getData('websites') ?: [];
$copyNoticeData = $this->getData('copy_notice');
$copyHighlightData = $this->getData('copy_highlight');
$copyNotice = is_array($copyNoticeData) ? $copyNoticeData : [];
$copyHighlight = is_array($copyHighlightData) ? $copyHighlightData : [];
$highlightType = (string)($copyHighlight['type'] ?? '');
$highlightWebsiteId = (int)($copyHighlight['website_id'] ?? 0);
$highlightWebsiteCode = (string)($copyHighlight['website_code'] ?? '');
$highlightPathGroup = (string)($copyHighlight['path_group'] ?? '');
$highlightPageId = (int)($copyHighlight['page_id'] ?? 0);
$statusLabels = [
    'draft' => __('草稿'),
    'published' => __('已发布'),
    'disabled' => __('已禁用'),
];
$websiteOptionValue = static function (array $website): string {
    $websiteId = (int)($website['website_id'] ?? $website['id'] ?? 0);
    $websiteCode = (string)($website['code'] ?? $website['website_code'] ?? 'default');
    return $websiteId . '|' . $websiteCode;
};
$isSourceWebsite = static function (array $website, int $sourceWebsiteId, string $sourceWebsiteCode): bool {
    $websiteId = (int)($website['website_id'] ?? $website['id'] ?? 0);
    $websiteCode = (string)($website['code'] ?? $website['website_code'] ?? 'default');
    if ($sourceWebsiteId > 0 && $websiteId > 0) {
        return $sourceWebsiteId === $websiteId;
    }
    return strcasecmp($sourceWebsiteCode, $websiteCode) === 0;
};
$matchesHighlightedSite = static function (int $websiteId, string $websiteCode) use ($highlightWebsiteId, $highlightWebsiteCode): bool {
    if ($highlightWebsiteId > 0 && $websiteId > 0) {
        return $highlightWebsiteId === $websiteId;
    }
    if ($highlightWebsiteCode !== '') {
        return strcasecmp($highlightWebsiteCode, $websiteCode) === 0;
    }
    return false;
};
