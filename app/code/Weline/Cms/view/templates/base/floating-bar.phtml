<?php
/**
 * 通用悬浮 Bar 组件
 * 包含 YouTube 和 WhatsApp 两个社交按钮
 * 在手机端悬浮在页面底部，桌面端隐藏或显示在底部
 * 
 * @var \Weline\Framework\View\Template $this
 * 
 * 使用说明：
 * 1. 在 footer.phtml 中引入：Weline_Cms::base/floating-bar.phtml
 * 2. 需要在 footer 配置中添加：
 *    - footer.youtube_url => YouTube 链接地址
 *    - footer.whatsapp_url => WhatsApp 链接地址
 *    - footer.youtube_event_name => YouTube 按钮事件名称（可选）
 *    - footer.whatsapp_event_name => WhatsApp 按钮事件名称（可选）
 *    - footer.floating_bar_enabled => 是否显示悬浮栏:bool:1（1 显示，0 隐藏）
 * 3. 组件会自动检测统计平台 ID，如果存在则提交事件（通过统一的 tracking.phtml 处理）
 */

// 引入 tracking.phtml 以获取统一的事件处理函数
$page = $this->getData('page');
$styleSettings = $this->getData('style') ?: $this->getData('style_settings') ?: [];

// 确保 styleSettings 是数组
if (!is_array($styleSettings)) {
    $styleSettings = [];
}

// 确保 tracking.phtml 已加载（如果 header 中已引入，这里不会重复加载）
// 统一的事件处理逻辑在 tracking.phtml 中通过事件委托自动处理所有带有 data-handle 属性的元素

// Helper function
if (!function_exists('getConfig')) {
    function getConfig($settings, $key, $default = '') {
        if (!is_array($settings)) {
            return $default;
        }
        return $settings[$key] ?? $default;
    }
}

// 获取配置
$youtubeUrl = trim((string)getConfig($styleSettings, 'footer.youtube_url', ''));
$whatsappUrl = trim((string)getConfig($styleSettings, 'footer.whatsapp_url', ''));
$floatingEnabledRaw = getConfig($styleSettings, 'footer.floating_bar_enabled', '1');
$floatingEnabled = !in_array((string)$floatingEnabledRaw, ['0', 'false', 'False', 'FALSE'], true);
$youtubeEventName = trim(getConfig($styleSettings, 'footer.youtube_event_name', ''));
$whatsappEventName = trim(getConfig($styleSettings, 'footer.whatsapp_event_name', ''));

// 获取页面 handle 用于默认事件名
$pageHandleForEvent = $page ? preg_replace('/[^a-zA-Z0-9_-]+/', '-', (string)$page->getData('handle')) : '';
$pageDefaultCtaEvent = $page ? trim((string)$page->getData('cta_event_name')) : '';

// 生成默认事件名
if (empty($youtubeEventName)) {
    if ($pageDefaultCtaEvent !== '') {
        $youtubeEventName = $pageDefaultCtaEvent;
    } else {
        $youtubeEventName = 'youtube_button_' . $pageHandleForEvent . '_click';
    }
}

if (empty($whatsappEventName)) {
    if ($pageDefaultCtaEvent !== '') {
        $whatsappEventName = $pageDefaultCtaEvent;
    } else {
        $whatsappEventName = 'whatsapp_button_' . $pageHandleForEvent . '_click';
    }
}

?>

