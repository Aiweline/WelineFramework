    /* 版心容器：限制最大宽度，内容居中 */
    .floating-social-bar-container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    /* 内层容器：版心 80% */
    .floating-social-bar-inner {
        width: 80%;
