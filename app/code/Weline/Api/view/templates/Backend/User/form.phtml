<js:part>
<script>
(function() {
    'use strict';
    
    window.ApiUserForm = {
        copyToClipboard: function(input) {
            input.select();
            document.execCommand('copy');
            if (typeof BackendToast !== 'undefined') {
                BackendToast.success('<?= __('已复制到剪贴板') ?>');
            }
        }
    };

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-api-user-action="copy"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        var target = document.getElementById(trigger.getAttribute('data-api-user-target') || '');
        if (target) {
            window.ApiUserForm.copyToClipboard(target);
        }
    });
})();
</script>
</js:part>
