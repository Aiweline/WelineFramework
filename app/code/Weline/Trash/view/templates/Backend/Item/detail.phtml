<?php
/**
 * @var \Weline\Framework\View\Template $this
 */
$item = $this->getData('item') ?: [];
$esc = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$json = static function (mixed $value): string {
    $encoded = json_encode(
        $value,
        JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE
    );
    return htmlspecialchars((string)($encoded ?: ''), ENT_QUOTES, 'UTF-8');
};
$trashId = (int)($item['trash_id'] ?? 0);
$status = (string)($item['status'] ?? '');
$open = in_array($status, ['active', 'restore_failed', 'purge_failed'], true);
$statusLabels = [
    'active' => __('待恢复'),
    'restore_failed' => __('恢复失败'),
    'purge_failed' => __('清理失败'),
    'restored' => __('已恢复'),
    'purged' => __('已清理'),
];
?>
