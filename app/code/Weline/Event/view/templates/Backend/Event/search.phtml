                                <div class="match-reasons">
                                    <?php
                                    $matchReasons = $eventInfo['match_reasons'] ?? [];
                                    foreach ($matchReasons as $reason):
                                    ?>
                                        <span class="badge badge-success"><?= htmlspecialchars($reason) ?></span>
                                    <?php endforeach; ?>
                                </div>
                            </td>
                            <td>
                                <div class="event-observers">
                                    <?php
                                    $observerCount = $eventInfo['observer_count'] ?? 0;
                                    ?>
                                    <?php if ($observerCount > 0): ?>
                                        <span class="badge badge-primary">
                                            <i class="mdi mdi-eye"></i> <?= $observerCount ?> 个
                                        </span>
                                    <?php else: ?>
                                        <span class="text-muted">无</span>
                                    <?php endif; ?>
                                </div>
                            </td>
                            <td>
                                <div class="actions">
                                    <a href="*/backend/event/detail/event/<?= urlencode($eventName) ?>" 
                                       class="btn btn-sm btn-outline-primary" title="查看详情">
                                        <i class="mdi mdi-eye"></i> 详情
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
