    <?php if (empty($searchTerm)): ?>
        <div class="empty-state">
            <i class="mdi mdi-magnify"></i>
            <h3>请输入搜索关键词</h3>
            <p>在搜索框中输入关键词，然后点击搜索按钮。</p>
        </div>
    <?php elseif (empty($results)): ?>
        <div class="empty-state">
            <i class="mdi mdi-magnify-close"></i>
            <h3>未找到匹配的事件</h3>
            <p>没有找到与 "<strong><?= htmlspecialchars($searchTerm) ?></strong>" 匹配的事件。</p>
            <p>请尝试使用其他关键词或搜索类型。</p>
        </div>
    <?php else: ?>
        <div class="results-header">
            <h3>找到 <?= count($results) ?> 个匹配的事件</h3>
            <p>搜索关键词: "<strong><?= htmlspecialchars($searchTerm) ?></strong>"</p>
