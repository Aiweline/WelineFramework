                                    <div class="event-description">
                                        <small class="text-muted"><?= htmlspecialchars(mb_substr($eventInfo['description'] ?? '', 0, 80)) ?><?= mb_strlen($eventInfo['description'] ?? '') > 80 ? '...' : '' ?></small>
                                    </div>
                                <?php endif; ?>
                            </td>
                            <td>
                                <div class="event-module">
                                    <span class="badge badge-info"><?= htmlspecialchars($eventInfo['module'] ?? '') ?></span>
                                </div>
